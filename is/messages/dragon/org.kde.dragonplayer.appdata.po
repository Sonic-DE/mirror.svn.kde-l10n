#. (itstool) path: component/name
#: org.kde.dragonplayer.appdata.xml:9
msgid "Dragon Player"
msgstr "Dragon-spilari"

#. (itstool) path: component/summary
#: org.kde.dragonplayer.appdata.xml:10
msgid "Play video files and streams"
msgstr "Spilaðu myndskeiðaskrár og myndstreymi"

#. (itstool) path: description/p
#: org.kde.dragonplayer.appdata.xml:12
msgid ""
"Dragon Player is a video player focusing on simplicity instead of features. "
"Its easy-to-use interface is designed to get out of your way and simply play "
"your video files and streams."
msgstr ""
"Dragon spilarinn er margmiðlunarspilari þar sem áhersla er lögð á "
"einfaldleika frekar en eiginleika. Einfalt notandaviðmótið flækist ekki "
"fyrir og gerir þér kleift að spila einfaldlega margmiðlunarskrár og "
"myndstreymi."

#. (itstool) path: description/p
#: org.kde.dragonplayer.appdata.xml:15
msgid "Features:"
msgstr "Eiginleikar:"

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:17
msgid ""
"Click to play or pause, and double-click to enter or exit full screen mode."
msgstr ""
"Smelltu til að spila eða setja í bið og tvísmelltu til að fara í eða úr "
"skjáfylliham."

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:18
msgid ""
"Choose the subtitle language, and automatically load the right one for your "
"language, if possible."
msgstr ""
"Veldu tungumál skjátexta og náðu sjálfvirkt í rétta skjátextann fyrir "
"tungumálið þitt, ef mögulegt er."

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:19
msgid "Choose the audio track."
msgstr "Veldu hljóðrás."

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:20
msgid "Choose the video track."
msgstr "Veldu myndspor"

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:21
msgid "Adjust the volume by scrolling."
msgstr "Aðlagaðu hljóðstyrk með því að skruna"

#~ msgid "Video player with focus on simplicity"
#~ msgstr "Myndspilari með áherslu á einfaldleika"

#~ msgid "Simple Interface"
#~ msgstr "Einfalt notandaviðmót"

#~ msgid ""
#~ "Resuming videos: Starts playing a video where you were watching it last "
#~ "time"
#~ msgstr ""
#~ "Halda áfram afspilun: Heldur áfram með myndskeið þar sem þú hættir síðast"

#~ msgid ""
#~ "Support for subtitles: Automatically loads subtitles with the matching "
#~ "name"
#~ msgstr ""
#~ "Stuðningur við skjátexta (þýðingar): Hleður sjálfkrafa inn skjátextaskrám "
#~ "með samsvarandi heitum"

#~ msgid "Video display settings (brightness, contrast)"
#~ msgstr "Stillingar á birtingu myndmerkis (birtustig, birtuskil)"

#~ msgid ""
#~ "Due to using Solid and Phonon DragonPlayer is independent of any "
#~ "multimedia framework or hardware abstraction layer"
#~ msgstr ""
#~ "Þar sem Dragon notar Solid og Phonon, er hann ekki háður neinu "
#~ "margmiðlunarkerfi eða vélbúnaðarhjúpun (hardware abstraction layer)."

#~ msgid "Supports playing CDs and DVDs"
#~ msgstr "Styður afspilun CD og DVD-diska"
