#. (itstool) path: component/summary
#: org.kde.kdf.appdata.xml:10
msgid "View Disk Usage"
msgstr "Skoða nýtni á diskum"

#. (itstool) path: description/p
#: org.kde.kdf.appdata.xml:12
msgid ""
"KDiskFree displays the available file devices (hard drive partitions, floppy "
"and CD drives, etc.) along with information on their capacity, free space, "
"type and mount point. It also allows you to mount and unmount drives and "
"view them in a file manager."
msgstr ""
"KDiskFree birtir tiltæk skráatæki (disksneiðar á hörðum diskum, disklingum "
"og CD-drifum, o.s.frv.) ásamt upplýsingum um rýmd þeirra, laust pláss, "
"tegund og tengipunkt. Það gerir einnig kleift að tengja drif í skráakerfi "
"eða aftengja og að skoða þau í skráastjóra."

