#. (itstool) path: component/name
#: org.kde.ark.appdata.xml:11
msgid "Ark"
msgstr "Ark"

#. (itstool) path: component/summary
#: org.kde.ark.appdata.xml:12
msgid "Archiving Tool"
msgstr "Safnskráaverkfæri"

#. (itstool) path: description/p
#: org.kde.ark.appdata.xml:14
msgid ""
"Ark is a graphical file compression/decompression utility with support for "
"multiple formats, including tar, gzip, bzip2, rar and zip, as well as CD-ROM "
"images. Ark can be used to browse, extract, create, and modify archives."
msgstr ""
"Ark er myndrænt þjöppunar-/afþjöppunarforrit sem styður "
"fjölmörgþjöppunarsnið, þ.á m. tar, gzip, bzip2, rar og zip, auk CD-ROM "
"diskmynda. Ark má nota til að skoða, afþjappa, búa til og breyta safnskrám."

#. (itstool) path: description/p
#: org.kde.ark.appdata.xml:19
msgid "Features:"
msgstr "Eiginleikar:"

#. (itstool) path: ul/li
#: org.kde.ark.appdata.xml:21
msgid "Several formats supported: gzip, bzip2, zip, rar, 7z and more"
msgstr "Stuðningur við fjölmörg skráasnið: gzip, bzip2, zip, rar, 7z og fleiri"

#. (itstool) path: ul/li
#: org.kde.ark.appdata.xml:22
msgid "Preview file contents without extracting files"
msgstr "Forskoðun á innihaldi skráa án þess að afþjappa skrám"

#. (itstool) path: screenshot/caption
