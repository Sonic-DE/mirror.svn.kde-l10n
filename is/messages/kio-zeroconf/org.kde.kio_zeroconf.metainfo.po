#. (itstool) path: component/name
#: org.kde.kio_zeroconf.metainfo.xml:9
msgid "Zeroconf Support"
msgstr "Stuðningur við Zeroconf"

#. (itstool) path: component/summary
#: org.kde.kio_zeroconf.metainfo.xml:10
msgid "Browse local network services in Dolphin's Network page"
msgstr "Flakka um þjónustur staðarnets í netkerfissíðu Dolphin"

#. (itstool) path: description/p
#: org.kde.kio_zeroconf.metainfo.xml:12
msgid ""
"Adds an entry to Dolphin's Network page to show local services such as "
"printers which advertise themselves with DNSSD (called Avahi or Bonjour by "
"other projects)."
msgstr ""
"Bætir færslu á síðuna 'Netkerfi' í Dolphin svo hægt sé að birta þjónustur á "
"staðarnetinu, eins og t.d. prentara, sem auglýsa sig með DNSSD (kallast líka "
"Avahi eða Bonjour í öðrum hugbúnaði)."
