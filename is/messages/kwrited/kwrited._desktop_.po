#: kwrited-autostart.desktop:2
msgctxt "Name"
msgid "KDE Write Daemon"
msgstr "KDE skriftarpúki"

#: kwrited-autostart.desktop:91
msgctxt "Comment"
msgid "Watch for messages from local users sent with write(1) or wall(1)"
msgstr ""
"Fylgjast með skilaboðum frá notendum sem senda með write(1) eða wall(1)"

#: kwrited.notifyrc:3
msgctxt "Name"
msgid "Local System Message Service"
msgstr "Staðvær kerfisskilaboðaþjónusta"

#: kwrited.notifyrc:48
msgctxt "Comment"
msgid "Local system message service"
msgstr "Staðvær kerfisskilaboðaþjónusta"

#: kwrited.notifyrc:117
msgctxt "Name"
msgid "New message received"
msgstr "Nýtt skeyti hefur borist"

#: kwrited.notifyrc:192
msgctxt "Comment"
msgid "The daemon received a new message sent with wall(1) or write(1)"
msgstr "Þjónninn tók við nýju skeyti sem sent var með wall(1) eða write(1)"

#~ msgctxt "Name"
#~ msgid "Write Daemon"
