#: src/android_defaults.notifyrc:2
msgctxt "Name"
msgid "Fatal Error"
msgstr "Banvæn villa"

#: src/android_defaults.notifyrc:61
msgctxt "Comment"
msgid "There was a serious error causing the program to exit"
msgstr "Alvarleg villa átti sér stað sem olli því að forritið slökkti á sér"

#: src/android_defaults.notifyrc:122
msgctxt "Name"
msgid "Notification"
msgstr "Tilkynning"

#: src/android_defaults.notifyrc:180
msgctxt "Comment"
msgid "Something special happened in the program"
msgstr "Eitthvað sérstakt gerðist í keyrslu forritsins"

#: src/android_defaults.notifyrc:240
msgctxt "Name"
msgid "Warning"
msgstr "Aðvörun"

#: src/android_defaults.notifyrc:298
msgctxt "Comment"
msgid "There was an error in the program which may cause problems"
msgstr "Villa kom upp í forritinu sem valdið vandamálum"

#: src/android_defaults.notifyrc:358
msgctxt "Name"
msgid "Catastrophe"
msgstr "Hörmungarástand"

#: src/android_defaults.notifyrc:415
msgctxt "Comment"
msgid "A very serious error occurred, at least causing the program to exit"
msgstr ""
"Mjög alvarleg villa átti sér stað, a.m.k. næg til að forritið slökkti á sér"
