msgctxt "Name"
msgid "Capture Entire Desktop"
msgstr "Taka mynd af öllu skjáborðinu"

#: desktop/org.kde.spectacle.desktop.cmake:264
msgctxt "Name"
msgid "Capture Current Monitor"
msgstr "Taka mynd af þessum skjá"

#: desktop/org.kde.spectacle.desktop.cmake:322
msgctxt "Name"
msgid "Capture Active Window"
msgstr "Taka mynd af virkum glugga"

#: desktop/org.kde.spectacle.desktop.cmake:380
msgctxt "Name"
msgid "Capture Rectangular Region"
msgstr "Taka mynd af rétthyrndu svæði"

#: desktop/org.kde.spectacle.desktop.cmake:438
msgctxt "Name"
msgid "Capture Window Under Cursor"
msgstr "Taka mynd af glugga undir bendli"

#: desktop/org.kde.spectacle.desktop.cmake:491
