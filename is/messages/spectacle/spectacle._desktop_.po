msgid "Start/Stop Screen Recording"
msgstr "Hefja/Stöðva upptöku á skjá"

#: desktop/org.kde.spectacle.desktop.cmake:571
msgctxt "Name"
msgid "Start/Stop Window Recording"
msgstr "Hefja/Stöðva upptöku á glugga"

#: desktop/org.kde.spectacle.desktop.cmake:611
msgctxt "Name"
msgid "Launch without taking a screenshot"
msgstr "Keyra án þess að taka skjámynd"

#: desktop/spectacle.notifyrc:57
msgctxt "Comment"
msgid "Screenshot Capture Utility"
msgstr "Skjámyndaforrit"

#: desktop/spectacle.notifyrc:113
