#. (itstool) path: component/name
#: org.kde.kolourpaint.appdata.xml:10
msgid "KolourPaint"
msgstr "KolourPaint"

#. (itstool) path: component/summary
#: org.kde.kolourpaint.appdata.xml:11
msgid "Paint Program"
msgstr "Myndmálunarforrit"

#. (itstool) path: description/p
#: org.kde.kolourpaint.appdata.xml:13
msgid ""
"KolourPaint is a simple painting program to quickly create raster images. It "
"is useful as a touch-up tool and for simple image editing tasks."
msgstr ""
"KolourPaint er einfalt myndmálunarforrit sem gefur kost á að útbúa "
"rastamyndir í snatri. Það nýtist vel í einfaldar lagfæringar og minni háttar "
"myndvinnsluaðgerðir."

#. (itstool) path: description/p
#: org.kde.kolourpaint.appdata.xml:17
msgid "Features:"
msgstr "Eiginleikar:"

#. (itstool) path: ul/li
#: org.kde.kolourpaint.appdata.xml:19
msgid ""
"Support for drawing various shapes - lines, rectangles, rounded rectangles, "
"ovals and polygons"
msgstr ""
"Stuðningur við að teikna ýmis form - línur, rétthyrninga, rúnnaða "
"rétthyrninga, sporöskjur og marghyrninga"

#. (itstool) path: ul/li
#: org.kde.kolourpaint.appdata.xml:20
msgid "Curves, lines and text"
msgstr "Ferlar, línur og texti"

#. (itstool) path: ul/li
#: org.kde.kolourpaint.appdata.xml:21
msgid "Color picker"
msgstr "Litplokkari"

#. (itstool) path: ul/li
#: org.kde.kolourpaint.appdata.xml:22
