#. (itstool) path: component/name
#: org.kde.krdc.appdata.xml:4
msgid "KRDC"
msgstr "KRDC"

#. (itstool) path: component/summary
#: org.kde.krdc.appdata.xml:5
msgid "Connect with RDP or VNC to another computer"
msgstr "Tengstu með RDP eða VNC við aðrar tölvur"

#. (itstool) path: description/p
#: org.kde.krdc.appdata.xml:11
msgid ""
"KRDC is a client application that allows you to view or even control the "
"desktop session on another machine that is running a compatible server. VNC "
"and RDP is supported."
msgstr ""
"KRDC er biðlaraforrit sem gerir þér kleift að skoða og jafnvel stýra "
"skjáborðssetum á öðrum tölvum sem keyra sambærilegan þjón. VNC og RDP eru "
"studdir samskiptamátar."
