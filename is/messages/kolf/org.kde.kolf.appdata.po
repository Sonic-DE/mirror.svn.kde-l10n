msgid "Kolf"
msgstr "Kolf"

#. (itstool) path: component/summary
#: org.kde.kolf.appdata.xml:10
msgid "Miniature Golf"
msgstr "Mínígolf"

#. (itstool) path: description/p
#: org.kde.kolf.appdata.xml:12
msgid ""
"Kolf is a miniature golf game. The game is played from an overhead view, "
"with a short bar representing the golf club. Kolf features many different "
"types of objects, such water hazards, slopes, sand traps, and black holes "
"(warps), among others."
msgstr ""
"Kolf er mínígolf-leikur. Leikurinn er spilaður í yfirlitssýn með stuttri slá "
"sem táknar golfkylfuna. Kolf inniheldur margar mismunandi gerðir hluta, á "
"borð við tjarnir, fláa, glompur og svarthol (ormagöng), auk annars."

