#. (itstool) path: component/name
#: org.kde.plasma-welcome.appdata.xml:14
msgid "Welcome Center"
msgstr "Kynningarmiðstöð"

#. (itstool) path: component/summary
#: org.kde.plasma-welcome.appdata.xml:15
msgid "Learn more about KDE Plasma"
msgstr "Læra meira um KDE Plasma"

#. (itstool) path: description/p
#: org.kde.plasma-welcome.appdata.xml:17
msgid ""
"Welcome Center is the perfect introduction to KDE Plasma! It can help you "
"learn how to connect to the internet, install apps, customize the system, "
"and more!"
msgstr ""
"Kynningarmiðstöðin er tilvalin kynning á KDE Plasma! Hún getur sýnt þér "
"hvernig hægt er að tengjast netinu, setja upp forrit, sérsníða tölvuna og "
"fleira!"

#. (itstool) path: screenshot/caption
#: org.kde.plasma-welcome.appdata.xml:22
msgid "Welcome Center first page: introducing KDE Plasma"
msgstr "Kynningarmiðstöð, fyrsta síða: við kynnum KDE Plasma"

#. (itstool) path: screenshot/caption
#: org.kde.plasma-welcome.appdata.xml:26
msgid "Welcome Center second page: how to install apps"
msgstr "Kynningarmiðstöð, önnur síða: hvernig á að setja upp forrit"

#. (itstool) path: screenshot/caption
#: org.kde.plasma-welcome.appdata.xml:30
msgid "Welcome Center sixth page: how to get involved"
msgstr "Kynningarmiðstöð, sjötta síða: hvernig hægt er að taka þátt"

#~ msgid "Friendly onboarding wizard for Plasma"
#~ msgstr "Vinalegt kynningarforrit fyrir Plasma"
