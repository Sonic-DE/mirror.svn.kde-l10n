msgid "Monitor app and system resource usage"
msgstr "Vakta notkun á tilföngum forrita og kerfis"

#. (itstool) path: description/p
#: org.kde.plasma-systemmonitor.metainfo.xml:13
msgid ""
"Plasma System Monitor provides an interface for monitoring system sensors, "
"process information and other system resources."
msgstr ""
"Plasma Kerfiseftirlit býður upp á viðmót til að fylgjast með skynjurum "
"kerfisins, vinna úr upplýsingum og annarri vinnslu í kerfinu."

#~ msgid "An application for monitoring system resources"
#~ msgstr "Forrit til að fylgjast með virkni stýrikerfisins"
