#: org.kde.klimbgrades.appdata.xml:8
msgid "Klimbgrades"
msgstr "Klifurgráður"

#. (itstool) path: component/summary
#: org.kde.klimbgrades.appdata.xml:9
msgid ""
"Quickly convert difficulty grades for rock climbing, lead and bouldering "
"scales"
msgstr ""
"Einfaldaðu umreikning á milli mismunandi erfiðleikastiga fyrir klettaklifur, "
"leiðsluklifur og grjótglímu"

#. (itstool) path: ul/li
#: org.kde.klimbgrades.appdata.xml:12
msgid "Lead: French, YDS, UIAA, British Tech, British Adjectival"
msgstr "Leiðsluklifur: Franskt, YDS, UIAA, breskt Tech, breskt Adjectival"

#. (itstool) path: ul/li
#: org.kde.klimbgrades.appdata.xml:13
msgid "Boulder: Fontainebleu, Hueco, B Grade"
msgstr "Grjótglíma: Fontainebleu, Hueco, B Grade"

#. (itstool) path: description/p
#: org.kde.klimbgrades.appdata.xml:15
msgid ""
"Example application to demonstrate KDE's Kirigami Qt-based framework for "
"building cross-platform applications."
msgstr ""
"Sýniforrit til að kenna hvernig hægt sé að nota Qt-byggða Kirigami kerfið í "
"KDE til að gera forrit á mörgum stýrikerfum."
