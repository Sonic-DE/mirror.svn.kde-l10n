#: org.kde.klimbgrades.desktop:2
msgctxt "Name"
msgid "Klimbgrades"
msgstr "Klifurgráður"

#: org.kde.klimbgrades.desktop:37
msgctxt "Comment"
msgid ""
"Small application to quickly convert difficulty grades for rock climbing, "
"lead and bouldering scales"
msgstr ""
"Lítið forrit til að einfalda umreikning á milli mismunandi erfiðleikastiga "
"fyrir klettaklifur, leiðsluklifur og grjótglímu."
