"os scripts da liña de ordes."

#. Tag: cmdsynopsis
#: advanced.docbook:245
#, no-c-format
msgid "<command>set-mode</command><arg choice=\"req\">STRING mode</arg>"
msgstr "<command>set-indent-mode</command><arg choice=\"req\">CADEA nome</arg>"

#. Tag: para
#: advanced.docbook:246
#, no-c-format
msgid "Choose the filetype scheme for the current document."
msgstr ""
"Definir o modo de edición para o documento actual. O argumento debe ser un "
"modo dos dispoñíbeis no menú <menuchoice><guimenu>Utilidades</"
"guimenu><guisubmenu>Modo</guisubmenu></menuchoice>."

#. Tag: cmdsynopsis
#: advanced.docbook:251
#, no-c-format
msgid ""
"<command>nn[oremap]</command><arg choice=\"req\">STRING original</arg> <arg "
"choice=\"req\">STRING mapped</arg>"
msgstr ""
"<command>nn[oremap]</command><arg choice=\"req\">CADEA orixinal</arg> <arg "
"choice=\"req\">CADEA nova</arg>"

#. Tag: para
#: advanced.docbook:253
#, no-c-format
msgid ""
"Map the key sequence <userinput>original</userinput> to <userinput>mapped</"
"userinput>."
