#, no-c-format
msgid "Isotope Table"
msgstr "Táboa de isótopos"

#. Tag: para
#: index.docbook:510
#, fuzzy, no-c-format
#| msgid ""
#| "The <guimenuitem>Isotope Table...</guimenuitem> shows you the isotopes of "
#| "the elements."
msgid ""
"The <guilabel>Isotope Table</guilabel> shows you the isotopes of the "
"elements."
msgstr ""
"A <guimenuitem>táboa de isótopos…</guimenuitem> mostra os isótopos dos "
