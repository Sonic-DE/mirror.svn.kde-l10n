#. Tag: option
#: index.docbook:3539
#, no-c-format
msgid "--recurrence <replaceable>spec</replaceable>"
msgstr "--recurrence <replaceable>espec</replaceable>"

#. Tag: entry
#: index.docbook:3541
#, no-c-format
msgid ""
"Set the alarm to recur. Specify the recurrence using iCalendar syntax "
"(defined in <ulink url=\"http://www.w3.org/2002/12/cal/rfc2445.html"
"\">RFC2445</ulink>), &eg; <quote>FREQ=MONTHLY;COUNT=4;INTERVAL=3;BYDAY=-1MO</"
"quote>. <option>--until</option> cannot be specified with this option."
msgstr ""
"Configurar a alarma para que se repita. Especificar a repetición usando a "
"sintaxe de iCalendar (definida en <ulink url=\"http://www.w3.org/2002/12/cal/"
"rfc2445.html\">RFC2445</ulink>, &eg; <quote>FREQ=MONTHLY;COUNT=4;INTERVAL=3;"
"BYDAY=-1MO</quote>. Con esta opción non se pode especificar <option>--until</"
"option>."

#. Tag: entry
#: index.docbook:3549
#, no-c-format
msgid ""
"<option>-r</option>, <option>--repeat <replaceable>count</replaceable></"
"option>"
