#. Tag: para
#: index.docbook:26
#, fuzzy, no-c-format
#| msgid ""
#| "In these modules, you can configure various aspects of &konqueror;'s file "
#| "manager functionality."
msgid ""
"In these modules, you can configure various aspects of &konqueror;’s file "
"manager functionality."
msgstr ""
"Nestes módulos pode configurar varios aspectos da funcionalidade de "
"&konqueror; como xestor de ficheiros."

#. Tag: para
#: index.docbook:29
#, fuzzy, no-c-format
#| msgid ""
