#. Tag: refpurpose
#: man-cvslastlog.1.docbook:20
#, no-c-format
msgid "Prints the log entry for the last commit for a file."
msgstr "Amosa a entrada de rexistro da última remisión dun ficheiro."

#. Tag: cmdsynopsis
#: man-cvslastlog.1.docbook:24
#, no-c-format
msgid ""
"<command>cvslastlog</command> <group><option><replaceable>filename</"
"replaceable></option></group>"
msgstr ""
"<command>cvslastlog</command> <group><option><replaceable>ficheiro</"
"replaceable></option></group>"

#. Tag: title
#: man-cvslastlog.1.docbook:32
#, no-c-format
msgid "Description"
msgstr "Descrición"

#. Tag: para
#: man-cvslastlog.1.docbook:34
#, no-c-format
msgid ""
"<command>cvslastlog</command> shows the log associated with the last CVS "
"commit for the given file. It depends on the version of the local file, not "
"the one on the server."
msgstr ""
"<command>cvslastlog</command> amosa o rexistro asociado coa última remisión "
"CVS do ficheiro dado. Depende da versión local do ficheiro, non da do "
"servidor."

#. Tag: para
#: man-cvslastlog.1.docbook:38
#, no-c-format
msgid "This utility is part of the &kde; Software Development Kit."
msgstr ""
"Esta utilidade forma parte do equipamento de desenvolvemento de programas de "
"&kde;."

