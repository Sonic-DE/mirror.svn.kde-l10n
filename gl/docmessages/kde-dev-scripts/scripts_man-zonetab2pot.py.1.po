#. Tag: refpurpose
#: man-zonetab2pot.py.1.docbook:20
#, no-c-format
msgid "Converts a timezone list to a PO file template."
msgstr "Converte unha lista de zonas horarias nun modelo de ficheiro PO."

#. Tag: cmdsynopsis
#: man-zonetab2pot.py.1.docbook:24
#, no-c-format
msgid ""
"<command>zonetab2pot.py</command> <group><option><replaceable>timezone-list</"
"replaceable></option></group>"
msgstr ""
"<command>zonetab2pot.py</command> <group><option><replaceable>lista-de-fusos-"
"horarios</replaceable></option></group>"

#. Tag: title
#: man-zonetab2pot.py.1.docbook:32
#, no-c-format
msgid "Description"
msgstr "Descrición"

#. Tag: para
#: man-zonetab2pot.py.1.docbook:34
#, no-c-format
msgid ""
"<command>zonetab2pot.py</command> reads the timezone list given on the "
"command-line and converts it to a gettext message file (PO-file) template "
"containing the names of the individual timezones."
msgstr ""
"<command>zonetab2pot.py</command> é a lista de zonas horarias dada na liña "
"de ordes e convértea nun ficheiro modelo de mensaxes gettext que contén os "
"nomes de cada zona horaria."

# skip-rule: trasno-file_reverse
#. Tag: para
#: man-zonetab2pot.py.1.docbook:39
#, no-c-format
msgid ""
"The given timezone list should be in the same format as the system zone.tab. "
"If no timezone list is specified on the command-line, <filename>/usr/share/"
"zoneinfo/zone.tab</filename> will be used."
msgstr ""
"A lista de zonas horarias resultantes debe ter o mesmo formato que o "
"ficheiro zone.tab do sistema. Se non se indica ningunha lista de zonas "
"horarias na liña de ordes, será usara <filename>/usr/share/zoneinfo/zone."
"tab</filename>."

#. Tag: para
#: man-zonetab2pot.py.1.docbook:43
#, no-c-format
msgid "The new PO-file template will be written to standard output."
msgstr "O novo ficheiro modelo será escrito na saída estándar."

#. Tag: para
#: man-zonetab2pot.py.1.docbook:45
#, no-c-format
msgid "This utility is part of the KDE Software Development Kit."
msgstr ""
"Esta utilidade forma parte do equipamento de desenvolvemento de programas de "
"KDE."

