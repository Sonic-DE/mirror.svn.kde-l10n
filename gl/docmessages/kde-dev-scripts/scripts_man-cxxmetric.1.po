"<command>cxxmetric</command> <group><option><replaceable>ficheiro</"
"replaceable></option></group>"

#. Tag: title
#: man-cxxmetric.1.docbook:33
#, no-c-format
msgid "Description"
msgstr "Descrición"

#. Tag: para
#: man-cxxmetric.1.docbook:35
#, no-c-format
msgid ""
"cxxmetric counts lines of code, comment and blank space and calculates "
"various other statistics for each given source file. Source files must be in "
"C or C++."
msgstr ""
"cxxmetric conta liñas de código, comentarios e espazo en branco e calcula "
"outras variábeis estatísticas para cada ficheiro de fontes dado. Os "
"ficheiros de fontes deben estar escritos en C ou C++."

#. Tag: para
#: man-cxxmetric.1.docbook:39
#, no-c-format
msgid "This utility is part of the KDE Software Development Kit."
msgstr ""
"Esta utilidade forma parte do equipamento de desenvolvemento de programas de "
"KDE."

