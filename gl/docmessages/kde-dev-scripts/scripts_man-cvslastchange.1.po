#. Tag: cmdsynopsis
#: man-cvslastchange.1.docbook:26
#, no-c-format
msgid "&cvslastchange; <group><replaceable>file</replaceable></group>"
msgstr "&cvslastchange; <group><replaceable>ficheiro</replaceable></group>"

#. Tag: title
#: man-cvslastchange.1.docbook:33
#, no-c-format
msgid "Description"
msgstr "Descrición"

#. Tag: para
#: man-cvslastchange.1.docbook:35
#, no-c-format
msgid ""
"&cvslastchange; displays the last change committed to &CVS; for a file. It "
"uses <command>cvs diff</command> and <command>cvs log</command> to do this."
msgstr ""
"&cvslastchange; amosa o último cambio remitido a &CVS; que afecta a un "
"ficheiro. Usa <command>cvs diff</command> e <command>cvs log</command>."

#. Tag: para
#: man-cvslastchange.1.docbook:39
#, no-c-format
msgid "&cvslastchange; works on any &CVS; branch, not just HEAD."
msgstr ""
"&cvslastchange; traballa sobre calquera rama do &CVS;, non só sobre HEAD."

#. Tag: para
#: man-cvslastchange.1.docbook:41
#, no-c-format
msgid "This utility is part of the &kde; Software Development Kit."
msgstr ""
"Esta utilidade forma parte do equipamento de desenvolvemento de programas de "
"&kde;."

