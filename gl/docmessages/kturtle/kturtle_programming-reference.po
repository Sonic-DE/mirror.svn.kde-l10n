"step <link linkend=\"number\">number</link> { ... }"
msgstr ""
"desde <link linkend=\"assignment-of-variables\">variábel</link> = <link "
"linkend=\"number\">número</link> ate <link linkend=\"number\">número</link> "
"pasando <link linkend=\"number\">número</link> { ... }"

