#. Tag: title
#: getting-started.docbook:2
#, no-c-format
msgid "Getting Started"
msgstr "Comezando"

#. Tag: para
#: getting-started.docbook:3
#, no-c-format
msgid "When you start &kturtle; you will see something like this:"
msgstr ""

#. Tag: screeninfo
#: getting-started.docbook:5
#, no-c-format
msgid "Here is a screenshot of &kturtle; when you start it for the first time"
msgstr ""

#. Tag: phrase
#: getting-started.docbook:11
#, no-c-format
msgid "&kturtle; on a fresh start"
msgstr ""

#. Tag: para
#: getting-started.docbook:15
#, fuzzy, no-c-format
#| msgid ""
#| "When you start &kturtle; you will see something like this: <screenshot> "
#| "<screeninfo>Here is a screenshot of &kturtle; when you start it for the "
#| "first time</screeninfo> <mediaobject> <imageobject> <imagedata fileref="
#| "\"mainwindow.png\" format=\"PNG\"/> </imageobject> <textobject> "
