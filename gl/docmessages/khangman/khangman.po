#~ "novo</guilabel> e aparece outra palabra ou seleccionar outra "
#~ "<guimenu>Categoría</guimenu> para xogar. Para saír do xogo selecciona "
#~ "<menuchoice><guimenu>Xogo</guimenu><guimenuitem>Saír</guimenuitem></"
