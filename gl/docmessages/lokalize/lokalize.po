#: index.docbook:294
#, no-c-format
msgid "Translation Memory"
msgstr "Memoria de tradución"

#. Tag: para
#: index.docbook:296
#, fuzzy, no-c-format
#| msgid ""
#| "The <guilabel>Translation Memory View</guilabel> allows you to drag and "
#| "drop a folder with translation files from say Dolphin into the view, and "
#| "then, within few minutes, translation suggestions will be shown "
#| "automatically on the message entry switch. To insert the translation "
