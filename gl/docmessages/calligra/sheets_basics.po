#. Tag: title
#: basics.docbook:523
#, no-c-format
msgid "Saving your Work"
msgstr "Gardar o traballo"

#. Tag: para
#: basics.docbook:524
#, fuzzy, no-c-format
#| msgid ""
#| "&kspread; saves the complete document, which may include more than one "
#| "worksheet, as a single document file."
msgid ""
"&sheets; saves the complete document, which may include more than one "
"worksheet, as a single document file."
