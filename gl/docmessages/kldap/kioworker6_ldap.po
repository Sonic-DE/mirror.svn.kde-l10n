# skip-rule: proposta-gl-directorio
#. Tag: para
#: index.docbook:17
#, no-c-format
msgid ""
"<acronym>ldap</acronym> is the lightweight directory access protocol. It "
"provides access to an X.500 directory, or to a stand-alone <acronym>LDAP</"
"acronym> server."
msgstr ""
"<acronym>ldap</acronym> é o protocolo lixeiro de acceso a directorios. "
"Fornece acceso a un directorio de X.500, ou a un servidor <acronym>LDAP</"
"acronym> independente."

#. Tag: para
#: index.docbook:21
#, no-c-format
msgid "You can use the ldap KIO worker as follows:"
msgstr "Pode usar o traballador de KIO de ldap así:"

#. Tag: para
#: index.docbook:23
#, no-c-format
msgid ""
"<userinput>ldap://host:port/ou=People,o=where,c=de??sub</userinput> for a "
"subtree-query"
msgstr ""
"<userinput>ldap://servidor:porto/ou=People,o=where,c=de??sub</userinput> "
"para unha consulta de subárbore."

#. Tag: para
#: index.docbook:26
#, no-c-format
msgid ""
"or <userinput>ldap://host:port/cn=MM,ou=People,o=where,c=de??base</"
"userinput> for a complete branch."
msgstr ""
"ou <userinput>ldap://servidor:porto/cn=MM,ou=People,o=where,c=de??base</"
"userinput> para unha rama completa."
