#. Tag: para
#: index.docbook:17
#, no-c-format
msgid ""
"The <emphasis>file</emphasis> protocol is used by all &kde; applications to "
"display locally available files."
msgstr ""
"O protocolo <emphasis>file</emphasis> úsano as aplicacións de &kde; para "
"amosar os ficheiros dispoñíbeis localmente."

#. Tag: para
#: index.docbook:21
#, no-c-format
msgid ""
"Entering <userinput><command>file:/directoryname</command></userinput> in "
"&konqueror; lists the files of this folder."
msgstr ""
"Se insire <userinput><command>file:/nomedodirectorio</command></userinput> "
"en &konqueror; listará os ficheiros que haxa nese cartafol."
