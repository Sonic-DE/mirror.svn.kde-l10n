#. Tag: phrase
#: index.docbook:399
#, fuzzy, no-c-format
#| msgid "Game Configuration"
msgid "<phrase>Game Configuration</phrase>"
msgstr "Configuración do xogo"

#. Tag: para
#: index.docbook:404
#, no-c-format
msgid ""
"<guilabel>Starting Player Color</guilabel>: Determine which player color "
"(<guilabel>Red</guilabel> or <guilabel>Black</guilabel>) has the first move "
"in the next game."
msgstr ""
"<guilabel>Cor do xogador que comeza</guilabel>: Determina cal é a cor do "
"xogador (<guilabel>Vermello</guilabel> ou <guilabel>Negro</guilabel>) que "
"comeza primeiro no partida seguinte."

#. Tag: para
#: index.docbook:405
#, no-c-format
msgid "<guilabel>Player Names</guilabel>: Change the names of the players."
msgstr "<guilabel>Nomes dos xogadores</guilabel>: Renomear os xogadores."

#. Tag: para
#: index.docbook:406
#, no-c-format
msgid ""
"<guilabel>Black Plays With</guilabel>: Choose who should play for player 1. "
"It can be either <guilabel>Mouse</guilabel> or <guilabel>Keyboard</"
"guilabel>, &ie; a local player using the mouse or keyboard as input device "
"or <guilabel>Computer</guilabel>, &ie; the computer plays for this player."
msgstr ""
"<guilabel>O negro xoga con</guilabel>: Escolle quen debe xogar como sendo o "
"xogador 1. Tanto pode ser o <guilabel>Rato</guilabel> ou o "
"<guilabel>Teclado</guilabel>, &ie; un xogador local que usa o rato ou o "
"teclado como dispositivo de entrada ou o <guilabel>Computador</guilabel>, "
"&ie; o computador xoga con este xogador."

#. Tag: para
#: index.docbook:412
#, no-c-format
msgid ""
"<guilabel>Red Plays With</guilabel>: Same as <guilabel>Black Plays With</"
"guilabel> but for player 2 (red)."
msgstr ""
"<guilabel>O vermello xoga con</guilabel>: O mesmo que para <guilabel>O negro "
"xoga con</guilabel>, pero para o xogador 2 (vermello)."

#. Tag: para
#: index.docbook:414
#, no-c-format
msgid ""
"<guilabel>Computer Difficulty</guilabel>: Select the level of the computer "
"player."
msgstr ""
"<guilabel>Dificultade do computador</guilabel>: Escolle o nivel do xogador "
"do computador."

#. Tag: para
#: index.docbook:415
#, no-c-format
msgid ""
"<guilabel>Use AI learning</guilabel>: The computer AI can learn from "
"mistakes made in one game."
msgstr ""
"<guilabel>Usar aprendizaxe da intelixencia artificial</guilabel>: A IA do "
"computador poderáaprender cos erros cometidos nun xogo."

