#: index.docbook:498
#, no-c-format
msgid ""
"In this exercise you have to compare 2 given fractions. You have to choose "
"the bigger fraction of both by selecting the correct comparison sign."
msgstr ""
"Neste tipo de exercicio hai que comparar 2 fraccións dadas. Hai que escoller "
"a maior entre ambas as dúas escollendo o símbolo correcto."

#. Tag: screeninfo
#: index.docbook:503
#, no-c-format
msgid "<screeninfo>Exercise Comparison</screeninfo>"
msgstr "<screeninfo>Exercicio de comparación</screeninfo>"

