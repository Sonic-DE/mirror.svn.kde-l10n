#. Tag: refpurpose
#: man-split2po.1.docbook:19
#, no-c-format
msgid "Creates a po file from two DocBook XML files"
msgstr "Crea un ficheiro po a partir de dous ficheiros XML DocBook."

#. Tag: cmdsynopsis
#: man-split2po.1.docbook:23
#, no-c-format
msgid ""
"<command>split2po</command> <group choice=\"req"
"\"><option><replaceable>Original-XML</replaceable></option> "
"<option><replaceable>Translated-XML</replaceable></option></group>"
msgstr ""
"<command>split2po</command> <group choice=\"req\"><option><replaceable>XML-"
"orixinal</replaceable></option> <option><replaceable>XML-traducido</"
"replaceable></option></group>"

#. Tag: title
#: man-split2po.1.docbook:31
#, no-c-format
msgid "Description"
msgstr "Descrición"

#. Tag: para
#: man-split2po.1.docbook:33
#, no-c-format
msgid ""
"<command>split2po</command> is a command-line tool that takes the two given "
"DocBook XML files and produces a <command>gettext</command> message file (PO-"
"file) that represents the changes between them. The resulting PO-file is "
"sent to standard output."
msgstr ""
"<command>split2po</command> é unha ferramenta para a liña de ordes que toma "
"os dous ficheiros XML DocBook e xera un ficheiro de mensaxes "
"<command>gettext</command> que representa os cambios entre eles. O ficheiro "
"PO resultante é enviado para a saída estándar."

#. Tag: para
#: man-split2po.1.docbook:39
#, no-c-format
msgid ""
"<filename>translated-XML</filename> must be the result of translating "
"<filename>original-XML</filename> into another language. It is this "
"translation that the resulting PO-file will represent."
msgstr ""
"<filename>XML-traducido</filename> debe ser o resultado de traducir "
"<filename>XML-orixinal</filename> a outro idioma. Esta é a tradución "
"representada no ficheiro PO resultante."

#. Tag: para
#: man-split2po.1.docbook:44
#, no-c-format
msgid "This utility is part of the KDE Software Development Kit."
msgstr ""
"Esta utilidade forma parte do equipamento de desenvolvemento de programas de "
"KDE."

