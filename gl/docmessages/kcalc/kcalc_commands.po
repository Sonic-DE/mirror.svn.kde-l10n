#. Tag: menuchoice
#: commands.docbook:12
#, no-c-format
msgid "<guimenu>Constants</guimenu> <guimenuitem>Mathematics</guimenuitem>"
msgstr "<guimenu>Constantes</guimenu> <guimenuitem>Matemáticas</guimenuitem>"

#. Tag: action
#: commands.docbook:16
#, no-c-format
msgid "Display Pi, Euler Number or Golden Ratio."
msgstr "Mostra o Pi, o número de Euler ou a Proporción áurea."

#. Tag: menuchoice
#: commands.docbook:21
#, no-c-format
msgid ""
"<guimenu>Constants</guimenu> <guimenuitem>Electromagnetism</guimenuitem>"
msgstr ""
"<guimenu>Constantes</guimenu> <guimenuitem>Electromagnetismo</guimenuitem>"

#. Tag: action
#: commands.docbook:25
#, no-c-format
msgid ""
"Display Light Speed, Elementary Charge, Impedance of Vacuum, Permeability of "
"Vacuum or Permittivity of Vacuum."
msgstr ""
"Mostra a Velocidade da luz, a Carga elemental, a Impedancia do Baleiro, a "
"Permeabilidade do baleiro ou a Permisividade do baleiro."

#. Tag: menuchoice
#: commands.docbook:31
#, no-c-format
msgid ""
"<guimenu>Constants</guimenu> <guimenuitem>Atomic &amp; Nuclear</guimenuitem>"
msgstr ""
"<guimenu>Constantes</guimenu> <guimenuitem>Atómico &amp; nuclear</"
"guimenuitem>"

#. Tag: action
#: commands.docbook:35
#, no-c-format
msgid ""
"Display Planck's Constant, Elementary Charge or Fine-Structure Constant."
msgstr ""
"Mostra a Constante de Planck, a Carga elemental ou a Constante de estrutura "
"fina."

#. Tag: menuchoice
#: commands.docbook:41
#, no-c-format
msgid "<guimenu>Constants</guimenu> <guimenuitem>Thermodynamics</guimenuitem>"
