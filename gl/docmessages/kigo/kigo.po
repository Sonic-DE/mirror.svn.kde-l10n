#: index.docbook:80
#, no-c-format
msgid "Starting a Game"
msgstr "Inicio dunha partida"

#. Tag: para
#: index.docbook:82
#, fuzzy, no-c-format
#| msgid ""
#| "When you have started &kappname; you have two options to play the "
