#: org.kde.kontrast.appdata.xml:10
msgid "Check color contrast"
msgstr "Comprobar o contraste de cores"

#. (itstool) path: description/p
#: org.kde.kontrast.appdata.xml:14
msgid ""
"Kontrast is a color contrast checker and tells you if your color "
"combinations are distinct enough to be readable and accessible."
msgstr ""
"Kontrast é un comprobador de contraste de cor que lle indica se as súas "
"combinacións de cores son distintas de abondo para ser lexíbeis e accesíbeis."

