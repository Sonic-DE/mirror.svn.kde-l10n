#. (itstool) path: component/name
#: org.kde.kgraphviewer.appdata.xml:9
msgid "KGraphViewer"
msgstr "KGraphViewer"

#. (itstool) path: component/summary
#: org.kde.kgraphviewer.appdata.xml:10
msgid "A Graphviz DOT graph viewer"
msgstr "Un visor de gráficos de Graphviz DOT"

#. (itstool) path: description/p
#: org.kde.kgraphviewer.appdata.xml:12
msgid ""
"KGraphViewer is a Graphviz DOT graph file viewer, aimed to replace the other "
"outdated Graphviz tools. Graphs are commonly used in scientific domains and "
"particularly in computer science."
msgstr ""
"KGraphViewer é un visor de ficheiros de gráficos DOT de Graphviz que "
"pretende substituír o resto de ferramentas obsoletas de Graphviz. Os "
"gráficos adoitan usarse en contextos científicos e, especialmente, na "
"enxeñaría informática."

#. (itstool) path: description/p
#: org.kde.kgraphviewer.appdata.xml:16
msgid "Features:"
msgstr "Funcionalidades:"

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:18
msgid "Zooming"
msgstr "Ampliación."

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:19
msgid "Threaded loading of several graphs in tabs"
msgstr "Cargar varios gráficos separadores usando fíos"

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:20
msgid "Saving of the recent files list"
msgstr "Gardar a lista de ficheiros recentes."

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:21
msgid "Manual reload of files"
msgstr "Cargar ficheiros de novo manualmente."

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:22
msgid "Display of a bird-eye view of the graph"
msgstr "Amosar unha vista de paxaro dos gráficos."

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:23
msgid "Moving of the graph by dragging"
msgstr "Usar arrastrar e soltar para mover os gráficos."

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:24
msgid "Full featured printing"
msgstr "Todo tipo de funcionalidades de impresión."

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:25
msgid "Perfect drawing of all graphviz example graphs"
msgstr "Debuxa perfectamente todos os gráficos de exemplo de Graphviz."

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:26
msgid "Automatically choose dot for directed graphs and neato for undirected"
msgstr ""
"Escolle automaticamente dot para os gráficos dirixidos e neato para os "
"gráficos non dirixidos."

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:27
msgid ""
"Possibility to use an arbitrary layout algorithm as soon as it produces xdot "
"format"
msgstr ""
"Permite usar un algoritmo de disposición arbitraria en canto produce o "
"formato xdot."

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:28
msgid ""
"Automatic reloading with user confirmation of (externally) modified files "
"(configurable)"
msgstr ""
"Permite cargar de novo automaticamente, previa confirmación por parte do "
"usuario, ficheiros modificador de maneira externa."

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:29
msgid "Open new instances as new tabs in the old one (configurable)"
msgstr "Permite abrir novas instancias como separadores da instancia anterior"
