#. (itstool) path: component/name
#: org.kde.skanlite.appdata.xml:10
msgid "Skanlite"
msgstr "Skanlite"

#. (itstool) path: component/summary
#: org.kde.skanlite.appdata.xml:11
msgid "Image Scanning Application"
msgstr "Aplicación de dixitalización de imaxes"

#. (itstool) path: description/p
#: org.kde.skanlite.appdata.xml:13
msgid ""
"Skanlite is a simple image scanning application to scan and save images. It "
"is optimized for scanning with flatbed scanners. Skanlite can capture not "
"only photos and documents, but also transparent slides and filmstrips, with "
"supported scanners."
msgstr ""
"Skanlite é unha aplicación simple para dixitalizar e gardar imaxes. Está "
"optimizado para dixitalizar con escáneres planos. Skanlite pode capturar non "
"só fotos e documentos, senón tamén diapositivas transparentes e tiras de "
"filme, cos escáneres compatíbeis."

#. (itstool) path: description/p
#: org.kde.skanlite.appdata.xml:17
msgid "Features:"
msgstr "Funcionalidades:"

#. (itstool) path: ul/li
#: org.kde.skanlite.appdata.xml:19
msgid ""
"Save dialog for every image scanned or saving the images immediately in a "
"specified folder with auto-generated names and format"
msgstr ""
"Diálogo de gardar para cada imaxe que se dixitaliza, ou gardar as imaxes "
"inmediatamente nun cartafol indicado con nome e formato xerados "
"automaticamente."

#. (itstool) path: ul/li
#: org.kde.skanlite.appdata.xml:20
msgid "Support for networks scanners"
msgstr "Compatibilidade con escáneres remotos."

#. (itstool) path: ul/li
#: org.kde.skanlite.appdata.xml:21
msgid "Preview with selection feature for the final scan"
msgstr ""
"Vista previa con funcionalidade de selección para a dixitalización final."

#. (itstool) path: ul/li
#: org.kde.skanlite.appdata.xml:22
msgid "Scanning multiple selections of an image"
msgstr "Dixitalización de varias seleccións dunha imaxe."

#. (itstool) path: screenshot/caption
#: org.kde.skanlite.appdata.xml:27
msgid "Skanlite's basic options screen with a scanned image visible"
msgstr "Pantalla de opcións básicas de Skanlite cunha imaxe escaneada visíbel."
