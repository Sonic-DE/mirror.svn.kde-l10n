#. (itstool) path: component/summary
#: org.kde.systemdgenie.metainfo.xml:12
msgid "System service manager"
msgstr "Xestor de servizos do sistema"

#. (itstool) path: description/p
#: org.kde.systemdgenie.metainfo.xml:14
msgid ""
"systemdGenie allows graphical management of systemd units, including user "
"units, and provides control over logind sessions. It also includes an "
"integrated text editor for easy modification of unit and configuration files."
msgstr ""
"systemdGenie permite a xestión gráfica de unidades de systemd, incluídas "
"unidades de persoa usuaria, e permite controlar sesións de logind. Tamén "
"inclúe un editor de texto integrado para modificar facilmente ficheiros de "
"unidades e de configuración."
