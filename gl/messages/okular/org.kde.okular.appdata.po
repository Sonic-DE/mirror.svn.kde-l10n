#. (itstool) path: component/name
#: org.kde.okular.appdata.xml:7
msgid "Okular"
msgstr "Okular"

#. (itstool) path: component/summary
#: org.kde.okular.appdata.xml:8
msgid "View and annotate documents"
msgstr "Ver e anotar documentos"

#. (itstool) path: description/p
#: org.kde.okular.appdata.xml:10
msgid ""
"Okular is a universal document viewer developed by KDE. Okular works on "
"multiple platforms, including but not limited to Linux, Windows, Mac OS X, "
"*BSD, etc."
msgstr ""
"Okular é un visor de documentos universal desenvolvido por KDE. Okular "
"funciona en varias plataformas, entre elas Linux, Windows, Mac OS X, *BSD, "
"etc."

#. (itstool) path: description/p
#: org.kde.okular.appdata.xml:13
msgid "Features:"
msgstr "Funcionalidades:"

#. (itstool) path: ul/li
#: org.kde.okular.appdata.xml:15
msgid ""
"Supported Formats: PDF, PS, Tiff, DjVu, Images, DVI, XPS, Fiction Book, "
"Comic Book, Plucker, EPub, Fax"
msgstr ""
"Formatos compatíbeis: PDF, PS, Tiff, DjVu, imaxes, DVI, XPS, Fiction Book, "
"banda deseñada, Plucker, EPub e fax."

#. (itstool) path: ul/li
#: org.kde.okular.appdata.xml:16
msgid "Sidebar with contents, thumbnails, reviews and bookmarks"
msgstr "Barra lateral con contido, miniaturas, revisións e marcadores."

#. (itstool) path: ul/li
#: org.kde.okular.appdata.xml:17
msgid "Annotations support"
msgstr "Funcionalidade de anotacións."

#. (itstool) path: screenshot/caption
#: org.kde.okular.appdata.xml:22
msgid "Reading manual in Okular"
msgstr "Ler o manual en Okular."

#~ msgid "Document Viewer"
