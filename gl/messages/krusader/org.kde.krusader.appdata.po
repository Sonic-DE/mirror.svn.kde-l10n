#. (itstool) path: component/name
#: org.kde.krusader.appdata.xml:7
msgid "Krusader"
msgstr "Krusader"

#. (itstool) path: component/summary
#: org.kde.krusader.appdata.xml:8
msgid "File Manager"
msgstr "Xestor de ficheiros"

#. (itstool) path: description/p
#: org.kde.krusader.appdata.xml:13
msgid ""
"Krusader is an advanced twin panel (commander style) file manager for KDE "
"Plasma and other desktops in the *nix world"
msgstr ""
"Krusader é un xestor de ficheiros avanzado de paneis xemelgos (como o "
"Commander) para KDE Plasma e outros escritorios do mundo *nix."

#. (itstool) path: description/p
#: org.kde.krusader.appdata.xml:14
msgid "Features:"
msgstr "Funcionalidades:"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:16
msgid "Extensive archive handling"
msgstr "Gran xestión de arquivos."

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:17
msgid "Mounted filesystem support"
msgstr "Compatibilidade con sistemas de ficheiros montados."

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:18
msgid "FTP support"
msgstr "Compatibilidade con FTP."

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:19
msgid "Advanced search module"
msgstr "Módulo avanzado de busca."

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:20
msgid "Internal viewer/editor"
msgstr "Visor e editor internos."

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:21
msgid "Folder synchronisation"
msgstr "Sincronización de cartafoles"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:22
msgid "File content comparisons"
msgstr "Comparación do contido de ficheiros."

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:23
msgid "Powerful batch renaming"
msgstr "Potente sistema de renomeamento por lotes."

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:24
msgid ""
"Support for a wide variety of archive formats and can handle other KIO "
"slaves such as smb or fish."
msgstr ""
"Compatibilidade cunha gran variedade de formatos de arquivo, e capaz de usar "
"servizos KIO como «smb» ou «fish»."

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:25
msgid "Completely customizable and very user friendly"
msgstr "Pode personalizarse completamente e é moi doado de usar."

