msgid "Several formats supported: gzip, bzip2, zip, rar, 7z and more"
msgstr "Compatíbel con moitos formatos: gzip, bzip2, zip, rar, 7z e máis."

#. (itstool) path: ul/li
#: org.kde.ark.appdata.xml:22
msgid "Preview file contents without extracting files"
msgstr "Obteña unha vista previa dos ficheiros comprimidos sen extraelos."

