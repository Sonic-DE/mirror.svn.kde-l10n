#~ "Complemento de sindicación para KTorrent compatíbel con fontes RSS e Atom."

#~ msgctxt "Name"
#~ msgid "UPnP"
#~ msgstr "UPnP"

#~ msgctxt "Comment"
#~ msgid "Forward ports using UPnP"
#~ msgstr "Reencamiñar portos mediante UPnP."

#~ msgctxt "Name"
#~ msgid "Zeroconf"
#~ msgstr "Zeroconf"

#~ msgctxt "Comment"
#~ msgid "Discover peers on the local network using the Zeroconf protocol"
#~ msgstr "Descubrir parceiros na rede local mediante o protocolo Zeroconf."

#~ msgctxt "Name"
#~ msgid "Scripting"
#~ msgstr "Scripts"

#~ msgctxt "Comment"
#~ msgid "Enables Kross scripting support"
#~ msgstr "Permite o uso de scripts escritos en Kross."

#~ msgctxt "Name"
#~ msgid "Automatic Remove"
#~ msgstr "Retiro automático"

#~ msgctxt "Comment"
#~ msgid ""
#~ "Script to automatically remove torrents when they finish downloading or "
#~ "seeding"
#~ msgstr ""
#~ "Un script para retirar os torrentes automaticamente cando remate a súa "
#~ "descarga ou espallamento."

#~ msgctxt "Name"
#~ msgid "Automatic Resume"
#~ msgstr "Continuación automática"

#~ msgctxt "Comment"
#~ msgid ""
#~ "Script to automatically resume after some time, when the suspended state "
#~ "is enabled"
#~ msgstr ""
#~ "Un script para continuar automaticamente despois dun tempo, cando se "
#~ "activa o estado de suspensión."

#~ msgctxt "Name"
#~ msgid "E-Mail Notifications"
#~ msgstr "Notificacións por correo"

#~ msgctxt "Comment"
#~ msgid "Script to notify you of events via e-mail"
#~ msgstr "Un script para notificarlle por correo os sucesos."

#~ msgctxt "Name"
#~ msgid "Tracker Grouping"
#~ msgstr "Agrupamento por localizador"

#~ msgctxt "Comment"
