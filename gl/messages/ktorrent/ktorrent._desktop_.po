#: ktorrent/ktorrent.notifyrc:4
msgctxt "Comment"
msgid "KTorrent"
msgstr "KTorrent"

#: ktorrent/ktorrent.notifyrc:67
msgctxt "Name"
msgid "Torrent silently opened"
msgstr "Abriuse un torrente silandeiramente."

#: ktorrent/ktorrent.notifyrc:117
msgctxt "Name"
msgid "Torrent stopped by error"
msgstr "Un erro provocou que se detivese un torrente"

#: ktorrent/ktorrent.notifyrc:174
msgctxt "Name"
msgid "Torrent has finished downloading"
msgstr "Rematou a descarga dun torrente"

#: ktorrent/ktorrent.notifyrc:231
msgctxt "Name"
msgid "Maximum share ratio reached"
msgstr "Acadouse a taxa máxima de compartición"

#: ktorrent/ktorrent.notifyrc:288
msgctxt "Name"
msgid "Maximum seed time reached"
msgstr "Acadouse o prazo máximo de compartición"

#: ktorrent/ktorrent.notifyrc:345
msgctxt "Name"
msgid "Disk space is running low"
msgstr "O espazo de almacenamento está esgotándose"

#: ktorrent/ktorrent.notifyrc:402
msgctxt "Name"
msgid "Corrupted data has been found"
msgstr "Atopáronse datos corrompidos"

#: ktorrent/ktorrent.notifyrc:460
msgctxt "Name"
msgid "Torrent cannot be enqueued"
msgstr "Non é posíbel pór o torrente na fila"

#: ktorrent/ktorrent.notifyrc:517
msgctxt "Name"
msgid "Torrent cannot be started"
msgstr "Non é posíbel iniciar o torrente"

#: ktorrent/ktorrent.notifyrc:574
msgctxt "Name"
msgid "Torrent cannot be loaded silently"
msgstr "Non é posíbel cargar silandeiramente o torrente"

#: ktorrent/ktorrent.notifyrc:631
msgctxt "Name"
msgid "DHT is not enabled"
msgstr "O DHT non está activado"

#: ktorrent/ktorrent.notifyrc:686
msgctxt "Name"
msgid "Event generated by plugin"
msgstr "Suceso xerado por un complemento"

#: ktorrent/ktorrent.notifyrc:738
msgctxt "Name"
msgid "Magnet link download started"
msgstr "Comezou a descarga dunha ligazón Magnet"

#: ktorrent/ktorrent.notifyrc:789
msgctxt "Name"
msgid "Magnet link copied to clipboard"
msgstr "A ligazón magnet copiouse no portapapeis."

#: ktorrent/org.kde.ktorrent.desktop:2
msgctxt "Name"
msgid "KTorrent"
msgstr "KTorrent"

#: ktorrent/org.kde.ktorrent.desktop:66
msgctxt "GenericName"
msgid "BitTorrent Client"
msgstr "Cliente de BitTorrent"

#: ktorrent/org.kde.ktorrent.desktop:137
msgctxt "Comment"
msgid "A BitTorrent program by KDE"
msgstr "Un programa BitTorrent de KDE"

#~ msgctxt "Name"
#~ msgid "Scheduler"
#~ msgstr "Planificador"

#~ msgctxt "Comment"
#~ msgid "Schedule upload and download limits over a period of a week"
