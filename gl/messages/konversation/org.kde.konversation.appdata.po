#. (itstool) path: component/name
#: org.kde.konversation.appdata.xml:10
msgid "Konversation"
msgstr "Konversation"

#. (itstool) path: component/summary
#: org.kde.konversation.appdata.xml:11
msgid "IRC client"
msgstr "Cliente de IRC"

# skip-rule: trasno-provide
#. (itstool) path: description/p
#: org.kde.konversation.appdata.xml:13
msgid ""
"Konversation is a user-friendly Internet Relay Chat (IRC) client by KDE. It "
"provides easy access to standard IRC networks such as Libera, where the KDE "
"IRC channels can be found."
msgstr ""
"Konversation é un cliente fácil de usar de Internet Relay Chat (IRC) de KDE. "
"Facilita acceder a redes IRC estándar como Libera, onde pode atopar as "
"canles de IRC de KDE."

#. (itstool) path: description/p
#: org.kde.konversation.appdata.xml:18
msgid "Features:"
msgstr "Funcionalidades:"

#. (itstool) path: ul/li
#: org.kde.konversation.appdata.xml:20
msgid "Standard IRC features"
msgstr "Funcionalidades estándar de IRC."

#. (itstool) path: ul/li
#: org.kde.konversation.appdata.xml:21
msgid "SSL server support"
msgstr "Compatibilidade con servidores SSL."

#. (itstool) path: ul/li
#: org.kde.konversation.appdata.xml:22
msgid "Bookmarking support"
msgstr "Funcionalidade de marcar"

#. (itstool) path: ul/li
#: org.kde.konversation.appdata.xml:23
msgid "Easy to use graphical user interface"
msgstr "Interface de usuario fácil de usar."

#. (itstool) path: ul/li
#: org.kde.konversation.appdata.xml:24
msgid "Multiple servers and channels in one single window"
msgstr "Varios servidores e canles nunha mesma xanela."

#. (itstool) path: ul/li
#: org.kde.konversation.appdata.xml:25
msgid "DCC file transfer"
msgstr "Transferencia de ficheiros por DCC."

#. (itstool) path: ul/li
#: org.kde.konversation.appdata.xml:26
msgid "Multiple identities for different servers"
msgstr "Varias identidades para distintos servidores."

#. (itstool) path: ul/li
#: org.kde.konversation.appdata.xml:27
msgid "Text decorations and colors"
msgstr "Decoracións e cores de texto."

#. (itstool) path: ul/li
#: org.kde.konversation.appdata.xml:28
msgid "OnScreen Display for notifications"
msgstr "Notificacións visualizadas na pantalla."

#. (itstool) path: ul/li
#: org.kde.konversation.appdata.xml:29
msgid "Automatic UTF-8 detection"
msgstr "Detección automática de UTF-8."

#. (itstool) path: ul/li
#: org.kde.konversation.appdata.xml:30
msgid "Per channel encoding support"
msgstr "Admite codificacións distintas en cada canle."

#. (itstool) path: ul/li
#: org.kde.konversation.appdata.xml:31
msgid "Theme support for nick icons"
msgstr "Funcionalidade de temas para iconas de alcumes."

#. (itstool) path: ul/li
#: org.kde.konversation.appdata.xml:32
msgid "Highly configurable"
msgstr "Altamente configurábel."

#~ msgid ""
#~ "Konversation is an IRC client which gives you speedy access to Freenode "
#~ "network's channels, where you will find support for most distributions. "
#~ "Its defaults are such that it needs no configuration other than telling "
#~ "it the name of your distribution channel, to get started."
#~ msgstr ""
#~ "Konversation é un cliente de IRC que lle da acceso rápido ás canles da "
#~ "rede Freenode, onde atopará asistencia técnica para a meirande parte das "
#~ "distribucións. A configuración predeterminada está deseñada para que só "
#~ "teña que indicar o nome da canle da distribución para comezar."
