#. (itstool) path: component/name
#: org.kde.kdiff3.appdata.xml:13
msgid "KDiff3"
msgstr "KDiff3"

#. (itstool) path: component/summary
#: org.kde.kdiff3.appdata.xml:14
msgid "A file and folder comparison and merge tool"
msgstr "Unha ferramenta de comparación e fusión de ficheiros e cartafoles"

# skip-rule: gl-dous-puntos-finais
#. (itstool) path: description/p
#: org.kde.kdiff3.appdata.xml:17
msgid "KDiff3 is a file and folder diff and merge tool which"
msgstr ""
"KDiff3 é unha ferramenta de diferenzas e fusión de ficheiros e cartafoles "
"que:"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:19
msgid "compares and merges two or three text input files or folders,"
msgstr ""
"compara e fusiona dous ou tres ficheiros ou cartafoles de entrada de texto,"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:20
msgid "shows the differences line by line and character by character(!),"
msgstr "amosa as diferenzas liña por liña e carácter por carácter(!),"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:21
msgid "provides an automatic merge-facility,"
msgstr "fornece unha ferramenta de fusión automática,"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:22
msgid "has an editor for comfortable solving of merge-conflicts,"
msgstr "ten un editor para solucionar de maneira cómoda conflitos de fusión,"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:23
msgid "provides network transparency via KIO,"
msgstr "fornece transparencia de rede mediante KIO,"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:24
msgid "has options to highlight or hide changes in white-space or comments,"
msgstr ""
"ten opcións para realzar ou agochar cambios en espazos en branco ou "
"comentarios,"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:25
msgid "supports Unicode, UTF-8 and other file encodings,"
msgstr "é compatíbel con Unicode, UTF-8 e outras codificacións de ficheiros,s"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:26
msgid "prints differences,"
msgstr "imprime diferenzas,"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:27
msgid "supports version control keyword and history merging."
msgstr "e permite fusionar historiais e palabras clave de control de versión."
