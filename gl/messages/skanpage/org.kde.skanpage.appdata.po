#. (itstool) path: component/name
#: org.kde.skanpage.appdata.xml:14
msgid "Skanpage"
msgstr "Skanpage"

#. (itstool) path: component/summary
#: org.kde.skanpage.appdata.xml:15
msgid "Scan multi-page documents and images"
msgstr "Escanear documentos de varias páxinas e imaxes"

#. (itstool) path: description/p
#: org.kde.skanpage.appdata.xml:17
msgid ""
"Skanpage is a simple scanning application optimized for multi-page document "
"scanning. It can also scan and save single-page documents and images."
msgstr ""
"Skanpage é unha aplicación de escanear sinxela optimizada para escanear "
"documentos de varias páxinas. Tamén pode escanear e gardar documentos dunha "
"única páxina e imaxes."

#. (itstool) path: description/p
#: org.kde.skanpage.appdata.xml:18
msgid "Features:"
msgstr "Funcionalidades:"

#. (itstool) path: ul/li
#: org.kde.skanpage.appdata.xml:20
msgid "Scanning from flatbed and ADF scanners"
msgstr "Escanear con escáneres planos e ADF."

#. (itstool) path: ul/li
#: org.kde.skanpage.appdata.xml:21
msgid "Configurable options for scanning device"
msgstr "Permite configurar o escáner."

#. (itstool) path: ul/li
#: org.kde.skanpage.appdata.xml:22
msgid "Reordering, rotation, and deletion of scanned pages"
msgstr "Cambio de orde, rotación e eliminación de páxinas."

#. (itstool) path: ul/li
#: org.kde.skanpage.appdata.xml:23
msgid "Saving to multi-page PDF documents and image files"
msgstr "Gardar en documentos PDF de varias páxinas e en ficheiros de imaxe."

