msgid "Journald Browser"
msgstr "Navegador de Journald"

#. (itstool) path: component/summary
#: org.kde.kjournaldbrowser.appdata.xml:15
msgid "Browser for journald databases"
msgstr "Navegador de bases de datos de journald"

#. (itstool) path: description/p
#: org.kde.kjournaldbrowser.appdata.xml:17
msgid ""
"Journald-browser is a reference implementation of the kjournald library and "
"provides a flexible tool to browse in local, remote and offline journald "
"databases."
msgstr ""
"Journald-browser é unha implementación de referencia da biblioteca kjournald "
"e fornece unha ferramenta flexíbel para navegar bases de datos de journald "
"en local, en remoto e sen conexión."

