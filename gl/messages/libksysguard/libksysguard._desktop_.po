msgid "System monitor Sensor Display Styles"
msgstr "Estilos de vista de sensores de vixilancia do sistema"

#: faces/systemmonitor-presets.knsrc:2
msgctxt "Name"
msgid "System monitor Sensor Presets"
msgstr "Predefinicións de sensores de vixilancia do sistema"

#: processcore/actions.actions:2
msgctxt "Name"
msgid "KSysGuard"
msgstr "KSysGuard"

#: processcore/actions.actions:82
msgctxt "Name"
msgid "Kill or stop etc a process"
msgstr "Matar, deter etc un proceso"

#: processcore/actions.actions:148
msgctxt "Description"
msgid "Sends a given signal to a given process"
msgstr "Envía un sinal dado a un proceso dado."

#: processcore/actions.actions:218
msgctxt "Name"
msgid "Change the priority of a process"
msgstr "Cambiar a prioridade dun proceso"

#: processcore/actions.actions:286
msgctxt "Description"
msgid "Change the niceness of a given process"
msgstr "Cambia a cortesía do proceso indicado."

#: processcore/actions.actions:355
msgctxt "Name"
msgid "Change IO Scheduler and priority"
msgstr "Cambiar o planificador de E/S e a prioridade"

#: processcore/actions.actions:420
msgctxt "Description"
msgid "Change how the read and writes of a given process are prioritized"
msgstr ""
"Cambiar como se da prioridade ás lecturas e escrituras dun proceso dado."

#: processcore/actions.actions:487
msgctxt "Name"
msgid "Change CPU Scheduler and priority"
msgstr "Cambias o planificador da CPU e a prioridade"

#: processcore/actions.actions:552
msgctxt "Description"
msgid ""
"Change which CPU scheduler is to schedule the running of a given process"
msgstr ""
"Cambia o planificador da CPU que planifica a execución dun proceso dado."

