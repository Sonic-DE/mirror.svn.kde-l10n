#: backgrounds/chinese_landscape.desktop:2
msgctxt "Name"
msgid "Chinese Landscape"
msgstr "נוף סיני"

#: backgrounds/chinese_landscape.desktop:62
msgctxt "Description"
msgid "Chinese landscape with mountains and a waterfall"
msgstr "נוסף סיני עם הרים ומפל"

#: backgrounds/color_plain.desktop:2
msgctxt "Name"
msgid "Plain Color"
msgstr "צבע פשוט"

#: backgrounds/color_plain.desktop:63
msgctxt "Description"
msgid "Use the default window background color."
msgstr "להשתמש בברירת המחדל לצבע רקע החלון."

#: backgrounds/default.desktop:2 tilesets/default.desktop:2
msgctxt "Name"
msgid "Default"
msgstr "ברירת מחדל"

#: backgrounds/default.desktop:68
msgctxt "Description"
msgid "A green background with light geometric patterns"
msgstr "רקע ירוק עם תבניות גאומטריות בהירות"

#: backgrounds/egyptian.desktop:2
msgctxt "Name"
msgid "Egyptian"
msgstr "מצרי"

#: backgrounds/egyptian.desktop:58
msgctxt "Description"
msgid "A Egyptian style background"
msgstr "רקע בסגנון מצרי"

#: backgrounds/summerfield.desktop:2
msgctxt "Name"
msgid "Summer Field"
msgstr "שדה קיצי"

#: backgrounds/summerfield.desktop:59
msgctxt "Description"
msgid "The Summertime Greens"
msgstr "הגוונים הירוקים של הקיץ"

#: backgrounds/wood_light.desktop:2
msgctxt "Name"
msgid "Light Wood"
msgstr "עץ בהיר"

#: backgrounds/wood_light.desktop:62
msgctxt "Description"
msgid "Resembles the surface of a wood table"
msgstr "מזכיר משטח של שולחן עץ"

#: tilesets/alphabet.desktop:2
msgctxt "Name"
msgid "Alphabet"
msgstr "אלפבית"

#: tilesets/alphabet.desktop:63
msgctxt "Description"
msgid "A colorful tileset designed for kids of all ages."
msgstr "ערכת אריחים צבעונית שמיועדת לילדים בכל הגילים."

#: tilesets/bamboo.desktop:2
msgctxt "Name"
msgid "Bamboo"
msgstr "במבוק"

#: tilesets/bamboo.desktop:55
msgctxt "Description"
msgid "Japanese tileset with brightly-colored kanji on a soft woodgrain"
msgstr "ערכת אריחים יפנית עם קאנג׳י בצבעים בהירים על מרקם עץ עדין"

#: tilesets/classic.desktop:2
msgctxt "Name"
msgid "Classic"
msgstr "קלסי"

#: tilesets/classic.desktop:65
msgctxt "Description"
msgid "Chinese tileset, inspired by the classic version shipped with KDE 3"
msgstr "ערכת אריחים סינית, בהשפעת הגרסה הקלסית שהושקה עם KDE 3"

#: tilesets/default.desktop:68
msgctxt "Description"
msgid "Art inspired by real Japanese Mahjongg tiles"
msgstr "אומנות שהושפעה מאריחי מהג׳ונג אמיתיים"

#: tilesets/egypt.desktop:2
msgctxt "Name"
msgid "Ancient Egyptians"
msgstr "מצרים העתיקה"

#: tilesets/jade.desktop:2
msgctxt "Name"
msgid "Imperial Jade"
msgstr "ג׳ייד האימפריאלית"

#: tilesets/traditional.desktop:2
msgctxt "Name"
msgid "Traditional"
msgstr "מסורתי"

#: tilesets/traditional.desktop:64
msgctxt "Description"
msgid "Americanized tiles inspired by Japanese Mahjongg tiles"
msgstr "אריחים בסגנון אמריקאי שהושפעו על ידי אריחי מהג׳ונג יפניים"
