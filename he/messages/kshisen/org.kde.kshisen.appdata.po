#: org.kde.kshisen.appdata.xml:9
msgid "KShisen"
msgstr "KShisen"

#. (itstool) path: component/summary
#: org.kde.kshisen.appdata.xml:10
msgid "Shisen-Sho Mahjongg-like Tile Game"
msgstr "משחק אריחים דמוי מהג׳ונג בשם שיסן־שו"

#. (itstool) path: description/p
#: org.kde.kshisen.appdata.xml:12
msgid ""
"KShisen is a solitaire-like game played using the standard set of Mahjong "
"tiles. Unlike Mahjong however, KShisen has only one layer of scrambled tiles."
msgstr ""
"KShisen הוא משחק ליחיד שמשחקים בו בערכת אריחים דמויי מהג׳ונג. בניגוד "
"למהג׳ונג, ל־KShisen יש רק שכבה אחת של אריחים מפוזרים."

#. (itstool) path: screenshot/caption
#: org.kde.kshisen.appdata.xml:23
msgid "Playing KShisen"
msgstr "איך משחקים ב־KShisen"
