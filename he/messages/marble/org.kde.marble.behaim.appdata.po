#. (itstool) path: component/name
#: org.kde.marble.behaim.appdata.xml:10
msgid "Behaim Globe"
msgstr "גלובוס בהיים"

#. (itstool) path: component/summary
#: org.kde.marble.behaim.appdata.xml:11
msgid "Martin Behaim's Erdapfel"
msgstr "ארדאפפל של מרטין בהיים"

#. (itstool) path: description/p
#: org.kde.marble.behaim.appdata.xml:13
msgid ""
"The oldest existent globe of the Earth. Martin Behaim and collaborators "
"created the globe around 1492 at the time of Columbus' first sea travel to "
"the west."
msgstr ""
"הגלובוס המציאותי העתיק ביותר של כדור הארץ. מרטין בהיים ושותפיו יצרו את "
"הגלובוס סביב שנת 1492 באותה התקופה שקולומבוס ערך את המסע הימי הראשון שלו "
"למערב."

#. (itstool) path: screenshot/caption
#: org.kde.marble.behaim.appdata.xml:68
msgid "Digital imagery taken directly from the original Behaim globe."
msgstr "הצילום הדיגיטלי לקוח ישירות מגלובוס בהיים המקורי."

#. (itstool) path: screenshot/caption
#: org.kde.marble.behaim.appdata.xml:72
msgid "A (rough) facsimile created by Friedrich Wilhelm Ghillany in 1853."
msgstr "עותק (גס) שנוצר על ידי פרידריך וילהלם גילני בשנת 1853."

#. (itstool) path: screenshot/caption
#: org.kde.marble.behaim.appdata.xml:76
msgid "A (rough) facsimile created by Ernest George Ravenstein in 1908."
msgstr "עותק (גס) שנוצר על ידי ארנסט ג׳ורג׳ רוונסטין בשנת 1908."
