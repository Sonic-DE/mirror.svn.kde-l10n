#: src/org.kde.kbreakout.desktop:2
msgctxt "Name"
msgid "KBreakOut"
msgstr "KBreakOut"

#: src/org.kde.kbreakout.desktop:63
msgctxt "GenericName"
msgid "Breakout-like Game"
msgstr "משחק דמוי Breakout"

#: src/org.kde.kbreakout.desktop:118
msgctxt "Comment"
msgid "Classic arcade game"
msgstr "משחק הרפתקה קלסי"

#: themes/alienbreakout.desktop:2
msgctxt "Name"
msgid "Alien Breakout"
msgstr "בריחה מחייזרים"

#: themes/alienbreakout.desktop:51
msgctxt "Description"
msgid "Breakout before the aliens do."
msgstr "צריך לברוח לפני שהחייזרים מספיקים."

#: themes/crystal.desktop:2
msgctxt "Name"
msgid "Crystal clear"
msgstr "בדולח שקוף"

#: themes/crystal.desktop:55
msgctxt "Description"
msgid "Crystal-like theme for KBreakOut"
msgstr "ערכת עיצוב דמוית בדולח"

#: themes/default.desktop:2
msgctxt "Name"
msgid "Egyptian Breakout"
msgstr "בריחה מצרית"

#: themes/default.desktop:52
msgctxt "Description"
msgid "Egyptian style breakout theme."
msgstr "ערכת עיצוב בסגנון מצרי לבריחה."

#: themes/IceWorld.desktop:2
msgctxt "Name"
msgid "IceWorld"
msgstr "עולם הקרח"

#: themes/IceWorld.desktop:56
msgctxt "Description"
msgid "Ice chilled theme"
msgstr "ערכת עיצוב קרה כקרח"

#: themes/simple.desktop:2
msgctxt "Name"
msgid "Simple"
msgstr "פשוט"

#: themes/simple.desktop:59
msgctxt "Description"
msgid "Simple KBreakOut theme"
msgstr "ערכת עיצוב פשוטה ל־KBreakOut"

#: themes/web20.desktop:2
msgctxt "Name"
msgid "WEB 2.0"
msgstr "אינטרנט 2.0"

#: themes/web20.desktop:57
msgctxt "Description"
msgid ""
"Web 2.0 theme showcases graphical elements reminiscent of those used in "
"popular 'WEB 2.0' movement, currently taking the interweb by storm."
msgstr ""
"ערכת עיצוב בסגנון אינטרנט 2.0 שמציגה את הרכיבים הגרפיים שמזכירים את אלו "
"שנעשה בהם שימוש בתנועת ‚אינטרנט 2.0’ (WEB 2.0), שסוחפת כרגע את האינטרנט "
"בסערה."
