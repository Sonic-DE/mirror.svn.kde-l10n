#: plugins/datenums/datenums.json
msgctxt "Description"
msgid ""
"For each day this plugin shows its daynumber of the year at the top of the "
"agenda view. For example, February 1 is day 32 of the year."
msgstr ""
"עבור כל יום התוסף הזה מציג את מספר היום בשנה בראש תצוגת סדר היום. למשל, 1 "
"בפברואר הוא היום ה־32 בשנה."

#: plugins/hebrew/hebrew.json
msgctxt "Description"
msgid "Shows all dates in KOrganizer also in the Jewish calendar system."
msgstr "הצגת כל התאריך ב־KOrganizer גם בלוח השנה העברי."

#: plugins/lunarphases/lunarphases.json
msgctxt "Description"
msgid "This plugin shows the day's lunar phase (New, First, Last, Full)"
msgstr "התוסף הזה מציג את מופע הירח היומי (מולד, ראשון, אחרון, מלא)"

#: plugins/picoftheday/picoftheday.json
