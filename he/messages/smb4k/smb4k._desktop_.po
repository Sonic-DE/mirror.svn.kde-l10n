#: core/smb4k.notifyrc:3 smb4k/org.kde.smb4k.desktop:3
msgctxt "Name"
msgid "Smb4K"
msgstr "Smb4K"

#: core/smb4k.notifyrc:44 smb4k/org.kde.smb4k.desktop:80
msgctxt "Comment"
msgid "Advanced Network Neighborhood Browser"
msgstr "דפדפן מתקדם לשכנים ברשת"

#: core/smb4k.notifyrc:87
msgctxt "Name"
msgid "Notification"
msgstr "התראה"

#: core/smb4k.notifyrc:128
msgctxt "Comment"
msgid "The user is notified about an action"
msgstr "נשלחת הודעה למשתמש על פעולה"

#: core/smb4k.notifyrc:169
msgctxt "Name"
msgid "Warning"
msgstr "אזהרה"

#: core/smb4k.notifyrc:210
msgctxt "Comment"
msgid "A warning is shown to the user"
msgstr "מופיע אזהרה למשתמש"

#: core/smb4k.notifyrc:252
msgctxt "Name"
msgid "Error"
msgstr "שגיאה"

#: core/smb4k.notifyrc:293
msgctxt "Comment"
msgid "An error message is shown to the user"
msgstr "מופיעה הודעת שגיאה למשתמש"

#: core/smb4k.notifyrc:333
msgctxt "Name"
msgid "Share mounted"
msgstr "שיתוף עוגן"

#: core/smb4k.notifyrc:371
msgctxt "Comment"
msgid "A share has been mounted"
msgstr "שיתוף עבר עיגון למערכת"

#: core/smb4k.notifyrc:413
msgctxt "Name"
msgid "Share unmounted"
msgstr "שיתוף נותק"

#: core/smb4k.notifyrc:451
msgctxt "Comment"
msgid "A share has been unmounted"
msgstr "שיתוף נותק מהמערכת"

#: core/smb4k.notifyrc:493
msgctxt "Name"
msgid "Shares mounted"
msgstr "שיתופים עוגנו"

#: core/smb4k.notifyrc:531
msgctxt "Comment"
msgid "Multiple shares have been mounted"
msgstr "מגוון שיתופים עוגנו"

#: core/smb4k.notifyrc:573
msgctxt "Name"
msgid "Shares unmounted"
msgstr "שיתופים נותקו"

#: core/smb4k.notifyrc:611
msgctxt "Comment"
msgid "Multiple shares have been unmounted"
msgstr "מספר שיתופים נותקו"

#: core/smb4k.notifyrc:653
msgctxt "Name"
msgid "Migrating login credentials"
msgstr "פרטי גישה מיובאים"

#: core/smb4k.notifyrc:682
msgctxt "Comment"
msgid ""
"The login credentials are migrated to the new format and the active password "
"manager"
msgstr "פרטי הגישה מיובאים לתסדיר החדש ולמנהל הסיסמאות הפעיל"

#: core/smb4k.notifyrc:714
msgctxt "Name"
msgid "Mimetype not supported"
msgstr "אין תמיכה בסוג התוכן (MIME)"

#: core/smb4k.notifyrc:752
msgctxt "Comment"
msgid "The mimetype of the file that is to be printed is not supported"
msgstr "סוג התוכן (MIME) של הקובץ להדפסה לא נתמך."

#: core/smb4k.notifyrc:794
msgctxt "Name"
msgid "Bookmark exists"
msgstr "הסימנייה קיימת"

#: core/smb4k.notifyrc:832
msgctxt "Comment"
msgid "The bookmark exists"
msgstr "הסימנייה כבר קיימת"

#: core/smb4k.notifyrc:875
msgctxt "Name"
msgid "Bookmark label in use"
msgstr "תווית הסימנייה תפוסה"

#: core/smb4k.notifyrc:913
msgctxt "Comment"
msgid "The label for the bookmark already exists"
msgstr "התווית שנבחרה לסימנייה כבר קיימת"

#: core/smb4k.notifyrc:956
msgctxt "Name"
msgid "Mounting failed"
msgstr "העיגון נכשל"

#: core/smb4k.notifyrc:995
msgctxt "Comment"
msgid "Mounting a share failed"
msgstr "עיגון שיתוף נכשל"

#: core/smb4k.notifyrc:1038
msgctxt "Name"
msgid "Unmounting failed"
msgstr "ניתוק נכשל"

#: core/smb4k.notifyrc:1077
msgctxt "Comment"
msgid "Unmounting a share failed"
msgstr "ניתוק עיגון נכשל"

#: core/smb4k.notifyrc:1120
msgctxt "Name"
msgid "Unmounting not allowed"
msgstr "אסור לנתק עיגון"

#: core/smb4k.notifyrc:1158
msgctxt "Comment"
msgid "The unmounting of a certain share is not allowed"
msgstr "ניתוק של עיגון מסוים אסור"

#: core/smb4k.notifyrc:1201
msgctxt "Name"
msgid "Synchronization failed"
msgstr "הסנכרון נכשל"

#: core/smb4k.notifyrc:1240
msgctxt "Comment"
msgid "The synchronization of a share and a local copy failed"
msgstr "סנכרון שיתוף מול עותק מקומי נכשל"

#: core/smb4k.notifyrc:1282
msgctxt "Name"
msgid "Command not found"
msgstr "הפקודה לא נמצאה"

#: core/smb4k.notifyrc:1322
msgctxt "Comment"
msgid "A required command could not be found"
msgstr "פקודה שנחוצה לתפקוד תקין לא נמצאה"

#: core/smb4k.notifyrc:1365
msgctxt "Name"
msgid "Cannot bookmark printer"
msgstr "לא ניתן להוסיף מדפסת לסימניות"

#: core/smb4k.notifyrc:1403
msgctxt "Comment"
msgid "A printer cannot be bookmarked"
msgstr "לא ניתן להוסיף מדפסת לסימניות"

#: core/smb4k.notifyrc:1446
msgctxt "Name"
msgid "File not found"
msgstr "קובץ לא נמצא"

#: core/smb4k.notifyrc:1487
msgctxt "Comment"
msgid "A file could not be found"
msgstr "אי אפשר למצוא קובץ"

#: core/smb4k.notifyrc:1530
msgctxt "Name"
msgid "Opening file failed"
msgstr "פתיחת קובץ נכשלה"

#: core/smb4k.notifyrc:1568
msgctxt "Comment"
msgid "A file could not be opened"
msgstr "אי אפשר לפתוח קובץ"

#: core/smb4k.notifyrc:1611
msgctxt "Name"
msgid "Reading file failed"
msgstr "קריאת קובץ נכשלה"

#: core/smb4k.notifyrc:1649
msgctxt "Comment"
msgid "A file could not be read"
msgstr "אי אפשר לקרוא קובץ"

#: core/smb4k.notifyrc:1692
msgctxt "Name"
msgid "mkdir failed"
msgstr "יצירת תיקייה (mkdir) נכשלה"

#: core/smb4k.notifyrc:1731
msgctxt "Comment"
msgid "A directory could not be created"
msgstr "אי אפשר ליצור תיקייה"

#: core/smb4k.notifyrc:1774
msgctxt "Name"
msgid "Process error"
msgstr "שגיאת עיבוד"

#: core/smb4k.notifyrc:1814
msgctxt "Comment"
msgid "A process error occurred"
msgstr "אירעה שגיאת עיבוד"

#: core/smb4k.notifyrc:1857
msgctxt "Name"
msgid "Action failed"
msgstr "פעולה נכשלה"

#: core/smb4k.notifyrc:1897
msgctxt "Comment"
msgid "A KAuth action failed"
msgstr "פעולה של KAuth נכשלה"

#: core/smb4k.notifyrc:1939
msgctxt "Name"
msgid "Invalid URL"
msgstr "כתובת שגויה"

#: core/smb4k.notifyrc:1980
msgctxt "Comment"
msgid "An invalid URL was passed"
msgstr "הועברה כתובת שגויה"

#: core/smb4k.notifyrc:2022
msgctxt "Name"
msgid "Network communication failed"
msgstr "תקשורת רשת נכשלה"

#: core/smb4k.notifyrc:2057
msgctxt "Comment"
msgid "A network related action could not be performed or failed"
msgstr "פעולה שקשורה לרשת לא יכלה להתבצע או שנכשלה"

#: core/smb4k.notifyrc:2097
msgctxt "Name"
msgid "Zeroconf error"
msgstr "שגיאת Zeroconf"

#: core/smb4k.notifyrc:2130
msgctxt "Comment"
msgid "An error with the Zeroconf daemon occurred"
msgstr "אירעה שגיאה מול הסוכן של Zeroconf"

#: core/smb4k.notifyrc:2167
msgctxt "Name"
msgid "Keychain error"
msgstr "שגיאת צרור מפתחות"

#: core/smb4k.notifyrc:2196
msgctxt "Comment"
msgid ""
"An error occurred while reading the login credentials from the secure storage"
msgstr "אירעה שגיאה בקריאת פרטי הגישה מהאחסון המאובטח"

#: helpers/smb4kmounthelper.actions:2
msgctxt "Name"
msgid "Mount action"
msgstr "פעולת עיגון"

#: helpers/smb4kmounthelper.actions:39
msgctxt "Description"
msgid "Mounts a share"
msgstr "מעגן שיתוף רשת"

#: helpers/smb4kmounthelper.actions:80
msgctxt "Name"
msgid "Unmount action"
msgstr "פעולת ניתוק"

#: helpers/smb4kmounthelper.actions:117
msgctxt "Description"
msgid "Unmounts a share"
msgstr "מנתק עיגון שיתוף רשת"

