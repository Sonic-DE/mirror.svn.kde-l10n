#: kwrited-autostart.desktop:2
msgctxt "Name"
msgid "KDE Write Daemon"
msgstr "תהליך הרקע Write של KDE"

#: kwrited-autostart.desktop:91
msgctxt "Comment"
msgid "Watch for messages from local users sent with write(1) or wall(1)"
msgstr "מעקב אחר הודעות ממשתמשים מקומיים שנשלחו באמצעות write(1)‎ או wall(1)‎"

#: kwrited.notifyrc:3
msgctxt "Name"
msgid "Local System Message Service"
msgstr "שירות הודעות מערכת מקומי"

#: kwrited.notifyrc:48
msgctxt "Comment"
msgid "Local system message service"
msgstr "שירות הודעות מערכת מקומי"

#: kwrited.notifyrc:117
msgctxt "Name"
msgid "New message received"
msgstr "הודעה חדשה התקבלה"

#: kwrited.notifyrc:192
msgctxt "Comment"
msgid "The daemon received a new message sent with wall(1) or write(1)"
msgstr "תהליך הרקע קיבל הודעה שנשלחה באמצעות wall(1) או write(1)"

#~ msgctxt "Name"
#~ msgid "Write Daemon"
#~ msgstr "תהליך הרקע Write"
