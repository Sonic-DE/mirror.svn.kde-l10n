#. (itstool) path: component/name
#: org.kde.pix.appdata.xml:7
msgid "Pix"
msgstr "פּיקס"

#. (itstool) path: component/summary
#: org.kde.pix.appdata.xml:8
msgid "Image Gallery"
msgstr "גלריית תמונות"

#. (itstool) path: description/p
#: org.kde.pix.appdata.xml:14
msgid ""
"Pix is an image gallery and image viewer. Pix can be used to open images "
"with other applications like an image editor, add tags to the files, add "
"annotations to pictures, rotate and share them."
msgstr ""
"פּיקס היא גלריית ומציג תמונות. אפשר להשתמש בפיקס כדי לפתוח תמונות עם יישומים "
"אחרים כגון עורך תמונות, להוסיף תגיות לקבצים, להוסיף הסברים לתמונות, לסובב "
"ולשתף אותן."

#. (itstool) path: screenshot/caption
#: org.kde.pix.appdata.xml:23
msgid "The Pix music player"
msgstr "נגן המוזיקה פּיקס"
