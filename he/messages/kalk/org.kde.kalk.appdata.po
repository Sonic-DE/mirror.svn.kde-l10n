#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:104
msgid "General bugfixing and code quality improvements"
msgstr "תיקון תקלות כללים ושיפורי איכות קוד"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:112
msgid "Rearrange trigonometric functions to be together"
msgstr "סידור הפונקציות הטריגונומטריות מחדש כדי שתהיינה יחד"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:113
msgid "Various user-interface improvements"
msgstr "מגוון שיפורי ממשק משתמש"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:120
msgid "Rework sidebar design"
msgstr "עבודה מחודשת על עיצוב סרגל הצד"

#. (itstool) path: description/p
#: org.kde.kalk.appdata.xml:133
msgid "Changes:"
msgstr "שינויים:"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:135
msgid "Updated the application icon"
msgstr "סמל היישום התעדכן"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:136
msgid "Added support for parentheses keyboard input"
msgstr "נוספה תמיכה בסוגריים דרך קלט מקלדת"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:137
msgid "Fixed the calculator drawer opening when the application opens"
msgstr "תוקנה פתיחת מגירת הדפדפן כשהיישום מופעל"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:138
msgid ""
"Changed backspace icon to use a proper system icon instead of a font "
"provided one"
msgstr ""
"הסמל של המחיקה (backspace) השתנה כך שישתמש בסמל המערכת המתאים במקום בסמל "
"שמגיע מגופן"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:139
msgid "Added keyboard support to unit converter"
msgstr "נוספה תמיכה במקלדת בממיר היחידות"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:140
msgid "Fixed page change animation for binary calculator"
msgstr "תוקנה הנפשת החלפת עמוד במחשבון הבינרי"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:141
msgid "Enabled qml debugging when compiled in debug mode"
msgstr "הופעל ניפוי שגיאות ב־qml כשבוצע הידור במצב ניפוי שגיאות"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:142
msgid "Added ability to recognize the decimal separator in other locales"
msgstr "נוספה היכולת לזהות את המפריד העשרוני בהגדרות מקומיות אחרות"
