#. (itstool) path: component/name
#: org.kde.kmenuedit.appdata.xml:9
msgid "Menu Editor"
msgstr "עורך התפריטים"

#. (itstool) path: component/summary
#: org.kde.kmenuedit.appdata.xml:10
msgid "Edit how applications are presented in app launchers"
msgstr "עריכת האופן בו יישומים מיוצגים במשגרי היישומים"

#. (itstool) path: description/p
#: org.kde.kmenuedit.appdata.xml:12
msgid ""
"KDE Menu Edit lets you edit how your apps are presented in application "
"launchers, such as Plasma's Application Launcher widget."
msgstr ""
"עורך תפריטי KDE מאפשר לך לעורך איך היישומים שלך מיוצגים במשגרי היישומים כגון "
"יישומון משגר היישומים של פלזמה."
