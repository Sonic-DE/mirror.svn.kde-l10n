#. (itstool) path: component/name
#: org.kde.accountwizard.appdata.xml:9
msgid "Account Wizard"
msgstr "אשף החשבונות"

#. (itstool) path: component/summary
#: org.kde.accountwizard.appdata.xml:10
msgid "Configure accounts"
msgstr "הגדרת חשבונות"

#. (itstool) path: description/p
#: org.kde.accountwizard.appdata.xml:12
msgid ""
"Accountwizard allows to edit, create, delete accounts. Accountwizard "
"supports IMAP/POP3/Kolab account type. Account information can be found by "
"using ispd service."
msgstr ""
"אשף החשבונות/AccountWizard מאפשר לך לערוך, ליצור או למחוק חשבונות. אשף "
"החשבונות תומך בסוגי החשבונות IMAP/POP3/Kolab. אפשר למצוא את פרטי החשבון דרך "
"השירות ispd."

#~ msgid "Accountwizard allows to edit, create, delete accounts."
#~ msgstr "אשף החשבונות מאפשר לערוך, ליצור או למחוק חשבונות."
