#. (itstool) path: component/name
#: org.kde.kbackup.appdata.xml:6
msgid "KBackup"
msgstr "KBackup"

#. (itstool) path: component/summary
#: org.kde.kbackup.appdata.xml:7
msgid "Create backups as .tar files to a local folder or remote URL"
msgstr "יצירת גיבויים כקובצי ‎.tar לתיקייה מקומית או כתובת מרוחקת"

#. (itstool) path: description/p
#: org.kde.kbackup.appdata.xml:9
msgid ""
"KBackup is an application which lets you back up your data in a simple, user "
"friendly way"
msgstr ""
"KBackup הוא יישום שמאפשר לך לגבות את הנתונים שלך בצורה פשוטה וידידותית למשתמש"

#. (itstool) path: description/p
#: org.kde.kbackup.appdata.xml:12
msgid "Features:"
msgstr "יכולות:"

#. (itstool) path: ul/li
#: org.kde.kbackup.appdata.xml:14
msgid ""
"Using profile files with definitions for Folders and files to be included or "
"excluded from the backup"
msgstr ""
"באמצעות קובצי פרופילים והגדרות לתיקיות ולקבצים שיגובו או יוחרגו מהגיבוי"

#. (itstool) path: ul/li
#: org.kde.kbackup.appdata.xml:15
msgid ""
"The backup target can be either a locally mounted device like a ZIP drive, "
"USB stick, etc. or any remote URL"
msgstr ""
"יעד הגיבוי יכול להיות התקן מעוגן מקומית כמו כונן גיבוי, החסן נייד ועוד או "
"כתובת מרוחקת"

#. (itstool) path: ul/li
#: org.kde.kbackup.appdata.xml:16
msgid "Running automated backups without using a graphical user interface"
msgstr "הרצת גיבויים אוטומטית מבלי צורך להשתמש בממשק חזותי"
