msgstr "רשימת נוסחאות מקיפה ועוצמתית"

#. (itstool) path: ul/li
#: org.kde.calligra.sheets.metainfo.xml:18
msgid "Work in a familiar environment"
msgstr "עבודה בסביבה מוכרת"

#. (itstool) path: description/p
