#: src/org.kde.kapman.desktop:4
msgctxt "Name"
msgid "Kapman"
msgstr "Kapman"

#: src/org.kde.kapman.desktop:63
msgctxt "GenericName"
msgid "Pac-Man Clone"
msgstr "שיבוט של פקמן"

#: src/org.kde.kapman.desktop:117
msgctxt "Comment"
msgid "Eat pills escaping ghosts"
msgstr "אוכלים כדוריות ומתחמקים מרוחות רפאים"

#: themes/invisible.desktop:2
msgctxt "Name"
msgid "Invisible"
msgstr "נעלם"

#: themes/invisible.desktop:59
msgctxt "Description"
msgid ""
"Getting bored with Kapman? More than 100,000 points over level 20? Next "
"step: the invisible maze!"
msgstr ""
"Kapman משעמם אותך? עברת 100,000 נקודות מעל שלב 20? השלב הבא: המבוך הנעלם!"

#: themes/matches.desktop:2
msgctxt "Name"
msgid "Matches"
msgstr "גפרורים"

#: themes/matches.desktop:59
msgctxt "Description"
msgid "A matches drawn maze"
msgstr "מבוך מצויר בגפרורים"

#: themes/mountain.desktop:2
msgctxt "Name"
msgid "Mountain Adventure"
msgstr "הרפתקה בהר הגעש"

#: themes/mountain.desktop:55
msgctxt "Description"
msgid "Default"
msgstr "ברירת מחדל"

#: themes/mummies_crypt.desktop:2
msgctxt "Name"
msgid "Mummies Crypt"
msgstr "צופן המומיות"

#: themes/mummies_crypt.desktop:54
msgctxt "Description"
msgid "Avoid the mummies at all costs!"
msgstr "יש להתחמק מהמומיות ויהי מה!"

#: themes/retro.desktop:2
msgctxt "Name"
msgid "Retro"
msgstr "רטרו"

#: themes/retro.desktop:58
msgctxt "Description"
msgid "The old game theme revisited"
msgstr "ערכת העיצוב הישנה של המשחק באווירה מודרנית"
