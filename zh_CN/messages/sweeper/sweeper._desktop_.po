#: org.kde.sweeper.desktop:8
msgctxt "Name"
msgid "Sweeper"
msgstr "Sweeper 系统清理工具"

#: org.kde.sweeper.desktop:75
msgctxt "GenericName"
msgid "System Cleaner"
msgstr "系统清理工具"

#: org.kde.sweeper.desktop:142
msgctxt "Comment"
msgid ""
"Helps to clean unwanted traces the user leaves on the system and to regain "
"disk space removing unused temporary files"
msgstr ""
"用于清理系统中用户使用记录的工具，通过移除不需要的临时文件来释放磁盘空间"
