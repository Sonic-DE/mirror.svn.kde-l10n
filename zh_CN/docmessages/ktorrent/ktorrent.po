#. Tag: para
#: index.docbook:40
#, no-c-format
msgid ""
"&ktorrent; is a bittorrent application by KDE which allows you to download "
"files using the BitTorrent protocol. It enables you to run multiple torrents "
"at the same time and comes with extended features to make it a full-featured "
"client for BitTorrent."
msgstr ""
"&ktorrent; 是 KDE 提供的 BT 下载应用。支持同时运行多个种子，并具有多种扩展特"
"性，是一个全功能的 BT 客户端。"

#. Tag: title
#: index.docbook:43
#, no-c-format
msgid "Features"
msgstr "特性"

#. Tag: para
#: index.docbook:44
#, no-c-format
msgid "Queuing of torrents"
msgstr "队列种子"

#. Tag: para
#: index.docbook:45
#, no-c-format
msgid "Global and per torrent speed limits"
msgstr "全局限速和单个种子限速"

#. Tag: para
#: index.docbook:46
#, no-c-format
msgid "Previewing of certain file types, build in (video and audio)"
msgstr "内置的文件预览功能 (视频和音频)"

#. Tag: para
#: index.docbook:47
#, no-c-format
msgid "Importing of partially or fully downloaded files"
msgstr "导入部分或完全下载的文件"

#. Tag: para
#: index.docbook:48
#, no-c-format
msgid "File prioritization for multi-file torrents"
msgstr "多文件种子设定文件优先级"

#. Tag: para
#: index.docbook:49
#, no-c-format
msgid "Selective downloading for multi-file torrents"
msgstr "多文件种子可选下载指定文件"

#. Tag: para
#: index.docbook:50
#, no-c-format
msgid ""
"Kick/ban peers with an additional IP Filter dialog for list/edit purposes"
msgstr "踢掉/屏蔽对等点，并可以用 IP 过滤器查看和编辑列表"

#. Tag: para
#: index.docbook:51
#, no-c-format
msgid "UDP tracker support"
msgstr "支持 UDP 追踪器"

#. Tag: para
#: index.docbook:52
#, no-c-format
msgid "Support for private trackers and torrents"
msgstr "支持私人追踪器和种子"

#. Tag: para
#: index.docbook:53
#, no-c-format
msgid "Support for µTorrent's peer exchange"
msgstr "支持 µTorrent 对等点交换"

#. Tag: para
#: index.docbook:54
#, no-c-format
msgid "Support for protocol encryption (compatible with Azureus)"
msgstr "支持协议加密 (兼容 Azureus)"

#. Tag: para
#: index.docbook:55
#, no-c-format
msgid "Support for creating trackerless torrents"
msgstr "支持创建无追踪器种子"

#. Tag: para
#: index.docbook:56
#, no-c-format
msgid "Support for distributed hash tables (DHT, the Mainline version)"
msgstr "支持分布式哈希表 (DHT，主线版本)"

#. Tag: para
#: index.docbook:57
#, no-c-format
msgid ""
"Support for UPnP to automatically forward ports on a LAN with dynamic "
"assigned hosts"
msgstr "支持 UPnP 局域网自动转发端口的动态主机名"

#. Tag: para
#: index.docbook:58
#, no-c-format
msgid "Support for webseeds"
msgstr "支持 Webseed"

#. Tag: para
#: index.docbook:59
#, no-c-format
msgid "System tray integration"
msgstr "系统托盘整合"

#. Tag: para
#: index.docbook:60
#, no-c-format
msgid "Tracker authentication support"
msgstr "追踪器认证支持"

#. Tag: para
#: index.docbook:61
#, no-c-format
msgid "Connection though a proxy"
msgstr "通过代理连接"

#. Tag: para
#: index.docbook:62
#, no-c-format
msgid "Interprocess control via DBus interface"
msgstr ""

