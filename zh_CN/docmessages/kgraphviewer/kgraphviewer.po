#, no-c-format
msgid "Press the arrows keys;"
msgstr ""

#. Tag: para
#: index.docbook:176
#, no-c-format
msgid "Click somewhere in the bird's-eye view;"
msgstr ""

#. Tag: para
#: index.docbook:177
#, no-c-format
