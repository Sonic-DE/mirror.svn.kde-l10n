#, no-c-format
msgid "The Bookmark Editor"
msgstr "书签编辑器"

#. Tag: author
#: index.docbook:14
#, no-c-format
msgid "&Pamela.Roberts;"
msgstr "&Pamela.Roberts;"

#. Tag: trans_comment
#: index.docbook:15
