msgstr "Vários slides-mestres"

#. (itstool) path: ul/li
#: org.kde.calligra.stage.metainfo.xml:18
msgid "Easily switch between slides during a presentation"
msgstr "Troca facilmente de slides durante uma apresentação"

#. (itstool) path: ul/li
