#~ "Plugin de agregação para o KTorrent, suportando fontes de notícias RSS e "
#~ "Atom"

#~ msgctxt "Name"
#~ msgid "UPnP"
#~ msgstr "UPnP"

#~ msgctxt "Comment"
#~ msgid "Forward ports using UPnP"
