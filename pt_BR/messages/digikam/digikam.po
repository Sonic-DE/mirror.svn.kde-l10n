msgid "A tool to preview items with OpenGL"
msgstr "Uma ferramenta para visualizar itens com o OpenGL"

#: core/dplugins/generic/view/glviewer/glviewerplugin.cpp:61
#, kde-format
msgid ""
"<p>This tool preview a series of items using OpenGL effects.</p><p><u>Usage:"
"</u></p><table><tr><td colspan=\"2\"><nobr><center><b><h1>Item Access</h1></"
"b></center></nobr></td></tr><tr><td>Previous Item:</td><td><i>Up</i> key</"
"td></tr><tr><td></td><td><i>PgUp</i> key</td></tr><tr><td></td><td><i>Left</"
"i> key</td></tr><tr><td></td><td>Mouse wheel up</td></tr><tr><td>Next Item:</"
"td><td><i>Down</i> key</td></tr><tr><td></td><td><i>PgDown</i> key</td></"
"tr><tr><td></td><td><i>Right</i> key</td></tr><tr><td></td><td>Mouse wheel "
"down</td></tr><tr><td>Quit:</td><td><i>Esc</i> key</td></tr><tr><td colspan="
"\"2\"><nobr><center><b><h1>Item Display</h1></b></center></nobr></td></"
"tr><tr><td>Toggle fullscreen to normal:</td><td><i>f</i> key</td></"
"tr><tr><td>Toggle scroll-wheel action:</td><td><i>c</i> key (either zoom or "
"change item)</td></tr><tr><td>Rotation:</td><td><i>r</i> key</td></"
"tr><tr><td>Reset view:</td><td>double click</td></tr><tr><td>Original size:</"
"td><td><i>o</i> key</td></tr><tr><td>Zooming:</td><td>Move mouse in up-down-"
"direction while pressing the right mouse button</td></tr><tr><td></"
"td><td><i>c</i> key and use the scroll-wheel</td></tr><tr><td></td><td><i>+</"
"i> and <i>-</i> keys</td></tr><tr><td></td><td>ctrl + scrollwheel</td></"
"tr><tr><td>Panning:</td><td>Move mouse while pressing the left button</td></"
"tr><tr><td colspan=\"2\"><nobr><center><b><h1>Others</h1></b></center></"
"nobr></td></tr><tr><td>Show this help:</td><td><i>F1</i> key</td></tr></"
"table>"
msgstr ""
"<p>Esta ferramenta visualiza uma série de itens usando efeitos OpenGL.</"
"p><p><u>Uso:</u></p><table><tr><td colspan=\"2\"><nobr><center><b><h1>Acesso "
"a itens</h1></b></center></nobr></td></tr><tr><td>Item anterior:</"
"td><td><i>Tecla para cima</i></td></tr><tr><td></td><td><i>Tecla PgUp</i></"
"td></tr><tr><td></td><td><i>Tecla para a esquerda</i></td></tr><tr><td></"
"td><td>Roda do mouse para cima</td></tr><tr><td>Próximo item:</"
"td><td><i>Tecla para baixo</i></td></tr><tr><td></td><td><i>PgDown</i> "
"tecla</td></tr><tr><td></td><td><i>Tecla direita</i></td></tr><tr><td></"
"td><td>Roda do mouse para baixo</td></tr><tr><td>Sair:</td><td><i>Tecla Esc</"
"i></td></tr><tr><td colspan=\"2\"><nobr><center><b><h1>Exibição de itens</"
"h1></b></center></nobr></td></tr><tr><td>Alternar tela cheia para normal:</"
"td><td><i>tecla f</i></td></tr><tr><td>Alternar ação da roda do mouse:</"
"td><td><i>tecla c</i> (ampliar ou alterar item)</td></tr><tr><td>Rotação:</"
"td><td><i>tecla r</i></td></tr><tr><td>Redefinir visualização:</"
"td><td>clique duplo</td></tr><tr><td>Tamanho original:</td><td><i>tecla o</"
"i></td></tr><tr><td>Zooming:</td><td>Mova o mouse para cima e para baixo "
"enquanto pressiona o botão direito do mouse</td></tr><tr><td></"
"td><td><i>tecla c</i> e use a roda de rolagem</td></tr><tr><td></td><td><i>"
"+</i> e <i>-</i></td></tr><tr><td></td><td>ctrl + roda de rolagem</td></"
"tr><tr><td>Panorâmica:</td><td>Mova o mouse enquanto pressiona o botão "
"esquerdo</td></tr><tr><td colspan=\"2\"><nobr><center><b><h1>Outros</h1></"
"b></center></nobr></td></tr><tr><td>Exibir esta ajuda:</td><td><i>Tecla F1</"
"i></td></tr></table>"

