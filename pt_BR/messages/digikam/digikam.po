#, kde-format
msgctxt "@item:inlistbox Noise Reduction"
msgid "FBDD"
msgstr "FBDD"

#: core/libs/rawengine/drawdecoderwidget.cpp:510
#, kde-kuit-format
msgctxt "@info:whatsthis"
msgid ""
"<title>Noise Reduction</title><para>Select here the noise reduction method "
"to apply during RAW decoding.</para><para><list><item><emphasis "
"strong='true'>None</emphasis>: no noise reduction.</item><item><emphasis "
"strong='true'>Wavelets</emphasis>: wavelets correction to erase noise while "
"preserving real detail. It is applied after interpolation.</"
"item><item><emphasis strong='true'>FBDD</emphasis>: Fake Before Demosaicing "
"Denoising noise reduction. It is applied before interpolation.</item></"
"list></para>"
msgstr ""
"<title>Redução de Ruído</title><para>Selecione aqui o método de redução de "
"ruído a ser aplicado durante a decodificação RAW.</"
"para><para><list><item><emphasis strong='true'>Nenhum</emphasis>: sem "
"redução de ruído.</item><item><emphasis strong='true'>Wavelets</emphasis>: "
"correção de wavelets para apagar ruído, preservando detalhes reais. É "
"aplicada após a interpolação.</item><item><emphasis strong='true'>FBDD</"
"emphasis>: redução de ruído com base no algoritmo Fake Before Demosaicing "
"Denoising. É aplicada antes da interpolação.</item></list></para>"

