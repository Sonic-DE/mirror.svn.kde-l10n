#: core/libs/facesengine/widgets/facescanwidget.cpp:105
#, kde-format
msgctxt "@label short translated text about the Face Workflow."
msgid "Workflow:"
msgstr "Fluxo de trabalho:"

#: core/libs/facesengine/widgets/facescanwidget.cpp:109
#, kde-format
msgctxt "@label:listbox"
msgid "Scan new images"
msgstr "Analisar novas imagens"

#: core/libs/facesengine/widgets/facescanwidget.cpp:110
#, kde-format
msgctxt "@label:listbox"
msgid "Scan all images"
msgstr "Analisar todas as imagens"

#: core/libs/facesengine/widgets/facescanwidget.cpp:111
#, kde-format
msgctxt "@label:listbox"
msgid "Recognize faces only"
msgstr "Reconhecer rostos somente"

#: core/libs/facesengine/widgets/facescanwidget.cpp:113
#, kde-format
msgctxt "@info:tooltip"
msgid ""
"digiKam can search for faces in your photos.<br>When you have identified "
"your friends on a number of photos,<br>it can also recognize the people "
"shown on your photos.<p><b>Scan new images</b> will scan for faces and "
"attempt recognition for new images found in the albums selected in the "
"\"Search in\" tab.</p><p><b>Scan all images</b> will scan for faces and "
"attempt recognition for all images found in the albums selected in the "
"\"Search in\" tab.</p><p><b>Recognize faces only</b> will try to match "
"unknown faces with confirmed faces without scanning images new faces.</p>"
msgstr ""
"O digiKam pode procurar rostos em suas fotos.<br>Depois de identificar seus "
"amigos em várias fotos,<br>ele também pode reconhecer as pessoas aparecendo "
"em suas fotos.<p><b>Analisar novas imagens</b> procurará rostos e tentará "
"reconhecer novas imagens encontradas nos álbuns selecionados na aba "
"\"Pesquisar em\".</p><p><b>Analisar todas as imagens</b> procurará rostos e "
"tentará reconhecer todas as imagens encontradas nos álbuns selecionados na "
"aba \"Procurar em\".</p><p><b>Reconhecer apenas rostos</b> tentará combinar "
"rostos desconhecidos com rostos confirmados sem escanear imagens com novos "
"rostos.</p>"

#: core/libs/facesengine/widgets/facescanwidget.cpp:131
#, kde-format
msgctxt "@label short translated text about the Face Detection Accuracy"
msgid "Accuracy:"
msgstr "Precisão:"

#: core/libs/facesengine/widgets/facescanwidget.cpp:138
#, kde-format
msgctxt "@info:tooltip"
msgid ""
"Adjust sensitivity versus specificity: the higher the value, the more "
"accurately faces will<br>be detected, but less faces will be detected."
msgstr ""
"Ajusta a sensibilidade versus especificidade: quanto maior o valor, mais "
"precisamente os rostos<br>serão detectados, mas menos rostos serão "
"detectados."

#: core/libs/facesengine/widgets/facescanwidget.cpp:143
#, kde-format
