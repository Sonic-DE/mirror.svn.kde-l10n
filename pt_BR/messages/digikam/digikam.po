#: core/dplugins/generic/tools/ocrtextconverter/textconverterplugin.cpp:65
#, kde-format
msgctxt "@info"
msgid ""
"This tool can convert documented images data to Text format by using "
"Tesseract, an open-source Optical Characters Recognition engine, originally "
"developed at HP labs and now sponsored by Google.<br><br>It supports "
"multiple languages and scripts (including right-to-left text) and page "
"layout analysis.<br><br>See details on %1 for more information on Tesseract"
msgstr ""
"Esta ferramenta pode converter dados de imagens de documentos para o formato "
"de texto usando o Tesseract, um mecanismo de reconhecimento óptico de "
"caracteres de código aberto, originalmente desenvolvido nos laboratórios da "
"HP e agora patrocinado pelo Google.<br><br>Ele suporta vários idiomas e "
"scripts (incluindo texto da direita para a esquerda) e análise de layout de "
"página.<br><br>Veja os detalhes em %1 para obter mais informações sobre o "
"Tesseract"

