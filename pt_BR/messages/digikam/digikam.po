msgstr "e convertê-la para o espaço de cor de trabalho"

#: core/utilities/setup/icc/setupicc.cpp:149
#, kde-format
msgid "Assume it is using the working color space"
msgstr "Assumir que está usando o espaço de cor de trabalho"

#. i18n("<p></p>"));
