#: core/utilities/setup/icc/setupicc.cpp:155
#, kde-format
msgid "Convert it from default input color space to working space"
msgstr ""
"Convertê-la do espaço de cor de entrada padrão para o espaço de trabalho"

#: core/utilities/setup/icc/setupicc.cpp:174
#, kde-format
msgid "When loading a RAW file with uncalibrated colors"
msgstr "Ao carregar um arquivo RAW com cores não calibradas"

#: core/utilities/setup/icc/setupicc.cpp:181
#, kde-format
msgid "Ask for the input profile"
msgstr "Perguntar pelo perfil de entrada"

#. i18n("<p></p>"));
