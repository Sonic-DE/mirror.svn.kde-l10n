msgstr ""
"Uma ferramenta para criar uma apresentações de slides em vídeo a partir de "
"imagens"

#: core/dplugins/generic/tools/videoslideshow/videoslideshowplugin.cpp:64
#, kde-format
msgid ""
"<p>This tool allows users to back-process image as frame to create video "
"slide-show.</p><p>Items to process can be selected one by one or by group "
"through a selection of albums.</p><p>Different visual effects can be applied "
"to images to make transitions while to render target video.</p>"
msgstr ""
"<p>Esta ferramenta permite que os usuários processem a imagem como um quadro "
"para criar uma apresentação de slides em vídeo.</p><p>Os itens a serem "
"processados podem ser selecionados um por um ou em grupo por meio de uma "
"seleção de álbuns.</p><p>Diferentes efeitos visuais podem ser aplicados às "
"imagens para fazer transições enquanto renderiza o vídeo de destino.</p>"

#: core/dplugins/generic/tools/videoslideshow/videoslideshowplugin.cpp:96
#, kde-format
msgctxt "@action"
msgid "Create video slideshow..."
msgstr "Criar apresentação em vídeo..."

#: core/dplugins/generic/tools/videoslideshow/vidslidefinalpage.cpp:130
#, kde-format
msgid "Starting to generate video slideshow..."
msgstr "Iniciando a geração da apresentação em vídeo..."

