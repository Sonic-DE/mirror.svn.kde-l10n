msgid "Spacebar"
msgstr "Spacebar"

#. (itstool) path: component/summary
#: org.kde.spacebar.appdata.xml:5
msgid "SMS/MMS messaging client"
msgstr "Cliente de mensagens SMS/MMS"

#. (itstool) path: description/p
#: org.kde.spacebar.appdata.xml:12
msgid ""
"Spacebar is a SMS/MMS messaging client. It allows you to send text messages, "
"pictures and other files over a cellular network."
msgstr ""
"O Spacebar é um cliente de mensagens SMS/MMS Ele permite que você envie "
"mensagens de texto, fotos e outros arquivos através de uma rede celular."

#~ msgid "KDE Community"
#~ msgstr "Comunidade KDE"

#~ msgid ""
#~ "Spacebar is a telepathy client for Plasma Mobile, that is primarily "
#~ "written for sending and receiving SMS/MMS."
#~ msgstr ""
#~ "O Spacebar é um cliente Telepathy para o Plasma Mobile, que é escrito "
#~ "principalmente para enviar e receber SMS/MMS."
