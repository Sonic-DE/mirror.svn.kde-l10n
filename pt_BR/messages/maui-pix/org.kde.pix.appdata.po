#: org.kde.pix.appdata.xml:7
msgid "Pix"
msgstr "Pix"

#. (itstool) path: component/summary
#: org.kde.pix.appdata.xml:8
msgid "Image Gallery"
msgstr "Galeria de imagens"

#. (itstool) path: description/p
#: org.kde.pix.appdata.xml:14
msgid ""
"Pix is an image gallery and image viewer. Pix can be used to open images "
"with other applications like an image editor, add tags to the files, add "
"annotations to pictures, rotate and share them."
msgstr ""
"O Pix é uma galeria e um visualizador de imagens. O Pix pode ser usado para "
"abrir imagens por meio de outros aplicativos como um editor de imagens, "
"adicionar tags aos seus arquivos, inserir anotações, rotacionar e "
"compartilhar suas imagens."

