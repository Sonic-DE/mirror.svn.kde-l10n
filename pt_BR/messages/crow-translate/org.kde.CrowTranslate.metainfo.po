#: org.kde.CrowTranslate.metainfo.xml:14
msgid "Application that allows you to translate and speak text using Mozhi"
msgstr "Aplicativo que permite traduzir e falar textos usando o Mozhi"

#. (itstool) path: description/p
#: org.kde.CrowTranslate.metainfo.xml:18
msgid ""
"Application written in C++ / Qt that allows you to translate and speak text "
"using Mozhi."
msgstr ""
"Aplicativo escrito em C++ / Qt que permite traduzir e falar texto usando o "
"Mozhi."

#. (itstool) path: description/p
#: org.kde.CrowTranslate.metainfo.xml:19
msgid "Features:"
msgstr "Funcionalidades:"

#. (itstool) path: ul/li
#: org.kde.CrowTranslate.metainfo.xml:21
msgid ""
"Multiple translation engines provided by Mozhi (some instances can disable "
"specific engines)*"
msgstr ""
"Vários mecanismos de tradução fornecidos pelo Mozhi (algumas instâncias "
"podem desabilitar mecanismos específicos)*"

