msgctxt "Description"
msgid "Send and receive SMS"
msgstr "Envia e recebe SMS"

#: plugins/systemvolume/kdeconnect_systemvolume.json
msgctxt "Description"
msgid "Enable volume to be controlled from the connected device"
msgstr "Permite que o volume seja controlado a partir do dispositivo conectado"

