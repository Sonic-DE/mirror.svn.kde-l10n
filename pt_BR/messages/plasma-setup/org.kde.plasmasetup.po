#: modules/finished/contents/ui/main.qml:34
#, kde-format
msgctxt "%1 is the distro name"
msgid ""
"Your device is now ready.<br /><br />After clicking <b>Finish</b> you will "
"be able to sign in to your new account.<br /><br />Enjoy <b>%1</b>!"
msgstr ""
"Seu dispositivo agora está pronto. <br /><br />Após clicar em <b>Concluir</"
"b>, você poderá entrar em sua nova conta.<br /><br />Aproveite <b>%1</b>!"

#: modules/hostname/contents/ui/main.qml:86
#, kde-format
msgctxt "@info:usagetip"
msgid "What should this device be called?"
msgstr "Qual deve ser o nome desse dispositivo?"

#: modules/hostname/contents/ui/main.qml:97
#, kde-format
msgctxt "@label:textbox"
msgid "Hostname:"
msgstr "Nome do host:"

#: modules/hostnameutil/hostnameutil.cpp:94
#, kde-format
msgctxt "@info"
msgid "Hostname cannot be empty."
msgstr "O nome do host não pode ser vazio."

#: modules/hostnameutil/hostnameutil.cpp:96
#, kde-format
msgctxt "@info"
msgid "Hostname cannot be “localhost” or “localhost.localdomain”."
msgstr "O nome do host não pode ser “localhost“ ou “localhost.localdomain“."

#: modules/hostnameutil/hostnameutil.cpp:98
#, kde-format
msgctxt "@info"
msgid "Hostname is too long (maximum 253 characters)."
msgstr "O nome do host é muito longo (máximo de 253 characters)."

#: modules/hostnameutil/hostnameutil.cpp:100
#, kde-format
msgctxt "@info"
msgid "Hostname cannot start with a dot."
msgstr "O nome do host não pode iniciar com um ponto."

#: modules/hostnameutil/hostnameutil.cpp:102
#, kde-format
msgctxt "@info"
msgid "Hostname cannot end with a dot."
msgstr "O nome do host não pode terminar com um ponto."

#: modules/hostnameutil/hostnameutil.cpp:104
#, kde-format
msgctxt "@info"
msgid "Hostname cannot contain consecutive dots."
msgstr "O nome do host não pode conter pontos consecutivos."

#: modules/hostnameutil/hostnameutil.cpp:106
#, kde-format
msgctxt "@info"
msgid "Hostname labels cannot be empty."
msgstr "Os rótulos de nome de host não podem estar vazios."

#: modules/hostnameutil/hostnameutil.cpp:108
#, kde-format
msgctxt "@info"
msgid "Each hostname label must be at most 63 characters."
msgstr "Cada rótulo de nome de host deve ter no máximo 63 caracteres."

#: modules/hostnameutil/hostnameutil.cpp:110
#, kde-format
msgctxt "@info"
msgid ""
"Hostnames may contain letters, numbers, and hyphens. Each label must start "
"and end with a letter or number."
msgstr ""
"Os nomes de host podem conter letras, números e hífenes. Cada rótulo deve "
"começar e terminar com uma letra ou um número."

