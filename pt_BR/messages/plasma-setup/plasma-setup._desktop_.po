#: files/plasma-setup.desktop.in:9 src/auth/org.kde.plasmasetup.actions:8
msgctxt "Name"
msgid "Plasma Setup"
msgstr "Configuração do Plasma"

#: files/plasma-setup.desktop.in:39
msgctxt "Comment"
msgid "Run the initial system setup for KDE"
msgstr "Executar a configuração inicial do sistema"

#: src/auth/org.kde.plasmasetup.actions:42
msgctxt "Name"
msgid "Create User"
msgstr "Criar usuário"

#: src/auth/org.kde.plasmasetup.actions:71
msgctxt "Description"
msgid "Create the initial user account"
msgstr "Cria a conta de usuário inicial"

#: src/auth/org.kde.plasmasetup.actions:103
msgctxt "Name"
msgid "Create Completion Flag File"
msgstr "Criar arquivo de marcador de completude"

#: src/auth/org.kde.plasmasetup.actions:131
msgctxt "Description"
msgid "Write the /etc/plasma-setup-done marker to prevent rerunning setup"
msgstr ""
"Escreve o marcador /etc/plasma-setup-done para prevenir a reexecução da "
"configuração"

#: src/auth/org.kde.plasmasetup.actions:162
msgctxt "Name"
msgid "Create New User Autostart Hook"
msgstr "Criar gancho de inicialização automática de novo usuário"

#: src/auth/org.kde.plasmasetup.actions:191
msgctxt "Description"
msgid "Create an autostart hook for the newly created user"
msgstr ""
"Criar um gancho de inicialização automática para o usuário recém-criado"

#: src/auth/org.kde.plasmasetup.actions:223
msgctxt "Name"
msgid "Remove Autologin"
msgstr "Remover o login automático"

#: src/auth/org.kde.plasmasetup.actions:252
msgctxt "Description"
msgid "Remove Display Manager autologin configuration"
msgstr "Remover configuração de login automático do gerenciador de login"

#: src/auth/org.kde.plasmasetup.actions:282
msgctxt "Name"
msgid "Set New User Global Theme"
msgstr "Definir novo tema global do usuário"

#: src/auth/org.kde.plasmasetup.actions:311
msgctxt "Description"
msgid "Set the global theme for the new user"
msgstr "Definir o tema global para o novo usuário"

#: src/auth/org.kde.plasmasetup.actions:343
msgctxt "Name"
msgid "Set New User Display Scaling"
msgstr "Definir nova escala de exibição do usuário"

#: src/auth/org.kde.plasmasetup.actions:372
msgctxt "Description"
msgid "Set display scaling for the new user"
msgstr "Definir escala de exibição para o novo usuário"

#: src/auth/org.kde.plasmasetup.actions:404
msgctxt "Name"
msgid "Set New User Home Directory Ownership"
msgstr "Definir propriedade do diretório inicial do novo usuário"

#: src/auth/org.kde.plasmasetup.actions:433
msgctxt "Description"
msgid "Set ownership of the new users home directory to the newly created user"
msgstr ""
"Definir a propriedade do diretório inicial (home) dos novos usuários para o "
"usuário recém-criado"

#: src/auth/org.kde.plasmasetup.actions:465
msgctxt "Name"
msgid "Set New User Temporary Autologin"
msgstr "Definir login automático temporário para novo usuário"

#: src/auth/org.kde.plasmasetup.actions:494
msgctxt "Description"
msgid ""
"Set display manager temporary autologin configuration for the newly created "
"user"
msgstr ""
"Definir a configuração de login automático temporário do gerenciador de "
"login para o usuário recém-criado"

#~ msgctxt "Name"
#~ msgid "Disable Systemd Unit"
#~ msgstr "Desabilitar unidade do systemd"

#~ msgctxt "Description"
#~ msgid "Disable the systemd unit for Plasma Setup"
#~ msgstr "Desabilitar a unidade systemd para a configuração do Plasma"

#~ msgctxt "Name"
#~ msgid "KDE Initial System Setup"
#~ msgstr "Configuração inicial do sistema"
