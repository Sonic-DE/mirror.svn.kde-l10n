#. (itstool) path: component/name
#: org.kde.dragonplayer.appdata.xml:9
msgid "Dragon Player"
msgstr "Dragon Player"

#. (itstool) path: component/summary
#: org.kde.dragonplayer.appdata.xml:10
msgid "Play video files and streams"
msgstr "Reproduz arquivos e transmissões de vídeo"

#. (itstool) path: description/p
#: org.kde.dragonplayer.appdata.xml:12
msgid ""
"Dragon Player is a video player focusing on simplicity instead of features. "
"Its easy-to-use interface is designed to get out of your way and simply play "
"your video files and streams."
msgstr ""
"O Dragon Player é um reprodutor de vídeo que prioriza a simplicidade em vez "
"de recursos. Sua interface fácil de usar foi projetada para facilitar a "
"reprodução de seus arquivos e transmissões de vídeo."

#. (itstool) path: description/p
#: org.kde.dragonplayer.appdata.xml:15
msgid "Features:"
msgstr "Funcionalidades:"

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:17
msgid ""
"Click to play or pause, and double-click to enter or exit full screen mode."
msgstr ""
"Clique para reproduzir ou pausar e clique duas vezes para entrar ou sair do "
"modo de tela cheia."

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:18
msgid ""
"Choose the subtitle language, and automatically load the right one for your "
"language, if possible."
msgstr ""
"Selecione o idioma da legenda e carregue automaticamente o correto para o "
"seu idioma, se possível."

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:19
msgid "Choose the audio track."
msgstr "Selecione a faixa de áudio."

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:20
msgid "Choose the video track."
msgstr "Selecione a faixa de vídeo."

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:21
msgid "Adjust the volume by scrolling."
msgstr "Ajuste o volume rolando o mouse."

#~ msgid "Video player with focus on simplicity"
#~ msgstr "Reprodutor de vídeo com foco na simplicidade"

#~ msgid "Simple Interface"
#~ msgstr "Interface simples"

#~ msgid ""
#~ "Resuming videos: Starts playing a video where you were watching it last "
#~ "time"
#~ msgstr ""
#~ "Continuação da reprodução de vídeos: Começa a reprodução de um vídeo no "
#~ "ponto em que parou de assistir"

#~ msgid ""
#~ "Support for subtitles: Automatically loads subtitles with the matching "
#~ "name"
#~ msgstr ""
#~ "Suporte a legendas: Carrega as legendas com o nome correspondente de "
#~ "forma automática"

#~ msgid "Video display settings (brightness, contrast)"
#~ msgstr "Configuração da exibição de vídeo (brilho, contraste)"

#~ msgid ""
#~ "Due to using Solid and Phonon DragonPlayer is independent of any "
#~ "multimedia framework or hardware abstraction layer"
#~ msgstr ""
#~ "Devido ao uso do Solid e Phonon, o Dragon Player independe de qualquer "
#~ "plataforma multimídia ou camada de abstração de hardware"

#~ msgid "Supports playing CDs and DVDs"
#~ msgstr "Suporte a reprodução de CDs e DVDs"
