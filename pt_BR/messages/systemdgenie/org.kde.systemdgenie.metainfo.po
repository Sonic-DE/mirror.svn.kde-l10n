msgid "systemdGenie"
msgstr "systemdGenie"

#. (itstool) path: component/summary
#: org.kde.systemdgenie.metainfo.xml:12
msgid "System service manager"
msgstr "Gerenciador de serviços do sistema"

#. (itstool) path: description/p
#: org.kde.systemdgenie.metainfo.xml:14
msgid ""
"systemdGenie allows graphical management of systemd units, including user "
"units, and provides control over logind sessions. It also includes an "
"integrated text editor for easy modification of unit and configuration files."
msgstr ""
"O systemdGenie permite o gerenciamento gráfico de unidades systemd, "
"incluindo unidades de usuário, e fornece controle sobre sessões de logind. "
"Ele também inclui um editor de texto integrado para facilitar a modificação "
"de unidades e arquivos de configuração."
