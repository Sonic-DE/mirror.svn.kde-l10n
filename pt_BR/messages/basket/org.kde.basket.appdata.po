#. (itstool) path: component/name
#: org.kde.basket.appdata.xml:10
msgid "Basket"
msgstr "Basket"

#. (itstool) path: component/summary
#: org.kde.basket.appdata.xml:11
msgid "Notes and to-dos organizer"
msgstr "Organizador de notas e tarefas"

#. (itstool) path: description/p
#: org.kde.basket.appdata.xml:13
msgid ""
"This application provides as many baskets as you wish, and you can drag and "
"drop."
msgstr ""
"Este aplicativo fornece quantas cestas você desejar, e você pode arrastar e "
"soltar."

#. (itstool) path: description/p
#: org.kde.basket.appdata.xml:14
msgid ""
"Objects can be edited, copied, dragged... So, you can arrange them as you "
"want !"
msgstr ""
"Os objetos podem ser editados, copiados, arrastados... Então, você pode "
"organizá-los como quiser!"

#. (itstool) path: description/p
#: org.kde.basket.appdata.xml:15
msgid "It allows to arrange notes, track to-dos and much more."
msgstr "Permite organizar notas, acompanhar tarefas e muito mais."

#~ msgid "KDE Community"
#~ msgstr "Comunidade KDE"
