#. (itstool) path: component/name
#: org.kde.gwenview.appdata.xml:9
msgid "Gwenview"
msgstr "Gwenview"

#. (itstool) path: component/summary
#: org.kde.gwenview.appdata.xml:10
msgid "Image Viewer"
msgstr "Visualizador de imagens"

#. (itstool) path: description/p
#: org.kde.gwenview.appdata.xml:12
msgid ""
"Gwenview is a fast and easy to use image viewer by KDE, ideal for browsing "
"and displaying a collection of images."
msgstr ""
"Gwenview é um visualizador de imagens rápido e fácil de usar, da KDE, ideal "
"para navegar e exibir uma coleção de imagens."

#. (itstool) path: description/p
#: org.kde.gwenview.appdata.xml:15
msgid "Features:"
msgstr "Funcionalidades:"

#. (itstool) path: ul/li
#: org.kde.gwenview.appdata.xml:17
msgid ""
"Simple image editing: rotate, crop, resize, mirror, flip, reduce red eye, "
"and adjust brightness, contrast, or gamma"
msgstr ""
"Edição de imagem simples: girar, cortar, redimensionar, espelhar, inverter, "
"reduzir olhos vermelhos e ajustar brilho, contraste ou gama"

#. (itstool) path: ul/li
#: org.kde.gwenview.appdata.xml:18
msgid ""
"Annotate and mark up images with arrows, shapes, text boxes, image stamps, "
"and more"
msgstr ""
"Anotar e marcar imagens com setas, formas, caixas de texto, carimbos de "
"imagem e muito mais"

#. (itstool) path: ul/li
#: org.kde.gwenview.appdata.xml:19
msgid "Basic file management actions such as copy, move, delete, and others"
msgstr ""
"Ações básicas de gerenciamento de arquivos, como copiar, mover, excluir "
"entre outras"

#. (itstool) path: screenshot/caption
#: org.kde.gwenview.appdata.xml:29
msgid "Main application window displaying an image and controls on the left"
msgstr ""
"Janela principal do aplicativo exibindo uma imagem e controles à esquerda"

#. (itstool) path: screenshot/caption
#: org.kde.gwenview.appdata.xml:33
msgid "Use Gwenview to manage your image collection"
msgstr "Use o Gwenview para gerenciar sua coleção de imagens"

#~ msgid ""
#~ "Functions both as a standalone application and an embedded viewer in the "
#~ "Konqueror web browser"
#~ msgstr ""
#~ "Funciona tanto como um aplicativo independente quanto como visualizador "
#~ "incorporado ao navegador web Konqueror"

#~ msgid ""
#~ "Supports simple image manipulations: rotate, mirror, flip, and resize"
#~ msgstr ""
#~ "Suporta manipulações simples de imagens: rotação, espelhamento, inversão "
#~ "e redimensionamento"

#~ msgid ""
#~ "Gwenview displaying an image, with additional metadata shown in the "
#~ "sidebar"
#~ msgstr ""
#~ "O Gwenview exibindo uma imagem com os metadados adicionais visíveis na "
#~ "barra lateral"

#~ msgid "Can be extended using KIPI plugins."
#~ msgstr "Pode ter suas funcionalidades ampliadas com os plugins do KIPI."
