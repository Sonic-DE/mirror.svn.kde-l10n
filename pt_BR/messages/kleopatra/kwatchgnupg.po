#: kwatchgnupgmainwin.cpp:110
#, kde-format
msgid ""
"The watchgnupg logging program could not be found.\n"
"Please make sure that watchgnupg is installed."
msgstr ""
"O programa de registro watchgnupg não foi encontrado.\n"
"Certifique-se de que o watchgnupg esteja instalado."

#: kwatchgnupgmainwin.cpp:111 kwatchgnupgmainwin.cpp:121
#, kde-format
msgid "[%1] Failed to start %2"
msgstr "[%1] Falhou ao iniciar %2"

#: kwatchgnupgmainwin.cpp:120
#, kde-format
msgid ""
"The watchgnupg logging process could not be started.\n"
"Please make sure that watchgnupg is installed properly."
msgstr ""
"O processo de registro do watchgnupg não pode ser iniciado.\n"
"Certifique-se de que o watchgnupg esteja instalado corretamente."

#: kwatchgnupgmainwin.cpp:125
#, kde-format
msgid "[%1] Log started"
msgstr "[%1] Registro iniciado"

#: kwatchgnupgmainwin.cpp:134
#, kde-format
msgid ""
"The watchgnupg logging process died.\n"
"Do you want to try to restart it?"
msgstr ""
"O processo de registro do watchgnupg foi encerrado.\n"
"Deseja tentar reiniciá-lo?"

#: kwatchgnupgmainwin.cpp:136
#, kde-format
msgctxt "@action:button"
msgid "Try Restart"
msgstr "Tentar reiniciá-lo"

#: kwatchgnupgmainwin.cpp:137
#, kde-format
msgctxt "@action:button"
msgid "Do Not Try"
msgstr "Não tentar"

#: kwatchgnupgmainwin.cpp:139
#, kde-format
msgid "====== Restarting logging process ====="
msgstr "====== Reiniciando processo de registro ====="

#: kwatchgnupgmainwin.cpp:143
#, kde-format
msgid ""
"The watchgnupg logging process is not running.\n"
"This log window is unable to display any useful information."
msgstr ""
"O processo de registro watchgnupg não está em execução.\n"
"Esta janela de registro não mostrará qualquer informação útil."

