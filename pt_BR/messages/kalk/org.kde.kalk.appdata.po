msgid "Fix bug preventing input of comma"
msgstr "Corrigido bug que impedia a inserção de vírgula"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:104
msgid "General bugfixing and code quality improvements"
msgstr "Correção geral de erros e melhorias na qualidade do código"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:112
msgid "Rearrange trigonometric functions to be together"
msgstr "Reorganização das funções trigonométricas para que fiquem juntas"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:113
msgid "Various user-interface improvements"
msgstr "Diversas melhorias na interface do usuário"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:120
msgid "Rework sidebar design"
msgstr "Reformulação do design da barra lateral"

