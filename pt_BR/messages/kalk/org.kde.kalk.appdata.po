#: org.kde.kalk.appdata.xml:133
msgid "Changes:"
msgstr "Alterações:"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:135
msgid "Updated the application icon"
msgstr "Ícone do aplicativo atualizado"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:136
msgid "Added support for parentheses keyboard input"
msgstr "Adicionado suporte para inserção de parênteses pelo teclado"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:137
msgid "Fixed the calculator drawer opening when the application opens"
msgstr ""
"Corrigido o problema que fazia com que a gaveta da calculadora abrisse ao "
"iniciar o aplicativo"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:138
msgid ""
"Changed backspace icon to use a proper system icon instead of a font "
"provided one"
msgstr ""
"Alterado o ícone da tecla Backspace para usar um ícone apropriado do sistema "
"em vez de um fornecido pela fonte"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:139
msgid "Added keyboard support to unit converter"
msgstr "Adicionado suporte para teclado ao conversor de unidades"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:140
msgid "Fixed page change animation for binary calculator"
msgstr "Correção da animação de mudança de página para a calculadora binária"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:141
msgid "Enabled qml debugging when compiled in debug mode"
msgstr "Ativada a depuração do QML quando compilado no modo de depuração"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:142
