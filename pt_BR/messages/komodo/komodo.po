#: src/main.cpp:49
#, kde-format
msgctxt "Longer description in about page"
msgid ""
"<p>KomoDo is a todo manager that uses todo.txt specification. It parses any "
"compliant todo.txt files and turns them into easy to use list of tasks.</p>"
msgstr ""
"<p>O KomoDo é um gerenciador de tarefas que utiliza a especificação todo."
"txt. Ele analisa qualquer arquivo todo.txt compatível e o transforma em uma "
"lista de tarefas fácil de usar.</p>"

