msgctxt "Name"
msgid "Cannot bookmark printer"
msgstr "Não foi possível marcar a impressora como favorita"

#: core/smb4k.notifyrc:1403
msgctxt "Comment"
msgid "A printer cannot be bookmarked"
msgstr "Não foi possível adicionar uma impressora aos favoritos"

#: core/smb4k.notifyrc:1446
msgctxt "Name"
msgid "File not found"
msgstr "Arquivo não encontrado"

#: core/smb4k.notifyrc:1487
msgctxt "Comment"
msgid "A file could not be found"
msgstr "Não foi possível encontrar um arquivo"

#: core/smb4k.notifyrc:1530
msgctxt "Name"
msgid "Opening file failed"
msgstr "Ocorreu uma falha ao abrir o arquivo"

#: core/smb4k.notifyrc:1568
msgctxt "Comment"
msgid "A file could not be opened"
msgstr "O arquivo não pode ser aberto"

#: core/smb4k.notifyrc:1611
msgctxt "Name"
msgid "Reading file failed"
msgstr "Falha na leitura do arquivo"

#: core/smb4k.notifyrc:1649
msgctxt "Comment"
msgid "A file could not be read"
msgstr "Não foi possível ler um arquivo"

#: core/smb4k.notifyrc:1692
msgctxt "Name"
msgid "mkdir failed"
msgstr "Erro na criação da pasta"

#: core/smb4k.notifyrc:1731
msgctxt "Comment"
msgid "A directory could not be created"
msgstr "Não foi possível criar uma pasta"

#: core/smb4k.notifyrc:1774
msgctxt "Name"
msgid "Process error"
msgstr "Erro no processo"

#: core/smb4k.notifyrc:1814
msgctxt "Comment"
msgid "A process error occurred"
msgstr "Ocorreu um erro no processo"

#: core/smb4k.notifyrc:1857
msgctxt "Name"
msgid "Action failed"
msgstr "Ação com falhas"

#: core/smb4k.notifyrc:1897
msgctxt "Comment"
msgid "A KAuth action failed"
msgstr "Ocorreu uma falha na ação do KAuth"

#: core/smb4k.notifyrc:1939
msgctxt "Name"
msgid "Invalid URL"
msgstr "URL inválida"

#: core/smb4k.notifyrc:1980
msgctxt "Comment"
msgid "An invalid URL was passed"
msgstr "Foi passada uma URL inválida"

#: core/smb4k.notifyrc:2022
msgctxt "Name"
msgid "Network communication failed"
msgstr "Falha na comunicação de rede"

#: core/smb4k.notifyrc:2057
msgctxt "Comment"
msgid "A network related action could not be performed or failed"
msgstr "Uma ação relacionada à rede não pode ser executada ou falhou"

#: core/smb4k.notifyrc:2097
msgctxt "Name"
msgid "Zeroconf error"
msgstr "Erro no Zeroconf"

#: core/smb4k.notifyrc:2130
msgctxt "Comment"
msgid "An error with the Zeroconf daemon occurred"
msgstr "Ocorreu um erro com o servidor Zeroconf"

#: core/smb4k.notifyrc:2167
msgctxt "Name"
msgid "Keychain error"
msgstr "Erro no Keychain"

#: core/smb4k.notifyrc:2196
msgctxt "Comment"
msgid ""
"An error occurred while reading the login credentials from the secure storage"
msgstr "Ocorreu um erro ao ler as credenciais de login do armazenamento seguro"

#: helpers/smb4kmounthelper.actions:2
msgctxt "Name"
msgid "Mount action"
msgstr "Ação de montagem"

#: helpers/smb4kmounthelper.actions:39
msgctxt "Description"
msgid "Mounts a share"
msgstr "Monta um compartilhamento"

#: helpers/smb4kmounthelper.actions:80
msgctxt "Name"
msgid "Unmount action"
msgstr "Ação de desmontagem"

#: helpers/smb4kmounthelper.actions:117
msgctxt "Description"
msgid "Unmounts a share"
msgstr "Desmonta um compartilhamento"

