#: org.kde.kjournaldbrowser.appdata.xml:14
msgid "Journald Browser"
msgstr "Navegador do journald"

#. (itstool) path: component/summary
#: org.kde.kjournaldbrowser.appdata.xml:15
msgid "Browser for journald databases"
msgstr "Navegador para os bancos de dados journald"

#. (itstool) path: description/p
#: org.kde.kjournaldbrowser.appdata.xml:17
msgid ""
"Journald-browser is a reference implementation of the kjournald library and "
"provides a flexible tool to browse in local, remote and offline journald "
"databases."
msgstr ""
"O Journald-browser é uma implementação de referência da biblioteca kjournald "
"e fornece uma ferramenta flexível para navegar nos bancos de dados local, "
"remoto e offline."

