#: org.kde.pumoku.metainfo.xml:12
msgid "A classic 9 × 9 sudoku game"
msgstr "Um clássico jogo de Sudoku 9x9"

#. (itstool) path: description/p
#: org.kde.pumoku.metainfo.xml:28
msgid ""
"PuMoKu is a classic, 9 × 9 Sudoku solving game aimed for Plasma Mobile. It "
"comes with flexible highlighting options and (touch) input methods, full "
"undo stack and more."
msgstr ""
"PuMoKu é um jogo clássico de resolução de pumoku 9x9 para dispositivos "
"Plasma Mobile. Ele oferece opções flexíveis de destaque de texto e métodos "
"de entrada (por toque), funcionalidade completa de desfazer e muito mais."

#. (itstool) path: ul/li
#: org.kde.pumoku.metainfo.xml:30
msgid "Input methods: Cell first, Number first or Hybrid"
msgstr "Métodos de entrada: Célula primeiro, Número primeiro ou Híbrido"

#. (itstool) path: ul/li
#: org.kde.pumoku.metainfo.xml:31
