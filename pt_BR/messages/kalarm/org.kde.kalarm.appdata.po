#. (itstool) path: component/name
#: org.kde.kalarm.appdata.xml:6
msgid "KAlarm"
msgstr "KAlarm"

#. (itstool) path: component/summary
#: org.kde.kalarm.appdata.xml:7
msgid "Personal Alarm Scheduler"
msgstr "Agendador de alarme pessoal"

#. (itstool) path: description/p
#: org.kde.kalarm.appdata.xml:13
msgid ""
"KAlarm is a personal alarm message, command and email scheduler application "
"by KDE"
msgstr ""
"O KAlarm é um aplicativo agendador pessoal de mensagens de alarme, comandos "
"e e-mails do KDE"

#. (itstool) path: description/p
#: org.kde.kalarm.appdata.xml:14
msgid "Features:"
msgstr "Funcionalidades:"

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:16
msgid ""
"Display alarms using your own text message, the text generated by a command, "
"or a text or image file."
msgstr ""
"Mostra os alarmes usando sua própria mensagem de texto, o texto gerado por "
"um comando ou um arquivo de texto ou de imagem."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:17
msgid "Audible alarm using a sound file"
msgstr "Alarme sonoro usando um arquivo de som"

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:18
msgid ""
"Recurring alarm on an hours/minutes, daily, weekly, monthly or annual basis, "
"or set it to trigger every time you log in."
msgstr ""
"Alarmes que se repetem com frequência de minutos, horas, diário, semanal, "
"mensal ou anual, ou ainda com possibilidade de ser acionado a cada vez que "
"inicia uma sessão."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:19
msgid "Display alarms color and font customization"
msgstr "Mostra alarmes com cores e fontes personalizadas"

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:20
msgid ""
"Support for multiple alarm calendars, which for example enables you to share "
"alarms between a laptop and desktop computer."
msgstr ""
"Suporte a diversos calendários de alarmes, permitindo-lhe, por exemplo, "
"compartilhar alarmes entre um notebook e um computador pessoal."

#. (itstool) path: screenshot/caption
#: org.kde.kalarm.appdata.xml:30
msgid "KAlarm configuration window with a testing message alarm"
msgstr "Janela de configuração do KAlarm com uma mensagem de teste de alarme"

