#: index.docbook:74
#, no-c-format
msgid "&kget; Drop Target"
msgstr "Alvo de transferência do &kget;"

#. Tag: para
#: index.docbook:76
#, no-c-format
msgid "The &kget; Drop Target has four options."
msgstr "O alvo de transferência do &kget; possui quatro opções."

#. Tag: screeninfo
#: index.docbook:81
#, no-c-format
msgid "<screeninfo>Screenshot of &kget; drop target</screeninfo>"
msgstr "<screeninfo>Imagem do alvo de transferência do &kget;</screeninfo>"

