#~ "(Power user mode)"
#~ msgstr ""
#~ "<menuchoice> <shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;"
#~ "<keycap>B</keycap></keycombo> </shortcut> <guimenu>Editar</"
