"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>Q</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Quit</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>Q</keycap></keycombo> </"
"shortcut> <guimenu>Arquivo</guimenu> <guimenuitem>Sair</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:333
#, no-c-format
msgid ""
"Closes &krusader; and cleans up the temporary folder, the same as pressing "
"<keycap>F10</keycap> key."
msgstr ""
"Fecha o &krusader; e limpa a pasta temporária; é equivalente a usar a tecla "
"<keycap>F10</keycap>."

