msgstr ""
"Opções avançadas para o painel de árvore na <link linkend=\"sidebar\">Barra "
"lateral</link>."

#. Tag: title
#: features.docbook:496
#, no-c-format
msgid "New features in the &krusader;-2.8.0 <quote>A New Day</quote> release"
msgstr ""
"Novas funcionalidades na versão &krusader;-2.8.0 <quote>Um novo dia</quote>"

#. Tag: para
#: features.docbook:499
#, no-c-format
msgid "Duplicating tabs with double click."
msgstr "Duplicar abas com um clique duplo."

#. Tag: para
#: features.docbook:503
#, no-c-format
msgid "Closing tabs with &Ctrl;+&LMB; or &Alt;+&LMB; (configurable)."
msgstr "Fechar abas com &Ctrl;+&LMB; ou &Alt;+&LMB; (configurável)."

#. Tag: para
#: features.docbook:507
#, no-c-format
msgid "Undoing the closed tabs while the app is running."
msgstr "Desfazer a abertura de abas enquanto o aplicativo está em execução."

