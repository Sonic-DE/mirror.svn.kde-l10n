#. Tag: title
#: diskusage.docbook:8
#, no-c-format
msgid "<title>Disk Usage</title>"
msgstr "<title>Utilização do Disco</title>"

#. Tag: primary
#: diskusage.docbook:10
#, no-c-format
msgid "<primary>Disk Usage</primary>"
msgstr "<primary>Utilização do Disco</primary>"

#. Tag: para
#: diskusage.docbook:12
#, no-c-format
msgid ""
"The Disk Usage is based on the code of &filelight;. The Disk Usage shows you "
"how your disk space is being used by a graphical representation of your file "
"system. The following presentations are possible:"
msgstr ""
"A Utilização do Disco baseia-se no código do &filelight;. A Utilização do "
"Disco mostra como o seu espaço em disco está sendo usado, com base numa "
"representação gráfica do seu sistema de arquivos. São possíveis as seguintes "
"apresentações:"

#. Tag: para
#: diskusage.docbook:18
#, no-c-format
msgid "Line view"
msgstr "Visualização em linha"

#. Tag: para
#: diskusage.docbook:21
#, no-c-format
msgid "Detailed view"
msgstr "Visualização detalhada"

#. Tag: para
#: diskusage.docbook:24
#, no-c-format
msgid ""
"<application>Filelight</application> view: as a set of concentric segmented-"
"rings"
msgstr ""
"Vista do <application>Filelight</application>: como um conjunto de anéis "
"segmentados e concêntricos"

#. Tag: para
#: diskusage.docbook:28
#, no-c-format
msgid ""
"Choose <menuchoice> <guimenu>Tools</guimenu> <guimenuitem>Disk Usage...</"
"guimenuitem> </menuchoice> or <keycombo action=\"simul\">&Alt;&Shift; "
"<keycap>S</keycap></keycombo> to start this feature in a separate window, or "
"open it inside the <link linkend=\"sidebar\">Sidebar</link>."
msgstr ""
"Escolha a opção <menuchoice> <guimenu>Ferramentas</guimenu> "
"<guimenuitem>Utilização do Disco...</guimenuitem> </menuchoice> ou <keycombo "
"action=\"simul\">&Alt;&Shift; <keycap>S</keycap></keycombo> para iniciar "
"esta funcionalidade numa janela separada, ou abra-a dentro da <link linkend="
"\"sidebar\">Barra lateral</link>."

#. Tag: para
#: diskusage.docbook:38
#, no-c-format
msgid "Disk Usage Keybindings, right click menu."
msgstr "Combinações de teclas da Utilização do disco; menu do botão direito."

#. Tag: para
#: diskusage.docbook:41
#, no-c-format
msgid "<keycap>Del</keycap>: Delete"
msgstr "<keycap>Del</keycap>: Apagar"

#. Tag: para
#: diskusage.docbook:45
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Ctrl; <keycap>E</keycap></keycombo>: Exclude"
msgstr ""
"<keycombo action=\"simul\">&Ctrl; <keycap>E</keycap></keycombo>: Excluir"

#. Tag: para
#: diskusage.docbook:50
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Shift; <keycap>Arrow Up</keycap></keycombo>: Up "
"one folder"
msgstr ""
"<keycombo action=\"simul\">&Shift; <keycap>Cima</keycap></keycombo>: Sobe "
"uma pasta"

#. Tag: para
#: diskusage.docbook:55
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Ctrl; <keycap>N</keycap></keycombo>: new search"
msgstr ""
"<keycombo action=\"simul\">&Ctrl; <keycap>N</keycap></keycombo>: nova "
"pesquisa"

#. Tag: para
#: diskusage.docbook:60
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Ctrl; <keycap>R</keycap></keycombo>: refresh"
msgstr ""
"<keycombo action=\"simul\">&Ctrl; <keycap>R</keycap></keycombo>: atualizar"

#. Tag: para
#: diskusage.docbook:65
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Ctrl; <keycap>I</keycap></keycombo>: include all"
msgstr ""
"<keycombo action=\"simul\">&Ctrl; <keycap>I</keycap></keycombo>: incluir tudo"

#. Tag: para
#: diskusage.docbook:70
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Shift; <keycap>Arrow Down</keycap></keycombo>: "
"step into"
msgstr ""
"<keycombo action=\"simul\">&Shift; <keycap>Baixo</keycap></keycombo>: entrar"

#. Tag: para
#: diskusage.docbook:75
#, no-c-format
msgid "View menu:"
msgstr "Menu Ver:"

#. Tag: para
#: diskusage.docbook:78
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Ctrl; <keycap>L</keycap></keycombo>: Line view"
msgstr ""
"<keycombo action=\"simul\">&Ctrl; <keycap>L</keycap></keycombo>: Vista em "
"linhas"

#. Tag: para
#: diskusage.docbook:83
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Ctrl; <keycap>D</keycap></keycombo>: Detailed "
"view"
msgstr ""
"<keycombo action=\"simul\">&Ctrl; <keycap>D</keycap></keycombo>: Vista "
"detalhada"

#. Tag: para
#: diskusage.docbook:88
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Ctrl; <keycap>F</keycap></keycombo>: Filelight "
"view"
msgstr ""
"<keycombo action=\"simul\">&Ctrl; <keycap>F</keycap></keycombo>: vista do "
"Filelight"

#. Tag: para
#: diskusage.docbook:93
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Shift; <keycap>Arrow Right</keycap></keycombo>: "
"Next view"
msgstr ""
"<keycombo action=\"simul\">&Shift; <keycap>Direita</keycap></keycombo>: "
"Vista seguinte"

#. Tag: para
#: diskusage.docbook:98
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Shift; <keycap>Arrow Left</keycap></keycombo>: "
"Previous view"
msgstr ""
"<keycombo action=\"simul\">&Shift; <keycap>Esquerda</keycap></keycombo>: "
"Vista anterior"
