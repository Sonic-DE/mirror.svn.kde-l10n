#. Tag: title
#: index.docbook:72
#, no-c-format
msgid "Gametype:"
msgstr "Tipo de jogo:"

#. Tag: para
#: index.docbook:72
#, no-c-format
msgid "Strategy, Board"
msgstr "Estratégia, tabuleiro"

#. Tag: title
#: index.docbook:73
#, no-c-format
msgid "Number of possible players:"
