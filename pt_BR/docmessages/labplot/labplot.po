"accurate for small x"
msgstr ""
"2(exp(x)-1-x)/x<superscript>2</superscript>, usando um algoritmo de precisão "
"para um x pequeno"

#. Tag: entry
#: index.docbook:1899
#, no-c-format
msgid "expreln(n,x)"
msgstr "expreln(n,x)"

#. Tag: action
#: index.docbook:1899
#, no-c-format
msgid ""
"n-relative exponential, which is the n-th generalization of the functions "
"`exprel'"
msgstr ""
"Exponencial em relação a 'n', o que é a n-ésima generalização da função "
"'exprel'"

#. Tag: entry
#: index.docbook:1900
#, no-c-format
msgid "E1(x)"
msgstr "E1(x)"

#. Tag: action
#: index.docbook:1900
#, no-c-format
msgid ""
"exponential integral E<subscript>1</subscript>(x), E<subscript>1</"
"subscript>(x) := Re &int;<subscript>1</subscript><superscript>&infin;</"
"superscript> exp(-xt)/t dt"
msgstr ""
"Integral da exponencial E<subscript>1</subscript>(x), E<subscript>1</"
"subscript>(x) := Re &int;<subscript>1</subscript><superscript>&infin;</"
"superscript> exp(-xt)/t dt"

#. Tag: entry
#: index.docbook:1901
#, no-c-format
msgid "E2(x)"
msgstr "E2(x)"

#. Tag: action
#: index.docbook:1901
#, no-c-format
msgid ""
"second-order exponential integral E<subscript>2</subscript>(x), "
"E<subscript>2</subscript>(x) := Re &int;<subscript>1</"
"subscript><superscript>&infin;</superscript> exp(-xt)/t<superscript>2</"
"superscript> dt"
msgstr ""
"Integral da exponencial de segunda ordem E<subscript>2</subscript>(x), "
"E<subscript>2</subscript>(x) := Re &int;<subscript>1</"
"subscript><superscript>&infin;</superscript> exp(-xt)/t<superscript>2</"
"superscript> dt"

#. Tag: entry
#: index.docbook:1902
#, no-c-format
msgid "En(x)"
msgstr "En(x)"

#. Tag: action
#: index.docbook:1902
#, no-c-format
msgid ""
"exponential integral E_n(x) of order n, E<subscript>n</subscript>(x) := Re "
"&int;<subscript>1</subscript><superscript>&infin;</superscript> exp(-xt)/"
"t<superscript>n</superscript> dt)"
msgstr ""
"Integral da exponencial de n-ésima ordem E_n(x), E<subscript>n</"
"subscript>(x) := Re &int;<subscript>1</subscript><superscript>&infin;</"
"superscript> exp(-xt)/t<superscript>n</superscript> dt)"

#. Tag: entry
#: index.docbook:1903
#, no-c-format
msgid "Ei(x)"
msgstr "Ei(x)"

#. Tag: action
#: index.docbook:1903
#, no-c-format
msgid ""
"exponential integral E_i(x), Ei(x) := PV(&int;<subscript>-x</"
"subscript><superscript>&infin;</superscript> exp(-t)/t dt)"
msgstr ""
"Integral da exponencial E_i(x), Ei(x) := PV(&int;<subscript>-x</"
"subscript><superscript>&infin;</superscript> exp(-t)/t dt)"

#. Tag: entry
#: index.docbook:1904
#, no-c-format
msgid "shi(x)"
msgstr "shi(x)"

#. Tag: action
#: index.docbook:1904
#, no-c-format
msgid ""
"Shi(x) = &int;<subscript>0</subscript><superscript>x</superscript> sinh(t)/t "
"dt"
msgstr ""
"Shi(x) = &int;<subscript>0</subscript><superscript>x</superscript> sinh(t)/t "
"dt"

#. Tag: entry
#: index.docbook:1905
#, no-c-format
msgid "chi(x)"
msgstr "chi(x)"

#. Tag: action
#: index.docbook:1905
#, no-c-format
msgid ""
"integral Chi(x) := Re[ &gamma;<subscript>E</subscript> + log(x) + &int;"
"<subscript>0</subscript><superscript>x</superscript> (cosh[t]-1)/t dt ]"
msgstr ""
"Integral de Chi(x) := Re[ &gamma;<subscript>E</subscript> + log(x) + &int;"
"<subscript>0</subscript><superscript>x</superscript> (cosh[t]-1)/t dt ]"

#. Tag: entry
#: index.docbook:1906
#, no-c-format
msgid "Ei3(x)"
msgstr "Ei3(x)"

#. Tag: action
#: index.docbook:1906
#, no-c-format
msgid ""
"exponential integral Ei<subscript>3</subscript>(x) = &int;<subscript>0</"
"subscript><superscript>x</superscript> exp(-t<superscript>3</superscript>) "
"dt for x &gt;= 0"
msgstr ""
"Integral da exponencial Ei<subscript>3</subscript>(x) = &int;<subscript>0</"
"subscript><superscript>x</superscript> exp(-t<superscript>3</superscript>) "
"dt for x &gt;= 0"

#. Tag: entry
#: index.docbook:1907
#, no-c-format
msgid "si(x)"
msgstr "si(x)"

#. Tag: action
#: index.docbook:1907
#, no-c-format
msgid ""
"Sine integral Si(x) = &int;<subscript>0</subscript><superscript>x</"
"superscript> sin(t)/t dt"
msgstr ""
"Integral do seno Si(x) = &int;<subscript>0</subscript><superscript>x</"
"superscript> sin(t)/t dt"

#. Tag: entry
#: index.docbook:1908
#, no-c-format
msgid "ci(x)"
msgstr "ci(x)"

#. Tag: action
#: index.docbook:1908
#, no-c-format
msgid ""
"Cosine integral Ci(x) = -&int;<subscript>x</subscript><superscript>&infin;</"
"superscript> cos(t)/t dt for x &gt; 0"
msgstr ""
"Integral do cosseno Ci(x) = -&int;<subscript>x</"
"subscript><superscript>&infin;</superscript> cos(t)/t dt para x &gt; 0"

#. Tag: entry
#: index.docbook:1909
#, no-c-format
msgid "atanint(x)"
msgstr "atanint(x)"

#. Tag: action
#: index.docbook:1909
#, no-c-format
msgid ""
"Arctangent integral AtanInt(x) = &int;<subscript>0</"
"subscript><superscript>x</superscript> arctan(t)/t dt"
msgstr ""
"Integral da arco-tangente AtanInt(x) = &int;<subscript>0</"
"subscript><superscript>x</superscript> arctan(t)/t dt"

#. Tag: entry
#: index.docbook:1910
#, no-c-format
msgid "Fm1(x)"
msgstr "Fm1(x)"

#. Tag: action
#: index.docbook:1910
#, no-c-format
msgid ""
"complete Fermi-Dirac integral with an index of -1, F<subscript>-1</"
"subscript>(x) = e<superscript>x</superscript> / (1 + e<superscript>x</"
"superscript>)"
msgstr ""
"Integral completa de Fermi-Dirac com um índice -1, F<subscript>-1</"
"subscript>(x) = e<superscript>x</superscript> / (1 + e<superscript>x</"
"superscript>)"

#. Tag: entry
#: index.docbook:1911
#, no-c-format
msgid "F0(x)"
msgstr "F0(x)"

#. Tag: action
#: index.docbook:1911
#, no-c-format
msgid ""
"complete Fermi-Dirac integral with an index of 0, F<subscript>0</"
"subscript>(x) = ln(1 + e<superscript>x</superscript>)"
msgstr ""
"Integral completa de Fermi-Dirac com um índice 0, F<subscript>0</"
"subscript>(x) = ln(1 + e<superscript>x</superscript>)"

#. Tag: entry
#: index.docbook:1912
#, no-c-format
msgid "F1(x)"
msgstr "F1(x)"

#. Tag: action
#: index.docbook:1912
#, no-c-format
msgid ""
"complete Fermi-Dirac integral with an index of 1, F<subscript>1</"
"subscript>(x) = &int;<subscript>0</subscript><superscript>&infin;</"
"superscript> (t /(exp(t-x)+1)) dt"
msgstr ""
"Integral completa de Fermi-Dirac com um índice 1, F<subscript>1</"
"subscript>(x) = &int;<subscript>0</subscript><superscript>&infin;</"
"superscript> (t /(exp(t-x)+1)) dt"

#. Tag: entry
#: index.docbook:1913
#, no-c-format
msgid "F2(x)"
msgstr "F2(x)"

#. Tag: action
#: index.docbook:1913
#, no-c-format
msgid ""
"complete Fermi-Dirac integral with an index of 2, F<subscript>2</"
"subscript>(x) = (1/2) &int;<subscript>0</subscript><superscript>&infin;</"
"superscript> (t<superscript>2</superscript> /(exp(t-x)+1)) dt"
msgstr ""
"Integral completa de Fermi-Dirac com um índice 2, F<subscript>2</"
"subscript>(x) = (1/2) &int;<subscript>0</subscript><superscript>&infin;</"
"superscript> (t<superscript>2</superscript> /(exp(t-x)+1)) dt"

#. Tag: entry
#: index.docbook:1914
#, no-c-format
msgid "Fj(j,x)"
msgstr "Fj(j,x)"

#. Tag: action
#: index.docbook:1914
#, no-c-format
msgid ""
"complete Fermi-Dirac integral with an index of j, F<subscript>j</"
"subscript>(x) = (1/&Gamma;(j+1)) &int;<subscript>0</"
"subscript><superscript>&infin;</superscript> (t<superscript>j</superscript> /"
"(exp(t-x)+1)) dt"
msgstr ""
"Integral completa de Fermi-Dirac com um índice j, F<subscript>j</"
"subscript>(x) = (1/&Gamma;(j+1)) &int;<subscript>0</"
"subscript><superscript>&infin;</superscript> (t<superscript>j</superscript> /"
"(exp(t-x)+1)) dt"

#. Tag: entry
#: index.docbook:1915
#, no-c-format
msgid "Fmhalf(x)"
msgstr "Fmhalf(x)"

#. Tag: action
#: index.docbook:1915
#, no-c-format
msgid "complete Fermi-Dirac integral F<subscript>-1/2</subscript>(x)"
msgstr "Integral completa de Fermi-Dirac F<subscript>-1/2</subscript>(x)"

#. Tag: entry
#: index.docbook:1916
#, no-c-format
msgid "Fhalf(x)"
msgstr "Fhalf(x)"

#. Tag: action
#: index.docbook:1916
#, no-c-format
msgid "complete Fermi-Dirac integral F<subscript>1/2</subscript>(x)"
msgstr "Integral completa de Fermi-Dirac F<subscript>1/2</subscript>(x)"

#. Tag: entry
#: index.docbook:1917
#, no-c-format
msgid "F3half(x)"
msgstr "F3half(x)"

#. Tag: action
#: index.docbook:1917
#, no-c-format
msgid "complete Fermi-Dirac integral F<subscript>3/2</subscript>(x)"
msgstr "Integral completa de Fermi-Dirac F<subscript>3/2</subscript>(x)"

#. Tag: entry
#: index.docbook:1918
#, no-c-format
msgid "Finc0(x,b)"
msgstr "Finc0(x,b)"

#. Tag: action
#: index.docbook:1918
#, no-c-format
msgid ""
"incomplete Fermi-Dirac integral with an index of zero, F<subscript>0</"
"subscript>(x,b) = ln(1 + e<superscript>b-x</superscript>) - (b-x)"
msgstr ""
"Integral incompleta de Fermi-Dirac com um índice 0, F<subscript>0</"
"subscript>(x,b) = ln(1 + e<superscript>b-x</superscript>) - (b-x)"

#. Tag: entry
#: index.docbook:1919
#, no-c-format
msgid "lngamma(x)"
msgstr "lngamma(x)"

#. Tag: action
#: index.docbook:1919
#, no-c-format
msgid "logarithm of the Gamma function"
msgstr "logaritmo da função Gamma"

#. Tag: entry
#: index.docbook:1920
#, no-c-format
msgid "gammastar(x)"
msgstr "gammastar(x)"

#. Tag: action
#: index.docbook:1920
#, no-c-format
msgid ""
"regulated Gamma Function &Gamma;<superscript>*</superscript>(x) for x &gt; 0"
msgstr ""
"Função Gamma regulada &Gamma;<superscript>*</superscript>(x) para x &gt; 0"

#. Tag: entry
#: index.docbook:1921
#, no-c-format
msgid "gammainv(x)"
msgstr "gammainv(x)"

#. Tag: action
#: index.docbook:1921
#, no-c-format
msgid ""
"reciprocal of the gamma function, 1/&Gamma;(x) using the real Lanczos method."
msgstr ""
"Inversa da função Gamma, 1/&Gamma;(x), usando o método real de Lanczos."

#. Tag: entry
#: index.docbook:1922
#, no-c-format
msgid "fact(n)"
msgstr "fact(n)"

#. Tag: action
#: index.docbook:1922
#, no-c-format
msgid "factorial n!"
msgstr "Fatorial de n!"

#. Tag: entry
#: index.docbook:1923
#, no-c-format
msgid "doublefact(n)"
msgstr "doublefact(n)"

#. Tag: action
#: index.docbook:1923
#, no-c-format
msgid "double factorial n!! = n(n-2)(n-4)..."
msgstr "Duplo fatorial de n!! = n(n-2)(n-4)..."

#. Tag: entry
#: index.docbook:1924
#, no-c-format
msgid "lnfact(n)"
msgstr "lnfact(n)"

#. Tag: action
#: index.docbook:1924
#, no-c-format
msgid "logarithm of the factorial of n, log(n!)"
msgstr "Logaritmo do fatorial de n, log(n!)"

#. Tag: entry
#: index.docbook:1925
#, no-c-format
msgid "lndoublefact(n)"
msgstr "lndoublefact(n)"

#. Tag: action
#: index.docbook:1925
#, no-c-format
msgid "logarithm of the double factorial log(n!!)"
msgstr "Logaritmo do duplo fatorial log(n!!)"

#. Tag: entry
#: index.docbook:1926
#, no-c-format
msgid "choose(n,m)"
msgstr "choose(n,m)"

#. Tag: action
#: index.docbook:1926
#, no-c-format
msgid "combinatorial factor `n choose m' = n!/(m!(n-m)!)"
msgstr "Fator combinatório 'combinações n a m' = n!/(m!(n-m)!)"

#. Tag: entry
#: index.docbook:1927
#, no-c-format
msgid "lnchoose(n,m)"
msgstr "lnchoose(n,m)"

#. Tag: action
#: index.docbook:1927
#, no-c-format
msgid "logarithm of `n choose m'"
msgstr "Logaritmo de 'combinações n a m'"

#. Tag: entry
#: index.docbook:1928
#, no-c-format
msgid "taylor(n,x)"
msgstr "taylor(n,x)"

#. Tag: action
#: index.docbook:1928
#, no-c-format
msgid ""
"Taylor coefficient x<superscript>n</superscript> / n! for x >= 0, n >= 0"
msgstr ""
"Coeficiente de Taylor x<superscript>n</superscript> / n! para x >= 0, n >= 0"

#. Tag: entry
#: index.docbook:1929
#, no-c-format
msgid "poch(a,x)"
msgstr "poch(a,x)"

#. Tag: action
#: index.docbook:1929
#, no-c-format
msgid ""
"Pochhammer symbol (a)<subscript>x</subscript> := &Gamma;(a + x)/&Gamma;(x)"
msgstr ""
"Símbolo de Pochhammer (a)<subscript>x</subscript> := &Gamma;(a + x)/&Gamma;"
"(x)"

#. Tag: entry
#: index.docbook:1930
#, no-c-format
msgid "lnpoch(a,x)"
msgstr "lnpoch(a,x)"

#. Tag: action
#: index.docbook:1930
#, no-c-format
msgid ""
"logarithm of the Pochhammer symbol (a)<subscript>x</subscript> := &Gamma;(a "
"+ x)/&Gamma;(x)"
msgstr ""
"Logaritmo do símbolo de Pochhammer (a)<subscript>x</subscript> := &Gamma;(a "
"+ x)/&Gamma;(x)"

#. Tag: entry
#: index.docbook:1931
#, no-c-format
msgid "pochrel(a,x)"
msgstr "pochrel(a,x)"

#. Tag: action
#: index.docbook:1931
#, no-c-format
msgid ""
"relative Pochhammer symbol ((a,x) - 1)/x where (a,x) = (a)<subscript>x</"
"subscript> := &Gamma;(a + x)/&Gamma;(a)"
msgstr ""
"Símbolo de Pochhammer relativo ((a,x) - 1)/x onde (a,x) = (a)<subscript>x</"
"subscript> := &Gamma;(a + x)/&Gamma;(a)"

#. Tag: entry
#: index.docbook:1932
#, no-c-format
msgid "gammainc(a,x)"
msgstr "gammainc(a,x)"

#. Tag: action
#: index.docbook:1932
#, no-c-format
msgid ""
"incomplete Gamma Function &Gamma;(a,x) = &int;<subscript>x</"
"subscript><superscript>&infin;</superscript> t<superscript>a-1</superscript> "
"exp(-t) dt for a &gt; 0, x &gt;= 0"
msgstr ""
"Função Gamma incompleta &Gamma;(a,x) = &int;<subscript>x</"
"subscript><superscript>&infin;</superscript> t<superscript>a-1</superscript> "
"exp(-t) dt para a &gt; 0, x &gt;= 0"

#. Tag: entry
#: index.docbook:1933
#, no-c-format
msgid "gammaincQ(a,x)"
msgstr "gammaincQ(a,x)"

#. Tag: action
#: index.docbook:1933
#, no-c-format
msgid ""
"normalized incomplete Gamma Function P(a,x) = 1/&Gamma;(a) &int;"
"<subscript>x</subscript><superscript>&infin;</superscript> "
"t<superscript>a-1</superscript> exp(-t) dt for a &gt; 0, x &gt;= 0"
msgstr ""
"Função Gamma incompleta normalizada P(a,x) = 1/&Gamma;(a) &int;<subscript>x</"
"subscript><superscript>&infin;</superscript> t<superscript>a-1</superscript> "
"exp(-t) dt para a &gt; 0, x &gt;= 0"

#. Tag: entry
#: index.docbook:1934
#, no-c-format
msgid "gammaincP(a,x)"
msgstr "gammaincP(a,x)"

#. Tag: action
#: index.docbook:1934
#, no-c-format
msgid ""
"complementary normalized incomplete Gamma Function P(a,x) = 1/&Gamma;(a) "
"&int;<subscript>0</subscript><superscript>x</superscript> t<superscript>a-1</"
"superscript> exp(-t) dt for a &gt; 0, x &gt;= 0"
msgstr ""
"Função Gamma incompleta normalizada complementar P(a,x) = 1/&Gamma;(a) &int;"
"<subscript>0</subscript><superscript>x</superscript> t<superscript>a-1</"
"superscript> exp(-t) dt para a &gt; 0, x &gt;= 0"

#. Tag: entry
#: index.docbook:1935
#, no-c-format
msgid "beta(a,b)"
msgstr "beta(a,b)"

#. Tag: action
#: index.docbook:1935
#, no-c-format
msgid ""
"Beta Function, B(a,b) = &Gamma;(a) &Gamma;(b)/&Gamma;(a+b) for a &gt; 0, b "
"&gt; 0"
msgstr ""
"Função Beta, B(a,b) = &Gamma;(a) &Gamma;(b)/&Gamma;(a+b) para a &gt; 0, b "
"&gt; 0"

#. Tag: entry
#: index.docbook:1936
#, no-c-format
msgid "lnbeta(a,b)"
msgstr "lnbeta(a,b)"

#. Tag: action
#: index.docbook:1936
#, no-c-format
msgid "logarithm of the Beta Function, log(B(a,b)) for a &gt; 0, b &gt; 0"
msgstr "Logaritmo da Função Beta, log(B(a,b)) para a &gt; 0, b &gt; 0"

#. Tag: entry
#: index.docbook:1937
#, no-c-format
msgid "betainc(a,b,x)"
msgstr "betainc(a,b,x)"

#. Tag: action
#: index.docbook:1937
#, no-c-format
msgid ""
"normalize incomplete Beta function B_x(a,b)/B(a,b) for a &gt; 0, b &gt; 0"
msgstr ""
"Função Beta incompleta normalizada B_x(a,b)/B(a,b) para a &gt; 0, b &gt; 0"

#. Tag: entry
#: index.docbook:1938
#, no-c-format
msgid "C1(&lambda;,x)"
msgstr "C1(&lambda;,x)"

#. Tag: action
#: index.docbook:1938
#, no-c-format
msgid ""
"Gegenbauer polynomial C<superscript>&lambda;</superscript><subscript>1</"
"subscript>(x)"
msgstr ""
"Polinômio de Gegenbauer C<superscript>&lambda;</superscript><subscript>1</"
"subscript>(x)"

#. Tag: entry
#: index.docbook:1939
#, no-c-format
msgid "C2(&lambda;,x)"
msgstr "C2(&lambda;,x)"

#. Tag: action
#: index.docbook:1939
#, no-c-format
msgid ""
"Gegenbauer polynomial C<superscript>&lambda;</superscript><subscript>2</"
"subscript>(x)"
msgstr ""
"Polinômio de Gegenbauer C<superscript>&lambda;</superscript><subscript>2</"
"subscript>(x)"

#. Tag: entry
#: index.docbook:1940
#, no-c-format
msgid "C3(&lambda;,x)"
msgstr "C3(&lambda;,x)"

#. Tag: action
#: index.docbook:1940
#, no-c-format
msgid ""
"Gegenbauer polynomial C<superscript>&lambda;</superscript><subscript>3</"
"subscript>(x)"
msgstr ""
"Polinômio de Gegenbauer C<superscript>&lambda;</superscript><subscript>3</"
"subscript>(x)"

#. Tag: entry
#: index.docbook:1941
#, no-c-format
msgid "Cn(n,&lambda;,x)"
msgstr "Cn(n,&lambda;,x)"

#. Tag: action
#: index.docbook:1941
#, no-c-format
msgid ""
"Gegenbauer polynomial C<superscript>&lambda;</superscript><subscript>n</"
"subscript>(x)"
msgstr ""
"Polinômio de Gegenbauer C<superscript>&lambda;</superscript><subscript>n</"
"subscript>(x)"

#. Tag: entry
#: index.docbook:1942
#, no-c-format
msgid "hyperg_0F1(c,x)"
msgstr "hyperg_0F1(c,x)"

#. Tag: action
#: index.docbook:1942
#, no-c-format
msgid ""
"hypergeometric function <subscript>0</subscript>F<subscript>1</subscript>(c,"
"x)"
msgstr ""
"Função hipergeométrica <subscript>0</subscript>F<subscript>1</subscript>(c,x)"

#. Tag: entry
#: index.docbook:1943
#, no-c-format
msgid "hyperg_1F1i(m,n,x)"
msgstr "hyperg_1F1i(m,n,x)"

#. Tag: action
#: index.docbook:1943
#, no-c-format
msgid ""
"confluent hypergeometric function <subscript>1</subscript>F<subscript>1</"
"subscript>(m,n,x) = M(m,n,x) for integer parameters m, n"
msgstr ""
"Função hipergeométrica confluente <subscript>1</subscript>F<subscript>1</"
"subscript>(m,n,x) = M(m,n,x) para os parâmetros inteiros m, n"

#. Tag: entry
#: index.docbook:1944
#, no-c-format
msgid "hyperg_1F1(a,b,x)"
msgstr "hyperg_1F1(a,b,x)"

#. Tag: action
#: index.docbook:1944
#, no-c-format
msgid ""
"confluent hypergeometric function <subscript>1</subscript>F<subscript>1</"
"subscript>(a,b,x) = M(a,b,x) for general parameters a,b"
msgstr ""
"Função hipergeométrica confluente <subscript>1</subscript>F<subscript>1</"
"subscript>(a,b,x) = M(a,b,x) para os parâmetros inteiros a,b"

#. Tag: entry
#: index.docbook:1945
#, no-c-format
msgid "hyperg_Ui(m,n,x)"
msgstr "hyperg_Ui(m,n,x)"

#. Tag: action
#: index.docbook:1945
#, no-c-format
msgid "confluent hypergeometric function U(m,n,x) for integer parameters m,n"
msgstr ""
"Função hipergeométrica confluente U(m,n,x) para os parâmetros inteiros m,n"

#. Tag: entry
#: index.docbook:1946
#, no-c-format
msgid "hyperg_U(a,b,x)"
msgstr "hyperg_U(a,b,x)"

#. Tag: action
#: index.docbook:1946
#, no-c-format
msgid "confluent hypergeometric function U(a,b,x)"
