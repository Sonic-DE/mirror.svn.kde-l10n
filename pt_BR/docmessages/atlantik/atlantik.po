msgid "The Menubar"
msgstr "A barra de menu"

#. Tag: title
#: index.docbook:97
#, no-c-format
msgid "The Game Menu"
msgstr "Menu Jogo"

#. Tag: menuchoice
#: index.docbook:101
#, no-c-format
msgid "<guimenu>Game</guimenu><guimenuitem>Show Event Log…</guimenuitem>"
msgstr ""
"<guimenu>Jogo</guimenu><guimenuitem>Mostrar registro de eventos…</"
"guimenuitem>"

#. Tag: para
#: index.docbook:103
#, no-c-format
msgid "<action>Display</action> the event log window."
msgstr "<action>Exibe</action> a janela de registro de eventos."

#. Tag: menuchoice
#: index.docbook:107
#, no-c-format
msgid ""
"<guimenu>Game</guimenu><guimenuitem>Reconnect (After Crash)</guimenuitem>"
msgstr ""
"<guimenu>Jogo</guimenu><guimenuitem>Reconectar (Após travamento)</"
"guimenuitem>"

#. Tag: para
#: index.docbook:109
#, no-c-format
msgid ""
"<action>Reconnect</action> to the last game. This is available only in case "
"&atlantik; did not quit cleanly from a game (usually because it crashed), "
"and cannot be done anymore once you connect to a server."
msgstr ""
"<action>Reconecta</action> ao último jogo. Esta opção está disponível apenas "
"caso o &atlantik; não tenha encerrado o jogo corretamente (geralmente devido "
"a uma falha), e não poderá mais ser feita após a conexão com um servidor."

#. Tag: menuchoice
