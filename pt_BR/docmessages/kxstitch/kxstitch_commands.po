#, no-c-format
msgid "Rotate the selected area anti clockwise 90 degrees"
msgstr "Gira a área selecionada em 90 graus no sentido anti-horário"

#. Tag: menuchoice
#: commands.docbook:126
#, no-c-format
msgid ""
"<guisubmenu>Rotate Selection</guisubmenu><guimenuitem>180 degrees</"
"guimenuitem>"
msgstr ""
"<guisubmenu>Girar a seleção</guisubmenu><guimenuitem>180 graus</guimenuitem>"

#. Tag: action
#: commands.docbook:127
#, no-c-format
