#: features.docbook:47
#, no-c-format
msgid "Conversion between floss schemes"
msgstr "Conversão entre esquemas de novelos"

#. Tag: para
#: features.docbook:50
#, no-c-format
msgid "Use of standard floss pallets, DMC, Anchor, etc."
msgstr "Usar paletas padrão de novelos, como a DMC, a Anchor, etc."

#. Tag: para
#: features.docbook:51
#, no-c-format
msgid "Create customized floss pallets"
msgstr "Criar paletas de novelos personalizadas"

#. Tag: para
#: features.docbook:52
#, no-c-format
msgid "Create new colors for any floss pallet"
msgstr "Criar novas cores para qualquer paleta de novelos"

#. Tag: para
#: features.docbook:53
#, no-c-format
msgid "Save / Load current palette"
msgstr "Salvar / Carregar a paleta atual"

#. Tag: para
#: features.docbook:54
#, no-c-format
msgid "Use of standard stitches"
msgstr "Uso de pontos padrão"

#. Tag: para
#: features.docbook:55
#, no-c-format
msgid "Pattern library manager"
msgstr "Gerenciador da biblioteca de padrões"

#. Tag: para
#: features.docbook:57
#, no-c-format
msgid "Create new library patterns"
msgstr "Criar novos padrões nas bibliotecas"

#. Tag: para
#: features.docbook:58
#, no-c-format
msgid "Insert library patterns into a design"
msgstr "Inserir padrões da biblioteca em um desenho"

#. Tag: para
#: features.docbook:59
#, no-c-format
msgid "Drag and drop from the library to the pattern"
msgstr "Arrastar e soltar a partir da biblioteca para o padrão"

#. Tag: para
#: features.docbook:60
#, no-c-format
msgid "Drag and drop from one library to another"
msgstr "Arrastar e soltar de uma biblioteca para outra"

#. Tag: para
#: features.docbook:61
#, no-c-format
msgid "Assign key press to patterns for use with the Alphabet tool"
msgstr ""
"Atribuir teclas pressionadas a padrões para usar com a ferramenta Alfabeto"

#. Tag: para
#: features.docbook:64
#, no-c-format
msgid "Free use of backstitching"
msgstr "Uso livre de pespontos"

#. Tag: para
#: features.docbook:65
#, no-c-format
msgid "Printing of completed patterns and floss keys"
msgstr "Impressão dos padrões completos e das chaves dos novelos"

#. Tag: para
#: features.docbook:67
#, no-c-format
msgid "Pattern image"
msgstr "Imagem do padrão"

#. Tag: para
#: features.docbook:68
#, no-c-format
msgid "Instructions"
msgstr "Instruções"

#. Tag: para
#: features.docbook:69
#, no-c-format
msgid "Floss key and stitch summary"
msgstr "Resumo de chaves de novelos e dos pontos"

#. Tag: para
#: features.docbook:70
#, no-c-format
msgid "Pattern chart with page map"
msgstr "Gráfico de padrões com o mapa da página"

#. Tag: para
#: features.docbook:71
#, no-c-format
msgid "Text boxes"
msgstr "Campos de texto"

#. Tag: para
#: features.docbook:74
#, no-c-format
msgid "Mapping of symbols to flosses"
msgstr "Associação de símbolos aos novelos"

#. Tag: para
#: features.docbook:75
#, no-c-format
msgid "Specify the number of threads for stitches and backstitches"
msgstr "Indicar o número de fios para os pontos e pespontos"

#. Tag: para
#: features.docbook:76
#, no-c-format
msgid "Calibration of floss colors"
msgstr "Calibração das cores dos novelos"

