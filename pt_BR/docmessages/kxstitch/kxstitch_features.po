#. Tag: title
#: features.docbook:2
#, no-c-format
msgid "Features"
msgstr "Funcionalidades"

#. Tag: para
#: features.docbook:3
#, no-c-format
msgid "The current feature list and other planned features is shown here."
msgstr ""
"A lista de funcionalidades atuais e de outras planejadas é apresentada aqui."

#. Tag: para
#: features.docbook:5
#, no-c-format
msgid "Creation of new patterns"
msgstr "Criação de novos padrões"

#. Tag: para
#: features.docbook:7
#, no-c-format
msgid "User defined size"
msgstr "Tamanho definido pelo usuário"

#. Tag: para
#: features.docbook:8
#, no-c-format
msgid "Selection of material color"
msgstr "Seleção da cor do material"

#. Tag: para
#: features.docbook:9
#, no-c-format
msgid "Insertion of a background images for tracing"
