msgstr "<manvolnum>1</manvolnum>"

#. Tag: refpurpose
#: man-kdiff3.1.docbook:24
#, no-c-format
msgid "Tool for Comparison and Merge of Files and Folders"
msgstr "Ferramenta para comparação e mesclagem de arquivos e pastas"

#. Tag: cmdsynopsis
#: man-kdiff3.1.docbook:28
#, no-c-format
msgid ""
"<command>kdiff3</command> <arg choice=\"opt\"><option>-u, --ignore</option></"
"arg> <arg choice=\"opt\"><option>--query</option></arg> <arg choice=\"opt"
"\"><option>--html</option></arg> <arg choice=\"opt\"><option>--abort</"
"option></arg> <arg choice=\"opt\"><option>-m, --merge</option></arg> <arg "
"choice=\"opt\"><option>-b, --base</option> <replaceable>file</replaceable></"
"arg> <arg choice=\"opt\"><option>-o, --output</option> <replaceable>file</"
"replaceable></arg> <arg choice=\"opt\"><option>--out</option> "
"<replaceable>file</replaceable></arg> <arg choice=\"opt\"><option>--noauto</"
"option></arg> <arg choice=\"opt\"><option>--auto</option></arg> <arg choice="
"\"opt\"><option>--L1</option> <replaceable>alias1</replaceable></arg> <arg "
"choice=\"opt\"><option>--L2</option> <replaceable>alias2</replaceable></arg> "
"<arg choice=\"opt\"><option>--L3</option> <replaceable>alias3</replaceable></"
"arg> <arg choice=\"opt\"><option>-L, --fname</option> <replaceable>alias</"
"replaceable></arg> <arg choice=\"opt\"><option>--cs</option> "
"<replaceable>string</replaceable></arg> <arg choice=\"opt\"><option>--"
"confighelp</option></arg> <arg choice=\"opt\"><option>--config</option> "
"<replaceable>file</replaceable></arg> <arg choice=\"opt"
"\"><option><replaceable>File1</replaceable></option></arg> <arg choice=\"opt"
"\"><option><replaceable>File2</replaceable></option></arg> <arg choice=\"opt"
"\"><option><replaceable>File3</replaceable></option></arg>"
msgstr ""
"<command>kdiff3</command> <arg choice=\"opt\"><option>-u, --ignore</option></"
"arg> <arg choice=\"opt\"><option>--query</option></arg> <arg choice=\"opt"
"\"><option>--html</option></arg> <arg choice=\"opt\"><option>--abort</"
"option></arg> <arg choice=\"opt\"><option>-m, --merge</option></arg> <arg "
"choice=\"opt\"><option>-b, --base</option> <replaceable>arquivo</"
"replaceable></arg> <arg choice=\"opt\"><option>-o, --output</option> "
"<replaceable>arquivo</replaceable></arg> <arg choice=\"opt\"><option>--out</"
"option> <replaceable>file</replaceable></arg> <arg choice=\"opt\"><option>--"
"noauto</option></arg> <arg choice=\"opt\"><option>--auto</option></arg> <arg "
"choice=\"opt\"><option>--L1</option> <replaceable>alias1</replaceable></arg> "
"<arg choice=\"opt\"><option>--L2</option> <replaceable>alias2</replaceable></"
"arg> <arg choice=\"opt\"><option>--L3</option> <replaceable>alias3</"
"replaceable></arg> <arg choice=\"opt\"><option>-L, --fname</option> "
"<replaceable>alias</replaceable></arg> <arg choice=\"opt\"><option>--cs</"
"option> <replaceable>string</replaceable></arg> <arg choice=\"opt"
"\"><option>--confighelp</option></arg> <arg choice=\"opt\"><option>--config</"
"option> <replaceable>arquivo</replaceable></arg> <arg choice=\"opt"
"\"><option><replaceable>Arquivo1</replaceable></option></arg> <arg choice="
"\"opt\"><option><replaceable>Arquivo2</replaceable></option></arg> <arg "
"choice=\"opt\"><option><replaceable>Arquivo3</replaceable></option></arg>"

#. Tag: title
#: man-kdiff3.1.docbook:54
#, no-c-format
msgid "Description"
msgstr "Descrição"

#. Tag: para
#: man-kdiff3.1.docbook:55
#, no-c-format
msgid "Compares two or three input files or folders."
msgstr "Compara dois ou três arquivos ou pastas de entrada."

#. Tag: title
#: man-kdiff3.1.docbook:60
#, no-c-format
msgid "Options"
msgstr "Opções"

#. Tag: option
#: man-kdiff3.1.docbook:63
#, no-c-format
msgid "-u, --ignore"
msgstr "-u, --ignore"

#. Tag: para
#: man-kdiff3.1.docbook:64 man-kdiff3.1.docbook:70 man-kdiff3.1.docbook:76
#: man-kdiff3.1.docbook:82
#, no-c-format
msgid "Ignored. (User defined.)"
msgstr "Ignorado. (definido pelo usuário.)"

#. Tag: option
#: man-kdiff3.1.docbook:69
#, no-c-format
msgid "--query"
msgstr "--query"

#. Tag: option
#: man-kdiff3.1.docbook:75
#, no-c-format
msgid "--html"
msgstr "--html"

#. Tag: option
#: man-kdiff3.1.docbook:81
#, no-c-format
msgid "--abort"
msgstr "--abort"

#. Tag: option
#: man-kdiff3.1.docbook:87
#, no-c-format
msgid "-m, --merge"
msgstr "-m, --merge"

#. Tag: para
#: man-kdiff3.1.docbook:88
#, no-c-format
msgid "Merge the input."
msgstr "Mescla a entrada."

#. Tag: term
#: man-kdiff3.1.docbook:93
#, no-c-format
msgid "<option>-b, --base</option> <replaceable>file</replaceable>"
msgstr "<option>-b, --base</option> <replaceable>arquivo</replaceable>"

#. Tag: para
#: man-kdiff3.1.docbook:94
#, no-c-format
msgid "Explicit base file. For compatibility with certain tools."
msgstr "Arquivo base explícito. Para compatibilidade com certas ferramentas."

#. Tag: term
#: man-kdiff3.1.docbook:99
#, no-c-format
msgid "<option>-o, --output</option> <replaceable>file</replaceable>"
msgstr "<option>-o, --output</option> <replaceable>arquivo</replaceable>"

#. Tag: para
#: man-kdiff3.1.docbook:100
#, no-c-format
msgid "Output file. Implies -m. &eg;: -o newfile.txt"
msgstr "Arquivo de saída Implica -m. Por exemplo: -o novoarquivo.txt"

#. Tag: term
#: man-kdiff3.1.docbook:105
#, no-c-format
msgid "<option>--out</option> <replaceable>file</replaceable>"
msgstr "<option>--out</option> <replaceable>arquivo</replaceable>"

#. Tag: para
#: man-kdiff3.1.docbook:106
#, no-c-format
msgid "Output file, again. (For compatibility with certain tools.)"
msgstr ""
"Arquivo de saída, novamente. (Para compatibilidade com certas ferramentas.)"

#. Tag: option
#: man-kdiff3.1.docbook:111
#, no-c-format
msgid "--auto"
msgstr "--auto"

#. Tag: para
#: man-kdiff3.1.docbook:112
#, no-c-format
msgid ""
"No GUI if all conflicts are auto-solvable. (Needs <option>-o</option> "
"<replaceable>file</replaceable>)"
msgstr ""
"Sem interface gráfica se todos os conflitos forem resolvidos "
"automaticamente. (Requer <option>-o</option> <replaceable>arquivo</"
"replaceable>)"

#. Tag: option
#: man-kdiff3.1.docbook:118
#, no-c-format
msgid "--noauto"
msgstr "--noauto"

#. Tag: para
#: man-kdiff3.1.docbook:119
#, no-c-format
msgid "Ignore --auto and always show GUI."
msgstr "Ignorar --auto e sempre mostrar a interface."

#. Tag: term
#: man-kdiff3.1.docbook:124
#, no-c-format
msgid "<option>--L1</option> <replaceable>alias1</replaceable>"
msgstr "<option>--L1</option> <replaceable>alias1</replaceable>"

#. Tag: para
#: man-kdiff3.1.docbook:125
#, no-c-format
msgid "Visible name replacement for input file 1 (base)."
msgstr "Substituição do nome visível para arquivo de entrada 1 (base)."

#. Tag: term
#: man-kdiff3.1.docbook:130
#, no-c-format
msgid "<option>--L2</option> <replaceable>alias2</replaceable>"
msgstr "<option>--L2</option> <replaceable>alias2</replaceable>"

#. Tag: para
#: man-kdiff3.1.docbook:131
#, no-c-format
msgid "Visible name replacement for input file 2."
msgstr "Substituição do nome visível para arquivo de entrada 2."

#. Tag: term
#: man-kdiff3.1.docbook:136
#, no-c-format
msgid "<option>--L3</option> <replaceable>alias3</replaceable>"
msgstr "<option>--L3</option> <replaceable>alias3</replaceable>"

#. Tag: para
#: man-kdiff3.1.docbook:137
#, no-c-format
msgid "Visible name replacement for input file 3."
msgstr "Substituição do nome visível para arquivo de entrada 3."

#. Tag: term
#: man-kdiff3.1.docbook:142
#, no-c-format
msgid "<option>-L, --fname</option> <replaceable>alias</replaceable>"
msgstr "<option>-L, --fname</option> <replaceable>alias</replaceable>"

#. Tag: para
#: man-kdiff3.1.docbook:143
#, no-c-format
msgid "Alternative visible name replacement. Supply this once for every input."
msgstr ""
"Substituição alternativa do nome visível. Forneça um para cada entrada."

#. Tag: term
#: man-kdiff3.1.docbook:148
#, no-c-format
msgid "<option>--cs</option> <replaceable>string</replaceable>"
msgstr "<option>--cs</option> <replaceable>string</replaceable>"

#. Tag: para
#: man-kdiff3.1.docbook:149
#, no-c-format
msgid ""
"Override a config setting. Use once for every setting. &eg;: <option>--cs</"
"option> <replaceable>AutoAdvance=1</replaceable>."
msgstr ""
"Substitui uma opção de configuração. Use uma vez para cada opção. Por "
"exemplo: <option>--cs</option> <replaceable>AutoAdvance=1</replaceable>."

#. Tag: option
#: man-kdiff3.1.docbook:155
#, no-c-format
msgid "--confighelp"
msgstr "--confighelp"

#. Tag: para
#: man-kdiff3.1.docbook:156
#, no-c-format
msgid "Show list of config settings and current values."
msgstr "Mostra uma lista das opções de configuração e os valores atuais."

#. Tag: term
#: man-kdiff3.1.docbook:161
#, no-c-format
msgid "<option>--config</option> <replaceable>file</replaceable>"
msgstr "<option>--config</option> <replaceable>arquivo</replaceable>"

#. Tag: para
#: man-kdiff3.1.docbook:162
#, no-c-format
msgid "Use a different config file."
msgstr "Usar um arquivo de configuração diferente."

#. Tag: replaceable
#: man-kdiff3.1.docbook:167
#, no-c-format
msgid "File1"
msgstr "Arquivo1"

#. Tag: para
#: man-kdiff3.1.docbook:168
#, no-c-format
msgid "file1 to open (base, if not specified via --<option>base</option>)"
msgstr ""
"arquivo 1 a abrir (base, se não especificado via --<option>base</option>)"

#. Tag: replaceable
#: man-kdiff3.1.docbook:173
#, no-c-format
msgid "File2"
msgstr "Arquivo2"

#. Tag: para
#: man-kdiff3.1.docbook:174
#, no-c-format
msgid "file2 to open"
msgstr "arquivo 2 a abrir"

#. Tag: replaceable
#: man-kdiff3.1.docbook:179
#, no-c-format
msgid "File3"
msgstr "Arquivo3"

#. Tag: para
#: man-kdiff3.1.docbook:180
#, no-c-format
msgid "file3 to open"
msgstr "arquivo 3 a abrir"

#. Tag: title
#: man-kdiff3.1.docbook:189
#, no-c-format
msgid "See Also"
msgstr "Veja também"

#. Tag: member
#: man-kdiff3.1.docbook:191
#, no-c-format
