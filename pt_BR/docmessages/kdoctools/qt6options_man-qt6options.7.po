#. Tag: title
#: man-qt6options.7.docbook:57
#, no-c-format
msgid "Options"
msgstr "Opções"

#. Tag: para
#: man-qt6options.7.docbook:59
#, no-c-format
msgid "The following options apply to all &Qt; applications:"
msgstr "As seguintes opções aplicam-se a todos os aplicativos do &Qt;:"

#. Tag: term
#: man-qt6options.7.docbook:64
#, no-c-format
msgid ""
"<option>-style=</option> <replaceable>style</replaceable> / <option>-style</"
"option> <replaceable>style</replaceable>"
msgstr ""
"<option>-style=</option> <replaceable>estilo</replaceable> / <option>-style</"
"option> <replaceable>estilo</replaceable>"

#. Tag: para
#: man-qt6options.7.docbook:67
#, no-c-format
msgid ""
"Set the application &GUI; style. Possible values depend on the system "
"configuration. If &Qt; is compiled with additional styles or has additional "
"styles as plugins these will be available to the <option>-style</option> "
"command line option."
msgstr ""
"Define o estilo da &GUI; do aplicativo. Os valores possíveis dependem da "
"configuração do sistema. Se o &Qt; for compilado com estilos adicionais ou "
"se tiver estilos adicionais como plugins, estes ficarão disponíveis na opção "
"<option>-style</option> da linha de comando."

#. Tag: term
#: man-qt6options.7.docbook:74
#, no-c-format
msgid ""
"<option>-stylesheet=</option> <replaceable>stylesheet</replaceable> / "
"<option>-stylesheet</option> <replaceable>stylesheet</replaceable>"
msgstr ""
"<option>-stylesheet=</option> <replaceable>folha de estilo</replaceable> / "
"<option>-stylesheet</option> <replaceable>folha de estilo</replaceable>"

#. Tag: para
#: man-qt6options.7.docbook:77
#, no-c-format
msgid ""
"Set the application styleSheet. The value must be a path to a file that "
"contains the Style Sheet."
msgstr ""
"Define a folha de estilo do aplicativo. O valor deverá ser o caminho de um "
"arquivo que contém a folha de estilo."

#. Tag: option
#: man-qt6options.7.docbook:84
#, no-c-format
msgid "-widgetcount"
msgstr "-widgetcount"

#. Tag: para
#: man-qt6options.7.docbook:86
#, no-c-format
msgid ""
"Print debug message at the end about number of widgets left undestroyed and "
"maximum number of widgets existed at the same time."
msgstr ""
"Mostra uma mensagem de depuração no fim sobre o número de widgets não "
"destruídos e o número máximo de widgets que existiram ao mesmo tempo."

#. Tag: option
#: man-qt6options.7.docbook:93
#, no-c-format
msgid "-reverse"
msgstr "-reverse"

#. Tag: para
#: man-qt6options.7.docbook:95
#, no-c-format
msgid ""
"Set the application's layout direction to <methodname>Qt::RightToLeft</"
"methodname>. This option is intended to aid debugging and should not be used "
"in production. The default value is automatically detected from the user's "
"locale (see also <methodname>QLocale::textDirection()</methodname>)."
msgstr ""
"Define a direção do layout do aplicativo como <methodname>Qt::RightToLeft</"
"methodname>. Esta opção pretende ajudar na depuração e não deve ser usada em "
"produção. O valor padrão é detectado automaticamente a partir da região do "
"usuário (veja também o <methodname>QLocale::textDirection()</methodname>)."

#. Tag: term
#: man-qt6options.7.docbook:104
#, no-c-format
msgid "<option>-qmljsdebugger=</option> <replaceable>port</replaceable>"
msgstr "<option>-qmljsdebugger=</option> <replaceable>porta</replaceable>"

#. Tag: para
#: man-qt6options.7.docbook:107
#, no-c-format
msgid ""
"Activate the QML/JS debugger with a specified port. The value must be of "
"format port:1234[,block], where block is optional and will make the "
"application wait until a debugger connects to it."
msgstr ""
"Ativa o depurador de QML/JS com uma porta específica. O valor deverá ser no "
"formato porta:1234[,bloqueio], onde bloqueio é opcional e fará com que o "
"aplicativo aguarde até que um depurador se conecte a ela."

#. Tag: term
#: man-qt6options.7.docbook:114
#, no-c-format
msgid ""
"<option>-platform</option> <replaceable>platformName[:options]</replaceable>"
msgstr ""
"<option>-platform</option> <replaceable>nomePlataforma[:opções]</replaceable>"

#. Tag: para
#: man-qt6options.7.docbook:117
#, no-c-format
msgid "Specify the &Qt; Platform Abstraction (QPA) plugin."
msgstr "Define o plugin do QPA (&Qt;Platform Abstraction)."

#. Tag: term
#: man-qt6options.7.docbook:123
#, no-c-format
msgid "<option>-platformpluginpath</option> <replaceable>path</replaceable>"
msgstr ""
"<option>-platformpluginpath</option> <replaceable>caminho</replaceable>"

#. Tag: para
#: man-qt6options.7.docbook:126
#, no-c-format
msgid "Specify the path to platform plugins."
msgstr "Define o caminho dos plugins da plataforma."

#. Tag: term
#: man-qt6options.7.docbook:132
#, no-c-format
msgid ""
"<option>-platformtheme</option> <replaceable>platformTheme</replaceable>"
msgstr ""
"<option>-platformtheme</option> <replaceable>temaPlataforma</replaceable>"

#. Tag: para
#: man-qt6options.7.docbook:135
#, no-c-format
msgid "Specify the platform theme."
msgstr "Define o tema da plataforma."

#. Tag: term
#: man-qt6options.7.docbook:141
#, no-c-format
msgid "<option>-plugin</option> <replaceable>plugin</replaceable>"
msgstr "<option>-plugin</option> <replaceable>plugin</replaceable>"

#. Tag: para
#: man-qt6options.7.docbook:144
#, no-c-format
msgid ""
"Specify additional plugins to load. The argument may appear multiple times."
msgstr ""
"Define os plugins adicionais a carregar. O argumento poderá aparecer várias "
"vezes."

#. Tag: term
#: man-qt6options.7.docbook:150
#, no-c-format
msgid "<option>-qwindowgeometry</option> <replaceable>geometry</replaceable>"
msgstr "<option>-qwindowgeometry</option> <replaceable>geometria</replaceable>"

#. Tag: para
#: man-qt6options.7.docbook:153
#, no-c-format
msgid ""
"Specify the window geometry for the main window using the &X11;-syntax. For "
"example: -qwindowgeometry 100x100+50+50"
msgstr ""
"Define a geometria da janela principal, usando a sintaxe do &X11;. Por "
"exemplo: -qwindowgeometry 100x100+50+50"

#. Tag: term
#: man-qt6options.7.docbook:159
#, no-c-format
msgid "<option>-qwindowicon</option> <replaceable>icon</replaceable>"
msgstr "<option>-qwindowicon</option> <replaceable>ícone</replaceable>"

#. Tag: para
#: man-qt6options.7.docbook:162
#, no-c-format
msgid "Set the default window icon."
msgstr "Define o ícone padrão da janela."

#. Tag: term
#: man-qt6options.7.docbook:168
#, no-c-format
msgid "<option>-qwindowtitle</option> <replaceable>title</replaceable>"
msgstr "<option>-qwindowtitle</option> <replaceable>título</replaceable>"

#. Tag: para
#: man-qt6options.7.docbook:171
#, no-c-format
msgid "Set the title of the first window."
msgstr "Define o título da primeira janela."

#. Tag: term
#: man-qt6options.7.docbook:177
#, no-c-format
msgid "<option>-session</option> <replaceable>session</replaceable>"
msgstr "<option>-session</option> <replaceable>sessão</replaceable>"

#. Tag: para
#: man-qt6options.7.docbook:180
#, no-c-format
msgid "Restore the application from an earlier session."
msgstr "Restaura o aplicativo a partir de uma sessão anterior."

#. Tag: term
#: man-qt6options.7.docbook:186
#, no-c-format
msgid ""
"<option>-display</option> <replaceable>hostname:screen_number</replaceable>"
msgstr ""
"<option>-display</option> <replaceable>máquina:número_tela</replaceable>"

#. Tag: para
#: man-qt6options.7.docbook:189
#, no-c-format
msgid ""
"Switch displays on &X11;. Overrides the <envar>DISPLAY</envar> environment "
"variable."
msgstr ""
"Muda de tela no &X11;. Substitui a variável de ambiente <envar>DISPLAY</"
"envar>."

#. Tag: term
#: man-qt6options.7.docbook:195
#, no-c-format
msgid "<option>-geometry</option> <replaceable>geometry</replaceable>"
msgstr "<option>-geometry</option> <replaceable>geometria</replaceable>"

#. Tag: para
#: man-qt6options.7.docbook:198
#, no-c-format
msgid ""
"Specify the window geometry for the main window on &X11;. For example: -"
"geometry 100x100+50+50"
msgstr ""
"Define a geometria da janela principal no &X11;. Por exemplo: -geometry "
"100x100+50+50."

#. Tag: term
#: man-qt6options.7.docbook:204
#, no-c-format
msgid "<option>-dialogs=</option> <replaceable>[xp|none]</replaceable>"
msgstr "<option>-dialogs=</option> <replaceable>[xp|none]</replaceable>"

#. Tag: para
#: man-qt6options.7.docbook:207
#, no-c-format
msgid ""
"Only available for the &Windows; platform. XP uses native style dialogs and "
"none disables them."
msgstr ""
"Só está disponível na plataforma &Windows;. O 'XP' usa as janelas nativas "
"com o estilo do XP e o 'none' desativa-as."

#. Tag: term
#: man-qt6options.7.docbook:213
#, no-c-format
msgid "<option>-fontengine=</option> <replaceable>freetype</replaceable>"
msgstr "<option>-fontengine=</option> <replaceable>freetype</replaceable>"

#. Tag: para
#: man-qt6options.7.docbook:216
#, no-c-format
msgid "Use the FreeType font engine."
msgstr "Usa o mecanismo de fontes FreeType."

#. Tag: option
#: man-qt6options.7.docbook:224
#, no-c-format
msgid "-h, --help and -? on &Windows;"
msgstr "-h, --help e -? no &Windows;"

#. Tag: para
#: man-qt6options.7.docbook:226
#, no-c-format
msgid "Print all options and the application description."
msgstr "Mostra todas as opções e a descrição do aplicativo."

#. Tag: option
#: man-qt6options.7.docbook:233
#, no-c-format
msgid "-v --version"
msgstr "-v --version"

#. Tag: para
#: man-qt6options.7.docbook:235
#, no-c-format
msgid "Display the version string of the application."
msgstr "Mostra o texto da versão do aplicativo."

