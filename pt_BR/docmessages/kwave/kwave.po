#~ "quiser apenas criar um pacote binário, poderá indicar <literal>-bb</"
#~ "literal>, em vez de <literal>-ba</literal>, ou apenas <literal>-bs</"
#~ "literal> para criar apenas um pacote com o código-fonte."

#~ msgid "<prompt>% </prompt><command>rpmbuild -ba SPECS/kwave.spec</command>"
#~ msgstr "<prompt>% </prompt><command>rpmbuild -ba SPECS/kwave.spec</command>"

#~ msgid ""
#~ "If everything was ok, you can install the binary rpm of &kwave;, it will "
#~ "be in the BUILD directory. If you already have a version of &kwave; "
