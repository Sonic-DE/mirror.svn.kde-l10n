#. Tag: title
#: index.docbook:2589
#, no-c-format
msgid "&no-i18n-cmd_delete;"
msgstr "&no-i18n-cmd_delete;"

#. Tag: title
#: index.docbook:2591
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_delete;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_delete;</command>()"

#. Tag: para
#: index.docbook:2592
#, no-c-format
msgid ""
"Deletes the currently selected range of samples. If the selection is empty, "
"this command does nothing. Affects all tracks."
msgstr ""
"Exclui o intervalo de amostras atualmente selecionado. Se a seleção estiver "
"vazia, esse comando não faz nada. Afeta todas as faixas."

#. Tag: title
#: index.docbook:2601
#, no-c-format
msgid "&no-i18n-cmd_delete_track;"
msgstr "&no-i18n-cmd_delete_track;"

#. Tag: title
#: index.docbook:2603
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_delete_track;</"
"command>(<replaceable>index</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_delete_track;</"
"command>(<replaceable>índice</replaceable>)"

#. Tag: para
#: index.docbook:2604
#, no-c-format
msgid ""
"Deletes a track, identified by its index (starting from zero). If no track "
"with the given index exists, this command exits with an error."
msgstr ""
"Exclui uma faixa identificada pelo seu índice (começando do zero). Se "
"nenhuma faixa com o índice fornecido existir, este comando sairá com um erro."

#. Tag: entry
#: index.docbook:2610 index.docbook:2733 index.docbook:2772 index.docbook:2800
#: index.docbook:3563 index.docbook:3577 index.docbook:3592
#, no-c-format
msgid "<parameter>index</parameter>:"
msgstr "<parameter>índice</parameter>:"

#. Tag: entry
#: index.docbook:2610
#, no-c-format
msgid "index of the track to delete, starting with 0"
msgstr "índice da faixa a eliminar, começando por 0"

#. Tag: title
#: index.docbook:2615
#, no-c-format
msgid "&no-i18n-cmd_dump_metadata;"
msgstr "&no-i18n-cmd_dump_metadata;"

#. Tag: title
#: index.docbook:2617
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_dump_metadata;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_dump_metadata;</"
"command>()"

#. Tag: para
#: index.docbook:2618
#, no-c-format
msgid ""
"Prints a list of all meta data entries to the console, for diagnostic "
"purposes. (Only available when &kwave; has been compiled with the option "
"<literal>WITH_DEBUG</literal> switched on)."
msgstr ""
"Imprime uma lista de todas as entradas de metadados no console, para fins de "
"diagnóstico. (Disponível apenas quando o &kwave; foi compilado com a opção "
"<literal>WITH_DEBUG</literal> ativada)."

#. Tag: title
#: index.docbook:2627
#, no-c-format
msgid "&no-i18n-tag;e"
msgstr "&no-i18n-tag;e"

#. Tag: title
#: index.docbook:2630
#, no-c-format
msgid "&no-i18n-cmd_expandtolabel;"
msgstr "&no-i18n-cmd_expandtolabel;"

#. Tag: title
#: index.docbook:2632
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_expandtolabel;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_expandtolabel;</"
"command>()"

#. Tag: para
#: index.docbook:2633
#, no-c-format
msgid ""
"Expands the current selection to the labels left and right from the current "
"selection borders. If the border of selection already is on a label, it "
"stays unchanged. If there is no label left or right of the current "
"selection, it will be expanded to the start or end of the file."
msgstr ""
"Expande a seleção atual para os rótulos à esquerda e à direita das bordas da "
"seleção atual. Se a borda da seleção já estiver em um rótulo, ela "
"permanecerá inalterada. Se não houver rótulo à esquerda ou à direita da "
"seleção atual, ela será expandida para o início ou o final do arquivo."

#. Tag: title
#: index.docbook:2644
#, no-c-format
msgid "&no-i18n-tag;f"
msgstr "&no-i18n-tag;f"

#. Tag: title
#: index.docbook:2647
#, no-c-format
msgid "&no-i18n-cmd_fileinfo;"
msgstr "&no-i18n-cmd_fileinfo;"

#. Tag: title
#: index.docbook:2649
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_fileinfo;</"
"command>(<replaceable>index</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_fileinfo;</"
"command>(<replaceable>índice</replaceable>)"

#. Tag: para
#: index.docbook:2650
#, no-c-format
msgid "Set a file info entry to a new value."
msgstr "Defina uma entrada de informações do arquivo para um novo valor."

#. Tag: entry
#: index.docbook:2655
#, no-c-format
msgid "<parameter>keyword</parameter>:"
msgstr "<parameter>palavra-chave</parameter>:"

#. Tag: entry
#: index.docbook:2655
#, no-c-format
msgid "keyword of the entry"
msgstr "palavra-chave da entrada"

#. Tag: entry
#: index.docbook:2656
#, no-c-format
msgid "<parameter>value</parameter>:"
msgstr "<parameter>valor</parameter>:"

#. Tag: entry
#: index.docbook:2656
#, no-c-format
msgid "value of the entry"
msgstr "valor da entrada"

#. Tag: title
#: index.docbook:2661
#, no-c-format
msgid "&no-i18n-cmd_forward;"
msgstr "&no-i18n-cmd_forward;"

#. Tag: title
#: index.docbook:2663
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_forward;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_forward;</command>()"

#. Tag: para
#: index.docbook:2664
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Forward</guibutton> toolbar button. If the "
"playback is currently running, it skips forward by 1/10 of the visible "
"range. If the playback is not running, this does the same as the command "
"<command>&no-i18n-cmd_view_scroll_right;</command>()."
msgstr ""
"Corresponde ao botão da barra de ferramentas <guibutton>Avançar</guibutton>."
"Se a reprodução estiver em execução, ela avança 1/10 do intervalo visível.Se "
"a reprodução não estiver em execução, isso faz o mesmo que o comando "
"<command>&no-i18n-cmd_view_scroll_right;</command>()."

#. Tag: para
#: index.docbook:2673
#, no-c-format
msgid ""
"<link linkend=\"cmd_sect_view_scroll_right\"><command>&no-i18n-tag;&no-i18n-"
"cmd_view_scroll_right;</command>()</link>, <link linkend=\"cmd_sect_rewind"
"\"><command>&no-i18n-tag;&no-i18n-cmd_rewind;</command>()</link>"
msgstr ""
"<link linkend=\"cmd_sect_view_scroll_right\"><command>&no-i18n-tag;&no-i18n-"
"cmd_view_scroll_right;</command>()</link>, <link linkend=\"cmd_sect_rewind"
"\"><command>&no-i18n-tag;&no-i18n-cmd_rewind;</command>()</link>"

#. Tag: title
#: index.docbook:2681
#, no-c-format
msgid "&no-i18n-tag;g"
msgstr "&no-i18n-tag;g"

#. Tag: title
#: index.docbook:2684
#, no-c-format
msgid "&no-i18n-cmd_goto;"
msgstr "&no-i18n-cmd_goto;"

#. Tag: title
#: index.docbook:2686
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_goto;</command>(<replaceable>pos</"
"replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_goto;</command>(<replaceable>pos</"
"replaceable>)"

#. Tag: para
#: index.docbook:2687
#, no-c-format
msgid ""
"Sets the cursor to the given position and makes it visible in current view. "
"After this the selection has zero length."
msgstr ""
"Define o cursor para a posição determinada e o torna visível na exibição "
"atual. Depois disso, a seleção tem duração igual a zero."

#. Tag: entry
#: index.docbook:2693 index.docbook:2711 index.docbook:2756
#, no-c-format
msgid "<parameter>pos</parameter>:"
msgstr "<parameter>pos</parameter>:"

#. Tag: entry
#: index.docbook:2693
#, no-c-format
msgid "position in samples where to go to"
msgstr "posição para onde ir nas amostras"

#. Tag: title
#: index.docbook:2698
#, no-c-format
msgid "&no-i18n-tag;i"
msgstr "&no-i18n-tag;i"

#. Tag: title
#: index.docbook:2701
#, no-c-format
msgid "&no-i18n-cmd_insert_at;"
msgstr "&no-i18n-cmd_insert_at;"

#. Tag: title
#: index.docbook:2703
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_insert_at;</"
"command>(<replaceable>pos</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_insert_at;</"
"command>(<replaceable>pos</replaceable>)"

#. Tag: para
#: index.docbook:2704
#, no-c-format
msgid ""
"Inserts the content of the clipboard at the given position, like the command "
"<command>&no-i18n-cmd_paste;</command>(). If the clipboard is currently "
"empty, this function does nothing."
msgstr ""
"Insere o conteúdo da área de transferência na posição determinada, como o "
"comando <command>&no-i18n-cmd_paste;</command>(). Se a área de transferência "
"estiver vazia no momento, essa função não fará nada."

#. Tag: entry
#: index.docbook:2711
#, no-c-format
msgid "position in samples where to insert"
msgstr "posição onde inserir nas amostras"

#. Tag: title
#: index.docbook:2719
#, no-c-format
msgid "&no-i18n-cmd_insert_track;"
msgstr "&no-i18n-cmd_insert_track;"

#. Tag: title
#: index.docbook:2721
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_insert_track;</"
"command>(<replaceable>index</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_insert_track;</"
"command>(<replaceable>índice</replaceable>)"

#. Tag: para
#: index.docbook:2722
#, no-c-format
msgid ""
"Inserts a new track at the given index, using the current length and sample "
"rate settings of the signal. If the index is higher than or equal to the "
"current number of tracks, it will be appended as the last track, same as by "
"the command <command>&no-i18n-cmd_add_track;</command>(). The index of all "
"existing tracks at and after the given index will be incremented by one."
msgstr ""
"Insere uma nova faixa no índice fornecido, usando as configurações atuais de "
"duração e taxa de amostragem do sinal. Se o índice for maior ou igual ao "
"número atual de faixas, ele será anexado como a última faixa, igual ao "
"comando <command>&no-i18n-cmd_add_track;</command>(). O índice de todas as "
"faixas existentes em e depois do índice dado será incrementado por um."

#. Tag: entry
#: index.docbook:2733
#, no-c-format
msgid "index of the track to insert, starting with 0"
msgstr "índice da faixa a inserir, começando com 0"

#. Tag: link
#: index.docbook:2737
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_add_track;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_add_track;</command>()"

#. Tag: title
#: index.docbook:2743
#, no-c-format
msgid "&no-i18n-tag;l"
msgstr "&no-i18n-tag;l"

#. Tag: title
#: index.docbook:2746
#, no-c-format
msgid "&no-i18n-cmd_label_add;"
msgstr "&no-i18n-cmd_label_add;"

#. Tag: title
#: index.docbook:2748
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_label_add;</"
"command>(<replaceable>pos</replaceable>[,<replaceable>text</replaceable>])"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_label_add;</"
"command>(<replaceable>pos</replaceable>[,<replaceable>texto</replaceable>])"

#. Tag: para
#: index.docbook:2749
#, no-c-format
msgid ""
"Add a new label at a given position. If the given position already contains "
"a label, then this command does nothing. The label can be given an optional "
"description."
msgstr ""
"Adicione um novo rótulo em uma determinada posição. Se a posição dada já "
"contiver um rótulo, este comando não fará nada. Além disso, o rótulo pode "
"receber uma descrição opcional."

#. Tag: entry
#: index.docbook:2756
#, no-c-format
msgid "position in samples where to insert the label"
msgstr "posição onde inserir o rótulo nas amostras"

#. Tag: entry
#: index.docbook:2757 index.docbook:3055
#, no-c-format
msgid "<parameter>text</parameter>:"
msgstr "<parameter>texto</parameter>:"

#. Tag: entry
#: index.docbook:2757
#, no-c-format
msgid "some descriptive text (optional)"
msgstr "algum texto descritivo (opcional)"

#. Tag: title
#: index.docbook:2762
#, no-c-format
msgid "&no-i18n-cmd_label_delete;"
msgstr "&no-i18n-cmd_label_delete;"

#. Tag: title
#: index.docbook:2764
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_label_delete;</"
"command>(<replaceable>index</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_label_delete;</"
"command>(<replaceable>índice</replaceable>)"

#. Tag: para
#: index.docbook:2765
#, no-c-format
msgid ""
"Deletes a label, identified by its index (starting from zero), or all labels "
"when using the special value -1 as index. If no label with the given index "
"exists, this command does nothing."
msgstr ""
"Exclui um rótulo, identificado por seu índice (começando do zero), ou todos "
"os rótulos ao usar o valor especial -1 como índice. Se nenhum rótulo com o "
"índice fornecido existir, este comando não fará nada."

#. Tag: entry
#: index.docbook:2772
#, no-c-format
msgid ""
"index of the label to delete, starting with 0 or -1 to delete all labels"
msgstr ""
"índice do rótulo a ser eliminado, começando por 0 ou -1 para eliminar todos "
"os rótulos"

#. Tag: title
#: index.docbook:2778
#, no-c-format
msgid "&no-i18n-cmd_label_edit;"
msgstr "&no-i18n-cmd_label_edit;"

#. Tag: screeninfo
#: index.docbook:2780 index.docbook:4379 index.docbook:4419 index.docbook:4564
#: index.docbook:4923 index.docbook:5231 index.docbook:5424 index.docbook:5460
#: index.docbook:5550 index.docbook:5643 index.docbook:5706 index.docbook:5750
#: index.docbook:5868 index.docbook:5943 index.docbook:6061 index.docbook:6154
#: index.docbook:6460 index.docbook:6685 index.docbook:6799 index.docbook:6810
#: index.docbook:6948 index.docbook:7002
#, no-c-format
msgid "Screenshot"
msgstr "Captura de tela"

#. Tag: phrase
#: index.docbook:2786
#, no-c-format
msgid "Screenshot of the label editing dialog"
msgstr "Captura de tela da janela de edição de rótulo"

#. Tag: title
#: index.docbook:2791
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_label_edit;</"
"command>(<replaceable>index</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_label_edit;</"
"command>(<replaceable>índice</replaceable>)"

#. Tag: para
#: index.docbook:2792
#, no-c-format
msgid ""
"Opens a dialog window in which the user can edit the position and the "
"description of a label, which is identified by its index (starting from "
"zero). If no label with the given index exists, this command does nothing."
msgstr ""
"Abre uma janela na qual o usuário pode editar a posição e a descrição de um "
"rótulo, que é identificado pelo seu índice (começando do zero). Se nenhum "
"rótulo com o índice fornecido existir, este comando não fará nada."

#. Tag: entry
#: index.docbook:2800
#, no-c-format
msgid "index of the label to edit, starting with 0"
msgstr "índice de rótulo para editar, começando com 0"

#. Tag: title
#: index.docbook:2805
#, no-c-format
msgid "&no-i18n-cmd_loadbatch;"
msgstr "&no-i18n-cmd_loadbatch;"

#. Tag: title
#: index.docbook:2807
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_loadbatch;</"
"command>(<replaceable>filename</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_loadbatch;</"
"command>(<replaceable>arquivo</replaceable>)"

#. Tag: para
#: index.docbook:2808
#, no-c-format
msgid ""
"Opens a &kwave; script file and processes the commands in it. Uses the "
"context of the currently opened file or the current main window if no file "
"is loaded."
msgstr ""
"Abre um arquivo de script do &kwave; e processa os comandos nele. Usa o "
"contexto do arquivo atualmente aberto ou da janela principal atual se nenhum "
"arquivo for carregado."

#. Tag: entry
#: index.docbook:2815 index.docbook:3138 index.docbook:3164 index.docbook:3460
#: index.docbook:3493 index.docbook:4234
#, no-c-format
msgid "<parameter>filename</parameter>:"
msgstr "<parameter>arquivo</parameter>:"

#. Tag: entry
#: index.docbook:2816
#, no-c-format
msgid "name of the kwave script file including path and extension"
msgstr "nome do arquivo de script kwave, incluindo caminho e extensão"

#. Tag: title
#: index.docbook:2821
#, no-c-format
msgid "&no-i18n-cmd_loop;"
msgstr "&no-i18n-cmd_loop;"

#. Tag: title
#: index.docbook:2823
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_loop;</command>()"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_loop;</command>()"

#. Tag: para
#: index.docbook:2824
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Loop</guibutton> toolbar button. Starts the "
"playback (if it is not already running) and lets it play in a loop."
msgstr ""
"Corresponde ao botão da barra de ferramentas <guibutton>Repetição</"
"guibutton>. Inicia a reprodução (se ainda não estiver em execução) e permite "
"repetir a reprodução."

#. Tag: link
#: index.docbook:2832
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_playback_start;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_playback_start;</command>()"

#. Tag: title
#: index.docbook:2838
#, no-c-format
msgid "&no-i18n-tag;m"
msgstr "&no-i18n-tag;m"

#. Tag: title
#: index.docbook:2841
#, no-c-format
msgid "&no-i18n-cmd_menu;"
msgstr "&no-i18n-cmd_menu;"

#. Tag: title
#: index.docbook:2843
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_menu;</command> "
"(<replaceable>command</replaceable>, <replaceable>path</replaceable>, "
"[<replaceable>hotkey</replaceable>], [<replaceable>id</replaceable>])"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_menu;</command> "
"(<replaceable>comando</replaceable>, <replaceable>caminho</replaceable>, "
"[<replaceable>atalho</replaceable>], [<replaceable>id</replaceable>])"

#. Tag: para
#: index.docbook:2849
#, no-c-format
msgid ""
"This is a very powerful command, which is used to add a new entry to the "
"menu or to modify an existing entry. It determines which <emphasis>command</"
"emphasis> is executed when the menu entry is activated, which "
"<emphasis>icon</emphasis> is shown in the menu and which <emphasis>hotkey</"
"emphasis> is used. Each menu entry can be <emphasis>disabled</emphasis> or "
"<emphasis>hidden</emphasis>, can be assigned a unique <emphasis>id</"
"emphasis> and can also join a <emphasis>menu group</emphasis>."
msgstr ""
"Este é um comando muito poderoso, que é usado para adicionar uma nova "
"entrada ao menu ou para modificar uma entrada existente. Determina qual "
"<emphasis>comando</emphasis>  é executado quando a entrada do menu é "
"ativada, qual <emphasis>ícone</emphasis> é mostrado no menu e qual "
"<emphasis>tecla de atalho</emphasis> é usada. Cada entrada de menu pode ser "
"<emphasis>desativada</emphasis> ou <emphasis>oculta</emphasis>, pode ser "
"atribuída uma <emphasis>identificação única</emphasis> e também pode "
"participar de um <emphasis>grupo de menus</emphasis>."

#. Tag: para
#: index.docbook:2860
#, no-c-format
msgid "You normally do not need this command within a &kwave; script!"
msgstr ""
"Você normalmente não precisa deste comando dentro de um script do &kwave;!"

#. Tag: entry
#: index.docbook:2867
#, no-c-format
msgid ""
"A text command (including parameters) or a command list that will be "
"executed when the menu entry gets activated. If a menu entry does not have a "
"corresponding command (for example if it is a sub menu and not menu entry), "
"you should use the special command <command>ignore</command>()."
msgstr ""
"Um comando de texto (incluindo parâmetros) ou uma lista de comandos que será "
"executada quando a entrada do menu for ativada. Se uma entrada do menu não "
"tiver um comando correspondente (por exemplo, se for um submenu e não uma "
"entrada do menu), você deve usar o comando especial <command>ignore</"
"command> ()."

#. Tag: entry
#: index.docbook:2876
#, no-c-format
msgid "<parameter>path</parameter>:"
msgstr "<parameter>caminho</parameter>:"

#. Tag: entry
#: index.docbook:2877
#, no-c-format
msgid ""
"The path within the menu, using a <quote><token>/</token></quote> as "
"separator. The last part of the path can be a <emphasis>sub command</"
"emphasis> which modifies some property of the menu entry (see <link linkend="
"\"menu_sub_commands\">below</link>). The last portion of the path (that is "
"not a sub command) produces a menu entry, the parts before produce the main "
"menu entry or sub menus that lead to it. Main menu entries or sub menus are "
"automatically created when a menu entry is created, you do not need them "
"manually."
msgstr ""
"O caminho dentro do menu, usando um <quote><token>/</token></quote> como "
"separador. A última parte do caminho poderá ser um <emphasis>sub-comando</"
"emphasis> que modifica uma dada propriedade da entrada do menu (ver <link "
"linkend=\"menu_sub_commands\">abaixo</link>). A última parte do caminho (que "
"não seja um sub-comando) produz uma entrada do menu, enquanto aspartes "
"anteriores produzem a entrada de menu principal ou os sub-menus que conduzem "
"até ela. As entradas do menu principal ou os sub-menus são criados "
"automaticamente quando criar uma entrada de menu, você não precisa criá-las "
"manualmente."

#. Tag: entry
#: index.docbook:2890
#, no-c-format
msgid "<parameter>hotkey</parameter>:"
msgstr "<parameter>atalho</parameter>:"

#. Tag: entry
#: index.docbook:2891
#, no-c-format
msgid ""
"A bitmask that consists of a combination of predefined <emphasis>keys</"
"emphasis> and <emphasis>modifiers</emphasis>, concatenated with a "
"<quote><token>+</token></quote>. The <emphasis>key</emphasis> can be either "
"a digit, an upper case letter, a function key (<quote>F1</quote> ... "
"<quote>F12</quote>) or any other key name understood by the Qt class "
"<quote><literal>QKeySequence</literal></quote>, including key names for "
"predefined actions (like for example <quote><literal>::Copy</literal></"
"quote>). Typical <emphasis>modifiers</emphasis> are <quote><literal>SHIFT</"
"literal></quote>, <quote><literal>ALT</literal></quote> and "
"<quote><literal>CTRL</literal></quote>."
msgstr ""
"Uma máscara de bits que consiste em uma combinação predefinida de "
"<emphasis>teclas</emphasis> e <emphasis>modificadores</emphasis>, em "
"associação com um <quote><token>+</token></quote>. A <emphasis>tecla</"
"emphasis> poderá ser um número, uma letra maiúscula, uma tecla de função "
"(<quote>F1</quote> ... <quote>F12</quote>) ou qualquer outro nome de tecla "
"compreendido pela classe Qt <quote><literal>QKeySequence</literal></quote>, "
"incluindo nome de teclas das ações predefinidas (como por exemplo "
"<quote><literal>::Copy</literal></quote>). Os <emphasis>modificadores</"
"emphasis> típicos são <quote><literal>SHIFT</literal></quote>, "
"<quote><literal>ALT</literal></quote> e <quote><literal>CTRL</literal></"
"quote>."

#. Tag: entry
#: index.docbook:2909
#, no-c-format
msgid "<parameter>id</parameter>:"
msgstr "<parameter>id</parameter>:"

#. Tag: entry
#: index.docbook:2910
#, no-c-format
msgid ""
"A unique id that can be internally used to identify this menu entry or "
"menu / sub menu. Only uppercase letters, digits and <quote><literal>_</"
"literal></quote> should be used and it should start with "
"<quote><literal>ID_</literal></quote>. It is in your own responsibility to "
"make sure that the same id is not used twice."
msgstr ""
"Um id único que possa ser usado internamente para identificar esta entrada "
"de menu ou menu / sub-menu. Só deverão ser usadas letras maiúsculas, números "
"e o <quote><literal>_</literal></quote> e deverá iniciar com "
"<quote><literal>ID_</literal></quote>. É de sua responsabilidade garantir "
"que o mesmo id não seja usado duas vezes."

#. Tag: title
#: index.docbook:2920
#, no-c-format
msgid "Sub Commands"
msgstr "Sub-Comandos"

#. Tag: entry
#: index.docbook:2922
#, no-c-format
msgid "<command>&no-i18n-tag;#checkable</command>:"
msgstr "<command>&no-i18n-tag;#checkable</command>:"

#. Tag: entry
#: index.docbook:2923
#, no-c-format
msgid ""
"Makes the menu entry <emphasis>checkable</emphasis>, so that it can be "
"switched on or off."
msgstr ""
"Torna a entrada do menu <emphasis>marcável</emphasis>, para que possa ser "
"ativada ou desativada."

#. Tag: entry
#: index.docbook:2928
#, no-c-format
msgid "<command>&no-i18n-tag;#disabled</command>:"
msgstr "<command>&no-i18n-tag;#disabled</command>:"

#. Tag: entry
#: index.docbook:2929
#, no-c-format
msgid "<emphasis>Disables</emphasis> the menu, sub menu or menu entry."
msgstr ""
"<emphasis>Desabilita</emphasis> o menu, o submenu ou a entrada de menu."

#. Tag: entry
#: index.docbook:2933
#, no-c-format
msgid "<command>&no-i18n-tag;#enabled</command>:"
msgstr "<command>&no-i18n-tag;#enabled</command>:"

#. Tag: entry
#: index.docbook:2934
#, no-c-format
msgid "<emphasis>Enables</emphasis> the menu, sub menu or menu entry."
msgstr "<emphasis>Habilita</emphasis> o menu, o submenu ou a entrada do menu."

#. Tag: entry
#: index.docbook:2938
#, no-c-format
msgid "<command>#exclusive</command>(<replaceable>group</replaceable>):"
msgstr "<command>#exclusive</command>(<replaceable>grupo</replaceable>):"

#. Tag: entry
#: index.docbook:2939
#, no-c-format
msgid ""
"Adds the menu entry to an <emphasis>exclusive</emphasis> "
"<emphasis><replaceable>group</replaceable></emphasis> (one of many "
"selection). The group that is given as parameter should not be used for any "
"other purpose. Only one entry within that group can be selected at a time."
msgstr ""
"Adiciona uma entrada de menu a um <emphasis><replaceable>grupo </"
"replaceable></emphasis> <emphasis>exclusivo</emphasis>(uma das muitas "
"opções). O grupo que é dado como parâmetro não deve ser usado para qualquer "
"outra finalidade. Apenas uma entrada nesse grupo pode ser selecionada por "
"vez."

#. Tag: entry
#: index.docbook:2947
#, no-c-format
msgid "<command>#group</command>(<replaceable>list</replaceable>):"
msgstr "<command>#group</command>(<replaceable>lista</replaceable>):"

#. Tag: para
#: index.docbook:2948
#, no-c-format
msgid ""
"Adds the menu, sub menu or menu entry to one or more a <emphasis>groups</"
"emphasis>, so that the application can enable/disable a bunch of menu "
"entries without need to know all their unique ids. Multiple groups can be "
"passed as a list with a <quote><literal>,</literal></quote> as separator. "
"Group names have to start with a <quote><literal>@</literal></quote>. The "
"following groups are predefined:"
msgstr ""
"Adiciona o menu, submenu ou entrada de menu a um ou mais <emphasis>grupos</"
"emphasis>, para que o aplicativo possa habilitar/desabilitar várias entradas "
"de menu sem precisar conhecer todas suas identidades únicas exclusivas. "
"Vários grupos podem ser passados como uma lista com uma <quote><literal>,</"
"literal></quote> como separador. Ainda, nomes de grupos têm que iniciar com "
"uma <quote><literal>@</literal></quote>. E os seguintes grupos são "
"predefinidos:"

#. Tag: term
#: index.docbook:2959
#, no-c-format
msgid "<command>&no-i18n-tag;@CLIPBOARD</command>:"
msgstr "<command>&no-i18n-tag;@CLIPBOARD</command>:"

#. Tag: para
#: index.docbook:2961
#, no-c-format
msgid "Only enabled when the clipboard is not empty."
msgstr "Habilitado somente quando a área de transferência não estiver vazia."

#. Tag: term
#: index.docbook:2967
#, no-c-format
msgid "<command>&no-i18n-tag;@LABELS</command>:"
msgstr "<command>&no-i18n-tag;@LABELS</command>:"

#. Tag: para
#: index.docbook:2969
#, no-c-format
msgid "Only enabled when the current signal contains at least one label."
msgstr "Habilitado somente quando o sinal atual contiver pelo menos um rótulo."

#. Tag: term
#: index.docbook:2976
#, no-c-format
msgid "<command>&no-i18n-tag;@NOT_CLOSED</command>:"
msgstr "<command>&no-i18n-tag;@NOT_CLOSED</command>:"

#. Tag: para
#: index.docbook:2978
#, no-c-format
msgid ""
"Enabled when the current signal is not closed (the signal might be empty or "
"zero length)."
msgstr ""
"Habilitado quando o sinal atual não está fechado (o sinal pode estar vazio "
"ou com duração igual a zero)."

#. Tag: term
#: index.docbook:2985
#, no-c-format
msgid "<command>&no-i18n-tag;@SELECTION</command>:"
msgstr "<command>&no-i18n-tag;@SELECTION</command>:"

#. Tag: para
#: index.docbook:2987
#, no-c-format
msgid ""
"Enabled when the selection is not empty (more than one sample is selected)."
msgstr ""
"Habilitado quando a seleção não está vazia (mais de uma amostra é "
"selecionada)."

#. Tag: term
#: index.docbook:2994
#, no-c-format
msgid "<command>&no-i18n-tag;@SIGNAL</command>:"
msgstr "<command>&no-i18n-tag;@SIGNAL</command>:"

#. Tag: para
#: index.docbook:2996
#, no-c-format
msgid ""
"Enabled when there is some signal loaded and it is not empty or zero length."
msgstr ""
"Habilitado quando há algum sinal carregado e não está vazio ou com duração "
"igual a zero."

#. Tag: entry
#: index.docbook:3005
#, no-c-format
msgid "<command>&no-i18n-tag;#hidden</command>:"
msgstr "<command>&no-i18n-tag;#hidden</command>:"

#. Tag: entry
#: index.docbook:3006
#, no-c-format
msgid "<emphasis>Hides</emphasis> the menu, sub menu or menu entry."
msgstr "<emphasis>Esconde</emphasis> o menu, sub-menu ou entrada de menu."

#. Tag: entry
#: index.docbook:3009
#, no-c-format
msgid "<command>#icon</command>(<replaceable>name</replaceable>):"
msgstr "<command>#icon</command>(<replaceable>nome</replaceable>):"

#. Tag: entry
#: index.docbook:3010
#, no-c-format
msgid ""
"Assigns an <emphasis>icon</emphasis> to the menu entry. The icon "
"<emphasis><replaceable>name</replaceable></emphasis> should correspond to an "
"icon file (without path and file extension) that is installed on the system "
"or with &kwave;."
msgstr ""
"Atribui um <emphasis>ícone</emphasis> a uma entrada de menu. O "
"<emphasis><replaceable>nome</replaceable></emphasis> do ícone deverá "
"corresponder  a um arquivo de ícone (sem caminho e extensão de arquivo) que "
"é instalado com o sistema ou com o &kwave;."

#. Tag: entry
#: index.docbook:3018
#, no-c-format
msgid ""
"<command>#listmenu</command>(<replaceable>id</replaceable>,"
"<replaceable>command</replaceable>):"
msgstr ""
"<command>#listmenu</command>(<replaceable>id</replaceable>,"
"<replaceable>comando</replaceable>):"

#. Tag: entry
#: index.docbook:3019
#, no-c-format
msgid ""
"Inserts a placeholder for a list of menu entries into a sub menu. The unique "
"<emphasis><replaceable>id</replaceable></emphasis> specified in this sub "
"command is used to add/remove or clear the list of menu entries. The "
"<emphasis><replaceable>command</replaceable></emphasis> parameter has to "
"contain <quote><literal>%1</literal></quote> as parameter, which will be "
"replaced with the text of the menu entry when it is activated. This sub "
"command is internally used for the list of recent files, list of tracks and "
"window list."
msgstr ""
"Insere um item de substituição para uma lista de entradas de menu para um "
"sub-menu. O <emphasis><replaceable>id</replaceable></emphasis> único "
"indicado neste sub-comando é usado para adicionar/remover ou limpar alista "
"de itens do menu. O parâmetro <emphasis><replaceable>comando </replaceable></"
"emphasis> tem de <quote><literal>%1</literal></quote> como parâmetro, o qual "
"será substituído pelo texto da entrada de menu, quando for ativado. (Este "
"sub-comando é usado internamente pela lista de arquivos recentes, pela lista "
"de faixas e pela lista de janelas)."

#. Tag: entry
#: index.docbook:3033
#, no-c-format
msgid "<command>&no-i18n-tag;#separator</command>:"
msgstr "<command>&no-i18n-tag;#separator</command>:"

#. Tag: entry
#: index.docbook:3034
#, no-c-format
msgid "Inserts a separator into a sub menu."
msgstr "Insere um separador em um submenu."

#. Tag: title
#: index.docbook:3044
#, no-c-format
msgid "&no-i18n-cmd_msgbox;"
msgstr "&no-i18n-cmd_msgbox;"

#. Tag: title
#: index.docbook:3046
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_msgbox;</command>(<replaceable>text</"
"replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_msgbox;</command>(<replaceable>texto</"
"replaceable>)"

#. Tag: para
#: index.docbook:3047
#, no-c-format
msgid ""
"Shows a message box with some <emphasis><replaceable>text</replaceable></"
"emphasis> and the two buttons <guibutton>OK</guibutton> (returns without "
"error code) and <guibutton>Cancel</guibutton> (returns and error code). You "
"can use this command to give the user a possibility to abort a running "
"script."
msgstr ""
"Mostra uma caixa de mensagem com algum <emphasis><replaceable>texto</"
"replaceable></emphasis> e dois botões <guibutton>OK</guibutton> (retorna sem "
"código de erro) e <guibutton>Cancelar</guibutton> (retorna com código de "
"erro). Você pode usar este comando para dar ao usuário a possibilidade de "
"interromper um script em execução."

#. Tag: entry
#: index.docbook:3056
#, no-c-format
msgid ""
"A message that will be shown in the message box, should contain a question "
"that can be answered with <guibutton>OK</guibutton> or <guibutton>Cancel</"
"guibutton>."
msgstr ""
"Uma mensagem que será exibida na caixa de mensagem deve conter uma pergunta "
"que possa ser respondida com <guibutton>OK</guibutton> ou "
"<guibutton>Cancelar</guibutton>."

#. Tag: title
#: index.docbook:3066
#, no-c-format
msgid "&no-i18n-tag;n"
msgstr "&no-i18n-tag;n"

#. Tag: title
#: index.docbook:3069
#, no-c-format
msgid "&no-i18n-cmd_newsignal;"
msgstr "&no-i18n-cmd_newsignal;"

#. Tag: title
#: index.docbook:3071
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_newsignal;</"
"command>( <replaceable>samples</replaceable>, <replaceable>rate</"
"replaceable>, <replaceable>bits</replaceable>, <replaceable>tracks</"
"replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_newsignal;</"
"command>( <replaceable>amostras</replaceable>, <replaceable>taxa</"
"replaceable>, <replaceable>bits</replaceable>, <replaceable>faixas</"
"replaceable>)"

#. Tag: para
#: index.docbook:3077
#, no-c-format
msgid ""
"Creates a new signal, with a given length in <emphasis><replaceable>samples</"
"replaceable></emphasis>, a <emphasis><replaceable>rate</replaceable></"
"emphasis> in samples per second (floating point number), a number of "
"<emphasis><replaceable>bits</replaceable></emphasis> per sample and number "
"of <emphasis><replaceable>tracks</replaceable></emphasis>. You can calculate "
"the length in samples by multiplying the desired length in seconds with the "
"sample rate."
msgstr ""
"Cria um novo sinal, com uma dada duração em <emphasis><replaceable>amostras</"
"replaceable></emphasis>, uma <emphasis><replaceable>taxa</replaceable></"
"emphasis> em amostras por segundo (número de ponto flutuante), um número de "
"<emphasis><replaceable>bits</replaceable></emphasis> por amostra e número de "
"<emphasis><replaceable>faixas</replaceable></emphasis>. Você pode calcular a "
"duração em amostras multiplicando o comprimento desejado em segundos com a "
"taxa de amostragem."

#. Tag: entry
#: index.docbook:3089
#, no-c-format
msgid "<parameter>samples</parameter>:"
msgstr "<parameter>amostras</parameter>:"

#. Tag: entry
#: index.docbook:3090
#, no-c-format
msgid "Length of the signal in samples."
msgstr "Duração do sinal nas amostras."

#. Tag: entry
#: index.docbook:3091
#, no-c-format
msgid "<parameter>rate</parameter>:"
msgstr "<parameter>taxa</parameter>:"

#. Tag: entry
#: index.docbook:3092
#, no-c-format
msgid "<entry>Sample rate in samples per second.</entry>"
msgstr "<entry>Taxa de amostragem em amostras por segundo.</entry>"

#. Tag: entry
#: index.docbook:3093
#, no-c-format
msgid "<parameter>bits</parameter>:"
msgstr "<parameter>bits</parameter>:"

#. Tag: entry
#: index.docbook:3094
#, no-c-format
msgid ""
"Number of bits per sample, must not be zero, should be a number from 8...32."
msgstr ""
"Número de bits por amostra, não deve ser igual a zero e deve ser um número "
"de 8... 32."

#. Tag: entry
#: index.docbook:3096
#, no-c-format
msgid "<parameter>tracks</parameter>:"
msgstr "<parameter>faixas</parameter>:"

#. Tag: entry
#: index.docbook:3097
#, no-c-format
msgid "Number of tracks."
msgstr "Número de faixas."

#. Tag: title
#: index.docbook:3102
#, no-c-format
msgid "&no-i18n-cmd_next;"
msgstr "&no-i18n-cmd_next;"

#. Tag: title
#: index.docbook:3104
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_next;</command>()"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_next;</command>()"

#. Tag: para
#: index.docbook:3105
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Next</guibutton> toolbar button. If the "
"playback is currently running, it skips forward to the next label. If the "
"playback is not running, this does the same as the command <command>&no-i18n-"
"cmd_view_scroll_next_label;</command>()."
msgstr ""
"Corresponde ao botão da barra de ferramentas <guibutton>Próximo</guibutton>."
"Se a reprodução estiver em execução, ela avança para o próximo rótulo. Se a "
"reprodução não estiver em execução, isso faz o mesmo que o comando "
"<command>&no-i18n-cmd_view_scroll_next_label;</command>()."

#. Tag: para
#: index.docbook:3114
#, no-c-format
msgid ""
"<link linkend=\"cmd_sect_view_scroll_next_label\"><command>&no-i18n-tag;&no-"
"i18n-cmd_view_scroll_next_label;</command>()</link>, <link linkend="
"\"cmd_sect_prev\"><command>&no-i18n-tag;&no-i18n-cmd_prev;</command>()</link>"
msgstr ""
"<link linkend=\"cmd_sect_view_scroll_next_label\"><command>&no-i18n-tag;&no-"
"i18n-cmd_view_scroll_next_label;</command>()</link>, <link linkend="
"\"cmd_sect_prev\"><command>&no-i18n-tag;&no-i18n-cmd_prev;</command>()</link>"

#. Tag: title
#: index.docbook:3122
#, no-c-format
msgid "&no-i18n-tag;o"
msgstr "&no-i18n-tag;o"

#. Tag: title
#: index.docbook:3125
#, no-c-format
msgid "&no-i18n-cmd_open;"
msgstr "&no-i18n-cmd_open;"

#. Tag: title
#: index.docbook:3127
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_open;</"
"command>([<replaceable>filename</replaceable>])"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_open;</"
"command>([<replaceable>arquivo</replaceable>])"

#. Tag: para
#: index.docbook:3128
#, no-c-format
msgid ""
"Opens a file, which can be either a sound file or a &kwave; script. If no "
"file name is passed, then a dialog window will be opened that allows to "
"select an existing file. Depending on the &GUI; mode the file will be opened "
"in the context of a new sub-window (MDI and tab) or in a new main window "
"(SDI, if there was already something loaded)."
msgstr ""
"Abre um arquivo, que pode ser um arquivo de som ou um script do &kwave;. Se "
"nenhum nome de arquivo for passado, será aberta uma janela que permitirá "
"selecionar um arquivo existente. Dependendo do modo &GUI;, o arquivo será "
"aberto no contexto de uma nova sub-janela (MDI e Aba) ou em uma nova janela "
"principal (SDI, se já houver algo carregado)."

#. Tag: entry
#: index.docbook:3139
#, no-c-format
msgid "name of a file including path and extension"
msgstr "nome de um arquivo, incluindo caminho e extensão"

#. Tag: link
#: index.docbook:3143 index.docbook:3332
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_close;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_close;</command>()"

#. Tag: title
#: index.docbook:3149
#, no-c-format
msgid "&no-i18n-cmd_openrecent;"
msgstr "&no-i18n-cmd_openrecent;"

#. Tag: title
#: index.docbook:3151
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_openrecent;</"
"command>(<replaceable>filename</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_openrecent;</"
"command>(<replaceable>arquivo</replaceable>)"

#. Tag: para
#: index.docbook:3152
#, no-c-format
msgid ""
"Practically the same as the command <command>&no-i18n-cmd_open;</command>(), "
"but intended to be used internally for the list of recently opened files in "
"the menu <menuchoice> <guimenu>File</guimenu><guimenu>Open Recent</guimenu> "
"</menuchoice>. In this command the parameter <replaceable>filename</"
"replaceable> is not optional."
msgstr ""
"Praticamente idêntico ao comando <command>&no-i18n-cmd_open;</command>(), "
"mas destina-se a ser usado internamente para a lista de arquivos abertos "
"recentemente no menu <menuchoice> <guimenu>Arquivo</guimenu><guimenu>Abrir "
"recente</guimenu> </menuchoice>. No comando o parâmetro "
"<replaceable>arquivo</replaceable> não é opcional."

#. Tag: entry
#: index.docbook:3165
#, no-c-format
msgid "entry of the list of recently opened files"
msgstr "entrada da lista de arquivos abertos recentemente"

#. Tag: link
#: index.docbook:3169
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_open;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_open;</command>()"

#. Tag: title
#: index.docbook:3175
#, no-c-format
msgid "&no-i18n-tag;p"
msgstr "&no-i18n-tag;p"

#. Tag: title
#: index.docbook:3178
#, no-c-format
msgid "&no-i18n-cmd_paste;"
msgstr "&no-i18n-cmd_paste;"

#. Tag: title
#: index.docbook:3180
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_paste;</command>()"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_paste;</command>()"

#. Tag: para
#: index.docbook:3181
#, no-c-format
msgid ""
"Replaces the current selection with the content of the clipboard. If the "
"clipboard is empty, this command does nothing. The sample rate of the "
"inserted data is adjusted to match the sample rate of the current signal if "
"necessary. Only enabled tracks are affected, disabled tracks remain "
"unchanged. Please be aware that this might produce a time shift between "
"enabled and disabled tracks! If the number of tracks of the clipboard data "
"differs from the number of enabled tracks, then the data is mixed to be "
"spread equally over all selected tracks."
msgstr ""
"Substitui a seleção atual pelo conteúdo da área de transferência. Se a área "
"de transferência estiver vazia, esse comando não faz nada. A taxa de "
"amostragem dos dados inseridos é ajustada para corresponder à taxa de "
"amostragem do sinal atual, se necessário. Apenas as faixas habilitadas são "
"afetadas, as faixas desabilitadas permanecem inalteradas. Esteja ciente de "
"que isso pode produzir uma mudança de horário entre as faixas habilitadas e "
"desabilitadas! Se o número de faixas dos dados da área de transferência for "
"diferente do número de faixas habilitadas, os dados serão misturados para "
"serem distribuídos igualmente por todas as faixas selecionadas."

#. Tag: link
#: index.docbook:3196
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_copy;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_copy;</command>()"

#. Tag: title
#: index.docbook:3202
#, no-c-format
msgid "&no-i18n-cmd_pause;"
msgstr "&no-i18n-cmd_pause;"

#. Tag: para
#: index.docbook:3205
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Pause</guibutton> toolbar button and lets the "
"playback pause if it is currently running, or continue if it is currently "
"paused."
msgstr ""
"Corresponde ao botão da barra de ferramentas <guibutton>Pausar</guibutton> e "
"permite que a reprodução seja pausada se estiver em execução no momento ou "
"continue se estiver pausada no momento."

#. Tag: link
#: index.docbook:3213
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_continue;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_continue;</command>()"

#. Tag: title
#: index.docbook:3219
#, no-c-format
msgid "&no-i18n-cmd_playback_start;"
msgstr "&no-i18n-cmd_playback_start;"

#. Tag: title
#: index.docbook:3221
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_playback_start;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_playback_start;</"
"command>()"

#. Tag: para
#: index.docbook:3222
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Start</guibutton> toolbar button and lets the "
"playback start if it is currently paused."
msgstr ""
"Corresponde ao botão da barra de ferramentas <guibutton>Iniciar</guibutton> "
"e permite que a reprodução inicie se estiver pausada no momento."

#. Tag: title
#: index.docbook:3230
#, no-c-format
msgid "&no-i18n-cmd_plugin;"
msgstr "&no-i18n-cmd_plugin;"

#. Tag: title
#: index.docbook:3232
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_plugin;</command>(<replaceable>name</"
"replaceable>, [<replaceable>parameter</replaceable> ...])"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_plugin;</command>(<replaceable>nome</"
"replaceable>, [<replaceable>parâmetro</replaceable> ...])"

#. Tag: para
#: index.docbook:3233
#, no-c-format
msgid ""
"Executes a plugin, with an optional list of parameters. If no parameter list "
"is given, then the setup function of the plugin will be called, using the "
"parameters of the previous invocation or default parameters as input "
"(normally shows a setup dialog, depending on the plugin). Please refer to "
"the chapter about <link linkend=\"plugins\">plugins</link> for a description "
"of the various plugins."
msgstr ""
"Executa um plugin, com uma lista opcional de parâmetros. Se nenhuma lista de "
"parâmetros for dada, então a função de configuração do plugin será chamada "
"usando os parâmetros da invocação anterior ou os parâmetros padrões como "
"entrada (normalmente mostra uma janela de configuração, dependendo do "
"plugin). Por favor, consulte o capítulo sobre <link linkend=\"plugins"
"\">plugins</link> para uma descrição dos vários plugins."

#. Tag: entry
#: index.docbook:3244 index.docbook:3268 index.docbook:3290
#, no-c-format
msgid "<parameter>name</parameter>:"
msgstr "<parameter>nome</parameter>:"

#. Tag: entry
#: index.docbook:3245 index.docbook:3269 index.docbook:3291
#, no-c-format
msgid "the (internal) name of a &kwave; plugin"
msgstr "o nome (interno) de um plugin do &kwave;"

#. Tag: entry
#: index.docbook:3246 index.docbook:3270 index.docbook:3292
#, no-c-format
msgid "<parameter>parameter</parameter>:"
msgstr "<parameter>parâmetro</parameter>:"

#. Tag: entry
#: index.docbook:3247 index.docbook:3293
#, no-c-format
msgid "a list of parameters understood by the plugin (optional)"
msgstr "uma lista de parâmetros compreendidos pelo plugin (opcional)"

#. Tag: para
#: index.docbook:3250
#, no-c-format
msgid ""
"<link linkend=\"cmd_sect_plugin_execute\"><command>&no-i18n-tag;&no-i18n-"
"cmd_plugin_execute;</command>()</link>, <link linkend=\"cmd_sect_plugin_setup"
"\"><command>&no-i18n-tag;&no-i18n-cmd_plugin_setup;</command>()</link>"
msgstr ""
"<link linkend=\"cmd_sect_plugin_execute\"><command>&no-i18n-tag;&no-i18n-"
"cmd_plugin_execute;</command>()</link>, <link linkend=\"cmd_sect_plugin_setup"
"\"><command>&no-i18n-tag;&no-i18n-cmd_plugin_setup;</command>()</link>"

#. Tag: title
#: index.docbook:3258
#, no-c-format
msgid "&no-i18n-cmd_plugin_execute;"
msgstr "&no-i18n-cmd_plugin_execute;"

#. Tag: title
#: index.docbook:3260
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_plugin_execute;</"
"command>(<replaceable>name</replaceable>, [<replaceable>parameter</"
"replaceable> ...])"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_plugin_execute;</"
"command>(<replaceable>nome</replaceable>, [<replaceable>parâmetro</"
"replaceable> ...])"

#. Tag: para
#: index.docbook:3261
#, no-c-format
msgid ""
"Similar to the command <command>&no-i18n-cmd_plugin;</command>(), but "
"without calling the setup function of the plugin if no parameters were "
"passed."
msgstr ""
"Semelhante ao comando <command>&no-i18n-cmd_plugin;</command>(), mas sem "
"chamar a função de configuração do plugin se nenhum parâmetro foi passado."

#. Tag: entry
#: index.docbook:3271
#, no-c-format
msgid "a list of parameters understood by the plugin"
msgstr "uma lista de parâmetros compreendidos pelo plugin"

#. Tag: title
#: index.docbook:3276
#, no-c-format
msgid "&no-i18n-cmd_plugin_setup;"
msgstr "&no-i18n-cmd_plugin_setup;"

#. Tag: title
#: index.docbook:3278
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_plugin_setup;</"
"command>(<replaceable>name</replaceable>, [<replaceable>parameter</"
"replaceable> ...])"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_plugin_setup;</"
"command>(<replaceable>nome</replaceable>, [<replaceable>parâmetro</"
"replaceable> ...])"

#. Tag: para
#: index.docbook:3279
#, no-c-format
msgid ""
"Calls the <emphasis>setup</emphasis> function of a plugin, with an optional "
"list of parameters. If no parameter list is given, the parameters of the "
"previous invocation or default parameters will be used as input. This "
"normally shows a setup dialog, depending on the plugin. Please refer to the "
"chapter about <link linkend=\"plugins\">plugins</link> for a description of "
"the various plugins."
msgstr ""
"Chama a função <emphasis>configuração</emphasis> de um plugin, com uma lista "
"opcional de parâmetros. Se nenhuma lista de parâmetros for fornecida, os "
"parâmetros da invocação anterior ou os parâmetros padrão serão usados como "
"entrada. Isso normalmente mostra uma janela de configuração, dependendo do "
"plugin. Por favor, consulte o capítulo sobre <link linkend=\"plugins"
"\">plugins</link> para uma descrição dos vários plugins."

#. Tag: title
#: index.docbook:3298
#, no-c-format
msgid "&no-i18n-cmd_prev;"
msgstr "&no-i18n-cmd_prev;"

#. Tag: title
#: index.docbook:3300
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_prev;</command>()"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_prev;</command>()"

#. Tag: para
#: index.docbook:3301
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Previous</guibutton> toolbar button. If the "
"playback is currently running, it skips back to the previous label or start "
"of the selection. If the playback is not running, this does the same as the "
"command <command>&no-i18n-cmd_view_scroll_prev_label;</command>()."
msgstr ""
"Corresponde ao botão da barra de ferramentas <guibutton>Anterior</"
"guibutton>. Se a reprodução estiver em execução, ela volta para o rótulo "
"anterior ou para o início da seleção. Se a reprodução não estiver em "
"execução, isso faz o mesmo que o comando <command>&no-i18n-"
"cmd_view_scroll_prev_label;</command>()."

#. Tag: para
#: index.docbook:3310
#, no-c-format
msgid ""
"<link linkend=\"cmd_sect_view_scroll_next_label\"><command>&no-i18n-tag;&no-"
"i18n-cmd_view_scroll_prev_label;</command>()</link>, <link linkend="
"\"cmd_sect_next\"><command>&no-i18n-tag;&no-i18n-cmd_next;</command>()</link>"
msgstr ""
"<link linkend=\"cmd_sect_view_scroll_next_label\"><command>&no-i18n-tag;&no-"
"i18n-cmd_view_scroll_prev_label;</command>()</link>, <link linkend="
"\"cmd_sect_next\"><command>&no-i18n-tag;&no-i18n-cmd_next;</command>()</link>"

#. Tag: title
#: index.docbook:3318
#, no-c-format
msgid "&no-i18n-tag;q"
msgstr "&no-i18n-tag;q"

#. Tag: title
#: index.docbook:3321
#, no-c-format
msgid "&no-i18n-cmd_quit;"
msgstr "&no-i18n-cmd_quit;"

#. Tag: title
#: index.docbook:3323
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_quit;</command>()"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_quit;</command>()"

#. Tag: para
#: index.docbook:3324
#, no-c-format
msgid ""
"Closes the current main window, including all sub-windows. In SDI mode this "
"is the same as the command <command>&no-i18n-cmd_close;</command>()."
msgstr ""
"Fecha a janela principal atual, incluindo todas as sub-janelas. No modo SDI, "
"este comando é o mesmo que <command>&no-i18n-cmd_close;</command>()."

#. Tag: title
#: index.docbook:3338
#, no-c-format
msgid "&no-i18n-tag;r"
msgstr "&no-i18n-tag;r"

#. Tag: title
#: index.docbook:3341
#, no-c-format
msgid "&no-i18n-cmd_redo;"
msgstr "&no-i18n-cmd_redo;"

#. Tag: title
#: index.docbook:3343
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_redo;</command>()"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_redo;</command>()"

#. Tag: para
#: index.docbook:3344
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Redo</guibutton> toolbar button and repeats "
"one operation that has been reverted with <command>&no-i18n-cmd_undo;</"
"command>()."
msgstr ""
"Corresponde ao botão da barra de ferramentas <guibutton>Refazer</guibutton> "
"e repete uma operação que foi revertida com <command>&no-i18n-cmd_undo;</"
"command>()."

#. Tag: link
#: index.docbook:3352 index.docbook:3368 index.docbook:3826
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_undo;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_undo;</command>()"

#. Tag: title
#: index.docbook:3358
#, no-c-format
msgid "&no-i18n-cmd_redo_all;"
msgstr "&no-i18n-cmd_redo_all;"

#. Tag: title
#: index.docbook:3360
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_redo_all;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_redo_all;</command>()"

#. Tag: para
#: index.docbook:3361
#, no-c-format
msgid ""
"Similar to <command>&no-i18n-cmd_redo;</command>(), but re-does as many "
"operations as possible."
msgstr ""
"Semelhante ao <command>&no-i18n-cmd_redo;</command>(), mas reverte o maior "
"número de operações possíveis."

#. Tag: title
#: index.docbook:3374
#, no-c-format
msgid "&no-i18n-cmd_reenable_dna;"
msgstr "&no-i18n-cmd_reenable_dna;"

#. Tag: title
#: index.docbook:3376
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_reenable_dna;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_reenable_dna;</command>()"

#. Tag: para
#: index.docbook:3377
#, no-c-format
msgid ""
"Some message boxes offer the possibility to prevent them from appearing "
"again (<quote>do not ask again</quote>). This command makes all of them "
"appear again."
msgstr ""
"Algumas caixas de mensagens oferecem a opção de não serem exibidas novamente "
"(<quote>não perguntar novamente</quote>). Este comando faz com que todas "
"apareçam novamente."

#. Tag: title
#: index.docbook:3386
#, no-c-format
msgid "&no-i18n-cmd_reset_toolbars;"
msgstr "&no-i18n-cmd_reset_toolbars;"

#. Tag: title
#: index.docbook:3388
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_reset_toolbars;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_reset_toolbars;</"
"command>()"

#. Tag: para
#: index.docbook:3389
#, no-c-format
msgid ""
"Resets all toolbar settings, like location, icon size and text location back "
"to defaults."
msgstr ""
"Redefine todas as configurações da barra de ferramentas, como localização, "
"tamanho do ícone e localização de texto de volta aos padrões."

#. Tag: title
#: index.docbook:3397
#, no-c-format
msgid "&no-i18n-cmd_revert;"
msgstr "&no-i18n-cmd_revert;"

#. Tag: title
#: index.docbook:3399
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_revert;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_revert;</command>()"

#. Tag: para
#: index.docbook:3400
#, no-c-format
msgid ""
"Reverts the currently loaded file back to the last saved state, discarding "
"all changes that are not saved."
msgstr ""
"Reverte o arquivo atualmente carregado de volta ao último estado salvo, "
"descartando todas as alterações que não foram salvas."

#. Tag: title
#: index.docbook:3408
#, no-c-format
msgid "&no-i18n-cmd_rewind;"
msgstr "&no-i18n-cmd_rewind;"

#. Tag: title
#: index.docbook:3410
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_rewind;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_rewind;</command>()"

#. Tag: para
#: index.docbook:3411
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Rewind</guibutton> toolbar button. If the "
"playback is currently running, it skips backward by 1/10 of the visible "
"range. If the playback is not running, this does the same as the command "
"<command>&no-i18n-cmd_view_scroll_left;</command>()."
msgstr ""
"Corresponde ao botão <guibutton>Retornar</guibutton> na barra de "
"ferramentas. Se a reprodução estiver em curso no momento, irá retornar 1/10 "
"of do intervalo visível. Se a reprodução não estiver em curso fará o mesmo "
"que o comando <command>&no-i18n-cmd_view_scroll_left;</command>()."

#. Tag: para
#: index.docbook:3420
#, no-c-format
msgid ""
"<link linkend=\"cmd_sect_view_scroll_left\"><command>&no-i18n-tag;&no-i18n-"
"cmd_view_scroll_left;</command>()</link>, <link linkend=\"cmd_sect_forward"
"\"><command>&no-i18n-tag;&no-i18n-cmd_forward;</command>()</link>"
msgstr ""
"<link linkend=\"cmd_sect_view_scroll_left\"><command>&no-i18n-tag;&no-i18n-"
"cmd_view_scroll_left;</command>()</link>, <link linkend=\"cmd_sect_forward"
"\"><command>&no-i18n-tag;&no-i18n-cmd_forward;</command>()</link>"

#. Tag: title
#: index.docbook:3428
#, no-c-format
msgid "&no-i18n-tag;s"
msgstr "&no-i18n-tag;s"

#. Tag: title
#: index.docbook:3431
#, no-c-format
msgid "&no-i18n-cmd_save;"
msgstr "&no-i18n-cmd_save;"

#. Tag: title
#: index.docbook:3433
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_save;</command>()"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_save;</command>()"

#. Tag: para
#: index.docbook:3434
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Save</guibutton> toolbar button. Saves the "
"current file if it has modifications. If the file does not already have a "
"name (&eg; a file that has just been created and does not yet have a file "
"name), this command does the same as <command>&no-i18n-cmd_saveas;</"
"command>()."
msgstr ""
"Corresponde ao botão <guibutton>Salvar</guibutton> na barra de ferramentas. "
"Salva o arquivo atual se ele tiver modificações. Se o ficheiro ainda não "
"tiver um nome (&eg; um ficheiro que acabou de ser criado e ainda não tem um "
"nome de ficheiro), este comando faz o mesmo <command>&no-i18n-cmd_saveas;</"
"command>()."

#. Tag: link
#: index.docbook:3444
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_saveas;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_saveas;</command>()"

#. Tag: title
#: index.docbook:3450
#, no-c-format
msgid "&no-i18n-cmd_saveas;"
msgstr "&no-i18n-cmd_saveas;"

#. Tag: title
#: index.docbook:3452
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_saveas;</"
"command>([<replaceable>filename</replaceable>])"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_saveas;</"
"command>([<replaceable>arquivo</replaceable>])"

#. Tag: para
#: index.docbook:3453
#, no-c-format
msgid ""
"Saves the currently opened file under a given file name. If no file name is "
"given as parameter, a dialog will be shown to select the directory and to "
"enter a file name."
msgstr ""
"Salva o arquivo atualmente aberto sob um determinado nome de arquivo. Se "
"nenhum nome de arquivo for fornecido como parâmetro, será exibida uma janela "
"para selecionar a pasta e para digitar um nome de arquivo."

#. Tag: entry
#: index.docbook:3461
#, no-c-format
msgid "file name for saving (optional)"
msgstr "nome de arquivo para salvar (opcional)"

#. Tag: title
#: index.docbook:3466
#, no-c-format
msgid "&no-i18n-cmd_saveselect;"
msgstr "&no-i18n-cmd_saveselect;"

#. Tag: title
#: index.docbook:3468
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_saveselect;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_saveselect;</command>()"

#. Tag: para
#: index.docbook:3469
#, no-c-format
msgid ""
"This command does the same as <command>&no-i18n-cmd_save;</command>(), but "
"saves only the currently selected range and the activated tracks instead of "
"the whole file."
msgstr ""
"Este comando faz o mesmo que o <command>&no-i18n-cmd_save;</command>(), mas "
"salva apenas o intervalo selecionado atualmente e as faixas ativadas em vez "
"do arquivo inteiro."

#. Tag: link
#: index.docbook:3477
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_save;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_save;</command>()"

#. Tag: title
#: index.docbook:3483
#, no-c-format
msgid "&no-i18n-cmd_select_gui_type;"
msgstr "&no-i18n-cmd_select_gui_type;"

#. Tag: title
#: index.docbook:3485
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_select_gui_type;</"
"command>(<replaceable>mode</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_select_gui_type;</"
"command>(<replaceable>modo</replaceable>)"

#. Tag: para
#: index.docbook:3486
#, no-c-format
msgid ""
"Select a &GUI; mode, which can be either SDI, MDI or Tab mode. Please be "
"aware that this change will immediately take effect!"
msgstr ""
"Seleciona um modo de &GUI;, o qual poderá ser SDI, MDI ou Aba. Esteja ciente "
"que estas alterações terão efeito imediatamente!"

#. Tag: entry
#: index.docbook:3494
#, no-c-format
msgid ""
"name of the mode, must be either <quote>SDI</quote>, <quote>MDI</quote> or "
"<quote>TAB</quote>."
msgstr ""
"o nome do modo, que poderá ser <quote>SDI</quote>, <quote>MDI</quote> ou "
"<quote>ABA</quote>."

#. Tag: title
#: index.docbook:3502
#, no-c-format
msgid "&no-i18n-cmd_select_track_all;"
msgstr "&no-i18n-cmd_select_track_all;"

#. Tag: title
#: index.docbook:3504 index.docbook:3521
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_select_track_all;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_select_track_all;</"
"command>()"

#. Tag: para
#: index.docbook:3505
#, no-c-format
msgid ""
"Mark all tracks <quote>enabled</quote>. This is the same as calling the "
"command <command>&no-i18n-tag;&no-i18n-cmd_select_track_on;</command>() for "
"all existing tracks."
msgstr ""
"Marque todas as faixas como <quote>habilitadas</quote>. Isso é o mesmo que "
"chamar o comando <command>&no-i18n-tag;&no-i18n-cmd_select_track_on;</"
"command>() para todas as faixas existentes."

#. Tag: link
#: index.docbook:3513
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_select_track_on;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_select_track_on;</command>()"

#. Tag: title
#: index.docbook:3519
#, no-c-format
msgid "&no-i18n-cmd_select_track_invert;"
msgstr "&no-i18n-cmd_select_track_invert;"

#. Tag: para
#: index.docbook:3522
#, no-c-format
msgid ""
"Invert the <quote>enabled</quote> state of all tracks. This is the same as "
"calling the command <command>&no-i18n-cmd_select_track_toggle;</command>() "
"for all existing tracks."
msgstr ""
"Inverte o estado <quote>habilitado</quote> de todas as faixas. Isso é o "
"mesmo que chamar o comando <command>&no-i18n-cmd_select_track_toggle;</"
"command>() para todas as faixas existentes."

#. Tag: link
#: index.docbook:3531
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_select_track_toggle;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_select_track_toggle;</command>()"

#. Tag: title
#: index.docbook:3537
#, no-c-format
msgid "&no-i18n-cmd_select_track_none;"
msgstr "&no-i18n-cmd_select_track_none;"

#. Tag: title
#: index.docbook:3539
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_select_track_none;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_select_track_none;</"
"command>()"

#. Tag: para
#: index.docbook:3540
#, no-c-format
msgid ""
"Mark all tracks <quote>disabled</quote>. This is the same as calling the "
"command <command>&no-i18n-cmd_select_track_off;</command>() for all existing "
"tracks."
msgstr ""
"Marcar todas as faixas <quote>desabilitadas</quote>. Isto é o mesmo que "
"chamar o comando <command>&no-i18n-cmd_select_track_off;</command>() para "
"todas as faixas existentes."

#. Tag: link
#: index.docbook:3548
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_select_track_off;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_select_track_off;</command>()"

#. Tag: title
#: index.docbook:3554
#, no-c-format
msgid "&no-i18n-cmd_select_track_off;"
msgstr "&no-i18n-cmd_select_track_off;"

#. Tag: title
#: index.docbook:3556
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_select_track_off;</"
"command>(<replaceable>index</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_select_track_off;</"
"command>(<replaceable>índice</replaceable>)"

#. Tag: para
#: index.docbook:3557
#, no-c-format
msgid ""
"Disables a single track, so that it does not get affected by most operations."
msgstr ""
"Desativa uma única faixa, para que ela não seja afetada pela maioria das "
"operações."

#. Tag: entry
#: index.docbook:3564 index.docbook:3578 index.docbook:3593
#, no-c-format
msgid "index of the track, starting with zero"
msgstr "índice da faixa, começando com zero"

#. Tag: title
#: index.docbook:3569
#, no-c-format
msgid "&no-i18n-cmd_select_track_on;"
msgstr "&no-i18n-cmd_select_track_on;"

#. Tag: title
#: index.docbook:3571
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_select_track_on;</"
"command>(<replaceable>index</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_select_track_on;</"
"command>(<replaceable>índice</replaceable>)"

#. Tag: para
#: index.docbook:3572
#, no-c-format
msgid "Enables a single track, so that it gets affected by all operations."
msgstr "Habilita uma única faixa para sofrer todas as operações."

#. Tag: title
#: index.docbook:3583
#, no-c-format
msgid "&no-i18n-cmd_select_track_toggle;"
msgstr "&no-i18n-cmd_select_track_toggle;"

#. Tag: title
#: index.docbook:3585
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_select_track_toggle;</"
"command>(<replaceable>index</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_select_track_toggle;</"
"command>(<replaceable>índice</replaceable>)"

#. Tag: para
#: index.docbook:3586
#, no-c-format
msgid ""
"Enables a track if it is currently disabled, or disables it if it is "
"currently enabled."
msgstr ""
"Habilita uma faixa, se esta estiver desabilitada no momento ou a desabilita "
"se estiver ativada."

#. Tag: title
#: index.docbook:3598
#, no-c-format
msgid "&no-i18n-cmd_selectall;"
msgstr "&no-i18n-cmd_selectall;"

#. Tag: title
#: index.docbook:3600
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectall;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectall;</command>()"

#. Tag: para
#: index.docbook:3601
#, no-c-format
msgid ""
"Selects the range of the whole signal, from the first to the last sample."
msgstr "Seleciona o intervalo de todo o sinal, da primeira à última amostra."

#. Tag: title
#: index.docbook:3609
#, no-c-format
msgid "&no-i18n-cmd_selectnext;"
msgstr "&no-i18n-cmd_selectnext;"

#. Tag: title
#: index.docbook:3611
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectnext;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectnext;</command>()"

#. Tag: para
#: index.docbook:3612
#, no-c-format
msgid ""
"Selects a range of samples that starts right after the current selection, "
"using the same length as the current selection. The selection is "
"automatically clipped to the end of the signal. For example: if you have "
"selected samples 1000 ... 1019, then the result will be a selection from "
"sample 1020 ... 1039."
msgstr ""
"Seleciona um intervalo de amostras que começa logo após a seleção atual, "
"usando o mesmo tamanho da seleção atual. A seleção é automaticamente cortada "
"no final do sinal. Por exemplo: se você selecionou o intervalo da amostra "
"1000... 1019, o resultado será uma seleção da amostra 1020... 1039."

#. Tag: link
#: index.docbook:3622
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_selectprev;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_selectprev;</command>()"

#. Tag: title
#: index.docbook:3628
#, no-c-format
msgid "&no-i18n-cmd_selectnextlabels;"
msgstr "&no-i18n-cmd_selectnextlabels;"

#. Tag: title
#: index.docbook:3630
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectnextlabels;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectnextlabels;</"
"command>()"

#. Tag: para
#: index.docbook:3631
#, no-c-format
msgid ""
"Selects a range of samples between the next two labels after the current "
"selection. If nothing is selected, it selects from the start of the signal "
"up to the first label. Otherwise the left border of the new selection will "
"be the position of first label after the selection (or the last label if "
"there are no more labels right from the selection), and the right border of "
"the new selection will be the first label after the left border of the new "
"selection (or the end of the signal if there is none). This command returns "
"an error when there are no labels at all."
msgstr ""
"Seleciona um intervalo de amostras entre os próximos dois rótulos após a "
"seleção atual. Se nada for selecionado, ele seleciona desde o início do "
"sinal até o primeiro rótulo. Caso contrário, a borda esquerda da nova "
"seleção será a posição do primeiro rótulo após a seleção (ou o último "
"rótulo, se não houver mais rótulos desde a seleção). E a borda direita da "
"nova seleção será o primeiro rótulo após a borda esquerda da nova seleção "
"(ou o final do sinal, se não houver nenhum). Este comando retorna um erro "
"quando não há rótulos."

#. Tag: link
#: index.docbook:3645
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_selectprevlabels;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_selectprevlabels;</command>()"

#. Tag: title
#: index.docbook:3651
#, no-c-format
msgid "&no-i18n-cmd_selectnone;"
msgstr "&no-i18n-cmd_selectnone;"

#. Tag: title
#: index.docbook:3653
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectnone;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectnone;</command>()"

#. Tag: para
#: index.docbook:3654
#, no-c-format
msgid "Resets the selection to zero length."
msgstr "Redefine a seleção para duração zero."

#. Tag: title
#: index.docbook:3661
#, no-c-format
msgid "&no-i18n-cmd_selectprev;"
msgstr "&no-i18n-cmd_selectprev;"

#. Tag: title
#: index.docbook:3663
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectprev;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectprev;</command>()"

#. Tag: para
#: index.docbook:3664
#, no-c-format
msgid ""
"Selects a range of samples that starts left from the current selection, "
"using the same length as the current selection. The selection is "
"automatically clipped to the start of the signal. For example: if you have "
"selected samples 1000 ... 1019, then the result will be a selection from "
"sample 980 ... 999."
msgstr ""
"Seleciona um intervalo de amostras que começa à esquerda da seleção atual, "
"usando a mesma duração da seleção atual. E a seleção é automaticamente "
"cortada no início do sinal. Por exemplo: se você selecionou as amostras "
"1000 ... 1019, o resultado será uma seleção da amostra 980... 999."

#. Tag: link
#: index.docbook:3674
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_selectnext;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_selectnext;</command>()"

#. Tag: title
#: index.docbook:3680
#, no-c-format
msgid "&no-i18n-cmd_selectprevlabels;"
msgstr "&no-i18n-cmd_selectprevlabels;"

#. Tag: title
#: index.docbook:3682
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectprevlabels;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectprevlabels;</"
"command>()"

#. Tag: para
#: index.docbook:3683
#, no-c-format
msgid ""
"Selects a range of samples between the previous two labels before the "
"current selection. If nothing is selected, it selects from the start of the "
"signal up to the first label. Otherwise the right border of the new "
"selection will be the position of first label before the selection (or the "
"first label if there are no more labels left from the selection), and the "
"left border of the new selection will be the first label before the right "
"border of the new selection (or the start of the signal if there is none). "
"This command returns an error when there are no labels at all."
msgstr ""
"Seleciona um intervalo de amostras entre os dois rótulos anteriores antes da "
"seleção atual. Se nada for selecionado, ele seleciona desde o início do "
"sinal até o primeiro rótulo. Caso contrário, a borda direita da nova seleção "
"será a posição do primeiro rótulo antes da seleção (ou o primeiro rótulo, se "
"não houver mais rótulos restantes da seleção). E a borda esquerda da nova "
"seleção será o primeiro rótulo antes da borda direita da nova seleção (ou o "
"início do sinal, se não houver nenhum). Este comando retorna um erro quando "
"não há rótulos."

#. Tag: link
#: index.docbook:3697
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_selectnextlabels;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_selectnextlabels;</command>()"

#. Tag: title
#: index.docbook:3703
#, no-c-format
msgid "&no-i18n-cmd_selecttoleft;"
msgstr "&no-i18n-cmd_selecttoleft;"

#. Tag: title
#: index.docbook:3705
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selecttoleft;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selecttoleft;</command>()"

#. Tag: para
#: index.docbook:3706
#, no-c-format
msgid ""
"Sets the start of the selection to the start of the signal, the end of the "
"current selection stays unchanged."
msgstr ""
"Define o início da seleção como o início do sinal, o final da seleção atual "
"permanece inalterada."

#. Tag: link
#: index.docbook:3713
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_selecttoright;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_selecttoright;</command>()"

#. Tag: title
#: index.docbook:3719
#, no-c-format
msgid "&no-i18n-cmd_selecttoright;"
msgstr "&no-i18n-cmd_selecttoright;"

#. Tag: title
#: index.docbook:3721
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selecttoright;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selecttoright;</"
"command>()"

#. Tag: para
#: index.docbook:3722
#, no-c-format
msgid ""
"Sets the end of the selection to the end of the signal, the start of the "
"current selection stays unchanged."
msgstr ""
"Define o final da seleção como o final do sinal, o início da seleção atual "
"permanece inalterada."

#. Tag: link
#: index.docbook:3729
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_selecttoleft;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_selecttoleft;</command>()"

#. Tag: title
#: index.docbook:3735
#, no-c-format
msgid "&no-i18n-cmd_selectvisible;"
msgstr "&no-i18n-cmd_selectvisible;"

#. Tag: title
#: index.docbook:3737
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectvisible;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectvisible;</"
"command>()"

#. Tag: para
#: index.docbook:3738
#, no-c-format
msgid "Selects the range of samples that is visible in the current window."
msgstr "Seleciona o intervalo de amostras que é visível na janela atual."

#. Tag: title
#: index.docbook:3746
#, no-c-format
msgid "&no-i18n-cmd_start;"
msgstr "&no-i18n-cmd_start;"

#. Tag: title
#: index.docbook:3748
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_start;</command>()"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_start;</command>()"

#. Tag: para
#: index.docbook:3749
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Start</guibutton> toolbar button and lets the "
"playback start from the beginning of the selection or continue if it is "
"currently paused."
msgstr ""
"Corresponde ao botão da barra de ferramentas <guibutton>Iniciar</guibutton> "
"e permite que a reprodução comece no início da seleção ou continue se "
"estiver pausada no momento."

#. Tag: link
#: index.docbook:3757
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_stop;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_stop;</command>()"

#. Tag: title
#: index.docbook:3763
#, no-c-format
msgid "&no-i18n-cmd_stop;"
msgstr "&no-i18n-cmd_stop;"

#. Tag: title
#: index.docbook:3765
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_stop;</command>()"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_stop;</command>()"

#. Tag: para
#: index.docbook:3766
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Stop</guibutton> toolbar button and lets the "
"playback stop if it is currently running."
msgstr ""
"Corresponde ao botão da barra de ferramentas <guibutton>Parar</guibutton> e "
"permite que a reprodução pare, se estiver em execução no momento."

#. Tag: link
#: index.docbook:3773
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_start;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_start;</command>()"

#. Tag: title
#: index.docbook:3779
#, no-c-format
msgid "&no-i18n-cmd_sync;"
msgstr "&no-i18n-cmd_sync;"

#. Tag: title
#: index.docbook:3781
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_sync;</command>()"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_sync;</command>()"

#. Tag: para
#: index.docbook:3782
#, no-c-format
msgid ""
"Waits until all commands which have been started asynchronously have "
"finished. If nothing is currently queued for delayed execution this command "
"has no effect."
msgstr ""
"Aguarda até que todos os comandos que foram iniciados de forma assíncrona "
"tenham terminado. Se nada estiver atualmente em espera para execução "
"posterior, este comando não terá efeito."

#. Tag: link
#: index.docbook:3790
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_delayed;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_delayed;</command>()"

#. Tag: title
#: index.docbook:3797
#, no-c-format
msgid "&no-i18n-tag;u"
msgstr "&no-i18n-tag;u"

#. Tag: title
#: index.docbook:3800
#, no-c-format
msgid "&no-i18n-cmd_undo;"
msgstr "&no-i18n-cmd_undo;"

#. Tag: title
#: index.docbook:3802
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_undo;</command>()"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_undo;</command>()"

#. Tag: para
#: index.docbook:3803
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Undo</guibutton> toolbar button and reverts "
"the last operation."
msgstr ""
"Corresponde ao botão da barra de ferramentas <guibutton>Desfazer</guibutton> "
"e reverte a última operação."

#. Tag: link
#: index.docbook:3810
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_redo;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_redo;</command>()"

#. Tag: title
#: index.docbook:3816
#, no-c-format
msgid "&no-i18n-cmd_undo_all;"
msgstr "&no-i18n-cmd_undo_all;"

#. Tag: title
#: index.docbook:3818
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_undo_all;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_undo_all;</command>()"

#. Tag: para
#: index.docbook:3819
#, no-c-format
msgid ""
"Similar to <command>&no-i18n-tag;&no-i18n-cmd_undo;</command>(), but reverts "
"as many operations as possible."
msgstr ""
"Semelhante ao <command>&no-i18n-tag;&no-i18n-cmd_undo;</command>(), mas "
"reverte tantas operações quantas possíveis."

#. Tag: title
#: index.docbook:3832
#, no-c-format
msgid "&no-i18n-tag;v"
msgstr "&no-i18n-tag;v"

#. Tag: title
#: index.docbook:3835
#, no-c-format
msgid "&no-i18n-cmd_view_scroll_end;"
msgstr "&no-i18n-cmd_view_scroll_end;"

#. Tag: title
#: index.docbook:3837
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_end;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_end;</"
"command>()"

#. Tag: para
#: index.docbook:3838
#, no-c-format
msgid "Scrolls the current view to the <emphasis>end</emphasis> of the signal."
msgstr "Desloca a visualização atual para o <emphasis>fim</emphasis> do sinal."

#. Tag: link
#: index.docbook:3842
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_start;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_start;</command>()"

#. Tag: title
#: index.docbook:3848
#, no-c-format
msgid "&no-i18n-cmd_view_scroll_left;"
msgstr "&no-i18n-cmd_view_scroll_left;"

#. Tag: title
#: index.docbook:3850
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_left;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_left;</"
"command>()"

#. Tag: para
#: index.docbook:3851
#, no-c-format
msgid ""
"Scrolls the current view by 1/10 of the currently visible range towards the "
"start of the signal. If the start of the signal is reached the visible area "
"starts at offset zero."
msgstr ""
"Desloca a visualização atual em 1/10 do intervalo atualmente visível em "
"direção ao início do sinal. Se atingir o início do sinal, a área visível "
"começa na posição zero."

#. Tag: link
#: index.docbook:3859
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_right;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_right;</command>()"

#. Tag: title
#: index.docbook:3865
#, no-c-format
msgid "&no-i18n-cmd_view_scroll_next;"
msgstr "&no-i18n-cmd_view_scroll_next;"

#. Tag: title
#: index.docbook:3867
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_next;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_next;</"
"command>()"

#. Tag: para
#: index.docbook:3868
#, no-c-format
msgid ""
"Scrolls the current view towards the end of the signal by the currently "
"visible range."
msgstr ""
"Desloca a visualização atual até o final do sinal pelo intervalo visível no "
"momento."

#. Tag: link
#: index.docbook:3875
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_prev;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_prev;</command>()"

#. Tag: title
#: index.docbook:3881
#, no-c-format
msgid "&no-i18n-cmd_view_scroll_next_label;"
msgstr "&no-i18n-cmd_view_scroll_next_label;"

#. Tag: title
#: index.docbook:3883
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_next_label;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_next_label;</"
"command>()"

#. Tag: para
#: index.docbook:3884
#, no-c-format
msgid ""
"Scrolls right and tries to show the next label centered in the view. If "
"there was no label right from the current position, it will scroll to the "
"end of the signal."
msgstr ""
"Desloca para a direita e tenta mostrar o próximo rótulo centrado na "
"exibição. Se não houver nenhum rótulo à direita da posição atual, ele "
"deslocará até o final do sinal."

#. Tag: link
#: index.docbook:3892
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_prev_label;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_prev_label;</command>()"

#. Tag: title
#: index.docbook:3898
#, no-c-format
msgid "&no-i18n-cmd_view_scroll_prev;"
msgstr "&no-i18n-cmd_view_scroll_prev;"

#. Tag: title
#: index.docbook:3900
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_prev;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_prev;</"
"command>()"

#. Tag: para
#: index.docbook:3901
#, no-c-format
msgid ""
"Scrolls the current view towards the start of the signal by the currently "
"visible range."
msgstr ""
"Desloca a visualização atual em direção ao início do sinal pelo intervalo "
"visível no momento."

#. Tag: link
#: index.docbook:3908
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_next;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_next;</command>()"

#. Tag: title
#: index.docbook:3914
#, no-c-format
msgid "&no-i18n-cmd_view_scroll_prev_label;"
msgstr "&no-i18n-cmd_view_scroll_prev_label;"

#. Tag: title
#: index.docbook:3916
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_prev_label;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_prev_label;</"
"command>()"

#. Tag: para
#: index.docbook:3917
#, no-c-format
msgid ""
"Scrolls left and tries to show the previous label centered in the view. If "
"there was no label left from the current position, it will scroll to the "
"start of the signal."
msgstr ""
"Desloca para a esquerda e tenta mostrar o rótulo anterior centrado na "
"exibição. Se não houver rótulo à esquerda da posição atual, ele deslocará "
"até o início do sinal."

#. Tag: link
#: index.docbook:3925
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_next_label;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_next_label;</command>()"

#. Tag: title
#: index.docbook:3931
#, no-c-format
msgid "&no-i18n-cmd_view_scroll_right;"
msgstr "&no-i18n-cmd_view_scroll_right;"

#. Tag: title
#: index.docbook:3933
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_right;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_right;</"
"command>()"

#. Tag: para
#: index.docbook:3934
#, no-c-format
msgid ""
"Scrolls the current view by 1/10 of the currently visible range towards the "
"end of the signal. If the end of the signal is reached the visible area ends "
"at the end of the signal."
msgstr ""
"Desloca a visualização atual em 1/10 do intervalo visível no momento até o "
"final do sinal. Se o final do sinal for atingido, a área visível termina no "
"final do sinal."

#. Tag: link
#: index.docbook:3942
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_left;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_left;</command>()"

#. Tag: title
#: index.docbook:3948
#, no-c-format
msgid "&no-i18n-cmd_view_scroll_start;"
msgstr "&no-i18n-cmd_view_scroll_start;"

#. Tag: title
#: index.docbook:3950
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_start;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_start;</"
"command>()"

#. Tag: para
#: index.docbook:3951
#, no-c-format
msgid "Scrolls the current view to the start of the signal."
msgstr "Rola a visualização atual até o início do sinal."

#. Tag: link
#: index.docbook:3955
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_end;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_end;</command>()"

#. Tag: title
#: index.docbook:3961
#, no-c-format
msgid "&no-i18n-cmd_view_zoom_all;"
msgstr "&no-i18n-cmd_view_zoom_all;"

#. Tag: title
#: index.docbook:3963
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_zoom_all;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_zoom_all;</"
"command>()"

#. Tag: para
#: index.docbook:3964
#, no-c-format
msgid ""
"Adjusts the zoom factor so that the complete signal is visible in the "
"current view."
msgstr ""
"Ajusta o fator de ampliação para que o sinal completo seja visível na "
"exibição atual."

#. Tag: title
#: index.docbook:3972
#, no-c-format
msgid "&no-i18n-cmd_view_zoom_in;"
msgstr "&no-i18n-cmd_view_zoom_in;"

#. Tag: title
#: index.docbook:3974
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_view_zoom_in;</"
"command>([<replaceable>position</replaceable>])"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_view_zoom_in;</"
"command>([<replaceable>posição</replaceable>])"

#. Tag: para
#: index.docbook:3975
#, no-c-format
msgid ""
"Reduces the zoom factor (in samples per pixel) by 30%, so that more details "
"get visible. If a <replaceable>position</replaceable> is given, it tries to "
"show that position centered in the current view, otherwise the center of the "
"view before the zoom change is used for centering. The minimum zoom factor "
"is limited to a minimum of five samples per width of the view."
msgstr ""
"Reduz o fator de ampliação (em amostras por pixel) em 30%, para que mais "
"detalhes fiquem visíveis. Se uma <replaceable>posição</replaceable> for "
"fornecida, ele tentará mostrar essa posição centralizada na visualização "
"atual, caso contrário, o centro da visualização antes da mudança de "
"ampliação será usado para centralizar. O fator de ampliação mínimo é "
"limitado a um mínimo de cinco amostras por largura da exibição."

#. Tag: entry
#: index.docbook:3987 index.docbook:4024
#, no-c-format
msgid "<parameter>position</parameter>:"
msgstr "<parameter>posição</parameter>:"

#. Tag: entry
#: index.docbook:3988
#, no-c-format
msgid "a zero based position in samples to center the view (optional)"
msgstr ""
"uma posição baseada em zero nas amostras para centralizar a visualização "
"(opcional)"

#. Tag: link
#: index.docbook:3992
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_view_zoom_out;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_view_zoom_out;</command>()"

#. Tag: title
#: index.docbook:3998
#, no-c-format
msgid "&no-i18n-cmd_view_zoom_normal;"
msgstr "&no-i18n-cmd_view_zoom_normal;"

#. Tag: title
#: index.docbook:4000
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_zoom_normal;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_zoom_normal;</"
"command>()"

#. Tag: para
#: index.docbook:4001
#, no-c-format
msgid ""
"Sets the zoom factor to one pixel per sample (factor 1.0) and tries to keep "
"the previous center of the view."
msgstr ""
"Define o fator de ampliação para um pixel por amostra (fator 1.0) e tenta "
"manter o mesmo centro da visualização anterior."

#. Tag: title
#: index.docbook:4009
#, no-c-format
msgid "&no-i18n-cmd_view_zoom_out;"
msgstr "&no-i18n-cmd_view_zoom_out;"

#. Tag: title
#: index.docbook:4011
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_view_zoom_out;"
"([<replaceable>position</replaceable>])</command>"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_view_zoom_out;([<replaceable>posição</"
"replaceable>])</command>"

#. Tag: para
#: index.docbook:4012
#, no-c-format
msgid ""
"Increases the zoom factor (in samples per pixel) by 30%, so that less "
"details get visible. If a <replaceable>position</replaceable> is given, it "
"tries to show that position centered in the current view, otherwise the "
"center of the view before the zoom change is used for centering. The maximum "
"zoom factor is limited to the number of samples of the complete signal and "
"the width of the view."
msgstr ""
"Aumenta o fator de ampliação (em amostras por pixel) em 30%, para que menos "
"detalhes fiquem visíveis. Se uma <replaceable>posição</replaceable> for "
"fornecida, ela tentará mostrar essa posição centralizada na visualização "
"atual, caso contrário, o centro da visualização anterior a mudança de "
"ampliação será usado para centralizar. O fator máximo de ampliação é "
"limitado ao número de amostras do sinal completo e à largura da visualização."

#. Tag: entry
#: index.docbook:4025
#, no-c-format
msgid "a zero based position is samples to center the view (optional)"
msgstr ""
"uma posição em amostras, a começar em zero, para centralizar a área visível "
"(opcional)"

#. Tag: link
#: index.docbook:4029
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_view_zoom_in;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_view_zoom_in;</command>()"

#. Tag: title
#: index.docbook:4035
#, no-c-format
msgid "&no-i18n-cmd_view_zoom_selection;"
msgstr "&no-i18n-cmd_view_zoom_selection;"

#. Tag: title
#: index.docbook:4037
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_zoom_selection;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_zoom_selection;</"
"command>()"

#. Tag: para
#: index.docbook:4038
#, no-c-format
msgid ""
"Adjusts the view (zoom factor and start of visible area) so that it matches "
"the current selection. This command does nothing if the selection is empty."
msgstr ""
"Ajusta a visualização (fator de ampliação e início da área visível) para que "
"corresponda à seleção atual. Este comando não faz nada se a seleção estiver "
"vazia."

#. Tag: title
#: index.docbook:4047
#, no-c-format
msgid "&no-i18n-tag;w"
msgstr "&no-i18n-tag;w"

#. Tag: title
#: index.docbook:4050
#, no-c-format
msgid "&no-i18n-cmd_window_activate;"
msgstr "&no-i18n-cmd_window_activate;"

#. Tag: title
#: index.docbook:4052
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_activate;</"
"command>(<replaceable>title</replaceable>])"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_activate;</"
"command>(<replaceable>título</replaceable>])"

#. Tag: para
#: index.docbook:4053
#, no-c-format
msgid ""
"Activates a sub-window, identified by its window <replaceable>title</"
"replaceable>. If the sub-window is minimized it will be restored. Only "
"available if in MDI and Tab mode. This command is internally used by the "
"<guisubmenu>Window</guisubmenu> menu."
msgstr ""
"Ativa uma sub-janela, identificada por seu <replaceable>título</replaceable> "
"de janela. Se a sub-janela for minimizada, ela será restaurada. Disponível "
"apenas nos modos MDI e Aba. Este comando é usado internamente pelo menu "
"<guisubmenu>Janela</guisubmenu>."

#. Tag: entry
#: index.docbook:4061
#, no-c-format
msgid "<parameter>title</parameter>:"
msgstr "<parameter>título</parameter>:"

#. Tag: entry
#: index.docbook:4062
#, no-c-format
msgid "the title of the sub-window that should be activated"
msgstr "o título da sub-janela que deve ser ativada"

#. Tag: title
#: index.docbook:4067
#, no-c-format
msgid "&no-i18n-cmd_window_cascade;"
msgstr "&no-i18n-cmd_window_cascade;"

#. Tag: title
#: index.docbook:4069
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_cascade;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_cascade;</"
"command>()"

#. Tag: para
#: index.docbook:4070
#, no-c-format
msgid ""
"Cascades all sub-windows when in MDI mode. All sub-windows that are "
"currently minimized stay minimized, they will not be restored."
msgstr ""
"Coloca todas as sub-janelas em cascata quando no modo MDI. Todas as sub-"
"janelas que estão atualmente minimizadas ficam minimizadas, elas não serão "
"restauradas."

#. Tag: title
#: index.docbook:4078
#, no-c-format
msgid "&no-i18n-cmd_window_click;"
msgstr "&no-i18n-cmd_window_click;"

#. Tag: title
#: index.docbook:4080
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_click;</"
"command>( <replaceable>class</replaceable>, <replaceable>x</replaceable>, "
"<replaceable>y</replaceable> )"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_click;</"
"command>( <replaceable>classe</replaceable>, <replaceable>x</replaceable>, "
"<replaceable>y</replaceable> )"

#. Tag: para
#: index.docbook:4085
#, no-c-format
msgid ""
"Sends a mouse click event to window, identified by its <replaceable>class</"
"replaceable> name. The event will only be sent to the first window that has "
"the given class name, therefore you should make sure that you have only one "
"instance of the given window when this command gets executed."
msgstr ""
"Envia um evento de clique do mouse para a janela, identificado pelo nome de "
"sua <replaceable>classe</replaceable>. O evento será enviado apenas para a "
"primeira janela que possui o nome da classe, logo, você deve certificar-se "
"de que há apenas uma instância da janela indicada quando este comando é "
"executado."

#. Tag: entry
#: index.docbook:4095 index.docbook:4119 index.docbook:4153 index.docbook:4204
#: index.docbook:4232 index.docbook:4257
#, no-c-format
msgid "<parameter>class</parameter>:"
msgstr "<parameter>classe</parameter>:"

#. Tag: entry
#: index.docbook:4096 index.docbook:4120 index.docbook:4154 index.docbook:4205
#: index.docbook:4233 index.docbook:4258
#, no-c-format
msgid "name of the window class"
msgstr "nome da classe da janela"

#. Tag: entry
#: index.docbook:4097 index.docbook:4155
#, no-c-format
msgid "<parameter>x</parameter>:"
msgstr "<parameter>x</parameter>:"

#. Tag: entry
#: index.docbook:4098 index.docbook:4156
#, no-c-format
msgid "x position, relative to the left border of the window (in pixels)"
msgstr "a posição em x, em relação à borda esquerda da janela (em pixeis)"

#. Tag: entry
#: index.docbook:4099 index.docbook:4157
#, no-c-format
msgid "<parameter>y</parameter>:"
msgstr "<parameter>y</parameter>:"

#. Tag: entry
#: index.docbook:4100 index.docbook:4158
#, no-c-format
msgid "y position, relative to the top border of the window (in pixels)"
msgstr "a posição em y, em relação à borda superior da janela (em pixeis)"

#. Tag: title
#: index.docbook:4105
#, no-c-format
msgid "&no-i18n-cmd_window_close;"
msgstr "&no-i18n-cmd_window_close;"

#. Tag: title
#: index.docbook:4107
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_close;</"
"command>( <replaceable>class</replaceable> )"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_close;</"
"command>( <replaceable>classe</replaceable> )"

#. Tag: para
#: index.docbook:4110
#, no-c-format
msgid ""
"Closes a window, identified by its <replaceable>class</replaceable> name. "
"Only the first window that has the given class name will be closed, "
"therefore you should make sure that you have only one instance of the given "
"window when this command gets executed."
msgstr ""
"Fecha uma janela, identificada pelo nome de sua <replaceable>classe</"
"replaceable>. Somente a primeira janela que possui o nome da classe "
"fornecida será fechada, logo, você deve certificar-se de que há apenas uma "
"instância da janela indicada quando este comando for executado."

#. Tag: title
#: index.docbook:4125
#, no-c-format
msgid "&no-i18n-cmd_window_minimize;"
msgstr "&no-i18n-cmd_window_minimize;"

#. Tag: title
#: index.docbook:4127
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-cmd_window_minimize;</command>"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-cmd_window_minimize;</command>"

#. Tag: para
#: index.docbook:4128
#, no-c-format
msgid ""
"Minimizes the currently active sub-window when in MDI mode or the current "
"toplevel window when in SDI or Tab mode."
msgstr ""
"Minimiza a sub-janela ativa no momento quando estiver no modo MDI ou na "
"janela de nível atual quando estiver nos modos SDI ou Aba."

#. Tag: title
#: index.docbook:4136
#, no-c-format
msgid "&no-i18n-cmd_window_mousemove;"
msgstr "&no-i18n-cmd_window_mousemove;"

#. Tag: title
#: index.docbook:4138
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_resize;</"
"command>( <replaceable>class</replaceable>, <replaceable>x</replaceable>, "
"<replaceable>y</replaceable> )"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_resize;</"
"command>( <replaceable>classe</replaceable>, <replaceable>x</replaceable>, "
"<replaceable>y</replaceable> )"

#. Tag: para
#: index.docbook:4143
#, no-c-format
msgid ""
"Sends a mouse move event to window, identified by its <replaceable>class</"
"replaceable> name. The event will only be sent to the first window that has "
"the given class name, therefore you should make sure that you have only one "
"instance of the given window when this command gets executed."
msgstr ""
"Envia um evento de movimento do mouse para a janela, identificada pelo nome "
"de sua <replaceable>classe</replaceable>. O evento só será enviado para a "
"primeira janela que possui o nome da classe, logo, você deve certificar-se "
"de que há apenas uma instância da janela indicada quando este comando é "
"executado."

#. Tag: title
#: index.docbook:4163
#, no-c-format
msgid "&no-i18n-cmd_window_next_sub;"
msgstr "&no-i18n-cmd_window_next_sub;"

#. Tag: title
#: index.docbook:4165
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_next_sub;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_next_sub;</"
"command>()"

#. Tag: para
#: index.docbook:4166
#, no-c-format
msgid ""
"Activates the <emphasis>next</emphasis> sub-window when in MDI or Tab mode. "
"If the next sub-window is minimized it will be restored."
msgstr ""
"Ativa a <emphasis>próxima</emphasis> sub-janela quando estiver nos modos MDI "
"ou Tab. Se a próxima sub-janela estiver minimizada, ela será restaurada."

#. Tag: title
#: index.docbook:4174
#, no-c-format
msgid "&no-i18n-cmd_window_prev_sub;"
msgstr "&no-i18n-cmd_window_prev_sub;"

#. Tag: title
#: index.docbook:4176
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_prev_sub;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_prev_sub;</"
"command>()"

#. Tag: para
#: index.docbook:4177
#, no-c-format
msgid ""
"Activates the <emphasis>previous</emphasis> sub-window when in MDI or Tab "
"mode. If the previous sub-window is minimized it will be restored."
msgstr ""
"Ativa a sub-janela <emphasis>anterior</emphasis>quando estiver nos modos MDI "
"ou Tab. Se a próxima sub-janela estiver minimizada, ela será restaurada."

#. Tag: title
#: index.docbook:4185
#, no-c-format
msgid "&no-i18n-cmd_window_resize;"
msgstr "&no-i18n-cmd_window_resize;"

#. Tag: title
#: index.docbook:4187
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_resize;</"
"command>( <replaceable>class</replaceable>, <replaceable>width</"
"replaceable>, <replaceable>height</replaceable> )"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_resize;</"
"command>( <replaceable>classe</replaceable>, <replaceable>largura</"
"replaceable>, <replaceable>altura</replaceable> )"

#. Tag: para
#: index.docbook:4192
#, no-c-format
msgid ""
"Changes the size of a window, identified by its <replaceable>class</"
"replaceable> name to a new <replaceable>width</replaceable> and "
"<replaceable>height</replaceable>. The change will only be applied to the "
"first window that has the given class name, therefore you should make sure "
"that you have only one instance of the given window when this command gets "
"executed."
msgstr ""
"Altera o tamanho de uma janela, identificada pelo nome de sua "
"<replaceable>classe</replaceable> para uma nova <replaceable>largura </"
"replaceable> e <replaceable>altura</replaceable>. A mudança será aplicada "
"somente na primeira janela que possui o nome da classe, logo, você deve ter "
"certeza de que há apenas uma instância da janela indicada quando este "
"comando é executado."

#. Tag: entry
#: index.docbook:4206
#, no-c-format
msgid "<parameter>width</parameter>:"
msgstr "<parameter>largura</parameter>:"

#. Tag: entry
#: index.docbook:4207
#, no-c-format
msgid "new width of the window (in pixels)"
msgstr "nova largura da janela (em pixel)"

#. Tag: entry
#: index.docbook:4208
#, no-c-format
msgid "<parameter>height</parameter>:"
msgstr "<parameter>altura</parameter>:"

#. Tag: entry
#: index.docbook:4209
#, no-c-format
msgid "new height of the window (in pixels)"
msgstr "nova altura da janela (em pixel)"

#. Tag: title
#: index.docbook:4214
#, no-c-format
msgid "&no-i18n-cmd_window_screenshot;"
msgstr "&no-i18n-cmd_window_screenshot;"

#. Tag: title
#: index.docbook:4216
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_screenshot;</"
"command>( <replaceable>class</replaceable>, <replaceable>filename</"
"replaceable> )"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_screenshot;</"
"command>( <replaceable>classe</replaceable>, <replaceable>arquivo</"
"replaceable> )"

#. Tag: para
#: index.docbook:4220
#, no-c-format
msgid ""
"Takes a screenshot of a window, identified by its <replaceable>class</"
"replaceable> and saves it to a file. The screenshot will be taken from the "
"first window that has the given class name, therefore you should make sure "
"that you have only one instance of the given window when this command gets "
"executed. Currently the format of the file is hardcoded and has to be "
"<literal>*.png</literal>."
msgstr ""
"Obtêm uma captura de tela de uma janela, identificada pela sua "
"<replaceable>class</replaceable> e a salva em um arquivo. A captura de tela "
"será obtida da primeira janela que possui o nome de classe fornecido, "
"portanto, você deve certificar-se que há apenas uma instância da janela "
"indicada quando este comando for executado. Atualmente, o formato do arquivo "
"é codificado e deve ser <literal>*.png</literal>."

#. Tag: entry
#: index.docbook:4235
#, no-c-format
msgid ""
"name of the file to save the screenshot, must have the extension <literal>*."
"png</literal>"
msgstr ""
"o nome do arquivo para salvar a captura de tela, deve ter a extensão "
"<literal>*.png</literal>"

#. Tag: title
#: index.docbook:4241
#, no-c-format
msgid "&no-i18n-cmd_window_sendkey;"
msgstr "&no-i18n-cmd_window_sendkey;"

#. Tag: title
#: index.docbook:4243
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_sendkey;</"
"command>( <replaceable>class</replaceable>, <replaceable>key code</"
"replaceable> )"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_sendkey;</"
"command>( <replaceable>classe</replaceable>, <replaceable>código chave</"
"replaceable> )"

#. Tag: para
#: index.docbook:4247
#, no-c-format
msgid ""
"Sends a key press and release event to a window, identified by its "
"<replaceable>class</replaceable> name. The key will only be sent to the "
"first window that has the given class name, therefore you should make sure "
"that you have only one instance of the given window when this command gets "
"executed."
msgstr ""
"Envia um evento de pressionar e soltar uma tecla para uma dada janela, "
"identificada pelo nome de sua <replaceable>classe</replaceable>. A tecla "
"será enviada apenas para a primeira janela que tenha o nome da classe "
"fornecida, logo, deverá ter certeza de que há apenas uma instância da janela "
"dada quando este comando é executado."

#. Tag: entry
#: index.docbook:4259
#, no-c-format
msgid "<parameter>key code</parameter>:"
msgstr "<parameter>código chave</parameter>:"

#. Tag: entry
#: index.docbook:4260
#, no-c-format
msgid ""
"the key code that should be sent, using the same syntax as used for setting "
"up menus"
msgstr ""
"o código chave que deve ser enviado, usando a mesma sintaxe usada para "
"configurar os menus"

#. Tag: para
#: index.docbook:4264
#, no-c-format
msgid ""
"Description of the parameter <link linkend=\"cmd_menu_param_hotkey"
"\"><parameter>hotkey</parameter></link> of the <command>&no-i18n-cmd_menu;</"
"command>() command."
msgstr ""
"Descrição do parâmetro <link linkend=\"cmd_menu_param_hotkey"
"\"><parameter>atalho</parameter></link> do <command>&no-i18n-cmd_menu;</"
"command>() comando."

#. Tag: title
#: index.docbook:4273
#, no-c-format
msgid "&no-i18n-cmd_window_tile;"
msgstr "&no-i18n-cmd_window_tile;"

#. Tag: title
#: index.docbook:4275
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_tile;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_tile;</command>()"

#. Tag: para
#: index.docbook:4276
#, no-c-format
msgid ""
"Tiles all sub-windows when in MDI mode, using some scheme of &plasma;. All "
"sub-windows that are currently minimized stay minimized, they will not be "
"restored."
msgstr ""
"Mosaico de todas as sub-janelas quando no modo MDI, usando algum esquema do "
"&plasma;. Todas as sub-janelas que estão atualmente minimizadas permanecem "
"minimizadas, elas não serão restauradas."

#. Tag: title
#: index.docbook:4285
#, no-c-format
msgid "&no-i18n-cmd_window_tile_vertical;"
msgstr "&no-i18n-cmd_window_tile_vertical;"

#. Tag: title
#: index.docbook:4287
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_tile_vertical;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_tile_vertical;</"
"command>()"

#. Tag: para
#: index.docbook:4288
#, no-c-format
msgid ""
"Tiles all sub-windows vertically when in MDI mode. All windows that are "
"currently minimized stay minimized, they will not be restored."
msgstr ""
"Mosaico vertical de todas as sub-janelas quando no modo MDI. Todas as "
"janelas atualmente minimizadas permanecem minimizadas, elas não serão "
"restauradas."

