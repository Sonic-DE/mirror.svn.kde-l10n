#. Tag: guimenuitem
#: index.docbook:2214
#, no-c-format
msgid "Thumbnail size"
msgstr "Tamanho da miniatura"

#. Tag: para
#: index.docbook:2215
#, no-c-format
msgid ""
"The thumbnail size option provides a slider and spin box for adjusting the "
