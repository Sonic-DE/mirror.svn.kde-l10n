#. Tag: screeninfo
#: index.docbook:2142
#, no-c-format
msgid "Folders Dialog Screenshot"
msgstr "Imagem do diálogo Pastas"

#. Tag: guimenuitem
#: index.docbook:2156
#, no-c-format
msgid "Save to HTML file"
msgstr "Salvar em arquivo HTML"

#. Tag: para
#: index.docbook:2157
#, no-c-format
msgid ""
