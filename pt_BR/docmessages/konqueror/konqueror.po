#. Tag: guimenuitem
#: index.docbook:2101
#, no-c-format
msgid "Show image file size"
msgstr "Mostrar tamanho do arquivo de imagem"

#. Tag: para
#: index.docbook:2102
#, no-c-format
msgid ""
"The Show image filesize check box allows you to choose whether to display "
