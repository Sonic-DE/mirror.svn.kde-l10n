#. Tag: guimenuitem
#: index.docbook:2118
#, no-c-format
msgid "Font size"
msgstr "Tamanho da fonte"

#. Tag: para
#: index.docbook:2119
#, no-c-format
msgid ""
"The Font size spin box is for changing the size of the font you selected."
msgstr ""
"A opção do tamanho da fonte permite-lhe alterar o tamanho da fonte "
