"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>Z</keycap></keycombo> </"
"shortcut> <guimenu>Mover</guimenu> <guimenuitem>Desfazer</guimenuitem>"

#. Tag: para
#: index.docbook:160
#, no-c-format
msgid "<action>Undo the previous move</action> if one exists."
msgstr "<action>Anula a jogada anterior</action>, se existir."

#. Tag: menuchoice
#: index.docbook:164
#, no-c-format
