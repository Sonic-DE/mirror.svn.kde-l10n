msgid ""
"<guimenu>Schedule</guimenu> <guimenuitem>Mail Free Busy Information...</"
"guimenuitem>"
msgstr ""
"<guimenu>Agendar</guimenu> <guimenuitem>Enviar por e-mail a informação de "
"livre/ocupado</guimenuitem>"

#. Tag: para
#: index.docbook:3457
#, no-c-format
msgid "Email your Free Busy information to one or more email addresses."
msgstr ""
