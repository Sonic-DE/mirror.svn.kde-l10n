#. Tag: para
#: index.docbook:3459 index.docbook:3470
#, no-c-format
msgid ""
"For more information about this action, please refer to <xref linkend=\"free-"
"busy\"/>."
msgstr ""
"Para mais informações sobre esta ação, veja por favor em <xref linkend="
"\"free-busy\"/>."

#. Tag: menuchoice
#: index.docbook:3464
#, no-c-format
msgid ""
"<guimenu>Schedule</guimenu> <guimenuitem>Upload Free Busy Information</"
"guimenuitem>"
msgstr ""
"<guimenu>Agendar</guimenu> <guimenuitem>Enviar a Informação de Livre/"
"Ocupado</guimenuitem>"

#. Tag: para
