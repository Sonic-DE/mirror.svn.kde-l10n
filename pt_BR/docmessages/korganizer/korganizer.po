msgstr "Muda a visualização para a visão do Mês."

#. Tag: para
#: index.docbook:3057
#, no-c-format
msgid ""
"For more information about this action, please refer to <xref linkend="
"\"month-view\"/>."
msgstr ""
"Para mais informações sobre esta ação, por favor veja em <xref linkend="
"\"month-view\"/>."

#. Tag: menuchoice
#: index.docbook:3064
#, no-c-format
msgid "<guimenu>View</guimenu> <guimenuitem>Timeline</guimenuitem>"
msgstr "<guimenu>Exibir</guimenu> <guimenuitem>Linha do tempo</guimenuitem>"

#. Tag: action
#: index.docbook:3068
#, no-c-format
