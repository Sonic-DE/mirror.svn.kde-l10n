"More <emphasis role=\"bold\"><link linkend=\"visualdict-panel\">Panels</"
"link></emphasis>"
msgstr ""
"Mais <emphasis role=\"bold\"><link linkend=\"visualdict-panel\">Painéis</"
"link></emphasis>"

