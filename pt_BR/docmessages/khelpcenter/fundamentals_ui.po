"A highlighted <emphasis role=\"bold\"><link linkend=\"visualdict-icon"
"\">Icon</link></emphasis>"
msgstr ""
"<emphasis role=\"bold\"><link linkend=\"visualdict-icon\">Ícone</link></"
"emphasis> realçado"

#. Tag: para
#: ui.docbook:146
#, no-c-format
msgid ""
"A <emphasis role=\"bold\"><link linkend=\"visualdict-context-menu\">Context "
"Menu</link></emphasis> listing actions that can be performed on a file"
msgstr ""
"<emphasis role=\"bold\"><link linkend=\"visualdict-context-menu\">Menu de "
"contexto</link></emphasis> que apresenta as ações que podem ser efetuadas em "
"um arquivo"

#. Tag: para
#: ui.docbook:151
#, no-c-format
msgid ""
"A <emphasis role=\"bold\"><link linkend=\"visualdict-slider\">Slider</link></"
