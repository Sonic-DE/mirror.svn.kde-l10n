msgstr ""
"<emphasis role=\"bold\"><link linkend=\"visualdict-icon\">Ícone</link></"
"emphasis> de uma pasta"

#. Tag: para
#: ui.docbook:138
#, no-c-format
msgid ""
"A file <emphasis role=\"bold\"><link linkend=\"visualdict-icon\">Icon</"
