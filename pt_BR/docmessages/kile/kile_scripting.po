msgstr "void document.insertParagraph();"

#. Tag: para
#: scripting.docbook:1133
#, no-c-format
msgid ""
"Insert a <userinput>\\paragraph</userinput> command (see also "
"<literal>document.insertSection()</literal>)."
msgstr ""
