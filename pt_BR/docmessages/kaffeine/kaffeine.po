"<shortcut> <keycombo action=\"simul\">&Left;</keycombo> </shortcut> "
"<guimenu>Playback</guimenu> <guisubmenu>Skip</guisubmenu> <guimenuitem>Skip "
"15s Backward</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"><keysym>←</keysym></keycombo> </"
