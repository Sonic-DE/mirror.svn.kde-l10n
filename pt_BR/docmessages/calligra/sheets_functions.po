msgstr "NPER(0.06; 0; -10000; 20000 ;0) retorna 11.906"

#. Tag: title
#: functions.docbook:3856
#, no-c-format
msgid "<title>NPV</title>"
msgstr "<title>NPV</title>"

#. Tag: para
#: functions.docbook:3857
#, no-c-format
msgid "The net present value (NPV) for a series of periodic cash flows."
msgstr ""
"O valor presente líquido (NPV) para uma série de fluxos monetários "
"periódicos."

#. Tag: para
#: functions.docbook:3858
#, no-c-format
msgid ""
"Computes the net present value for a series of periodic cash flows with the "
"discount rate Rate. Values should be positive if they are received as "
"income, and negative if the amounts are expenditure."
msgstr ""
"Calcula o valor líquido atual para uma série de fluxos monetários periódicos "
"com a taxa de desconto. Os valores deverão ser positivos se forem créditos "
"ou negativos se forem débitos."

