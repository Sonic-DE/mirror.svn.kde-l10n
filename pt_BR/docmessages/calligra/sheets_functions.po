msgstr "CEILING(-6,43; -4; 1) é igual a -8"

#. Tag: para
#: functions.docbook:5719
#, no-c-format
msgid "CEILING(-6.43; -4; 0) equals -4"
msgstr "CEILING(-6,43; -4; 0) é igual a -4"

