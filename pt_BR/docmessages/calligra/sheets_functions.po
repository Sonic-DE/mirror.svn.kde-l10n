msgstr "ISLEAPYEAR"

#. Tag: para
#: functions.docbook:1321
#, no-c-format
msgid "The function ISLEAPYEAR() returns True if the given year is leap."
msgstr ""
"A função ISLEAPYEAR() retorna Verdadeiro se o ano fornecido é bissexto."

