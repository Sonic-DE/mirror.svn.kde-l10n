msgstr "BOOL2STRING(false) retorna \"False\""

#. Tag: para
#: functions.docbook:256
#, no-c-format
msgid "upper(BOOL2STRING(find(\"nan\";\"banana\"))) returns TRUE"
msgstr "upper(BOOL2STRING(find(\"nan\";\"banana\"))) retorna TRUE"

#. Tag: title
