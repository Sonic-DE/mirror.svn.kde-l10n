#: functions.docbook:335
#, no-c-format
msgid "CHARTOASCII(\"v\") returns 118"
msgstr "CHARTOASCII(\"v\") retorna 118"

#. Tag: para
#: functions.docbook:338
#, no-c-format
msgid "CHARTOASCII(r) is an error. The character must be in quotes."
msgstr "CHARTOASCII(r) é um erro. O caractere deve estar entre aspas."

#. Tag: title
#: functions.docbook:344
#, no-c-format
msgid "DECSEX"
msgstr "DECSEX"

#. Tag: para
#: functions.docbook:345
#, no-c-format
msgid "The DECSEX() function converts a double value to a time value."
msgstr ""
"A função DECSEX() converte um valor de precisão dupla para valor de tempo."

