msgstr "Fornece tabelas com base em uma única variável."

#. Tag: entry
#: index.docbook:2883
#, no-c-format
msgid "rkward::limit_vector_length"
msgstr "rkward::limit_vector_length"

#. Tag: entry
#: index.docbook:2885
#, no-c-format
