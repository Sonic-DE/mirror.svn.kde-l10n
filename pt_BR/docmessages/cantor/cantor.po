msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>N</keycap></keycombo> </"
"shortcut> <guimenu>Arquivo</guimenu> <guimenuitem>Novo</guimenuitem>"

#. Tag: action
#: index.docbook:576
#, no-c-format
msgid "Creates a new worksheet with the default backend."
msgstr "Cria uma nova folha de trabalho com a infraestrutura padrão."

#. Tag: menuchoice
#: index.docbook:579
#, no-c-format
msgid ""
"<guimenu>File</guimenu> <guisubmenu>New</guisubmenu> "
"<guimenuitem><replaceable>Backend</replaceable></guimenuitem>"
msgstr ""
"<guimenu>Arquivo</guimenu> <guisubmenu>Novo</guisubmenu> "
"<guimenuitem><replaceable>Linguagem</replaceable></guimenuitem>"

#. Tag: action
#: index.docbook:584
#, no-c-format
msgid "Creates a new worksheet with the chosen backend."
msgstr "Cria uma nova folha de trabalho com a linguagem escolhida."

#. Tag: menuchoice
#: index.docbook:587
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>O</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Open...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>O</keycap></keycombo> </"
"shortcut> <guimenu>Arquivo</guimenu> <guimenuitem>Abrir...</guimenuitem>"

#. Tag: action
#: index.docbook:594
#, no-c-format
msgid "Open a supported new worksheet with the file dialog."
msgstr "Abre uma nova planilha compatível com a janela de arquivo."

#. Tag: menuchoice
#: index.docbook:597
#, no-c-format
msgid "<guimenu>File</guimenu> <guisubmenu>Open Recent</guisubmenu>"
msgstr "<guimenu>Arquivo</guimenu> <guisubmenu>Abrir recente</guisubmenu>"

#. Tag: action
#: index.docbook:601
#, no-c-format
msgid "Choose a worksheet from a list of recently used files."
msgstr "Escolha uma planilha de uma lista de arquivos usados ​​recentemente."

#. Tag: menuchoice
#: index.docbook:604
#, no-c-format
msgid ""
"<guimenu>File</guimenu> <guimenuitem>Download Example Worksheets</"
"guimenuitem>"
msgstr ""
"<guimenu>Arquivo</guimenu> <guimenuitem>Baixar planilhas de exemplo</"
"guimenuitem>"

#. Tag: action
#: index.docbook:608
#, no-c-format
msgid ""
"Opens the dialog to download examples uploaded by other &cantor; users with "
"<ulink url=\"https://userbase.kde.org/Special:MyLanguage/"
"Glossary#Get_Hot_New_Stuff\">GetHotNewStuff</ulink>."
msgstr ""
"Abre a janela para baixar exemplos enviados por outros usuários do &cantor; "
"com o <ulink url=\"https://userbase.kde.org/Special:MyLanguage/"
"Glossary#Get_Hot_New_Stuff\">GetHotNewStuff</ulink>."

#. Tag: menuchoice
#: index.docbook:612
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Open Example</guimenuitem>"
msgstr "<guimenu>Arquivo</guimenu> <guimenuitem>Abrir exemplo</guimenuitem>"

#. Tag: para
#: index.docbook:616
#, no-c-format
msgid ""
"<action>Opens the dialog to choose an example to load.</action> The examples "
"should be downloaded with <menuchoice><guimenu>File</guimenu> "
"<guimenuitem>Download Example Worksheets</guimenuitem></menuchoice> "
"beforehand."
msgstr ""
"<action>Abre a janela para escolher um exemplo a carregar.</action> Os "
"exemplos deverão ser transferidos com a opção <menuchoice><guimenu>Arquivo</"
"guimenu> <guimenuitem>Baixar planilha de exemplo</guimenuitem></menuchoice> "
"de antemão."

#. Tag: menuchoice
#: index.docbook:620
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Save Plain Text</guimenuitem>"
msgstr ""
"<guimenu>Arquivo</guimenu> <guimenuitem>Salvar em texto simples</guimenuitem>"

#. Tag: action
#: index.docbook:624
#, no-c-format
msgid "Allows saving the current worksheet as a plain text document."
msgstr "Permite salvar a planilha atual como um documento em texto simples."

#. Tag: menuchoice
#: index.docbook:627
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Export to LaTeX</guimenuitem>"
msgstr ""
"<guimenu>Arquivo</guimenu> <guimenuitem>Exportar para LaTeX</guimenuitem>"

#. Tag: action
#: index.docbook:631
#, no-c-format
