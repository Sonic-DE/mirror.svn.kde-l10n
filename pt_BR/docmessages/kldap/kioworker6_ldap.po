#. Tag: para
#: index.docbook:17
#, no-c-format
msgid ""
"<acronym>ldap</acronym> is the lightweight directory access protocol. It "
"provides access to an X.500 directory, or to a stand-alone <acronym>LDAP</"
"acronym> server."
msgstr ""
"O <acronym>ldap</acronym> é um protocolo de acesso a serviço de diretório, e "
"fornece acesso a um diretório X.500, ou a um servidor <acronym>LDAP</"
"acronym> independente."

#. Tag: para
#: index.docbook:21
#, no-c-format
msgid "You can use the ldap KIO worker as follows:"
msgstr "Você pode usar o KIO worker do ldap da seguinte forma:"

#. Tag: para
#: index.docbook:23
#, no-c-format
msgid ""
"<userinput>ldap://host:port/ou=People,o=where,c=de??sub</userinput> for a "
"subtree-query"
msgstr ""
"<userinput>ldap://máquina:porta/ou=People,o=onde,c=br??sub</userinput> para "
"uma consulta pela subárvore"

#. Tag: para
#: index.docbook:26
#, no-c-format
msgid ""
"or <userinput>ldap://host:port/cn=MM,ou=People,o=where,c=de??base</"
"userinput> for a complete branch."
msgstr ""
"ou <userinput>ldap://máquina:porta/cn=MM,ou=People,o=onde,c=br??base</"
"userinput> para uma ramificação completa."
