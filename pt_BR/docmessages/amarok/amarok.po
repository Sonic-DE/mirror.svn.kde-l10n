msgstr "<link linkend=\"collection-scanning\">Analisando coleção</link>&nbsp;"

#. Tag: para
#: index.docbook:3606 index.docbook:3632
#, no-c-format
msgid ""
"<link linkend=\"search-in-collection\">Search in Collection</link>&nbsp;"
msgstr ""
"<link linkend=\"search-in-collection\">Pesquisar na coleção</link>&nbsp;"

#. Tag: para
#: index.docbook:3607 index.docbook:3633
#, no-c-format
msgid "<link linkend=\"organize-collection\">Organize Collection</link>&nbsp;"
msgstr "<link linkend=\"organize-collection\">Organizar a coleção</link>&nbsp;"

#. Tag: para
#: index.docbook:3608 index.docbook:3635
#, no-c-format
msgid "<link linkend=\"remote-collections\">Remote Collections</link>&nbsp;"
msgstr "<link linkend=\"remote-collections\">Coleções remotas</link>&nbsp;"

