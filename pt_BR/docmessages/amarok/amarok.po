msgstr "<guilabel>Reproduzir mídia</guilabel>"

#. Tag: para
#: index.docbook:6984
#, no-c-format
msgid "Opens a media file to be played."
msgstr "Abre um arquivo multimídia para reprodução."

#. Tag: keycombo
#: index.docbook:6987 index.docbook:8153
#, no-c-format
msgid "&Ctrl;<keycap>O</keycap>"
msgstr "&Ctrl;<keycap>O</keycap>"

#. Tag: guilabel
#: index.docbook:6992
#, no-c-format
msgid "<guilabel>Previous Track</guilabel>"
msgstr "<guilabel>Faixa anterior</guilabel>"

#. Tag: para
#: index.docbook:6995
#, no-c-format
msgid "Skips back to the last track played within your current session."
msgstr "Volta à última faixa reproduzida na sua sessão atual."

#. Tag: guilabel
#: index.docbook:7003
#, no-c-format
msgid "<guilabel>Play/Pause</guilabel>"
msgstr "<guilabel>Reproduzir/Pausar</guilabel>"

#. Tag: para
#: index.docbook:7006
#, no-c-format
msgid "Starts or temporarily stops the playing of the current media file."
msgstr ""
"Inicia ou para temporariamente a reprodução do arquivo multimídia atual."

#. Tag: keycap
#: index.docbook:7009 index.docbook:8161
#, no-c-format
msgid "Space"
msgstr "Espaço"

#. Tag: guilabel
#: index.docbook:7014
#, no-c-format
msgid "<guilabel>Stop</guilabel>"
msgstr "<guilabel>Parar</guilabel>"

#. Tag: para
#: index.docbook:7017
#, no-c-format
msgid "Stops all playback in progress."
msgstr "Para todas as reproduções em andamento."

#. Tag: guilabel
#: index.docbook:7025
#, no-c-format
msgid "Stop after current Track"
msgstr "Parar após a faixa atual"

#. Tag: para
#: index.docbook:7028
#, no-c-format
msgid ""
"Waits until the current track ends before stopping the playback. This is "
"useful when using a playlist."
msgstr ""
"Aguarda até a faixa atual terminar antes de parar a reprodução de músicas. "
"Isto é útil ao utilizar uma lista de músicas."

#. Tag: guilabel
#: index.docbook:7036
#, no-c-format
msgid "<guilabel>Next Track</guilabel>"
msgstr "<guilabel>Próxima faixa</guilabel>"

#. Tag: para
#: index.docbook:7039
#, no-c-format
msgid "Skips playback to the next media file in your playlist."
msgstr ""
"Salta a reprodução para o próximo arquivo multimídia da sua lista de músicas."

#. Tag: guilabel
