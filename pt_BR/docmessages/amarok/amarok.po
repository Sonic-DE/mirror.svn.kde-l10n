#: index.docbook:3611 index.docbook:3637 index.docbook:4172
#, no-c-format
msgid "<link linkend=\"digital-audio-access-protocol-daap\">DAAP</link>&nbsp;"
msgstr "<link linkend=\"digital-audio-access-protocol-daap\">DAAP</link>&nbsp;"

#. Tag: para
#: index.docbook:3612 index.docbook:3638 index.docbook:4173
#, no-c-format
msgid "<link linkend=\"samba\">Samba</link>&nbsp;"
msgstr "<link linkend=\"samba\">Samba</link>&nbsp;"

