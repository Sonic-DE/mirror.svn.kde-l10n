#, no-c-format
msgid "Password"
msgstr "Senha"

#. Tag: para
#: index.docbook:3050
#, no-c-format
msgid "Enter the password for the default user."
msgstr "Insira a senha para o usuário padrão."

#. Tag: guilabel
#: index.docbook:3055
#, no-c-format
msgid "<guilabel>Database</guilabel>"
msgstr "<guilabel>Banco de dados</guilabel>"

#. Tag: para
#: index.docbook:3058
#, no-c-format
msgid "Enter the name of the database. Default preset is amarokdb."
msgstr "Insira o nome do banco de dados. O amarokdb é o preset padrão."

#. Tag: para
#: index.docbook:3064
#, no-c-format
msgid ""
"You can find more information about the External Database <link linkend="
