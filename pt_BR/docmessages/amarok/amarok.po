#: index.docbook:5803
#, no-c-format
msgid ""
"<link linkend=\"amarok-on-other-platforms\">Amarok on other Desktops and "
"Operating Systems</link>&nbsp;"
msgstr ""
"<link linkend=\"amarok-on-other-platforms\">O Amarok em outros ambientes de "
