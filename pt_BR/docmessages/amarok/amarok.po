#: index.docbook:3610 index.docbook:3636 index.docbook:4171
#, no-c-format
msgid "<link linkend=\"ampache\">Ampache</link>&nbsp;"
msgstr "<link linkend=\"ampache\">Ampache</link>&nbsp;"

