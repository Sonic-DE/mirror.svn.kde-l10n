"menu.</phrase>"
msgstr ""
"<phrase>Uma captura de tela do menu de contexto da <quote>Lista de contatos</"
"quote> do &kaddressbook;.</phrase>"

#. Tag: para
#: index.docbook:1839
#, no-c-format
msgid "&kaddressbook;'s <quote>Contact List</quote> context menu."
msgstr ""
"Menu de contexto da <quote>Lista de contatos</quote> do &kaddressbook;."

#. Tag: menuchoice
#: index.docbook:1850
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>N</keycap></keycombo></"
