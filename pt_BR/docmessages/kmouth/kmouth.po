"<guimenu>Arquivo</guimenu> <guimenuitem>Salvar histórico como...</"
"guimenuitem>"

#. Tag: action
#: index.docbook:442
#, no-c-format
msgid "Saves the history into a text file."
msgstr "Salva o histórico num arquivo de texto."

#. Tag: menuchoice
