#. Tag: para
#: index.docbook:47
#, no-c-format
msgid ""
"&kalzium; is a program which shows you the Periodic Table of Elements. You "
"can use &kalzium; to search for information about the elements or to learn "
"facts about the periodic table."
msgstr ""
"&kalzium; é um programa que mostra a Tabela Periódica. Você pode usá-lo para "
"procurar informações sobre os elementos ou para aprender coisas sobre a "
"tabela periódica."

#. Tag: keyword
#: index.docbook:53
#, no-c-format
msgid "<keyword>KDE</keyword>"
msgstr "<keyword>KDE</keyword>"

