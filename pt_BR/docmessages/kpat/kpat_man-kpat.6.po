#, no-c-format
msgid "A highly addictive card game"
msgstr "Um jogo de cartas viciante"

#. Tag: cmdsynopsis
#: man-kpat.6.docbook:25
#, no-c-format
msgid ""
"<command>kpat</command> <group choice=\"opt\"><option>--solvegame</option> "
