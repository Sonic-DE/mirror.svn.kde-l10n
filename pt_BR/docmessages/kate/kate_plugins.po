msgstr ""
"<link linkend=\"kate-application-plugin-sql\">Plugin do SQL</link> - Executa "
"pesquisas em bancos de dados SQL"

#. Tag: para
#: plugins.docbook:107
#, no-c-format
msgid ""
"<link linkend=\"kate-application-plugin-symbolviewer\">Symbol Viewer</link> "
