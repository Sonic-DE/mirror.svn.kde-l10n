msgstr "<command>indent-width</command><arg>INTEIRO</arg>"

#. Tag: para
#: configuring.docbook:1313
#, no-c-format
msgid "Set the indentation width."
msgstr "Define a largura do recuo."

#. Tag: cmdsynopsis
#: configuring.docbook:1317
