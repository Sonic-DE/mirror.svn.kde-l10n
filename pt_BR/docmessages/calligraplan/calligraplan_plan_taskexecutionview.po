#. Tag: title
#: taskexecutionview.docbook:2
#, no-c-format
msgid "<title>Description</title>"
msgstr "<title>Descrição</title>"

#. Tag: para
#: taskexecutionview.docbook:3
#, no-c-format
msgid ""
"The Task Execution View is used to inspect task performance information."
msgstr ""
"A visualização de execução de tarefas é usada para inspecionar informações "
"sobre o desempenho das tarefas."

#. Tag: title
#: taskexecutionview.docbook:20
#, no-c-format
msgid "Data"
msgstr "Dados"

#. Tag: para
#: taskexecutionview.docbook:27
#, no-c-format
msgid ""
"Progress information can be edited in-line as described <link linkend="
"\"using-the-views\">here</link> or by using the task progress dialog."
msgstr ""
"As informações de progresso podem ser editadas diretamente na página, "
"conforme descrito <link linkend=\"using-the-views\">aqui</link>, ou através "
"da caixa de diálogo de progresso da tarefa."

