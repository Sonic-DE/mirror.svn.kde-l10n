#. Tag: title
#: projectperformanceview.docbook:1
#, no-c-format
msgid "Description"
msgstr "Descrição"

#. Tag: para
#: projectperformanceview.docbook:2
#, no-c-format
msgid ""
"The Project performance view is a project management chart where can be "
"understood the actual situation of the project according to the Earned Value "
"Method."
msgstr ""
"A visão de desempenho do projeto é um gráfico de gerenciamento de projetos "
"onde se pode compreender a situação real do projeto de acordo com o método "
"do Valor Agregado."

#. Tag: para
#: projectperformanceview.docbook:18
#, no-c-format
msgid "where:"
msgstr "onde:"

#. Tag: para
#: projectperformanceview.docbook:21
#, no-c-format
msgid "BCWS means Budgeted Cost Work Scheduled,"
msgstr ""
"BCWS significa Orçamento de Custo e Trabalho Programado (sigla em inglês),"

#. Tag: para
#: projectperformanceview.docbook:22
#, no-c-format
msgid "BCWP means Budgeted Cost Work Performed,"
msgstr "BCWP significa Trabalho Executado ao Custo Orçado (sigla em inglês),"

#. Tag: para
#: projectperformanceview.docbook:23
#, no-c-format
msgid "ACWP means Actual Cost Work Performed."
msgstr "ACWP significa Trabalho Realizado ao Custo Real (sigla em inglês)."

#. Tag: para
#: projectperformanceview.docbook:25
#, no-c-format
msgid "All these are considered as effort in hours and costs."
msgstr "Tudo isso é considerado como esforço em termos de horas e custos."

#. Tag: para
#: projectperformanceview.docbook:27
#, no-c-format
msgid "PI are the Performance Indexes, where:"
msgstr "PI são os Índices de Desempenho (sigla em inglês), onde:"

#. Tag: para
#: projectperformanceview.docbook:30
#, no-c-format
msgid "CPI is the Cost Performance Index,"
msgstr "CPI é o Índice de Desempenho do Custo (sigla em inglês),"

#. Tag: para
#: projectperformanceview.docbook:31
#, no-c-format
msgid "SPI is the Schedule Performance Index."
msgstr "SPI é o Índice de Desempenho do Agendamento (sigla em inglês)."
