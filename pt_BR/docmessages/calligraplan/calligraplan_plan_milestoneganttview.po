#, no-c-format
msgid "<guilabel>Description</guilabel>"
msgstr "<guilabel>Descrição</guilabel>"

#. Tag: para
#: milestoneganttview.docbook:40
#, no-c-format
msgid "WBS Code"
msgstr "Código WBS"

#. Tag: para
#: milestoneganttview.docbook:43
#, no-c-format
msgid "The Work Breakdown Structure code"
msgstr "O código da Estrutura de Repartição de Trabalho (sigla em inglês)"

#. Tag: para
#: milestoneganttview.docbook:48
#, no-c-format
msgid "Name"
msgstr "Nome"

#. Tag: para
#: milestoneganttview.docbook:51
#, no-c-format
msgid "The name of the milestone."
msgstr "O nome do marco."

#. Tag: para
#: milestoneganttview.docbook:56
#, no-c-format
msgid "Start Time"
msgstr "Hora inicial"

#. Tag: para
#: milestoneganttview.docbook:59
#, no-c-format
msgid "The scheduled start time."
msgstr "A hora inicial agendada."

#. Tag: title
#: milestoneganttview.docbook:66
#, no-c-format
msgid "Configuration"
msgstr "Configuração"

#. Tag: para
#: milestoneganttview.docbook:73
#, no-c-format
msgid ""
"Using the context menu, the view can be configured using the configure "
"dialog."
msgstr ""
"Usando o menu de contexto, a visualização pode ser configurada através da "
"caixa de diálogo de configuração."

#. Tag: para
#: milestoneganttview.docbook:74
#, no-c-format
msgid ""
"The configure dialog enables you to tailor the amount of information the "
"view displays to fit your needs."
msgstr ""
"A caixa de diálogo de configuração permite que você personalize a quantidade "
"de informações que a visualização exibe para atender às suas necessidades."

