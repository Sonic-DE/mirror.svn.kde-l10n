#. Tag: title
#: milestoneganttview.docbook:2
#, no-c-format
msgid "<title>Description</title>"
msgstr "<title>Descrição</title>"

#. Tag: para
#: milestoneganttview.docbook:3
#, no-c-format
msgid "The Milestone Gantt view is used to show milestones in a time line."
msgstr ""
"A visualização de marcos de Gantt é usada para mostrar marcos em uma linha "
"do tempo."

#. Tag: phrase
#: milestoneganttview.docbook:14
#, no-c-format
msgid "<phrase>Gantt View</phrase>"
msgstr "<phrase>Visualização Gantt</phrase>"

#. Tag: para
#: milestoneganttview.docbook:17
#, no-c-format
msgid "<para>Gantt View</para>"
msgstr "<para>Visualização Gantt</para>"

#. Tag: title
#: milestoneganttview.docbook:23
#, no-c-format
msgid "Editing data"
msgstr "Editando dados"

#. Tag: para
#: milestoneganttview.docbook:24
#, no-c-format
msgid ""
"Milestone description and progress can be edited using the context menu."
msgstr ""
"A descrição e o progresso dos marcos podem ser editados usando o menu de "
"contexto."

#. Tag: para
#: milestoneganttview.docbook:26
#, no-c-format
msgid "The following columns are displayed as default:"
msgstr "As colunas a seguir são exibidas por padrão:"

#. Tag: guilabel
#: milestoneganttview.docbook:33
#, no-c-format
msgid "Column"
msgstr "Coluna"

#. Tag: guilabel
