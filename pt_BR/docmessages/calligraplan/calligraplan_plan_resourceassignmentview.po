#. Tag: title
#: resourceassignmentview.docbook:2
#, no-c-format
msgid "<title>Description</title>"
msgstr "<title>Descrição</title>"

#. Tag: para
#: resourceassignmentview.docbook:3
#, no-c-format
msgid ""
"The Resource Assignment View displays the scheduled task-resource "
"assignments in a table."
msgstr ""
"A visualização de atribuição de recursos exibe as atribuições de tarefas e "
"recursos agendadas em uma tabela."

#. Tag: para
#: resourceassignmentview.docbook:5
#, no-c-format
msgid "This view can severely impact performance in large projects."
msgstr ""
"Essa perspectiva pode afetar seriamente o desempenho em grandes projetos."

#. Tag: title
#: resourceassignmentview.docbook:26
#, no-c-format
msgid "Data"
msgstr "Dados"

#. Tag: para
#: resourceassignmentview.docbook:27
#, no-c-format
msgid "The following columns are displayed as default:"
msgstr "As colunas a seguir são exibidas por padrão:"

#. Tag: guilabel
#: resourceassignmentview.docbook:34
#, no-c-format
msgid "Column"
msgstr "Coluna"

#. Tag: guilabel
#: resourceassignmentview.docbook:35
#, no-c-format
msgid "<guilabel>Description</guilabel>"
msgstr "<guilabel>Descrição</guilabel>"

#. Tag: para
#: resourceassignmentview.docbook:41
#, no-c-format
msgid "Name"
msgstr "Nome"

#. Tag: para
#: resourceassignmentview.docbook:44
#, no-c-format
msgid "The name of the object (Resource group, resource, task)"
msgstr "O nome do objeto (grupo de recursos, recurso, tarefa)"

#. Tag: para
#: resourceassignmentview.docbook:49
#, no-c-format
msgid "Total"
msgstr "Total"

#. Tag: para
#: resourceassignmentview.docbook:52
#, no-c-format
msgid "The total assignment for a resource"
msgstr "A atribuição total de um recurso"

#. Tag: para
#: resourceassignmentview.docbook:57
#, no-c-format
msgid "Dates"
msgstr "Datas"

#. Tag: para
#: resourceassignmentview.docbook:60
#, no-c-format
msgid ""
"The total assignments for a resource per day and the assignments for the "
"resource per task."
msgstr ""
"O total de atribuições para um recurso por dia e as atribuições para o "
"recurso por tarefa."

#. Tag: title
#: resourceassignmentview.docbook:67
#, no-c-format
msgid "Editing data"
msgstr "Editando dados"

#. Tag: para
#: resourceassignmentview.docbook:68
#, no-c-format
msgid "The task description and progress can be edited using the context menu."
msgstr ""
"A descrição da tarefa e o progresso podem ser editados usando o menu de "
"contexto."
