#. Tag: title
#: taskganttview.docbook:2
#, no-c-format
msgid "<title>Description</title>"
msgstr "<title>Descrição</title>"

#. Tag: para
#: taskganttview.docbook:3
#, no-c-format
msgid "The Gantt view is used to show tasks in a timeline."
msgstr ""
"A visualização de Gantt é usada para mostrar tarefas em uma linha do tempo."

#. Tag: phrase
#: taskganttview.docbook:14
#, no-c-format
msgid "<phrase>Gantt View</phrase>"
msgstr "<phrase>Visualização de Gantt</phrase>"

#. Tag: para
#: taskganttview.docbook:17
#, no-c-format
msgid "<para>Gantt View</para>"
msgstr "<para>Visualização de Gantt</para>"

#. Tag: title
#: taskganttview.docbook:23
#, no-c-format
msgid "Editing data"
msgstr "Editando dados"

#. Tag: para
#: taskganttview.docbook:24
#, no-c-format
msgid "Task description and progress can be edited using the context menu."
msgstr ""
"A descrição e o progresso da tarefa podem ser editados usando o menu de "
"contexto."

#. Tag: para
#: taskganttview.docbook:26
#, no-c-format
msgid "The following columns are displayed as default:"
msgstr "As colunas a seguir são exibidas por padrão:"

#. Tag: guilabel
#: taskganttview.docbook:33
#, no-c-format
msgid "Column"
msgstr "Coluna"

#. Tag: guilabel
#: taskganttview.docbook:34
#, no-c-format
msgid "<guilabel>Description</guilabel>"
msgstr "<guilabel>Descrição</guilabel>"

