#. Tag: title
#: reportsgeneratorview.docbook:2
#, no-c-format
msgid "<title>Description</title>"
msgstr "<title>Descrição</title>"

#. Tag: para
#: reportsgeneratorview.docbook:3
#, no-c-format
msgid ""
"The Reports Generator View is used to add and generate reports in Open "
"Document Text (odt) format."
msgstr ""
"A visualização do gerador de relatórios é usada para adicionar e gerar "
"relatórios no formato Open Document Text (odt)."

#. Tag: para
#: reportsgeneratorview.docbook:4
#, no-c-format
msgid ""
"The reports can be based on the supplied report templates, or you can <link "
"linkend=\"creating-odt-report-templates\">write your own templates</link>."
msgstr ""
"Os relatórios podem ser baseados nos modelos de relatório fornecidos ou você "
"pode <link linkend=\"creating-odt-report-templates\">escrever seus próprios "
"modelos</link>."

#. Tag: guilabel
#: reportsgeneratorview.docbook:24
#, no-c-format
msgid "Column"
msgstr "Coluna"

#. Tag: guilabel
#: reportsgeneratorview.docbook:25 reportsgeneratorview.docbook:81
#, no-c-format
msgid "<guilabel>Description</guilabel>"
msgstr "<guilabel>Descrição</guilabel>"

#. Tag: para
#: reportsgeneratorview.docbook:31
#, no-c-format
msgid "Name"
msgstr "Nome"

#. Tag: para
#: reportsgeneratorview.docbook:34
#, no-c-format
msgid "A name of your choice"
msgstr "Um nome de sua escolha"

#. Tag: para
#: reportsgeneratorview.docbook:39
#, no-c-format
msgid "Report Template"
msgstr "Modelo do relatório"

#. Tag: para
#: reportsgeneratorview.docbook:42
#, no-c-format
msgid ""
"Path to the report template file. You can select one of the supplied "
"standard templates or you can enter the filename of a template you provide "
"yourself."
msgstr ""
"Caminho para o arquivo do modelo de relatório. Você pode selecionar um dos "
"modelos padrão fornecidos ou pode inserir o nome do arquivo de um modelo que "
"você mesmo fornecer."

#. Tag: para
#: reportsgeneratorview.docbook:47
#, no-c-format
msgid "Report File"
msgstr "Arquivo do relatório"

#. Tag: para
#: reportsgeneratorview.docbook:50
#, no-c-format
msgid "The name of the file that will be generated."
msgstr "O nome do arquivo que será gerado."

#. Tag: para
#: reportsgeneratorview.docbook:55
#, no-c-format
msgid "<para>Add</para>"
msgstr "<para>Adicionar</para>"

#. Tag: para
#: reportsgeneratorview.docbook:58
#, no-c-format
msgid ""
"Information that can be added to the report file name to distinguish it from "
"previously generated versions. This can be:"
msgstr ""
"Informações que podem ser adicionadas ao nome do arquivo de relatório para "
"diferenciá-lo de versões geradas anteriormente. Isso pode ser:"

#. Tag: para
#: reportsgeneratorview.docbook:60
#, no-c-format
msgid "<emphasis>Nothing</emphasis>; use the filename as is"
msgstr "<emphasis>Nada</emphasis>; usa o nome do arquivo como está"

#. Tag: para
#: reportsgeneratorview.docbook:61
#, no-c-format
msgid "<emphasis>Number</emphasis>; add a sequence number to the file name"
msgstr ""
"<emphasis>Número</emphasis>; adiciona um número sequencial ao nome do arquivo"

#. Tag: para
#: reportsgeneratorview.docbook:62
#, no-c-format
msgid "<emphasis>Date</emphasis>; add the current date to the file name"
msgstr "<emphasis>Data</emphasis>; adiciona a data atual ao nome do arquivo"

#. Tag: title
#: reportsgeneratorview.docbook:71
#, no-c-format
msgid "Toolbar"
msgstr "Barra de ferramentas"

#. Tag: para
#: reportsgeneratorview.docbook:72
#, no-c-format
msgid "The toolbar provides the means to add, remove and generate reports."
msgstr "A barra de ferramentas permite adicionar, remover e gerar relatórios."

#. Tag: guilabel
#: reportsgeneratorview.docbook:79
#, no-c-format
msgid "Button"
msgstr "Botão"

#. Tag: guilabel
#: reportsgeneratorview.docbook:80
#, no-c-format
msgid "Shortcut"
msgstr "Atalho"

#. Tag: para
#: reportsgeneratorview.docbook:87
#, no-c-format
msgid "Add Report"
msgstr "Adicionar relatório"

