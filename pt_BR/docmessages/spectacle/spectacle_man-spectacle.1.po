#. Tag: title
#: man-spectacle.1.docbook:35
#, no-c-format
msgid "Description"
msgstr "Descrição"

#. Tag: para
#: man-spectacle.1.docbook:36
#, no-c-format
msgid ""
"<command>spectacle</command> is a simple application for capturing desktop "
"screenshots. It can capture images of the entire desktop, a single monitor, "
"the currently active window, the window currently under the mouse, or a "
"rectangular region of the screen. The images can then be annotated, printed, "
"sent to other applications for manipulation, or quickly be saved as-is."
msgstr ""
"<command>spectacle</command> é um aplicativo simples para capturar imagens "
"da tela. É capaz de capturar imagens de toda a área de trabalho, de apenas "
"um monitor, da janela ativa, da janela que estiver sob o ponteiro do mouse "
"ou de uma região retangular. As imagens podem ser anotadas, impressas, "
"enviadas para outros aplicativos ou salvas em diversos formatos."

#. Tag: title
#: man-spectacle.1.docbook:40
#, no-c-format
msgid "Spectacle options"
msgstr "Opções do Spectacle"

#. Tag: option
#: man-spectacle.1.docbook:44
#, no-c-format
msgid "-h, --help"
msgstr "-h, --help"

#. Tag: para
#: man-spectacle.1.docbook:46
#, no-c-format
msgid "Displays help on commandline options."
msgstr "Exibe a ajuda sobre as opções da linha de comando."

#. Tag: option
#: man-spectacle.1.docbook:51
#, no-c-format
msgid "--help-all"
msgstr "--help-all"

#. Tag: para
#: man-spectacle.1.docbook:53
#, no-c-format
msgid "Displays help including Qt specific options."
msgstr "Exibe a ajuda, incluindo opções específicas do Qt."

#. Tag: option
#: man-spectacle.1.docbook:58
#, no-c-format
msgid "-v, --version"
msgstr "-v, --version"

#. Tag: para
#: man-spectacle.1.docbook:60
#, no-c-format
msgid "Displays version information."
msgstr "Exibe informações sobre a versão."

#. Tag: option
#: man-spectacle.1.docbook:65
#, no-c-format
msgid "-f, --fullscreen"
msgstr "-f, --fullscreen"

#. Tag: para
#: man-spectacle.1.docbook:67
#, no-c-format
msgid "Capture the entire desktop (default)."
msgstr "Captura toda a área de trabalho (padrão)."

#. Tag: option
#: man-spectacle.1.docbook:72
#, no-c-format
msgid "--scaled"
msgstr "--scaled"

#. Tag: para
#: man-spectacle.1.docbook:74
#, no-c-format
msgid ""
"When used with <option>-f</option>/<option>--fullscreen</option>, capture "
"all screens scaled to the same size. Has no effect without <option>-f</"
"option>."
msgstr ""
"Quando usado com <option>-f</option>/<option>--fullscreen</option>, captura "
"todas as telas redimensionadas para o mesmo tamanho. Não tem efeito sem "
"<option>-f</option>."

#. Tag: option
#: man-spectacle.1.docbook:79
#, no-c-format
msgid "-m, --current"
msgstr "-m, --current"

#. Tag: para
#: man-spectacle.1.docbook:81
#, no-c-format
msgid "Capture the current monitor."
msgstr "Captura o monitor atual."

#. Tag: option
#: man-spectacle.1.docbook:86
#, no-c-format
msgid "-a, --activewindow"
msgstr "-a, --activewindow"

#. Tag: para
#: man-spectacle.1.docbook:88
#, no-c-format
msgid "Capture the active window."
msgstr "Captura a janela ativa."

#. Tag: option
#: man-spectacle.1.docbook:93
#, no-c-format
msgid "-u, --windowundercursor"
msgstr "-u, --windowundercursor"

#. Tag: para
#: man-spectacle.1.docbook:95
#, no-c-format
msgid ""
"Capture the window currently under the cursor, including parents of pop-up "
"menus."
msgstr ""
"Captura a janela que estiver sob o cursor, incluindo os menus de origem."

#. Tag: option
#: man-spectacle.1.docbook:100
#, no-c-format
msgid "-t, --transientonly"
msgstr "-t, --transientonly"

#. Tag: para
#: man-spectacle.1.docbook:102
#, no-c-format
msgid ""
"Capture the window currently under the cursor, excluding parents of pop-up "
"menus."
msgstr ""
"Captura a janela que estiver sob o cursor, excluindo os menus de origem."

#. Tag: option
#: man-spectacle.1.docbook:107
#, no-c-format
msgid "-r, --region"
msgstr "-r, --region"

#. Tag: para
#: man-spectacle.1.docbook:109
#, no-c-format
msgid "Capture a rectangular region of the screen."
msgstr "Captura uma região retangular da tela."

#. Tag: option
#: man-spectacle.1.docbook:114
#, no-c-format
msgid "-l, --launchonly"
msgstr "-l, --launchonly"

#. Tag: para
#: man-spectacle.1.docbook:116
#, no-c-format
msgid "Launch Spectacle without taking a screenshot."
msgstr "Inicia o Spectacle sem capturar uma imagem."

#. Tag: option
#: man-spectacle.1.docbook:121
#, no-c-format
msgid "-g, --gui"
msgstr "-g, --gui"

#. Tag: para
#: man-spectacle.1.docbook:123
#, no-c-format
msgid "Start in GUI mode (default)."
msgstr "Inicia no modo gráfico (padrão)."

#. Tag: option
#: man-spectacle.1.docbook:128
#, no-c-format
msgid "-b, --background"
msgstr "-b, --background"

#. Tag: para
#: man-spectacle.1.docbook:130
#, no-c-format
msgid "Take a screenshot and exit without showing the GUI."
msgstr "Captura uma imagem e sai sem mostrar a interface."

#. Tag: option
#: man-spectacle.1.docbook:135
#, no-c-format
msgid "-s, --dbus"
msgstr "-s, --dbus"

#. Tag: para
#: man-spectacle.1.docbook:137
#, no-c-format
msgid "Start in DBus-Activation mode."
msgstr "Inicia no modo de ativação por D-Bus."

#. Tag: option
#: man-spectacle.1.docbook:142
#, no-c-format
msgid "-n, --nonotify"
msgstr "-n, --nonotify"

#. Tag: para
#: man-spectacle.1.docbook:144
#, no-c-format
msgid ""
"In background mode, do not pop up a notification when the screenshot is "
"taken."
msgstr ""
"No modo em segundo plano, não mostrar uma mensagem informando que a imagem "
"foi tirada."

#. Tag: option
#: man-spectacle.1.docbook:149
#, no-c-format
msgid "-o, --output <replaceable>fileName</replaceable>"
msgstr "-o, --output <replaceable>nomeArquivo</replaceable>"

#. Tag: para
#: man-spectacle.1.docbook:151
#, no-c-format
msgid ""
"In background mode, save image to specified file <replaceable>fileName</"
"replaceable>."
msgstr ""
"No modo em segundo plano, salva a imagem no arquivo "
"<replaceable>nomeArquivo</replaceable> indicado."

#. Tag: option
#: man-spectacle.1.docbook:156
#, no-c-format
msgid "-d, --delay <replaceable>delayMsec</replaceable>"
msgstr "-d, --delay <replaceable>atrasoMsec</replaceable>"

#. Tag: para
#: man-spectacle.1.docbook:158
#, no-c-format
msgid "In background mode, delay before taking the shot (in milliseconds)."
msgstr ""
"No modo em segundo plano, com um atraso antes de capturar a tela (em "
"milissegundos)."

#. Tag: option
#: man-spectacle.1.docbook:163
#, no-c-format
msgid "-c, --copy-image"
msgstr "-c, --copy-image"

#. Tag: para
#: man-spectacle.1.docbook:165
#, no-c-format
msgid ""
"In background mode, copy screenshot only to clipboard, unless -o is also "
"used."
msgstr ""
"No modo em segundo plano, copia a imagem para a área de transferência, a "
"menos que -o também seja usado."

#. Tag: option
#: man-spectacle.1.docbook:170
#, no-c-format
msgid "-C, --copy-path"
msgstr "-C, --copy-path"

#. Tag: para
#: man-spectacle.1.docbook:172
#, no-c-format
msgid "In background mode, copy screenshot file path to clipboard."
msgstr ""
"No modo em segundo plano, copia o caminho do arquivo da imagem para a área "
"de transferência."

#. Tag: option
#: man-spectacle.1.docbook:177
#, no-c-format
msgid "-w, --onclick"
msgstr "-w, --onclick"

#. Tag: para
#: man-spectacle.1.docbook:179
#, no-c-format
msgid "Wait for a click before taking screenshot. Invalidates delay.."
msgstr "Aguarda por um clique antes de capturar a imagem. Invalida o atraso.."

#. Tag: option
#: man-spectacle.1.docbook:184
#, no-c-format
msgid "-i, --new-instance"
msgstr "-i, --new-instance"

#. Tag: para
#: man-spectacle.1.docbook:186
#, no-c-format
msgid "Starts a new GUI instance of spectacle without registering to DBus."
msgstr ""
"Inicia uma nova instância da interface do Spectacle sem registrar no DBus."

#. Tag: option
#: man-spectacle.1.docbook:191
#, no-c-format
msgid "-p, --pointer"
msgstr "-p, --pointer"

#. Tag: para
#: man-spectacle.1.docbook:193
#, no-c-format
msgid "In background mode, include pointer in the screenshot."
msgstr "No modo em segundo plano, inclui o ponteiro na imagem."

#. Tag: option
#: man-spectacle.1.docbook:198
#, no-c-format
msgid "-e, --no-decoration"
msgstr "-e, --no-decoration"

#. Tag: para
#: man-spectacle.1.docbook:200
#, no-c-format
msgid ""
"In background mode, do not include window decorations in the screenshot."
msgstr "No modo em segundo plano, exclui as decorações da imagem."

#. Tag: option
#: man-spectacle.1.docbook:205
#, no-c-format
msgid "-E, --edit-existing <replaceable>existingFileName</replaceable>"
msgstr "-E, --edit-existing <replaceable>nomeArquivoExistente</replaceable>"

#. Tag: para
#: man-spectacle.1.docbook:207
#, no-c-format
msgid "Open and edit existing screenshot file."
msgstr "Abre e edita o arquivo de captura existente."

