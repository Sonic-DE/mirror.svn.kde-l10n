#~ msgstr ""
#~ "<guimenu>Mensagem</guimenu> <guimenuitem>Nova Janela Principal</"
#~ "guimenuitem>"

#~ msgid "Creates a new main window."
#~ msgstr "Cria uma nova janela principal."

#~ msgid ""
#~ "<guimenu>Message</guimenu> <guimenuitem>New AddressBook Contact</"
#~ "guimenuitem>"
#~ msgstr ""
#~ "<guimenu>Mensagem</guimenu> <guimenuitem>Novo contato do livro de "
#~ "endereços</guimenuitem>"

#~ msgid ""
#~ "<action>Brings up the &kontact; New Contact Dialog</action> to add a new "
#~ "contact your addressbook."
#~ msgstr ""
#~ "<action>Abre a caixa de diálogo de novo contato do &kontact;</action> "
#~ "para adicionar um novo contato ao seu livro de endereços."

#~ msgid ""
#~ "Allows you to choose which outgoing account to send your send later "
#~ "configured message."
#~ msgstr ""
#~ "Permite-lhe escolher qual a conta de envio para onde enviar "
#~ "posteriormente a mensagem configurada."

#~ msgid "Saves the message as a text document."
#~ msgstr "Salva a mensagem como um documento de texto."

#~ msgid "Prints the current text."
#~ msgstr "Imprime o texto atual."

#~ msgid ""
#~ "<action>Pastes the text from the clipboard</action> marked as quotation."
#~ msgstr ""
#~ "<action>Cola o texto da área de transferência</action> marcado como "
