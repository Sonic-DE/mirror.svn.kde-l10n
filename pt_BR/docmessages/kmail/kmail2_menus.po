#~ msgid ""
#~ "<action>Pastes the text from the clipboard</action> as an attachment."
#~ msgstr ""
#~ "<action>Cola o texto da área de transferência</action> como um anexo."

#~ msgid "Prepends the selected text with quotation marks."
