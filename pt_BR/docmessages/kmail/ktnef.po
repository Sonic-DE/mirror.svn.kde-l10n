#. Tag: para
#: index.docbook:39
#, no-c-format
msgid ""
"The TNEF File Viewer is an application for <ulink url=\"https://en.wikipedia."
"org/wiki/TNEF\">TNEF</ulink> mail attachments."
msgstr ""
"O Visualizador de Arquivos TNEF é um aplicativo para anexos de e-mail em "
"formato <ulink url=\"https://en.wikipedia.org/wiki/TNEF\">TNEF</ulink>."

#. Tag: keyword
#: index.docbook:42
#, no-c-format
msgid "mail"
