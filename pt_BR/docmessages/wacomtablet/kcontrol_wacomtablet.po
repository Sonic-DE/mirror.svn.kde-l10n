#. Tag: para
#: index.docbook:35
#, no-c-format
msgid ""
"This is the documentation for the &kde; &systemsettings; module that "
"configures graphic tablets."
msgstr ""
"Esta é a documentação do módulo do &systemsettings; para o &kde; para "
"configurar as mesas digitalizadoras."

#. Tag: keyword
#: index.docbook:39
#, no-c-format
msgid "<keyword>KDE</keyword>"
msgstr "<keyword>KDE</keyword>"

#. Tag: keyword
#: index.docbook:40
#, no-c-format
msgid "System Settings"
msgstr "Configurações do sistema"

#. Tag: keyword
#: index.docbook:41
#, no-c-format
msgid "Wacom"
msgstr "Wacom"

#. Tag: keyword
