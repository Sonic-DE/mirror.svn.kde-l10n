#~ "de vídeo com aceleração 3D e drivers instalados corretamente para ela."

#~ msgid "IEEE 1394 Device Information Module"
#~ msgstr "Módulo de Informação dos Dispositivos IEEE 1394"

#~ msgid ""
#~ "The IEEE 1394 interface, also known as <trademark>FireWire</trademark>, "
#~ "is a serial bus interface standard for high-speed communications and "
#~ "isochronous real-time data transfer."
#~ msgstr ""
#~ "A interface IEEE 1394, também conhecida como <trademark>FireWire</"
#~ "trademark>, é uma interface-padrão serial para comunicações em alta "
#~ "velocidade para a transferência de dados em tempo-real isócrona."

#~ msgid ""
#~ "The list in this module displays all devices attached to IEEE 1394 bus "
#~ "and allows you to reset the bus by clicking the <guibutton>Generate 1394 "
#~ "Bus Reset</guibutton> button."
#~ msgstr ""
#~ "A lista neste módulo apresenta todos os dispositivos ligados ao "
#~ "barramento IEEE 1394 e permite-lhe reiniciar o barramento, ao clicar no "
#~ "botão <guibutton>Gerar um Reinício do Barramento 1394</guibutton>."

#~ msgid "The meaning of the columns in this list:"
#~ msgstr "O significado das colunas nesta lista é:"

#~ msgid ""
#~ "<guilabel>Name</guilabel>: port or node name, the number can change with "
#~ "each bus reset"
#~ msgstr ""
#~ "<guilabel>Nome</guilabel>: o nome do nó ou da porta, sendo que o número "
#~ "poderá mudar com cada reinício"

#~ msgid "<guilabel>GUID</guilabel>: the 64 bit GUID of the node"
#~ msgstr "<guilabel>GUID</guilabel>: o GUID de 64 bits do nó"

#~ msgid ""
#~ "<guilabel>Local</guilabel>: checked if the node is an IEEE 1394 port of "
#~ "your computer"
#~ msgstr ""
#~ "<guilabel>Local</guilabel>: assinalado se o nó for uma porta IEEE 1394 do "
#~ "seu computador"

#~ msgid ""
#~ "<guilabel>IRM</guilabel>: checked if the node is isochronous resource "
#~ "manager capable"
#~ msgstr ""
#~ "<guilabel>IRM</guilabel>: assinalado se o nó for capaz de gerenciar os "
#~ "recursos isócronos"

#~ msgid ""
#~ "<guilabel>CRM</guilabel>: checked if the node is cycle master capable"
#~ msgstr ""
#~ "<guilabel>CRM</guilabel>: assinalado se o nó for um mestre de ciclos"

#~ msgid ""
#~ "<guilabel>ISO</guilabel>: checked if the node supports isochronous "
#~ "transfers"
#~ msgstr ""
#~ "<guilabel>ISO</guilabel>: assinalado se o nó suporta transferências "
#~ "isócronas"

#~ msgid "<guilabel>BM</guilabel>: checked if the node is bus manager capable"
#~ msgstr ""
#~ "<guilabel>BM</guilabel>: assinalado se o nó for capaz de gerenciar o "
#~ "barramento"

#~ msgid ""
#~ "<guilabel>PM</guilabel>: checked if the node is power management capable"
#~ msgstr ""
#~ "<guilabel>PM</guilabel>: assinalado se o nó for capaz de fazer a gestão "
#~ "de energia"

#~ msgid ""
#~ "<guilabel>Acc</guilabel>: the cycle clock accuracy of the node, valid "
#~ "from 0 to 100"
#~ msgstr ""
#~ "<guilabel>Prec</guilabel>: a precisão do ciclo de relógio do nó, válida "
#~ "de 0 a 100"

#~ msgid "<guilabel>Speed</guilabel>: the speed of the node"
#~ msgstr "<guilabel>Velocidade</guilabel>: a velocidade do nó"

#~ msgid "<guilabel>Vendor</guilabel>: the vendor of the device"
#~ msgstr "<guilabel>Fabricante</guilabel>: o fabricante do dispositivo"

#~ msgid "File Indexer Monitor Module"
#~ msgstr "Módulo Monitor de Indexação de Arquivos"

#~ msgid ""
#~ "This Module shows the state of the file indexer. If the indexer is not "
#~ "running you can start it and then suspend or resume the indexing."
#~ msgstr ""
#~ "Este módulo mostra o estado do indexador de arquivos. Se o indexador não "
#~ "estiver em execução, você pode iniciá-lo e então suspender ou continuar a "
#~ "indexação."

