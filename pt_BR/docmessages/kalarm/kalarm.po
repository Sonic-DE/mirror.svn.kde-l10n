#. Tag: para
#: index.docbook:4456
#, no-c-format
msgid ""
"The &kmail; identity to use as the sender of the email. If empty, the "
"sender's email address will be that configured in &kalarm;'s <link linkend="
"\"preferences-email\">Email preferences</link>."
msgstr ""
"A identidade do &kmail; a ser usada como remetente do e-mail. Se estiver "
"vazio, o endereço do remetente do e-mail será o configurado nas <link "
"linkend=\"preferences-email\">preferências de e-mail</link> do &kalarm;."

#. Tag: parameter
#: index.docbook:4464
#, no-c-format
msgid "addresses"
msgstr "endereços"

#. Tag: para
#: index.docbook:4466
#, no-c-format
msgid "A comma separated list of recipients' email addresses."
msgstr ""
"Uma lista separada por vírgulas de endereços de e-mail dos destinatários."

#. Tag: parameter
#: index.docbook:4471
#, no-c-format
msgid "subject"
msgstr "assunto"

#. Tag: para
#: index.docbook:4473
#, no-c-format
msgid "Specifies the subject line of the email."
msgstr "Indica a linha de assunto da mensagem de e-mail."

#. Tag: para
#: index.docbook:4480
#, no-c-format
