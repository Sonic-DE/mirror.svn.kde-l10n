#. Tag: para
#: index.docbook:46
#, no-c-format
msgid ""
"&kalarm; is a personal alarm message, command and email scheduler by &kde;."
msgstr ""
"O &kalarm; é um agendador de mensagens de alarme pessoais, comandos e "
"mensagens eletrônicas do &kde;."

#. Tag: keyword
#: index.docbook:51
#, no-c-format
