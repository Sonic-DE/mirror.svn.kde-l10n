#, no-c-format
msgid "<title>Theme options</title>"
msgstr "<title>Opções do tema</title>"

#. Tag: term
#: index.docbook:456
#, no-c-format
msgid "<guilabel>Theme</guilabel> selector"
msgstr "Seletor do <guilabel>Tema</guilabel>"

#. Tag: para
#: index.docbook:457
#, no-c-format
msgid ""
"Use the <guilabel>Theme</guilabel> selector to set a theme for the game."
msgstr ""
"Use o seletor do <guilabel>Tema</guilabel> para definir um tema para o jogo."

#. Tag: screeninfo
#: index.docbook:461
#, no-c-format
msgid "<screeninfo>Theme options</screeninfo>"
msgstr "<screeninfo>Opções do tema</screeninfo>"

