#. Tag: title
#: index.docbook:470
#, no-c-format
msgid "<title>Background options</title>"
msgstr "<title>Opções do fundo</title>"

#. Tag: para
#: index.docbook:471
#, no-c-format
msgid ""
"You can choose a background graphic for the game. There are three kinds of "
"background type you can use."
msgstr ""
"Você poderá escolher um fundo gráfico para o jogo. Existem três tipos de "
"fundos que poderá usar."

#. Tag: guilabel
#: index.docbook:475
#, no-c-format
msgid "Theme"
msgstr "Tema"

#. Tag: para
#: index.docbook:476
#, no-c-format
msgid "Use the background shipped with the current theme."
msgstr "Usa o fundo enviado com o tema atual."

#. Tag: guilabel
#: index.docbook:479
#, no-c-format
msgid "Color"
msgstr "Cor"

#. Tag: para
#: index.docbook:480
#, no-c-format
msgid "Use a custom solid color for the background."
msgstr "Usa uma cor única personalizada para o fundo."

#. Tag: guilabel
#: index.docbook:483
#, no-c-format
msgid "Image"
msgstr "Imagem"

#. Tag: para
#: index.docbook:484
#, no-c-format
msgid "Use an image for the background graphic."
msgstr "Usa uma imagem para o fundo."

#. Tag: screeninfo
#: index.docbook:489
#, no-c-format
msgid "<screeninfo>Background options</screeninfo>"
msgstr "<screeninfo>Opções do fundo</screeninfo>"

#. Tag: phrase
#: index.docbook:492
#, no-c-format
msgid "<phrase>Background options</phrase>"
msgstr "<phrase>Opções do fundo</phrase>"

#. Tag: title
#: index.docbook:498
#, no-c-format
msgid "Custom Game options"
msgstr "Opções personalizadas do jogo"

#. Tag: para
#: index.docbook:499
#, no-c-format
msgid ""
"You can set the <guilabel>Height:</guilabel> and <guilabel>Width:</guilabel> "
"of the board and the <guilabel>Color count:</guilabel> used in your custom "
"level."
msgstr ""
"Você poderá definir a <guilabel>Altura:</guilabel> e <guilabel>Largura:</"
"guilabel> do tabuleiro e o <guilabel>Número de cores:</guilabel> usado no "
"seu nível personalizado."

#. Tag: screeninfo
#: index.docbook:504
#, no-c-format
msgid "<screeninfo>Custom game options</screeninfo>"
msgstr "<screeninfo>Opções personalizadas do jogo</screeninfo>"

