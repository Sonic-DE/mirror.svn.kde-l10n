#: src/helper/systemdgenie.actions:2
msgctxt "Name"
msgid "Systemd Genie"
msgstr "Systemd ਜਿੰਨੀ"

#: src/helper/systemdgenie.actions:46
msgctxt "Name"
msgid "Save a systemd unit file"
msgstr "systemd ਯੂਨਿਟ ਫਾਈਲ ਨੂੰ ਸੰਭਾਲੋ"

#: src/helper/systemdgenie.actions:88
msgctxt "Description"
msgid "Administrator authorization is required to save the systemd unit file"
msgstr "systemd ਯੂਨਿਟ ਫਾਈਲ ਸੰਭਾਲਣ ਲਈ ਪ੍ਰਸ਼ਾਸ਼ਕ ਪ੍ਰਮਾਣਕਿਤਾ ਦੀ ਲੋੜ ਹੈ"

#: src/helper/systemdgenie.actions:134
msgctxt "Name"
msgid "Manipulate systemd over D-Bus"
msgstr "D-Bus ਰਾਹੀਂ systemd ਨੂੰ ਵਰਤੋਂ"

#: src/helper/systemdgenie.actions:176
msgctxt "Description"
msgid "Administrator authorization is required to manipulate systemd"
msgstr "systemd ਬਦਲਣ ਲਈ ਪ੍ਰਸ਼ਾਸ਼ਕ ਪ੍ਰਮਾਣਕਿਤਾ ਦੀ ਲੋੜ ਹੈ"

#: src/org.kde.systemdgenie.desktop:2
msgctxt "Name"
msgid "systemdGenie"
msgstr "systemdGenie"

#: src/org.kde.systemdgenie.desktop:32
msgctxt "GenericName"
msgid "systemd Management Tool"
msgstr "systemd ਪਰਸ਼ਾਸ਼ਕੀ ਟੂਲ"

#: src/org.kde.systemdgenie.desktop:62
msgctxt "Comment"
msgid "Manage systemd units, timers, sessions and config files"
msgstr "systemd ਯੂਨਿਟ, ਟਾਈਮਰ, ਸ਼ੈਸ਼ਨ ਅਤੇ ਸੰਰਚਨਾ ਫ਼ਾਇਲਾਂ ਦਾ ਇੰਤਜ਼ਾਮ ਕਰੋ"

#~ msgctxt "Comment"
#~ msgid "Manage the systemd daemon"
#~ msgstr "systemd ਡੈਮਨ ਦਾ ਇੰਤਜ਼ਾਮ ਕਰੋ"
