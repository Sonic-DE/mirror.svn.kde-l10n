msgstr "ਲੋਕਲ ਸਿਸਟਮ ਸੁਨੇਹਾ ਸਰਵਿਸ"

#: kwrited.notifyrc:48
msgctxt "Comment"
msgid "Local system message service"
msgstr "ਲੋਕਲ ਸਿਸਟਮ ਸੁਨੇਹਾ ਸਰਵਿਸ"

#: kwrited.notifyrc:117
msgctxt "Name"
msgid "New message received"
msgstr "ਨਵਾਂ ਸੁਨੇਹਾ ਆਇਆ"

#: kwrited.notifyrc:192
msgctxt "Comment"
msgid "The daemon received a new message sent with wall(1) or write(1)"
msgstr "ਡੈਮਨ ਨੂੰ wall(1) ਜਾਂ write(1) ਤੋਂ ਨਵਾਂ ਭੇਜਿਆ ਸੁਨੇਹਾ ਮਿਲਿਆ"

