msgid "Phone"
msgstr "ਫ਼ੋਨ"

#. (itstool) path: component/summary
#: org.kde.plasma.dialer.appdata.xml:9
msgid "Send and receive phone calls"
msgstr "ਫ਼ੋਨ ਕਾਲਾਂ ਕਰੋ ਤੇ ਲਵੋ"

#. (itstool) path: description/p
#: org.kde.plasma.dialer.appdata.xml:24
msgid ""
"The Phone app lets you easily send and receive phone calls from your "
"smartphone."
msgstr "ਫ਼ੋਨ ਐਪ ਤੁਹਾਨੂੰ ਤੁਹਾਡੇ ਸਮਾਰਟ-ਫ਼ੋਨ ਤੋਂ ਸੌਖੀ ਤਰ੍ਹਾਂ ਫ਼ੋਨ ਕਾਲਾਂ ਕਰਨ ਤੇ ਲੈਣ ਲਈ ਸਹਾਇਕ ਹੈ।"

#. (itstool) path: description/p
#: org.kde.plasma.dialer.appdata.xml:25
msgid "Features:"
msgstr "ਫ਼ੀਚਰ:"

#. (itstool) path: ul/li
#: org.kde.plasma.dialer.appdata.xml:27
msgid "See your call history and easily call the same number again"
msgstr "ਆਪਣੇ ਕਾਲ ਅਤੀਤ ਨੂੰ ਵੇਖੋ ਅਤੇ ਉਸ ਨੰਬਰ ਨੂੰ ਮੁੜ ਕੇ ਸੌਖੀ ਤਰ੍ਹਾਂ ਕਾਲ ਕਰੋ"

#. (itstool) path: ul/li
#: org.kde.plasma.dialer.appdata.xml:28
msgid "Manage your contacts that have a phone number set"
msgstr "ਆਪਣੇ ਸੰਪਰਕਾਂ ਦਾ ਇੰਤਜ਼ਾਮ ਕਰੋ, ਜਿੰਨ੍ਹਾਂ ਲਈ ਫ਼ੋਨ ਨੰਬਰ ਸੈੱਟ ਹੈ"

