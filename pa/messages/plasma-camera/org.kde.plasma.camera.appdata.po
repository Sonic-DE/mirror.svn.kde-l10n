#. (itstool) path: component/name
#: org.kde.plasma.camera.appdata.xml:8
msgid "Plasma Camera"
msgstr "ਪਲਾਜ਼ਮਾ ਕੈਮਰਾ"

#. (itstool) path: component/summary
#: org.kde.plasma.camera.appdata.xml:9
msgid "Take photos and videos"
msgstr "ਫੋਟੋ ਖਿੱਚੋ ਤੇ ਵੀਡੀਓ ਬਣਾਓ"

#. (itstool) path: description/p
#: org.kde.plasma.camera.appdata.xml:19
msgid "Camera Application for Plasma Mobile."
msgstr "ਪਲਾਜ਼ਮਾ ਮੋਬਾਈਲ ਲਈ ਕੈਮਰਾ ਐਪਲੀਕੇਸ਼ਨ ਹੈ।"

#. (itstool) path: description/p
#: org.kde.plasma.camera.appdata.xml:20
msgid ""
"It supports different resolutions, different white balance modes and "
"switching between different camera devices."
msgstr ""
"ਇਹ ਵੱਖੋ-ਵੱਖ ਰੋਜ਼ੂਲੇਸ਼ਨ, ਵੱਖੋ-ਵੱਖ ਵਾਈਟ ਬੈਲਨਸ ਢੰਗ ਤੇ ਵੱਖੋ-ਵੱਖ ਕੈਮਰਾ ਡਿਵਾਈਸਾਂ ਵਿਚਾਲੇ ਬਦਲਣ ਲਈ ਸਹਾਇਕ "
"ਹੈ।"

#~ msgid "KDE Community"
#~ msgstr "ਕੇਡੀਈ ਕਮਿਊਨਟੀ"
