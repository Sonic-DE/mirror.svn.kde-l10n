#. Tag: para
#: basics.docbook:490
#, fuzzy, no-c-format
#| msgid ""
#| "The value displayed is the number of cells containing numeric values."
msgid "The value displayed is the number of non empty cells."
msgstr "Выводится количество ячеек содержащих числовые значения."

#. Tag: guilabel
#: basics.docbook:495
#, no-c-format
msgid "<guilabel>Max</guilabel>"
msgstr "<guilabel>Максимум</guilabel>"

#. Tag: para
#: basics.docbook:496
#, no-c-format
msgid "The value displayed is the maximum of the values in the selected cells."
msgstr "Выводится максимальное из значений в выделенных ячейках."

#. Tag: guilabel
#: basics.docbook:502
#, no-c-format
msgid "<guilabel>Min</guilabel>"
msgstr "<guilabel>Минимум</guilabel>"

#. Tag: para
#: basics.docbook:503
#, no-c-format
msgid "The value displayed is the minimum of the values in the selected cells."
msgstr "Выводится минимальное из значений в выделенных ячейках."

#. Tag: guilabel
#: basics.docbook:509
#, no-c-format
msgid "<guilabel>Sum</guilabel>"
msgstr "<guilabel>Сумма</guilabel>"

#. Tag: para
#: basics.docbook:510
#, no-c-format
