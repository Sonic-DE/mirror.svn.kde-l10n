#. Tag: action
#: index.docbook:243
#, no-c-format
msgid "Decrease the view of the filemap."
msgstr "Уменьшает масштаб файловой карты."

#. Tag: title
#: index.docbook:249
#, no-c-format
msgid "The Go Menu"
msgstr "Меню «Переход»"

#. Tag: menuchoice
#: index.docbook:251
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt;<keycap>Up</keycap></keycombo> </"
"shortcut> <guimenu>Go</guimenu> <guimenuitem>Up</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt;<keycap>Up</keycap></keycombo> </"
"shortcut> <guimenu>Переход</guimenu> <guimenuitem>Вверх</guimenuitem>"

#. Tag: action
#: index.docbook:258
#, no-c-format
msgid "Moves you up one step in the filesystem to the parent folder."
