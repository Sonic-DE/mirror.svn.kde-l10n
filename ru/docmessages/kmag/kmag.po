msgstr ""
"Запустить/Остановить обновление экрана. После остановки обновления нагрузка "
"на процессор снижается до нуля."

#. Tag: menuchoice
#: index.docbook:299
#, no-c-format
msgid "<guimenu>View</guimenu> <guimenuitem>Zoom</guimenuitem>"
msgstr "<guimenu>Вид</guimenu> <guimenuitem>Масштаб</guimenuitem>"

#. Tag: para
#: index.docbook:303
#, no-c-format
msgid "Select the zoom factor."
msgstr "Выбрать коэффициент увеличения."

#. Tag: menuchoice
#: index.docbook:307
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>-</keycap></keycombo> </"
"shortcut> <guimenu>View</guimenu> <guimenuitem>Zoom Out</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>-</keycap></keycombo> </"
"shortcut> <guimenu>Вид</guimenu> <guimenuitem>Уменьшить</guimenuitem>"

#. Tag: para
#: index.docbook:315
#, no-c-format
msgid "Click on this button to zoom-out on the selected region."
msgstr "Эта кнопка позволяет уменьшить выделенную область."

#. Tag: menuchoice
#: index.docbook:319
#, no-c-format
msgid ""
