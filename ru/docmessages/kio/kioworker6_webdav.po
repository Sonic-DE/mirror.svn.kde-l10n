#. Tag: title
#: index.docbook:9
#, no-c-format
msgid "webdav / webdavs"
msgstr "webdav / webdavs"

#. Tag: author
#: index.docbook:12
#, no-c-format
msgid "&Hamish.Rodda; &Hamish.Rodda.mail;"
msgstr "&Hamish.Rodda; &Hamish.Rodda.mail;"

