#. Tag: para
#: index.docbook:41
#, no-c-format
msgid ""
"&knetattach; is a wizard which makes it easier to integrate your network "
"resources with your &kde; Desktop."
msgstr ""
"&knetattach; — это приложение, облегчающее интеграцию сетевых ресурсов с "
"рабочим столом &kde;."

#. Tag: keyword
#: index.docbook:52
#, no-c-format
msgid "<keyword>KDE</keyword>"
msgstr "<keyword>KDE</keyword>"

#. Tag: keyword
