#. Tag: para
#: index.docbook:31
#, no-c-format
msgid ""
"&kdesu; is a graphical front end for the &UNIX; <command>su</command> "
"command."
msgstr ""
"&kdesu; представляет собой графическую оболочку к &UNIX;-команде "
"<command>su</command>."

#. Tag: keyword
#: index.docbook:35
#, no-c-format
msgid "<keyword>KDE</keyword>"
msgstr "<keyword>KDE</keyword>"

#. Tag: keyword
#: index.docbook:36
#, no-c-format
