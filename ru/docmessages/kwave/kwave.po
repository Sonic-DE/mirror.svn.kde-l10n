"        0,   8388352 #            1\n"
" -5930752,   5930496 #            2\n"
" -8388608,         0 #            3\n"
" -5930752,  -5930752 #            4\n"
"        0,  -8388608 #            5\n"
"  5930496,  -5930752 #            6\n"
"  8388352,         0 #            7\n"
"  5930496,   5930496 #            8\n"
"        0,   8388352 #            9\n"
" -5930752,   5930496 #           10\n"
