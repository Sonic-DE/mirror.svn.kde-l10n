#: index.docbook:4152 index.docbook:4203 index.docbook:4231 index.docbook:4256
#, no-c-format
msgid "<title>Parameters</title>"
msgstr "<title>Параметры</title>"

#. Tag: entry
#: index.docbook:2570
#, no-c-format
msgid "<parameter>milliseconds</parameter>:"
msgstr "<parameter>миллисекунды</parameter>:"

#. Tag: entry
#: index.docbook:2571
#, no-c-format
msgid "number of whole milliseconds to wait before executing the command"
msgstr "количество целых миллисекунд ожидания перед выполнением команды"

#. Tag: entry
