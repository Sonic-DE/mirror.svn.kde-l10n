#. Tag: title
#: index.docbook:2589
#, no-c-format
msgid "&no-i18n-cmd_delete;"
msgstr "&no-i18n-cmd_delete;"

#. Tag: title
#: index.docbook:2591
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_delete;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_delete;</command>()"

#. Tag: para
#: index.docbook:2592
#, no-c-format
msgid ""
"Deletes the currently selected range of samples. If the selection is empty, "
"this command does nothing. Affects all tracks."
msgstr ""
"Удаляет текущий выделенный диапазон сэмплов. Если ничего не выделено, "
"команда не выполняется. Влияет на все дорожки."

#. Tag: title
#: index.docbook:2601
#, no-c-format
msgid "&no-i18n-cmd_delete_track;"
msgstr "&no-i18n-cmd_delete_track;"

#. Tag: title
#: index.docbook:2603
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_delete_track;</"
"command>(<replaceable>index</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_delete_track;</"
"command>(<replaceable>индекс</replaceable>)"

#. Tag: para
#: index.docbook:2604
#, no-c-format
msgid ""
"Deletes a track, identified by its index (starting from zero). If no track "
"with the given index exists, this command exits with an error."
msgstr ""
"Удаляет дорожку, определяемую по её индексу (начиная с нуля). Если дорожки с "
"заданным индексом не существует, то эта команда выдаёт ошибку."

#. Tag: entry
#: index.docbook:2610 index.docbook:2733 index.docbook:2772 index.docbook:2800
#: index.docbook:3563 index.docbook:3577 index.docbook:3592
#, no-c-format
msgid "<parameter>index</parameter>:"
msgstr "<parameter>индекс</parameter>:"

#. Tag: entry
#: index.docbook:2610
#, no-c-format
msgid "index of the track to delete, starting with 0"
msgstr "индекс дорожки для удаления, начиная с 0"

#. Tag: title
#: index.docbook:2615
#, no-c-format
msgid "&no-i18n-cmd_dump_metadata;"
msgstr "&no-i18n-cmd_dump_metadata;"

#. Tag: title
#: index.docbook:2617
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_dump_metadata;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_dump_metadata;</"
"command>()"

#. Tag: para
#: index.docbook:2618
#, no-c-format
msgid ""
"Prints a list of all meta data entries to the console, for diagnostic "
"purposes. (Only available when &kwave; has been compiled with the option "
"<literal>WITH_DEBUG</literal> switched on)."
msgstr ""
"Выводит список всех записей метаданных к консоли для диагностических целей. "
"(Доступно только в том случае, если &kwave; был собран с параметром "
"<literal>WITH_DEBUG</literal>)."

#. Tag: title
#: index.docbook:2627
#, no-c-format
msgid "&no-i18n-tag;e"
msgstr "&no-i18n-tag;e"

#. Tag: title
#: index.docbook:2630
#, no-c-format
msgid "&no-i18n-cmd_expandtolabel;"
msgstr "&no-i18n-cmd_expandtolabel;"

#. Tag: title
#: index.docbook:2632
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_expandtolabel;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_expandtolabel;</"
"command>()"

#. Tag: para
#: index.docbook:2633
#, no-c-format
msgid ""
"Expands the current selection to the labels left and right from the current "
"selection borders. If the border of selection already is on a label, it "
"stays unchanged. If there is no label left or right of the current "
"selection, it will be expanded to the start or end of the file."
msgstr ""
"Расширяет текущее выделение до отметок слева и справа от границ текущего "
"выделенного фрагмента. Если граница выделения уже находится на отметке, она "
"останется неизменной. Если слева или справа от текущего выделенного "
"фрагмента нет отметки, то выделение будет расширено до начала или конца "
"файла."

#. Tag: title
#: index.docbook:2644
#, no-c-format
msgid "&no-i18n-tag;f"
msgstr "&no-i18n-tag;f"

#. Tag: title
#: index.docbook:2647
#, no-c-format
msgid "&no-i18n-cmd_fileinfo;"
msgstr "&no-i18n-cmd_fileinfo;"

#. Tag: title
#: index.docbook:2649
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_fileinfo;</"
"command>(<replaceable>index</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_fileinfo;</"
"command>(<replaceable>индекс</replaceable>)"

#. Tag: para
#: index.docbook:2650
#, no-c-format
msgid "Set a file info entry to a new value."
msgstr "Устанавливает новое значение для записи информации о файле."

#. Tag: entry
#: index.docbook:2655
#, no-c-format
msgid "<parameter>keyword</parameter>:"
msgstr "<parameter>ключевое слово</parameter>:"

#. Tag: entry
#: index.docbook:2655
#, no-c-format
msgid "keyword of the entry"
msgstr "ключевое слово записи"

#. Tag: entry
#: index.docbook:2656
#, no-c-format
msgid "<parameter>value</parameter>:"
msgstr "<parameter>значение</parameter>:"

#. Tag: entry
#: index.docbook:2656
#, no-c-format
msgid "value of the entry"
msgstr "значение записи"

#. Tag: title
#: index.docbook:2661
#, no-c-format
msgid "&no-i18n-cmd_forward;"
msgstr "&no-i18n-cmd_forward;"

#. Tag: title
#: index.docbook:2663
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_forward;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_forward;</command>()"

#. Tag: para
#: index.docbook:2664
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Forward</guibutton> toolbar button. If the "
"playback is currently running, it skips forward by 1/10 of the visible "
"range. If the playback is not running, this does the same as the command "
"<command>&no-i18n-cmd_view_scroll_right;</command>()."
msgstr ""
"Соответствует кнопке <guibutton>Вперёд</guibutton> на панели инструментов. "
"Если воспроизведение выполняется в данный момент, оно перематывается вперёд "
"на 1/10 видимого диапазона. Если воспроизведение не выполняется, то "
"производится то же самое действие, что и при команде <command>&no-i18n-"
"cmd_view_scroll_right;</command>()."

#. Tag: para
#: index.docbook:2673
#, no-c-format
msgid ""
"<link linkend=\"cmd_sect_view_scroll_right\"><command>&no-i18n-tag;&no-i18n-"
"cmd_view_scroll_right;</command>()</link>, <link linkend=\"cmd_sect_rewind"
"\"><command>&no-i18n-tag;&no-i18n-cmd_rewind;</command>()</link>"
msgstr ""
"<link linkend=\"cmd_sect_view_scroll_right\"><command>&no-i18n-tag;&no-i18n-"
"cmd_view_scroll_right;</command>()</link>, <link linkend=\"cmd_sect_rewind"
"\"><command>&no-i18n-tag;&no-i18n-cmd_rewind;</command>()</link>"

#. Tag: title
#: index.docbook:2681
#, no-c-format
msgid "&no-i18n-tag;g"
msgstr "&no-i18n-tag;g"

#. Tag: title
#: index.docbook:2684
#, no-c-format
msgid "&no-i18n-cmd_goto;"
msgstr "&no-i18n-cmd_goto;"

#. Tag: title
#: index.docbook:2686
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_goto;</command>(<replaceable>pos</"
"replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_goto;</command>(<replaceable>позиция</"
"replaceable>)"

#. Tag: para
#: index.docbook:2687
#, no-c-format
msgid ""
"Sets the cursor to the given position and makes it visible in current view. "
"After this the selection has zero length."
msgstr ""
"Устанавливает курсор в заданное положение и отображает его в текущей области "
"просмотра. После этого выделение имеет нулевую длительность."

#. Tag: entry
#: index.docbook:2693 index.docbook:2711 index.docbook:2756
#, no-c-format
msgid "<parameter>pos</parameter>:"
msgstr "<parameter>позиция</parameter>:"

#. Tag: entry
#: index.docbook:2693
#, no-c-format
msgid "position in samples where to go to"
msgstr "позиция в сэмплах, которая определяет место для перехода"

#. Tag: title
#: index.docbook:2698
#, no-c-format
msgid "&no-i18n-tag;i"
msgstr "&no-i18n-tag;i"

#. Tag: title
#: index.docbook:2701
#, no-c-format
msgid "&no-i18n-cmd_insert_at;"
msgstr "&no-i18n-cmd_insert_at;"

#. Tag: title
#: index.docbook:2703
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_insert_at;</"
"command>(<replaceable>pos</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_insert_at;</"
"command>(<replaceable>позиция</replaceable>)"

#. Tag: para
#: index.docbook:2704
#, no-c-format
msgid ""
"Inserts the content of the clipboard at the given position, like the command "
"<command>&no-i18n-cmd_paste;</command>(). If the clipboard is currently "
"empty, this function does nothing."
msgstr ""
"Вставляет содержимое буфера обмена в заданную позицию, аналогичную команде "
"<command>&no-i18n-cmd_paste;</command>(). Если буфер обмена в данный момент "
"пуст, эта команда не выполняется."

#. Tag: entry
#: index.docbook:2711
#, no-c-format
msgid "position in samples where to insert"
msgstr "позиция в сэмплах, которая определяет место для вставки"

#. Tag: title
#: index.docbook:2719
#, no-c-format
msgid "&no-i18n-cmd_insert_track;"
msgstr "&no-i18n-cmd_insert_track;"

#. Tag: title
#: index.docbook:2721
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_insert_track;</"
"command>(<replaceable>index</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_insert_track;</"
"command>(<replaceable>индекс</replaceable>)"

#. Tag: para
#: index.docbook:2722
#, no-c-format
msgid ""
"Inserts a new track at the given index, using the current length and sample "
"rate settings of the signal. If the index is higher than or equal to the "
"current number of tracks, it will be appended as the last track, same as by "
"the command <command>&no-i18n-cmd_add_track;</command>(). The index of all "
"existing tracks at and after the given index will be incremented by one."
msgstr ""
"Вставляет новую дорожку с заданным индексом, используя текущие параметры "
"длительности и частоты дискретизации сигнала. Если индекс больше или равен "
"текущему количеству дорожек, данные будут добавлены к последней дорожке, что "
"аналогично команде <command>&no-i18n-cmd_add_track;</command>(). Индекс всех "
"существующих дорожек после заданного индекса будет увеличен на единицу."

#. Tag: entry
#: index.docbook:2733
#, no-c-format
msgid "index of the track to insert, starting with 0"
msgstr "индекс дорожки для вставки, начиная с 0"

#. Tag: link
#: index.docbook:2737
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_add_track;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_add_track;</command>()"

#. Tag: title
#: index.docbook:2743
#, no-c-format
msgid "&no-i18n-tag;l"
msgstr "&no-i18n-tag;l"

#. Tag: title
#: index.docbook:2746
#, no-c-format
msgid "&no-i18n-cmd_label_add;"
msgstr "&no-i18n-cmd_label_add;"

#. Tag: title
#: index.docbook:2748
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_label_add;</"
"command>(<replaceable>pos</replaceable>[,<replaceable>text</replaceable>])"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_label_add;</"
"command>(<replaceable>позиция</replaceable>[,<replaceable>текст</"
"replaceable>])"

#. Tag: para
#: index.docbook:2749
#, no-c-format
msgid ""
"Add a new label at a given position. If the given position already contains "
"a label, then this command does nothing. The label can be given an optional "
"description."
msgstr ""
"Добавляет новую отметку в указанную позицию. Если указанная позиция уже "
"содержит отметку, команда не выполняется. Отметке возможно присвоить "
"необязательное описание."

#. Tag: entry
#: index.docbook:2756
#, no-c-format
msgid "position in samples where to insert the label"
msgstr "позиция в сэмплах, которая определяет место для вставки отметки"

#. Tag: entry
#: index.docbook:2757 index.docbook:3055
#, no-c-format
msgid "<parameter>text</parameter>:"
msgstr "<parameter>текст</parameter>:"

#. Tag: entry
#: index.docbook:2757
#, no-c-format
msgid "some descriptive text (optional)"
msgstr "текст описания (необязательно)"

#. Tag: title
#: index.docbook:2762
#, no-c-format
msgid "&no-i18n-cmd_label_delete;"
msgstr "&no-i18n-cmd_label_delete;"

#. Tag: title
#: index.docbook:2764
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_label_delete;</"
"command>(<replaceable>index</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_label_delete;</"
"command>(<replaceable>индекс</replaceable>)"

#. Tag: para
#: index.docbook:2765
#, no-c-format
msgid ""
"Deletes a label, identified by its index (starting from zero), or all labels "
"when using the special value -1 as index. If no label with the given index "
"exists, this command does nothing."
msgstr ""
"Удаляет отметку, определяемую по её индексу (начиная с нуля), или все "
"отметки при использовании специального значения -1 в качестве индекса. Если "
"отметки с заданным индексом не существует, то эта команда не выполняется."

#. Tag: entry
#: index.docbook:2772
#, no-c-format
msgid ""
"index of the label to delete, starting with 0 or -1 to delete all labels"
msgstr ""
"индекс отметки для удаления, начиная с 0 или -1 для удаления всех отметок"

#. Tag: title
#: index.docbook:2778
#, no-c-format
msgid "&no-i18n-cmd_label_edit;"
msgstr "&no-i18n-cmd_label_edit;"

#. Tag: screeninfo
#: index.docbook:2780 index.docbook:4379 index.docbook:4419 index.docbook:4564
#: index.docbook:4923 index.docbook:5231 index.docbook:5424 index.docbook:5460
#: index.docbook:5550 index.docbook:5643 index.docbook:5706 index.docbook:5750
#: index.docbook:5868 index.docbook:5943 index.docbook:6061 index.docbook:6154
#: index.docbook:6460 index.docbook:6685 index.docbook:6799 index.docbook:6810
#: index.docbook:6948 index.docbook:7002
#, no-c-format
msgid "Screenshot"
msgstr "Снимок экрана"

#. Tag: phrase
#: index.docbook:2786
#, no-c-format
msgid "Screenshot of the label editing dialog"
msgstr "Снимок экрана диалогового окна редактирования"

#. Tag: title
#: index.docbook:2791
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_label_edit;</"
"command>(<replaceable>index</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_label_edit;</"
"command>(<replaceable>индекс</replaceable>)"

#. Tag: para
#: index.docbook:2792
#, no-c-format
msgid ""
"Opens a dialog window in which the user can edit the position and the "
"description of a label, which is identified by its index (starting from "
"zero). If no label with the given index exists, this command does nothing."
msgstr ""
"Открывает диалоговое окно, в котором пользователь может редактировать "
"положение и описание отметки, которая определяется по её индексу (начиная с "
"нуля). Если отметки с заданным индексом не существует, то команда не "
"выполняется."

#. Tag: entry
#: index.docbook:2800
#, no-c-format
msgid "index of the label to edit, starting with 0"
msgstr "индекс отметки для редактирования, начиная с 0"

#. Tag: title
#: index.docbook:2805
#, no-c-format
msgid "&no-i18n-cmd_loadbatch;"
msgstr "&no-i18n-cmd_loadbatch;"

#. Tag: title
#: index.docbook:2807
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_loadbatch;</"
"command>(<replaceable>filename</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_loadbatch;</"
"command>(<replaceable>имя_файла</replaceable>)"

#. Tag: para
#: index.docbook:2808
#, no-c-format
msgid ""
"Opens a &kwave; script file and processes the commands in it. Uses the "
"context of the currently opened file or the current main window if no file "
"is loaded."
msgstr ""
"Открывает файл сценария &kwave; и обрабатывает содержащиеся в нём команды. "
"Использует содержимое текущего открытого файла или текущего главного окна, "
"если не загружено ни одного файла."

#. Tag: entry
#: index.docbook:2815 index.docbook:3138 index.docbook:3164 index.docbook:3460
#: index.docbook:3493 index.docbook:4234
#, no-c-format
msgid "<parameter>filename</parameter>:"
msgstr "<parameter>имя_файла</parameter>:"

#. Tag: entry
#: index.docbook:2816
#, no-c-format
msgid "name of the kwave script file including path and extension"
msgstr "имя сценария kwave, включающее в себя путь и расширение"

#. Tag: title
#: index.docbook:2821
#, no-c-format
msgid "&no-i18n-cmd_loop;"
msgstr "&no-i18n-cmd_loop;"

#. Tag: title
#: index.docbook:2823
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_loop;</command>()"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_loop;</command>()"

#. Tag: para
#: index.docbook:2824
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Loop</guibutton> toolbar button. Starts the "
"playback (if it is not already running) and lets it play in a loop."
msgstr ""
"Соответствует кнопке <guibutton>Запустить в цикле</guibutton> на панели "
"инструментов. Запускает воспроизведение (если оно ещё не запущено) и "
"зацикливает его."

#. Tag: link
#: index.docbook:2832
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_playback_start;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_playback_start;</command>()"

#. Tag: title
#: index.docbook:2838
#, no-c-format
msgid "&no-i18n-tag;m"
msgstr "&no-i18n-tag;m"

#. Tag: title
#: index.docbook:2841
#, no-c-format
msgid "&no-i18n-cmd_menu;"
msgstr "&no-i18n-cmd_menu;"

#. Tag: title
#: index.docbook:2843
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_menu;</command> "
"(<replaceable>command</replaceable>, <replaceable>path</replaceable>, "
"[<replaceable>hotkey</replaceable>], [<replaceable>id</replaceable>])"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_menu;</command> "
"(<replaceable>команда</replaceable>, <replaceable>путь</replaceable>, "
"[<replaceable>горячая_клавиша</replaceable>], [<replaceable>идентификатор</"
"replaceable>])"

#. Tag: para
#: index.docbook:2849
#, no-c-format
msgid ""
"This is a very powerful command, which is used to add a new entry to the "
"menu or to modify an existing entry. It determines which <emphasis>command</"
"emphasis> is executed when the menu entry is activated, which "
"<emphasis>icon</emphasis> is shown in the menu and which <emphasis>hotkey</"
"emphasis> is used. Each menu entry can be <emphasis>disabled</emphasis> or "
"<emphasis>hidden</emphasis>, can be assigned a unique <emphasis>id</"
"emphasis> and can also join a <emphasis>menu group</emphasis>."
msgstr ""
"Это очень мощная команда, которая используется для добавления нового пункта "
"меню или для внесения изменений в существующий пункт. Она определяет, какая "
"<emphasis>команда</emphasis> будет выполняться при активации пункта меню, "
"какой <emphasis>значок</emphasis> будет отображаться в меню и какая "
"<emphasis>клавиша</emphasis> будет использоваться для его активации. Каждый "
"пункт меню может быть <emphasis>отключён</emphasis> или <emphasis>скрыт</"
"emphasis>, ему может быть присвоен уникальный <emphasis>идентификатор</"
"emphasis>, либо он может быть присоединён к <emphasis>группе меню</emphasis>."

#. Tag: para
#: index.docbook:2860
#, no-c-format
msgid "You normally do not need this command within a &kwave; script!"
msgstr ""
"Обычно потребности в этой команде при выполнении сценариев &kwave; не "
"возникает."

#. Tag: entry
#: index.docbook:2867
#, no-c-format
msgid ""
"A text command (including parameters) or a command list that will be "
"executed when the menu entry gets activated. If a menu entry does not have a "
"corresponding command (for example if it is a sub menu and not menu entry), "
"you should use the special command <command>ignore</command>()."
msgstr ""
"Текстовая команда (включая параметры) или список команд, которые будут "
"выполняться при выборе пункта меню. Если в пункте меню отсутствует "
"соответствующая команда (например, если это вложенное меню, а не пункт "
"меню), следует воспользоваться специальной командой <command>ignore</"
"command>()."

#. Tag: entry
#: index.docbook:2876
#, no-c-format
msgid "<parameter>path</parameter>:"
msgstr "<parameter>путь</parameter>:"

#. Tag: entry
#: index.docbook:2877
#, no-c-format
msgid ""
"The path within the menu, using a <quote><token>/</token></quote> as "
"separator. The last part of the path can be a <emphasis>sub command</"
"emphasis> which modifies some property of the menu entry (see <link linkend="
"\"menu_sub_commands\">below</link>). The last portion of the path (that is "
"not a sub command) produces a menu entry, the parts before produce the main "
"menu entry or sub menus that lead to it. Main menu entries or sub menus are "
"automatically created when a menu entry is created, you do not need them "
"manually."
msgstr ""
"Путь в иерархии меню с использованием символа «<token>/</token>» в качестве "
"разделителя уровней иерархии. Последняя часть пути может быть "
"<emphasis>дополнительной командой</emphasis>, которая изменяет некоторые "
"свойства элемента меню (смотрите <link linkend=\"menu_sub_commands\">далее</"
"link>). Последняя часть пути (не являющаяся дополнительной командой), "
"создаёт пункт меню, а части перед ней — пункт главного меню или вложенное "
"меню, которые ведут к нему. Пункты главного меню или вложенного меню "
"создаются автоматически при создании пункта меню, вручную их создавать не "
"требуется."

#. Tag: entry
#: index.docbook:2890
#, no-c-format
msgid "<parameter>hotkey</parameter>:"
msgstr "<parameter>горячая_клавиша</parameter>:"

#. Tag: entry
#: index.docbook:2891
#, no-c-format
msgid ""
"A bitmask that consists of a combination of predefined <emphasis>keys</"
"emphasis> and <emphasis>modifiers</emphasis>, concatenated with a "
"<quote><token>+</token></quote>. The <emphasis>key</emphasis> can be either "
"a digit, an upper case letter, a function key (<quote>F1</quote> ... "
"<quote>F12</quote>) or any other key name understood by the Qt class "
"<quote><literal>QKeySequence</literal></quote>, including key names for "
"predefined actions (like for example <quote><literal>::Copy</literal></"
"quote>). Typical <emphasis>modifiers</emphasis> are <quote><literal>SHIFT</"
"literal></quote>, <quote><literal>ALT</literal></quote> and "
"<quote><literal>CTRL</literal></quote>."
msgstr ""
"Битовая маска, состоящая из комбинации предопределённых <emphasis>клавиш</"
"emphasis> и <emphasis>модификаторов</emphasis>, объединённых символом "
"«<token>+</token>». <emphasis>Клавишей</emphasis> может быть цифра, буква "
"верхнего регистра или функциональная клавиша («F1»-«F12»), или любое другое "
"название клавиши, относящееся к классу Qt «<literal>QKeySequence</literal>», "
"включая имена клавиш для определённых действий (например, «<literal>::Copy</"
"literal>». Типичными <emphasis>модификаторами</emphasis> являются "
"«<literal>SHIFT</literal>», «<literal>ALT</literal>» и «<literal>CTRL</"
"literal>»."

#. Tag: entry
#: index.docbook:2909
#, no-c-format
msgid "<parameter>id</parameter>:"
msgstr "<parameter>идентификатор</parameter>:"

#. Tag: entry
#: index.docbook:2910
#, no-c-format
msgid ""
"A unique id that can be internally used to identify this menu entry or "
"menu / sub menu. Only uppercase letters, digits and <quote><literal>_</"
"literal></quote> should be used and it should start with "
"<quote><literal>ID_</literal></quote>. It is in your own responsibility to "
"make sure that the same id is not used twice."
msgstr ""
"Уникальный идентификатор, который может быть использован приложением для "
"определения этого пункта меню или меню/вложенного меню. Допустимы только "
"буквы верхнего регистра, цифры и символ «<literal>_</literal>», а начинаться "
"идентификатор должен с символов «<literal>ID_</literal>». Необходимо следить "
"за тем, чтобы один и тот же идентификатор не использовался дважды."

#. Tag: title
#: index.docbook:2920
#, no-c-format
msgid "Sub Commands"
msgstr "Дополнительные команды"

#. Tag: entry
#: index.docbook:2922
#, no-c-format
msgid "<command>&no-i18n-tag;#checkable</command>:"
msgstr "<command>&no-i18n-tag;#checkable</command>:"

#. Tag: entry
#: index.docbook:2923
#, no-c-format
msgid ""
"Makes the menu entry <emphasis>checkable</emphasis>, so that it can be "
"switched on or off."
msgstr ""
"Присваивает пункту меню возможность установки и снятия флажка, чтобы его "
"можно было включить или выключить."

#. Tag: entry
#: index.docbook:2928
#, no-c-format
msgid "<command>&no-i18n-tag;#disabled</command>:"
msgstr "<command>&no-i18n-tag;#disabled</command>:"

#. Tag: entry
#: index.docbook:2929
#, no-c-format
msgid "<emphasis>Disables</emphasis> the menu, sub menu or menu entry."
msgstr "<emphasis>Отключает</emphasis> меню, вложенное меню или пункт меню."

#. Tag: entry
#: index.docbook:2933
#, no-c-format
msgid "<command>&no-i18n-tag;#enabled</command>:"
msgstr "<command>&no-i18n-tag;#enabled</command>:"

#. Tag: entry
#: index.docbook:2934
#, no-c-format
msgid "<emphasis>Enables</emphasis> the menu, sub menu or menu entry."
msgstr "<emphasis>Включает</emphasis> меню, вложенное меню или пункт меню."

#. Tag: entry
#: index.docbook:2938
#, no-c-format
msgid "<command>#exclusive</command>(<replaceable>group</replaceable>):"
msgstr "<command>#exclusive</command>(<replaceable>группа</replaceable>):"

#. Tag: entry
#: index.docbook:2939
#, no-c-format
msgid ""
"Adds the menu entry to an <emphasis>exclusive</emphasis> "
"<emphasis><replaceable>group</replaceable></emphasis> (one of many "
"selection). The group that is given as parameter should not be used for any "
"other purpose. Only one entry within that group can be selected at a time."
msgstr ""
"Добавляет пункт меню в <emphasis>эксклюзивную</emphasis> "
"<emphasis><replaceable>группу</replaceable></emphasis> (одну из широкого "
"диапазона). Группа, указанная в качестве параметра, не должна использоваться "
"для каких-либо других целей. За раз в этой группе возможно выбрать только "
"один пункт."

#. Tag: entry
#: index.docbook:2947
#, no-c-format
msgid "<command>#group</command>(<replaceable>list</replaceable>):"
msgstr "<command>#group</command>(<replaceable>список</replaceable>):"

#. Tag: para
#: index.docbook:2948
#, no-c-format
msgid ""
"Adds the menu, sub menu or menu entry to one or more a <emphasis>groups</"
"emphasis>, so that the application can enable/disable a bunch of menu "
"entries without need to know all their unique ids. Multiple groups can be "
"passed as a list with a <quote><literal>,</literal></quote> as separator. "
"Group names have to start with a <quote><literal>@</literal></quote>. The "
"following groups are predefined:"
msgstr ""
"Добавляет меню, вложенное меню или пункт меню к одной или нескольким "
"<emphasis>группам</emphasis>, чтобы приложение могло включать или отключать "
"несколько пунктов меню без необходимости в знании всех их уникальных "
"идентификаторов. Несколько групп могут быть переданы в виде списка с "
"символом «<literal>,</literal>» в качестве разделителя. Имена групп должны "
"начинаться с символа «<literal>@</literal>». Предопределены следующие группы:"

#. Tag: term
#: index.docbook:2959
#, no-c-format
msgid "<command>&no-i18n-tag;@CLIPBOARD</command>:"
msgstr "<command>&no-i18n-tag;@CLIPBOARD</command>:"

#. Tag: para
#: index.docbook:2961
#, no-c-format
msgid "Only enabled when the clipboard is not empty."
msgstr "Активируется только когда буфер обмена не пустой."

#. Tag: term
#: index.docbook:2967
#, no-c-format
msgid "<command>&no-i18n-tag;@LABELS</command>:"
msgstr "<command>&no-i18n-tag;@LABELS</command>:"

#. Tag: para
#: index.docbook:2969
#, no-c-format
msgid "Only enabled when the current signal contains at least one label."
msgstr "Активируется только если текущий сигнал содержит хотя бы одну отметку."

#. Tag: term
#: index.docbook:2976
#, no-c-format
msgid "<command>&no-i18n-tag;@NOT_CLOSED</command>:"
msgstr "<command>&no-i18n-tag;@NOT_CLOSED</command>:"

#. Tag: para
#: index.docbook:2978
#, no-c-format
msgid ""
"Enabled when the current signal is not closed (the signal might be empty or "
"zero length)."
msgstr ""
"Активируется только когда текущий сигнал не закрыт (сигнал может быть пустым "
"или с нулевой длительностью)."

#. Tag: term
#: index.docbook:2985
#, no-c-format
msgid "<command>&no-i18n-tag;@SELECTION</command>:"
msgstr "<command>&no-i18n-tag;@SELECTION</command>:"

#. Tag: para
#: index.docbook:2987
#, no-c-format
msgid ""
"Enabled when the selection is not empty (more than one sample is selected)."
msgstr ""
"Активируется только когда выделение не пустое (выделено более одного сэмпла)."

#. Tag: term
#: index.docbook:2994
#, no-c-format
msgid "<command>&no-i18n-tag;@SIGNAL</command>:"
msgstr "<command>&no-i18n-tag;@SIGNAL</command>:"

#. Tag: para
#: index.docbook:2996
#, no-c-format
msgid ""
"Enabled when there is some signal loaded and it is not empty or zero length."
msgstr ""
"Активируется только когда какой-либо загруженный сигнал не пустой или имеет "
"нулевую длительность."

#. Tag: entry
#: index.docbook:3005
#, no-c-format
msgid "<command>&no-i18n-tag;#hidden</command>:"
msgstr "<command>&no-i18n-tag;#hidden</command>:"

#. Tag: entry
#: index.docbook:3006
#, no-c-format
msgid "<emphasis>Hides</emphasis> the menu, sub menu or menu entry."
msgstr "<emphasis>Скрывает</emphasis> меню, вложенное меню или пункт меню."

#. Tag: entry
#: index.docbook:3009
#, no-c-format
msgid "<command>#icon</command>(<replaceable>name</replaceable>):"
msgstr "<command>#icon</command>(<replaceable>имя</replaceable>):"

#. Tag: entry
#: index.docbook:3010
#, no-c-format
msgid ""
"Assigns an <emphasis>icon</emphasis> to the menu entry. The icon "
"<emphasis><replaceable>name</replaceable></emphasis> should correspond to an "
"icon file (without path and file extension) that is installed on the system "
"or with &kwave;."
msgstr ""
"Назначает <emphasis>значок</emphasis> пункту меню. "
"<emphasis><replaceable>Имя</replaceable></emphasis> значка должно "
"соответствовать файлу значка (без пути и расширения), установленному в "
"системе или в &kwave;."

#. Tag: entry
#: index.docbook:3018
#, no-c-format
msgid ""
"<command>#listmenu</command>(<replaceable>id</replaceable>,"
"<replaceable>command</replaceable>):"
msgstr ""
"<command>#listmenu</command>(<replaceable>идентификатор</replaceable>,"
"<replaceable>команда</replaceable>):"

#. Tag: entry
#: index.docbook:3019
#, no-c-format
msgid ""
"Inserts a placeholder for a list of menu entries into a sub menu. The unique "
"<emphasis><replaceable>id</replaceable></emphasis> specified in this sub "
"command is used to add/remove or clear the list of menu entries. The "
"<emphasis><replaceable>command</replaceable></emphasis> parameter has to "
"contain <quote><literal>%1</literal></quote> as parameter, which will be "
"replaced with the text of the menu entry when it is activated. This sub "
"command is internally used for the list of recent files, list of tracks and "
"window list."
msgstr ""
"Вставляет заполнитель для списка пунктов меню к вложенному меню. Уникальный "
"<emphasis><replaceable>идентификатор</replaceable></emphasis>, указанный в "
"этой дополнительной команде, используется для добавления, удаления или "
"очистки списка пунктов меню. Параметр <emphasis><replaceable>команда</"
"replaceable></emphasis> должен содержать «<literal>%1</literal>» в качестве "
"параметра, который будет заменён текстом пункта меню, когда команда будет "
"активирована. Эта дополнительная команда внутренне используется для списка "
"последних файлов, дорожек или списка окон."

#. Tag: entry
#: index.docbook:3033
#, no-c-format
msgid "<command>&no-i18n-tag;#separator</command>:"
msgstr "<command>&no-i18n-tag;#separator</command>:"

#. Tag: entry
#: index.docbook:3034
#, no-c-format
msgid "Inserts a separator into a sub menu."
msgstr "Добавляет разделитель во вложенное меню."

#. Tag: title
#: index.docbook:3044
#, no-c-format
msgid "&no-i18n-cmd_msgbox;"
msgstr "&no-i18n-cmd_msgbox;"

#. Tag: title
#: index.docbook:3046
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_msgbox;</command>(<replaceable>text</"
"replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_msgbox;</command>(<replaceable>текст</"
"replaceable>)"

#. Tag: para
#: index.docbook:3047
#, no-c-format
msgid ""
"Shows a message box with some <emphasis><replaceable>text</replaceable></"
"emphasis> and the two buttons <guibutton>OK</guibutton> (returns without "
"error code) and <guibutton>Cancel</guibutton> (returns and error code). You "
"can use this command to give the user a possibility to abort a running "
"script."
msgstr ""
"Отображает окно сообщения с определённым <emphasis><replaceable>текстом</"
"replaceable></emphasis> и двумя кнопками <guibutton>OK</guibutton> (не "
"выдаёт ошибку) и <guibutton>Отмена</guibutton> (выдаёт код ошибки). Эту "
"команду возможно использовать для того, чтобы получить возможность прервать "
"выполнение сценария."

#. Tag: entry
#: index.docbook:3056
#, no-c-format
msgid ""
"A message that will be shown in the message box, should contain a question "
"that can be answered with <guibutton>OK</guibutton> or <guibutton>Cancel</"
"guibutton>."
msgstr ""
"Сообщение, которое будет отображаться в окне сообщения, должно содержать "
"вопрос, на который возможно ответить с помощью кнопок <guibutton>OK</"
"guibutton> или <guibutton>Отмена</guibutton>."

#. Tag: title
#: index.docbook:3066
#, no-c-format
msgid "&no-i18n-tag;n"
msgstr "&no-i18n-tag;n"

#. Tag: title
#: index.docbook:3069
#, no-c-format
msgid "&no-i18n-cmd_newsignal;"
msgstr "&no-i18n-cmd_newsignal;"

#. Tag: title
#: index.docbook:3071
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_newsignal;</"
"command>( <replaceable>samples</replaceable>, <replaceable>rate</"
"replaceable>, <replaceable>bits</replaceable>, <replaceable>tracks</"
"replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_newsignal;</"
"command>(<replaceable>сэмплы</replaceable>, <replaceable>частота</"
"replaceable>, <replaceable>биты</replaceable>, <replaceable>дорожки</"
"replaceable>)"

#. Tag: para
#: index.docbook:3077
#, no-c-format
msgid ""
"Creates a new signal, with a given length in <emphasis><replaceable>samples</"
"replaceable></emphasis>, a <emphasis><replaceable>rate</replaceable></"
"emphasis> in samples per second (floating point number), a number of "
"<emphasis><replaceable>bits</replaceable></emphasis> per sample and number "
"of <emphasis><replaceable>tracks</replaceable></emphasis>. You can calculate "
"the length in samples by multiplying the desired length in seconds with the "
"sample rate."
msgstr ""
"Создаёт новый сигнал с заданными значениями длительности в "
"<emphasis><replaceable>сэмплах</replaceable></emphasis>, "
"<emphasis><replaceable>частоте</replaceable></emphasis> сэмплов в секунду "
"(число с плавающей запятой), числа <emphasis><replaceable>битов</"
"replaceable></emphasis> на сэмпл и количества "
"<emphasis><replaceable>дорожек</replaceable></emphasis>. Чтобы рассчитать "
"длительность в сэмплах, умножьте желаемую длину в секундах на частоту "
"дискретизации."

#. Tag: entry
#: index.docbook:3089
#, no-c-format
msgid "<parameter>samples</parameter>:"
msgstr "<parameter>сэмплы</parameter>:"

#. Tag: entry
#: index.docbook:3090
#, no-c-format
msgid "Length of the signal in samples."
msgstr "Длительность сигнала в сэмплах."

#. Tag: entry
#: index.docbook:3091
#, no-c-format
msgid "<parameter>rate</parameter>:"
msgstr "<parameter>частота</parameter>:"

#. Tag: entry
#: index.docbook:3092
#, no-c-format
msgid "<entry>Sample rate in samples per second.</entry>"
msgstr "<entry>Частота дискретизации в сэмплах в секунду.</entry>"

#. Tag: entry
#: index.docbook:3093
#, no-c-format
msgid "<parameter>bits</parameter>:"
msgstr "<parameter>биты</parameter>:"

#. Tag: entry
#: index.docbook:3094
#, no-c-format
msgid ""
"Number of bits per sample, must not be zero, should be a number from 8...32."
msgstr ""
"Количество битов на сэмпл, значение не должно быть нулевым, допустимы "
"значения от 8 до 32."

#. Tag: entry
#: index.docbook:3096
#, no-c-format
msgid "<parameter>tracks</parameter>:"
msgstr "<parameter>дорожки</parameter>:"

#. Tag: entry
#: index.docbook:3097
#, no-c-format
msgid "Number of tracks."
msgstr "Количество дорожек"

#. Tag: title
#: index.docbook:3102
#, no-c-format
msgid "&no-i18n-cmd_next;"
msgstr "&no-i18n-cmd_next;"

#. Tag: title
#: index.docbook:3104
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_next;</command>()"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_next;</command>()"

#. Tag: para
#: index.docbook:3105
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Next</guibutton> toolbar button. If the "
"playback is currently running, it skips forward to the next label. If the "
"playback is not running, this does the same as the command <command>&no-i18n-"
"cmd_view_scroll_next_label;</command>()."
msgstr ""
"Соответствует кнопке <guibutton>Следующий</guibutton> на панели "
"инструментов. Если воспроизведение в данный момент выполняется, происходит "
"переход к следующей отметке. Если воспроизведение не запущено, происходит "
"процесс, аналогичный команде <command>&no-i18n-cmd_view_scroll_next_label;</"
"command>()."

#. Tag: para
#: index.docbook:3114
#, no-c-format
msgid ""
"<link linkend=\"cmd_sect_view_scroll_next_label\"><command>&no-i18n-tag;&no-"
"i18n-cmd_view_scroll_next_label;</command>()</link>, <link linkend="
"\"cmd_sect_prev\"><command>&no-i18n-tag;&no-i18n-cmd_prev;</command>()</link>"
msgstr ""
"<link linkend=\"cmd_sect_view_scroll_next_label\"><command>&no-i18n-tag;&no-"
"i18n-cmd_view_scroll_next_label;</command>()</link>, <link linkend="
"\"cmd_sect_prev\"><command>&no-i18n-tag;&no-i18n-cmd_prev;</command>()</link>"

#. Tag: title
#: index.docbook:3122
#, no-c-format
msgid "&no-i18n-tag;o"
msgstr "&no-i18n-tag;o"

#. Tag: title
#: index.docbook:3125
#, no-c-format
msgid "&no-i18n-cmd_open;"
msgstr "&no-i18n-cmd_open;"

#. Tag: title
#: index.docbook:3127
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_open;</"
"command>([<replaceable>filename</replaceable>])"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_open;</"
"command>([<replaceable>имя_файла</replaceable>])"

#. Tag: para
#: index.docbook:3128
#, no-c-format
msgid ""
"Opens a file, which can be either a sound file or a &kwave; script. If no "
"file name is passed, then a dialog window will be opened that allows to "
"select an existing file. Depending on the &GUI; mode the file will be opened "
"in the context of a new sub-window (MDI and tab) or in a new main window "
"(SDI, if there was already something loaded)."
msgstr ""
"Открывает файл, который может быть либо звуковым файлом, либо сценарием "
"&kwave;. Если имя файла не указано, то откроется диалоговое окно, в котором "
"можно выбрать существующий файл. В зависимости от режима графического "
"интерфейса, файл будет открыт либо во вложенном окне (режим MDI или режим "
"вкладок) либо в новом главном окне (режим SDI, если что-то уже загружено)."

#. Tag: entry
#: index.docbook:3139
#, no-c-format
msgid "name of a file including path and extension"
msgstr "имя файла, включающее в себя путь и расширение"

#. Tag: link
#: index.docbook:3143 index.docbook:3332
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_close;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_close;</command>()"

#. Tag: title
#: index.docbook:3149
#, no-c-format
msgid "&no-i18n-cmd_openrecent;"
msgstr "&no-i18n-cmd_openrecent;"

#. Tag: title
#: index.docbook:3151
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_openrecent;</"
"command>(<replaceable>filename</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_openrecent;</"
"command>(<replaceable>имя_файла</replaceable>)"

#. Tag: para
#: index.docbook:3152
#, no-c-format
msgid ""
"Practically the same as the command <command>&no-i18n-cmd_open;</command>(), "
"but intended to be used internally for the list of recently opened files in "
"the menu <menuchoice> <guimenu>File</guimenu><guimenu>Open Recent</guimenu> "
"</menuchoice>. In this command the parameter <replaceable>filename</"
"replaceable> is not optional."
msgstr ""
"Эта команда практически аналогична команде <command>&no-i18n-cmd_open;</"
"command>(), однако она предназначена для внутреннего использования для "
"списка недавно открытых файлов в меню <menuchoice> <guimenu>Файл</"
"guimenu><guimenu>Последние файлы</guimenu> </menuchoice>. Для этой команды "
"параметр <replaceable>имя_файла</replaceable> является обязательным."

#. Tag: entry
#: index.docbook:3165
#, no-c-format
msgid "entry of the list of recently opened files"
msgstr "запись списка недавно открытых файлов"

#. Tag: link
#: index.docbook:3169
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_open;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_open;</command>()"

#. Tag: title
#: index.docbook:3175
#, no-c-format
msgid "&no-i18n-tag;p"
msgstr "&no-i18n-tag;p"

#. Tag: title
#: index.docbook:3178
#, no-c-format
msgid "&no-i18n-cmd_paste;"
msgstr "&no-i18n-cmd_paste;"

#. Tag: title
#: index.docbook:3180
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_paste;</command>()"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_paste;</command>()"

#. Tag: para
#: index.docbook:3181
#, no-c-format
msgid ""
"Replaces the current selection with the content of the clipboard. If the "
"clipboard is empty, this command does nothing. The sample rate of the "
"inserted data is adjusted to match the sample rate of the current signal if "
"necessary. Only enabled tracks are affected, disabled tracks remain "
"unchanged. Please be aware that this might produce a time shift between "
"enabled and disabled tracks! If the number of tracks of the clipboard data "
"differs from the number of enabled tracks, then the data is mixed to be "
"spread equally over all selected tracks."
msgstr ""
"Заменяет выделение содержимым буфера обмена. Если буфер обмена пуст, команда "
"не выполняется. Частота дискретизации вставленных данных будет "
"скорректирована для того, чтобы соответствовать частоте дискретизации "
"текущего сигнала, если это необходимо. Процесс выполняется только для "
"включённых дорожек, остальные остаются без изменений. Обратите внимание, что "
"это может привести к временно́му сдвигу между включёнными и отключёнными "
"дорожками. Если количество дорожек данных буфера обмена отличается от "
"количества включённых дорожек, то данные будут микшированы для равномерного "
"распределения по всем выбранным дорожкам."

#. Tag: link
#: index.docbook:3196
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_copy;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_copy;</command>()"

#. Tag: title
#: index.docbook:3202
#, no-c-format
msgid "&no-i18n-cmd_pause;"
msgstr "&no-i18n-cmd_pause;"

#. Tag: para
#: index.docbook:3205
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Pause</guibutton> toolbar button and lets the "
"playback pause if it is currently running, or continue if it is currently "
"paused."
msgstr ""
"Соответствует кнопке <guibutton>Приостановить</guibutton> на панели "
"инструментов и позволяет приостановить воспроизведение, если оно в данный "
"момент выполняется, или продолжить, если оно в данный момент приостановлено."

#. Tag: link
#: index.docbook:3213
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_continue;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_continue;</command>()"

#. Tag: title
#: index.docbook:3219
#, no-c-format
msgid "&no-i18n-cmd_playback_start;"
msgstr "&no-i18n-cmd_playback_start;"

#. Tag: title
#: index.docbook:3221
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_playback_start;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_playback_start;</"
"command>()"

#. Tag: para
#: index.docbook:3222
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Start</guibutton> toolbar button and lets the "
"playback start if it is currently paused."
msgstr ""
"Соответствует кнопке <guibutton>Начать</guibutton> на панели инструментов и "
"позволяет начать воспроизведение, если оно в данный момент приостановлено."

#. Tag: title
#: index.docbook:3230
#, no-c-format
msgid "&no-i18n-cmd_plugin;"
msgstr "&no-i18n-cmd_plugin;"

#. Tag: title
#: index.docbook:3232
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_plugin;</command>(<replaceable>name</"
"replaceable>, [<replaceable>parameter</replaceable> ...])"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_plugin;</command>(<replaceable>имя</"
"replaceable>, [<replaceable>параметр</replaceable> ...])"

#. Tag: para
#: index.docbook:3233
#, no-c-format
msgid ""
"Executes a plugin, with an optional list of parameters. If no parameter list "
"is given, then the setup function of the plugin will be called, using the "
"parameters of the previous invocation or default parameters as input "
"(normally shows a setup dialog, depending on the plugin). Please refer to "
"the chapter about <link linkend=\"plugins\">plugins</link> for a description "
"of the various plugins."
msgstr ""
"Запускает модуль с необязательным списком параметров. Если список параметров "
"не задан, будет вызвана функция настройки модуля с использованием параметров "
"предыдущего вызова или параметров по умолчанию в качестве входных данных "
"(обычно показывает диалог настройки, в зависимости от модуля). Для "
"ознакомления с описанием различных модулей, обратитесь к главе о <link "
"linkend=\"plugins\">подключаемых модулях</link>."

#. Tag: entry
#: index.docbook:3244 index.docbook:3268 index.docbook:3290
#, no-c-format
msgid "<parameter>name</parameter>:"
msgstr "<parameter>имя</parameter>:"

#. Tag: entry
#: index.docbook:3245 index.docbook:3269 index.docbook:3291
#, no-c-format
msgid "the (internal) name of a &kwave; plugin"
msgstr "(внутреннее) имя модуля &kwave;"

#. Tag: entry
#: index.docbook:3246 index.docbook:3270 index.docbook:3292
#, no-c-format
msgid "<parameter>parameter</parameter>:"
msgstr "<parameter>параметр</parameter>:"

#. Tag: entry
#: index.docbook:3247 index.docbook:3293
#, no-c-format
msgid "a list of parameters understood by the plugin (optional)"
msgstr "список параметров, распознаваемых модулем (необязательно)"

#. Tag: para
#: index.docbook:3250
#, no-c-format
msgid ""
"<link linkend=\"cmd_sect_plugin_execute\"><command>&no-i18n-tag;&no-i18n-"
"cmd_plugin_execute;</command>()</link>, <link linkend=\"cmd_sect_plugin_setup"
"\"><command>&no-i18n-tag;&no-i18n-cmd_plugin_setup;</command>()</link>"
msgstr ""
"<link linkend=\"cmd_sect_plugin_execute\"><command>&no-i18n-tag;&no-i18n-"
"cmd_plugin_execute;</command>()</link>, <link linkend=\"cmd_sect_plugin_setup"
"\"><command>&no-i18n-tag;&no-i18n-cmd_plugin_setup;</command>()</link>"

#. Tag: title
#: index.docbook:3258
#, no-c-format
msgid "&no-i18n-cmd_plugin_execute;"
msgstr "&no-i18n-cmd_plugin_execute;"

#. Tag: title
#: index.docbook:3260
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_plugin_execute;</"
"command>(<replaceable>name</replaceable>, [<replaceable>parameter</"
"replaceable> ...])"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_plugin_execute;</"
"command>(<replaceable>имя</replaceable>, [<replaceable>параметр</"
"replaceable> ...])"

#. Tag: para
#: index.docbook:3261
#, no-c-format
msgid ""
"Similar to the command <command>&no-i18n-cmd_plugin;</command>(), but "
"without calling the setup function of the plugin if no parameters were "
"passed."
msgstr ""
"Аналогично команде <command>&no-i18n-cmd_plugin;</command>(), но без вызова "
"функции настройки модуля, если параметры не были определены."

#. Tag: entry
#: index.docbook:3271
#, no-c-format
msgid "a list of parameters understood by the plugin"
msgstr "список параметров, распознаваемых модулем"

#. Tag: title
#: index.docbook:3276
#, no-c-format
msgid "&no-i18n-cmd_plugin_setup;"
msgstr "&no-i18n-cmd_plugin_setup;"

#. Tag: title
#: index.docbook:3278
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_plugin_setup;</"
"command>(<replaceable>name</replaceable>, [<replaceable>parameter</"
"replaceable> ...])"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_plugin_setup;</"
"command>(<replaceable>имя</replaceable>, [<replaceable>параметр</"
"replaceable> ...])"

#. Tag: para
#: index.docbook:3279
#, no-c-format
msgid ""
"Calls the <emphasis>setup</emphasis> function of a plugin, with an optional "
"list of parameters. If no parameter list is given, the parameters of the "
"previous invocation or default parameters will be used as input. This "
"normally shows a setup dialog, depending on the plugin. Please refer to the "
"chapter about <link linkend=\"plugins\">plugins</link> for a description of "
"the various plugins."
msgstr ""
"Вызывает функцию <emphasis>настройки</emphasis> модуля с необязательным "
"списком параметров. Если список параметров не задан, в качестве входных "
"данных будут использоваться параметры предыдущего вызова или параметры по "
"умолчанию. Обычно отображается диалог настройки в зависимости от модуля. Для "
"ознакомления с описанием различных модулей, обратитесь к главе <link linkend="
"\"plugins\">подключаемых модулей</link>."

#. Tag: title
#: index.docbook:3298
#, no-c-format
msgid "&no-i18n-cmd_prev;"
msgstr "&no-i18n-cmd_prev;"

#. Tag: title
#: index.docbook:3300
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_prev;</command>()"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_prev;</command>()"

#. Tag: para
#: index.docbook:3301
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Previous</guibutton> toolbar button. If the "
"playback is currently running, it skips back to the previous label or start "
"of the selection. If the playback is not running, this does the same as the "
"command <command>&no-i18n-cmd_view_scroll_prev_label;</command>()."
msgstr ""
"Соответствует кнопке <guibutton>Предыдущий</guibutton> на панели "
"инструментов. Если воспроизведение в данный момент выполняется, оно "
"возвращается к предыдущей отметке или к началу выделения. Если "
"воспроизведение не запущено, происходит действие, аналогичное команде "
"<command>&no-i18n-cmd_view_scroll_prev_label;</command>()."

#. Tag: para
#: index.docbook:3310
#, no-c-format
msgid ""
"<link linkend=\"cmd_sect_view_scroll_next_label\"><command>&no-i18n-tag;&no-"
"i18n-cmd_view_scroll_prev_label;</command>()</link>, <link linkend="
"\"cmd_sect_next\"><command>&no-i18n-tag;&no-i18n-cmd_next;</command>()</link>"
msgstr ""
"<link linkend=\"cmd_sect_view_scroll_next_label\"><command>&no-i18n-tag;&no-"
"i18n-cmd_view_scroll_prev_label;</command>()</link>, <link linkend="
"\"cmd_sect_next\"><command>&no-i18n-tag;&no-i18n-cmd_next;</command>()</link>"

#. Tag: title
#: index.docbook:3318
#, no-c-format
msgid "&no-i18n-tag;q"
msgstr "&no-i18n-tag;q"

#. Tag: title
#: index.docbook:3321
#, no-c-format
msgid "&no-i18n-cmd_quit;"
msgstr "&no-i18n-cmd_quit;"

#. Tag: title
#: index.docbook:3323
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_quit;</command>()"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_quit;</command>()"

#. Tag: para
#: index.docbook:3324
#, no-c-format
msgid ""
"Closes the current main window, including all sub-windows. In SDI mode this "
"is the same as the command <command>&no-i18n-cmd_close;</command>()."
msgstr ""
"Закрывает текущее главное окно и все вложенные окна. В режиме SDI действует "
"так же, как и команда <command>&no-i18n-cmd_close;</command>()."

#. Tag: title
#: index.docbook:3338
#, no-c-format
msgid "&no-i18n-tag;r"
msgstr "&no-i18n-tag;r"

#. Tag: title
#: index.docbook:3341
#, no-c-format
msgid "&no-i18n-cmd_redo;"
msgstr "&no-i18n-cmd_redo;"

#. Tag: title
#: index.docbook:3343
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_redo;</command>()"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_redo;</command>()"

#. Tag: para
#: index.docbook:3344
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Redo</guibutton> toolbar button and repeats "
"one operation that has been reverted with <command>&no-i18n-cmd_undo;</"
"command>()."
msgstr ""
"Соответствует кнопке <guibutton>Повторить</guibutton> на панели инструментов "
"и повторяет последнюю операцию, отменённую командой <command>&no-i18n-"
"cmd_undo;</command>()."

#. Tag: link
#: index.docbook:3352 index.docbook:3368 index.docbook:3826
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_undo;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_undo;</command>()"

#. Tag: title
#: index.docbook:3358
#, no-c-format
msgid "&no-i18n-cmd_redo_all;"
msgstr "&no-i18n-cmd_redo_all;"

#. Tag: title
#: index.docbook:3360
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_redo_all;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_redo_all;</command>()"

#. Tag: para
#: index.docbook:3361
#, no-c-format
msgid ""
"Similar to <command>&no-i18n-cmd_redo;</command>(), but re-does as many "
"operations as possible."
msgstr ""
"Аналогично команде <command>&no-i18n-cmd_redo;</command>(), но отменяет "
"столько операций, сколько возможно."

#. Tag: title
#: index.docbook:3374
#, no-c-format
msgid "&no-i18n-cmd_reenable_dna;"
msgstr "&no-i18n-cmd_reenable_dna;"

#. Tag: title
#: index.docbook:3376
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_reenable_dna;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_reenable_dna;</command>()"

#. Tag: para
#: index.docbook:3377
#, no-c-format
msgid ""
"Some message boxes offer the possibility to prevent them from appearing "
"again (<quote>do not ask again</quote>). This command makes all of them "
"appear again."
msgstr ""
"В некоторых окнах сообщений предусмотрена функция отключения повторного "
"появления («Не задавать больше этот вопрос»). Эта команда снова включает "
"повторное появление таких окон."

#. Tag: title
#: index.docbook:3386
#, no-c-format
msgid "&no-i18n-cmd_reset_toolbars;"
msgstr "&no-i18n-cmd_reset_toolbars;"

#. Tag: title
#: index.docbook:3388
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_reset_toolbars;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_reset_toolbars;</"
"command>()"

#. Tag: para
#: index.docbook:3389
#, no-c-format
msgid ""
"Resets all toolbar settings, like location, icon size and text location back "
"to defaults."
msgstr ""
"Сбрасывает на значения по умолчанию все параметры панели инструментов, такие "
"как расположение, размер иконок и расположение текста."

#. Tag: title
#: index.docbook:3397
#, no-c-format
msgid "&no-i18n-cmd_revert;"
msgstr "&no-i18n-cmd_revert;"

#. Tag: title
#: index.docbook:3399
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_revert;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_revert;</command>()"

#. Tag: para
#: index.docbook:3400
#, no-c-format
msgid ""
"Reverts the currently loaded file back to the last saved state, discarding "
"all changes that are not saved."
msgstr ""
"Возвращает текущий загруженный файл в последнее сохранённое состояние, "
"отменяя все несохранённые изменения."

#. Tag: title
#: index.docbook:3408
#, no-c-format
msgid "&no-i18n-cmd_rewind;"
msgstr "&no-i18n-cmd_rewind;"

#. Tag: title
#: index.docbook:3410
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_rewind;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_rewind;</command>()"

#. Tag: para
#: index.docbook:3411
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Rewind</guibutton> toolbar button. If the "
"playback is currently running, it skips backward by 1/10 of the visible "
"range. If the playback is not running, this does the same as the command "
"<command>&no-i18n-cmd_view_scroll_left;</command>()."
msgstr ""
"Соответствует кнопке <guibutton>Назад</guibutton> на панели инструментов. "
"Если воспроизведение в данный момент выполняется, оно возвращается назад на "
"1/10 видимого диапазона. Если воспроизведение не выполняется, то "
"производится то же самое действие, что и при команде <command>&no-i18n-"
"cmd_view_scroll_left;</command>()."

#. Tag: para
#: index.docbook:3420
#, no-c-format
msgid ""
"<link linkend=\"cmd_sect_view_scroll_left\"><command>&no-i18n-tag;&no-i18n-"
"cmd_view_scroll_left;</command>()</link>, <link linkend=\"cmd_sect_forward"
"\"><command>&no-i18n-tag;&no-i18n-cmd_forward;</command>()</link>"
msgstr ""
"<link linkend=\"cmd_sect_view_scroll_left\"><command>&no-i18n-tag;&no-i18n-"
"cmd_view_scroll_left;</command>()</link>, <link linkend=\"cmd_sect_forward"
"\"><command>&no-i18n-tag;&no-i18n-cmd_forward;</command>()</link>"

#. Tag: title
#: index.docbook:3428
#, no-c-format
msgid "&no-i18n-tag;s"
msgstr "&no-i18n-tag;s"

#. Tag: title
#: index.docbook:3431
#, no-c-format
msgid "&no-i18n-cmd_save;"
msgstr "&no-i18n-cmd_save;"

#. Tag: title
#: index.docbook:3433
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_save;</command>()"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_save;</command>()"

#. Tag: para
#: index.docbook:3434
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Save</guibutton> toolbar button. Saves the "
"current file if it has modifications. If the file does not already have a "
"name (&eg; a file that has just been created and does not yet have a file "
"name), this command does the same as <command>&no-i18n-cmd_saveas;</"
"command>()."
msgstr ""
"Соответствует кнопке <guibutton>Сохранить</guibutton> на панели "
"инструментов. Сохраняет текущий файл, если в нём имеются изменения. Если "
"файлу ещё не было присвоено имя (например, файл, который только что был "
"создан и не имеет названия), эта команда выполняется по такому же принципу, "
"как и команда <command>&no-i18n-cmd_saveas;</command>()."

#. Tag: link
#: index.docbook:3444
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_saveas;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_saveas;</command>()"

#. Tag: title
#: index.docbook:3450
#, no-c-format
msgid "&no-i18n-cmd_saveas;"
msgstr "&no-i18n-cmd_saveas;"

#. Tag: title
#: index.docbook:3452
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_saveas;</"
"command>([<replaceable>filename</replaceable>])"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_saveas;</"
"command>([<replaceable>имя_файла</replaceable>])"

#. Tag: para
#: index.docbook:3453
#, no-c-format
msgid ""
"Saves the currently opened file under a given file name. If no file name is "
"given as parameter, a dialog will be shown to select the directory and to "
"enter a file name."
msgstr ""
"Сохраняет текущий открытый файл под заданным именем. Если в качестве "
"параметра не указано имя файла, появится диалоговое окно для выбора каталога "
"и ввода имени файла."

#. Tag: entry
#: index.docbook:3461
#, no-c-format
msgid "file name for saving (optional)"
msgstr "имя файла для сохранения (необязательно)"

#. Tag: title
#: index.docbook:3466
#, no-c-format
msgid "&no-i18n-cmd_saveselect;"
msgstr "&no-i18n-cmd_saveselect;"

#. Tag: title
#: index.docbook:3468
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_saveselect;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_saveselect;</command>()"

#. Tag: para
#: index.docbook:3469
#, no-c-format
msgid ""
"This command does the same as <command>&no-i18n-cmd_save;</command>(), but "
"saves only the currently selected range and the activated tracks instead of "
"the whole file."
msgstr ""
"Соответствует команде <command>&no-i18n-cmd_save;</command>(), но вместо "
"всего файла сохраняет только текущий выбранный диапазон и активные дорожки."

#. Tag: link
#: index.docbook:3477
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_save;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_save;</command>()"

#. Tag: title
#: index.docbook:3483
#, no-c-format
msgid "&no-i18n-cmd_select_gui_type;"
msgstr "&no-i18n-cmd_select_gui_type;"

#. Tag: title
#: index.docbook:3485
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_select_gui_type;</"
"command>(<replaceable>mode</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_select_gui_type;</"
"command>(<replaceable>режим</replaceable>)"

#. Tag: para
#: index.docbook:3486
#, no-c-format
msgid ""
"Select a &GUI; mode, which can be either SDI, MDI or Tab mode. Please be "
"aware that this change will immediately take effect!"
msgstr ""
"Позволяет выбрать один из трёх режимов графического интерфейса пользователя: "
"SDI, MDI или режим вкладок. Обратите внимание, что это изменение сразу же "
"вступит в силу."

#. Tag: entry
#: index.docbook:3494
#, no-c-format
msgid ""
"name of the mode, must be either <quote>SDI</quote>, <quote>MDI</quote> or "
"<quote>TAB</quote>."
msgstr "имя режима, доступны три варианта: «SDI», «MDI» или «во вкладках»."

#. Tag: title
#: index.docbook:3502
#, no-c-format
msgid "&no-i18n-cmd_select_track_all;"
msgstr "&no-i18n-cmd_select_track_all;"

#. Tag: title
#: index.docbook:3504 index.docbook:3521
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_select_track_all;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_select_track_all;</"
"command>()"

#. Tag: para
#: index.docbook:3505
#, no-c-format
msgid ""
"Mark all tracks <quote>enabled</quote>. This is the same as calling the "
"command <command>&no-i18n-tag;&no-i18n-cmd_select_track_on;</command>() for "
"all existing tracks."
msgstr ""
"Отмечает все дорожки как «включённые». Это аналогично команде <command>&no-"
"i18n-tag;&no-i18n-cmd_select_track_on;</command>() для всех существующих "
"дорожек."

#. Tag: link
#: index.docbook:3513
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_select_track_on;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_select_track_on;</command>()"

#. Tag: title
#: index.docbook:3519
#, no-c-format
msgid "&no-i18n-cmd_select_track_invert;"
msgstr "&no-i18n-cmd_select_track_invert;"

#. Tag: para
#: index.docbook:3522
#, no-c-format
msgid ""
"Invert the <quote>enabled</quote> state of all tracks. This is the same as "
"calling the command <command>&no-i18n-cmd_select_track_toggle;</command>() "
"for all existing tracks."
msgstr ""
"Инвертирует состояние всех дорожек, отмеченных как «включённые». Это "
"аналогично команде <command>&no-i18n-cmd_select_track_toggle;</command>() "
"для всех существующих дорожек."

#. Tag: link
#: index.docbook:3531
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_select_track_toggle;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_select_track_toggle;</command>()"

#. Tag: title
#: index.docbook:3537
#, no-c-format
msgid "&no-i18n-cmd_select_track_none;"
msgstr "&no-i18n-cmd_select_track_none;"

#. Tag: title
#: index.docbook:3539
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_select_track_none;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_select_track_none;</"
"command>()"

#. Tag: para
#: index.docbook:3540
#, no-c-format
msgid ""
"Mark all tracks <quote>disabled</quote>. This is the same as calling the "
"command <command>&no-i18n-cmd_select_track_off;</command>() for all existing "
"tracks."
msgstr ""
"Отмечает все дорожки как «отключённые». Это аналогично команде <command>&no-"
"i18n-cmd_select_track_off;</command>() для всех существующих дорожек."

#. Tag: link
#: index.docbook:3548
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_select_track_off;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_select_track_off;</command>()"

#. Tag: title
#: index.docbook:3554
#, no-c-format
msgid "&no-i18n-cmd_select_track_off;"
msgstr "&no-i18n-cmd_select_track_off;"

#. Tag: title
#: index.docbook:3556
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_select_track_off;</"
"command>(<replaceable>index</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_select_track_off;</"
"command>(<replaceable>индекс</replaceable>)"

#. Tag: para
#: index.docbook:3557
#, no-c-format
msgid ""
"Disables a single track, so that it does not get affected by most operations."
msgstr "Отключает одну дорожку, чтобы на неё не повлияло большинство операций."

#. Tag: entry
#: index.docbook:3564 index.docbook:3578 index.docbook:3593
#, no-c-format
msgid "index of the track, starting with zero"
msgstr "индекс дорожки, начинающийся с нуля"

#. Tag: title
#: index.docbook:3569
#, no-c-format
msgid "&no-i18n-cmd_select_track_on;"
msgstr "&no-i18n-cmd_select_track_on;"

#. Tag: title
#: index.docbook:3571
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_select_track_on;</"
"command>(<replaceable>index</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_select_track_on;</"
"command>(<replaceable>индекс</replaceable>)"

#. Tag: para
#: index.docbook:3572
#, no-c-format
msgid "Enables a single track, so that it gets affected by all operations."
msgstr "Включает одну дорожку, чтобы на неё повлияли все операции."

#. Tag: title
#: index.docbook:3583
#, no-c-format
msgid "&no-i18n-cmd_select_track_toggle;"
msgstr "&no-i18n-cmd_select_track_toggle;"

#. Tag: title
#: index.docbook:3585
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_select_track_toggle;</"
"command>(<replaceable>index</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_select_track_toggle;</"
"command>(<replaceable>индекс</replaceable>)"

#. Tag: para
#: index.docbook:3586
#, no-c-format
msgid ""
"Enables a track if it is currently disabled, or disables it if it is "
"currently enabled."
msgstr ""
"Включает дорожку, если она в данный момент отключена, либо выключает "
"дорожку, если она в данный момент включена."

#. Tag: title
#: index.docbook:3598
#, no-c-format
msgid "&no-i18n-cmd_selectall;"
msgstr "&no-i18n-cmd_selectall;"

#. Tag: title
#: index.docbook:3600
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectall;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectall;</command>()"

#. Tag: para
#: index.docbook:3601
#, no-c-format
msgid ""
"Selects the range of the whole signal, from the first to the last sample."
msgstr "Выделяет диапазон всего сигнала, от первого до последнего сэмпла."

#. Tag: title
#: index.docbook:3609
#, no-c-format
msgid "&no-i18n-cmd_selectnext;"
msgstr "&no-i18n-cmd_selectnext;"

#. Tag: title
#: index.docbook:3611
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectnext;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectnext;</command>()"

#. Tag: para
#: index.docbook:3612
#, no-c-format
msgid ""
"Selects a range of samples that starts right after the current selection, "
"using the same length as the current selection. The selection is "
"automatically clipped to the end of the signal. For example: if you have "
"selected samples 1000 ... 1019, then the result will be a selection from "
"sample 1020 ... 1039."
msgstr ""
"Выделяет диапазон сэмплов, которые начинаются сразу после текущего "
"выделения, при этом используется длительность, соответствующая этому "
"выделению. Выбор автоматически обрезается к концу сигнала. Например: если "
"были выделены сэмплы от 1000 до 1019, то результатом будет выделение сэмплов "
"от 1020 до 1039."

#. Tag: link
#: index.docbook:3622
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_selectprev;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_selectprev;</command>()"

#. Tag: title
#: index.docbook:3628
#, no-c-format
msgid "&no-i18n-cmd_selectnextlabels;"
msgstr "&no-i18n-cmd_selectnextlabels;"

#. Tag: title
#: index.docbook:3630
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectnextlabels;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectnextlabels;</"
"command>()"

#. Tag: para
#: index.docbook:3631
#, no-c-format
msgid ""
"Selects a range of samples between the next two labels after the current "
"selection. If nothing is selected, it selects from the start of the signal "
"up to the first label. Otherwise the left border of the new selection will "
"be the position of first label after the selection (or the last label if "
"there are no more labels right from the selection), and the right border of "
"the new selection will be the first label after the left border of the new "
"selection (or the end of the signal if there is none). This command returns "
"an error when there are no labels at all."
msgstr ""
"Выделяет диапазон сэмплов между двумя отметками после текущего выделения. "
"Если ничего не выбрано, происходит выделение от начала сигнала до первой "
"отметки. Если же выделен какой-нибудь фрагмент, левая граница нового "
"выделения будет расположена на позиции первой отметки после выделения (или "
"последней отметки, если справа от выделения нет других отметок), а правая "
"граница нового выделения будет расположена на позиции первой отметки после "
"левой границы нового выделения (или на конце сигнала, если её нет). Если "
"отметок нет, команда выдаёт ошибку."

#. Tag: link
#: index.docbook:3645
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_selectprevlabels;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_selectprevlabels;</command>()"

#. Tag: title
#: index.docbook:3651
#, no-c-format
msgid "&no-i18n-cmd_selectnone;"
msgstr "&no-i18n-cmd_selectnone;"

#. Tag: title
#: index.docbook:3653
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectnone;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectnone;</command>()"

#. Tag: para
#: index.docbook:3654
#, no-c-format
msgid "Resets the selection to zero length."
msgstr "Сбрасывает выделение до нулевой длительности."

#. Tag: title
#: index.docbook:3661
#, no-c-format
msgid "&no-i18n-cmd_selectprev;"
msgstr "&no-i18n-cmd_selectprev;"

#. Tag: title
#: index.docbook:3663
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectprev;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectprev;</command>()"

#. Tag: para
#: index.docbook:3664
#, no-c-format
msgid ""
"Selects a range of samples that starts left from the current selection, "
"using the same length as the current selection. The selection is "
"automatically clipped to the start of the signal. For example: if you have "
"selected samples 1000 ... 1019, then the result will be a selection from "
"sample 980 ... 999."
msgstr ""
"Выделяет диапазон сэмплов, который начинается сразу перед текущим "
"выделением, при этом используется длительность, соответствующая этому "
"выделению. Выбор автоматически обрезается к началу сигнала. Например: если "
"были выделены сэмплы от 1000 до 1019, то результатом будет выделение сэмплов "
"от 980 до 999."

#. Tag: link
#: index.docbook:3674
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_selectnext;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_selectnext;</command>()"

#. Tag: title
#: index.docbook:3680
#, no-c-format
msgid "&no-i18n-cmd_selectprevlabels;"
msgstr "&no-i18n-cmd_selectprevlabels;"

#. Tag: title
#: index.docbook:3682
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectprevlabels;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectprevlabels;</"
"command>()"

#. Tag: para
#: index.docbook:3683
#, no-c-format
msgid ""
"Selects a range of samples between the previous two labels before the "
"current selection. If nothing is selected, it selects from the start of the "
"signal up to the first label. Otherwise the right border of the new "
"selection will be the position of first label before the selection (or the "
"first label if there are no more labels left from the selection), and the "
"left border of the new selection will be the first label before the right "
"border of the new selection (or the start of the signal if there is none). "
"This command returns an error when there are no labels at all."
msgstr ""
"Выделяет диапазон сэмплов между предыдущими двумя отметками перед текущим "
"выделением. Если ничего не выбрано, происходит выделение от начала сигнала "
"до первой отметки. Если же выделен какой-нибудь фрагмент, правая граница "
"нового выделения будет расположена на позиции первой отметки относительно "
"начала выделения (или первой отметки, если слева от выделения нет других "
"отметок), а левая граница нового выделения будет расположена на позиции "
"первой отметки после правой границы нового выделения (или в начале сигнала, "
"если её нет). Если отметок нет, команда выдаёт ошибку."

#. Tag: link
#: index.docbook:3697
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_selectnextlabels;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_selectnextlabels;</command>()"

#. Tag: title
#: index.docbook:3703
#, no-c-format
msgid "&no-i18n-cmd_selecttoleft;"
msgstr "&no-i18n-cmd_selecttoleft;"

#. Tag: title
#: index.docbook:3705
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selecttoleft;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selecttoleft;</command>()"

#. Tag: para
#: index.docbook:3706
#, no-c-format
msgid ""
"Sets the start of the selection to the start of the signal, the end of the "
"current selection stays unchanged."
msgstr ""
"Устанавливает начало выделения на начало сигнала, при этом конец текущего "
"выделения остаётся неизменным."

#. Tag: link
#: index.docbook:3713
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_selecttoright;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_selecttoright;</command>()"

#. Tag: title
#: index.docbook:3719
#, no-c-format
msgid "&no-i18n-cmd_selecttoright;"
msgstr "&no-i18n-cmd_selecttoright;"

#. Tag: title
#: index.docbook:3721
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selecttoright;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selecttoright;</"
"command>()"

#. Tag: para
#: index.docbook:3722
#, no-c-format
msgid ""
"Sets the end of the selection to the end of the signal, the start of the "
"current selection stays unchanged."
msgstr ""
"Устанавливает конец выделения на конец сигнала, при этом начало текущего "
"выделения остаётся неизменным."

#. Tag: link
#: index.docbook:3729
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_selecttoleft;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_selecttoleft;</command>()"

#. Tag: title
#: index.docbook:3735
#, no-c-format
msgid "&no-i18n-cmd_selectvisible;"
msgstr "&no-i18n-cmd_selectvisible;"

#. Tag: title
#: index.docbook:3737
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectvisible;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectvisible;</"
"command>()"

#. Tag: para
#: index.docbook:3738
#, no-c-format
msgid "Selects the range of samples that is visible in the current window."
msgstr "Выбор диапазона сэмплов, отображающихся в текущем окне."

#. Tag: title
#: index.docbook:3746
#, no-c-format
msgid "&no-i18n-cmd_start;"
msgstr "&no-i18n-cmd_start;"

#. Tag: title
#: index.docbook:3748
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_start;</command>()"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_start;</command>()"

#. Tag: para
#: index.docbook:3749
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Start</guibutton> toolbar button and lets the "
"playback start from the beginning of the selection or continue if it is "
"currently paused."
msgstr ""
"Соответствует кнопке <guibutton>Воспроизведение</guibutton> на панели "
"инструментов и начинает воспроизведение с начала выделения или продолжает "
"воспроизведение с места, где оно было приостановлено."

#. Tag: link
#: index.docbook:3757
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_stop;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_stop;</command>()"

#. Tag: title
#: index.docbook:3763
#, no-c-format
msgid "&no-i18n-cmd_stop;"
msgstr "&no-i18n-cmd_stop;"

#. Tag: title
#: index.docbook:3765
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_stop;</command>()"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_stop;</command>()"

#. Tag: para
#: index.docbook:3766
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Stop</guibutton> toolbar button and lets the "
"playback stop if it is currently running."
msgstr ""
"Соответствует кнопке <guibutton>Остановить</guibutton> на панели "
"инструментов и останавливает воспроизведение, если оно в данный момент идёт."

#. Tag: link
#: index.docbook:3773
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_start;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_start;</command>()"

#. Tag: title
#: index.docbook:3779
#, no-c-format
msgid "&no-i18n-cmd_sync;"
msgstr "&no-i18n-cmd_sync;"

#. Tag: title
#: index.docbook:3781
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_sync;</command>()"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_sync;</command>()"

#. Tag: para
#: index.docbook:3782
#, no-c-format
msgid ""
"Waits until all commands which have been started asynchronously have "
"finished. If nothing is currently queued for delayed execution this command "
"has no effect."
msgstr ""
"Ожидает завершения всех команд, запущенных асинхронно. Если в очереди команд "
"нет команд для отложенного выполнения, эта команда не будет выполняться."

#. Tag: link
#: index.docbook:3790
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_delayed;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_delayed;</command>()"

#. Tag: title
#: index.docbook:3797
#, no-c-format
msgid "&no-i18n-tag;u"
msgstr "&no-i18n-tag;u"

#. Tag: title
#: index.docbook:3800
#, no-c-format
msgid "&no-i18n-cmd_undo;"
msgstr "&no-i18n-cmd_undo;"

#. Tag: title
#: index.docbook:3802
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_undo;</command>()"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_undo;</command>()"

#. Tag: para
#: index.docbook:3803
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Undo</guibutton> toolbar button and reverts "
"the last operation."
msgstr ""
"Соответствует кнопке <guibutton>Отменить</guibutton> на панели инструментов "
"и отменяет последнюю операцию."

#. Tag: link
#: index.docbook:3810
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_redo;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_redo;</command>()"

#. Tag: title
#: index.docbook:3816
#, no-c-format
msgid "&no-i18n-cmd_undo_all;"
msgstr "&no-i18n-cmd_undo_all;"

#. Tag: title
#: index.docbook:3818
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_undo_all;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_undo_all;</command>()"

#. Tag: para
#: index.docbook:3819
#, no-c-format
msgid ""
"Similar to <command>&no-i18n-tag;&no-i18n-cmd_undo;</command>(), but reverts "
"as many operations as possible."
msgstr ""
"Соответствует команде <command>&no-i18n-tag;&no-i18n-cmd_undo;</command>(), "
"но отменяет столько операций, сколько возможно."

#. Tag: title
#: index.docbook:3832
#, no-c-format
msgid "&no-i18n-tag;v"
msgstr "&no-i18n-tag;v"

#. Tag: title
#: index.docbook:3835
#, no-c-format
msgid "&no-i18n-cmd_view_scroll_end;"
msgstr "&no-i18n-cmd_view_scroll_end;"

#. Tag: title
#: index.docbook:3837
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_end;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_end;</"
"command>()"

#. Tag: para
#: index.docbook:3838
#, no-c-format
msgid "Scrolls the current view to the <emphasis>end</emphasis> of the signal."
msgstr ""
"Прокручивает текущую область просмотра до <emphasis>конца</emphasis> сигнала."

#. Tag: link
#: index.docbook:3842
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_start;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_start;</command>()"

#. Tag: title
#: index.docbook:3848
#, no-c-format
msgid "&no-i18n-cmd_view_scroll_left;"
msgstr "&no-i18n-cmd_view_scroll_left;"

#. Tag: title
#: index.docbook:3850
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_left;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_left;</"
"command>()"

#. Tag: para
#: index.docbook:3851
#, no-c-format
msgid ""
"Scrolls the current view by 1/10 of the currently visible range towards the "
"start of the signal. If the start of the signal is reached the visible area "
"starts at offset zero."
msgstr ""
"Прокручивает текущую область просмотра на 1/10 от текущего видимого "
"диапазона к началу сигнала. При достижении начала сигнала видимая область "
"будет начинаться с нулевым отступом."

#. Tag: link
#: index.docbook:3859
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_right;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_right;</command>()"

#. Tag: title
#: index.docbook:3865
#, no-c-format
msgid "&no-i18n-cmd_view_scroll_next;"
msgstr "&no-i18n-cmd_view_scroll_next;"

#. Tag: title
#: index.docbook:3867
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_next;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_next;</"
"command>()"

#. Tag: para
#: index.docbook:3868
#, no-c-format
msgid ""
"Scrolls the current view towards the end of the signal by the currently "
"visible range."
msgstr ""
"Прокручивает текущую область просмотра к концу сигнала в текущем видимом "
"диапазоне."

#. Tag: link
#: index.docbook:3875
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_prev;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_prev;</command>()"

#. Tag: title
#: index.docbook:3881
#, no-c-format
msgid "&no-i18n-cmd_view_scroll_next_label;"
msgstr "&no-i18n-cmd_view_scroll_next_label;"

#. Tag: title
#: index.docbook:3883
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_next_label;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_next_label;</"
"command>()"

#. Tag: para
#: index.docbook:3884
#, no-c-format
msgid ""
"Scrolls right and tries to show the next label centered in the view. If "
"there was no label right from the current position, it will scroll to the "
"end of the signal."
msgstr ""
"Прокручивает вправо и показывает следующую отметку, находящуюся в области "
"просмотра. Если справа от текущей позиции нет отметки, то прокручивать будет "
"до конца сигнала."

#. Tag: link
#: index.docbook:3892
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_prev_label;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_prev_label;</command>()"

#. Tag: title
#: index.docbook:3898
#, no-c-format
msgid "&no-i18n-cmd_view_scroll_prev;"
msgstr "&no-i18n-cmd_view_scroll_prev;"

#. Tag: title
#: index.docbook:3900
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_prev;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_prev;</"
"command>()"

#. Tag: para
#: index.docbook:3901
#, no-c-format
msgid ""
"Scrolls the current view towards the start of the signal by the currently "
"visible range."
msgstr ""
"Прокручивает текущую область просмотра по направлению к началу сигнала в "
"текущем видимом диапазоне"

#. Tag: link
#: index.docbook:3908
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_next;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_next;</command>()"

#. Tag: title
#: index.docbook:3914
#, no-c-format
msgid "&no-i18n-cmd_view_scroll_prev_label;"
msgstr "&no-i18n-cmd_view_scroll_prev_label;"

#. Tag: title
#: index.docbook:3916
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_prev_label;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_prev_label;</"
"command>()"

#. Tag: para
#: index.docbook:3917
#, no-c-format
msgid ""
"Scrolls left and tries to show the previous label centered in the view. If "
"there was no label left from the current position, it will scroll to the "
"start of the signal."
msgstr ""
"Прокручивает влево и показывает следующую отметку, находящуюся в области "
"просмотра. Если слева от текущей позиции нет отметки, то прокручивать будет "
"до начала сигнала."

#. Tag: link
#: index.docbook:3925
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_next_label;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_next_label;</command>()"

#. Tag: title
#: index.docbook:3931
#, no-c-format
msgid "&no-i18n-cmd_view_scroll_right;"
msgstr "&no-i18n-cmd_view_scroll_right;"

#. Tag: title
#: index.docbook:3933
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_right;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_right;</"
"command>()"

#. Tag: para
#: index.docbook:3934
#, no-c-format
msgid ""
"Scrolls the current view by 1/10 of the currently visible range towards the "
"end of the signal. If the end of the signal is reached the visible area ends "
"at the end of the signal."
msgstr ""
"Прокручивает текущую область просмотра на 1/10 от текущего видимого "
"диапазона к концу сигнала. При достижении конца сигнала видимая область "
"заканчивается."

#. Tag: link
#: index.docbook:3942
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_left;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_left;</command>()"

#. Tag: title
#: index.docbook:3948
#, no-c-format
msgid "&no-i18n-cmd_view_scroll_start;"
msgstr "&no-i18n-cmd_view_scroll_start;"

#. Tag: title
#: index.docbook:3950
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_start;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_start;</"
"command>()"

#. Tag: para
#: index.docbook:3951
#, no-c-format
msgid "Scrolls the current view to the start of the signal."
msgstr "Прокручивает текущую область просмотра к началу сигнала."

#. Tag: link
#: index.docbook:3955
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_end;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_end;</command>()"

#. Tag: title
#: index.docbook:3961
#, no-c-format
msgid "&no-i18n-cmd_view_zoom_all;"
msgstr "&no-i18n-cmd_view_zoom_all;"

#. Tag: title
#: index.docbook:3963
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_zoom_all;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_zoom_all;</"
"command>()"

#. Tag: para
#: index.docbook:3964
#, no-c-format
msgid ""
"Adjusts the zoom factor so that the complete signal is visible in the "
"current view."
msgstr ""
"Регулирует масштаб таким образом, чтобы весь сигнал был виден в текущей "
"области просмотра."

#. Tag: title
#: index.docbook:3972
#, no-c-format
msgid "&no-i18n-cmd_view_zoom_in;"
msgstr "&no-i18n-cmd_view_zoom_in;"

#. Tag: title
#: index.docbook:3974
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_view_zoom_in;</"
"command>([<replaceable>position</replaceable>])"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_view_zoom_in;</"
"command>([<replaceable>позиция</replaceable>])"

#. Tag: para
#: index.docbook:3975
#, no-c-format
msgid ""
"Reduces the zoom factor (in samples per pixel) by 30%, so that more details "
"get visible. If a <replaceable>position</replaceable> is given, it tries to "
"show that position centered in the current view, otherwise the center of the "
"view before the zoom change is used for centering. The minimum zoom factor "
"is limited to a minimum of five samples per width of the view."
msgstr ""
"Увеличивает масштаб (в сэмплах на пиксел) на 30%, чтобы обеспечить более "
"детальный просмотр. Если указан параметр <replaceable>позиция</replaceable>, "
"приложение старается сделать так, чтобы указанное положение было расположено "
"в центре панели просмотра после масштабирования. Если позиция не указана, "
"центр панели будет находиться в центре текущей области просмотра. "
"Максимальный масштаб ограничен наибольшим значением в пять сэмплов на ширину "
"области просмотра."

#. Tag: entry
#: index.docbook:3987 index.docbook:4024
#, no-c-format
msgid "<parameter>position</parameter>:"
msgstr "<parameter>позиция</parameter>:"

#. Tag: entry
#: index.docbook:3988
#, no-c-format
msgid "a zero based position in samples to center the view (optional)"
msgstr ""
"позиция в сэмплах для центрирования просмотра (начинается с нуля, "
"необязательно)"

#. Tag: link
#: index.docbook:3992
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_view_zoom_out;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_view_zoom_out;</command>()"

#. Tag: title
#: index.docbook:3998
#, no-c-format
msgid "&no-i18n-cmd_view_zoom_normal;"
msgstr "&no-i18n-cmd_view_zoom_normal;"

#. Tag: title
#: index.docbook:4000
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_zoom_normal;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_zoom_normal;</"
"command>()"

#. Tag: para
#: index.docbook:4001
#, no-c-format
msgid ""
"Sets the zoom factor to one pixel per sample (factor 1.0) and tries to keep "
"the previous center of the view."
msgstr ""
"Устанавливает масштаб в один пиксел на сэмпл (масштаб 1,0) и сохраняет "
"предыдущий центр области просмотра."

#. Tag: title
#: index.docbook:4009
#, no-c-format
msgid "&no-i18n-cmd_view_zoom_out;"
msgstr "&no-i18n-cmd_view_zoom_out;"

#. Tag: title
#: index.docbook:4011
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_view_zoom_out;"
"([<replaceable>position</replaceable>])</command>"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_view_zoom_out;([<replaceable>позиция</"
"replaceable>])</command>"

#. Tag: para
#: index.docbook:4012
#, no-c-format
msgid ""
"Increases the zoom factor (in samples per pixel) by 30%, so that less "
"details get visible. If a <replaceable>position</replaceable> is given, it "
"tries to show that position centered in the current view, otherwise the "
"center of the view before the zoom change is used for centering. The maximum "
"zoom factor is limited to the number of samples of the complete signal and "
"the width of the view."
msgstr ""
"Уменьшает масштаб (в сэмплах на пиксел) на 30%, чтобы обеспечить общий "
"просмотр. Если указан параметр <replaceable>позиция</replaceable>, "
"приложение старается сделать так, чтобы указанное положение было расположено "
"в центре панели просмотра после масштабирования. Если позиция не указана, "
"центр панели будет находиться в центре текущей области просмотра. "
"Максимальный масштаб ограничен количеством сэмплов в сигнале и шириной "
"области просмотра."

#. Tag: entry
#: index.docbook:4025
#, no-c-format
msgid "a zero based position is samples to center the view (optional)"
msgstr ""
"позиция в сэмплах для центрирования просмотра (начинается с нуля, "
"необязательно)"

#. Tag: link
#: index.docbook:4029
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_view_zoom_in;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_view_zoom_in;</command>()"

#. Tag: title
#: index.docbook:4035
#, no-c-format
msgid "&no-i18n-cmd_view_zoom_selection;"
msgstr "&no-i18n-cmd_view_zoom_selection;"

#. Tag: title
#: index.docbook:4037
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_zoom_selection;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_zoom_selection;</"
"command>()"

#. Tag: para
#: index.docbook:4038
#, no-c-format
msgid ""
"Adjusts the view (zoom factor and start of visible area) so that it matches "
"the current selection. This command does nothing if the selection is empty."
msgstr ""
"Корректирует область просмотра (масштаб и начало видимой области) так, чтобы "
"она соответствовала текущему выделению. Команда не выполняется, если ничего "
"не выделено."

#. Tag: title
#: index.docbook:4047
#, no-c-format
msgid "&no-i18n-tag;w"
msgstr "&no-i18n-tag;w"

#. Tag: title
#: index.docbook:4050
#, no-c-format
msgid "&no-i18n-cmd_window_activate;"
msgstr "&no-i18n-cmd_window_activate;"

#. Tag: title
#: index.docbook:4052
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_activate;</"
"command>(<replaceable>title</replaceable>])"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_activate;</"
"command>(<replaceable>заголовок</replaceable>])"

#. Tag: para
#: index.docbook:4053
#, no-c-format
msgid ""
"Activates a sub-window, identified by its window <replaceable>title</"
"replaceable>. If the sub-window is minimized it will be restored. Only "
"available if in MDI and Tab mode. This command is internally used by the "
"<guisubmenu>Window</guisubmenu> menu."
msgstr ""
"Вызывает вложенное окно, определяемое <replaceable>заголовком</replaceable> "
"основного окна. Если вложенное окно свёрнуто, то оно будет восстановлено. "
"Доступно только в режиме MDI или в режиме вкладок. Эту команду внутренне "
"использует меню <guisubmenu>Окно</guisubmenu>."

#. Tag: entry
#: index.docbook:4061
#, no-c-format
msgid "<parameter>title</parameter>:"
msgstr "<parameter>заголовок</parameter>:"

#. Tag: entry
#: index.docbook:4062
#, no-c-format
msgid "the title of the sub-window that should be activated"
msgstr "название вложенного окна, которое должно быть активировано"

#. Tag: title
#: index.docbook:4067
#, no-c-format
msgid "&no-i18n-cmd_window_cascade;"
msgstr "&no-i18n-cmd_window_cascade;"

#. Tag: title
#: index.docbook:4069
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_cascade;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_cascade;</"
"command>()"

#. Tag: para
#: index.docbook:4070
#, no-c-format
msgid ""
"Cascades all sub-windows when in MDI mode. All sub-windows that are "
"currently minimized stay minimized, they will not be restored."
msgstr ""
"Располагает каскадом все вложенные окна, когда приложение находится в режиме "
"MDI. Все свёрнутые вложенные окна не будут восстановлены."

#. Tag: title
#: index.docbook:4078
#, no-c-format
msgid "&no-i18n-cmd_window_click;"
msgstr "&no-i18n-cmd_window_click;"

#. Tag: title
#: index.docbook:4080
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_click;</"
"command>( <replaceable>class</replaceable>, <replaceable>x</replaceable>, "
"<replaceable>y</replaceable> )"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_click;</"
"command>(<replaceable>класс</replaceable>, <replaceable>x</replaceable>, "
"<replaceable>y</replaceable>)"

#. Tag: para
#: index.docbook:4085
#, no-c-format
msgid ""
"Sends a mouse click event to window, identified by its <replaceable>class</"
"replaceable> name. The event will only be sent to the first window that has "
"the given class name, therefore you should make sure that you have only one "
"instance of the given window when this command gets executed."
msgstr ""
"Отправляет событие нажатия мыши в окно с указанным <replaceable>классом</"
"replaceable>. Событие будет отправлено только в первое окно с заданным "
"классом, поэтому перед выполнением команды следует убедиться, что открыт "
"только один экземпляр данного окна."

#. Tag: entry
#: index.docbook:4095 index.docbook:4119 index.docbook:4153 index.docbook:4204
#: index.docbook:4232 index.docbook:4257
#, no-c-format
msgid "<parameter>class</parameter>:"
msgstr "<parameter>класс</parameter>:"

#. Tag: entry
#: index.docbook:4096 index.docbook:4120 index.docbook:4154 index.docbook:4205
#: index.docbook:4233 index.docbook:4258
#, no-c-format
msgid "name of the window class"
msgstr "имя класса окна"

#. Tag: entry
#: index.docbook:4097 index.docbook:4155
#, no-c-format
msgid "<parameter>x</parameter>:"
msgstr "<parameter>x</parameter>:"

#. Tag: entry
#: index.docbook:4098 index.docbook:4156
#, no-c-format
msgid "x position, relative to the left border of the window (in pixels)"
msgstr "положение x относительно левой границы окна (в пикселах)"

#. Tag: entry
#: index.docbook:4099 index.docbook:4157
#, no-c-format
msgid "<parameter>y</parameter>:"
msgstr "<parameter>y</parameter>:"

#. Tag: entry
#: index.docbook:4100 index.docbook:4158
#, no-c-format
msgid "y position, relative to the top border of the window (in pixels)"
msgstr "положение y относительно верхней границы окна (в пикселах)"

#. Tag: title
#: index.docbook:4105
#, no-c-format
msgid "&no-i18n-cmd_window_close;"
msgstr "&no-i18n-cmd_window_close;"

#. Tag: title
#: index.docbook:4107
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_close;</"
"command>( <replaceable>class</replaceable> )"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_close;</"
"command>(<replaceable>класс</replaceable>)"

#. Tag: para
#: index.docbook:4110
#, no-c-format
msgid ""
"Closes a window, identified by its <replaceable>class</replaceable> name. "
"Only the first window that has the given class name will be closed, "
"therefore you should make sure that you have only one instance of the given "
"window when this command gets executed."
msgstr ""
"Закрывает окно с указанным <replaceable>классом</replaceable>. Будет закрыто "
"только первое окно с заданным классом, поэтому перед выполнением команды "
"следует убедиться, что открыт только один экземпляр данного окна."

#. Tag: title
#: index.docbook:4125
#, no-c-format
msgid "&no-i18n-cmd_window_minimize;"
msgstr "&no-i18n-cmd_window_minimize;"

#. Tag: title
#: index.docbook:4127
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-cmd_window_minimize;</command>"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-cmd_window_minimize;</command>"

#. Tag: para
#: index.docbook:4128
#, no-c-format
msgid ""
"Minimizes the currently active sub-window when in MDI mode or the current "
"toplevel window when in SDI or Tab mode."
msgstr ""
"Сворачивает текущее активное вложенное окно в режиме MDI или текущее "
"активное окно в режиме SDI или в режиме вкладок."

#. Tag: title
#: index.docbook:4136
#, no-c-format
msgid "&no-i18n-cmd_window_mousemove;"
msgstr "&no-i18n-cmd_window_mousemove;"

#. Tag: title
#: index.docbook:4138
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_resize;</"
"command>( <replaceable>class</replaceable>, <replaceable>x</replaceable>, "
"<replaceable>y</replaceable> )"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_resize;</"
"command>(<replaceable>класс</replaceable>, <replaceable>x</replaceable>, "
"<replaceable>y</replaceable>)"

#. Tag: para
#: index.docbook:4143
#, no-c-format
msgid ""
"Sends a mouse move event to window, identified by its <replaceable>class</"
"replaceable> name. The event will only be sent to the first window that has "
"the given class name, therefore you should make sure that you have only one "
"instance of the given window when this command gets executed."
msgstr ""
"Отправляет событие перемещения курсора к окну с указанным "
"<replaceable>классом</replaceable>. Событие будет отправлено только в первое "
"окно с заданным классом, поэтому перед выполнением команды следует "
"убедиться, что открыт только один экземпляр данного окна."

#. Tag: title
#: index.docbook:4163
#, no-c-format
msgid "&no-i18n-cmd_window_next_sub;"
msgstr "&no-i18n-cmd_window_next_sub;"

#. Tag: title
#: index.docbook:4165
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_next_sub;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_next_sub;</"
"command>()"

#. Tag: para
#: index.docbook:4166
#, no-c-format
msgid ""
"Activates the <emphasis>next</emphasis> sub-window when in MDI or Tab mode. "
"If the next sub-window is minimized it will be restored."
msgstr ""
"Активирует <emphasis>следующее</emphasis> вложенное окно в режиме MDI или в "
"режиме вкладок. Если следующее вложенное окно свёрнуто, оно будет "
"восстановлено."

#. Tag: title
#: index.docbook:4174
#, no-c-format
msgid "&no-i18n-cmd_window_prev_sub;"
msgstr "&no-i18n-cmd_window_prev_sub;"

#. Tag: title
#: index.docbook:4176
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_prev_sub;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_prev_sub;</"
"command>()"

#. Tag: para
#: index.docbook:4177
#, no-c-format
msgid ""
"Activates the <emphasis>previous</emphasis> sub-window when in MDI or Tab "
"mode. If the previous sub-window is minimized it will be restored."
msgstr ""
"Активирует <emphasis>предыдущее</emphasis> вложенное окно в режиме MDI или в "
"режиме вкладок. Если предыдущее вложенное окно свёрнуто, оно будет "
"восстановлено."

#. Tag: title
#: index.docbook:4185
#, no-c-format
msgid "&no-i18n-cmd_window_resize;"
msgstr "&no-i18n-cmd_window_resize;"

#. Tag: title
#: index.docbook:4187
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_resize;</"
"command>( <replaceable>class</replaceable>, <replaceable>width</"
"replaceable>, <replaceable>height</replaceable> )"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_resize;</"
"command>(<replaceable>класс</replaceable>, <replaceable>ширина</"
"replaceable>, <replaceable>высота</replaceable>)"

#. Tag: para
#: index.docbook:4192
#, no-c-format
msgid ""
"Changes the size of a window, identified by its <replaceable>class</"
"replaceable> name to a new <replaceable>width</replaceable> and "
"<replaceable>height</replaceable>. The change will only be applied to the "
"first window that has the given class name, therefore you should make sure "
"that you have only one instance of the given window when this command gets "
"executed."
msgstr ""
"Изменяет размер окна с указанным <replaceable>классом</replaceable>, и "
"присваивает ему новую <replaceable>ширину</replaceable> и "
"<replaceable>высоту</replaceable>. Изменение будет применено только к "
"первому окну с заданным классом, поэтому перед выполнением команды следует "
"убедиться, что открыт только один экземпляр данного окна."

#. Tag: entry
#: index.docbook:4206
#, no-c-format
msgid "<parameter>width</parameter>:"
msgstr "<parameter>ширина</parameter>:"

#. Tag: entry
#: index.docbook:4207
#, no-c-format
msgid "new width of the window (in pixels)"
msgstr "новая ширина окна (в пикселах)"

#. Tag: entry
#: index.docbook:4208
#, no-c-format
msgid "<parameter>height</parameter>:"
msgstr "<parameter>высота</parameter>:"

#. Tag: entry
#: index.docbook:4209
#, no-c-format
msgid "new height of the window (in pixels)"
msgstr "новая высота окна (в пикселах)"

#. Tag: title
#: index.docbook:4214
#, no-c-format
msgid "&no-i18n-cmd_window_screenshot;"
msgstr "&no-i18n-cmd_window_screenshot;"

#. Tag: title
#: index.docbook:4216
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_screenshot;</"
"command>( <replaceable>class</replaceable>, <replaceable>filename</"
"replaceable> )"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_screenshot;</"
"command>(<replaceable>класс</replaceable>, <replaceable>имя_файла</"
"replaceable>)"

#. Tag: para
#: index.docbook:4220
#, no-c-format
msgid ""
"Takes a screenshot of a window, identified by its <replaceable>class</"
"replaceable> and saves it to a file. The screenshot will be taken from the "
"first window that has the given class name, therefore you should make sure "
"that you have only one instance of the given window when this command gets "
"executed. Currently the format of the file is hardcoded and has to be "
"<literal>*.png</literal>."
msgstr ""
"Делает снимок экрана окна с указанным <replaceable>классом</replaceable>, и "
"сохраняет его в файл. Будет произведён снимок только первого окна с заданным "
"классом, поэтому перед выполнением команды следует убедиться, что открыт "
"только один экземпляр данного окна. В текущей версии выбор формата снимков "
"не предусмотрен, все снимки сохраняются в формате <literal>*.png</literal>."

#. Tag: entry
#: index.docbook:4235
#, no-c-format
msgid ""
"name of the file to save the screenshot, must have the extension <literal>*."
"png</literal>"
msgstr ""
"имя файла для сохранения снимка экрана, должно иметь расширение <literal>*."
"png</literal>"

#. Tag: title
#: index.docbook:4241
#, no-c-format
msgid "&no-i18n-cmd_window_sendkey;"
msgstr "&no-i18n-cmd_window_sendkey;"

#. Tag: title
#: index.docbook:4243
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_sendkey;</"
"command>( <replaceable>class</replaceable>, <replaceable>key code</"
"replaceable> )"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_sendkey;</"
"command>(<replaceable>класс</replaceable>, <replaceable>код_клавиши</"
"replaceable>)"

#. Tag: para
#: index.docbook:4247
#, no-c-format
msgid ""
"Sends a key press and release event to a window, identified by its "
"<replaceable>class</replaceable> name. The key will only be sent to the "
"first window that has the given class name, therefore you should make sure "
"that you have only one instance of the given window when this command gets "
"executed."
msgstr ""
"Отправляет событие нажатия и отпускания клавиши в окно с указанным "
"<replaceable>классом</replaceable>. Событие будет отправлено только в первое "
"окно с заданным классом, поэтому перед выполнением команды следует "
"убедиться, что открыть только один экземпляр данного окна."

#. Tag: entry
#: index.docbook:4259
#, no-c-format
msgid "<parameter>key code</parameter>:"
msgstr "<parameter>код_клавиши</parameter>:"

#. Tag: entry
#: index.docbook:4260
#, no-c-format
msgid ""
"the key code that should be sent, using the same syntax as used for setting "
"up menus"
msgstr ""
"посылаемый код клавиши, который должен использовать тот же синтаксис, что "
"используется для настройки параметров меню."

#. Tag: para
#: index.docbook:4264
#, no-c-format
msgid ""
"Description of the parameter <link linkend=\"cmd_menu_param_hotkey"
"\"><parameter>hotkey</parameter></link> of the <command>&no-i18n-cmd_menu;</"
"command>() command."
msgstr ""
"Описание параметра <link linkend=\"cmd_menu_param_hotkey"
"\"><parameter>горячая_клавиша</parameter></link> команды <command>&no-i18n-"
"cmd_menu;</command>()."

#. Tag: title
#: index.docbook:4273
#, no-c-format
msgid "&no-i18n-cmd_window_tile;"
msgstr "&no-i18n-cmd_window_tile;"

#. Tag: title
#: index.docbook:4275
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_tile;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_tile;</command>()"

#. Tag: para
#: index.docbook:4276
#, no-c-format
msgid ""
"Tiles all sub-windows when in MDI mode, using some scheme of &plasma;. All "
"sub-windows that are currently minimized stay minimized, they will not be "
"restored."
msgstr ""
"Располагает все вложенные окна рядом, когда приложение находится в режиме "
"MDI с использованием некоторых схем &plasma;. Все свёрнутые вложенные окна "
"не будут восстановлены."

#. Tag: title
#: index.docbook:4285
#, no-c-format
msgid "&no-i18n-cmd_window_tile_vertical;"
msgstr "&no-i18n-cmd_window_tile_vertical;"

#. Tag: title
#: index.docbook:4287
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_tile_vertical;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_tile_vertical;</"
"command>()"

#. Tag: para
#: index.docbook:4288
#, no-c-format
msgid ""
"Tiles all sub-windows vertically when in MDI mode. All windows that are "
"currently minimized stay minimized, they will not be restored."
msgstr ""
"При работе приложения в режиме MDI располагает все вложенные окна "
"вертикально. Все свёрнутые вложенные окна не будут восстановлены."

