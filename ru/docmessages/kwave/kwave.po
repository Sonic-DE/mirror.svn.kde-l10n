#, no-c-format
msgid "Project Homepage<anchor id=\"project-homepage\"/>"
msgstr "Домашняя страница проекта<anchor id=\"project-homepage\"/>"

#. Tag: para
#: index.docbook:434
#, fuzzy, no-c-format
#| msgid ""
#| "For information about new up-to-date releases or some other information "
#| "about this project, take a look at the <ulink url=\"&url_homepage;"
#| "\">&kwave; homepage</ulink>."
msgid ""
"For information about new up-to-date releases see the <ulink url="
"\"&url_apps_kde;\">&kwave; page</ulink> on apps.kde.org. For other "
"information take a look at the <ulink url=\"&url_homepage;\">&kwave; "
"homepage</ulink> ."
