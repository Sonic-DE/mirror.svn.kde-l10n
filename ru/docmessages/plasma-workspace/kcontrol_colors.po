#~ msgid ""
#~ "A <emphasis>Widget</emphasis> is a commonly-used programmer's term for "
#~ "referring to User Interface elements such as buttons, menus, and scroll "
#~ "bars. You can think of them as the fundamental pieces that are assembled "
#~ "to make your application."
#~ msgstr ""
#~ "Термин <emphasis>Элемент управления</emphasis> часто используется в "
#~ "программировании для обозначения элементов пользовательского интерфейса, "
