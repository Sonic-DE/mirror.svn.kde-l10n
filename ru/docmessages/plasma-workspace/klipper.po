#. Tag: para
#: index.docbook:37
#, no-c-format
msgid "&klipper; is the &plasma; clipboard cut &amp; paste utility."
msgstr ""
"&klipper; &mdash; служебная программа &plasma; для работы с буфером обмена."

#. Tag: keyword
#: index.docbook:41
#, no-c-format
msgid "<keyword>KDE</keyword>"
