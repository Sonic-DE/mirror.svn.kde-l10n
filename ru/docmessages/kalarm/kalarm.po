msgid ""
"<mousebutton>Right</mousebutton> click on the desired entries in the alarm "
"list and choose <menuchoice><guimenuitem>Disable</guimenuitem></menuchoice> "
"from the context menu."
msgstr ""
"Щёлкните <mousebutton>правой</mousebutton> кнопкой мыши по нужным записям "
"напоминаний в списке и выберите в контекстном меню пункт "
"<menuchoice><guimenuitem>Отключить</guimenuitem></menuchoice>."

#. Tag: title
#: index.docbook:2561
#, fuzzy, no-c-format
#| msgid "Enabling and Disabling Individual Alarms"
