msgstr "Параметры"

#. Tag: guilabel
#: plugins.docbook:1798
#, no-c-format
msgid "Executable"
msgstr "Исполняемый файл"

#. Tag: para
#: plugins.docbook:1799
#, no-c-format
msgid "Path to the target (executable) for debugging."
msgstr "Путь к исполняемому файлу для отладки."

#. Tag: para
#: plugins.docbook:1804
#, no-c-format
msgid "The current working directory provided to the target."
msgstr "Текущий рабочий каталог, относящийся к цели."

