#. Tag: screeninfo
#: plugins.docbook:1828
#, no-c-format
msgid "<screeninfo>The Settings dialog</screeninfo>"
msgstr "<screeninfo>Вкладка «Параметры»</screeninfo>"

#. Tag: phrase
#: plugins.docbook:1831
#, no-c-format
msgid "<phrase>The Settings dialog</phrase>"
msgstr "<phrase>Вкладка «Параметры»</phrase>"

#. Tag: para
#: plugins.docbook:1832
#, no-c-format
msgid ""
"The <guilabel>Settings</guilabel> dialog displaying the configuration of a "
"debugging session."
msgstr ""
"Вкладка <guilabel>Параметры</guilabel>, отображающая параметры текущего "
"сеанса отладки."

