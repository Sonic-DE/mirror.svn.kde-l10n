#: plugins.docbook:1841
#, no-c-format
msgid "<guilabel>IO</guilabel>"
msgstr "<guilabel>Ввод и вывод</guilabel>"

#. Tag: para
#: plugins.docbook:1843
#, no-c-format
msgid ""
"Contains an area that displays output from the running program and a command "
"line where you may provide input to it."
msgstr ""
"Содержит область, в которой отображается вывод из выполняемой программы, и "
"командную строку, которая обеспечивает возможность ввода в неё. "

#. Tag: screeninfo
#: plugins.docbook:1847
#, no-c-format
msgid "The IO Tab"
msgstr "Вкладка «Ввод и вывод»"

#. Tag: phrase
#: plugins.docbook:1850
#, no-c-format
msgid "The IO tab."
msgstr "Вкладка «Ввод и вывод»."

#. Tag: para
#: plugins.docbook:1851
#, no-c-format
msgid ""
"The <guilabel>IO</guilabel> tab displaying output from a simple test program."
msgstr ""
"Вкладка <guilabel>Ввод и вывод</guilabel>, отображающая вывод простой "
