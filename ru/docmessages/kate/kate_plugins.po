#. Tag: phrase
#: plugins.docbook:1783
#, no-c-format
msgid "The Output tab."
msgstr "Вкладка «Вывод GDB»."

#. Tag: para
#: plugins.docbook:1784
#, no-c-format
msgid ""
"The <guilabel>Output</guilabel> tab displaying the output from a debugging "
"session."
msgstr ""
"Вкладка <guilabel>Вывод GDB</guilabel>, отображающая результат текущего "
