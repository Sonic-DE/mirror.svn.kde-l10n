msgstr "Аргументы для программы."

#. Tag: guilabel
#: plugins.docbook:1814
#, no-c-format
msgid "Keep focus"
msgstr "Удерживать фокус"

#. Tag: para
#: plugins.docbook:1815
#, no-c-format
msgid "Keeps focus on the &gdb; command line."
msgstr "Удерживать фокус в командной строке &gdb;."

#. Tag: guilabel
#: plugins.docbook:1819
#, no-c-format
