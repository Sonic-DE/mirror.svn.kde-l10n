#, no-c-format
msgid "&gdb; Output"
msgstr "Вывод &gdb;"

#. Tag: para
#: plugins.docbook:1777
#, no-c-format
msgid "Contains output from &gdb; and a &gdb; command line."
msgstr "Содержит вывод из &gdb; и командную строку &gdb;."

#. Tag: screeninfo
