msgstr "Предыдущая створка"

#. Tag: keycombo
#: fundamentals.docbook:357
#, no-c-format
msgid "&Ctrl;&Shift;<keycap>R</keycap>"
msgstr "&Ctrl;&Shift;<keycap>R</keycap>"

#. Tag: para
#: fundamentals.docbook:358
#, no-c-format
msgid "Close Current View"
msgstr "Закрыть текущую створку"

