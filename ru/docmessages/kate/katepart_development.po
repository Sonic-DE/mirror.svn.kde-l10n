msgstr ""
"bool document.isChar(<parameter>int <replaceable>строка</replaceable></"
"parameter>, <parameter>int <replaceable>столбец</replaceable></parameter>);\n"
"bool document.isChar(<parameter>Cursor <replaceable>курсор</replaceable></"
"parameter>);"

#. Tag: para
#: development.docbook:3906
#, no-c-format
