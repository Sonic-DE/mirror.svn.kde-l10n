#. Tag: refpurpose
#: man-zonetab2pot.py.1.docbook:20
#, no-c-format
msgid "Converts a timezone list to a PO file template."
msgstr "Преобразовывает список часовых поясов в шаблон PO-файлов."

#. Tag: cmdsynopsis
#: man-zonetab2pot.py.1.docbook:24
#, no-c-format
msgid ""
"<command>zonetab2pot.py</command> <group><option><replaceable>timezone-list</"
"replaceable></option></group>"
msgstr ""
"<command>zonetab2pot.py</command> "
"<group><option><replaceable>список_часовых_поясов</replaceable></option></"
"group>"

#. Tag: title
#: man-zonetab2pot.py.1.docbook:32
#, no-c-format
msgid "Description"
msgstr "Описание"

#. Tag: para
#: man-zonetab2pot.py.1.docbook:34
#, no-c-format
msgid ""
"<command>zonetab2pot.py</command> reads the timezone list given on the "
"command-line and converts it to a gettext message file (PO-file) template "
"containing the names of the individual timezones."
msgstr ""
"<command>zonetab2pot.py</command> выполняет чтение указанного в командной "
"строке списка часовых поясов и преобразует его в шаблон файлов сообщений "
"gettext (PO-файлов), содержащий названия отдельных часовых поясов."

#. Tag: para
#: man-zonetab2pot.py.1.docbook:39
#, no-c-format
msgid ""
"The given timezone list should be in the same format as the system zone.tab. "
"If no timezone list is specified on the command-line, <filename>/usr/share/"
"zoneinfo/zone.tab</filename> will be used."
msgstr ""
"Указанный список часовых поясов должен иметь тот же формат, что и системный "
"файл zone.tab. Если в командной строке не указан список часовых поясов, "
"будет использован файл <filename>/usr/share/zoneinfo/zone.tab</filename>."

#. Tag: para
#: man-zonetab2pot.py.1.docbook:43
#, no-c-format
msgid "The new PO-file template will be written to standard output."
msgstr "Созданный шаблон PO-файлов будет передан на стандартный вывод."

#. Tag: para
#: man-zonetab2pot.py.1.docbook:45
#, no-c-format
msgid "This utility is part of the KDE Software Development Kit."
msgstr "Эта утилита является частью пакета KDE Software Development Kit."

