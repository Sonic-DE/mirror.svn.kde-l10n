#~ msgid "IEEE 1394 Device Information Module"
#~ msgstr "Модуль «Устройства IEEE 1394»"

#~ msgid ""
#~ "The IEEE 1394 interface, also known as <trademark>FireWire</trademark>, "
#~ "is a serial bus interface standard for high-speed communications and "
#~ "isochronous real-time data transfer."
#~ msgstr ""
#~ "Интерфейс IEEE 1394, также известный как <trademark>FireWire</trademark>, "
#~ "— это стандарт интерфейса последовательной шины для высокоскоростной "
#~ "связи и передачи данных в изохронном реальном времени."

#~ msgid ""
#~ "The list in this module displays all devices attached to IEEE 1394 bus "
#~ "and allows you to reset the bus by clicking the <guibutton>Generate 1394 "
#~ "Bus Reset</guibutton> button."
#~ msgstr ""
#~ "В этом модуле показан список устройств, которые подключены к шине IEEE "
#~ "1394. Чтобы выполнить сброс шины, нажмите кнопку <guibutton>Генерировать "
#~ "сброс шины 1394</guibutton>."

#~ msgid "The meaning of the columns in this list:"
#~ msgstr "Значение столбцов списка:"

#~ msgid ""
#~ "<guilabel>Name</guilabel>: port or node name, the number can change with "
#~ "each bus reset"
#~ msgstr ""
#~ "<guilabel>Название</guilabel>: название порта или узла, номер может "
#~ "изменяться при каждом сбросе шины"

#~ msgid "<guilabel>GUID</guilabel>: the 64 bit GUID of the node"
#~ msgstr "<guilabel>GUID</guilabel>: 64-битный GUID узла"

#~ msgid ""
#~ "<guilabel>Local</guilabel>: checked if the node is an IEEE 1394 port of "
#~ "your computer"
#~ msgstr ""
#~ "<guilabel>Локально</guilabel>: отмечено, если узел является портом IEEE "
#~ "1394 компьютера"

#~ msgid ""
#~ "<guilabel>IRM</guilabel>: checked if the node is isochronous resource "
#~ "manager capable"
#~ msgstr ""
#~ "<guilabel>Изохронный</guilabel>: отмечено, если узел доступен для "
#~ "управления диспетчером изохронных ресурсов"

#~ msgid ""
#~ "<guilabel>CRM</guilabel>: checked if the node is cycle master capable"
#~ msgstr ""
#~ "<guilabel>Циклический</guilabel>: отмечено, если узел доступен для "
#~ "управления мастером циклов"

#~ msgid ""
#~ "<guilabel>ISO</guilabel>: checked if the node supports isochronous "
#~ "transfers"
#~ msgstr ""
#~ "<guilabel>Пересылка</guilabel>: отмечено, если узел поддерживает "
#~ "изохронные передачи"

#~ msgid "<guilabel>BM</guilabel>: checked if the node is bus manager capable"
#~ msgstr ""
#~ "<guilabel>Шина</guilabel>: отмечено, если узел доступен для управления "
#~ "диспетчером шины"

#~ msgid ""
#~ "<guilabel>PM</guilabel>: checked if the node is power management capable"
#~ msgstr ""
#~ "<guilabel>Питание</guilabel>: отмечено, если узел доступен для управления "
#~ "питанием"

#~ msgid ""
#~ "<guilabel>Acc</guilabel>: the cycle clock accuracy of the node, valid "
#~ "from 0 to 100"
#~ msgstr ""
#~ "<guilabel>Точность</guilabel>: точность временного цикла узла, корректны "
#~ "значения от 0 до 100"

#~ msgid "<guilabel>Speed</guilabel>: the speed of the node"
#~ msgstr "<guilabel>Скорость</guilabel>: скорость узла"

#~ msgid "<guilabel>Vendor</guilabel>: the vendor of the device"
#~ msgstr "<guilabel>Поставщик</guilabel>: поставщик устройства"

