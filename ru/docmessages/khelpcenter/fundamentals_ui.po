msgstr "Показывает информацию о версии приложения и его авторе."

#. Tag: menuchoice
#: ui.docbook:1278
#, no-c-format
msgid "<guimenu>Help</guimenu> <guimenuitem>About KDE</guimenuitem>"
msgstr "<guimenu>Справка</guimenu> <guimenuitem>О KDE</guimenuitem>"

