msgid ""
"<phrase>A screenshot of &kaddressbook;'s <quote>Contact List</quote> context "
"menu.</phrase>"
msgstr "<phrase>Контекстное меню списка контактов &kaddressbook;</phrase>"

#. Tag: para
#: index.docbook:1839
