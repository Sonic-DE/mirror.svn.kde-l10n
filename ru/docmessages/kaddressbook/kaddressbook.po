msgid ""
"<screeninfo>A screenshot of &kaddressbook;'s <quote>Tools</quote> menu.</"
"screeninfo>"
msgstr "<screeninfo>Меню «Сервис» &kaddressbook;</screeninfo>"

#. Tag: phrase
