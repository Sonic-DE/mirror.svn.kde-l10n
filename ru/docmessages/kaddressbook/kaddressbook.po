#: index.docbook:69
#, no-c-format
msgid ""
"<screeninfo>A screenshot of &kaddressbook;'s primary &GUI; interface</"
"screeninfo>"
msgstr ""
"<screeninfo>Основное окно интерфейса пользователя &kaddressbook;</screeninfo>"

