"screeninfo>"
msgstr "<screeninfo>Меню «Вид» &kaddressbook;</screeninfo>"

#. Tag: phrase
#: index.docbook:1302
#, no-c-format
msgid ""
"<phrase>A screenshot of &kaddressbook;'s <quote>View</quote> menu.</phrase>"
msgstr "<phrase>Меню «Вид» &kaddressbook;</phrase>"

