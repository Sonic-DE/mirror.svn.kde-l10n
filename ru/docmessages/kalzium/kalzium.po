#: index.docbook:736
#, no-c-format
msgid "Equation Balancer"
msgstr "Балансировка уравнений"

#. Tag: para
#: index.docbook:738
#, fuzzy, no-c-format
#| msgid ""
#| "The <guimenuitem>Equation Balancer</guimenuitem> enables the user to "
