#. Tag: para
#: index.docbook:6064
#, no-c-format
msgid ""
"<ulink url=\"https://en.wikipedia.org/wiki/ReplayGain\">Replay gain</ulink> "
"will automatically adjust the volume of the currently played song, relative "
"to other songs, as determined by the person who encoded the audio file. To "
"enable replay gain, see <link linkend=\"settings-menu\">Settings menu</link>."
msgstr ""

