msgstr "<entry>Действие</entry>"

#. Tag: guilabel
#: index.docbook:438
#, no-c-format
msgid "<guilabel>Local Music</guilabel>"
msgstr "<guilabel>Локальная музыка</guilabel>"

#. Tag: para
#: index.docbook:441
#, no-c-format
msgid "Your &amarok; collection"
