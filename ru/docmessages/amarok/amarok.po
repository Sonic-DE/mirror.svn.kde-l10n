msgid "<emphasis>Off</emphasis>"
msgstr "<emphasis>Или</emphasis>"

#. Tag: para
#: index.docbook:4134
#, no-c-format
msgid ""
"Tracks are matched properly, but if you change your tags after some time, "
"your play-count will be split in two tracks."
msgstr ""

#. Tag: emphasis
#: index.docbook:4137
#, fuzzy, no-c-format
#| msgid "<emphasis>Or</emphasis>"
msgid "<emphasis>On</emphasis>"
msgstr "<emphasis>Или</emphasis>"

#. Tag: para
#: index.docbook:4139
#, no-c-format
msgid ""
"You can play-count the tracks even if tags are changed after some time, but "
"you will have to use Last.fm preferred spelling."
msgstr ""

