msgid "%artist%/%album%{/Disc %discnumber%}/%track% %title%"
msgstr "%artist%/%album%{/Диск %discnumber%}/%track% %title%"

#. Tag: para
#: index.docbook:4037
#, no-c-format
msgid ""
"Note: formerly, the coding was <varname>%token</varname>, as of 2.4 it is "
"<varname>%token%</varname>."
msgstr ""
"Заметьте: раньше переменные назывались <varname>%переменная</varname>, а с "
"версии 2.4 — <varname>%переменная%</varname>."

