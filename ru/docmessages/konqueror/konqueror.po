#. Tag: guimenuitem
#: index.docbook:2009
#, no-c-format
msgid "<guimenuitem>Plugins</guimenuitem>"
msgstr "<guimenuitem>Модули</guimenuitem>"

#. Tag: para
#: index.docbook:2010
#, no-c-format
