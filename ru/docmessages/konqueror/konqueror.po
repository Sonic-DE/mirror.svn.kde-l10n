#. Tag: guimenuitem
#: index.docbook:2019
#, no-c-format
msgid "Enable Proxy"
msgstr "Использовать прокси"

#. Tag: para
#: index.docbook:2020
#, no-c-format
msgid ""
"Allows you to enable or disable the use of a proxy in the &konqueror; "
"browser."
msgstr ""
"Позволяет включить или отключить использование прокси-серверов в &konqueror;."

#. Tag: guimenuitem
#: index.docbook:2024
#, no-c-format
msgid "Enable Cache"
msgstr "Использовать кэш"

#. Tag: para
#: index.docbook:2025
