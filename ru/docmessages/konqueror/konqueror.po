#. Tag: guimenuitem
#: index.docbook:2014
#, no-c-format
msgid "Autoload Images"
msgstr "Автозагрузка изображений"

#. Tag: para
#: index.docbook:2015
#, no-c-format
msgid "Allows you to turn on or off the loading of images in web pages."
msgstr ""
