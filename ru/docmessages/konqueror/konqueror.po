#. Tag: para
#: index.docbook:2035
#, no-c-format
msgid "Use Cache if Possible"
msgstr "Использовать кэш, если это возможно"

#. Tag: para
#: index.docbook:2036
#, no-c-format
msgid "Offline Browsing Mode"
msgstr "Автономный режим работы"

#. Tag: title
