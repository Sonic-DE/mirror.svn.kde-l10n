<entry
>20.06.2013</entry>
<entry
>&kde;</entry>
<entry
>Вклад в СПО &gt; KDE</entry>
<entry
>200 руб.</entry>
</row>
<row>
<entry
>20.07.2013</entry>
<entry
>&kde;</entry>
<entry
>Вклад в СПО &gt; KDE</entry>
<entry
>200 руб.</entry>
