#: src/cli.cpp:37
msgctxt "Cli|"
msgid "Display all language codes."
msgstr "Показать все языковые коды."

#: src/cli.cpp:39
msgctxt "Cli|"
msgid ""
"Specify the source language (by default, engine will try to determine the "
"language on its own)."
msgstr ""
"Укажите исходный язык (по умолчанию движок попытается определить язык "
"самостоятельно)."

#: src/cli.cpp:43
msgctxt "Cli|"
msgid ""
"Specify the translation language(s), split by '+' (by default, the system "
"language is used)."
msgstr ""
"Укажите язык(и) перевода, разделённые '+' (по умолчанию используется "
"системный язык)."

#: src/cli.cpp:47
msgctxt "Cli|"
msgid ""
"Specify the translator engine ('google', 'yandex', 'bing', 'libretranslate' "
"or 'lingva'), Google is used by default."
msgstr ""
"Укажите движок переводчика ('google', 'yandex', 'bing', 'libretranslate' или "
"'lingva'), Google используется по умолчанию."

#: src/cli.cpp:51
msgctxt "Cli|"
msgid ""
"Specify Mozhi instance URL. Instance URL from the app settings will be used "
"by default."
msgstr ""
"Указать URL экземпляра Mozhi. По умолчанию будет использоваться URL "
"экземпляра из настроек приложения."

#: src/cli.cpp:55
msgctxt "Cli|"
msgid ""
"Specify translation provider ('copy' or 'mozhi'). Provider from app settings "
"will be used by default."
msgstr ""
"Указать провайдера перевода («copy» или «mozhi»). По умолчанию используется "
"провайдер из настроек приложения."

#: src/cli.cpp:58
msgctxt "Cli|"
msgid ""
"Specify TTS provider ('none', 'mozhi', 'qt', or 'piper'). Provider from app "
"settings will be used by default."
msgstr ""
"Указать поставщика TTS («none», «mozhi», «qt» или «piper»). По умолчанию "
"будет использован поставщик из настроек приложения."

#: src/cli.cpp:60
msgctxt "Cli|"
msgid "Speak the translation."
msgstr "Озвучить перевод."

#: src/cli.cpp:61
msgctxt "Cli|"
msgid "Speak the source."
msgstr "Озвучить исходный текст."

#: src/cli.cpp:62
msgctxt "Cli|"
msgid ""
"Read source text from files. Arguments will be interpreted as file paths."
msgstr ""
"Считать исходный текст из файлов. Аргументы будут интерпретироваться как "
"пути к файлам."

#: src/cli.cpp:63
msgctxt "Cli|"
msgid "Add stdin data to source text."
msgstr "Добавить данные стандартного ввода в исходный текст."

#: src/cli.cpp:65
#, qt-format
msgctxt "Cli|"
msgid "Do not print any text when using --%1 or --%2."
msgstr "Не печатать текст при использовании --%1 или --%2."

#: src/cli.cpp:66
msgctxt "Cli|"
msgid "Print only translations."
msgstr "Печатать только переводы."

#: src/cli.cpp:67
msgctxt "Cli|"
msgid "Print output formatted as JSON."
msgstr "Печатать вывод в формате JSON."

#: src/cli.cpp:70
msgctxt "Cli|"
msgid ""
"Application that allows to translate and speak text using various providers"
msgstr ""
"Приложение для перевода и озвучивания текста с использованием различных "
"провайдеров"

#: src/cli.cpp:71
msgctxt "Cli|"
msgid ""
"Text to translate. By default, the translation will be done to the system "
"language."
msgstr ""
"Текст для перевода. По умолчанию перевод будет выполнен на язык системы."

