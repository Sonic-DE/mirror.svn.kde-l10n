#. (itstool) path: component/name
#: org.kde.krfb.appdata.xml:6
msgid "Krfb"
msgstr "Krfb"

#. (itstool) path: component/summary
#: org.kde.krfb.appdata.xml:7
msgid "Share your desktop to another computer via VNC"
msgstr ""
"Предоставление другому компьютеру доступа к рабочему столу с помощью VNC"

#. (itstool) path: description/p
#: org.kde.krfb.appdata.xml:9
msgid ""
"Krfb Desktop Sharing is a server application that allows you to share your "
"current session with a user on another machine, who can use a VNC client to "
"view or even control the desktop."
msgstr ""
"Krfb является сервером, который позволяет вам предоставлять доступ к своему "
"текущему сеансу пользователю на другом компьютере, который использует клиент "
"VNC для просмотра или управления вашим рабочим столом."

#. (itstool) path: screenshot/caption
#: org.kde.krfb.appdata.xml:17
msgid "Sharing desktop with Krfb"
msgstr "Общий доступ к рабочему столу с использованием Krfb"

#~ msgid "Desktop sharing"
#~ msgstr "Общий рабочий стол"
