#. (itstool) path: component/name
#: org.kde.okular.appdata.xml:7
msgid "Okular"
msgstr "Okular"

#. (itstool) path: component/summary
#: org.kde.okular.appdata.xml:8
msgid "View and annotate documents"
msgstr "Просмотр и рецензирование документов"

#. (itstool) path: description/p
#: org.kde.okular.appdata.xml:10
msgid ""
"Okular is a universal document viewer developed by KDE. Okular works on "
"multiple platforms, including but not limited to Linux, Windows, Mac OS X, "
"*BSD, etc."
msgstr ""
"Okular — универсальная программа просмотра документов от KDE. Okular "
"работает на многих платформах: Linux, Windows, Mac OS X, *BSD и других."

#. (itstool) path: description/p
#: org.kde.okular.appdata.xml:13
msgid "Features:"
msgstr "Возможности:"

#. (itstool) path: ul/li
#: org.kde.okular.appdata.xml:15
msgid ""
"Supported Formats: PDF, PS, Tiff, DjVu, Images, DVI, XPS, Fiction Book, "
"Comic Book, Plucker, EPub, Fax"
msgstr ""
"Поддержка форматов PDF, PS, Tiff, DjVu, изображений, DVI, XPS, Fiction Book, "
"Comic Book, Plucker, EPub, факсов;"

#. (itstool) path: ul/li
#: org.kde.okular.appdata.xml:16
msgid "Sidebar with contents, thumbnails, reviews and bookmarks"
msgstr ""
"Боковая панель с содержанием, миниатюрами страниц, комментариями и "
"закладками;"

#. (itstool) path: ul/li
#: org.kde.okular.appdata.xml:17
msgid "Annotations support"
msgstr "Поддержка комментариев."

#. (itstool) path: screenshot/caption
#: org.kde.okular.appdata.xml:22
msgid "Reading manual in Okular"
msgstr "Документ, открытый в Okular"

#~ msgid "Document Viewer"
#~ msgstr "Просмотр документов"

