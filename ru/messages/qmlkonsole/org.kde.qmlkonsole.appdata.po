#. (itstool) path: ul/li
#: org.kde.qmlkonsole.appdata.xml:83
msgid "Fix bar and tilde toolbar buttons not working"
msgstr ""
"Исправлена неработоспособность кнопок панели инструментов для символов «|» и "
"«~»;"

#. (itstool) path: ul/li
#: org.kde.qmlkonsole.appdata.xml:84
msgid "General user interface improvements"
msgstr "Улучшения пользовательского интерфейса;"

#. (itstool) path: ul/li
#: org.kde.qmlkonsole.appdata.xml:95
msgid "Fix support for modifier keys like Alt and Ctrl"
msgstr "Исправлена поддержка клавиш-модификаторов, таких как Alt и Ctrl;"

#. (itstool) path: ul/li
#: org.kde.qmlkonsole.appdata.xml:96
