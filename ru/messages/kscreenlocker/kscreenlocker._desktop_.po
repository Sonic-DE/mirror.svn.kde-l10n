msgstr "Экран был заблокирован"

#: kscreenlocker.notifyrc:165
msgctxt "Name"
msgid "Screen unlocked"
msgstr "Экран разблокирован"

#: kscreenlocker.notifyrc:218
msgctxt "Comment"
msgid "The screen has been unlocked"
msgstr "Экран был разблокирован"

