#: core/smb4k.notifyrc:3 smb4k/org.kde.smb4k.desktop:3
msgctxt "Name"
msgid "Smb4K"
msgstr "Smb4K"

#: core/smb4k.notifyrc:44 smb4k/org.kde.smb4k.desktop:80
msgctxt "Comment"
msgid "Advanced Network Neighborhood Browser"
msgstr "Диспетчер сетевого окружения"

#: core/smb4k.notifyrc:87
msgctxt "Name"
msgid "Notification"
msgstr "Уведомление"

#: core/smb4k.notifyrc:128
msgctxt "Comment"
msgid "The user is notified about an action"
msgstr "Пользователь уведомляется о действии"

#: core/smb4k.notifyrc:169
msgctxt "Name"
msgid "Warning"
msgstr "Предупреждение"

#: core/smb4k.notifyrc:210
msgctxt "Comment"
msgid "A warning is shown to the user"
msgstr "Предупреждение для пользователя"

#: core/smb4k.notifyrc:252
msgctxt "Name"
msgid "Error"
msgstr "Ошибка"

#: core/smb4k.notifyrc:293
msgctxt "Comment"
msgid "An error message is shown to the user"
msgstr "Сообщение об ошибке для пользователя"

#: core/smb4k.notifyrc:333
msgctxt "Name"
msgid "Share mounted"
msgstr "Подключён общий ресурс"

#: core/smb4k.notifyrc:371
msgctxt "Comment"
msgid "A share has been mounted"
msgstr "Общий ресурс был подключён"

#: core/smb4k.notifyrc:413
msgctxt "Name"
msgid "Share unmounted"
msgstr "Отключён общий ресурс"

#: core/smb4k.notifyrc:451
msgctxt "Comment"
msgid "A share has been unmounted"
msgstr "Общий ресурс был отключён"

#: core/smb4k.notifyrc:493
msgctxt "Name"
msgid "Shares mounted"
msgstr "Подключены общие ресурсы"

#: core/smb4k.notifyrc:531
msgctxt "Comment"
msgid "Multiple shares have been mounted"
msgstr "Были подключены некоторые общие ресурсы"

#: core/smb4k.notifyrc:573
msgctxt "Name"
msgid "Shares unmounted"
msgstr "Отключены общие ресурсы"

#: core/smb4k.notifyrc:611
msgctxt "Comment"
msgid "Multiple shares have been unmounted"
msgstr "Были отключены некоторые общие ресурсы"

#: core/smb4k.notifyrc:653
msgctxt "Name"
msgid "Migrating login credentials"
msgstr "Перенос учётных данных входа"

#: core/smb4k.notifyrc:682
msgctxt "Comment"
msgid ""
"The login credentials are migrated to the new format and the active password "
"manager"
msgstr ""
"Учётные данные входа перенесены в новый формат и активный диспетчер паролей"

#: core/smb4k.notifyrc:714
msgctxt "Name"
msgid "Mimetype not supported"
msgstr "Тип MIME не поддерживается"

#: core/smb4k.notifyrc:752
msgctxt "Comment"
msgid "The mimetype of the file that is to be printed is not supported"
msgstr ""
"Не поддерживается тип MIME файла, который требуется напечатать на принтере"

#: core/smb4k.notifyrc:794
msgctxt "Name"
msgid "Bookmark exists"
msgstr "Закладка существует"

#: core/smb4k.notifyrc:832
msgctxt "Comment"
msgid "The bookmark exists"
msgstr "Такая закладка уже существует"

#: core/smb4k.notifyrc:875
msgctxt "Name"
msgid "Bookmark label in use"
msgstr "Название закладки уже используется"

#: core/smb4k.notifyrc:913
msgctxt "Comment"
msgid "The label for the bookmark already exists"
msgstr "Выбранное название для закладки уже существует"

#: core/smb4k.notifyrc:956
msgctxt "Name"
msgid "Mounting failed"
msgstr "Ошибка подключения"

#: core/smb4k.notifyrc:995
msgctxt "Comment"
msgid "Mounting a share failed"
msgstr "Не удалось подключить общий ресурс"

#: core/smb4k.notifyrc:1038
msgctxt "Name"
msgid "Unmounting failed"
msgstr "Ошибка отключения"

#: core/smb4k.notifyrc:1077
msgctxt "Comment"
msgid "Unmounting a share failed"
msgstr "Не удалось отключить общий ресурс"

#: core/smb4k.notifyrc:1120
msgctxt "Name"
msgid "Unmounting not allowed"
msgstr "Отключение не разрешено"

#: core/smb4k.notifyrc:1158
msgctxt "Comment"
msgid "The unmounting of a certain share is not allowed"
msgstr "Отключение определённого общего ресурса не разрешено"

#: core/smb4k.notifyrc:1201
msgctxt "Name"
msgid "Synchronization failed"
msgstr "Ошибка синхронизации"

#: core/smb4k.notifyrc:1240
msgctxt "Comment"
msgid "The synchronization of a share and a local copy failed"
msgstr ""
"Не удалось синхронизировать общий ресурс и его копию на этом компьютере"

#: core/smb4k.notifyrc:1282
msgctxt "Name"
msgid "Command not found"
msgstr "Команда не найдена"

#: core/smb4k.notifyrc:1322
msgctxt "Comment"
msgid "A required command could not be found"
msgstr "Необходимая команда не была найдена"

#: core/smb4k.notifyrc:1365
msgctxt "Name"
msgid "Cannot bookmark printer"
msgstr "Невозможно добавить принтер в закладки"

#: core/smb4k.notifyrc:1403
msgctxt "Comment"
msgid "A printer cannot be bookmarked"
msgstr ""
"Невозможно создать закладку для общего ресурса, потому что он является "
"принтером."

#: core/smb4k.notifyrc:1446
msgctxt "Name"
msgid "File not found"
msgstr "Файл не найден"

#: core/smb4k.notifyrc:1487
msgctxt "Comment"
msgid "A file could not be found"
msgstr "Не удалось найти файл"

#: core/smb4k.notifyrc:1530
msgctxt "Name"
msgid "Opening file failed"
msgstr "Ошибка открытия файла"

#: core/smb4k.notifyrc:1568
msgctxt "Comment"
msgid "A file could not be opened"
msgstr "Не удалось открыть файл"

#: core/smb4k.notifyrc:1611
msgctxt "Name"
msgid "Reading file failed"
msgstr "Ошибка чтения из файла"

#: core/smb4k.notifyrc:1649
msgctxt "Comment"
msgid "A file could not be read"
msgstr "Не удалось прочитать из файла"

#: core/smb4k.notifyrc:1692
msgctxt "Name"
msgid "mkdir failed"
msgstr "Ошибка создания каталога"

#: core/smb4k.notifyrc:1731
msgctxt "Comment"
msgid "A directory could not be created"
msgstr "Не удалось создать каталог"

#: core/smb4k.notifyrc:1774
msgctxt "Name"
msgid "Process error"
msgstr "Ошибка процесса"

#: core/smb4k.notifyrc:1814
msgctxt "Comment"
msgid "A process error occurred"
msgstr "В работе программного процесса произошла ошибка"

#: core/smb4k.notifyrc:1857
msgctxt "Name"
msgid "Action failed"
msgstr "Ошибка выполнения действия"

#: core/smb4k.notifyrc:1897
msgctxt "Comment"
msgid "A KAuth action failed"
msgstr "Не удалось выполнить действие с помощью KAuth"

#: core/smb4k.notifyrc:1939
msgctxt "Name"
msgid "Invalid URL"
msgstr "Недопустимый адрес URL"

#: core/smb4k.notifyrc:1980
msgctxt "Comment"
msgid "An invalid URL was passed"
msgstr "Передан недопустимый адрес URL"

#: core/smb4k.notifyrc:2022
msgctxt "Name"
msgid "Network communication failed"
msgstr "Ошибка сети"

#: core/smb4k.notifyrc:2057
msgctxt "Comment"
msgid "A network related action could not be performed or failed"
msgstr "Произошла ошибка, связанная с подсистемой передачи данных по сети"

#: core/smb4k.notifyrc:2097
msgctxt "Name"
msgid "Zeroconf error"
msgstr "Ошибка Zeroconf"

#: core/smb4k.notifyrc:2130
msgctxt "Comment"
msgid "An error with the Zeroconf daemon occurred"
msgstr "Возникла ошибка при использовании управляющей программы Zeroconf"

#: core/smb4k.notifyrc:2167
msgctxt "Name"
msgid "Keychain error"
msgstr "Ошибка цепочки ключей"

#: core/smb4k.notifyrc:2196
msgctxt "Comment"
msgid ""
"An error occurred while reading the login credentials from the secure storage"
msgstr ""
"При чтении учётных данных входа из защищённого хранилища произошла ошибка"

#: helpers/smb4kmounthelper.actions:2
msgctxt "Name"
msgid "Mount action"
msgstr "Действие подключения"

#: helpers/smb4kmounthelper.actions:39
msgctxt "Description"
msgid "Mounts a share"
msgstr "Подключение общего ресурса"

#: helpers/smb4kmounthelper.actions:80
msgctxt "Name"
msgid "Unmount action"
msgstr "Действие отключения"

#: helpers/smb4kmounthelper.actions:117
msgctxt "Description"
msgid "Unmounts a share"
msgstr "Отключение общего ресурса"

#: smb4k/org.kde.smb4k.desktop:44
msgctxt "GenericName"
msgid "Advanced Network Browser for SAMBA"
msgstr "Диспетчер сетевого окружения для SAMBA"

