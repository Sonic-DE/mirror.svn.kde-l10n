#. (itstool) path: component/name
#: org.kde.kweather.appdata.xml:12
msgid "Weather"
msgstr "Погода"

#. (itstool) path: component/summary
#: org.kde.kweather.appdata.xml:13
msgid "View real-time weather forecasts"
msgstr "Просмотр прогнозов погоды в режиме реального времени"

#. (itstool) path: description/p
#: org.kde.kweather.appdata.xml:28
msgid ""
"A convergent weather application for Plasma. Has flat and dynamic/animated "
"views for showing forecasts and other information."
msgstr ""
"Адаптивное приложение для просмотра прогноза погоды при работе в Plasma. "
"Предусмотрены два варианта оформления: плоское и динамическое."

#. (itstool) path: screenshot/caption
#: org.kde.kweather.appdata.xml:32 org.kde.kweather.appdata.xml:40
msgid "Desktop dynamic view"
msgstr "Динамический режим для ПК"

#. (itstool) path: screenshot/caption
#: org.kde.kweather.appdata.xml:36
msgid "Desktop Welcome Screen"
msgstr "Экран приветствия на рабочем столе"

#. (itstool) path: screenshot/caption
#: org.kde.kweather.appdata.xml:44 org.kde.kweather.appdata.xml:48
msgid "Desktop flat view"
msgstr "Плоский режим для ПК"

#. (itstool) path: screenshot/caption
#: org.kde.kweather.appdata.xml:52 org.kde.kweather.appdata.xml:60
msgid "Mobile dynamic view"
msgstr "Динамический режим для мобильных устройств"

#. (itstool) path: screenshot/caption
#: org.kde.kweather.appdata.xml:56
msgid "Mobile Welcome Screen"
msgstr "Экран приветствия на мобильном устройстве"

#. (itstool) path: screenshot/caption
#: org.kde.kweather.appdata.xml:64 org.kde.kweather.appdata.xml:68
msgid "Mobile flat view"
msgstr "Плоский режим для мобильных устройств"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:136 org.kde.kweather.appdata.xml:144
#: org.kde.kweather.appdata.xml:152
msgid "User interface improvements and bugfixes"
msgstr "Улучшения интерфейса и исправления ошибок"

#. (itstool) path: description/p
#: org.kde.kweather.appdata.xml:159 org.kde.kweather.appdata.xml:174
#: org.kde.kweather.appdata.xml:185
msgid "Changes:"
msgstr "Изменения:"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:161
msgid "Performance improvements in Dynamic view"
msgstr "Улучшение производительности в динамическом представлении"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:162
msgid "Dynamic view action bar rewritten to be inline to content"
msgstr ""
"Панель действий динамического представления переписана для размещения в "
"строке с содержимым"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:163
msgid "Allow setting non-current location in default forecasts page"
msgstr ""
"Разрешено задание не текущего местоположения на странице прогнозов по "
"умолчанию"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:164
msgid "Added ability to fetch temperature units from system locale"
msgstr ""
"Добавлена возможность получения единиц измерения температуры из системной "
"локали"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:165
msgid "Fixed timezone format not being correctly read for local location time"
msgstr ""
"Исправлено некорректное чтение формата часового пояса для местного времени"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:176
msgid "Rewrote the weather plasmoid"
msgstr "Переписан плазмоид погоды"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:177
msgid "Use inline page indicator for flat mode forecasts"
msgstr ""
"Использован встроенный индикатор страницы для прогнозов в плоском режиме"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:178
msgid "Fix location ordering not persisting"
msgstr "Исправлено сохранение порядок расположений"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:187
msgid "Reworked the locations page to better handle long location names"
msgstr ""
"Переработана страница местоположений для лучшей обработки длинных названий"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:188
msgid "Add maximum width to dynamic forecast to better deal with widescreen"
msgstr ""
"Определена максимальная ширина для динамического прогноза для лучшей работы "
"с широкоэкранными дисплеями"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:189
msgid "Remove plasmoid (it is being reworked!)"
msgstr "Удалён виджет (ведётся переработка!)"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:190
msgid "Fixed default page not being loaded when new locations are added"
msgstr ""
"Исправлена ошибка загрузки страницы по умолчанию при добавлении новых "
"местоположений"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:191
msgid "Unify application settings location"
msgstr "Унифицировано расположение параметров приложения"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:192
msgid "Enable qml debugging when in debug mode"
msgstr "Добавлена возможность отладки QML в режиме отладки"

