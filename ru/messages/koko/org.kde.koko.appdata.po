#. (itstool) path: component/name
#: org.kde.koko.appdata.xml:13
msgid "Photos"
msgstr "Фотографии"

#. (itstool) path: component/summary
#: org.kde.koko.appdata.xml:14
msgid "Image Gallery"
msgstr "Галерея изображений"

#. (itstool) path: description/p
#: org.kde.koko.appdata.xml:16
msgid "An Image gallery application"
msgstr "Приложение для работы с галереей изображений"

#. (itstool) path: description/p
#: org.kde.koko.appdata.xml:72
msgid ""
"This release modernizes the settings page, updates the style of the album "
"page and adds a confirmation dialog before discarding image edits. This also "
"fixes the full screen and slideshow mode."
msgstr ""
"В этом выпуске обновлена страница настроек, изменён стиль страницы альбома и "
"добавлен диалог подтверждения перед отменой изменений изображения. Также "
"исправлены полноэкранный режим и режим слайд-шоу."

#. (itstool) path: ul/li
#: org.kde.koko.appdata.xml:85
msgid "Fixes related to window activation"
msgstr "Исправления, связанные с активацией окна"

#. (itstool) path: ul/li
#: org.kde.koko.appdata.xml:86
msgid "Various code improvements and bugfixes"
msgstr "Различные улучшения кода и исправления ошибок"

#. (itstool) path: ul/li
#: org.kde.koko.appdata.xml:97
msgid "Raise window on activation."
msgstr "Поднятие окна при активации."

#. (itstool) path: ul/li
#: org.kde.koko.appdata.xml:105
msgid "User interface improvements."
msgstr "Улучшения пользовательского интерфейса."

#. (itstool) path: ul/li
#: org.kde.koko.appdata.xml:106
msgid "Image resizing and cropping support improvements."
msgstr "Улучшена поддержка изменения размера и обрезки изображений."

#. (itstool) path: ul/li
#: org.kde.koko.appdata.xml:107
msgid "Improvements for SVG rendering"
msgstr "Улучшения отрисовки SVG"

#. (itstool) path: ul/li
#: org.kde.koko.appdata.xml:108
msgid "Support for color correction on X11"
msgstr "Поддержка коррекции цвета в X11"

#. (itstool) path: description/p
#: org.kde.koko.appdata.xml:120
msgid "This release contains only a small bugfix and updated translations."
msgstr "В этом выпуске исправлена небольшая ошибка и обновлены переводы."

#. (itstool) path: description/p
#: org.kde.koko.appdata.xml:127
msgid ""
"Initial release of Koko, an convergent image viewer for Plasma Mobile and "
"desktop"
msgstr ""
"Представлен первый выпуск Koko — универсального просмотрщика изображений для "
"Plasma Mobile и настольных систем"

