msgid "Phonebook"
msgstr "Телефонная книга"

#. (itstool) path: component/summary
#: org.kde.phonebook.metainfo.xml:5
msgid "View and edit contacts"
msgstr "Просмотр и редактирование контактов"

#. (itstool) path: component/developer_name
