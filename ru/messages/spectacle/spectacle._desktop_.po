msgctxt "Name"
msgid "Spectacle"
msgstr "Spectacle"

#: desktop/org.kde.spectacle.desktop.cmake:109
msgctxt "Comment"
msgid "Take screenshots and screen recordings"
msgstr "Создание снимков и записей экрана"

#: desktop/org.kde.spectacle.desktop.cmake:147
msgctxt "Keywords"
msgid "snapshot;capture;print;screenshot;snipping;snipping tool;snip;"
msgstr ""
"snapshot;capture;print;screenshot;snipping;snipping tool;snip;снимок;захват;"
"печать;снимок экрана;скриншот;обрезка;инструмент обрезки;обрезать;"

