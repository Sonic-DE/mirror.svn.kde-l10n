msgid "Configure navigation, number and layout of virtual desktops"
msgstr "Число, расположение и способ переключения рабочих столов"

#: src/kcms/effects/kcm_kwin_effects.json
msgctxt "Description"
msgid "Configure compositor settings for desktop effects"
msgstr "Настройка модуля обеспечения эффектов рабочего стола"

#: src/kcms/options/kcm_kwinoptions.json
msgctxt "Description"
msgid "Configure window actions and behavior"
msgstr "Настройка поведения окон"

#: src/kcms/rules/kcm_kwinrules.json
msgctxt "Description"
msgid "Individual Window Behavior"
msgstr "Особые параметры конкретных окон"

#: src/kcms/screenedges/kcm_kwinscreenedges.json
msgctxt "Description"
msgid "Configure active screen corners and edges"
msgstr "Настройка действий для краёв и углов экрана"

#: src/kcms/screenedges/kcm_kwintouchscreen.json
msgctxt "Description"
msgid "Configure touch screen swipe gestures"
msgstr "Настройка действий при проведении по сенсорному экрану"

#: src/kcms/scripts/kcm_kwin_scripts.json
msgctxt "Description"
msgid "Manage KWin scripts"
msgstr "Управление сценариями KWin"

#: src/kcms/tabbox/kcm_kwintabbox.json
msgctxt "Description"
msgid "Navigation Through Windows"
msgstr "Настройка переключателя окон"

#: src/kcms/virtualkeyboard/kcm_virtualkeyboard.json
msgctxt "Description"
msgid "Select which virtual keyboard to use"
msgstr "Выбор виртуальной клавиатуры"

#: src/kcms/xwayland/kcm_kwinxwayland.json
msgctxt "Description"
msgid "Select which keys will be globally available to legacy X11 apps"
msgstr "Поддержка передачи нажатий клавиш в устаревшие приложения X11"

#: src/plugins/blendchanges/metadata.json
msgctxt "Description"
msgid "Animates system style changes"
msgstr "Анимация изменения оформления"

#: src/plugins/blur/metadata.json
msgctxt "Description"
msgid "Blurs the background behind semi-transparent windows"
msgstr "Размывание фона под полупрозрачными окнами"

#: src/plugins/colorblindnesscorrection/metadata.json
msgctxt "Description"
msgid "Enhances color perception for color blindness"
msgstr "Улучшение восприятия цветов при цветовой слепоте"

#: src/plugins/colorpicker/metadata.json
msgctxt "Description"
msgid "Supports picking a color"
msgstr "Выбор цвета на экране"

#: src/plugins/desktopchangeosd/package/metadata.json
msgctxt "Description"
msgid "An on screen display indicating the desktop change"
msgstr "Экранные уведомления об изменении рабочего стола"

#: src/plugins/dialogparent/package/metadata.json
msgctxt "Description"
msgid "Darkens the parent window of the currently active dialog"
msgstr "Затемнение основного окна при показе диалога"

#: src/plugins/diminactive/metadata.json
msgctxt "Description"
msgid "Darken inactive windows"
msgstr "Затемнение неактивных окон"

#: src/plugins/dimscreen/package/metadata.json
msgctxt "Description"
msgid "Darkens the entire screen when requesting root privileges"
msgstr "Затемнение всего экрана при запросе привилегий суперпользователя"

#: src/plugins/eyeonscreen/package/metadata.json
msgctxt "Description"
msgid "Suck windows into the desktop"
msgstr "Втягивание окон в центр рабочего стола"

#: src/plugins/fadedesktop/package/metadata.json
msgctxt "Description"
msgid "Fade between virtual desktops when switching"
msgstr "Постепенная смена изображения при переключении на другой рабочий стол"

#: src/plugins/fade/package/metadata.json
msgctxt "Description"
msgid "Make windows fade in and out when they are shown or hidden"
msgstr ""
"Закрывающиеся окна будут становиться всё более прозрачными, а потом совсем "
"исчезать"

#: src/plugins/fadingpopups/package/metadata.json
msgctxt "Description"
msgid "Fade popups in and out"
msgstr "Изменение прозрачности всплывающих окон при их появлении и скрытии"

#: src/plugins/fallapart/metadata.json
msgctxt "Description"
msgid "Closed windows fall into pieces"
msgstr "Распад закрывающихся окон на части"

#: src/plugins/frozenapp/package/metadata.json
msgctxt "Description"
msgid "Desaturate windows of unresponsive (frozen) applications"
msgstr "Обесцвечивание окон приложений, не отвечающих на запросы"

#: src/plugins/fullscreen/package/metadata.json
msgctxt "Description"
msgid "Stretch windows going to and leaving full screen mode"
msgstr "Растягивание окон при переходе в полноэкранный режим и выходе из него"

#: src/plugins/glide/metadata.json
msgctxt "Description"
msgid "Glide windows as they appear or disappear"
msgstr "Эффект «глиссирования» окон при появлении и исчезновении"

#: src/plugins/hidecursor/metadata.json
msgctxt "Description"
msgid "Hide mouse cursor on inactivity or keyboard input"
msgstr "Сокрытие курсора мыши при простое или вводе с клавиатуры"

#: src/plugins/highlightwindow/metadata.json
msgctxt "Description"
msgid "Highlight the appropriate window when hovering over taskbar entries"
msgstr "Подсветка окна при наведении и соответствующем элементе в панели задач"

#: src/plugins/invert/metadata.json
msgctxt "Description"
msgid ""
"Inverts the color of the desktop and windows; activated with a keyboard "
"shortcut"
msgstr ""
"Инверсия цвета рабочего стола и окон; активируется нажатием комбинации клавиш"

#: src/plugins/kscreen/metadata.json
msgctxt "Description"
msgid "Helper Effect for KScreen"
msgstr "Вспомогательный эффект для KScreen"

#: src/plugins/login/package/metadata.json
msgctxt "Description"
msgid "Fade to the desktop when logging in"
msgstr "Постепенное появление рабочего стола при входе в систему"

#: src/plugins/logout/package/metadata.json
msgctxt "Description"
msgid "Fade to the logout screen"
msgstr "Постепенное появление экрана завершения работы"

#: src/plugins/magiclamp/metadata.json
msgctxt "Description"
msgid "Simulate a magic lamp when minimizing windows"
msgstr "Эффект волшебной лампы при сворачивании окон"

#: src/plugins/magnifier/metadata.json
msgctxt "Description"
msgid ""
"Magnify the section of the screen that is near the mouse cursor; activated "
"with a keyboard shortcut"
msgstr ""
"Увеличение части экрана у курсора мыши; активируется нажатием комбинации "
"клавиш"

#: src/plugins/maximize/package/metadata.json
msgctxt "Description"
msgid "Stretch windows when they are maximized or restored"
msgstr "Растягивание окна при распахивании или разворачивании"

#: src/plugins/minimizeall/package/metadata.json
msgctxt "Description"
msgid "Adds a shortcut to minimize and restore all windows"
msgstr ""
"Добавляет глобальную комбинацию клавиш для сворачивания и восстановления "
"всех окон"

#: src/plugins/mouseclick/metadata.json
msgctxt "Description"
msgid ""
"Creates an animation whenever a mouse button is clicked. This is useful for "
"screenrecordings/presentations. Activated with a keyboard shortcut"
msgstr ""
"Создание анимации при каждом щелчке мышью. Это удобно для записи видео с "
"экрана и для презентаций. Активируется нажатием комбинации клавиш"

#: src/plugins/mousemark/metadata.json
msgctxt "Description"
msgid ""
"Allows you to draw lines on the desktop; activated with a keyboard shortcut"
msgstr ""
"Рисование на экране курсором мыши; активируется нажатием комбинации клавиш"

#: src/plugins/outputlocator/metadata.json
msgctxt "Description"
msgid "Show screen names"
msgstr "Просмотр названий экранов"

#: src/plugins/overview/metadata.json
msgctxt "Description"
msgid ""
"Allows you to overview virtual desktops and windows; activated with a "
"keyboard shortcut"
msgstr ""
"Режим обзора виртуальных  столов и окон; активируется нажатием комбинации "
"клавиш"

#: src/plugins/scale/package/metadata.json
msgctxt "Description"
msgid "Make windows scale in and out when they are shown or hidden"
msgstr "Увеличение или уменьшение окон при их появлении и скрытии"

#: src/plugins/screenedge/metadata.json
msgctxt "Description"
msgid ""
"Highlights screen edges and corners that trigger actions when touched as the "
"cursor approaches them"
msgstr ""
"Выделение краёв и углов экрана, которые активируют действия, когда их "
"касается подведённый курсор"

#: src/plugins/screentransform/metadata.json
msgctxt "Description"
msgid "Animates display transformations"
msgstr "Анимация преобразований рабочего стола"

#: src/plugins/sessionquit/package/metadata.json
msgctxt "Description"
msgid "Keep the desktop background alive during logout until the end"
msgstr "Сохранение фона рабочего стола до окончания завершения сеанса"

#: src/plugins/shakecursor/metadata.json
msgctxt "Description"
msgid ""
"Makes the cursor larger when the pointer is quickly moved back and forth"
msgstr "Увеличение размера курсора при его быстром перемещении вперёд и назад"

#: src/plugins/sheet/metadata.json
msgctxt "Description"
msgid ""
"Make modal dialogs smoothly fly in and out when they are shown or hidden"
msgstr "Плавное появление и скрытие модальных диалогов"

#: src/plugins/showcompositing/metadata.json
msgctxt "Description"
msgid "Display if compositing is active"
msgstr "Индикатор активности графических эффектов"

#: src/plugins/showfps/metadata.json
msgctxt "Description"
msgid "Display KWin's performance in the corner of the screen"
msgstr "Индикатор производительности эффектов в углу экрана"

#: src/plugins/showpaint/metadata.json
msgctxt "Description"
msgid ""
"Highlight areas of the desktop that have been recently updated; activated "
"with a keyboard shortcut"
msgstr ""
"Подсветка обновляемых областей экрана; активируется нажатием комбинации "
"клавиш"

#: src/plugins/slideback/metadata.json
msgctxt "Description"
msgid "Slide back windows when another window is raised"
msgstr "При подъёме окна другие окна соскальзывают назад"

#: src/plugins/slide/metadata.json
msgctxt "Description"
msgid "Slide between virtual desktops when switching"
msgstr "Скольжение изображения при переключении на другой рабочий стол"

#: src/plugins/slidingpopups/metadata.json
msgctxt "Description"
msgid "Slide Plasma popups in and out"
msgstr "Скольжение всплывающих окон Plasma при их появлении и скрытии"

#: src/plugins/squash/package/metadata.json
msgctxt "Description"
msgid "Squash windows when they are minimized"
msgstr "Сжатие окна при сворачивании"

#: src/plugins/startupfeedback/metadata.json
msgctxt "Description"
msgid "Helper effect for startup feedback"
msgstr "Вспомогательный эффект для отклика запуска приложений"

#: src/plugins/synchronizeskipswitcher/package/metadata.json
msgctxt "Description"
msgid ""
"Hides all windows marked as Skip Taskbar to be also excluded from window "
"switchers (e.g. Alt+Tab)"
msgstr ""
"Скрывает все окна, не показываемые на панели задач, чтобы исключить их также "
"из переключателей окон (например, Alt+Tab)"

#: src/plugins/systembell/metadata.json
msgctxt "Description"
msgid "Provides the bell"
msgstr "Предоставление сигнала"

#: src/plugins/thumbnailaside/metadata.json
msgctxt "Description"
msgid ""
"Display window thumbnails on the edge of the screen; activated with a "
"keyboard shortcut"
msgstr ""
"Отображение миниатюр окон на краю экрана; активируется нажатием комбинации "
"клавиш"

#: src/plugins/tileseditor/metadata.json
msgctxt "Description"
msgid "Editor for the tiling areas"
msgstr ""
"Редактирование областей окон приложений в мозаичном режиме рабочего стола"

#: src/plugins/touchpoints/metadata.json
msgctxt "Description"
msgid "Visualize touch points"
msgstr "Визуализация событий касания экрана"

#: src/plugins/trackmouse/metadata.json
msgctxt "Description"
msgid ""
"Display a mouse cursor locating effect; activated with a keyboard shortcut"
msgstr ""
"Положение курсора мыши на экране; активируется нажатием комбинации клавиш"

#: src/plugins/translucency/package/metadata.json
msgctxt "Description"
msgid "Make windows translucent under different conditions"
msgstr "Использование полупрозрачности окон при разных событиях"

#: src/plugins/videowall/package/metadata.json
msgctxt "Description"
msgid ""
"Spans fullscreen video player over all attached screens to create a Video "
"Wall"
msgstr ""
"Для создания видеостены вывод видеопроигрывателя распределяется по всем "
"подключённым экранам"

#: src/plugins/windowaperture/package/metadata.json
msgctxt "Description"
msgid "Move windows into screen corners"
msgstr "Перемещение окон в углы экрана"

#: src/plugins/windowview/metadata.json
msgctxt "Description"
msgid "Zoom out until all opened windows can be displayed side-by-side"
msgstr "Просмотр миниатюр всех открытых окон рядом друг с другом"

#: src/plugins/wobblywindows/metadata.json
msgctxt "Description"
msgid "Deform windows while they are moving"
msgstr "Колыхание окна при его перемещении"

#: src/plugins/zoom/metadata.json
msgctxt "Description"
msgid "Magnify the entire desktop; activated with a keyboard shortcut"
msgstr ""
"Увеличение всего рабочего стола; активируется нажатием комбинации клавиш"

#: src/tabbox/switchers/thumbnail_grid/metadata.json
msgctxt "Description"
msgid "A window switcher layout using a small grid of thumbnails"
msgstr "Переключатель окон в виде сетки миниатюр окон"

