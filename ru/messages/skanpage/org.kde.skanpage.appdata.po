#. (itstool) path: component/name
#: org.kde.skanpage.appdata.xml:14
msgid "Skanpage"
msgstr "Skanpage"

#. (itstool) path: component/summary
#: org.kde.skanpage.appdata.xml:15
msgid "Scan multi-page documents and images"
msgstr "Сканирование многостраничных документов и изображений"

#. (itstool) path: description/p
#: org.kde.skanpage.appdata.xml:17
msgid ""
"Skanpage is a simple scanning application optimized for multi-page document "
"scanning. It can also scan and save single-page documents and images."
msgstr ""
"Skanpage — простое приложение для сканирования и сохранения документов и "
"изображений, состоящих из одной или нескольких страниц."

#. (itstool) path: description/p
#: org.kde.skanpage.appdata.xml:18
msgid "Features:"
msgstr "Возможности:"

#. (itstool) path: ul/li
#: org.kde.skanpage.appdata.xml:20
msgid "Scanning from flatbed and ADF scanners"
msgstr ""
"Поддержка планшетных сканеров и сканеров с устройством автоматической подачи;"

#. (itstool) path: ul/li
#: org.kde.skanpage.appdata.xml:21
msgid "Configurable options for scanning device"
msgstr "Настройка параметров сканирования;"

#. (itstool) path: ul/li
#: org.kde.skanpage.appdata.xml:22
msgid "Reordering, rotation, and deletion of scanned pages"
msgstr "Упорядочивание, вращение и удаление отсканированных страниц;"

#. (itstool) path: ul/li
#: org.kde.skanpage.appdata.xml:23
msgid "Saving to multi-page PDF documents and image files"
msgstr ""
"Поддержка формата PDF для сохранения документов и форматов файлов изображений"

