#~ msgstr ""
#~ "Поддержка простых преобразований изображения: поворот, отражение, "
#~ "переворот и изменение размера"

#~ msgid ""
#~ "Gwenview displaying an image, with additional metadata shown in the "
#~ "sidebar"
#~ msgstr ""
#~ "Просмотр изображения и дополнительных метаданных, показанных на боковой "
