#. (itstool) path: component/name
#: org.kde.kdiff3.appdata.xml:13
msgid "KDiff3"
msgstr "KDiff3"

#. (itstool) path: component/summary
#: org.kde.kdiff3.appdata.xml:14
msgid "A file and folder comparison and merge tool"
msgstr "Инструмент для сравнения и объединения файлов и папок"

#. (itstool) path: description/p
#: org.kde.kdiff3.appdata.xml:17
msgid "KDiff3 is a file and folder diff and merge tool which"
msgstr ""
" — это приложение для поиска различий между файлами и каталогами, которое:"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:19
msgid "compares and merges two or three text input files or folders,"
msgstr ""
"позволяет сравнивать и объединять два или три текстовых вводных файла или "
"папки;"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:20
msgid "shows the differences line by line and character by character(!),"
msgstr "позволяет просматривать различия построчно и посимвольно;"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:21
msgid "provides an automatic merge-facility,"
msgstr "поддерживает автоматическое объединение;"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:22
msgid "has an editor for comfortable solving of merge-conflicts,"
msgstr ""
"предоставляет редактор для комфортного разрешения конфликтов объединения;"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:23
msgid "provides network transparency via KIO,"
msgstr ""
"с помощью KIO поддерживает работу с файлами, расположенными на сетевых "
"ресурсах;"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:24
msgid "has options to highlight or hide changes in white-space or comments,"
msgstr ""
"предоставляет возможность подсветки или скрытия изменений в пробельных "
"символах или в комментариях;"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:25
msgid "supports Unicode, UTF-8 and other file encodings,"
msgstr "поддерживает Юникод, UTF-8 и другие кодировки файлов;"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:26
msgid "prints differences,"
msgstr "показывает различия;"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:27
msgid "supports version control keyword and history merging."
msgstr ""
"поддерживает ключевые слова систем контроля версий и объединение их историй."
