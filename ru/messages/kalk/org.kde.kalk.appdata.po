#. (itstool) path: component/name
#: org.kde.kalk.appdata.xml:12
msgid "Calculator"
msgstr "Калькулятор"

#. (itstool) path: component/summary
#: org.kde.kalk.appdata.xml:13
msgid "A feature rich calculator"
msgstr "Калькулятор с широкими возможностями"

#. (itstool) path: description/p
#: org.kde.kalk.appdata.xml:18
msgid "Kalk is a convergent calculator for Plasma."
msgstr "Kalk — мощный калькулятор для Plasma."

#. (itstool) path: screenshot/caption
#: org.kde.kalk.appdata.xml:22
msgid "Calculator Page"
msgstr "Страница калькулятора"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:95
msgid "Show decimal separator according to locale"
msgstr ""
"Вид десятичного разделителя в соответствии с региональными настройками;"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:96
msgid "Fix bug preventing input of comma"
msgstr "Исправлена ошибка, препятствующая вводу запятой;"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:104
msgid "General bugfixing and code quality improvements"
msgstr "Исправление ошибок и улучшение качества кода;"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:112
msgid "Rearrange trigonometric functions to be together"
msgstr ""
"Изменено расположение тригонометрических функций, чтобы они располагались "
"рядом;"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:113
msgid "Various user-interface improvements"
msgstr "Различные улучшения пользовательского интерфейса;"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:120
msgid "Rework sidebar design"
msgstr "Изменён дизайн боковой панели;"

#. (itstool) path: description/p
#: org.kde.kalk.appdata.xml:133
msgid "Changes:"
msgstr "Изменения:"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:135
msgid "Updated the application icon"
msgstr "Обновлён значок приложения;"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:136
msgid "Added support for parentheses keyboard input"
msgstr "Добавлена поддержка ввода скобок с клавиатуры;"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:137
msgid "Fixed the calculator drawer opening when the application opens"
msgstr "Исправлено открытие панели калькулятора при запуске приложения;"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:138
msgid ""
"Changed backspace icon to use a proper system icon instead of a font "
"provided one"
msgstr ""
"Изменён значок клавиши «Backspace» на системный вместо предоставленного "
"шрифтом;"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:139
msgid "Added keyboard support to unit converter"
msgstr "Добавлена поддержка клавиатуры в конвертере единиц измерения;"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:140
msgid "Fixed page change animation for binary calculator"
msgstr "Исправлена анимация переключения страниц для двоичного калькулятора;"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:141
msgid "Enabled qml debugging when compiled in debug mode"
msgstr "Включена отладка QML при компиляции в режиме отладки;"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:142
msgid "Added ability to recognize the decimal separator in other locales"
msgstr ""
"Добавлено распознавание десятичного разделителя в других языковых стандартах;"

