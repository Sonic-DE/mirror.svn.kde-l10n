#: src/helper/kcmgrub2.actions:2
msgctxt "Name"
msgid "GRUB2 Bootloader Control Module"
msgstr "Styringsmodul for GRUB2 oppstartslaster"

#: src/helper/kcmgrub2.actions:50
msgctxt "Name"
msgid "Restore the default GRUB2 Bootloader settings"
msgstr "Gjenopprett standard innstillinger for GRUB2 oppstartslaster"

#: src/helper/kcmgrub2.actions:94
msgctxt "Description"
msgid ""
"Administrator authorization is required to restore the default GRUB2 "
"Bootloader settings"
msgstr ""
"Det kreves autorisasjon som administrator for å gjenopprette standard "
"innstillinger for GRUB2 oppstartslaster"

#: src/helper/kcmgrub2.actions:141
msgctxt "Name"
msgid "Install the GRUB2 Bootloader"
msgstr "Installer GRUB2 oppstartslaster"

#: src/helper/kcmgrub2.actions:187
msgctxt "Description"
msgid "Administrator authorization is required to install the GRUB2 Bootloader"
msgstr ""
"Det kreves autorisasjon som administrator for å installere GRUB2 "
"oppstartslaster"

#: src/helper/kcmgrub2.actions:235
msgctxt "Name"
msgid "Load the GRUB2 Bootloader settings"
msgstr "Last inn innstillinger for GRUB2 oppstartslaster"

#: src/helper/kcmgrub2.actions:281
msgctxt "Description"
msgid ""
"Administrator authorization is required to load the GRUB2 Bootloader settings"
msgstr ""
"Det kreves autorisasjon som administrator for å laste inn innstillinger for "
"GRUB2 oppstartslaster"

#: src/helper/kcmgrub2.actions:329
msgctxt "Name"
msgid "Save the GRUB2 Bootloader settings"
msgstr "Lagre innstillinger for GRUB2 oppstartslaster"

#: src/helper/kcmgrub2.actions:374
msgctxt "Description"
msgid ""
"Administrator authorization is required to save the GRUB2 Bootloader settings"
msgstr ""
"Det kreves autorisasjon som administrator for å lagre innstillinger for "
"GRUB2 oppstartslaster"
