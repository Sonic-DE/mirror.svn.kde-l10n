#. Tag: para
#: index.docbook:17
#, no-c-format
msgid ""
"<acronym>ldap</acronym> is the lightweight directory access protocol. It "
"provides access to an X.500 directory, or to a stand-alone <acronym>LDAP</"
"acronym> server."
msgstr ""
"<acronym>ldap</acronym> er Lightweight Directory Access Protocol. Med ldap "
"får du tilgang til en X 500-katalog, eller til en frittstående "
"<acronym>LDAP</acronym>-tjener."

#. Tag: para
#: index.docbook:21
#, fuzzy, no-c-format
#| msgid "You can use the ldap kioslave as follows:"
msgid "You can use the ldap KIO worker as follows:"
msgstr "Du kan bruke kioslaven ldap slik:"

#. Tag: para
#: index.docbook:23
#, no-c-format
msgid ""
"<userinput>ldap://host:port/ou=People,o=where,c=de??sub</userinput> for a "
"subtree-query"
msgstr ""
"<userinput>ldap://host:port/ou=folk,o=hvor,c=no??sub</userinput> for å slå "
"opp i et sub-tre."

#. Tag: para
#: index.docbook:26
#, no-c-format
msgid ""
"or <userinput>ldap://host:port/cn=MM,ou=People,o=where,c=de??base</"
"userinput> for a complete branch."
msgstr ""
"eller <userinput>ldap://host:port/cn=MM,ou=Folk,o=hvor,c=no??base</"
"userinput> for en fullstendig gren."
