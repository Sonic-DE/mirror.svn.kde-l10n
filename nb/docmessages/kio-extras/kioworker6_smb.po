#. Tag: para
#: index.docbook:18
#, fuzzy, no-c-format
#| msgid ""
#| "The smb ioslave enables you to browse the shares of a &Windows; (or "
#| "Samba) network."
msgid ""
"The smb worker enables you to browse the shares of a &Windows; (or Samba) "
"network."
msgstr ""
"Med kioslaven smb kan du bla gjennom delte områder på et &Windows; (eller "
"Samba-) nettverk."

#. Tag: para
#: index.docbook:23
#, no-c-format
msgid ""
"To see the workgroups, enter <userinput><command>smb:/</command></userinput>."
msgstr ""
"For å se arbeidsgruppene taster du inn <userinput><command>smb:/</command></"
"userinput>."

#. Tag: para
#: index.docbook:27
#, no-c-format
msgid ""
"<userinput><command>smb://</command><replaceable>a_workgroup</replaceable></"
"userinput> will list the hosts in this workgroup."
msgstr ""
"<userinput><command>smb://</command><replaceable>a_workgroup</replaceable></"
"userinput> lister vertene i den arbeidsgruppa."

#. Tag: para
#: index.docbook:31
#, no-c-format
msgid ""
"To see the shares of a host, enter <userinput><command>smb://</"
"command><replaceable>the_host</replaceable></userinput> or "
"<userinput><command>smb:/</command><replaceable>a_workgroup</replaceable>/"
"<replaceable>the_host</replaceable></userinput>."
msgstr ""
"For å se de delte områdene på en bestemt vert taster du "
"<userinput><command>smb://</command><replaceable>verten</replaceable></"
"userinput> eller <userinput><command>smb:/</command><replaceable>en_gruppe</"
"replaceable>/<replaceable>verten</replaceable></userinput>."

#. Tag: para
#: index.docbook:37
#, no-c-format
msgid ""
"To access a share directly enter <userinput><command>smb://</"
"command><replaceable>the_host/the_share</replaceable></userinput> or "
"<userinput><command>smb:/</command><replaceable>a_workgroup</replaceable>/"
"<replaceable>the_host</replaceable>/<replaceable>the_share</replaceable></"
"userinput>"
msgstr ""
"For å få direkte tilgang til en delt ressurs taster du "
"<userinput><command>smb://</command><replaceable>verten/området</"
"replaceable></userinput>  eller <userinput><command>smb:/</"
"command><replaceable>en_gruppe</replaceable>/<replaceable>verten</"
"replaceable>/<replaceable>området</replaceable></userinput>"

#. Tag: para
#: index.docbook:44
#, fuzzy, no-c-format
#| msgid ""
#| "The smb ioslave requires that you have libsmbclient to use this ioslave."
msgid "The smb worker requires that you have libsmbclient to use this worker."
msgstr "Du må ha libsmbclient installert for å bruke denne ioslaven."

#. Tag: para
#: index.docbook:48
#, no-c-format
msgid ""
"You can set your default user name and password in the &systemsettings; "
"category <guilabel>Network</guilabel> in "
"<menuchoice><guisubmenu>Connectivity</guisubmenu><guimenuitem> Windows "
"Shares</guimenuitem></menuchoice>. This is especially useful if you are a "
"member of a &Windows; <acronym>NT</acronym> domain. There you can also set "
"your workgroup name, but in most cases this is not required. The worker will "
"ask for your username and password if a default is not set."
msgstr ""
