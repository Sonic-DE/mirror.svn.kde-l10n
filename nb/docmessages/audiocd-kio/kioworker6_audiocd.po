#, no-c-format
msgid "audiocd"
msgstr "audiocd"

#. Tag: author
#: index.docbook:12
#, no-c-format
msgid "&Rik.Hemsley; &Rik.Hemsley.mail;"
msgstr ""

#. Tag: personname
#: index.docbook:13
#, no-c-format
msgid "<firstname>Benjamin</firstname><surname>Meyer</surname>"
msgstr ""

#. Tag: trans_comment
#: index.docbook:14
#, no-c-format
msgid "ROLES_OF_TRANSLATORS"
msgstr ""

