#: data/org.kde.yakuake.desktop:2
msgctxt "Name"
msgid "Yakuake"
msgstr "याकुआके"

#: data/org.kde.yakuake.desktop:65
msgctxt "GenericName"
msgid "Drop-down Terminal"
msgstr "खाली येणारा टर्मिनल"

#: data/org.kde.yakuake.desktop:128
msgctxt "Comment"
msgid "A drop-down terminal emulator based on KDE Konsole technology."
msgstr "केडीई कंसोल तंत्रज्ञानावर आधारित खाली येणारा टर्मिनल एम्युलेटर."

#: data/yakuake.notifyrc:4
msgctxt "Comment"
msgid "Yakuake"
msgstr "याकुआके"

#: data/yakuake.notifyrc:63
msgctxt "Name"
msgid "Silence detected"
msgstr "विराम आढळले"

#: data/yakuake.notifyrc:118
msgctxt "Comment"
msgid "Silence detected in a monitored terminal or session"
msgstr "नियंत्रीत टर्मिनल किंवा सत्र अंतर्गत विराम आढळले"

#: data/yakuake.notifyrc:175
msgctxt "Name"
msgid "Activity detected"
msgstr "क्रिया आढळले"

#: data/yakuake.notifyrc:230
msgctxt "Comment"
msgid "Activity detected in a monitored terminal or session"
msgstr "नियंत्रीत टर्मिनल किंवा सत्र अंतर्गत क्रिया आढळले"

#: data/yakuake.notifyrc:287
msgctxt "Name"
msgid "Bell in Visible Session"
msgstr "दृश्यस्पाद सत्र आढळल्यास घंटी वाजवा"

#: data/yakuake.notifyrc:344
msgctxt "Comment"
msgid "Bell emitted within a visible session"
msgstr "एक दृश्यास्पद सत्रच्या अंतर्गत घंटी वाजवा"

#: data/yakuake.notifyrc:404
msgctxt "Name"
msgid "Bell in Non-Visible Session"
msgstr "विनादृश्यास्पद सत्रच्या अंतर्गत घंटी वाजवा"

#: data/yakuake.notifyrc:461
msgctxt "Comment"
msgid "Bell emitted within a non-visible session"
msgstr "विनादृश्यस्पाद सत्र अंतर्गत घंटी वाजवा"

#~ msgctxt "Name"
#~ msgid "Startup"
#~ msgstr "सुरुवात"

#~ msgctxt "Comment"
#~ msgid "Yakuake has started"
#~ msgstr "याकुआके सुरु झाला आहे"
