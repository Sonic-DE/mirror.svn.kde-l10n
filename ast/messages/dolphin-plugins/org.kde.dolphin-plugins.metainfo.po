msgid ""
"Dolphin integration for revision control systems, Dropbox, and disk images"
msgstr ""

#. (itstool) path: description/p
#: org.kde.dolphin-plugins.metainfo.xml:10
msgid ""
"These plugins integrate Dolphin with the revision control systems Bazaar, "
"Mercurial and Git. A Dropbox plugin gives action items to keep your files "
"synced to the Dropbox service. A disk image integration plugin adds a mount "
"or unmount action."
msgstr ""
