#. Tag: title
#: man-kmymoney.1.docbook:121
#, no-c-format
msgid "Description"
msgstr "Açıklama"

#. Tag: para
#: man-kmymoney.1.docbook:123
#, no-c-format
msgid ""
"&kmymoney; is the Personal Finance Manager by &kde;. It provides the "
"functions required to balance your checkbooks, manage your personal loans "
"and categories your incomes and expenses using a checkbook style graphical "
"user interface."
msgstr ""
"&kmymoney;, &kde; tarafından yapılan kişisel finans yöneticisidir. "
"Çeklerinizin mutabakatını yapmak, kişisel kredilerinizi yönetmek ve çek "
"defteri tarzı bir grafiksel arayüz kullanarak gelirlerinizi ve giderlerinizi "
"yönetmek üzere gerekli işlevlere sahiptir."

#. Tag: title
#: man-kmymoney.1.docbook:131
#, no-c-format
msgid "Options"
msgstr "Seçenekler"

#. Tag: option
#: man-kmymoney.1.docbook:136
#, no-c-format
msgid "--lang"
msgstr "--lang"

#. Tag: para
#: man-kmymoney.1.docbook:138
#, no-c-format
msgid "Language to be used"
msgstr "Kullanılacak dil"

#. Tag: option
#: man-kmymoney.1.docbook:143
#, no-c-format
msgid "<option>-n</option>"
msgstr "<option>-n</option>"

#. Tag: para
#: man-kmymoney.1.docbook:145
#, no-c-format
msgid "Do not open last used file"
msgstr "Son kullanılan dosyayı açma"

#. Tag: option
#: man-kmymoney.1.docbook:150
#, no-c-format
msgid "--timers"
msgstr "--timers"

#. Tag: para
#: man-kmymoney.1.docbook:152
#, no-c-format
msgid "Enable performance timers"
msgstr "Başarım sayaçlarını etkinleştir"

#. Tag: option
#: man-kmymoney.1.docbook:157
#, no-c-format
msgid "--nocatch"
msgstr "--nocatch"

#. Tag: para
#: man-kmymoney.1.docbook:159
#, no-c-format
msgid "Do not globally catch uncaught exceptions"
msgstr "Yakalanmamış istisnaları global olarak yakalama"

#. Tag: option
#: man-kmymoney.1.docbook:164
#, no-c-format
msgid "--trace"
msgstr "--trace"

#. Tag: para
#: man-kmymoney.1.docbook:166
#, no-c-format
msgid ""
"Turn on program traces. This option is only available when &kmymoney; is "
"compiled in debug mode."
msgstr "Program izlerini aç. &kmymoney; hata ayıklama kipinde geçerlidir."

#. Tag: option
#: man-kmymoney.1.docbook:174
#, no-c-format
msgid "--dump-actions"
msgstr "--dump-actions"

#. Tag: para
#: man-kmymoney.1.docbook:176
#, no-c-format
msgid ""
"Dump the names of all defined QAction objects to stdout and quit. This "
"option is only available when &kmymoney; is compiled in debug mode."
msgstr ""
"Tüm tanımlı QAction nesnelerini stdout’a dök ve çık. &kmymoney; hata "
"ayıklama kipinde geçerlidir."

