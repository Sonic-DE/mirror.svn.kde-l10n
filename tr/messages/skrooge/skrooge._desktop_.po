"This event is triggered when a neutral message (information) is displayed"
msgstr "Bu olay, bir nötr ileti (bilgi) görüntülendiğinde tetiklenir"

#: skrooge/skrooge.notifyrc:229
msgctxt "Name"
msgid "Positive message"
msgstr "Olumlu ileti"

#: skrooge/skrooge.notifyrc:262
msgctxt "Comment"
msgid ""
"This event is triggered when a positive action is done (example: creation of "
"an operation) or a positive message is displayed"
msgstr ""
"Bu olay, bir olumlu eylem gerçekleştirildiğinde (örn. bir işlem oluşturma) "
"veya bir olumlu ileti görüntülendiğinde tetiklenir"
