msgid "Changes:"
msgstr "Değişiklikler:"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:161
msgid "Performance improvements in Dynamic view"
msgstr "Devingen görünümde başarım iyileştirmeleri"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:162
msgid "Dynamic view action bar rewritten to be inline to content"
msgstr ""
"Devingen görünüm eylem çubuğu, içeriğe paralel olacak şekilde yeniden "
"yazıldı."

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:163
msgid "Allow setting non-current location in default forecasts page"
msgstr ""
"Öntanımlı tahminler sayfasında geçerli olmayan bir konum ayarlanmasına izin "
"veriliyor."

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:164
msgid "Added ability to fetch temperature units from system locale"
msgstr "Sistem yerel ayarlarından sıcaklık birimlerini alma özelliği eklendi."

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:165
msgid "Fixed timezone format not being correctly read for local location time"
msgstr ""
"Yerel konum saati için saat dilimi biçiminin doğru okunamaması sorunu "
"düzeltildi."

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:176
msgid "Rewrote the weather plasmoid"
msgstr "Hava durumu Plasmoid’i yeniden yazıldı."

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:177
msgid "Use inline page indicator for flat mode forecasts"
msgstr "Düz kip tahminleri için satır içi sayfa göstergesi kullanılıyor."

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:178
msgid "Fix location ordering not persisting"
msgstr "Konum sıralamasının kalıcı olmaması sorunu düzeltildi."

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:187
msgid "Reworked the locations page to better handle long location names"
msgstr ""
"Konumlar sayfası, uzun konum adlarını daha iyi işleyecek şekilde yeniden "
"düzenlendi."

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:188
msgid "Add maximum width to dynamic forecast to better deal with widescreen"
msgstr ""
"Geniş ekranlarla daha iyi başa çıkmak için devingen tahmine maksimum "
"genişlik eklendi."

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:189
msgid "Remove plasmoid (it is being reworked!)"
msgstr "Plasmoid kaldırıldı (yeniden yazılıyor)."

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:190
msgid "Fixed default page not being loaded when new locations are added"
msgstr ""
"Yeni konumlar eklendiğinde öntanımlı sayfanın yüklenmemesi sorunu düzeltildi."

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:191
