#. (itstool) path: component/summary
#: org.kde.plasma.disks.metainfo.xml:12
msgid "Hard disk health monitoring for KDE Plasma"
msgstr "Monitorizarea sănătății discurilor pentru Plasma KDE"

#. (itstool) path: description/p
#: org.kde.plasma.disks.metainfo.xml:14
msgid ""
"Plasma Disks monitors S.M.A.R.T. data of disks and alerts the user when "
"signs of imminent failure appear."
msgstr ""
"Discuri Plasma monitorizează datele S.M.A.R.T. ale discurilor și alertează "
"utilizatorul la apariția semnelor de defecțiune iminentă."

#. (itstool) path: screenshot/caption
