msgid "KDialog"
msgstr "KDialog"

#. (itstool) path: component/summary
#: org.kde.kdialog.metainfo.xml:7
msgid "Display dialog boxes from shell scripts"
msgstr "Afișează casete de dialog din scripturi de consolă"

#. (itstool) path: description/p
#: org.kde.kdialog.metainfo.xml:9
msgid ""
"KDialog allows you to display dialog boxes from shell scripts. The syntax is "
"very much inspired from the \"dialog\" command (which shows text mode "
"dialogs)."
msgstr ""
"KDialog permite afișarea casetelor de dialog din scripturi de consolă. "
"Sintaxa e inspirată din comanda „dialog” (care arată dialoguri în regim "
"textual)."
