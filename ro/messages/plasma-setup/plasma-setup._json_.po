#: modules/account/metadata.json
msgctxt "Description"
msgid "Allow the user to set the account name."
msgstr "Permite utilizatorului să-și stabilească denumirea contului."

#: modules/cellular/metadata.json
msgctxt "Description"
msgid "Allow the user to configure the cellular network."
msgstr "Permite utilizatorului să-și configureze rețeaua celulară."

#: modules/finished/metadata.json
msgctxt "Description"
msgid ""
"Shown when the initial system setup is completed, and the user can commit "
"the changes."
msgstr ""
"Arătat când configurarea inițială a sistemului e completă și utilizatorul "
"poate comite modificările."

#: modules/hostname/metadata.json
msgctxt "Description"
msgid "Allow the user to set the system hostname."
msgstr "Permite utilizatorului să stabilească numele de gazdă al sistemului."

#: modules/keyboard/metadata.json
msgctxt "Description"
msgid "Allow the user to choose the keyboard layout."
msgstr "Permite utilizatorului să aleagă aranjamentul tastaturii."

#: modules/language/metadata.json
msgctxt "Description"
msgid "Allow the user to set the system language."
msgstr "Permite utilizatorului să stabilească limba sistemului."

#: modules/prepare/metadata.json
msgctxt "Description"
msgid "Allows the user to configure the environment before using it."
msgstr "Permite utilizatorului să configureze mediul înainte de a-l folosi."

#: modules/time/metadata.json
msgctxt "Description"
msgid "Allow the user to set the timezone."
msgstr "Permite utilizatorului să stabilească fusul orar."

#: modules/wifi/metadata.json
msgctxt "Description"
msgid "Allow the user to connect to a Wi-Fi network."
msgstr "Permite utilizatorului să se conecteze la o rețea Wi-Fi."

