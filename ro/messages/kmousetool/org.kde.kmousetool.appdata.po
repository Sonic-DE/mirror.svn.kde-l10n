#. (itstool) path: component/name
#: org.kde.kmousetool.appdata.xml:9
msgid "KMouseTool"
msgstr "KMouseTool"

#. (itstool) path: component/summary
#: org.kde.kmousetool.appdata.xml:10
msgid "Automatic clicks to reduce the effects of repetitive strain injury"
msgstr ""
"Face clicuri automate pentru a reduce efectele leziunilor de încordare "
"repetitivă"

#. (itstool) path: description/p
#: org.kde.kmousetool.appdata.xml:12
msgid ""
"KMouseTool clicks the mouse for you, so you don't have to. KMouseTool works "
"with any mouse or pointing device."
msgstr ""
"KMouseTool apasă butonul mausului pentru dumneavoastră, ca să nu o faceți "
"singur. KMouseTool funcționează cu orice maus sau dispozitiv de indicare."
