#. (itstool) path: component/name
#: org.kde.dragonplayer.appdata.xml:9
msgid "Dragon Player"
msgstr "Dragon Player"

#. (itstool) path: component/summary
#: org.kde.dragonplayer.appdata.xml:10
msgid "Play video files and streams"
msgstr "Redă fișiere și fluxuri video"

#. (itstool) path: description/p
#: org.kde.dragonplayer.appdata.xml:12
msgid ""
"Dragon Player is a video player focusing on simplicity instead of features. "
"Its easy-to-use interface is designed to get out of your way and simply play "
"your video files and streams."
msgstr ""
"Dragon Player e un lector video orientat spre simplitate în loc de "
"caracteristici. Interfața sa simplă e proiectată să nu vă stea în cale și "
"doar să redea fișiere și fluxuri video."

#. (itstool) path: description/p
#: org.kde.dragonplayer.appdata.xml:15
msgid "Features:"
msgstr "Caracteristici:"

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:17
msgid ""
"Click to play or pause, and double-click to enter or exit full screen mode."
msgstr ""
"Apăsați pentru a reda sau întrerupe, apăsați dublu pentru a intra sau ieși "
"din regimul de ecran complet"

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:18
msgid ""
"Choose the subtitle language, and automatically load the right one for your "
"language, if possible."
msgstr ""
"Alegeți limba subtilului și cel potrivit va fi încărcat automat atunci când "
"e posibil."

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:19
msgid "Choose the audio track."
msgstr "Alegeți pista de sunet."

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:20
msgid "Choose the video track."
msgstr "Alegeți pista de imagine."

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:21
msgid "Adjust the volume by scrolling."
msgstr "Ajustați volumul prin derulare."

#~ msgid "Video player with focus on simplicity"
#~ msgstr "Lector video orientat spre simplitate"

#~ msgid "Simple Interface"
#~ msgstr "Interfață simplă"

#~ msgid ""
#~ "Resuming videos: Starts playing a video where you were watching it last "
#~ "time"
#~ msgstr ""
#~ "Reluarea videoclipurilor: Începe redarea unui videoclip de unde îl "
#~ "vizionați ultima dată"

#~ msgid ""
#~ "Support for subtitles: Automatically loads subtitles with the matching "
#~ "name"
#~ msgstr ""
#~ "Suport pentru subtitre: Încarcă automat subtitre cu denumirea potrivită"

#~ msgid "Video display settings (brightness, contrast)"
#~ msgstr "Configurări afișare video (luminozitate, contrast)"

#~ msgid ""
#~ "Due to using Solid and Phonon DragonPlayer is independent of any "
#~ "multimedia framework or hardware abstraction layer"
#~ msgstr ""
#~ "Datorită folosirii Solid și Phonon, Dragon Player e independent de vreo "
#~ "platformă multimedia sau strat de abstractizare a echipamentului."

#~ msgid "Supports playing CDs and DVDs"
#~ msgstr "Susține redarea CD-urilor și DVD-urilor"
