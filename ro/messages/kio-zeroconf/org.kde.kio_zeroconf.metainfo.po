#: org.kde.kio_zeroconf.metainfo.xml:9
msgid "Zeroconf Support"
msgstr "Suport pentru Zeroconf"

#. (itstool) path: component/summary
#: org.kde.kio_zeroconf.metainfo.xml:10
msgid "Browse local network services in Dolphin's Network page"
msgstr "Răsfoiește servicii de rețea locală în pagina Rețea din Dolphin"

#. (itstool) path: description/p
#: org.kde.kio_zeroconf.metainfo.xml:12
msgid ""
"Adds an entry to Dolphin's Network page to show local services such as "
"printers which advertise themselves with DNSSD (called Avahi or Bonjour by "
"other projects)."
msgstr ""
"Adaugă o înregistrare la pagina Rețea din Dolphin ce arată servicii locale "
"cum ar fi imprimante ce se anunță prin DNSSD (numit Avahi sau Bonjour în "
"alte proiecte)."
