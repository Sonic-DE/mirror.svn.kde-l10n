#. (itstool) path: component/name
#: org.kde.dragonplayer.appdata.xml:9
msgid "Dragon Player"
msgstr "Dragon Player"

#. (itstool) path: component/summary
#: org.kde.dragonplayer.appdata.xml:10
msgid "Play video files and streams"
msgstr "Riproduci file e flussi video"

#. (itstool) path: description/p
#: org.kde.dragonplayer.appdata.xml:12
msgid ""
"Dragon Player is a video player focusing on simplicity instead of features. "
"Its easy-to-use interface is designed to get out of your way and simply play "
"your video files and streams."
msgstr ""
"Dragon Player è un lettore video il cui obiettivo è la semplicità, anziché "
"la molteplicità di funzioni. La sua interfaccia semplice è progettata per "
"non metterti in difficoltà e per permetterti semplicemente di riprodurre i "
"file multimediali."

#. (itstool) path: description/p
#: org.kde.dragonplayer.appdata.xml:15
msgid "Features:"
msgstr "Caratteristiche:"

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:17
msgid ""
"Click to play or pause, and double-click to enter or exit full screen mode."
msgstr ""
"Fai clic per riprodurre o mettere in pausa e fai doppio clic per entrare o "
"uscire dalla modalità a schermo intero."

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:18
msgid ""
"Choose the subtitle language, and automatically load the right one for your "
"language, if possible."
msgstr ""
"Seleziona la lingua dei sottotitoli e, se possibile, carica automaticamente "
"quella giusta per la tua lingua."

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:19
msgid "Choose the audio track."
msgstr "Scegli la traccia audio."

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:20
msgid "Choose the video track."
msgstr "Scegli la traccia video."

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:21
msgid "Adjust the volume by scrolling."
msgstr "Regola il volume scorrendo."

#~ msgid "Video player with focus on simplicity"
#~ msgstr "Lettore video con l'obiettivo della semplicità"

#~ msgid "Simple Interface"
#~ msgstr "Interfaccia semplice"

#~ msgid ""
#~ "Resuming videos: Starts playing a video where you were watching it last "
#~ "time"
#~ msgstr ""
#~ "Riavvio del video: avvia la riproduzione video dal punto in cui l'avevi "
#~ "interrotta l'ultima volta"

#~ msgid ""
#~ "Support for subtitles: Automatically loads subtitles with the matching "
#~ "name"
#~ msgstr ""
#~ "Supporto sottotitoli: carica automaticamente i sottotitoli che "
#~ "corrispondono al nome del video"

#~ msgid "Video display settings (brightness, contrast)"
#~ msgstr "Impostazioni di visualizzazione (luminosità, contrasto)"

#~ msgid ""
#~ "Due to using Solid and Phonon DragonPlayer is independent of any "
#~ "multimedia framework or hardware abstraction layer"
#~ msgstr ""
#~ "Grazie all'uso di Solid e Phonon, DragonPlayer è indipendente da "
#~ "qualsiasi infrastruttura multimediale o livello di astrazione hardware"

#~ msgid "Supports playing CDs and DVDs"
#~ msgstr "Supporto per la riproduzione di CD e DVD"
