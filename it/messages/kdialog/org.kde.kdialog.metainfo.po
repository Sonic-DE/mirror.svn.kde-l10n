msgid "KDialog"
msgstr "KDialog"

#. (itstool) path: component/summary
#: org.kde.kdialog.metainfo.xml:7
msgid "Display dialog boxes from shell scripts"
msgstr "Visualizza finestre di dialogo da script di shell"

#. (itstool) path: description/p
#: org.kde.kdialog.metainfo.xml:9
msgid ""
"KDialog allows you to display dialog boxes from shell scripts. The syntax is "
"very much inspired from the \"dialog\" command (which shows text mode "
"dialogs)."
msgstr ""
"KDialog ti permette di visualizzare delle finestre di dialogo da script di "
"shell. La sintassi prende decisamente ispirazione dal comando «dialog» (che "
"mostra finestre in modalità testuale)."
