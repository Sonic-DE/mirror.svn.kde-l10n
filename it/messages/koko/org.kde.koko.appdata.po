msgid "Photos"
msgstr "Foto"

#. (itstool) path: component/summary
#: org.kde.koko.appdata.xml:14
msgid "Image Gallery"
msgstr "Galleria di immagini"

#. (itstool) path: description/p
#: org.kde.koko.appdata.xml:16
msgid "An Image gallery application"
msgstr "Un'applicazione per gallerie di immagini"

#. (itstool) path: description/p
#: org.kde.koko.appdata.xml:72
msgid ""
"This release modernizes the settings page, updates the style of the album "
"page and adds a confirmation dialog before discarding image edits. This also "
"fixes the full screen and slideshow mode."
msgstr ""
"Questa versione modernizza la pagina delle impostazioni, aggiorna lo stile "
"della pagina degli album, e aggiunge una finestra di conferma prima di "
"eliminare le modifiche alle immagini. Inoltre, corregge la modalità a "
"schermo intero e la modalità presentazione."

#. (itstool) path: ul/li
#: org.kde.koko.appdata.xml:85
msgid "Fixes related to window activation"
msgstr "Correzioni in merito all'attivazione della finestra"

#. (itstool) path: ul/li
#: org.kde.koko.appdata.xml:86
msgid "Various code improvements and bugfixes"
msgstr "Vari miglioramenti al codice, e correzioni di bug"

#. (itstool) path: ul/li
#: org.kde.koko.appdata.xml:97
msgid "Raise window on activation."
msgstr "Alza la finestra all'attivazione."

#. (itstool) path: ul/li
#: org.kde.koko.appdata.xml:105
msgid "User interface improvements."
msgstr "Miglioramenti all'interfaccia utente."

#. (itstool) path: ul/li
#: org.kde.koko.appdata.xml:106
msgid "Image resizing and cropping support improvements."
msgstr ""
"Miglioramenti al ridimensionamento delle immagini e al supporto al ritaglio."

#. (itstool) path: ul/li
#: org.kde.koko.appdata.xml:107
msgid "Improvements for SVG rendering"
msgstr "Miglioramenti al rendering SVG"

#. (itstool) path: ul/li
#: org.kde.koko.appdata.xml:108
msgid "Support for color correction on X11"
msgstr "Supporto alla correzione dei colori in X11"

#. (itstool) path: description/p
#: org.kde.koko.appdata.xml:120
msgid "This release contains only a small bugfix and updated translations."
msgstr ""
"Questa versione contiene solo una piccola correzione di bug e aggiornamenti "
"alle traduzioni."

#. (itstool) path: description/p
#: org.kde.koko.appdata.xml:127
msgid ""
"Initial release of Koko, an convergent image viewer for Plasma Mobile and "
"desktop"
msgstr ""
"Versione iniziale di Koko, un semplice visualizzatore di immagini per Plasma "
"Mobile e desktop"

