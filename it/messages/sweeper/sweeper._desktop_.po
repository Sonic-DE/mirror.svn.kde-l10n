#: org.kde.sweeper.desktop:8
msgctxt "Name"
msgid "Sweeper"
msgstr "Spazzino"

#: org.kde.sweeper.desktop:75
msgctxt "GenericName"
msgid "System Cleaner"
msgstr "Pulizia del sistema e riservatezza dei dati"

#: org.kde.sweeper.desktop:142
msgctxt "Comment"
msgid ""
"Helps to clean unwanted traces the user leaves on the system and to regain "
"disk space removing unused temporary files"
msgstr ""
"Aiuta a cancellare le tracce indesiderate che l'utente lascia nel sistema ed "
"a riguadagnare spazio su disco rimuovendo i file temporanei non usati"
