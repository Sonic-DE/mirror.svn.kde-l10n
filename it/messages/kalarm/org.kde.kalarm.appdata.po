#: org.kde.kalarm.appdata.xml:176 org.kde.kalarm.appdata.xml:184
#: org.kde.kalarm.appdata.xml:194 org.kde.kalarm.appdata.xml:202
#: org.kde.kalarm.appdata.xml:211
msgid "Release description"
msgstr "Descrizione del rilascio"

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:43
msgid "Fix sound files being played at the wrong volume when using VLC."
msgstr ""
"Correzione della riproduzione di file audio con il volume sbagliato quando "
"viene usato VLC."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:51
msgid ""
"Fix hang evaluating recurring date-only alarms when start-of-day time is non-"
"zero."
msgstr ""
"Correzione del blocco durante la valutazione di avvisi ricorrenti senza "
"orario quando l'ora di inizio della giornata non è zero."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:52
msgid ""
"Fix hang evaluating next recurrence time for time zones with daylight "
"savings time."
msgstr ""
"Correzione del blocco durante la valutazione del successivo orario di "
"ricorrenza per i fusi orari con ora legale."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:60
msgid "Prevent multiple Defer Alarm dialogs for the same event."
msgstr ""
"Prevenzione di finestre di rinvio avviso multiple per lo stesso evento."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:61
msgid ""
"If Defer is disabled for a notification alarm, don't show two Edit buttons."
msgstr ""
"Se il rinvio è disabilito per un avviso di notifica, non mostrare due "
"pulsanti di modifica."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:69
msgid ""
"If a recurrence is suppressed by work time/holidays/exception, suppress its "
"sub-repetitions."
msgstr ""
"Se la ricorrenza è rimossa in base a orari di lavoro/festività/eccezioni, ne "
"sono rimosse anche le sotto-ripetizioni."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:70
msgid ""
"Improvements and bug fixes to recurrence/work time/holidays calculations."
msgstr ""
"Miglioramenti e correzioni di bug nel calcolo di ricorrenze/orari lavorativi/"
"festività."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:71
msgid "Fix formatting of user messages which showed HTML tags."
msgstr "Correzione della formattazione di messaggi utente contenenti tag HTML."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:72
msgid ""
"Distinguish between daily and minutely sub-repetitions in alarm calendar."
msgstr ""
"Vengono distinte le sotto-ripetizioni ogni giorno/ogni minuto nel calendario "
"degli avvisi."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:73
msgid ""
"Only mark calendars as 'KeepFormat' if the user declines to update them."
msgstr ""
"I calendari vengono marcati come «KeepFormat« solo se l'utente rifiuta di "
"aggiornarli."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:82
msgid ""
"If an alarm is late-cancelled, don't remove the event if a sub-repetition is "
"still due."
msgstr ""
"Se è un avviso viene annullato in ritardo, non viene rimosso l'evento se ci "
"sono ancora sotto-ripetizioni che si devono attivare."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:83
msgid ""
"Fix infinite loop when alarms trigger, if they are read-only or if the "
"calendar is non-writable."
msgstr ""
"Correzione di un ciclo infinito quando si attivano degli avvisi in solo "
"lettura o il cui calendario non è scrivibile."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:84
msgid ""
"In edit dialog, don't display high accuracy warning if start time is before "
"now."
msgstr ""
"Nelle finestra di modifica, non mostrare avvisi di alta previsione se l'ora "
"di inizio è prima di adesso."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:93
msgid "Remove excess spacing in Preferences dialog."
msgstr "Rimozione della spaziatura eccessiva nella finestra delle preferenze."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:101
msgid "Prevent message windows taking keyboard focus when they pop up."
msgstr ""
"Viene impedito alle finestre dei messaggi di prendere il fuoco quando "
"appaiono."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:111
msgid "Implement audio backends as plugins to allow user selection."
msgstr ""
"Implementazione di motori audio come estensioni per permettere all'utente di "
"scegliere tra loto."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:112
msgid "Clean up time spin box appearance in some styles, e.g. Oxygen."
msgstr ""
"Pulizia dell'aspetto della casella numerica dell'orario in alcuni stili, ad "
"es Oxygen."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:120
msgid "Fix KAlarm exiting before executing session restoration."
msgstr ""
"Correzione della chiusura di KAlarm prima di eseguire il ripristino della "
"sessione."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:128
msgid "Fix system tray showing blank KAlarm icon under XFCE."
msgstr "Correzione dell'icona vuota di KAlarm nel vassoio di sistema in XFCE."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:136
msgid ""
"Show normal decorated alarm windows over full screen applications on X11."
msgstr ""
"Mostra finestre di avviso con decorazione normale sopra applicazioni a "
"schermo intero su X11."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:137
msgid "Fix Akonadi functionality not working."
msgstr "Correzione delle funzionalità Akonadi, non funzionanti."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:138
msgid "Make fade work each time a repeated sound alarm is played."
msgstr ""
"La sfumatura del suono ora funziona quando un avviso sonoro ripetuto viene "
"riprodotto."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:139
msgid "Fix Edit Alarm dialog error setting time if user's time zone is UTC."
msgstr ""
"Correzione dell'errore nella finestra Modifica avviso all'impostazione "
"dell'orario se il fuso orario dell'utente è UTC."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:140
msgid "Fix build on FreeBSD if using MPV audio."
msgstr "Correzione della compilazione su FreeBSD se si usa l'audio via MPV."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:148
msgid "Show all Run Mode options in Preferences dialog."
msgstr ""
"Mostra tutte le opzioni delle Modalità di esecuzione nella finestra delle "
"preferenze."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:149
msgid "Provide build option to use VLC or MPV to play sounds."
msgstr ""
"Fornita un'opzione di compilazione per usare VLC o MPV per riprodurre suoni."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:150
msgid "Convert to Qt 6.5 QDateTime/QTimeZone changes."
msgstr "Conversione alle modifiche di QDateTime/QTimeZone in Qt 6.5."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:159
msgid "Fix crash if kernel alarm timers are supported."
msgstr ""
"Correzione di un blocco quando i timer di avviso del kernel sono supportati."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:160
msgid "Fix Wake from Suspend not working when using RTC wake."
msgstr ""
"Correzione della riattivazione dalla sospensione che non funzionava quando "
"si usavano una riattivazione RTC."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:161
msgid ""
"Display any audio error message immediately when using Try button while "
"editing an alarm."
msgstr ""
"Mostra un messaggio di errore audio immediatamente quando si usa il pulsante "
"Prova mente si modifica un avviso."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:162
msgid "Fix failure to play sound files using VLC on some systems."
msgstr ""
"Correzione dell'impossibilità di riprodurre file audio usando VLC su alcuni "
"sistemi."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:170
msgid "Fix repeating audio alarms only playing once."
msgstr "Correzione della ripetizione di avvisi audio riprodotti una sola vola."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:178
msgid "Use VLC instead of libcanberra to play sounds."
msgstr "Usa VLC invece di libcanberra per riprodurre i suoni."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:186
msgid "Fix crash after editing new alarm if spell checking is enabled."
msgstr ""
"Correzione di un blocco dopo la modifica di un nuovo avviso se il correttore "
"ortografico è abilitato."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:196
msgid "Display error message if error occurs trying to play an audio file."
msgstr ""
"Mostra un messaggio di errore se si verifica un errore quando si tenta di "
"riprodurre un file audio."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:204
msgid "Use libcanberra instead of Phonon to play sounds, for thread safety."
msgstr ""
"Uso di libcanberra invece di Phonon per la riproduzione di suoni, per "
"assicurare thread safety."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:205
msgid "In Edit Alarm dialog, allow save if Set Volume checkbox is toggled."
msgstr ""
"Nella finestra di dialogo Modifica avviso, è consentito il salvataggio se la "
"casella Imposta volume è marcata."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:213
msgid "Convert to Qt6 / KDE Frameworks 6."
msgstr "Conversione a Qt6 / KDE Frameworks 6."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:214
msgid ""
"Enable wake-from-suspend for multiple alarms if user kernel alarm timers are "
"supported (Linux only)."
msgstr ""
"Abilita il risveglio dalla sospensione per avvisi multipli se i timer per "
"gli avvisi a livello utente del kernel sono supportati (solo su Linux)."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:215
msgid ""
"Set units for reminder and late-cancel depending on date-only selection in "
"Edit Alarm Template dialog."
msgstr ""
"Imposta le unità per i promemoria e annullamenti in ritardo in base allo "
"sola selezione di date nella finestra di modifica dei modelli di avviso."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:216
msgid "Remove migration of pre-Akonadi KResources calendar configuration."
msgstr ""
"Rimossa la migrazione della configurazione di calendari di tipo KResources "
"precedenti ad Akonadi."
