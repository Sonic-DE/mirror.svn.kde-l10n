#. (itstool) path: component/name
#: org.kde.merkuro.mail.metainfo.xml:10
msgid "Merkuro Mail"
msgstr "Merkuro Posta"

#. (itstool) path: component/summary
#: org.kde.merkuro.mail.metainfo.xml:11
msgid "Read and write emails"
msgstr "Leggi e scrivi messaggi di posta elettronica"

#. (itstool) path: description/p
#: org.kde.merkuro.mail.metainfo.xml:18
msgid ""
"Merkuro Mail is a free and open source email client. Merkuro Mail is part of "
"the Merkuro groupware suite and is currently in beta. For now, it only "
"allows you to read your emails."
msgstr ""
"Merkuro Posta è un client di posta elettronica libero e open source. Merkuro "
"Posta fa parte della suite di groupware Merkuro ed è attualmente in versione "
"beta. Per ora, ti consente solo di leggere i tuoi messaggi di posta "
"elettronica."

#. (itstool) path: screenshot/caption
#: org.kde.merkuro.mail.metainfo.xml:82
msgid "Mail View"
msgstr "Vista messaggi"

#~ msgid "Read your emails with speed and ease"
#~ msgstr "Leggi i tuoi messaggi di posta con velocità e facilità"

#~ msgid "KDE Community, Clau Cambra and Carl Schwan"
#~ msgstr "Comunità KDE, Clau Cambra e Carl Schwan"

#~ msgid "Merkuro Mail is an email client compatible with many servers"
#~ msgstr "Merkuro Posta è un client di posta compatibile con molti server"
