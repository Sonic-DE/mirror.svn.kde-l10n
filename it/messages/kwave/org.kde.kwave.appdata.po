#. (itstool) path: component/name
#: org.kde.kwave.appdata.xml:10
msgid "Kwave"
msgstr "Kwave"

#. (itstool) path: component/summary
#: org.kde.kwave.appdata.xml:11
msgid "Sound editor"
msgstr "Editor del suono"

#. (itstool) path: description/p
#: org.kde.kwave.appdata.xml:13
msgid ""
"Kwave is a sound editor that can record to, play, open, and edit many file "
"formats. Kwave makes it simple to edit audio in many ways."
msgstr ""
"Kwave è un editor del suono che può registrare, riprodurre, aprire e "
"modificare molti formati di file. Kwave rende semplice la modifica di un "
"audio in molti modi."

#. (itstool) path: description/p
#: org.kde.kwave.appdata.xml:16
msgid "Adjust volume level:"
msgstr "Regola il livello del volume:"

#. (itstool) path: ul/li
#: org.kde.kwave.appdata.xml:18
msgid "Fade in, fade out, or custom amplitude curve"
msgstr ""
"Dissolvenza in entrata, in uscita, o curva di amplificazione personalizzata"

#. (itstool) path: ul/li
#: org.kde.kwave.appdata.xml:19
msgid "Scale volume by a constant factor"
msgstr "Scala il volume di un fattore costante"

#. (itstool) path: ul/li
#: org.kde.kwave.appdata.xml:20
msgid "Normalize volume"
msgstr "Normalizza il volume"

#. (itstool) path: description/p
#: org.kde.kwave.appdata.xml:22
msgid "Adjust frequency content:"
msgstr "Regola il contenuto della frequenza:"

#. (itstool) path: ul/li
