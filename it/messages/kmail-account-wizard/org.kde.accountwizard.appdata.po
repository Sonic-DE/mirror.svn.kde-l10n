#. (itstool) path: component/name
#: org.kde.accountwizard.appdata.xml:9
msgid "Account Wizard"
msgstr "Procedura guidata per la creazione di account"

#. (itstool) path: component/summary
#: org.kde.accountwizard.appdata.xml:10
msgid "Configure accounts"
msgstr "Configura account"

#. (itstool) path: description/p
#: org.kde.accountwizard.appdata.xml:12
msgid ""
"Accountwizard allows to edit, create, delete accounts. Accountwizard "
"supports IMAP/POP3/Kolab account type. Account information can be found by "
"using ispd service."
msgstr ""
"La procedura guidata per la creazione di account (accountwizard) permette di "
"modificare, creare ed eliminare account. Supporta account di tipo IMAP/POP3/"
"Kolab. Le informazioni sull'account possono essere trovate usando il "
"servizio ispd."

#~ msgid "Accountwizard allows to edit, create, delete accounts."
#~ msgstr ""
#~ "La procedura guidata per la creazione di account (accountwizard) permette "
#~ "di modificare, creare ed eliminare account."
