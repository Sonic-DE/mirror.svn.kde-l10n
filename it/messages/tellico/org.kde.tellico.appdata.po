#. (itstool) path: component/name
#: org.kde.tellico.appdata.xml:9
msgid "Tellico"
msgstr "Tellico"

#. (itstool) path: component/summary
#: org.kde.tellico.appdata.xml:10
msgid "Collection Manager"
msgstr "Gestore della collezione"

#. (itstool) path: description/p
#: org.kde.tellico.appdata.xml:12
msgid ""
"Tellico is an application for organizing your collections. It provides "
"default templates for books, bibliographies, videos, music, video games, "
"coins, stamps, trading cards, comic books, and wines. It allows you to enter "
"your collection in a catalogue database, saving many different properties "
"like title, author, etc."
msgstr ""
"Tellico è un'applicazione per organizzare le tue collezioni. Fornisce "
"modelli predefiniti per libri, bibliografie, video, musica, videogiochi, "
"monete, francobolli, carte da gioco, fumetti e vini. Ti permette di inserire "
"la tua collezione in una base di dati, salvando molte proprietà differenti "
"come titolo, autore, ecc."

#. (itstool) path: description/p
#: org.kde.tellico.appdata.xml:17
msgid "Features:"
msgstr "Funzionalità:"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:19
msgid ""
"Supports default collections of books, bibliographic entries, videos, music, "
"video games, comic books, coins, stamps, trading cards, wines, board games, "
"and file catalogs"
msgstr ""
"Supporta collezioni standard di libri, voci bibliografiche, video, musica, "
"videogiochi, fumetti, monete, francobolli, carte da gioco, vini, giochi da "
"tavolo e collezioni di file"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:20
msgid "Supports user-defined custom collections"
msgstr "Supporta collezioni personalizzate definite dall'utente"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:21
msgid ""
"Supports any number of user-defined fields, of several different types: "
"text, paragraph, list, checkbox, number, URL, date, images, and combinations"
msgstr ""
"Supporta un qualsiasi numero di campi definiti dall'utente, di molti tipi "
"differenti: testo, paragrafi, liste, caselle, numeri, URL, dati, immagini e "
"combinazioni"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:22
msgid "Handles entries with multiple authors, genres, keywords, etc"
msgstr "Gestisce voci con autori multipli, generi, parole chiave, ecc."

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:23
msgid "Automatically formats titles and names"
msgstr "Formatta automaticamente titoli e nomi"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:24
msgid "Supports collection searching and view filtering"
msgstr "Supporta ricerche nella collezione e filtraggio della vista"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:25
msgid "Sorts and groups collection by various properties"
msgstr "Ordina e raggruppa la collezione in base a varie proprietà"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:26
msgid "Allows customizable entry templates through XSLT"
msgstr "Permette modelli di immissione personalizzabili attraverso XSLT"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:27
msgid "Imports MODS, Bibtex, RIS, CSV, PDF metadata, and many other formats"
msgstr ""
"Importa MODS, Bibtex, RIS, CSV, metadati dei PDF, e molti altri formati"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:28
msgid "Exports to Bibtex, ONIX, CSV, HTML, and other formats"
msgstr "Esporta in formato Bibtex, ONIX, CSV, HTML e altri"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:29
msgid ""
"Imports information directly from Amazon.com, IMDb, z39.50 servers, PubMed, "
"SRU servers, CrossRef.org, various other websites, and from external scripts"
msgstr ""
"Importa informazioni direttamente da Amazon.com, IMDb, server z39.50, "
"PubMed, server SRU, CrossRef.org, svariati altri siti web, e da script "
"esterni"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:30
msgid "Imports CDDB data for cataloging audio CDs"
msgstr "Importa dati CDDB per catalogare cd audio"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:31
msgid "Scans and imports audio file collections, such as mp3 or ogg"
msgstr "Cerca e importa collezioni di file audio, come mp3 oppure ogg"

