#. (itstool) path: component/name
#: org.kde.liquidshell.appdata.xml:4
msgid "liquidshell"
msgstr "liquidshell"

#. (itstool) path: component/summary
#. (itstool) path: description/p
#: org.kde.liquidshell.appdata.xml:5 org.kde.liquidshell.appdata.xml:10
msgid "liquidshell is an alternative to plasmashell"
msgstr "liquidshell è un'alternativa a plasmashell"

#. (itstool) path: description/p
#: org.kde.liquidshell.appdata.xml:11
msgid ""
"It does not use QtQuick but instead relies on QtWidgets, therefore no "
"hardware graphics acceleration is needed."
msgstr ""
"Non usa QtQuick ma si affida invece a QtWidgets; non è quindi necessaria "
"nessuna accelerazione grafica hardware."

#. (itstool) path: description/p
#: org.kde.liquidshell.appdata.xml:13
msgid "Main Features:"
msgstr "Funzionalità principali:"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:15
msgid "Wallpaper per virtual desktop"
msgstr "Sfondo per i desktop virtuali"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:16
msgid "No animations, no CPU hogging, low Memory footprint"
msgstr ""
"Nessuna animazione, nessun uso intensivo della CPU, utilizzo della memoria "
"limitato"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:17
msgid "Instant startup"
msgstr "Avvio istantaneo"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:18
msgid "No use of activities"
msgstr "Nessun utilizzo delle attività"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:19
msgid "QtWidgets based, therefore follows widget style from systemsettings"
msgstr ""
"È basato su QtWidgets, quindi segue lo stile degli oggetti dalle "
"Impostazioni di sistema"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:20
msgid ""
"Icons are used from your globally defined icon theme from systemsettings"
msgstr ""
"Le icone utilizzate sono quelle del tema di icone definito globalmente nelle "
"Impostazioni di sistema"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:21
msgid ""
"Colors are used from your globally defined color theme from systemsettings"
msgstr ""
"I colori utilizzati sono quelli del tema di colori definito globalmente "
"nelle Impostazioni di sistema"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:22
msgid ""
"Can additionally be styled with css by passing the commandline option -"
"stylesheet filename.css (see included example stylesheet.css)"
msgstr ""
"Lo stile può inoltre essere reso mediante css, passando l'opzione di riga di "
"comando -stylesheet nomefile.css (vedi l'esempio stylesheet.css incluso)"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:23
msgid ""
"uses existing KDE dialogs for most configurations, e.g. StartMenu, Virtual "
"Desktops, Bluetooth, Network"
msgstr ""
"Utilizza le finestre esistenti di KDE per la maggior parte delle "
"configurazioni, ad esempio il Menu Avvio, i desktop virtuali, il Bluetooth e "
"la rete"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:24
msgid "One bottom DesktopPanel"
msgstr "Un pannello desktop in basso"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:25
msgid "Desktop Applets"
msgstr "Applet desktop"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:43
msgid "Added install options (sleep/shutdown after install)"
msgstr ""
"Aggiunta delle opzioni d'installazione (sospendi/spegni dopo l'installazione)"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:44
msgid "Improved EULA handling on package installation"
msgstr "Miglioramento della gestione dell'EULA all'installazione del pacchetto"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:45
msgid "Added long format of time and date display to calendar popup"
msgstr ""
"È stato aggiunto il formato lungo di visualizzazione di data e orario alla "
"finestrella a comparsa del calendario"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:46
msgid "Create default folder for storing quicklaunch apps"
msgstr ""
"È stata creata la cartella predefinita per il salvataggio dei programmi "
"quicklaunch"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:47
msgid "SysLoad widget width depends on CPU count"
msgstr "L'ampiezza dell'oggetto Carico del sistema dipende dal numero di CPU"

#. (itstool) path: ul/li
#. (itstool) path: description/p
#: org.kde.liquidshell.appdata.xml:48 org.kde.liquidshell.appdata.xml:54
msgid "Bugfixes and adjustments to newer KDE components"
msgstr ""
"Sono stati corretti bug, e sono stati sistemati gli ultimi componenti di KDE"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:60
msgid "Notifications show how long they remain open (small animation)"
msgstr ""
"Le notifiche mostrano per quanto tempo rimangono aperte (piccola animazione)"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:61
msgid "Weather Applet shows moon phase"
msgstr "L'applet per il tempo meteorologico mostra le fasi lunari"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:62
msgid "Disk Usage Applet watches for mount/unmount to react quicker for update"
msgstr ""
"L'applet per l'utilizzo del disco controlla i montaggi e gli smontaggi, per "
"reagire più velocemente agli aggiornamenti"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:63
msgid "Display improvements in software updates component"
msgstr "Miglioramenti alla visualizzazione dei componenti software aggiornati"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:64
msgid ""
"Added DBUS-Menu support (some apps don't provide own menu but only via DBUS, "
"e.g. MS teams)"
msgstr ""
"È stato aggiunto il supporto al menu DBUS (alcuni programmi non ne hanno uno "
"proprio ma solo attraverso DBUS, ad esempio Teams di MS)"
