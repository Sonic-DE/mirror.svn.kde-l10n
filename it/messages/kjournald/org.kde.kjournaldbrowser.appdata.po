msgid "Journald Browser"
msgstr "Navigatore journald"

#. (itstool) path: component/summary
#: org.kde.kjournaldbrowser.appdata.xml:15
msgid "Browser for journald databases"
msgstr "Navigatore per i database di journald"

#. (itstool) path: description/p
#: org.kde.kjournaldbrowser.appdata.xml:17
msgid ""
"Journald-browser is a reference implementation of the kjournald library and "
"provides a flexible tool to browse in local, remote and offline journald "
"databases."
msgstr ""
"Journald-browser è un'implementazione di riferimento della libreria "
"kjournald e fornisce uno strumento flessibile per navigare nei database "
"journald locali, remoti e non in linea."

