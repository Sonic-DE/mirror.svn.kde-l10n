#: org.kde.pimdataexporter.appdata.xml:10
msgid "PIM Data Exporter"
msgstr "Esportatore dei dati di PIM"

#. (itstool) path: component/summary
#: org.kde.pimdataexporter.appdata.xml:11
msgid "Saves all data from PIM apps and restore them in other systems."
msgstr ""
"Salva tutti i dati dalle applicazioni di PIM e li ripristina in altri "
"sistemi."

#. (itstool) path: description/p
