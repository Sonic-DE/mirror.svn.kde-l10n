msgid "Plasma Browser Integration Flatpak Integration"
msgstr "Integrazione Plasma del browser per integrazione Flatpak"

#: reminder/browserintegrationreminder.json
msgctxt "Name"
msgid "Plasma Browser Integration Installation Reminder"
msgstr "Promemoria dell'installazione dell'integrazione del browser con Plasma"

#: flatpak-integrator/browserintegrationflatpakintegrator.json
msgctxt "Description"
msgid "Automatically enables support for Firefox Flatpak"
msgstr "Abilita automaticamente il supporto per Firefox Flatpak"

#: reminder/browserintegrationreminder.json
