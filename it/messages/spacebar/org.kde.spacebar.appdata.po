msgid "Spacebar"
msgstr "Spacebar"

#. (itstool) path: component/summary
#: org.kde.spacebar.appdata.xml:5
msgid "SMS/MMS messaging client"
msgstr "Client di messaggistica SMS/MMS"

#. (itstool) path: description/p
#: org.kde.spacebar.appdata.xml:12
msgid ""
"Spacebar is a SMS/MMS messaging client. It allows you to send text messages, "
"pictures and other files over a cellular network."
msgstr ""
"Spacebar è un client di messaggistica SMS/MMS. Ti permette di inviare "
"messaggi di testo, immagini e altri file su una rete cellulare."

#~ msgid "KDE Community"
#~ msgstr "Comunità KDE"

#~ msgid ""
#~ "Spacebar is a telepathy client for Plasma Mobile, that is primarily "
#~ "written for sending and receiving SMS/MMS."
#~ msgstr ""
#~ "Spacebar è un client di telepathy per Plasma Mobile, che è stato scritto "
#~ "principalmente per inviare e per ricevere SMS e MMS."
