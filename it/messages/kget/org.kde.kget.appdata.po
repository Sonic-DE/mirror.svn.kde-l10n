#. (itstool) path: component/name
#: org.kde.kget.appdata.xml:9
msgid "KGet"
msgstr "KGet"

#. (itstool) path: component/summary
#: org.kde.kget.appdata.xml:10
msgid "Download manager"
msgstr "Gestore degli scaricamenti"

#. (itstool) path: description/p
#: org.kde.kget.appdata.xml:12
msgid "KGet is a versatile and user-friendly download manager."
msgstr "KGet è un gestore degli scaricamenti versatile e facile da usare."

#. (itstool) path: description/p
#: org.kde.kget.appdata.xml:15
msgid "Features:"
msgstr "Caratteristiche:"

#. (itstool) path: ul/li
#: org.kde.kget.appdata.xml:17
msgid "Downloading files from FTP and HTTP(S) sources."
msgstr "Scaricamento di file da fonti FTP e HTTP(S)."

#. (itstool) path: ul/li
#: org.kde.kget.appdata.xml:18
msgid ""
"Pausing and resuming of downloading files, as well as the ability to restart "
"a download."
msgstr ""
"Interruzione e ripresa dello scaricamento dei file, oltre alla capacità di "
"riavviare uno scaricamento."

#. (itstool) path: ul/li
#: org.kde.kget.appdata.xml:19
msgid "Tells lots of information about current and pending downloads."
msgstr "Fornisce molte informazioni sugli scaricamenti in corso e in attesa."

#. (itstool) path: ul/li
#: org.kde.kget.appdata.xml:20
msgid "Embedding into system tray."
msgstr "Integrato nel vassoio di sistema."

#. (itstool) path: ul/li
#: org.kde.kget.appdata.xml:21
msgid "Integration with the Konqueror web browser."
msgstr "Integrazione con il browser web Konqueror."

#. (itstool) path: ul/li
#: org.kde.kget.appdata.xml:22
msgid ""
"Metalink support which contain multiple URLs for downloads, along with "
"checksums and other information."
msgstr ""
"Supporto per Metalink che contiene diversi URL da scaricare, oltre a codici "
"di controllo ed altre informazioni."

#. (itstool) path: screenshot/caption
#: org.kde.kget.appdata.xml:31
msgid "Downloading files with KGet"
msgstr "Scaricamento di file con KGet"
