#. (itstool) path: component/name
#: org.kde.ksirk.appdata.xml:10
msgid "KsirK"
msgstr "KsirK"

#. (itstool) path: component/summary
#: org.kde.ksirk.appdata.xml:11
msgid "World Domination Strategy Game"
msgstr "Gioco di strategia per la dominazione del mondo"

#. (itstool) path: description/p
#: org.kde.ksirk.appdata.xml:13
msgid ""
"KsirK is a computerized version of the well known strategic board game Risk. "
"The goal of the game is simply to conquer the world by attacking your "
"neighbors with your armies."
msgstr ""
"KsirK è una versione per il computer del famoso gioco strategico da tavola "
"Risk. L'obiettivo del gioco è semplicemente la conquista del mondo "
"attaccando i vicini con le proprie armate."

#. (itstool) path: description/p
#: org.kde.ksirk.appdata.xml:17
msgid "Features:"
msgstr "Caratteristiche:"

#. (itstool) path: ul/li
#: org.kde.ksirk.appdata.xml:19
msgid "Support for 1-6 human or computer (AI) players"
msgstr "Supporto da 1 a 6 giocatori umani o computer (IA)"

#. (itstool) path: ul/li
#: org.kde.ksirk.appdata.xml:20
msgid "Multi-player gaming over a network"
msgstr "Gioco multi-giocatore tramite la rete"

#. (itstool) path: ul/li
#: org.kde.ksirk.appdata.xml:21
msgid "You can easily create new skins with SVG graphics and the skin editor"
msgstr "Puoi creare facilmente nuovi temi con immagini SVG e l'editore di temi"

#. (itstool) path: ul/li
#: org.kde.ksirk.appdata.xml:22
msgid "Hot New Stuff support. You can easily download and install new skins"
msgstr ""
"Supporto per le Novità. Puoi scaricare e installare facilmente nuovi temi"

