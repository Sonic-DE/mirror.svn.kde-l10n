#: src/org.kde.kapman.desktop:4
msgctxt "Name"
msgid "Kapman"
msgstr "Kapman"

#: src/org.kde.kapman.desktop:63
msgctxt "GenericName"
msgid "Pac-Man Clone"
msgstr "Clone di Pac-Man"

#: src/org.kde.kapman.desktop:117
msgctxt "Comment"
msgid "Eat pills escaping ghosts"
msgstr "Mangia le pastiglie mentre sfuggi ai fantasmi"

#: themes/invisible.desktop:2
msgctxt "Name"
msgid "Invisible"
msgstr "Invisibile"

#: themes/invisible.desktop:59
msgctxt "Description"
msgid ""
"Getting bored with Kapman? More than 100,000 points over level 20? Next "
"step: the invisible maze!"
msgstr ""
"Ti stai annoiando con Kapman? Hai fatto più di 100.000 punti al livello 20? "
"Il tuo prossimo livello è il labirinto invisibile!"

#: themes/matches.desktop:2
msgctxt "Name"
msgid "Matches"
msgstr "Fiammiferi"

#: themes/matches.desktop:59
msgctxt "Description"
msgid "A matches drawn maze"
msgstr "Un percorso segnato con i fiammiferi"

#: themes/mountain.desktop:2
msgctxt "Name"
msgid "Mountain Adventure"
msgstr "Avventura in montagna"

#: themes/mountain.desktop:55
msgctxt "Description"
msgid "Default"
msgstr "Predefinito"

#: themes/mummies_crypt.desktop:2
msgctxt "Name"
msgid "Mummies Crypt"
msgstr "Cripta delle mummie"

#: themes/mummies_crypt.desktop:54
msgctxt "Description"
msgid "Avoid the mummies at all costs!"
msgstr "Evita le mummie a tutti i costi!"

#: themes/retro.desktop:2
