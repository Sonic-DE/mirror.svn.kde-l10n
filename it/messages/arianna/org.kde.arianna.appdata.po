#: org.kde.arianna.appdata.xml:14
msgid ""
"An ebook reader and library management app supporting \".epub\" files. "
"Arianna discovers your books automatically, and sorts them by categories, "
"genres and authors."
msgstr ""
"Un lettore di ebook e gestore di libreria che supporta file «.epub». Arianna "
"individua automaticamente i libri e li ordina per categorie, generi e autori."

