msgid "LightDM KDE Greeter (X11)"
msgstr "Schermata di benvenuto per KDE di LightDM (X11)"

#: greeter/lightdm-kde-greeter-x11.desktop:31
msgctxt "Comment"
msgid ""
"This runs the KDE greeter (X11 session), it should only be run from LightDM"
msgstr ""
"Questo esegue la schermata di benvenuto di KDE (sessione di X11), dovrebbe "
"essere eseguito solo da LightDM"

