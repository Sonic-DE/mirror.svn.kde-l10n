#. (itstool) path: component/name
#: org.kde.krusader.appdata.xml:7
msgid "Krusader"
msgstr "Krusader"

#. (itstool) path: component/summary
#: org.kde.krusader.appdata.xml:8
msgid "File Manager"
msgstr "Gestore di file"

#. (itstool) path: description/p
#: org.kde.krusader.appdata.xml:13
msgid ""
"Krusader is an advanced twin panel (commander style) file manager for KDE "
"Plasma and other desktops in the *nix world"
msgstr ""
"Krusader è un gestore di file avanzato a due pannelli (in stile commander), "
"per KDE Plasma e altri ambienti desktop del mondo *nix"

#. (itstool) path: description/p
#: org.kde.krusader.appdata.xml:14
msgid "Features:"
msgstr "Caratteristiche:"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:16
msgid "Extensive archive handling"
msgstr "Gestione estesa degli archivi"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:17
msgid "Mounted filesystem support"
msgstr "Supporto ai file system montati"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:18
msgid "FTP support"
msgstr "Supporto FTP"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:19
msgid "Advanced search module"
msgstr "Modulo per la ricerca avanzata"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:20
msgid "Internal viewer/editor"
msgstr "Visualizzatore/editor interno"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:21
msgid "Folder synchronisation"
msgstr "Sincronizzazione cartelle"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:22
msgid "File content comparisons"
msgstr "Confronto del contenuto dei file"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:23
msgid "Powerful batch renaming"
msgstr "Potente strumento di rinomina in serie"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:24
msgid ""
"Support for a wide variety of archive formats and can handle other KIO "
"slaves such as smb or fish."
msgstr ""
"Supporto a un'ampia varietà di formati di archivi e possibilità di gestione "
"di altri slave KIO come smb o fish."

#. (itstool) path: ul/li
