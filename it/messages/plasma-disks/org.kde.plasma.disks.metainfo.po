#. (itstool) path: component/name
#: org.kde.plasma.disks.metainfo.xml:11
msgid "Plasma Disks"
msgstr "Dischi di Plasma"

#. (itstool) path: component/summary
#: org.kde.plasma.disks.metainfo.xml:12
msgid "Hard disk health monitoring for KDE Plasma"
msgstr "Controllo della salute dei dischi rigidi per KDE Plasma"

#. (itstool) path: description/p
#: org.kde.plasma.disks.metainfo.xml:14
msgid ""
"Plasma Disks monitors S.M.A.R.T. data of disks and alerts the user when "
"signs of imminent failure appear."
msgstr ""
"Dischi di Plasma controlla i dati S.M.A.R.T. dei dischi, e avverte l'utente "
"quando si manifestano dei segni di guasto imminente."

#. (itstool) path: screenshot/caption
#: org.kde.plasma.disks.metainfo.xml:19
msgid "The Plasma Disks Info Center module showing the state of devices."
msgstr ""
"Il modulo Dischi di Plasma del Centro d'informazione che mostra lo stato dei "
"dispositivi."

