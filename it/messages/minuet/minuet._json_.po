msgid "CSound-based Audio Controller"
msgstr "Controller audio basato su CSound"

#: src/plugins/fluidsynthsoundcontroller/fluidsynthsoundcontroller.json
msgctxt "Name"
msgid "FluidSynth-based Audio Controller"
msgstr "Controller audio basato su FluidSynth"

#: src/plugins/csoundsoundcontroller/csoundsoundcontroller.json
msgctxt "Description"
msgid ""
"This plugin provides Minuet with a CSound-based implementation of sound "
"controller."
msgstr ""
"Questa estensione fornisce a Minuet un'implementazione basata su CSound del "
"controller sonoro."

#: src/plugins/fluidsynthsoundcontroller/fluidsynthsoundcontroller.json
msgctxt "Description"
msgid ""
"This plugin provides Minuet with a FluidSynth-based implementation of sound "
"controller."
msgstr ""
"Questa estensione fornisce a Minuet un'implementazione basata su FluidSynth "
"del controller sonoro."
