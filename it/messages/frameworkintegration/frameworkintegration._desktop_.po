#: plasma_workspace.notifyrc:3
msgctxt "Comment"
msgid "System Notifications"
msgstr "Notifiche di sistema"

#: plasma_workspace.notifyrc:43
msgctxt "Name"
msgid "Trash: Emptied"
msgstr "Cestino: svuotato"

#: plasma_workspace.notifyrc:98
msgctxt "Comment"
msgid "The trash has been emptied"
msgstr "Il cestino è stato svuotato"

#: plasma_workspace.notifyrc:157
msgctxt "Name"
msgid "Textcompletion: Rotation"
msgstr "Completamento del testo: rotazione"

#: plasma_workspace.notifyrc:211
msgctxt "Comment"
msgid "The end of the list of matches has been reached"
msgstr "La fine dell'elenco di corrispondenze è stata raggiunta"

#: plasma_workspace.notifyrc:269
msgctxt "Name"
msgid "Textcompletion: No Match"
msgstr "Completamento del testo: nessuna corrispondenza"

#: plasma_workspace.notifyrc:323
msgctxt "Comment"
msgid "No matching completion was found"
msgstr "Non è stato trovato alcun completamento corrispondente"

#: plasma_workspace.notifyrc:381
msgctxt "Name"
msgid "Textcompletion: Partial Match"
msgstr "Completamento del testo: corrispondenza parziale"

#: plasma_workspace.notifyrc:435
msgctxt "Comment"
msgid "There is more than one possible match"
msgstr "C'è più di una corrispondenza possibile"

#: plasma_workspace.notifyrc:494
msgctxt "Name"
msgid "Fatal Error"
msgstr "Errore grave"

#: plasma_workspace.notifyrc:550
msgctxt "Comment"
msgid "There was a serious error causing the program to exit"
msgstr ""
"Si è verificato un errore grave, che ha causato la chiusura del programma"

#: plasma_workspace.notifyrc:609
msgctxt "Name"
msgid "Notification"
msgstr "Notifica"

#: plasma_workspace.notifyrc:665
msgctxt "Comment"
msgid "Something special happened in the program"
msgstr "Si è verificato qualcosa di speciale nel programma"

#: plasma_workspace.notifyrc:723
msgctxt "Name"
msgid "Warning"
msgstr "Avviso"

#: plasma_workspace.notifyrc:779
msgctxt "Comment"
msgid "There was an error in the program which may cause problems"
msgstr "Si è verificato un errore nel programma che potrebbe causare problemi"

#: plasma_workspace.notifyrc:838
msgctxt "Name"
msgid "Catastrophe"
msgstr "Catastrofe"

#: plasma_workspace.notifyrc:893
msgctxt "Comment"
msgid "A very serious error occurred, at least causing the program to exit"
msgstr ""
"Si è verificato un errore molto grave, che ha causato almeno la chiusura del "
"programma"

#: plasma_workspace.notifyrc:951
msgctxt "Name"
msgid "Application Crash"
msgstr "Chiusura inattesa dell'applicazione"

#: plasma_workspace.notifyrc:1003
msgctxt "Comment"
msgid "An application just closed unexpectedly"
msgstr "Un'applicazione si è appena chiusa in modo inatteso"

#: plasma_workspace.notifyrc:1057
msgctxt "Name"
msgid "Login"
msgstr "Accesso"

#: plasma_workspace.notifyrc:1112
msgctxt "Comment"
msgid "A new session is starting"
msgstr "Una nuova sessione sta per essere iniziata"

#: plasma_workspace.notifyrc:1170
msgctxt "Name"
msgid "Logout"
msgstr "Chiudi sessione"

#: plasma_workspace.notifyrc:1225
msgctxt "Comment"
msgid "Session is exiting"
msgstr "La sessione sta per essere terminata"

#: plasma_workspace.notifyrc:1284
msgctxt "Name"
msgid "Logout Canceled"
msgstr "Chiusura della sessione annullata"

#: plasma_workspace.notifyrc:1339
msgctxt "Comment"
msgid "Plasma logout was canceled"
msgstr "La chiusura di Plasma è stata annullata"

#: plasma_workspace.notifyrc:1397
msgctxt "Name"
msgid "Print Error"
msgstr "Errore di stampa"

#: plasma_workspace.notifyrc:1453
msgctxt "Comment"
msgid "A print error has occurred"
msgstr "Si è verificato un errore di stampa"

#: plasma_workspace.notifyrc:1512
msgctxt "Name"
msgid "Information Message"
msgstr "Messaggio informativo"

#: plasma_workspace.notifyrc:1568
msgctxt "Comment"
msgid "An information message is being shown"
msgstr "Un messaggio informativo viene mostrato"

#: plasma_workspace.notifyrc:1627
msgctxt "Name"
msgid "Warning Message"
msgstr "Messaggio di avviso"

#: plasma_workspace.notifyrc:1683
msgctxt "Comment"
msgid "A warning message is being shown"
msgstr "Un messaggio di avviso viene mostrato"

#: plasma_workspace.notifyrc:1742
msgctxt "Name"
msgid "Critical Message"
msgstr "Messaggio critico"

#: plasma_workspace.notifyrc:1798
msgctxt "Comment"
msgid "A critical message is being shown"
msgstr "Un messaggio critico è stato mostrato"

#: plasma_workspace.notifyrc:1857
msgctxt "Name"
msgid "Question"
msgstr "Domanda"

#: plasma_workspace.notifyrc:1913
msgctxt "Comment"
msgid "A question is being asked"
msgstr "Una domanda viene posta"

#: plasma_workspace.notifyrc:1973
msgctxt "Name"
msgid "Beep"
msgstr "Bip"

#: plasma_workspace.notifyrc:2028
msgctxt "Comment"
msgid "Sound bell"
msgstr "Campanella"

#: plasma_workspace.notifyrc:2086
msgctxt "Name"
msgid "Widget failed to install"
msgstr "Installazione dell'oggetto non riuscita"

#: plasma_workspace.notifyrc:2138
msgctxt "Comment"
msgid "A widget could not be installed"
msgstr "Un oggetto non può essere installato"

#: plasma_workspace.notifyrc:2193
msgctxt "Name"
msgid "Widget deleted"
msgstr "Oggetto eliminato"

#: plasma_workspace.notifyrc:2247
msgctxt "Comment"
msgid "A widget has been deleted"
msgstr "Un oggetto è stato eliminato"

#: plasma_workspace.notifyrc:2304
msgctxt "Name"
msgid "Device plugged in"
msgstr "Dispositivo collegato"

#: plasma_workspace.notifyrc:2344
msgctxt "Comment"
msgid "A device was plugged in"
msgstr "Un dispositivo è stato collegato"

#: plasma_workspace.notifyrc:2389
msgctxt "Name"
msgid "Device unplugged"
msgstr "Dispositivo scollegato"

#: plasma_workspace.notifyrc:2429
msgctxt "Comment"
msgid "A device was unplugged"
msgstr "Un dispositivo è stato scollegato"

#~ msgctxt "Comment"
#~ msgid "Plasma Workspace"
#~ msgstr "Spazio di lavoro Plasma"
