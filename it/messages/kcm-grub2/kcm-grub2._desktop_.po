#: src/helper/kcmgrub2.actions:2
msgctxt "Name"
msgid "GRUB2 Bootloader Control Module"
msgstr "Modulo di controllo del bootloader GRUB2"

#: src/helper/kcmgrub2.actions:50
msgctxt "Name"
msgid "Restore the default GRUB2 Bootloader settings"
msgstr "Ripristina le impostazioni predefinite del bootloader GRUB2"

#: src/helper/kcmgrub2.actions:94
msgctxt "Description"
msgid ""
"Administrator authorization is required to restore the default GRUB2 "
"Bootloader settings"
msgstr ""
"Sono i richiesti i privilegi amministrativi per ripristinare le impostazioni "
"predefinite del bootloader GRUB2"

#: src/helper/kcmgrub2.actions:141
msgctxt "Name"
msgid "Install the GRUB2 Bootloader"
msgstr "Installa il bootloader GRUB2"

#: src/helper/kcmgrub2.actions:187
msgctxt "Description"
msgid "Administrator authorization is required to install the GRUB2 Bootloader"
msgstr ""
"Sono i richiesti i privilegi amministrativi per installare il bootloader "
"GRUB2"

#: src/helper/kcmgrub2.actions:235
msgctxt "Name"
msgid "Load the GRUB2 Bootloader settings"
msgstr "Carica le impostazioni del bootloader GRUB2"

#: src/helper/kcmgrub2.actions:281
msgctxt "Description"
msgid ""
"Administrator authorization is required to load the GRUB2 Bootloader settings"
msgstr ""
"Sono i richiesti i privilegi amministrativi per caricare le impostazioni del "
"bootloader GRUB2"

#: src/helper/kcmgrub2.actions:329
msgctxt "Name"
msgid "Save the GRUB2 Bootloader settings"
msgstr "Salva le impostazioni del bootloader GRUB2"

#: src/helper/kcmgrub2.actions:374
msgctxt "Description"
msgid ""
"Administrator authorization is required to save the GRUB2 Bootloader settings"
msgstr ""
"Sono i richiesti i privilegi amministrativi per salvare le impostazioni del "
"bootloader GRUB2"

