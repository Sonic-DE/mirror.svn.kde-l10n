#~ "Administrator authorization is required to probe devices for their GRUB2 "
#~ "names"
#~ msgstr ""
#~ "Sono i richiesti i privilegi amministrativi per sondare i dispositivi e "
#~ "trovarne i nomi in GRUB2"

