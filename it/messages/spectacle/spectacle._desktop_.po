msgid "A recording was captured and saved"
msgstr "Una nuova registrazione è stata catturata e salvata"

#: desktop/spectacle.notifyrc:319
msgctxt "Name"
msgid "Text Extracted"
msgstr "Testo estratto"

#: desktop/spectacle.notifyrc:351
