#. (itstool) path: component/name
#: org.kde.basket.appdata.xml:10
msgid "Basket"
msgstr "Basket"

#. (itstool) path: component/summary
#: org.kde.basket.appdata.xml:11
msgid "Notes and to-dos organizer"
msgstr "Gestore di note e cose da fare"

#. (itstool) path: description/p
#: org.kde.basket.appdata.xml:13
msgid ""
"This application provides as many baskets as you wish, and you can drag and "
"drop."
msgstr ""
"Questa applicazione ti mette a disposizione tutti i cesti che vuoi, e puoi "
"trascinarvi del contenuto."

#. (itstool) path: description/p
#: org.kde.basket.appdata.xml:14
msgid ""
"Objects can be edited, copied, dragged... So, you can arrange them as you "
"want !"
msgstr ""
"Gli oggetti possono essere modificati, copiati, trascinati... Puoi quindi "
"organizzarli come preferisci!"

#. (itstool) path: description/p
#: org.kde.basket.appdata.xml:15
msgid "It allows to arrange notes, track to-dos and much more."
msgstr ""
"Ti permette di organizzare note, tenere traccia delle cose da fare, e altro "
"ancora."

