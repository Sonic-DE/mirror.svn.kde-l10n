#. (itstool) path: component/name
#: org.kde.phonebook.metainfo.xml:4
msgid "Phonebook"
msgstr "Phonebook"

#. (itstool) path: component/summary
#: org.kde.phonebook.metainfo.xml:5
msgid "View and edit contacts"
msgstr "Visualizza e modifica i contatti"

#. (itstool) path: component/developer_name
#: org.kde.phonebook.metainfo.xml:8
msgid "KDE Community"
msgstr "La comunità KDE"

#. (itstool) path: description/p
#: org.kde.phonebook.metainfo.xml:10
msgid ""
"Convergent contact management application for both desktop and mobile "
"devices."
msgstr ""
"Applicazione convergente di gestione dei contatti sia per dispositivi "
"desktop che mobili."

#. (itstool) path: description/p
#: org.kde.phonebook.metainfo.xml:11
msgid ""
"It provides a central place for starting conversations. Depending on the "
"information available about a contact, respective actions are displayed."
msgstr ""
"Fornisce un posto centralizzato per iniziare le conversazioni. A seconda "
"delle informazioni disponibili sul contatto vengono mostrate le rispettive "
"azioni."

#. (itstool) path: description/p
#: org.kde.phonebook.metainfo.xml:13
msgid "Features"
msgstr "Funzionalità"

