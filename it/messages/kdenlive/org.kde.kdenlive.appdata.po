msgid ""
"This is the first bugfix release for the 24.02 version. Some of the most "
"noteworthy fixes:"
msgstr ""
"Questa è la prima versione di correzione dei bug per la versione 24.02. "
"Alcune delle correzioni più importanti:"

#. (itstool) path: ul/li
#: org.kde.kdenlive.appdata.xml:97
msgid "Fix distorted font in some parts of the UI"
msgstr ""
"Correzione dei caratteri distorti in alcune parti dell'interfaccia utente"

#. (itstool) path: ul/li
#: org.kde.kdenlive.appdata.xml:98
msgid "Fix crash editing gradients in titler"
msgstr ""
"Correzione del crash durante la modifica dei gradienti nella titolatrice"

#. (itstool) path: ul/li
#: org.kde.kdenlive.appdata.xml:99
msgid "Fix adding a mix to a grouped clip could move existing cut"
msgstr ""
"Correzione all'aggiunta di una miscela alle clip raggruppate, che poteva "
