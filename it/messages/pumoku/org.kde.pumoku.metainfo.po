msgid "PuMoKu"
msgstr "PuMoKu"

#. (itstool) path: component/summary
#: org.kde.pumoku.metainfo.xml:12
msgid "A classic 9 × 9 sudoku game"
msgstr "Un classico gioco di Sudoku 9x9"

#. (itstool) path: description/p
#: org.kde.pumoku.metainfo.xml:28
msgid ""
"PuMoKu is a classic, 9 × 9 Sudoku solving game aimed for Plasma Mobile. It "
"comes with flexible highlighting options and (touch) input methods, full "
"undo stack and more."
msgstr ""
"PuMoKu è un classico gioco di risoluzione di Sudoku 9x9, pensato per Plasma "
"Mobile. Offre opzioni di evidenziazione flessibili e metodi di input "
"(tocco), una pila completa di annullamenti e altro."

#. (itstool) path: ul/li
#: org.kde.pumoku.metainfo.xml:30
msgid "Input methods: Cell first, Number first or Hybrid"
msgstr "Metodi di input: prima cella, prima numero o ibrido"

#. (itstool) path: ul/li
#: org.kde.pumoku.metainfo.xml:31
msgid "Built in sudoku generator"
msgstr "Generatore di sudoku integrato"

#. (itstool) path: ul/li
#: org.kde.pumoku.metainfo.xml:32
msgid "Automatic undo when the same action is repeated"
msgstr "Annullamento automatico quando la stessa azione viene ripetuta"

