#: org.kde.kweather.appdata.xml:152
msgid "User interface improvements and bugfixes"
msgstr "Miglioramenti dell'interfaccia utente e correzioni di bug"

#. (itstool) path: description/p
#: org.kde.kweather.appdata.xml:159 org.kde.kweather.appdata.xml:174
#: org.kde.kweather.appdata.xml:185
msgid "Changes:"
msgstr "Modifiche:"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:161
msgid "Performance improvements in Dynamic view"
msgstr "Miglioramenti delle prestazioni nella vista dinamica"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:162
msgid "Dynamic view action bar rewritten to be inline to content"
msgstr ""
"Barra delle azioni di visualizzazione dinamica riscritta per essere in linea "
"con il contenuto"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:163
msgid "Allow setting non-current location in default forecasts page"
msgstr ""
"Consente l'impostazione della posizione non corrente nella pagina delle "
"previsioni predefinite"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:164
msgid "Added ability to fetch temperature units from system locale"
msgstr ""
"Aggiunta la possibilità di recuperare le unità di temperatura dalle "
"impostazioni locali del sistema"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:165
msgid "Fixed timezone format not being correctly read for local location time"
msgstr ""
"Corretto il formato del fuso orario che non veniva letto correttamente per "
"l'ora locale"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:176
msgid "Rewrote the weather plasmoid"
msgstr "Riscritto il plasmoide meteorologico"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:177
msgid "Use inline page indicator for flat mode forecasts"
msgstr ""
"Utilizza l'indicatore di pagina in linea per le previsioni in modalità piatta"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:178
msgid "Fix location ordering not persisting"
msgstr "Corregge l'ordinamento delle posizioni che non viene mantenuta"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:187
msgid "Reworked the locations page to better handle long location names"
msgstr ""
"La pagina delle posizioni è stata rielaborata per gestire meglio i nomi di "
"posizione lunghi"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:188
msgid "Add maximum width to dynamic forecast to better deal with widescreen"
msgstr ""
"Aggiunge la larghezza massima alle previsioni dinamiche per gestire meglio "
"lo schermo panoramico"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:189
msgid "Remove plasmoid (it is being reworked!)"
msgstr "Rimuove il plasmoide (è in fase di rielaborazione!)"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:190
msgid "Fixed default page not being loaded when new locations are added"
msgstr ""
"Risolto il problema per cui la pagina predefinita non veniva caricata quando "
"venivano aggiunte nuove posizioni"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:191
msgid "Unify application settings location"
msgstr "Unifica la posizione delle impostazioni dell'applicazione"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:192
msgid "Enable qml debugging when in debug mode"
msgstr "Abilita il debug qml quando si è in modalità debug"

