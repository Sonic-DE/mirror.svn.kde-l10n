#. (itstool) path: component/name
#: org.kde.filelight.appdata.xml:10
msgid "Filelight"
msgstr "Filelight"

#. (itstool) path: component/summary
#: org.kde.filelight.appdata.xml:11
msgid "Show disk usage and delete unused files"
msgstr "Mostra l'uso del disco ed elimina i file non utilizzati"

#. (itstool) path: description/p
#: org.kde.filelight.appdata.xml:13
msgid ""
"Filelight is an application to visualize the disk usage on your computer by "
"showing folders using an easy-to-understand view of concentric rings. "
"Filelight makes it simple to free up space!"
msgstr ""
"Filelight è un'applicazione per visualizzare l'uso del disco nel tuo "
"computer, che mostra le cartelle in una vista ad anelli concentrici di "
"semplice interpretazione. Filelight rende semplice liberare dello spazio!"

#. (itstool) path: description/p
#: org.kde.filelight.appdata.xml:16
msgid "Features:"
msgstr "Funzionalità:"

#. (itstool) path: ul/li
#: org.kde.filelight.appdata.xml:18
msgid "Scan local, remote, or removable disks"
msgstr "Analizza i dischi locali, quelli remoti e quelli rimovibili"

#. (itstool) path: ul/li
#: org.kde.filelight.appdata.xml:19
msgid "View detailed information about files and folders"
msgstr "Visualizza informazioni dettagliate su file e cartelle"

#. (itstool) path: ul/li
#: org.kde.filelight.appdata.xml:20
msgid "Delete files or folders that are taking up too much space"
msgstr "Elimina i file o le cartelle che occupano troppo spazio"

#. (itstool) path: ul/li
#: org.kde.filelight.appdata.xml:21
msgid "Integration into the Dolphin, Konqueror, and Krusader file managers"
msgstr "Integrazione nei gestore di file Dolphin, Konqueror e Krusader"

#. (itstool) path: ul/li
#: org.kde.filelight.appdata.xml:22
msgid "Configurable color schemes"
msgstr "Schemi di colori configurabili"

#~ msgid ""
#~ "Filelight creates an interactive map of concentric segmented-rings that "
#~ "helps visualize disk usage on your computer"
#~ msgstr ""
#~ "Filelight crea una mappa interattiva di anelli segmentati concentrici che "
#~ "aiuta a visualizzare l'uso del disco nel tuo computer"

#~ msgid ""
#~ "Filelight is an application to visualize the disk usage on your computer"
#~ msgstr ""
#~ "Filelight è un'applicazione per visualizzare l'uso del disco nel tuo "
#~ "computer"

#~ msgid "File system navigation by mouse clicks"
#~ msgstr "Navigazione del file system a clic di mouse"

