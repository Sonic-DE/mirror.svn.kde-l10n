#: kwrited-autostart.desktop:2
msgctxt "Name"
msgid "KDE Write Daemon"
msgstr "Demone di write di KDE"

#: kwrited-autostart.desktop:91
msgctxt "Comment"
msgid "Watch for messages from local users sent with write(1) or wall(1)"
msgstr ""
"Controlla l'arrivo di messaggi da utenti locali inviati con write(1) o "
"wall(1)"

#: kwrited.notifyrc:3
msgctxt "Name"
msgid "Local System Message Service"
msgstr "Servizio dei messaggi del sistema locale"

#: kwrited.notifyrc:48
msgctxt "Comment"
msgid "Local system message service"
msgstr "Servizio dei messaggi di sistema locale"

#: kwrited.notifyrc:117
msgctxt "Name"
msgid "New message received"
msgstr "Nuovo messaggio ricevuto"

#: kwrited.notifyrc:192
msgctxt "Comment"
msgid "The daemon received a new message sent with wall(1) or write(1)"
msgstr ""
"Il demone ha ricevuto un nuovo messaggio mandato con wall(1) o write(1)"

#~ msgctxt "Name"
#~ msgid "Write Daemon"
#~ msgstr "Demone di write"
