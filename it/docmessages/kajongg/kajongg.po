#, no-c-format
msgid "&c1; .. &c9;"
msgstr "&c1; .. &c9;"

#. Tag: entry
#: index.docbook:708
#, no-c-format
msgid "Character 1 to Character 9"
msgstr "Da carattere 1 a carattere 9"

#. Tag: entry
