#, no-c-format
msgid "<guimenu>Move</guimenu><guimenuitem>End Turn</guimenuitem>"
msgstr "<guimenu>Mossa</guimenu><guimenuitem>Fine del turno</guimenuitem>"

#. Tag: action
#: index.docbook:137
#, no-c-format
msgid "Let the other players know you have finished moving."
msgstr "Informa gli altri giocatori che tu hai finito le tue mosse."

#. Tag: menuchoice
#: index.docbook:142
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>R</keycap></keycombo></"
