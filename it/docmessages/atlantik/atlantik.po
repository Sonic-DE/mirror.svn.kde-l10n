#. Tag: para
#: index.docbook:36
#, no-c-format
msgid ""
"&atlantik; is a client for playing &Monopoly;-like board games on the "
"&monopd; network."
msgstr ""
"&atlantik; è un client per giocare a dei giochi da tavola simili a "
"&Monopoly; sulla rete &monopd;."

#. Tag: keyword
#: index.docbook:44
#, no-c-format
msgid "<keyword>KDE</keyword>"
