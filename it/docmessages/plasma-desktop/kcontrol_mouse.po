#~ msgid ""
#~ "Some Logitech USB mice support special features, such as switching to a "
#~ "higher resolution, or providing cordless status. If &kde; was built with "
#~ "libusb support, then you will get an additional tab for each supported "
#~ "mouse that is plugged in."
