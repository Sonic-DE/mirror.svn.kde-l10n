#: commands.docbook:96
#, no-c-format
msgid "Limit selections to the currently selected stitch type"
msgstr "Limitare le selezioni al tipo di punto attualmente selezionato"

#. Tag: menuchoice
#: commands.docbook:99
#, no-c-format
msgid ""
"<guisubmenu>Selection Masks</guisubmenu><guimenuitem>Color Mask</guimenuitem>"
msgstr ""
"<guisubmenu>Maschere di selezione</guisubmenu><guimenuitem>Maschera di "
"colori</guimenuitem>"

#. Tag: action
#: commands.docbook:100
#, no-c-format
msgid "Limit selections to the currently selected color"
msgstr "Limitare le selezioni al colore attualmente selezionato"

#. Tag: menuchoice
#: commands.docbook:102
#, no-c-format
msgid ""
"<guisubmenu>Selection Masks</guisubmenu><guimenuitem>Exclude Backstitches</"
"guimenuitem>"
msgstr ""
"<guisubmenu>Maschere di selezione</guisubmenu><guimenuitem>Escludi "
"impunture</guimenuitem>"

#. Tag: action
#: commands.docbook:103
#, no-c-format
msgid "Exclude backstitches from the selection"
msgstr "Escludere le impunture dalla selezione"

#. Tag: menuchoice
#: commands.docbook:106
#, no-c-format
msgid ""
"<guisubmenu>Selection Masks</guisubmenu><guimenuitem>Exclude Knots</"
"guimenuitem>"
