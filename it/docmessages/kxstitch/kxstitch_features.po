#. Tag: title
#: features.docbook:2
#, no-c-format
msgid "Features"
msgstr "Funzionalità"

#. Tag: para
#: features.docbook:3
#, no-c-format
msgid "The current feature list and other planned features is shown here."
msgstr ""
"L'elenco attuale delle funzionalità e altre funzionalità pianificate è "
"mostrato qui."

#. Tag: para
#: features.docbook:5
#, no-c-format
msgid "Creation of new patterns"
msgstr "Creazione di nuovi modelli"

#. Tag: para
#: features.docbook:7
#, no-c-format
msgid "User defined size"
msgstr "Dimensione definita dall'utente"

#. Tag: para
#: features.docbook:8
#, no-c-format
msgid "Selection of material color"
msgstr "Selezione del colore del materiale"

#. Tag: para
#: features.docbook:9
#, no-c-format
msgid "Insertion of a background images for tracing"
msgstr "Inserimento di immagini di sfondo per la traccia"

#. Tag: para
#: features.docbook:10
#, no-c-format
msgid "Importing of various image formats"
msgstr "Importazione di vari formati di immagine"

#. Tag: para
#: features.docbook:11
#, no-c-format
msgid "Importing options allow"
msgstr "Importazione delle opzioni consentita"

#. Tag: para
#: features.docbook:13
#, no-c-format
msgid "Limiting the number of colors"
msgstr "Limitare il numero di colori"

#. Tag: para
#: features.docbook:14
#, no-c-format
msgid "Limiting colors to a specific palette"
msgstr "Limitare il numero di colori a una tavolozza specifica"

#. Tag: para
#: features.docbook:15
#, no-c-format
msgid "Scaling to a finished size"
msgstr "Ridimensionare a una dimensione finita"

#. Tag: para
#: features.docbook:16
#, no-c-format
msgid "Support for transparency in images"
msgstr "Supporto della trasparenza nelle immagini"

#. Tag: para
#: features.docbook:17
#, no-c-format
msgid "Allow the use of fractional stitches"
msgstr "Consentire l'uso di punti frazionari"

#. Tag: para
#: features.docbook:22
#, no-c-format
msgid "Editing of existing patterns, Editing tools will include"
msgstr "Modifica di modelli esistenti, gli strumenti di modifica includeranno"

#. Tag: para
#: features.docbook:24
#, no-c-format
msgid "Open and filled rectangles"
msgstr "Rettangoli aperti e pieni"

#. Tag: para
#: features.docbook:25
#, no-c-format
msgid "Open and filled ellipses"
msgstr "Ellissi aperte e piene"

#. Tag: para
#: features.docbook:26
#, no-c-format
msgid "Filled polygons"
msgstr "Poligoni pieni"

#. Tag: para
#: features.docbook:27
#, no-c-format
msgid "Painting"
msgstr "Disegno"

#. Tag: para
#: features.docbook:28
#, no-c-format
msgid "Lines"
msgstr "Linee"

#. Tag: para
#: features.docbook:29
#, no-c-format
msgid "Erasing stitches, knots and backstitches"
msgstr "Cancellare punti, nodi e impunture"

#. Tag: para
#: features.docbook:30
#, no-c-format
msgid "Color selection from existing stitches"
msgstr "Selezione del colore da punti esistenti"

#. Tag: para
#: features.docbook:31
#, no-c-format
msgid "Swapping two colors"
msgstr "Scambiare due colori"

#. Tag: para
#: features.docbook:32
#, no-c-format
msgid "Replace one color with another"
msgstr "Sostituire un colore con un altro"

#. Tag: para
#: features.docbook:33
#, no-c-format
msgid "Text with user defined fonts and sizes"
msgstr "Testo con caratteri e dimensioni definiti dall'utente"

#. Tag: para
#: features.docbook:34
#, no-c-format
msgid "Cut, copy and paste of rectangular areas."
msgstr "Taglia, copia e incolla di aree rettangolari."

#. Tag: para
#: features.docbook:35
#, no-c-format
msgid "Unlimited undo and redo"
msgstr "Annulla e rifai illimitati"

#. Tag: para
#: features.docbook:36
#, no-c-format
msgid "Mirroring, horizontally and vertically."
msgstr "Rispecchiamento, orizzontale e verticale."

#. Tag: para
#: features.docbook:37
#, no-c-format
msgid "Rotation, 90, 180 and 270 degrees anti clockwise."
msgstr "Rotazione, 90, 180, 270 gradi in senso antiorario."

#. Tag: para
#: features.docbook:38
#, no-c-format
msgid "Resizing of the canvas"
msgstr "Ridimensionamento delle tele"

#. Tag: para
#: features.docbook:40
#, no-c-format
msgid "Extend canvas left, top, right, bottom"
msgstr "Estendere le tele a sinistra, in alto, a destra, in basso"

#. Tag: para
#: features.docbook:41
#, no-c-format
msgid "Cropping canvas to pattern"
msgstr "Ritaglio della tela al modello"

#. Tag: para
#: features.docbook:42
#, no-c-format
msgid "Cropping canvas to selection"
msgstr "Ritaglio della tela alla selezione"

#. Tag: para
#: features.docbook:43
#, no-c-format
msgid "Inserting rows and columns"
msgstr "Inserire righe e colonne"

#. Tag: para
#: features.docbook:44
#, no-c-format
msgid "Center the pattern on the canvas"
msgstr "Centrare il modello sulla tela"

#. Tag: para
#: features.docbook:47
#, no-c-format
msgid "Conversion between floss schemes"
msgstr "Conversione tra schemi di fili"

#. Tag: para
#: features.docbook:50
#, no-c-format
msgid "Use of standard floss pallets, DMC, Anchor, etc."
msgstr "Utilizzo di tavolozze di filo standard, DMC, Anchor, ecc."

#. Tag: para
#: features.docbook:51
#, no-c-format
msgid "Create customized floss pallets"
msgstr "Creare tavolozze di filo personalizzate"

#. Tag: para
#: features.docbook:52
#, no-c-format
msgid "Create new colors for any floss pallet"
msgstr "Creare nuovi colori per ogni tavolozza di filo"

#. Tag: para
#: features.docbook:53
#, no-c-format
msgid "Save / Load current palette"
msgstr "Salvare / Caricare la tavolozza attuale"

#. Tag: para
#: features.docbook:54
#, no-c-format
msgid "Use of standard stitches"
msgstr "Utilizzo dei punti standard"

#. Tag: para
#: features.docbook:55
#, no-c-format
msgid "Pattern library manager"
msgstr "Gestore delle librerie di modelli"

#. Tag: para
#: features.docbook:57
#, no-c-format
msgid "Create new library patterns"
msgstr "Creare nuovi modelli di librerie"

#. Tag: para
#: features.docbook:58
#, no-c-format
msgid "Insert library patterns into a design"
msgstr "Inserire i modelli di librerie in un progetto"

#. Tag: para
#: features.docbook:59
#, no-c-format
msgid "Drag and drop from the library to the pattern"
msgstr "Trascinare e rilasciare dalla libreria al modello"

#. Tag: para
#: features.docbook:60
#, no-c-format
msgid "Drag and drop from one library to another"
msgstr "Trascinare e rilasciare da una libreria a un'altra"

#. Tag: para
#: features.docbook:61
#, no-c-format
msgid "Assign key press to patterns for use with the Alphabet tool"
msgstr ""
"Assegnare un tasto ai modelli per utilizzarli con lo strumento Alfabeto"

#. Tag: para
#: features.docbook:64
#, no-c-format
msgid "Free use of backstitching"
msgstr "Utilizzo libero dell'impuntura"

#. Tag: para
#: features.docbook:65
#, no-c-format
msgid "Printing of completed patterns and floss keys"
msgstr "Stampa di modelli completati e farfalle di filo"

#. Tag: para
#: features.docbook:67
#, no-c-format
msgid "Pattern image"
msgstr "Immagine del modello"

#. Tag: para
#: features.docbook:68
#, no-c-format
msgid "Instructions"
msgstr "Istruzioni"

#. Tag: para
#: features.docbook:69
#, no-c-format
msgid "Floss key and stitch summary"
msgstr "Farfalla del filo e riepilogo dei punti"

#. Tag: para
#: features.docbook:70
#, no-c-format
msgid "Pattern chart with page map"
msgstr "Grafico del modello con mappa della pagina"

#. Tag: para
#: features.docbook:71
#, no-c-format
msgid "Text boxes"
msgstr "Caselle di testo"

#. Tag: para
#: features.docbook:74
#, no-c-format
msgid "Mapping of symbols to flosses"
msgstr "Associazione dei simboli ai fili"

#. Tag: para
#: features.docbook:75
#, no-c-format
msgid "Specify the number of threads for stitches and backstitches"
msgstr "Specificare il numero di fili per punti e impunture"

#. Tag: para
#: features.docbook:76
#, no-c-format
msgid "Calibration of floss colors"
msgstr "Calibrazione dei colori del filo"

#. Tag: para
#: features.docbook:78
#, no-c-format
msgid ""
"Requests for new features can be made to the <ulink url=\"http://bugs.kde.org"
"\">KDE Bugtracking System</ulink>"
msgstr ""
"Richieste di nuove funzionalità possono essere inviate al <ulink url="
"\"http://bugs.kde.org\">Sistema di tracciamento dei bug di KDE</ulink>"
