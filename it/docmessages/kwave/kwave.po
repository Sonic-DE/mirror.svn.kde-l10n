msgstr "&no-i18n-tag;<command>1</command>"

#. Tag: entry
#: index.docbook:5347 index.docbook:6664
#, no-c-format
msgid ""
"Save only the sections that are within the current selection. If nothing is "
"selected, the whole file will be saved."
msgstr ""
"Salva solo le sezioni che sono all'interno della selezione corrente. Se non "
"è selezionato nulla, sarà salvato l'intero file."

#. Tag: replaceable
#: index.docbook:5361
#, no-c-format
msgid "project file"
msgstr "file progetto"

#. Tag: para
#: index.docbook:5363
#, no-c-format
msgid ""
"The name of the K3b project file, which will also be used as the base name "
"for the exported file names."
msgstr ""
"Il nome del file del progetto K3b originale, che sarà usato anche come base "
"per i nomi dei file esportati."

#. Tag: replaceable
#: index.docbook:5371 index.docbook:6635
#, no-c-format
msgid "export location"
msgstr "posizione esportazione"

#. Tag: para
#: index.docbook:5373
#, no-c-format
msgid "The location where the blocks should be saved."
msgstr "La posizione dove devono essere salvati i blocchi."

#. Tag: replaceable
