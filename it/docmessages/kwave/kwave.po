msgstr "dispositivo di registrazione"

#. Tag: para
#: index.docbook:6264
#, no-c-format
msgid "A string that determines the recording device."
msgstr "Una stringa che determina il dispositivo di registrazione."

#. Tag: para
#: index.docbook:6272
#, no-c-format
msgid "The number of channels to use for recording."
msgstr "Il numero dei canali da usare per la registrazione."

#. Tag: replaceable
#: index.docbook:6278
#, no-c-format
msgid "sample rate"
msgstr "frequenza di campionamento"

#. Tag: para
#: index.docbook:6280
#, no-c-format
msgid "<para>Sample rate in samples per second.</para>"
msgstr "<para>Frequenza di campionamento in campioni per secondo.</para>"

