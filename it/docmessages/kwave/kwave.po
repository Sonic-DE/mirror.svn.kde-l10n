#, no-c-format
msgid "<parameter>milliseconds</parameter>:"
msgstr "<parameter>millisecondi</parameter>:"

#. Tag: entry
#: index.docbook:2571
#, no-c-format
msgid "number of whole milliseconds to wait before executing the command"
msgstr "numero di millisecondi di attesa prima dell'esecuzione del comando"

#. Tag: entry
#: index.docbook:2572 index.docbook:2866
#, no-c-format
msgid "<parameter>command</parameter>:"
msgstr "<parameter>comando</parameter>:"

#. Tag: entry
#: index.docbook:2573
#, no-c-format
