#~ msgstr ""
#~ "Marcando la casella <guilabel>Mostra suggerimenti</guilabel> nella pagina "
#~ "<menuchoice><guimenu>Gestione dei file</guimenu><guimenuitem>Generale</"
#~ "guimenuitem></menuchoice> della finestra di configurazione di &konqueror; "
