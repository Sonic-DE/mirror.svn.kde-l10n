#. Tag: para
#: index.docbook:17
#, no-c-format
msgid ""
"<acronym>ldap</acronym> is the lightweight directory access protocol. It "
"provides access to an X.500 directory, or to a stand-alone <acronym>LDAP</"
"acronym> server."
msgstr ""
"L'<acronym>ldap</acronym> è il Lightweight Directory Access Protocol. "
"Fornisce accesso a directory X.500 o ad un server <acronym>LDAP</acronym> "
"indipendente."

#. Tag: para
#: index.docbook:21
#, no-c-format
msgid "You can use the ldap KIO worker as follows:"
msgstr "Il KIO worker ldap si usa come segue:"

#. Tag: para
#: index.docbook:23
#, no-c-format
msgid ""
"<userinput>ldap://host:port/ou=People,o=where,c=de??sub</userinput> for a "
"subtree-query"
msgstr ""
"<userinput>ldap://host:port/ou=People,o=where,c=de??sub</userinput> per una "
"ricerca su sottoalbero"

#. Tag: para
#: index.docbook:26
#, no-c-format
msgid ""
"or <userinput>ldap://host:port/cn=MM,ou=People,o=where,c=de??base</"
"userinput> for a complete branch."
msgstr ""
"oppure <userinput>ldap://host:port/cn=MM,ou=People,o=where,c=de??base</"
"userinput> per un ramo completo."
