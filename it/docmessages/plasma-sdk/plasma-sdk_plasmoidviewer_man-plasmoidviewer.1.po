#. Tag: date
#: man-plasmoidviewer.1.docbook:9
#, no-c-format
msgid "2017-01-09"
msgstr "2017-01-09"

#. Tag: releaseinfo
#: man-plasmoidviewer.1.docbook:10
#, no-c-format
msgid "Plasma 5.8"
msgstr "Plasma 5.8"

#. Tag: productname
#: man-plasmoidviewer.1.docbook:11
#, no-c-format
msgid "KDE Plasma"
msgstr "KDE Plasma"

#. Tag: manvolnum
