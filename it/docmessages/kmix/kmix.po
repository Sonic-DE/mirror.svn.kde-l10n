#. Tag: menuchoice
#: index.docbook:169
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Audio Setup</guimenuitem>"
msgstr ""
"<guimenu>Impostazioni</guimenu> <guimenuitem>Configurazione dell'audio</"
"guimenuitem>"

#. Tag: para
#: index.docbook:173
#, no-c-format
msgid ""
"<action>Open <ulink url=\"help:/kcontrol/phonon\">&phonon; &systemsettings; "
"module</ulink></action> to configure the sound and video device preference "
"and the backends used by &kde; multimedia API, &phonon;."
msgstr ""
"<action>Apri il <ulink url=\"help:/kcontrol/phonon\">modulo di &phonon; "
"delle &systemsettings;</ulink></action> per configurare le preferenze per i "
"dispositivi audio e video e i motori usati dall'API multimediale di &kde;, "
"&phonon;."

