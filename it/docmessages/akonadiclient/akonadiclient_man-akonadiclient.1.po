msgstr "akonadiclient info [OPZIONI] RACCOLTA | ELEMENTO"

#. Tag: para
#: man-akonadiclient.1.docbook:363
#, no-c-format
msgid "Show full information about a collection or item"
msgstr "Mostra le informazioni complete su una raccolta o su un elemento"

#. Tag: para
#: man-akonadiclient.1.docbook:369
#, no-c-format
msgid "Assume that a collection is specified"
msgstr "Assumi che una raccolta sia specificata"

#. Tag: para
#: man-akonadiclient.1.docbook:374
#, no-c-format
msgid "Assume that an item is specified"
msgstr "Assumi che un elemento sia specificato"

#. Tag: option
#: man-akonadiclient.1.docbook:382
#, no-c-format
msgid "show"
msgstr "mostra"

#. Tag: para
#: man-akonadiclient.1.docbook:384
#, no-c-format
msgid "akonadiclient show ITEM"
msgstr "akonadiclient show ELEMENTO"

#. Tag: para
#: man-akonadiclient.1.docbook:385
#, no-c-format
msgid "Shows the raw payload of an item"
msgstr "Mostra il contenuto grezzo di un elemento"

#. Tag: option
#: man-akonadiclient.1.docbook:390
#, no-c-format
msgid "tags"
msgstr "etichette"

#. Tag: para
#: man-akonadiclient.1.docbook:392
#, no-c-format
msgid "akonadiclient tags [OPTIONS]"
msgstr "akonadiclient tags [OPZIONI]"

#. Tag: para
#: man-akonadiclient.1.docbook:393
#, no-c-format
msgid "List all known tags"
msgstr "Elenca tutte le etichette conosciute"

#. Tag: para
#: man-akonadiclient.1.docbook:399
#, no-c-format
msgid "Brief output - tag names only"
msgstr "Risultato breve - solo i nomi delle etichette"

#. Tag: option
#: man-akonadiclient.1.docbook:403
#, no-c-format
msgid "-u, --urls"
msgstr "-u, --urls"

#. Tag: para
#: man-akonadiclient.1.docbook:404
#, no-c-format
msgid "Brief output - tag URLs only"
msgstr "Risultato breve - solo gli URL delle etichette"

#. Tag: option
#: man-akonadiclient.1.docbook:412
#, no-c-format
msgid "update"
msgstr "aggiorna"

#. Tag: para
#: man-akonadiclient.1.docbook:414
#, no-c-format
msgid "akonadiclient update [OPTIONS] ITEM FILE"
msgstr "akonadiclient update [OPZIONI] ELEMENTO FILE"

#. Tag: para
#: man-akonadiclient.1.docbook:415
#, no-c-format
msgid "Updates the raw payload of ITEM with the contents of FILE"
msgstr "Aggiorna il contenuto grezzo di ELEMENTO con il contenuto di FILE"

#. Tag: title
#: man-akonadiclient.1.docbook:432
#, no-c-format
msgid "Miscellaneous Commands"
msgstr "Comandi vari"

#. Tag: option
#: man-akonadiclient.1.docbook:436
#, no-c-format
msgid "agents"
msgstr "agenti"

#. Tag: para
#: man-akonadiclient.1.docbook:438
#, no-c-format
msgid "akonadiclient agents [OPTIONS] [AGENTS...]"
msgstr "akonadiclient agents [OPZIONI] [AGENTI...]"

#. Tag: para
#: man-akonadiclient.1.docbook:439
#, no-c-format
msgid ""
"Allows managing of Akonadi agents like changing their state, restarting an "
"agent or listing all agents and their state."
msgstr ""
"Consente di gestire gli agenti di Akonadi come cambiare il loro stato, "
"riavviare un agente o elencare tutti gli agenti e il loro stato."

#. Tag: option
#: man-akonadiclient.1.docbook:444
#, no-c-format
msgid "-l, --list"
msgstr "-l, --list"

#. Tag: para
#: man-akonadiclient.1.docbook:445
#, no-c-format
msgid "List all agents"
msgstr "Elenca tutti gli agenti"

#. Tag: option
#: man-akonadiclient.1.docbook:449
#, no-c-format
msgid "-s, --setstate <replaceable>state</replaceable>"
msgstr "-s, --setstate <replaceable>stato</replaceable>"

#. Tag: para
#: man-akonadiclient.1.docbook:450
#, no-c-format
msgid ""
"Set the state for specified agents. Valid states are 'offline' and 'online'."
msgstr ""
"Imposta lo stato per gli agenti specificati. Gli stati validi sono «non in "
"linea» e «in linea»."

#. Tag: option
#: man-akonadiclient.1.docbook:454
#, no-c-format
msgid "-g, --getstate"
msgstr "-g, --getstate"

#. Tag: para
#: man-akonadiclient.1.docbook:455
#, no-c-format
msgid "Get the state for specified agents"
msgstr "Ottieni lo stato per gli agenti specificati"

#. Tag: option
#: man-akonadiclient.1.docbook:459
#, no-c-format
msgid "-i, --info"
msgstr "-i, --info"

#. Tag: para
#: man-akonadiclient.1.docbook:460
#, no-c-format
msgid "Show information about the specified agents"
msgstr "Mostra le informazioni sugli agenti specificati"

#. Tag: option
#: man-akonadiclient.1.docbook:464
#, no-c-format
msgid "-r, --restart"
msgstr "-r, --restart"

#. Tag: para
#: man-akonadiclient.1.docbook:465
#, no-c-format
msgid "Restarts the specified agents"
msgstr "Riavvia gli agenti specificati"

#. Tag: option
#: man-akonadiclient.1.docbook:478
#, no-c-format
msgid "help"
msgstr "aiuto"

#. Tag: para
#: man-akonadiclient.1.docbook:480
#, no-c-format
msgid "akonadiclient help [COMMAND]"
msgstr "akonadiclient help [COMANDO]"

#. Tag: para
#: man-akonadiclient.1.docbook:481
#, no-c-format
msgid ""
"Displays help for COMMAND. If COMMAND is not specified then it lists all the "
"available commands"
msgstr ""
"Visualizza la guida per COMANDO. Se COMANDO non è specificato, elenca tutti "
"i comandi disponibili"

#. Tag: option
#: man-akonadiclient.1.docbook:486
#, no-c-format
msgid "shell"
msgstr "shell"

#. Tag: para
#: man-akonadiclient.1.docbook:488
#, no-c-format
msgid "akonadiclient shell"
msgstr "akonadiclient shell"

#. Tag: para
#: man-akonadiclient.1.docbook:489
#, no-c-format
msgid "Enter commands in an interactive shell"
msgstr "Digita i comandi in una shell interattiva"

#. Tag: title
#: man-akonadiclient.1.docbook:497
#, no-c-format
msgid "Examples"
msgstr "Esempi"

#. Tag: para
#: man-akonadiclient.1.docbook:498
#, no-c-format
msgid ""
"<emphasis role=\"bold\">akonadiclient list /</emphasis> - Lists all the "
"collections under the root collection"
msgstr ""
"<emphasis role=\"bold\">akonadiclient list /</emphasis> - Elenca tutte le "
"raccolte sotto la raccolta radice"

#. Tag: para
#: man-akonadiclient.1.docbook:499
#, no-c-format
msgid ""
"<emphasis role=\"bold\">akonadiclient export /Notes notes.xml</emphasis> - "
"Exports all the items and sub-collections of the /Notes collection to the "
"file 'notes.xml'"
msgstr ""
"<emphasis role=\"bold\">akonadiclient export /Notes notes.xml</emphasis> - "
"Esporta tutti gli elementi e le sotto-raccolte della raccolta /Notes nel "
"file 'notes.xml'"

#. Tag: para
#: man-akonadiclient.1.docbook:500
#, no-c-format
msgid ""
"<emphasis role=\"bold\">akonadiclient agents -l</emphasis> - Lists all agents"
msgstr ""
"<emphasis role=\"bold\">akonadiclient agents -l</emphasis> - Elenca tutti "
"gli agenti"

#. Tag: para
#: man-akonadiclient.1.docbook:501
#, no-c-format
msgid ""
"<emphasis role=\"bold\">akonadiclient add /Notes note.txt</emphasis> - Adds "
"the contents of the file note.txt as an item in the collection /Notes"
msgstr ""
"<emphasis role=\"bold\">akonadiclient add /Notes nota.txt</emphasis> - "
"Aggiunge il contenuto del file nota.txt come un elemento nella raccolta /"
"Notes"

#. Tag: para
#: man-akonadiclient.1.docbook:502
#, no-c-format
msgid ""
"<emphasis role=\"bold\">akonadiclient add -m application/x-vnd.akonadi."
"calendar.todo /Todos todo.ics</emphasis> - Adds the contents of the file "
"todo.ics as a TODO calendar entry in the collection /Todos"
msgstr ""
"<emphasis role=\"bold\">akonadiclient add -m application/x-vnd.akonadi."
"calendar.todo /Todos dafare.ics</emphasis> - Aggiunge il contenuto del file "
"dafare.ics come una voce DA FARE del calendario nella raccolta /Todos"

