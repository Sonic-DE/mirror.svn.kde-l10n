msgstr "Funziona anche se la cartella di destinazione non è vuota"

#. Tag: option
#: man-akonadiclient.1.docbook:244
#, no-c-format
msgid "edit"
msgstr "modifica"

#. Tag: para
#: man-akonadiclient.1.docbook:246
#, no-c-format
msgid "akonadiclient edit [OPTIONS] ITEM"
msgstr "akonadiclient edit [OPZIONI] ELEMENTO"

#. Tag: para
#: man-akonadiclient.1.docbook:247
#, no-c-format
msgid ""
"Opens the payload of ITEM in a text editor specified by the environment "
"variable $EDITOR"
msgstr ""
"Apre il contenuto di ELEMENTO in un editor di testo specificato dalla "
"variabile d'ambiente $EDITOR"

#. Tag: option
#: man-akonadiclient.1.docbook:261
#, no-c-format
msgid "expand"
msgstr "espandi"

#. Tag: para
#: man-akonadiclient.1.docbook:263
#, no-c-format
msgid "akonadiclient expand [OPTIONS] ITEM"
msgstr "akonadiclient expand [OPZIONI] ELEMENTO"

#. Tag: para
#: man-akonadiclient.1.docbook:264
#, no-c-format
msgid "Expands a contact group item"
msgstr "Espandi un elemento del gruppo di contatti"

#. Tag: option
#: man-akonadiclient.1.docbook:269 man-akonadiclient.1.docbook:328
#: man-akonadiclient.1.docbook:398
#, no-c-format
msgid "-b, --brief"
msgstr "-b, --brief"

#. Tag: para
#: man-akonadiclient.1.docbook:270
#, no-c-format
msgid "Brief output (email addresses only)"
msgstr "Risultato breve (solo gli indirizzi di posta)"

#. Tag: option
#: man-akonadiclient.1.docbook:278
#, no-c-format
msgid "export"
msgstr "esporta"

#. Tag: para
#: man-akonadiclient.1.docbook:280
#, no-c-format
msgid "akonadiclient export [OPTIONS] COLLECTION FILE"
msgstr "akonadiclient export [OPZIONI] RACCOLTA FILE"

#. Tag: para
#: man-akonadiclient.1.docbook:281
#, no-c-format
msgid ""
"Export the collection specified by COLLECTION to an XML file specified by "
"FILE."
msgstr ""
"Esporta la raccolta specificata da RACCOLTA in un file XML specificato da "
"FILE."

#. Tag: option
#: man-akonadiclient.1.docbook:295
#, no-c-format
msgid "group"
msgstr "gruppo"

#. Tag: para
#: man-akonadiclient.1.docbook:297
#, no-c-format
msgid "akonadiclient group [OPTIONS] GROUP ARGS"
msgstr "akonadiclient group [OPZIONI] GRUPPO ARGOMENTI"

#. Tag: para
#: man-akonadiclient.1.docbook:298
#, no-c-format
msgid "Expand or modify a contact GROUP"
msgstr "Espandi o modifica un GRUPPO di contatti"

#. Tag: option
#: man-akonadiclient.1.docbook:303
#, no-c-format
msgid "-e, --expand"
msgstr "-e, --expand"

#. Tag: para
#: man-akonadiclient.1.docbook:304
#, no-c-format
msgid "Show the expanded contact group (the default operation)"
msgstr "Mostra il gruppo di contatti espanso (l'operazione predefinita)"

#. Tag: option
#: man-akonadiclient.1.docbook:308
#, no-c-format
msgid "-a, --add"
msgstr "-a, --add"

#. Tag: para
#: man-akonadiclient.1.docbook:309
#, no-c-format
msgid "Add a contact to the group"
msgstr "Aggiungi un contatto al gruppo"

#. Tag: option
#: man-akonadiclient.1.docbook:313
#, no-c-format
msgid "-d, --delete"
msgstr "-d, --delete"

#. Tag: para
#: man-akonadiclient.1.docbook:314
#, no-c-format
msgid "Delete a contact from the group"
msgstr "Elimina un contatto dal gruppo"

#. Tag: option
#: man-akonadiclient.1.docbook:318
#, no-c-format
msgid "-C, --clean"
msgstr "-C, --clean"

#. Tag: para
#: man-akonadiclient.1.docbook:319
#, no-c-format
