#, no-c-format
msgid "akonadiclient rename [OPTIONS] COLLECTION NAME"
msgstr "akonadiclient rename [OPZIONI] RACCOLTA NOME"

#. Tag: para
#: man-akonadiclient.1.docbook:159
#, no-c-format
msgid "Renames a specified collection to NAME"
msgstr "Rinomina una raccolta specificata con NOME"

#. Tag: title
