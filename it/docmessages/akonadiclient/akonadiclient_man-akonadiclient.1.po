msgstr "Rimuovi i riferimenti di un elemento sconosciuto dal gruppo"

#. Tag: option
#: man-akonadiclient.1.docbook:323
#, no-c-format
msgid "-c, --comment <replaceable>name</replaceable>"
msgstr "-c, --comment <replaceable>nome</replaceable>"

