msgstr "Estrai gli elementi con categorie di Akonadi, altrimenti testo"

#. Tag: option
#: man-akonadiclient.1.docbook:230
#, no-c-format
msgid "-f, --force"
msgstr "-f, --force"

#. Tag: para
#: man-akonadiclient.1.docbook:231
#, no-c-format
