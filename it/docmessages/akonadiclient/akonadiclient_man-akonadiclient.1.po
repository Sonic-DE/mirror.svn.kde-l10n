msgid "Brief output (for 'expand', email addresses only)"
msgstr "Risultato breve (per «espandi», solo indirizzi di posta)"

#. Tag: option
#: man-akonadiclient.1.docbook:343
#, no-c-format
msgid "import"
msgstr "importa"

#. Tag: para
#: man-akonadiclient.1.docbook:345
#, no-c-format
msgid "akonadiclient import [OPTIONS] PARENT FILE"
msgstr "akonadiclient import [OPZIONI] ORIGINE FILE"

#. Tag: para
#: man-akonadiclient.1.docbook:346
#, no-c-format
msgid ""
"Imports an XML file inside the collection specified by PARENT. If the "
"collection already exists, its contents are merged with the contents of the "
"collection in the XML file."
msgstr ""
"Importa un file XML nella raccolta specificata da PARENT. Se la raccolta "
"esiste già, il suo contenuto è unito con il contenuto della raccolta nel "
"file XML."

#. Tag: option
