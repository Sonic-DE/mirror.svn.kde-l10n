#. Tag: title
#: man-akonadiclient.1.docbook:40
#, no-c-format
msgid "Description"
msgstr "Descrizione"

#. Tag: para
#: man-akonadiclient.1.docbook:41
#, no-c-format
msgid ""
"akonadiclient is a commandline client for manipulating KDE's Akonadi "
"datastore. It provides an easy way to manipulate Akonadi's data through the "
"commandline. For example, adding items, collections, renaming or moving "
"collections and also controlling the Akonadi agents."
msgstr ""
"akonadiclient è un client da riga di comando per manipolare l'archivio di "
"dati Akonadi di KDE. Fornisce un modo semplice per manipolare i dati di "
"Akonadi tramite la riga di comando. Ad esempio, aggiungere elementi, "
"raccolte, rinominare o spostare raccolte e inoltre controllare gli agenti di "
"Akonadi."

#. Tag: title
#: man-akonadiclient.1.docbook:47
#, no-c-format
msgid "Commands"
msgstr "Comandi"

#. Tag: title
#: man-akonadiclient.1.docbook:49
#, no-c-format
msgid "Filesystem Commands"
msgstr "Comandi del filesystem"

#. Tag: option
#: man-akonadiclient.1.docbook:53
#, no-c-format
msgid "copy"
msgstr "copia"

#. Tag: para
#: man-akonadiclient.1.docbook:55
#, no-c-format
msgid "akonadiclient copy [OPTIONS] SOURCE DESTINATION"
msgstr "akonadiclient copy [OPZIONI] SORGENTE DESTINAZIONE"

#. Tag: para
#: man-akonadiclient.1.docbook:56
#, no-c-format
msgid "Used to copy collections or items from one collection to another."
msgstr "Utilizzato per copiare raccolte o elementi da una raccolta a un'altra."

