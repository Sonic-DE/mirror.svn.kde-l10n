#: man-akonadiclient.1.docbook:204
#, no-c-format
msgid "MIME type to use (instead of auto-detection)"
msgstr "Il tipo MIME da utilizzare (invece del rilevamento automatico)"

#. Tag: option
#: man-akonadiclient.1.docbook:212
#, no-c-format
msgid "dump"
msgstr "estrai"

#. Tag: para
#: man-akonadiclient.1.docbook:214
#, no-c-format
msgid "akonadiclient dump [OPTIONS] COLLECTION DIRECTORY"
msgstr "akonadiclient dump [OPZIONI] RACCOLTA CARTELLA"

