"subscript>(m,n,x) = M(m,n,x) a parametri interi m, n"

#. Tag: entry
#: index.docbook:1944
#, no-c-format
msgid "hyperg_1F1(a,b,x)"
msgstr "hyperg_1F1(a,b,x)"

#. Tag: action
#: index.docbook:1944
#, no-c-format
