msgstr ""
"<guimenu>Partita</guimenu> <guimenuitem>Editor di disposizioni</guimenuitem>"

#. Tag: action
#: index.docbook:291
#, no-c-format
msgid "Shows the board editor."
msgstr "Mostra l'editor delle disposizioni."

#. Tag: screeninfo
#: index.docbook:293
#, no-c-format
msgid "<screeninfo>The board editor</screeninfo>"
msgstr "<screeninfo>L'editor del tavolo</screeninfo>"

#. Tag: phrase
#: index.docbook:296
#, no-c-format
msgid "<phrase>The board editor</phrase>"
msgstr "<phrase>L'editor del tavolo</phrase>"

#. Tag: para
#: index.docbook:300
#, no-c-format
msgid "Procedure to edit layout:"
msgstr "Procedura per modificare la disposizione:"

#. Tag: para
#: index.docbook:303
#, no-c-format
msgid ""
"Use the board editor toolbar to create a new layout or to load and edit an "
"existing one."
msgstr ""
"Utilizzare la barra degli strumenti dell'editor del piano di gioco per "
"creare una nuova disposizione o per caricare e modificare una esistente."

#. Tag: para
#: index.docbook:304
#, no-c-format
msgid ""
"Save the layout in your user's local home folder in <filename>"
"$<envar>XDG_DATA_HOME</envar>/kmahjongg/layouts</filename>"
msgstr ""
"Salvare la disposizione nella propria cartella home locale in <filename>"
"$<envar>XDG_DATA_HOME</envar>/kmahjongg/layouts</filename>"

#. Tag: para
#: index.docbook:305
#, no-c-format
msgid ""
"Create the <filename><replaceable>name_of_your_layout</replaceable>.desktop</"
"filename> file in the same folder."
msgstr ""
"Creare il file <filename><replaceable>nome_della_propria_disposizione</"
"replaceable>.desktop</filename>."

#. Tag: para
#: index.docbook:306
#, no-c-format
msgid "Put the following lines in this file using your favorite text editor:"
msgstr ""
"Inserisci le righe seguenti in questo file utilizzando il tuo editor di "
"testo preferito:"

#. Tag: programlisting
#: index.docbook:307
#, no-c-format
msgid ""
"[KMahjonggLayout]\n"
"Name=<replaceable>name_of_your_layout</replaceable>\n"
"Description=<replaceable>description_of_your_layout</replaceable>\n"
"VersionFormat=1\n"
"Author=<replaceable>your_name</replaceable>\n"
"AuthorEmail=<replaceable>your_email</replaceable>\n"
"FileName=<replaceable>name_of_your_layout</replaceable>.layout"
msgstr ""
"[KMahjonggLayout]\n"
"Name=<replaceable>nome_della_propria_disposizione</replaceable>\n"
"Description=<replaceable>descrizione_della_propria_disposizione</"
"replaceable>\n"
"VersionFormat=1\n"
"Author=<replaceable>proprio_nome</replaceable>\n"
"AuthorEmail=<replaceable>proprio_indirizzo_di_posta</replaceable>\n"
"FileName=<replaceable>nome_della_propria_disposizione</replaceable>.layout"

#. Tag: para
#: index.docbook:308
#, no-c-format
msgid "Reload &kmahjongg; to use your new layout."
msgstr "Ricaricare &kmahjongg; per utilizzare la nuova disposizione."

#. Tag: menuchoice
#: index.docbook:314
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>Q</keycap></keycombo></"
"shortcut> <guimenu>Game</guimenu> <guimenuitem>Quit</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>Q</keycap></keycombo> </"
"shortcut> <guimenu>Partita</guimenu> <guimenuitem>Esci</guimenuitem>"

#. Tag: para
#: index.docbook:319
#, no-c-format
msgid "<action>Quits</action> &kmahjongg;."
msgstr "<action>Fa terminare</action> &kmahjongg;."

#. Tag: menuchoice
#: index.docbook:323
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>Z</keycap></keycombo></"
"shortcut> <guimenu>Move</guimenu> <guimenuitem>Undo</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>Z</keycap></keycombo> </"
"shortcut> <guimenu>Mosse</guimenu> <guimenuitem>Annulla</guimenuitem>"

#. Tag: para
#: index.docbook:328
#, no-c-format
msgid "<action>Undo</action> your last move."
msgstr "<action>Annulla</action> la tua ultima mossa."

#. Tag: menuchoice
#: index.docbook:331
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;&Shift;<keycap>Z</keycap></"
"keycombo></shortcut> <guimenu>Move</guimenu> <guimenuitem>Redo</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>Z</keycap></"
"keycombo> </shortcut> <guimenu>Mosse</guimenu> <guimenuitem>Rifai</"
"guimenuitem>"

#. Tag: para
#: index.docbook:336
#, no-c-format
msgid "<action>Redo</action> a move that was undone."
msgstr "<action>Rifa</action> una mossa che avevi annullato."

#. Tag: menuchoice
#: index.docbook:339
#, no-c-format
msgid ""
"<shortcut><keycap>H</keycap></shortcut> <guimenu>Move</guimenu> "
"<guimenuitem>Hint</guimenuitem>"
msgstr ""
"<shortcut> <keysym>H</keysym> </shortcut> <guimenu>Mosse</guimenu> "
"<guimenuitem>Suggerimento</guimenuitem>"

#. Tag: para
#: index.docbook:344
#, no-c-format
msgid "<action>Gives a Hint</action> by flashing a matching pair of tiles."
msgstr ""
"<action>Fornisce un suggerimento</action> facendo lampeggiare una coppia di "
"tessere simili."

#. Tag: menuchoice
#: index.docbook:347
#, no-c-format
msgid ""
"<shortcut><keycap>D</keycap></shortcut> <guimenu>Move</guimenu> "
"<guimenuitem>Demo</guimenuitem>"
msgstr ""
"<shortcut> <keysym>D</keysym> </shortcut> <guimenu>Mosse</guimenu> "
"<guimenuitem>Demo</guimenuitem>"

#. Tag: para
#: index.docbook:352
#, no-c-format
msgid "<action>Starts the game Demo</action> mode."
msgstr "<action>Avvia una dimostrazione</action> di come funziona il gioco."

#. Tag: menuchoice
#: index.docbook:355
#, no-c-format
msgid "<guimenu>Move</guimenu> <guimenuitem>Shuffle</guimenuitem>"
msgstr "<guimenu>Mosse</guimenu> <guimenuitem>Rimescola</guimenuitem>"

#. Tag: para
#: index.docbook:359
#, no-c-format
msgid "<action>Shuffles the tiles</action> on the board."
msgstr "<action>Rimescola le tessere</action> rimaste sul piano di gioco."

#. Tag: menuchoice
#: index.docbook:363
#, no-c-format
msgid ""
"<shortcut><keycap>G</keycap></shortcut> <guimenu>View</guimenu> "
"<guimenuitem>Rotate View Clockwise</guimenuitem>"
msgstr ""
"<shortcut><keycap>G</keycap></shortcut> <guimenu>Visualizza</guimenu> "
"<guimenuitem>Ruota la vista in senso orario</guimenuitem>"

#. Tag: para
#: index.docbook:368
#, no-c-format
msgid "<action>Rotates</action> the tile viewing angle clockwise."
msgstr ""
"<action>Ruota</action> l'angolo di vista delle tessere in senso orario."

#. Tag: menuchoice
#: index.docbook:371
#, no-c-format
msgid ""
"<shortcut><keycap>F</keycap></shortcut> <guimenu>View</guimenu> "
"<guimenuitem>Rotate View Counterclockwise</guimenuitem>"
msgstr ""
"<shortcut><keycap>F</keycap></shortcut> <guimenu>Visualizza</guimenu> "
"<guimenuitem>Ruota la vista in senso antiorario</guimenuitem>"

#. Tag: para
#: index.docbook:376
#, no-c-format
msgid "<action>Rotates</action> the tile viewing angle counter clockwise."
msgstr ""
"<action>Ruota</action> l'angolo di vista delle tessere in senso antiorario."

#. Tag: para
#: index.docbook:379
#, no-c-format
msgid ""
"Additionally &kmahjongg; has the common &kde; <guimenu>Settings</guimenu> "
"and <guimenu>Help</guimenu> menu items, for more information read the "
"sections about the <ulink url=\"help:/fundamentals/menus.html#menus-settings"
"\">Settings Menu</ulink> and <ulink url=\"help:/fundamentals/menus."
"html#menus-help\">Help Menu</ulink> of the &kde; Fundamentals."
msgstr ""
"Inoltre &kmahjongg; ha le voci dei menu <guimenu>Impostazioni</guimenu> e "
"<guimenu>Aiuto</guimenu> comuni di &kde;; per maggiori informazioni, "
"consulta i capitoli <ulink url=\"help:/fundamentals/menus.html#menus-settings"
"\">Menu Impostazioni</ulink> e <ulink url=\"help:/fundamentals/menus."
"html#menus-help\">menu Aiuto</ulink> dei «Fondamentali di &kde;»."

#. Tag: title
#: index.docbook:389
#, no-c-format
msgid "Frequently asked questions"
msgstr "Domande frequenti"

#. Tag: para
#: index.docbook:394
#, no-c-format
msgid "I want to change the way this game looks. Can I?"
msgstr "Voglio cambiare l'aspetto del gioco. È possibile?"

#. Tag: para
#: index.docbook:395
#, no-c-format
msgid ""
"Yes. To change the way &kmahjongg; looks use the <link linkend=\"menu"
"\">menubar</link> to open the <link linkend=\"configuration\">configuration "
"utility</link>."
msgstr ""
"Sì. Per cambiare l'aspetto di &kmahjongg; usa la <link linkend=\"menu"
"\">barra dei menu</link> per aprire la <link linkend=\"configuration"
"\">finestra di configurazione</link>."

#. Tag: para
#: index.docbook:398
#, no-c-format
msgid "Can I use the keyboard to play the game?"
msgstr "Si può giocare con la tastiera?"

#. Tag: para
#: index.docbook:399
#, no-c-format
msgid "No. This game does not feature a keyboard play mode yet."
msgstr ""
"No. Per il momento questo gioco non permette di giocare con la tastiera."

#. Tag: title
#: index.docbook:406
#, no-c-format
msgid "Game Configuration"
msgstr "Configurazione del gioco"

#. Tag: screeninfo
#: index.docbook:409
#, no-c-format
msgid "<screeninfo>Configure Dialog</screeninfo>"
msgstr "<screeninfo>Modulo di configurazione</screeninfo>"

#. Tag: phrase
#: index.docbook:415
#, no-c-format
msgid "<phrase>Configure Dialog</phrase>"
msgstr "<phrase>Modulo di configurazione</phrase>"

#. Tag: para
#: index.docbook:420
#, no-c-format
msgid ""
"<menuchoice><guimenu>Settings</guimenu><guimenuitem>Configure &kmahjongg;…</"
"guimenuitem></menuchoice> opens the <guilabel>Configure - &kmahjongg;</"
"guilabel> dialog."
msgstr ""
"<menuchoice><guimenu>Impostazioni</guimenu><guimenuitem>Configura "
"&kmahjongg;...</guimenuitem></menuchoice> apre la finestra "
"<guilabel>Configura – &kmahjongg;</guilabel>."

#. Tag: title
#: index.docbook:422
#, no-c-format
msgid "General options"
msgstr "Opzioni generali"

#. Tag: guilabel
#: index.docbook:425
#, no-c-format
msgid "Blink matching tiles when first one is selected"
msgstr ""
"Fai lampeggiare le tessere corrispondenti quando viene selezionata la prima"

#. Tag: para
#: index.docbook:426
#, no-c-format
msgid ""
"This setting will make the game highlight the selected tile on mouse click, "
"and flash any matching tiles that have a free side at each move. No "
"additional tiles will be highlighted if there are no matching tiles with a "
"free side."
msgstr ""
"Questa impostazione fa in modo che ad ogni mossa il gioco evidenzi la "
"tessera selezionata dal clic del mouse, e fa lampeggiare le tessere "
"corrispondenti che hanno un lato libero. Non verranno evidenziate altre "
"tessere se non ci sono tessere rimovibili."

#. Tag: guilabel
#: index.docbook:431
#, no-c-format
msgid "Generate solvable games"
msgstr "Genera giochi risolvibili"

#. Tag: para
#: index.docbook:432
#, no-c-format
msgid "Selects only games that can be solved when you start a new game."
msgstr ""
"Quando avvi un nuovo gioco la disposizione verrà scelta solo tra quelle "
"risolvibili."

#. Tag: guilabel
#: index.docbook:437
#, no-c-format
msgid "Show removed tiles"
msgstr "Mostra le tessere rimosse"

#. Tag: para
#: index.docbook:438
#, no-c-format
msgid ""
"If checked, this setting allows &kmahjongg; to show the removed tiles on the "
"board."
msgstr ""
"Se marcata, questa opzione permette a &kmahjongg; di mostrare le tessere "
"rimosse sulla disposizione."

#. Tag: title
#: index.docbook:445
#, no-c-format
msgid "Board layout options"
msgstr "Opzioni per l'Apertura"

#. Tag: guilabel
#: index.docbook:448
#, no-c-format
msgid "Random Layout"
msgstr "Disposizione casuale"

#. Tag: para
#: index.docbook:449
#, no-c-format
msgid ""
"Every new game will have a random layout of the existing one in the list."
msgstr ""
"Ogni nuova partita avrà una disposizione a caso tra quelle nella lista."

#. Tag: term
#: index.docbook:453
#, no-c-format
msgid "<guilabel>Board Layout</guilabel> selector"
msgstr "Selezionatore per l'<guilabel>Apertura</guilabel>"

#. Tag: para
#: index.docbook:454
#, no-c-format
msgid ""
"Use the <guilabel>Board Layout</guilabel> selector to pick a gameboard to "
"play. Different boards provide variable difficulty, depending on the number "
"of tiles and their position."
msgstr ""
"Usa la finestra di selezione per l'<guilabel>Apertura</guilabel> per "
"scegliere la disposizione di pezzi dell'apertura per la partita. Le varie "
"disposizioni offrono diversi gradi di difficoltà, in base al numero di "
"tessere e alla loro posizione."

#. Tag: screeninfo
#: index.docbook:458
#, no-c-format
msgid "<screeninfo>Board Layout selector</screeninfo>"
msgstr "<screeninfo>Modulo per scegliere l'apertura</screeninfo>"

#. Tag: phrase
