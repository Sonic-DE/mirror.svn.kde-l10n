msgstr "<phrase>Configurare Amarok</phrase>"

#. Tag: para
#: index.docbook:7788
#, no-c-format
msgid "<para>Configure Amarok</para>"
msgstr "<para>Configura Amarok</para>"

#. Tag: para
#: index.docbook:7793
#, no-c-format
msgid ""
"Configure many aspects of &amarok;. Details in <link linkend=\"configuring-"
"amarok\">Configuring Amarok</link>."
msgstr ""
"Configurare molti aspetti di &amarok;. Dettagli in <link linkend="
"\"configuring-amarok\">Configurare Amarok</link>."

