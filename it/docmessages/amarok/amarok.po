#. Tag: para
#: index.docbook:3620
#, no-c-format
msgid ""
"The <guilabel>Cover Manager</guilabel> organizes your album covers, the "
"<emphasis>Tag Editor</emphasis> helps &amarok; categorize your tracks, and "
"transcoding allows you to transfer tracks to your devices in encoding they "
"can play."
msgstr ""
"Il <guilabel>Gestore delle copertine</guilabel> organizza le copertine dei "
"propri album, l'<emphasis> Editor dei tag</emphasis> aiuta &amarok; a "
"categorizzare le tracce e la transcodifica consente di trasferire le tracce "
"ai propri dispositivi con codifiche che ne permettono la riproduzione."

#. Tag: para
#: index.docbook:3623
#, no-c-format
msgid "<link linkend=\"cover-manager\">Cover Manager</link>&nbsp;"
msgstr "<link linkend=\"cover-manager\">Gestore delle copertine</link>&nbsp;"

