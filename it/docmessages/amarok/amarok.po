msgid "<phrase>The Amarok Settings Menu</phrase>"
msgstr "<phrase>Il menu Impostazioni di Amarok</phrase>"

#. Tag: para
#: index.docbook:7710
#, no-c-format
msgid "<para>The Amarok Settings Menu</para>"
msgstr "<para>Il menu Impostazioni di Amarok</para>"

#. Tag: guilabel
#: index.docbook:7727
