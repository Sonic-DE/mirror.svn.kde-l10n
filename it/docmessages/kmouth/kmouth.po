#. Tag: para
#: index.docbook:35
#, no-c-format
msgid ""
"&kmouth; is an application that enables persons that cannot speak to let "
"their computers speak."
msgstr ""
"&kmouth; è un'applicazione che permette alle persone che non possono parlare "
"di far parlare il loro computer."

#. Tag: keyword
#: index.docbook:42
#, no-c-format
msgid "<keyword>KDE</keyword>"
