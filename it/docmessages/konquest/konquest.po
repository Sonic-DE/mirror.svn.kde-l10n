#, no-c-format
msgid "<guimenu>Game</guimenu> <guimenuitem>Measure Distance…</guimenuitem>"
msgstr ""
"<guimenu>Partita</guimenu> <guimenuitem>Misura della distanza</guimenuitem>"

#. Tag: para
#: index.docbook:277
#, no-c-format
msgid ""
"<action>Allows to measure the distance.</action> Click with the &LMB; on two "
"planets to see their distance."
msgstr ""
"<action>Consente di misurare la distanza.</action> Fai clic con il &LMB; su "
"due pianeti per vedere la loro distanza."

#. Tag: menuchoice
#: index.docbook:281
#, no-c-format
msgid "<guimenu>Game</guimenu> <guimenuitem>Fleet Overview</guimenuitem>"
msgstr ""
"<guimenu>Partita</guimenu> <guimenuitem>Situazione flotte</guimenuitem>"

#. Tag: para
#: index.docbook:285
#, no-c-format
msgid ""
"<action>Opens a window</action> to display detailed information for all "
"fleets."
msgstr ""
"<action>Apre una finestra</action> che mostra informazioni dettagliate su "
"tutte le flotte"

#. Tag: menuchoice
#: index.docbook:290
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>Q</keycap></keycombo> </"
