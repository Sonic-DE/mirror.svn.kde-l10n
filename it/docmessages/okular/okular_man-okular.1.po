#: man-okular.1.docbook:10
#, no-c-format
msgid ""
"<firstname>Yuri</firstname><surname>Chornoivan</surname> <contrib>Okular man "
"page.</contrib> <email>yurchor@ukr.net</email>"
msgstr ""
"<firstname>Yuri</firstname><surname>Chornoivan</surname> <contrib>Pagina di "
"manuale di Okular.</contrib> <email>yurchor@ukr.net</email>"

