"shortcut> <guimenu>Mossa</guimenu> <guimenuitem>Carica posizione</"
"guimenuitem>"

#. Tag: action
#: index.docbook:180
#, no-c-format
msgid "Loads the most recently saved position."
msgstr "Carica la posizione salvata più recentemente."

#. Tag: menuchoice
#: index.docbook:184
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>S</keycap></keycombo> </"
"shortcut> <guimenu>Move</guimenu> <guimenuitem>Save Position</guimenuitem>"
msgstr ""
