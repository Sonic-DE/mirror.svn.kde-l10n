"shortcut> <guimenu>Mossa</guimenu> <guimenuitem>Salva posizione</guimenuitem>"

#. Tag: action
#: index.docbook:187
#, no-c-format
msgid "Saves the current board position."
msgstr "Salva la posizione attuale del piano di gioco."

#. Tag: menuchoice
#: index.docbook:191
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;&Shift;<keycap>F</keycap></"
