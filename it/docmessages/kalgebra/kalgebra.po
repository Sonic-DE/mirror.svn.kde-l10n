"<shortcut><keycombo action=\"simul\">&Ctrl; <keycap>N</keycap></keycombo></"
"shortcut> <guimenu>Session</guimenu><guimenuitem>New</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl; <keycap>N</keycap></keycombo></"
"shortcut> <guimenu>Sessione</guimenu><guimenuitem>Nuova</guimenuitem>"

#. Tag: para
#: index.docbook:139
#, no-c-format
msgid "Opens a new &kalgebra; window."
msgstr "Apre una nuova finestra di &kalgebra;."

#. Tag: menuchoice
#: index.docbook:143
#, no-c-format
