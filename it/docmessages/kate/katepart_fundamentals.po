#~ "cambiamenti."

#~ msgid "Ignore All"
#~ msgstr "Ignora sempre"

#~ msgid ""
#~ "This button tells the checker to do nothing with the current "
#~ "<guilabel>Unknown word:</guilabel> and to pass over any other instances "
#~ "of the same word."
#~ msgstr ""
#~ "Questo pulsante comunica al controllo di ignorare questa <guilabel>Parola "
#~ "sconosciuta</guilabel> ed andare oltre senza considerare altre eventuali "
#~ "occorrenze della stessa parola."

#~ msgid ""
