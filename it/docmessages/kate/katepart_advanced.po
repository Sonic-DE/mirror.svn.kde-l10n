#~ "<parameter>uint colonna</parameter> ); [funzione]"

#~ msgid ""
#~ "Sets the input cursor position to [<parameter>line</parameter>, "
#~ "<parameter>col</parameter>]. This sets the string position, that is a TAB "
#~ "character counts for 1. The cursor position is made visible. Both line "
#~ "and column are zero-based."
#~ msgstr ""
#~ "Sposta la posizione del cursore nella vista a [<parameter>riga</"
#~ "parameter>, <parameter>colonna</parameter>]. Questa funzione imposta la "
#~ "posizione nella stringa di caratterim cioè un carattere di tabulazione "
#~ "conta per uno. Sia la riga che la colonna sono contate partendo da zero."

#~ msgid ""
