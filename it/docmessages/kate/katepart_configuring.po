#~ msgstr ""
#~ "<guimenu>Strumenti</guimenu><guimenuitem>Correzione ortografica (dal "
#~ "cursore)...</guimenuitem>"

#~ msgid ""
#~ "This initiates the spellchecking program but it starts where your cursor "
