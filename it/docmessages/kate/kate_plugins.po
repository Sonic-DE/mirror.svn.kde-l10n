"<guimenu>Build</guimenu><guimenuitem>Focus Next Tab to the Left</guimenuitem>"
msgstr ""
"<guimenu>Compila</guimenu> <guimenuitem>Attiva la scheda successiva sulla "
"sinistra</guimenuitem>"

#. Tag: para
