"&XML; permesse da DTD."

#. Tag: para
#: plugins.docbook:121
#, no-c-format
msgid ""
"<link linkend=\"kate-application-plugin-xmlcheck\">&XML; Validation</link>- "
"Validates &XML; files using xmllint"
msgstr ""
"<link linkend=\"kate-application-plugin-xmlcheck\">Validazione &XML;</link>: "
"valida i file &XML; con xmllint"

#. Tag: para
#: plugins.docbook:124
#, no-c-format
msgid ""
"<link linkend=\"kate-application-plugin-compilerexplorer\">Compiler "
