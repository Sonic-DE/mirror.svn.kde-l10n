#. Tag: title
#: man-neochat.1.docbook:42
#, no-c-format
msgid "Description"
msgstr "Descrizione"

#. Tag: para
#: man-neochat.1.docbook:43
#, no-c-format
msgid ""
"<command>neochat</command> is a chat application for the matrix protocol "
"that work on both desktop and mobile."
msgstr ""
"<command>neochat</command> è un'applicazione di chat per il protocollo "
"Matrix che funziona sia su desktop che su dispositivi mobili."

#. Tag: title
#: man-neochat.1.docbook:49
#, no-c-format
msgid "Options"
msgstr "Opzioni"

#. Tag: option
#: man-neochat.1.docbook:52
#, no-c-format
msgid "<option>URI</option>"
msgstr "<option>URI</option>"

#. Tag: para
#: man-neochat.1.docbook:54
#, no-c-format
msgid ""
"The matrix uri for an user or a room. e.g matrix:u/user:example.org and "
"matrix:r/root:example.org. This will makes NeoChat try to open the given "
"room or conversation."
msgstr ""
"L'URI matrix per un utente o una stanza. ad esempio matrix:u/utente:esempio."
"org e matrix:r/stanza:esempio.org. Questo farà in modo che NeoChat provi ad "
"aprire la stanza o la conversazione specificata."

#. Tag: title
#: man-neochat.1.docbook:65
#, no-c-format
msgid "Reporting bugs"
msgstr "Segnalazione bug"

#. Tag: para
#: man-neochat.1.docbook:66
#, no-c-format
