#. Tag: guimenuitem
#: commands.docbook:31
#, no-c-format
msgid "Save Symbol"
msgstr "Salvare un simbolo"

#. Tag: listitem
#: commands.docbook:32
#, no-c-format
msgid ""
"<simpara><action>Save the symbol being edited</action></simpara> <simpara>If "
"the symbol being edited was selected from the library, saving will update "
"that symbol. If it is a new symbol, it will be appended to the library and "
"subsequent saves will append another new symbol to the library. </simpara>"
msgstr ""
"<simpara><action>Salvare il simbolo in fase di modifica</action></"
"simpara><simpara>Se il simbolo in fase di modifica è stato selezionato dalla "
"libreria, il salvataggio aggiornerà quel simbolo. Se si tratta di un nuovo "
"simbolo, sarà aggiunto alla libreria e i salvataggi successivi aggiungeranno "
"un altro nuovo simbolo alla libreria. </simpara>"

#. Tag: guimenuitem
#: commands.docbook:39
#, no-c-format
msgid "Save Symbol as New"
msgstr "Salvare un simbolo come nuovo"

#. Tag: listitem
#: commands.docbook:40
#, no-c-format
msgid ""
"<simpara><action>Save the symbol being edited as a new symbol</action></"
"simpara> <simpara>When a symbol is saved as new it will be appended to the "
"library regardless of it having originally been selected from the library "
"for editing. Subsequent saves will append another new symbol to the library. "
"</simpara>"
msgstr ""
"<simpara><action>Salvare il simbolo in fase di modifica come nuovo simbolo</"
"action></simpara><simpara>Quando un simbolo viene salvato come nuovo, sarà "
"aggiunto alla libreria indipendentemente dal fatto che sia stato "
"originariamente selezionato dalla libreria per la modifica. I salvataggi "
"successivi aggiungeranno un altro nuovo simbolo alla libreria. </simpara>"

