"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>T</keycap></"
"keycombo></shortcut> <guimenu>Finestra</guimenu> <guimenuitem>Dividi la "
"vista alto/basso</guimenuitem>"

#. Tag: para
#: index.docbook:3386
#, no-c-format
msgid "Split the view from top to bottom."
msgstr "Dividi la vista dall'alto in basso."

#. Tag: menuchoice
