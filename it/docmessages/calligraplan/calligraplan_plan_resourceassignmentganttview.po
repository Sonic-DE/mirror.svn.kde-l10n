#. Tag: title
#: resourceassignmentganttview.docbook:2
#, no-c-format
msgid "<title>Description</title>"
msgstr "<title>Descrizione</title>"

#. Tag: para
#: resourceassignmentganttview.docbook:3
#, no-c-format
msgid ""
"The Resource Assignment Gantt View displays the scheduled task-resource "
"assignments in a Gantt chart."
msgstr ""
"La vista di Gantt di assegnazione delle risorse visualizza le assegnazioni "
"di attività pianificate/risorse in un diagramma di Gantt."

#. Tag: title
#: resourceassignmentganttview.docbook:24
#, no-c-format
msgid "Data"
msgstr "Dati"

#. Tag: para
#: resourceassignmentganttview.docbook:25
#, no-c-format
msgid "The following columns are displayed as default:"
msgstr "Le seguenti colonne sono visualizzate in modo predefinito:"

#. Tag: guilabel
#: resourceassignmentganttview.docbook:32
#, no-c-format
msgid "Column"
msgstr "Colonna"

#. Tag: guilabel
#: resourceassignmentganttview.docbook:33
#, no-c-format
msgid "<guilabel>Description</guilabel>"
msgstr "<guilabel>Descrizione</guilabel>"

#. Tag: para
#: resourceassignmentganttview.docbook:39
#, no-c-format
msgid "Name"
msgstr "Nome"

#. Tag: para
#: resourceassignmentganttview.docbook:42
#, no-c-format
msgid "The name of the object (Resource group, resource, task)"
msgstr "Il nome dell'oggetto (gruppo di risorse, risorsa, attività)"

#. Tag: para
#: resourceassignmentganttview.docbook:47
#, no-c-format
msgid "Type"
msgstr "Tipo"

#. Tag: para
#: resourceassignmentganttview.docbook:50
#, no-c-format
msgid "Object type"
msgstr "Tipo di oggetto"

#. Tag: para
#: resourceassignmentganttview.docbook:55
#, no-c-format
msgid "Start Time"
msgstr "Ora di inizio"

#. Tag: para
#: resourceassignmentganttview.docbook:58
#, no-c-format
msgid "The start of the assignment"
msgstr "L'inizio dell'assegnazione"

#. Tag: para
#: resourceassignmentganttview.docbook:63
#, no-c-format
msgid "End Time"
msgstr "Ora di fine"

#. Tag: para
#: resourceassignmentganttview.docbook:66
#, no-c-format
msgid "The end of the assignment"
msgstr "La fine dell'assegnazione"

#. Tag: title
#: resourceassignmentganttview.docbook:73
#, no-c-format
msgid "Editing data"
msgstr "Modificare i dati"

#. Tag: para
#: resourceassignmentganttview.docbook:74
#, no-c-format
msgid "The task description and progress can be edited using the context menu."
msgstr ""
"La descrizione e l'avanzamento dell'attività possono essere modificate "
"utilizzando il menu contestuale."

#. Tag: title
#: resourceassignmentganttview.docbook:77
#, no-c-format
msgid "Configuration"
msgstr "Configurazione"

#. Tag: para
#: resourceassignmentganttview.docbook:84
#, no-c-format
msgid ""
"Using the context menu, the view can be configured using the configure "
"dialog."
msgstr ""
"Utilizzare il menu contestuale, la vista può essere configurata utilizzando "
"la finestra di configurazione."

#. Tag: para
#: resourceassignmentganttview.docbook:84
#, no-c-format
msgid "The configure dialog enables you to select which columns to display."
msgstr ""
"La finestra di configurazione consente di selezionare quali colonne "
"visualizzare."

#. Tag: phrase
#: resourceassignmentganttview.docbook:97
#, no-c-format
msgid "<phrase>Configuration Dialog</phrase>"
msgstr "<phrase>Finestra di configurazione</phrase>"

#. Tag: para
#: resourceassignmentganttview.docbook:100
#, no-c-format
msgid "<para>Configuration Dialog</para>"
msgstr "<para>Finestra di configurazione</para>"

