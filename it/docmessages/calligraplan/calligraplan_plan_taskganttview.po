#. Tag: title
#: taskganttview.docbook:2
#, no-c-format
msgid "<title>Description</title>"
msgstr "<title>Descrizione</title>"

#. Tag: para
#: taskganttview.docbook:3
#, no-c-format
msgid "The Gantt view is used to show tasks in a timeline."
msgstr ""
"La vista Gantt è utilizzata per mostrare le attività in una linea temporale."

#. Tag: phrase
#: taskganttview.docbook:14
#, no-c-format
msgid "<phrase>Gantt View</phrase>"
msgstr "<phrase>Vista Gantt</phrase>"

#. Tag: para
#: taskganttview.docbook:17
#, no-c-format
msgid "<para>Gantt View</para>"
msgstr "<para>Vista Gantt</para>"

#. Tag: title
#: taskganttview.docbook:23
#, no-c-format
msgid "Editing data"
msgstr "Modificare i dati"

#. Tag: para
#: taskganttview.docbook:24
#, no-c-format
msgid "Task description and progress can be edited using the context menu."
msgstr ""
"La descrizione e l'avanzamento dell'attività possono essere modificate "
"utilizzando il menu contestuale."

#. Tag: para
#: taskganttview.docbook:26
#, no-c-format
msgid "The following columns are displayed as default:"
msgstr "Le seguenti colonne sono visualizzate in modo predefinito:"

#. Tag: guilabel
#: taskganttview.docbook:33
#, no-c-format
msgid "Column"
msgstr "Colonna "

#. Tag: guilabel
#: taskganttview.docbook:34
#, no-c-format
msgid "<guilabel>Description</guilabel>"
msgstr "<guilabel>Descrizione</guilabel>"

#. Tag: para
#: taskganttview.docbook:40
#, no-c-format
msgid "Name"
msgstr "Nome"

#. Tag: para
#: taskganttview.docbook:43
#, no-c-format
msgid "The name of the task."
msgstr "Il nome dell'attività."

#. Tag: para
#: taskganttview.docbook:48
#, no-c-format
msgid "Start Time"
msgstr "Ora di inizio"

#. Tag: para
#: taskganttview.docbook:51
#, no-c-format
msgid "The scheduled start time."
msgstr "L'ora d'inizio pianificata."

#. Tag: para
#: taskganttview.docbook:56
#, no-c-format
msgid "End Time"
msgstr "Ora di fine"

#. Tag: para
#: taskganttview.docbook:59
#, no-c-format
msgid "The scheduled end time."
msgstr "L'ora di fine pianificata."

#. Tag: para
#: taskganttview.docbook:64
#, no-c-format
msgid "% Completed"
msgstr "% completata"

#. Tag: para
#: taskganttview.docbook:67
#, no-c-format
msgid "Completion"
msgstr "Completamento"

#. Tag: title
#: taskganttview.docbook:74
#, no-c-format
msgid "Configuration"
msgstr "Configurazione"

#. Tag: para
#: taskganttview.docbook:81
#, no-c-format
msgid ""
"Using the context menu, the view can be configured using the configure "
"dialog."
msgstr ""
"Utilizzando il menu contestuale, la vista può essere configurata utilizzando "
"la finestra di configurazione."

#. Tag: para
#: taskganttview.docbook:82
#, no-c-format
msgid ""
"The configure dialog enables you to tailor the amount of information the "
"view displays to fit your needs."
msgstr ""
"La finestra di configurazione consente di personalizzare la quantità di "
"informazioni visualizzate dalla vista in base alle proprie esigenze."

#. Tag: phrase
#: taskganttview.docbook:93
#, no-c-format
msgid "<phrase>Configuration Dialog</phrase>"
msgstr "<phrase>Finestra di configurazione</phrase>"

