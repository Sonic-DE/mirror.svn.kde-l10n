#. Tag: title
#: resourceassignmentview.docbook:2
#, no-c-format
msgid "<title>Description</title>"
msgstr "<title>Descrizione</title>"

#. Tag: para
#: resourceassignmentview.docbook:3
#, no-c-format
msgid ""
"The Resource Assignment View displays the scheduled task-resource "
"assignments in a table."
msgstr ""
"La vista di assegnazione delle risorse visualizza le assegnazioni di "
"attività pianificate-risorse in una tabella."

#. Tag: para
#: resourceassignmentview.docbook:5
#, no-c-format
msgid "This view can severely impact performance in large projects."
msgstr ""
"Questa vista può degradare fortemente le prestazioni in progetti grandi."

#. Tag: title
#: resourceassignmentview.docbook:26
#, no-c-format
msgid "Data"
msgstr "Dati"

#. Tag: para
#: resourceassignmentview.docbook:27
#, no-c-format
msgid "The following columns are displayed as default:"
msgstr "Le seguenti colonne sono visualizzate in modo predefinito:"

#. Tag: guilabel
#: resourceassignmentview.docbook:34
#, no-c-format
msgid "Column"
msgstr "Colonna"

#. Tag: guilabel
#: resourceassignmentview.docbook:35
#, no-c-format
msgid "<guilabel>Description</guilabel>"
msgstr "<guilabel>Descrizione</guilabel>"

#. Tag: para
#: resourceassignmentview.docbook:41
#, no-c-format
msgid "Name"
msgstr "Nome"

#. Tag: para
#: resourceassignmentview.docbook:44
#, no-c-format
msgid "The name of the object (Resource group, resource, task)"
msgstr "Il nome dell'oggetto (gruppo di risorse, risorsa, attività)"

#. Tag: para
#: resourceassignmentview.docbook:49
#, no-c-format
msgid "Total"
msgstr "Totale"

#. Tag: para
#: resourceassignmentview.docbook:52
#, no-c-format
msgid "The total assignment for a resource"
msgstr "L'assegnazione totale per una risorsa"

#. Tag: para
#: resourceassignmentview.docbook:57
#, no-c-format
msgid "Dates"
msgstr "Date"

#. Tag: para
#: resourceassignmentview.docbook:60
#, no-c-format
msgid ""
"The total assignments for a resource per day and the assignments for the "
"resource per task."
msgstr ""
"Le assegnazioni totali per una risorsa per giorno e le assegnazioni per la "
"risorsa per attività."

#. Tag: title
#: resourceassignmentview.docbook:67
#, no-c-format
msgid "Editing data"
msgstr "Modificare i dati"

#. Tag: para
#: resourceassignmentview.docbook:68
#, no-c-format
msgid "The task description and progress can be edited using the context menu."
msgstr ""
"La descrizione e l'avanzamento dell'attività possono essere modificate "
"utilizzando il menu contestuale."

#~ msgid "Configuration"
#~ msgstr "Configurazione"

#~ msgid ""
#~ "Using the context menu, the view can be configured using the configure "
#~ "dialog."
#~ msgstr ""
#~ "Utilizzando il menu contestuale, la vista può essere configurata "
#~ "utilizzando la finestra di configurazione."

#~ msgid "The configure dialog enables you to include or exclude assignments."
#~ msgstr ""
#~ "La finestra di configurazione consente di includere o escludere le "
#~ "assegnazioni."

