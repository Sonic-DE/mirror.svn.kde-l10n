#. Tag: title
#: taskexecutionview.docbook:2
#, no-c-format
msgid "<title>Description</title>"
msgstr "<title>Descrizione</title>"

#. Tag: para
#: taskexecutionview.docbook:3
#, no-c-format
msgid ""
"The Task Execution View is used to inspect task performance information."
msgstr ""
"La vista di esecuzione delle attività viene utilizzata per ispezionare le "
"informazioni sulle prestazioni dell'attività."

#. Tag: title
#: taskexecutionview.docbook:20
#, no-c-format
msgid "Data"
msgstr "Dati"

#. Tag: para
#: taskexecutionview.docbook:27
#, no-c-format
msgid ""
"Progress information can be edited in-line as described <link linkend="
"\"using-the-views\">here</link> or by using the task progress dialog."
msgstr ""
"Le informazioni di avanzamento possono essere modificate in linea come "
"descritto <link linkend=\"using-the-views\">qui</link> o utilizzando la "
"finestra di avanzamento dell'attività."

