"Posizione: <filename>$KDEDIR/share/krusader/useraction-examples.xml</"
"filename>"

#. Tag: emphasis
#: configuration-files.docbook:129
#, no-c-format
msgid "foo.keymap"
msgstr "pippo.keypap"

#. Tag: para
#: configuration-files.docbook:131
#, no-c-format
msgid ""
"This is a <literal role=\"extension\">.ini</literal> file that holds a <link "
"linkend=\"configure-shortcuts\">Key binding profile</link>. Until "
"&krusader;-1.70.0 this was a binary file. &krusader; is backwards compatible "
"for importing this legacy binary format."
msgstr ""
"Questo è un file <literal role=\"extension\">.ini</literal> che contiene il "
"<link linkend=\"configure-shortcuts\">profilo delle combinazioni di tasti</"
"link>. Fino alla versione &krusader;-1.70.0 era un file binario. &krusader; "
"garantisce la retrocompatibilità con questo formato binario anche se "
"obsoleto, permettendone l'importazione."

#. Tag: para
#: configuration-files.docbook:136
#, no-c-format
msgid "Location: <filename> /usr/share/krusader/foo.keymap</filename>"
msgstr "Posizione: <filename>/usr/share/krusader/pippo.keymap</filename>"

#. Tag: emphasis
#: configuration-files.docbook:140
#, no-c-format
msgid "foo.color"
msgstr "pippo.color"

#. Tag: para
#: configuration-files.docbook:142
#, no-c-format
msgid ""
"This is a binary file that holds the <link linkend=\"konfig-color\">Color "
"Scheme</link>."
msgstr ""
"Si tratta di un file binario che contiene lo <link linkend=\"konfig-color"
"\">Schema di colori</link>."

#. Tag: para
#: configuration-files.docbook:144
#, no-c-format
msgid "Location: <filename>/usr/share/krusader/foo.color</filename>"
msgstr "Posizione: <filename>/usr/share/krusader/foo.color</filename>"

