msgstr ""
"<shortcut> <keycap>F6</keycap> </shortcut> <guimenu>File</guimenu> "
"<guimenuitem>Sposta</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:121
#, no-c-format
msgid ""
"Opens a dialog to <link linkend=\"copying\">move</link> the currently "
"selected files or folders to a specified location."
msgstr ""
"Apre una finestra di dialogo per <link linkend=\"copying\">spostare</link> i "
"file o le cartelle attualmente selezionate nella posizione specificata."

#. Tag: menuchoice
#: menu-commands.docbook:128
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift; <keycap>P</keycap></"
"keycombo> </shortcut> <guimenu>File</guimenu> <guimenuitem>Pack...</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift; <keycap>P</keycap></"
"keycombo> </shortcut> <guimenu>File</guimenu> <guimenuitem>Comprimi...</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:138
#, no-c-format
msgid ""
"Creates a <link linkend=\"pack-archive\">new archive</link> of all the "
"selected files and folders in the active panel."
msgstr ""
"Crea un <link linkend=\"pack-archive\">nuovo archivio</link> di tutti i file "
"e le cartelle selezionate nel pannello attivo."

#. Tag: menuchoice
#: menu-commands.docbook:146
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift; <keycap>U</keycap></"
"keycombo> </shortcut> <guimenu>File</guimenu> <guimenuitem>Unpack...</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift; <keycap>U</keycap></"
"keycombo> </shortcut> <guimenu>File</guimenu> <guimenuitem>Estrai...</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:156
#, no-c-format
msgid ""
"<link linkend=\"unpacking-archives\">Unpacks</link> all the selected files "
"in the active panel."
msgstr ""
"<link linkend=\"unpacking-archives\">Estrae</link> tutti i file selezionati "
"nel pannello attivo."

#. Tag: menuchoice
#: menu-commands.docbook:163
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift; <keycap>E</keycap></"
"keycombo> </shortcut> <guimenu>File</guimenu> <guimenuitem>Test Archive</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift; <keycap>E</keycap></"
"keycombo> </shortcut> <guimenu>File</guimenu> <guimenuitem>Prova archivio</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:173
#, no-c-format
msgid "<link linkend=\"test-archive\">Tests archive</link> for corruption."
msgstr ""
"<link linkend=\"test-archive\">Prova l'archivio</link> per verificare la sua "
"integrità."

#. Tag: menuchoice
#: menu-commands.docbook:180
#, no-c-format
msgid ""
"<guimenu>File</guimenu> <guimenuitem>Compare by Content...</guimenuitem>"
msgstr ""
"<guimenu>File</guimenu> <guimenuitem>Confronta per contenuto...</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:186
#, no-c-format
msgid ""
"Compares two current files by content - one from each panel via an external "
"graphical diff utility. By default &kompare; is used, but you can also use "
"&eg; <ulink url=\"http://furius.ca/xxdiff/\"><application>xxdiff</"
"application></ulink> or <ulink url=\"https://apps.kde.org/"
"kdiff3\"><application>KDiff3</application></ulink> , change it in the <link "
"linkend=\"konfig-dependencies\">Konfigurator Dependencies page</link>."
msgstr ""
"Confronta i due file selezionati in base al contenuto - uno per ciascun "
"pannello, tramite un'utilità grafica esterna di controllo delle differenze. "
"Per impostazione predefinita viene usato &kompare;, ma puoi anche usare, "
"&eg;, <ulink url=\"http://furius.ca/xxdiff/\"><application>xxdiff</"
"application></ulink> o <ulink url=\"https://apps.kde.org/"
"kdiff3\"><application>KDiff3</application></ulink>; scegli l'utilità nella "
"<link linkend=\"konfig-dependencies\">pagina Dipendenze di Konfigurator</"
"link>."

#. Tag: menuchoice
#: menu-commands.docbook:196
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Shift; <keycap>F2</keycap></keycombo> "
"</shortcut> <guimenu>File</guimenu> <guimenuitem>Multi Rename...</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Shift; <keycap>F2</keycap></keycombo> "
"</shortcut> <guimenu>File</guimenu> <guimenuitem>Rinomina multipla...</"
"guimenuitem>"

