#: menu-commands.docbook:1601
#, no-c-format
msgid ""
"<guimenu>Settings</guimenu> <guisubmenu>Toolbars</guisubmenu> "
"<guimenuitem>Show Job Toolbar</guimenuitem>"
msgstr ""
"<guimenu>Impostazioni</guimenu> <guisubmenu>Barre degli strumenti</"
"guisubmenu> <guimenuitem>Barra degli strumenti delle operazioni</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1608
#, no-c-format
msgid "Shows the <link linkend=\"job_toolbar\">Job Toolbar</link> if checked."
msgstr ""
"Mostra la <link linkend=\"job_toolbar\">Barra degli strumenti delle "
"operazioni</link>, se selezionata."

#. Tag: menuchoice
#: menu-commands.docbook:1614
#, no-c-format
msgid ""
"<guimenu>Settings</guimenu> <guisubmenu>Toolbars</guisubmenu> "
"<guimenuitem>Show Actions Toolbar</guimenuitem>"
msgstr ""
"<guimenu>Impostazioni</guimenu> <guisubmenu>Barre degli strumenti</"
"guisubmenu> <guimenuitem>Mostra la barra degli strumenti delle azioni "
"utente</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1621
#, no-c-format
msgid ""
"Shows the <link linkend=\"actions_toolbar\">Actions Toolbar</link> if "
"checked."
msgstr ""
"Mostra la <link linkend=\"actions_toolbar\">barra delle azioni utente</"
