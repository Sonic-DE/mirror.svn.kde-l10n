#~ msgid ""
#~ "<guimenu>File</guimenu> <guimenuitem>Use Current Slide as Default "
#~ "Template</guimenuitem>"
#~ msgstr ""
#~ "<guimenu>File</guimenu> <guimenuitem>Usa la diapositiva attuale come "
#~ "modello predefinito</guimenuitem>"

#~ msgid ""
#~ "<action>Sets the current slide as your default template</action>. "
#~ "Especially useful if you have created a template of your own to fit into "
#~ "corporate style guidelines, or if you just use a particular layout very "
#~ "often."
#~ msgstr ""
#~ "<action>Imposta la diapositiva attuale come il tuo modello predefinito</"
#~ "action>. Particolarmente utile se hai creato un tuo modello per adattarti "
#~ "alle linee guida di stile della compagnia, o se usi un certo schema molto "
#~ "spesso."

#~ msgid "<guimenu>Edit</guimenu> Menu"
#~ msgstr "Il menu <guimenu>Modifica</guimenu>"

#~ msgid "<guimenu>Edit</guimenu> <guimenuitem>Duplicate Slide</guimenuitem>"
#~ msgstr ""
#~ "<guimenu>Modifica</guimenu> <guimenuitem>Duplica diapositiva</guimenuitem>"

#~ msgid ""
#~ "<guimenu>Edit</guimenu> <guimenuitem>Duplicate Object...</guimenuitem>"
#~ msgstr ""
#~ "<guimenu>Modifica</guimenu><guimenuitem>Duplica oggetto...</guimenuitem>"

#~ msgid ""
#~ "Create a duplicate of the currently selected object. A dialog will "
#~ "display allowing you to set some options for the duplicate, &eg; if it "
#~ "should be rotated, or scaled, or offset to a new position on the slide."
#~ msgstr ""
#~ "Crea un duplicato dell'oggetto attualmente selezionato. Apparirà una "
#~ "finestra che ti permetterà di impostare alcune opzioni per il duplicato, "
#~ "per esempio se dovrebbe essere ruotato, riscalato o spostato a una nuova "
#~ "posizione sulla diapositiva."

#~ msgid "<guimenu>View</guimenu> Menu"
#~ msgstr "Il menu <guimenu>Visualizza</guimenu>"

#~ msgid ""
#~ "<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>W</keycap></"
#~ "keycombo></shortcut> <guimenu>View</guimenu> <guimenuitem>Close All "
#~ "Views</guimenuitem>"
#~ msgstr ""
#~ "<shortcut><keycombo action=\"simul\">&Ctrl;&Shift;<keycap>W</keycap></"
#~ "keycombo></shortcut> <guimenu>Visualizza</guimenu><guimenuitem>Chiudi "
#~ "tutte le viste</guimenuitem>"

#~ msgid ""
#~ "<action>Close all views on the presentation.</action> You will be given a "
#~ "chance to save any changes, or to cancel closing."
#~ msgstr ""
#~ "<action>Chiude tutte le viste della presentazione.</action> Ti sarà data "
#~ "la possibilità di salvare ogni cambiamento, o di annullare, quando chiudi."

#~ msgid "<guimenu>View</guimenu> <guimenuitem>Split View</guimenuitem>"
#~ msgstr ""
#~ "<guimenu>Visualizza</guimenu><guimenuitem>Dividi la vista</guimenuitem>"

#~ msgid ""
#~ "<action>Splits the window into two (or more) views on the same "
#~ "presentation.</action> The default split is horizontal."
#~ msgstr ""
#~ "<action>Divide la finestra in due (o più) viste della stessa "
#~ "presentazione.</action> La divisione predefinita è orizzontale."

#~ msgid "<guimenu>View</guimenu> <guimenuitem>Remove View</guimenuitem>"
#~ msgstr ""
#~ "<guimenu>Visualizza</guimenu><guimenuitem>Rimuovi la vista</guimenuitem>"

#~ msgid ""
#~ "<action>Close only the currently active view</action>. The presentation, "
#~ "and any other views you have open, remain open, and any changes you have "
#~ "made remain unsaved."
#~ msgstr ""
#~ "<action>Chiude solo la vista attualmente attiva</action>. La "
#~ "presentazione, e ogni altra vista che potrebbe essere aperta, rimangono "
#~ "aperte, e ogni cambiamento che hai fatto non è ancora salvato."

#~ msgid ""
#~ "<guimenu>View</guimenu> <guisubmenu>Splitter Orientation</guisubmenu>"
#~ msgstr ""
#~ "<guimenu>Visualizza</guimenu><guisubmenu>Orientazione della divisione</"
#~ "guisubmenu>"

#~ msgid ""
#~ "<action>Toggle the split view</action> between <guimenuitem>Horizontal</"
#~ "guimenuitem> (the default) and <guimenuitem>Vertical</guimenuitem>."
#~ msgstr ""
#~ "<action>Passa tra le modalità di divisione della vista</action> "
#~ "<guimenuitem>Orizzontale</guimenuitem> (predefinita) e "
#~ "<guimenuitem>Verticale</guimenuitem>."

#~ msgid ""
#~ "<action>Toggle the display of the sidebar</action> where you can see an "
#~ "overview of all the slides in your presentation."
#~ msgstr ""
#~ "<action>Commuta la visualizzazione della barra laterale</action> dove "
#~ "puoi vedere una panoramica di tutte le diapositive della tua "
#~ "presentazione."

#~ msgid "<guimenu>View</guimenu> <guimenuitem>Show Notebar</guimenuitem>"
#~ msgstr ""
#~ "<guimenu>Visualizza</guimenu> <guimenuitem>Mostra la barra delle note</"
#~ "guimenuitem>"

#~ msgid ""
#~ "<action>Toggle the display of the notebar</action> where you can see an "
#~ "overview of all the notes in your presentation."
#~ msgstr ""
#~ "<action>Commuta la visualizzazione della barra delle note</action> dove "
#~ "puoi vedere una panoramica di tutte le note della tua presentazione."

#~ msgid "<guimenu>View</guimenu> <guimenuitem>Slide Master</guimenuitem>"
#~ msgstr ""
#~ "<guimenu>Visualizza</guimenu><guimenuitem>Diapositiva principale</"
#~ "guimenuitem>"

#~ msgid ""
#~ "<guimenu>View</guimenu> <guimenuitem>Formatting Characters</guimenuitem>"
#~ msgstr ""
#~ "<guimenu>Visualizza</guimenu> <guimenuitem>Caratteri di formattazione</"
#~ "guimenuitem>"

#~ msgid ""
#~ "Show a visual representation of <quote>non-printing characters</quote>, "
#~ "such as tabs and paragraph markers. This can be a useful aid to precisely "
#~ "positioning text."
#~ msgstr ""
#~ "Mostra una rappresentazione visuale dei <quote>caratteri non stampabili</"
#~ "quote>, come tabulatori e delimitatori di paragrafo. Può essere un valido "
#~ "aiuto per posizionare il testo con precisione."

#~ msgid ""
#~ "This item can be toggled. If enabled, formatting characters are visible; "
#~ "if disabled, they are not."
#~ msgstr ""
#~ "Questo elemento può essere commutato. Se abilitato, i caratteri di "
#~ "formattazione sono visibili; se disabilitato, non lo sono."

#~ msgid "<guimenu>View</guimenu> <guimenuitem>Guide Lines</guimenuitem>"
#~ msgstr ""
#~ "<guimenu>Visualizza</guimenu> <guimenuitem>Linee guida</guimenuitem>"

#~ msgid "<guimenu>View</guimenu> <guimenuitem>Add Guide Line...</guimenuitem>"
#~ msgstr ""
#~ "<guimenu>Visualizza</guimenu> <guimenuitem>Aggiungi linea guida...</"
#~ "guimenuitem>"

#~ msgid ""
#~ "Opens a dialog to select the <guilabel>Orientation</guilabel> "
#~ "(<guilabel>Horizontal</guilabel> or <guilabel>Vertical</guilabel>) and "
#~ "choose a <guilabel>Position:</guilabel>"
#~ msgstr ""
#~ "Apre una finestra per selezionare l'<guilabel>Orientazione</guilabel> "
#~ "(<guilabel>Orizzontale</guilabel> o <guilabel>Verticale</guilabel>) e "
#~ "scegliere una <guilabel>Posizione:</guilabel>"

#~ msgid "<guimenu>Insert</guimenu> Menu"
#~ msgstr "Il menu <guimenu>Inserisci</guimenu>"

#~ msgid ""
#~ "<shortcut> <keycombo action=\"simul\">&Alt;&Shift;<keycap>C</keycap></"
#~ "keycombo> </shortcut> <guimenu>Insert</guimenu> <guimenuitem>Special "
#~ "Character...</guimenuitem>"
#~ msgstr ""
#~ "<shortcut><keycombo action=\"simul\"> &Alt;&Shift;<keycap>C</keycap></"
#~ "keycombo> </shortcut> <guimenu>Inserisci</guimenu> <guimenuitem>Carattere "
#~ "speciale...</guimenuitem>"

#~ msgid ""
#~ "Insert a special character. This might be a character you don't have a "
#~ "key for on your keyboard layout, for instance &uuml; on a US Keyboard."
#~ msgstr ""
#~ "Inserisci un carattere speciale. Potrebbe essere un carattere per cui non "
#~ "hai un tasto sulla tua tastiera, per esempio &Egrave; su una tastiera "
#~ "italiana."

#~ msgid "<guimenu>Insert</guimenu> <guimenuitem>Link...</guimenuitem>"
#~ msgstr ""
#~ "<guimenu>Inserisci</guimenu><guimenuitem>Collegamento...</guimenuitem>"

#~ msgid ""
#~ "Insert a hyperlink to a file, a website, or an email address. This "
#~ "enables these locations to be linked to directly from within active "
#~ "presentations, with resources being handled as appropriately by other "
#~ "applications installed on your system."
#~ msgstr ""
#~ "Inserisci un collegamento ipertestuale a un file, un sito Web, o un "
#~ "indirizzo di posta elettronica. Ciò permette a questi indirizzi di essere "
#~ "collegati direttamente da una presentazione attiva ed essere gestiti da "
#~ "altre applicazioni installate sul tuo sistema."

#~ msgid "<guimenu>Insert</guimenu> <guimenuitem>Comment...</guimenuitem>"
#~ msgstr "<guimenu>Inserisci</guimenu><guimenuitem>Commento...</guimenuitem>"

#~ msgid ""
#~ "Enter a small note that does not display during the real presentation. "
#~ "You might use this to comment on a colleague's text, or to leave a note "
#~ "for yourself about something to do later."
#~ msgstr ""
#~ "Inserisci una breve nota che non viene visualizzata nella presentazione "
#~ "vera e propria. Potresti usare questo commento sul testo di un collega, o "
#~ "per lasciare una nota per te stesso su qualcosa da fare più tardi."

#~ msgid ""
#~ "<shortcut><keycap>F2</keycap></shortcut> <guimenu>Insert</guimenu> "
#~ "<guimenuitem>Slide...</guimenuitem>"
#~ msgstr ""
#~ "<shortcut><keycap>F2</keycap></shortcut> <guimenu>Inserisci</guimenu> "
#~ "<guimenuitem>Diapositiva...</guimenuitem>"

#~ msgid ""
#~ "<action>Add a new page to your presentation.</action> A dialog will open "
#~ "allowing you to choose a template, and whether to insert the new page "
#~ "before or after the currently selected page."
#~ msgstr ""
#~ "<action>Aggiunge una nuova pagina alla presentazione.</action> Si aprirà "
#~ "una finestra che ti permetterà di scegliere un modello, e se inserire la "
#~ "nuova pagina prima o dopo la pagina attualmente selezionata."

