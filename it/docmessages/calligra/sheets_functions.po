msgid "NOW()"
msgstr "NOW()"

#. Tag: para
#: functions.docbook:1519
#, no-c-format
msgid "NOW() returns \"Saturday 13 April 2002 19:12:01\""
msgstr "NOW() restituisce \"19:12, sabato 13 aprile 2002\""

