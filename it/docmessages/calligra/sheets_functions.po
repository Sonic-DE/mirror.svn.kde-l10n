#, no-c-format
msgid "ISOWEEKNUM(date)"
msgstr "ISOWEEKNUM(data)"

#. Tag: para
#: functions.docbook:1352
#, no-c-format
msgid "ISOWEEKNUM(A1) returns 51 when A1 is \"21st of Dec\"."
msgstr "ISOWEEKNUM(A1) restituisce 51 se A1 è \"21 dic\"."

