#: functions.docbook:6892
#, no-c-format
msgid "Numerator"
msgstr "Numeratore"

#. Tag: seg
#: functions.docbook:6893
#, no-c-format
msgid "Denumerator"
msgstr "Denominatore"

#. Tag: para
#: functions.docbook:6896
#, no-c-format
msgid "QUOTIENT(21;4) returns 5"
msgstr "QUOTIENT(21;4) restituisce 5"

