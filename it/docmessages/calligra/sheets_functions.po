#. Tag: title
#: functions.docbook:322
#, no-c-format
msgid "CHARTOASCII"
msgstr "CHARTOASCII"

#. Tag: para
#: functions.docbook:323
#, no-c-format
msgid ""
"The CHARTOASCII() function returns the ASCII code for the given character."
msgstr ""
"La funzione CHARTOASCII() restituisce il codice ASCII per un dato carattere."

#. Tag: para
#: functions.docbook:328
#, no-c-format
msgid "CHARTOASCII(value)"
msgstr "CHARTOASCII(valore)"

#. Tag: seg
#: functions.docbook:332
#, no-c-format
msgid "A one character string to convert"
msgstr "Una stringa di un carattere da convertire"

#. Tag: para
#: functions.docbook:335
#, no-c-format
msgid "CHARTOASCII(\"v\") returns 118"
msgstr "CHARTOASCII(\"v\") restituisce 118"

#. Tag: para
#: functions.docbook:338
#, no-c-format
msgid "CHARTOASCII(r) is an error. The character must be in quotes."
msgstr "CHARTOASCII(r) è un errore. Il carattere deve essere tra virgolette."

#. Tag: title
#: functions.docbook:344
#, no-c-format
msgid "DECSEX"
msgstr "DECSEX"

#. Tag: para
#: functions.docbook:345
#, no-c-format
