msgid "HOUR"
msgstr "HOUR"

#. Tag: para
#: functions.docbook:1274
#, no-c-format
msgid ""
"The HOUR functions returns the hour of a time. If no parameter is specified "
"the current hour gets returned."
msgstr ""
"La funzione HOUR restituisce l'ora di un orario. Se non vengono specificati "
"parametri, viene restituita l'ora attuale."

#. Tag: para
#: functions.docbook:1279
#, no-c-format
msgid "HOUR(time)"
msgstr "HOURS(orario)"

#. Tag: seg
#: functions.docbook:1283 functions.docbook:1311 functions.docbook:1373
#: functions.docbook:1401 functions.docbook:1541 functions.docbook:1569
#: functions.docbook:1615
#, no-c-format
msgid "Time"
msgstr "Ora"

#. Tag: para
#: functions.docbook:1286
#, no-c-format
msgid "HOUR(\"22:10:12\") returns 22"
msgstr "HOUR(\"22:5:2\") restituisce 22"

#. Tag: para
#: functions.docbook:1289
#, no-c-format
msgid "HOUR(0.1285) returns 3"
msgstr "HOUR(0,1285) restituisce 3"

#. Tag: member
