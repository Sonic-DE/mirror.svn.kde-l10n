msgstr "DAYSINMONTH"

#. Tag: para
#: functions.docbook:1155
#, no-c-format
msgid ""
"The function DAYSINMONTH() returns the number of days in the given year and "
"month."
msgstr ""
"La funzione DAYSINMONTH() restituisce il numero di giorni in un dato mese di "
"un dato anno."

#. Tag: para
#: functions.docbook:1160
#, no-c-format
msgid "DAYSINMONTH(year;month)"
msgstr "DAYSINMONTH(anno;mese)"

#. Tag: para
#: functions.docbook:1168
#, no-c-format
msgid "DAYSINMONTH(2000;2) returns 29"
msgstr "DAYSINMONTH(2000;2) restituisce 29"

#. Tag: title
#: functions.docbook:1174
#, no-c-format
msgid "DAYSINYEAR"
msgstr "DAYSINYEAR"

#. Tag: para
#: functions.docbook:1175
#, no-c-format
msgid "The function DAYSINYEAR() returns the number of days in the given year."
msgstr ""
"La funzione DAYSINYEAR() restituisce il numero di giorni in un dato anno."

#. Tag: para
#: functions.docbook:1180
#, no-c-format
msgid "DAYSINYEAR(year)"
msgstr "DAYSINYEAR(anno)"

#. Tag: para
#: functions.docbook:1187
#, no-c-format
msgid "DAYSINYEAR(2000) returns 366"
msgstr "DAYSINYEAR(2000) restituisce 366"

#. Tag: title
#: functions.docbook:1193
#, no-c-format
msgid "EASTERSUNDAY"
msgstr "EASTERSUNDAY"

#. Tag: para
#: functions.docbook:1194
#, no-c-format
msgid ""
"The EASTERSUNDAY() function returns the date which corresponds to Easter "
"Sunday in the year given as the parameter."
msgstr ""
"La funzione EASTERSUNDAY() restituisce la data in cui cadrà la Pasqua "
"dell'anno fornito come parametro."

#. Tag: para
#: functions.docbook:1199
#, no-c-format
msgid "EASTERSUNDAY(year)"
msgstr "EASTERSUNDAY(anno)"

#. Tag: para
#: functions.docbook:1206
#, no-c-format
msgid "EASTERSUNDAY(2003) returns \"20th April 2003\""
msgstr "EASTERSUNDAY(2003) restituisce \"20 aprile 2003\""

#. Tag: title
#: functions.docbook:1212
#, no-c-format
msgid "EDATE"
msgstr "EDATE"

#. Tag: para
#: functions.docbook:1213
#, no-c-format
msgid ""
"The EDATE functions returns the date that is specified by a given date and a "
"number of months before or after that date."
msgstr ""
"La funzione EDATE restituisce la data calcolata sommando o sottraendo un "
"certo numero di mesi ad un giorno assegnato."

#. Tag: para
#: functions.docbook:1218
#, no-c-format
msgid "EDATE(date; months)"
msgstr "EDATE(data;mesi)"

#. Tag: seg
#: functions.docbook:1223 functions.docbook:1252
#, no-c-format
msgid "Months"
msgstr "Mesi"

#. Tag: para
#: functions.docbook:1226
#, no-c-format
msgid "EDATE(\"2/22/2002\"; 3) returns \"5/22/2002\""
msgstr "EDATE(\"22/2/2002\"; 3) restituisce \"22/5/2002\""

#. Tag: para
#: functions.docbook:1229
#, no-c-format
msgid "EDATE(\"3/31/2002\"; -1) returns \"2/28/2002\""
msgstr "EDATE(\"31/3/2002\"; -1) restituisce \"28/2/2002\""

#. Tag: member
#: functions.docbook:1233
#, no-c-format
msgid "<link linkend=\"DATE\">DATE</link>&nbsp;"
msgstr "<link linkend=\"DATE\">DATE</link>&nbsp;"

