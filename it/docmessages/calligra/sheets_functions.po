#. Tag: title
#: functions.docbook:237
#, no-c-format
msgid "BOOL2STRING"
msgstr "BOOL2STRING"

#. Tag: para
#: functions.docbook:238
#, no-c-format
msgid ""
"The BOOL2STRING() function returns a string value for a given boolean value. "
"This method is intended for using a boolean in methods which require a string"
msgstr ""
"La funzione BOOL2STRING() restituisce un valore stringa per ogni dato valore "
"booleano. Questo metodo è inteso per l'utilizzo di un booleano nei metodi "
"che richiedono una stringa"

#. Tag: para
#: functions.docbook:243
#, no-c-format
msgid "BOOL2STRING(value)"
msgstr "BOOL2STRING(valore)"

#. Tag: para
#: functions.docbook:250
#, no-c-format
msgid "BOOL2STRING(true) returns \"True\""
msgstr "BOOL2STRING(true) restituisce \"True\""

#. Tag: para
#: functions.docbook:253
#, no-c-format
msgid "BOOL2STRING(false) returns \"False\""
msgstr "BOOL2STRING(false) restituisce \"False\""

#. Tag: para
#: functions.docbook:256
#, no-c-format
msgid "upper(BOOL2STRING(find(\"nan\";\"banana\"))) returns TRUE"
msgstr "upper(BOOL2STRING(find(\"nan\";\"banana\"))) restituisce TRUE"

#. Tag: title
#: functions.docbook:262
#, no-c-format
msgid "CARX"
msgstr "CARX"

#. Tag: para
#: functions.docbook:263
#, no-c-format
