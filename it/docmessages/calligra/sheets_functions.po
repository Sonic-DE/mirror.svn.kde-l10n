#: functions.docbook:3760
#, no-c-format
msgid ""
"MDURATION(\"2004-02-01\"; \"2004-05-31\"; 0.08; 0.09; 2; 0) returns "
"0.316321106"
msgstr ""
"MDURATION(\"1/2/2004\"; \"31/5/2004\"; 0,08; 0,09; 2; 0) restituisce "
"0,316321106"

