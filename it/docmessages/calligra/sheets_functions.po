#: functions.docbook:1035
#, no-c-format
msgid "DAY(date)"
msgstr "Giorno(data)"

#. Tag: para
#: functions.docbook:1042
#, no-c-format
msgid "DAY(\"2/22/2002\") returns 22"
msgstr "DAY(\"22/2/2002\") restituisce 22"

#. Tag: para
#: functions.docbook:1045
#, no-c-format
msgid "DAY(2323.1285) returns 11"
msgstr "DAY(2323,1285) restituisce 11"

