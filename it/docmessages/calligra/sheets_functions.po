msgstr "ISNOTTEXT"

#. Tag: para
#: functions.docbook:4721
#, no-c-format
msgid ""
"The ISNOTTEXT() function returns True if the parameter is not a string. "
"Otherwise it returns False. It's the same as ISNONTEXT."
msgstr ""
"La funzione ISNOTTEXT() restituisce True se il parametro non è una stringa. "
"Altrimenti restituisce False. È identica alla funzione ISNONTEXT."

#. Tag: para
#: functions.docbook:4726
#, no-c-format
msgid "ISNOTTEXT(x)"
msgstr "ISNOTTEXT(x)"

#. Tag: para
#: functions.docbook:4733
#, no-c-format
msgid "ISNOTTEXT(12) returns True"
msgstr "ISNOTTEXT(12) restituisce True"

#. Tag: para
#: functions.docbook:4736
#, no-c-format
msgid "ISNOTTEXT(\"hello\") returns False"
msgstr "ISNOTTEXT(\"ciao\") restituisce False"

