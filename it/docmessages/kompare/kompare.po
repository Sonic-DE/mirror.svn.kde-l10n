msgstr "<para>File di origine e di destinazione</para>"

#. Tag: para
#: index.docbook:128
#, no-c-format
msgid "<para>Source and Destination Line Changes</para>"
msgstr "<para>Cambiamenti di righe di origine e di destinazione</para>"

#. Tag: para
#: index.docbook:129
#, no-c-format
msgid "Source and Destination Text View"
