#. Tag: para
#: index.docbook:39
#, no-c-format
msgid ""
"The TNEF File Viewer is an application for <ulink url=\"https://en.wikipedia."
"org/wiki/TNEF\">TNEF</ulink> mail attachments."
msgstr ""
"Il visualizzatore di file TNEF è un'applicazione per gli allegati di posta "
"in formato <ulink url=\"https://en.wikipedia.org/wiki/TNEF\">TNEF</ulink>."

#. Tag: keyword
#: index.docbook:42
#, no-c-format
msgid "mail"
msgstr "posta"

#. Tag: keyword
#: index.docbook:43
#, no-c-format
