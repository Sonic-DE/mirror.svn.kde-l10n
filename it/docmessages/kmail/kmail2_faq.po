#~ "fine del processo l'elenco dei messaggi avrà lo stesso carattere degli "
#~ "altri elementi."

#~ msgid "How to remove alternate line colourings?"
#~ msgstr "Come disabilitare la strisce alternate di colori diversi?"

#~ msgid ""
#~ "In <menuchoice><guimenu>&systemsettings;</guimenu><guisubmenu>Application "
#~ "Appearance</guisubmenu><guimenuitem>Colors</"
