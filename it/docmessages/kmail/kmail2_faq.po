#~ "color set except <guilabel>Common Colors</guilabel> (which doesn't have "
#~ "it), change the <guilabel>Alternate Background</guilabel> to be the same "
#~ "as the <guilabel>Normal Background</guilabel>."
#~ msgstr ""
#~ "In <menuchoice><guimenu>&systemsettings;</guimenu><guisubmenu>Aspetto "
#~ "delle applicazioni</guisubmenu><guimenuitem>Colori</"
#~ "guimenuitem><guimenuitem>Colori</guimenuitem></menuchoice>, modifica il "
#~ "valore di <guilabel>Sfondo alternativo</guilabel> in modo che sia lo "
#~ "stesso di <guilabel>Sfondo normale</guilabel> per ogni insieme di colori "
#~ "eccetto <guilabel>Colori comuni</guilabel> (che non ce l'ha)."

#~ msgid ""
