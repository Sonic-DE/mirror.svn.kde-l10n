#. Tag: para
#: index.docbook:36
#, no-c-format
msgid "&kiten; is a Japanese reference/study tool by &kde;."
msgstr ""
"&kiten; è uno strumento di &kde; di riferimento e di studio del giapponese."

#. Tag: keyword
#: index.docbook:45
#, no-c-format
msgid "<keyword>KDE</keyword>"
msgstr "<keyword>KDE</keyword>"

#. Tag: keyword
#: index.docbook:46
#, no-c-format
msgid "Japanese"
msgstr "Giapponese"

#. Tag: keyword
#: index.docbook:47
#, no-c-format
msgid "Language"
