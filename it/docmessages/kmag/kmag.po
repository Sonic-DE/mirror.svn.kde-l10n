msgstr "Esce dall'applicazione"

#. Tag: title
#: index.docbook:260
#, no-c-format
msgid "The Edit Menu"
msgstr "Il menu <guimenu>Modifica</guimenu>"

#. Tag: menuchoice
#: index.docbook:265
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>C</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Copy</guimenuitem>"
msgstr ""
