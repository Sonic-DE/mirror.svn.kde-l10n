#~ msgid ""
#~ "The following commands are defined in definitions.tex: <itemizedlist> "
#~ "<listitem><userinput>\\command[\\optarg]{\\symbol}</userinput>: <para> "
#~ "Include the symbol <userinput>\\symbol</userinput> in the symbol list, "
#~ "the optional argument <userinput>\\optarg</userinput> specifies the "
#~ "command which kile should insert. If it is not given the command in the "
#~ "mandatory argument is used.</para></listitem> <listitem><userinput>"
#~ "\\mathcommand[\\optarg]{\\symbol}</userinput>: <para> Same as above, "
#~ "except that the command in the mandatory argument is inserted in math "
#~ "mode.</para></listitem> <listitem><userinput>\\pkgs[arg]{pkg}</"
#~ "userinput>: <para> Declare that the command given in this line needs the "
#~ "&latex; package <userinput>pkg</userinput> with the optional argument "
#~ "<userinput>arg</userinput>. This command has to be in front of the "
#~ "<userinput>\\command</userinput> command and overrides any package "
#~ "specification by the neededpkgs enviroment.</para></listitem> "
#~ "<listitem><userinput>\\begin{neededpkgs}[pkgs-args]{pkgs} ... "
#~ "\\end{neededpkgs}</userinput>: <para> Has the same effect as above, but "
#~ "for all enclosed commands.</para></listitem> </itemizedlist> An example "
#~ "for completeness is given here:"
#~ msgstr ""
#~ "In <filename>definitions.tex</filename> sono disponibili i seguenti "
#~ "comandi:<itemizedlist><listitem><userinput>\\<command>command</"
#~ "command>[\\<replaceable>argomento opzionale</replaceable>]"
#~ "{\\<replaceable>simbolo</replaceable>}</userinput>: <para>Includi il "
#~ "simbolo <userinput>\\<replaceable>simbolo</replaceable></userinput> "
#~ "nell'elenco dei simboli, l'<userinput>\\<replaceable>argomento opzionale</"
#~ "replaceable></userinput> specifica il comando che &kile; dovrebbe "
#~ "inserire. Se non viene dato, verrà usato il comando nell'argomento tra "
#~ "parentesi graffe.</para></listitem><listitem><userinput>"
#~ "\\<command>mathcommand</command>[<replaceable>argomento opzionale</"
#~ "replaceable>]{<replaceable>simbolo</replaceable>}</userinput>: "
#~ "<para>Esattamente come sopra, eccetto che il comando nell'argomento "
#~ "obbligatorio viene inserito in modalità matematica.</para></"
#~ "listitem><listitem><userinput>\\<command>pkgs</"
#~ "command>[<replaceable>argomenti</replaceable>]{<replaceable>pacchetto</"
#~ "replaceable>}</userinput>: <para>Dichiara che il comando dato in questa "
#~ "riga ha bisogno del pacchetto &latex; <userinput><replaceable>pacchetto</"
#~ "replaceable></userinput>. Questo comando deve essere prima del comando "
#~ "<userinput>\\<command>command</command></userinput> e sostituisce "
#~ "qualsiasi specifica dei pacchetti dell'ambiente <option>neededpkgs</"
#~ "option>.</para></listitem><listitem><userinput>\\<command>begin</"
#~ "command>{<option>neededpkgs</option>}[<replaceable>opzioni</replaceable>]"
#~ "{<replaceable>pacchetti</replaceable>} ... \\<command>end</"
#~ "command>{<option>neededpkgs</option>}</userinput>: <para>Ha lo stesso "
#~ "effetto del comando sopra enunciato, ma per tutti i comandi compresi tra "
#~ "l'inizio e la fine dell'ambiente.</para></listitem></itemizedlist>Per "
#~ "completezza, ecco un esempio: :"

