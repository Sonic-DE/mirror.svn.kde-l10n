#~ "#\n"
#~ "#           Unicode   Tasto     x     y    Largh.  Alt.\n"
#~ "#\n"
#~ "ControlKey  260      Tab        0     10    15    10\n"
#~ "ControlKey  13       Enter      138   20    12    10\n"
