#. Tag: para
#: index.docbook:58
#, no-c-format
msgid ""
"&i18n-kapplication; is a work-in-progress infinite whiteboard tool written "
"in Qt/C++."
msgstr ""
"&i18n-kapplication; è uno strumento di lavagna infinita in fase di sviluppo, "
"scritto in Qt/C++."

#. Tag: title
#: index.docbook:61
#, no-c-format
msgid "Using &i18n-kapplication;"
msgstr "Utilizzare &i18n-kapplication;"

#. Tag: para
#: index.docbook:63
#, no-c-format
msgid ""
"&i18n-kapplication; is a work-in-progress infinite whiteboard tool written "
"in Qt/C++, which aims to be a native-desktop alternative to the amazing web-"
"based Excalidraw."
msgstr ""
"&i18n-kapplication; è uno strumento di lavagna infinita in fase di sviluppo, "
"scritto in Qt/C++, che si propone di essere un'alternativa desktop nativa "
"allo straordinario Excalidraw basato sul web."

