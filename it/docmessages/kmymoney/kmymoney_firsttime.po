msgstr ""
"<guiicon> <inlinemediaobject> <imageobject> <imagedata fileref="
"\"forecast_view.png\" format=\"PNG\"/> </imageobject> <textobject> "
"<phrase>Vista delle previsioni</phrase> </textobject> </inlinemediaobject> </"
"guiicon> Previsione: previsione dei saldi dei tuoi conti e categorie."

