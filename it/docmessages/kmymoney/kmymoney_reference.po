#. Tag: para
#: reference.docbook:436
#, no-c-format
msgid ""
"Opens a YTD (Year to date) chart of the balance of the selected account."
msgstr "Apre un grafico YTD (da inizio anno) del saldo del conto selezionato."

#. Tag: menuchoice
#: reference.docbook:441
#, no-c-format
msgid "<guimenu>Account</guimenu><guimenuitem>Close account</guimenuitem>"
msgstr "<guimenu>Conto</guimenu><guimenuitem>Chiudi conto</guimenuitem>"

