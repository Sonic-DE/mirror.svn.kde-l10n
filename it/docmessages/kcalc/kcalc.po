#, no-c-format
msgid "<keycap>H</keycap>"
msgstr "<keycap>H</keycap>"

#. Tag: entry
#: index.docbook:517
#, no-c-format
msgid "Hyperbolic as in Hyp Sin, the sinh"
msgstr "Iperbolico, come ad esempio in Iper sen, il seno iperbolico"

#. Tag: keycap
#: index.docbook:520
#, no-c-format
msgid "<keycap>S</keycap>"
msgstr "<keycap>S</keycap>"

#. Tag: keycap
#: index.docbook:524
#, no-c-format
msgid "<keycap>C</keycap>"
msgstr "<keycap>C</keycap>"

#. Tag: keycap
#: index.docbook:528
#, no-c-format
msgid "<keycap>T</keycap>"
msgstr "<keycap>T</keycap>"

