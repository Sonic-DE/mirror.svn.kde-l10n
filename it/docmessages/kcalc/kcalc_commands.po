#. Tag: title
#: commands.docbook:3
#, no-c-format
msgid "Command Reference"
msgstr "Guida ai comandi"

#. Tag: title
#: commands.docbook:6
#, no-c-format
msgid "Menu Items"
msgstr "Voci dei menu"

#. Tag: para
#: commands.docbook:8
#, no-c-format
msgid "A brief overview of some special menu items in &kcalc;:"
msgstr "Una breve panoramica di alcune voci dei menu speciali di &kcalc;:"

#. Tag: menuchoice
#: commands.docbook:12
#, no-c-format
msgid "<guimenu>Constants</guimenu> <guimenuitem>Mathematics</guimenuitem>"
msgstr "<guimenu>Costanti</guimenu> <guimenuitem>Matematica</guimenuitem>"

#. Tag: action
#: commands.docbook:16
#, no-c-format
msgid "Display Pi, Euler Number or Golden Ratio."
msgstr "Mostra pi greco, il numero di nepero o la sezione aurea."

#. Tag: menuchoice
#: commands.docbook:21
#, no-c-format
msgid ""
"<guimenu>Constants</guimenu> <guimenuitem>Electromagnetism</guimenuitem>"
msgstr ""
"<guimenu>Costanti</guimenu> <guimenuitem>Elettromagnetismo</guimenuitem>"

#. Tag: action
#: commands.docbook:25
#, no-c-format
msgid ""
"Display Light Speed, Elementary Charge, Impedance of Vacuum, Permeability of "
"Vacuum or Permittivity of Vacuum."
msgstr ""
"Mostra la velocità della luce, la carica elementare, l'impedenza del vuoto, "
"la permeabilità oppure la permittività del vuoto."

#. Tag: menuchoice
#: commands.docbook:31
#, no-c-format
msgid ""
"<guimenu>Constants</guimenu> <guimenuitem>Atomic &amp; Nuclear</guimenuitem>"
msgstr ""
"<guimenu>Costanti</guimenu> <guimenuitem>Fisica atomica e nucleare</"
"guimenuitem>"

#. Tag: action
#: commands.docbook:35
#, no-c-format
msgid ""
"Display Planck's Constant, Elementary Charge or Fine-Structure Constant."
msgstr ""
"Mostra la costante di Planck, la carica elementare o la costante di "
"struttura fine."

#. Tag: menuchoice
#: commands.docbook:41
#, no-c-format
msgid "<guimenu>Constants</guimenu> <guimenuitem>Thermodynamics</guimenuitem>"
msgstr "<guimenu>Costanti</guimenu> <guimenuitem>Termodinamica</guimenuitem>"

#. Tag: action
#: commands.docbook:45
#, no-c-format
msgid ""
"Display Boltzmann Constant, Atomic Mass Unit, Molar Gas Constant, Stefan-"
"Boltzmann Constant or Avogadro's Number."
msgstr ""
"Mostra la costante di Boltzmann, l'unità di massa atomica, la costante "
"universale dei gas perfetti, la costante di Stefan-Boltzmann oppure il "
"numero di Avogadro."

#. Tag: menuchoice
#: commands.docbook:51
#, no-c-format
msgid "<guimenu>Constants</guimenu> <guimenuitem>Gravitation</guimenuitem>"
msgstr "<guimenu>Costanti</guimenu> <guimenuitem>Gravità</guimenuitem>"

#. Tag: para
#: commands.docbook:55
#, no-c-format
msgid "Display Constant of Gravitation or Earth Acceleration."
msgstr "Mostra la costante di gravità o l'accelerazione della terra."

#. Tag: menuchoice
#: commands.docbook:60
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Simple Mode</guimenuitem>"
msgstr ""
"<guimenu>Impostazioni</guimenu> <guimenuitem>Modalità semplice</guimenuitem>"

#. Tag: action
#: commands.docbook:64
#, no-c-format
msgid "Displays the simple math buttons."
msgstr "Mostra i pulsanti matematici semplici."

#. Tag: menuchoice
#: commands.docbook:69
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Science Mode</guimenuitem>"
msgstr ""
"<guimenu>Impostazioni</guimenu> <guimenuitem>Modalità scientifica</"
"guimenuitem>"

#. Tag: action
#: commands.docbook:73
#, no-c-format
msgid "Displays trigonometric and science buttons."
msgstr "Mostra i pulsanti per la trigonometria e la scienza."

#. Tag: menuchoice
#: commands.docbook:78
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Statistic Mode</guimenuitem>"
msgstr ""
"<guimenu>Impostazioni</guimenu> <guimenuitem>Modalità statistica</"
"guimenuitem>"

#. Tag: action
#: commands.docbook:82
#, no-c-format
msgid "Displays <link linkend=\"statistical-mode\">statistic buttons.</link>"
msgstr ""
"Mostra i <link linkend=\"statistical-mode\">pulsanti statistici</link>."

#. Tag: menuchoice
#: commands.docbook:88
#, no-c-format
msgid ""
"<guimenu>Settings</guimenu> <guimenuitem>Numeral System Mode</guimenuitem>"
msgstr ""
"<guimenu>Impostazioni</guimenu> <guimenuitem>Modalità base di numerazione</"
"guimenuitem>"

#. Tag: action
#: commands.docbook:92
#, no-c-format
msgid ""
"Displays <link linkend=\"and-or-xor\">logic buttons</link> and allows "
"changing the numeral system."
msgstr ""
"Mostra i <link linkend=\"and-or-xor\">pulsanti logici</link> e permette di "
"cambiare la base di numerazione."

#. Tag: menuchoice
#: commands.docbook:98
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Show History</guimenuitem>"
msgstr ""
"<guimenu>Impostazioni</guimenu> <guimenuitem>Mostra la cronologia</"
"guimenuitem>"

#. Tag: action
#: commands.docbook:102
#, no-c-format
msgid "Display the history."
msgstr "Mostra la cronologia."

#. Tag: menuchoice
#: commands.docbook:107
#, no-c-format
msgid ""
"<guimenu>Settings</guimenu> <guimenuitem>Constants Buttons</guimenuitem>"
msgstr ""
"<guimenu>Impostazioni</guimenu> <guimenuitem>Pulsanti delle costanti</"
"guimenuitem>"

#. Tag: action
#: commands.docbook:111
#, no-c-format
msgid ""
"Display constants buttons. They are available in <link linkend=\"science-mode"
"\">science mode</link> and <link linkend=\"statistical-mode\">statistic "
"mode</link>."
msgstr ""
"Mostra i pulsanti delle costanti. Sono disponibili in <link linkend="
"\"science-mode\">modalità scientifica</link> e <link linkend=\"statistical-"
"mode\">statistica</link>."

#. Tag: menuchoice
#: commands.docbook:117
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Show Bit Edit</guimenuitem>"
msgstr ""
"<guimenu>Impostazioni</guimenu> <guimenuitem>Mostra modificatori dei bit</"
"guimenuitem>"

#. Tag: action
#: commands.docbook:121
#, no-c-format
msgid ""
"Displays a bit edit field. Click on a bit to toggle it. Only available in "
"<link linkend=\"numeral-system-mode\">numeral system mode</link>."
msgstr ""
"Mostra un campo di modifica dei bit. Fai clic su un bit per commutarlo. "
"Disponibile solo in <link linkend=\"numeral-system-mode\">modalità base di "
"numerazione</link>."

#. Tag: para
#: commands.docbook:128
#, no-c-format
msgid ""
"Additionally &kcalc; has the common <guimenu>File</guimenu>, <guimenu>Edit</"
"guimenu>, <guimenu>Settings</guimenu> and <guimenu>Help</guimenu> menu "
"items, for more information read the sections about the <ulink url=\"help:/"
"fundamentals/menus.html\">Menus</ulink> in the &kde; Fundamentals."
msgstr ""
"Inoltre, &kcalc; ha le normali voci del menu <guimenu>File</guimenu>, "
"<guimenu>Modifica</guimenu>, <guimenu>Impostazioni</guimenu> e "
"<guimenu>Aiuto</guimenu>; per maggiori informazioni leggi la sezione sui "
"<ulink url=\"help:/fundamentals/menus.html\">menu</ulink> nei Fondamentali "
"di &kde;."

