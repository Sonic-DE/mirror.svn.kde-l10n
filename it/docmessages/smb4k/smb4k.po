msgstr "Predefinito: <guimenuitem>In basso</guimenuitem>"

#. Tag: guibutton
#: index.docbook:1577
#, no-c-format
msgid "Show custom bookmark label if available"
msgstr "Mostra etichetta personalizzata del segnalibro se disponibile"

#. Tag: para
#: index.docbook:1580
#, no-c-format
msgid ""
"The custom description (label) of the bookmark is shown. It can be defined "
"in the <link linkend=\"bookmarks_editor\">bookmark editor</link>."
msgstr ""
"Viene visualizzata la descrizione personalizzata (etichetta) del segnalibro. "
"Può essere definita nell'<link linkend=\"bookmarks_editor\">editor dei "
"segnalibri</link>."

#. Tag: para
#: index.docbook:1581 index.docbook:1610 index.docbook:1619 index.docbook:1628
#: index.docbook:1637 index.docbook:1646 index.docbook:1712 index.docbook:1754
