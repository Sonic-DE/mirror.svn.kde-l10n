msgstr "<guimenuitem>In alto</guimenuitem>"

#. Tag: para
#: index.docbook:1544
#, no-c-format
msgid "The tabs are located at the top."
msgstr "Le schede sono posizionate in alto."

#. Tag: guimenuitem
#: index.docbook:1549
#, no-c-format
msgid "Bottom"
msgstr "In basso"

#. Tag: para
#: index.docbook:1552
#, no-c-format
msgid "The tabs are located at the bottom."
msgstr "Le schede sono posizionate in basso."

#. Tag: guimenuitem
#: index.docbook:1557
#, no-c-format
msgid "Left"
msgstr "A sinistra"

#. Tag: para
#: index.docbook:1560
#, no-c-format
msgid "The tabs are located on the left side."
msgstr "Le schede sono posizionate nella parte sinistra."

#. Tag: guimenuitem
#: index.docbook:1565
#, no-c-format
