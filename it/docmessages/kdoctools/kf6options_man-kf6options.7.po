#. Tag: refpurpose
#: man-kf6options.7.docbook:22
#, no-c-format
msgid "Common commandline options for all applications based on &kf6-full;"
msgstr ""
"Opzioni dalla riga di comando comuni a tutte le applicazioni basate su &kf6-"
"full;"

#. Tag: cmdsynopsis
#: man-kf6options.7.docbook:26
#, no-c-format
msgid ""
"<command><replaceable>KDE application</replaceable></command> <arg choice="
"\"opt\"><option>-h, --help</option></arg> <arg choice=\"opt\"><option>-v, --"
"version</option></arg> <arg choice=\"opt\"><option>--author</option></arg> "
"<arg choice=\"opt\"><option>--license</option></arg> <arg choice=\"opt"
"\"><option>--desktopfile</option> <replaceable>file name</replaceable></arg>"
msgstr ""
"<command><replaceable>applicazione KDE</replaceable></command> <arg choice="
"\"opt\"><option>-h, --help</option></arg> <arg choice=\"opt\"><option>-v, --"
"version</option></arg> <arg choice=\"opt\"><option>--author</option></arg> "
"<arg choice=\"opt\"><option>--license</option></arg> <arg choice=\"opt"
"\"><option>--desktopfile</option> <replaceable>nome file</replaceable> </arg>"

#. Tag: title
#: man-kf6options.7.docbook:37
#, no-c-format
msgid "Options"
msgstr "Opzioni"

#. Tag: para
#: man-kf6options.7.docbook:39
#, no-c-format
msgid "The following options apply to all &kde; applications:"
msgstr "Le seguenti opzioni si applicano a tutte le applicazioni di &kde;:"

#. Tag: term
#: man-kf6options.7.docbook:43
#, no-c-format
msgid "<option>-h</option> <option>--help</option>"
msgstr "<option>-h</option> <option>--help</option>"

#. Tag: para
#: man-kf6options.7.docbook:44
#, no-c-format
msgid "This lists the options available at the command line."
msgstr "Questo elenca le opzioni disponibili da riga di comando."

#. Tag: term
#: man-kf6options.7.docbook:49
#, no-c-format
msgid "<option>-v</option> <option>--version</option>"
msgstr "<option>-v</option> <option>--version</option>"

#. Tag: para
#: man-kf6options.7.docbook:51
#, no-c-format
msgid ""
"Lists version information for <replaceable>KDE application</replaceable>."
msgstr ""
"Mostra le informazioni di versione per l'<replaceable>applicazione KDE</"
"replaceable>"

#. Tag: option
#: man-kf6options.7.docbook:55
#, no-c-format
msgid "--author"
msgstr "--author"

#. Tag: para
#: man-kf6options.7.docbook:56
#, no-c-format
msgid ""
"Lists <replaceable>KDE application</replaceable> authors in the terminal "
"window."
msgstr ""
"Mostra gli autori per le <replaceable>applicazioni KDE</replaceable> nella "
"finestra di terminale."

#. Tag: option
#: man-kf6options.7.docbook:60
#, no-c-format
msgid "--license"
msgstr "--license"

#. Tag: para
#: man-kf6options.7.docbook:61
#, no-c-format
msgid "Shows license information."
msgstr "Mostra le informazioni di licenza."

#. Tag: term
#: man-kf6options.7.docbook:65
#, no-c-format
msgid "<option>--desktopfile</option> <replaceable>file name</replaceable>"
msgstr "<option>--desktopfile</option> <replaceable>nome file</replaceable>"

#. Tag: para
#: man-kf6options.7.docbook:66
#, no-c-format
msgid "The base file name of the desktop entry for this application."
msgstr "Il percorso del file della voce del desktop per questa applicazione."

#. Tag: para
#: man-kf6options.7.docbook:67
#, no-c-format
msgid ""
"This is in particular useful for wrapper applications and applications "
"having in general multiple desktop files. Thus each desktop file can put its "
"own name into the exec command."
msgstr ""
"Questo è utile in particolare per applicazioni adattatori ed per "
"applicazioni in generale con più file desktop. In questo modo ogni file "
"desktop può specificare il proprio nome nel comando exec."

#. Tag: title
#: man-kf6options.7.docbook:78
#, no-c-format
msgid "See Also"
msgstr "Vedi anche"

#. Tag: para
#: man-kf6options.7.docbook:79
#, no-c-format
msgid "qt6options(7)"
msgstr "qt6options(7)"

#. Tag: title
#: man-kf6options.7.docbook:84
#, no-c-format
msgid "Authors"
msgstr "Autori"

#. Tag: para
#: man-kf6options.7.docbook:85
#, no-c-format
msgid ""
"Man page originally written by &Lauri.Watts; &Lauri.Watts.mail; for kdelibs4"
msgstr ""
"Pagina di manuale originariamente scritta da &Lauri.Watts; &Lauri.Watts."
"mail; per kdelibs4"

#. Tag: para
#: man-kf6options.7.docbook:86
#, no-c-format
msgid "Updated to &frameworks; 5 by &Burkhard.Lueck; &Burkhard.Lueck.mail;"
msgstr "Aggiornata a &frameworks; 5 da &Burkhard.Lueck; &Burkhard.Lueck.mail;"

#~ msgid "kf5options User's Manual"
#~ msgstr "Manuale utente kf5options"

#~ msgid "2014-03-04"
#~ msgstr "2014-03-04"

#~ msgid ""
#~ "<command><replaceable>KDE application</replaceable></command> <arg choice="
#~ "\"opt\">KDE Generic Options</arg>"
#~ msgstr ""
#~ "<command><replaceable>Applicazione KDE</replaceable></command> <arg "
#~ "choice=\"opt\">Opzioni generiche KDE</arg>"

#~ msgid "<option>--caption</option> <parameter>caption</parameter>"
#~ msgstr "<option>--caption</option> <parameter>titolo</parameter>"

#~ msgid "Use <parameter>caption</parameter> as name in the titlebar."
#~ msgstr "Usa <parameter>titolo</parameter> come nome nella barra del titolo."

#~ msgid "Use <parameter>icon</parameter> as the application icon."
#~ msgstr "Usa <parameter>icona</parameter> come icona dell'applicazione."

#~ msgid "<option>--config</option> <parameter>filename</parameter>"
#~ msgstr "<option>--config</option> <parameter>nomefile</parameter>"

#~ msgid "Use the alternative configuration <parameter>filename</parameter>"
#~ msgstr "Usa la configurazione alternativa <parameter>nomefile</parameter>"

#~ msgid "--nocrashhandler"
#~ msgstr "--nocrashhandler"

#~ msgid "Disable the crash handler, to get core dumps."
#~ msgstr "Disattiva la gestione dei crash, per ottenere i core dump."

#~ msgid "--waitforwm"
#~ msgstr "--waitforwm"

#~ msgid "Waits for a WM_NET compatible windowmanager."
#~ msgstr ""
#~ "Resta in attesa di un gestore delle finestre (windowmanager) compatibile "
#~ "con WM_NET."

#~ msgid "<option>--style</option> <parameter>style</parameter>"
#~ msgstr "<option>--style</option> <parameter>stile</parameter>"

#~ msgid "Sets the application &GUI; style."
#~ msgstr "Imposta lo stile della &GUI; dell'applicazione."

#~ msgid "<option>--geometry</option> <parameter>geometry</parameter>"
#~ msgstr "<option>--geometry</option> <parameter>geometria</parameter>"

#~ msgid "Sets the client geometry of the main widget."
#~ msgstr "Imposta la geometria del client dell'elemento principale."

#~ msgid "<replaceable>qt5options</replaceable>(7)"
#~ msgstr "<replaceable>qt5options</replaceable>(7)"

#~ msgid "2004-02-02"
#~ msgstr "2004-02-02"

#~ msgid "KDE Software"
#~ msgstr "Software KDE"

#~ msgid "K Desktop Environment"
#~ msgstr "Ambiente desktop KDE"

#~ msgid "<option>--display</option> <parameter>displayname</parameter>"
#~ msgstr "<option>--display</option> <parameter>nomedisplay</parameter>"

#~ msgid "<option>--session</option> <parameter>sessionId</parameter>"
#~ msgstr "<option>--session</option> <parameter>IDSessione</parameter>"

#~ msgid ""
#~ "Restore the application for the given <parameter>sessionId</parameter>."
#~ msgstr ""
#~ "Ripristina l'applicazione per l'<parameter>IDSessione</parameter> "
#~ "specificato."

#~ msgid "--cmap"
#~ msgstr "--cmap"

#~ msgid ""
#~ "Causes the application to install a private color map on an 8-bit display."
#~ msgstr ""
#~ "Induce l'applicazione ad installare una mappa colori personalizzata in un "
#~ "display a 8 bit."

#~ msgid ""
#~ "Limits the number of colors allocated in the color cube on an 8-bit "
#~ "display, if the application is using the <methodname>QApplication::"
#~ "ManyColor</methodname> color specification."
#~ msgstr ""
#~ "Limita il numero di colori allocati nel cubo del colore su un display a 8 "
#~ "bit, se l'applicazione sta usando la specifica colore "
#~ "<methodname>QApplication::ManyColor</methodname>."

#~ msgid "--nograb"
#~ msgstr "--nograb"

#~ msgid "Tells &Qt; to never grab the mouse or the keyboard."
#~ msgstr "Dice a &Qt; di non gestire il mouse o la tastiera."

#~ msgid "--dograb"
#~ msgstr "--dograb"

#~ msgid ""
#~ "Running under a debugger can cause an implicit <option>--nograb</option>, "
#~ "use <option>--dograb</option> to override."
#~ msgstr ""
#~ "L'esecuzione all'interno di un debugger può causare l'attivazione "
#~ "implicita dell'opzione <option>--nograb</option>, usa <option>--dograb</"
#~ "option> per evitare questo comportamento."

#~ msgid "--sync"
#~ msgstr "--sync"

#~ msgid "Switches to synchronous mode for debugging."
#~ msgstr "Passa alla modalità di debug sincrona."

#~ msgid ""
#~ "<option>--fn</option>,<option>--font</option> <parameter>fontname</"
#~ "parameter>"
#~ msgstr ""
#~ "<option>--fn</option>,<option>--font</option> <parameter>nomefont</"
#~ "parameter>"

#~ msgid "Defines the application font."
#~ msgstr "Definisce il font dell'applicazione."

#~ msgid ""
#~ "<option>--bg</option>,<option>--background</option> <parameter>color</"
#~ "parameter>"
#~ msgstr ""
#~ "<option>--bg</option>,<option>--background</option> <parameter>colore</"
#~ "parameter>"

#~ msgid ""
#~ "Sets the default background color and an application palette (light and "
#~ "dark shades are calculated)."
#~ msgstr ""
#~ "Imposta il colore di sfondo predefinito e la gamma di colori "
#~ "dell'applicazione (le ombre chiare e scure vengono calcolate)."

#~ msgid ""
#~ "<option>--fg</option>,<option>--foreground</option> <parameter>color</"
#~ "parameter>"
#~ msgstr ""
#~ "<option>--fg</option>,<option>--foreground</option> <parameter>colore</"
#~ "parameter>"

#~ msgid "Sets the default foreground color"
#~ msgstr "Imposta il colore del primo piano."

#~ msgid ""
#~ "<option>--btn</option>,<option>--button</option> <parameter>color</"
#~ "parameter>"
#~ msgstr ""
#~ "<option>--btn</option>,<option>--button</option> <parameter>colore</"
#~ "parameter>"

#~ msgid "Sets the default button color."
#~ msgstr "Imposta il colore predefinito del pulsante."

#~ msgid "Sets the application title (caption)."
#~ msgstr "Imposta il titolo dell'applicazione."

#~ msgid "<option>--visual</option> <parameter>TrueColor</parameter>"
#~ msgstr "<option>--visual</option> <parameter>TrueColor</parameter>"

#~ msgid ""
#~ "Forces the application to use a <parameter>TrueColor</parameter> visual "
#~ "on an 8-bit display."
#~ msgstr ""
#~ "Forza l'applicazione ad usare una visuale <parameter>TrueColor</"
#~ "parameter> in un display a 8 bit."

#~ msgid "<option>--inputstyle</option> <parameter>inputstyle</parameter>"
#~ msgstr "<option>--inputstyle</option> <parameter>stileinput</parameter>"

#~ msgid ""
#~ "Sets XIM (X Input Method) input style. Possible values are "
#~ "<parameter>onthespot</parameter>, <parameter>overthespot</parameter>, "
#~ "<parameter>offthespot</parameter> and <parameter>root</parameter>."
#~ msgstr ""
#~ "Imposta lo stile di input di XIM (Metodo di Input di X). I valori "
#~ "possibili sono <parameter>onthespot</parameter>, <parameter>overthespot</"
#~ "parameter>, <parameter>offthespot</parameter> e <parameter>root</"
#~ "parameter>."

#~ msgid "<option>--im</option> <parameter>XIM server</parameter>"
#~ msgstr "<option>--im</option> <parameter>Server XIM</parameter>"

#~ msgid "Set XIM server."
#~ msgstr "Imposta il server XIM."

#~ msgid "--noxim"
#~ msgstr "--noxim"

#~ msgid "Disable XIM"
#~ msgstr "Disabilita XIM"

#~ msgid "--reverse"
#~ msgstr "--reverse"

#~ msgid "mirrors the whole layout of widgets"
#~ msgstr "mette allo specchio il layout degli elementi"

#~ msgid ""
#~ "<date>2004-02-02</date> <productname>K Desktop Environment</productname>"
#~ msgstr ""
#~ "<date>02-02-2004</date> <productname>Ambiente Desktop KDE</productname>"
