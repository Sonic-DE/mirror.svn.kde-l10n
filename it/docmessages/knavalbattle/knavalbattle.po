msgstr ""
"<guimenu>Partita</guimenu> <guimenuitem>Singolo giocatore</guimenuitem>"

#. Tag: action
#: index.docbook:262
#, no-c-format
msgid "Start a game with your computer as the opponent."
msgstr "Avvia una partita contro il computer."

#. Tag: menuchoice
#: index.docbook:269
#, no-c-format
msgid "<guimenu>Game</guimenu> <guimenuitem>Host Game…</guimenuitem>"
msgstr "<guimenu>Partita</guimenu> <guimenuitem>Server di gioco…</guimenuitem>"

#. Tag: action
#: index.docbook:277
#, no-c-format
msgid "Start the server so another player can connect to you."
msgstr "Avvia il server in modo che un altro giocatore possa connettersi a te."

#. Tag: menuchoice
#: index.docbook:284
#, no-c-format
msgid "<guimenu>Game</guimenu> <guimenuitem>Connect to Game…</guimenuitem>"
msgstr ""
"<guimenu>Partita</guimenu> <guimenuitem>Collegarsi per giocare…</guimenuitem>"

#. Tag: action
#: index.docbook:292
#, no-c-format
msgid "Connect to a server to start a game."
msgstr "Collegarsi a un server per incominciare una partita."

#. Tag: menuchoice
#: index.docbook:299
#, no-c-format
