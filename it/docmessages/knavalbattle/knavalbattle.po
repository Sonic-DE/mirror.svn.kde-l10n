"<guimenuitem>Riavvia la battaglia</guimenuitem>"

#. Tag: action
#: index.docbook:232
#, no-c-format
msgid "Restart the game."
msgstr "Riavvia la partita."

#. Tag: menuchoice
#: index.docbook:239
#, no-c-format
