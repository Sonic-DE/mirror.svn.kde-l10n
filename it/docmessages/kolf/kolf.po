msgstr ""
"<guimenu>Partita</guimenu> <guimenuitem>Salva partita come</guimenuitem>"

#. Tag: para
#: index.docbook:291
#, no-c-format
msgid ""
"Open a file dialog allowing you to <action>save the current game with a "
