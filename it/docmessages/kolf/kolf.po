msgstr "<action>Termina la partita attuale, senza chiudere</action> &kolf;"

#. Tag: menuchoice
#: index.docbook:309
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>H</keycap></keycombo> </"
