#. Tag: action
#: index.docbook:325
#, no-c-format
msgid "Show name, author, and number of holes of the course."
msgstr "Mostra nome, autore e numero di buche del percorso."

#. Tag: menuchoice
#: index.docbook:330
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>Q</keycap></keycombo> </"
