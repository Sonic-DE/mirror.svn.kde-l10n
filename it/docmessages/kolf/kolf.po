msgstr "Visualizza la classifica."

#. Tag: menuchoice
#: index.docbook:321
#, no-c-format
msgid "<guimenu>Game</guimenu><guimenuitem>About Course…</guimenuitem>"
msgstr ""
"<guimenu>Partita</guimenu><guimenuitem>Informazioni sul percorso...</"
