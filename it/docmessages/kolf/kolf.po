#. Tag: action
#: index.docbook:487
#, no-c-format
msgid "Go to the last hole in the course."
msgstr "Vai all'ultima buca del percorso."

#. Tag: menuchoice
#: index.docbook:492
#, no-c-format
msgid "<guimenu>Go</guimenu> <guimenuitem>Random Hole</guimenuitem>"
msgstr "<guimenu>Vai</guimenu><guimenuitem>Buca a caso</guimenuitem>"

#. Tag: action
