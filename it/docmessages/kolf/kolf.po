msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>Q</keycap></keycombo> </"
"shortcut><guimenu>Partita</guimenu><guimenuitem>Esci</guimenuitem>"

#. Tag: para
#: index.docbook:335
#, no-c-format
msgid "<action>Quit</action> &kolf;."
msgstr "<action>Chiudi</action> &kolf;."

#. Tag: title
#: index.docbook:342
#, no-c-format
msgid "The Hole Menu"
msgstr "Il menu Buca"

#. Tag: menuchoice
#: index.docbook:346
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>E</keycap></keycombo> </"
"shortcut> <guimenu>Hole</guimenu> <guimenuitem>Edit</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>E</keycap></keycombo> </"
"shortcut> <guimenu>Buca</guimenu><guimenuitem>Modifica</guimenuitem>"

#. Tag: para
#: index.docbook:353
#, no-c-format
msgid "<action>Switch to editing mode</action> to edit the current hole."
msgstr ""
"<action>Passa alla modalità modifica</action> per modificare la buca attuale."

#. Tag: menuchoice
#: index.docbook:358
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>N</keycap></"
"keycombo> </shortcut> <guimenu>Hole</guimenu> <guimenuitem>New</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;&Shift;<keycap>N</keycap></"
"keycombo> </shortcut><guimenu>Buca</guimenu><guimenuitem>Nuova</guimenuitem>"

#. Tag: para
#: index.docbook:365
#, no-c-format
msgid "<action>Create a new hole.</action> (Only while editing.)"
msgstr ""
"<action>Crea una nuova buca</action>(Solamente nella modalità modifica)"

#. Tag: menuchoice
#: index.docbook:370
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Del;</keycombo> </shortcut> "
"<guimenu>Hole</guimenu> <guimenuitem>Clear</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Del;</keycombo> </shortcut> "
"<guimenu>Buca</guimenu><guimenuitem>Cancella</guimenuitem>"

#. Tag: para
#: index.docbook:377
#, no-c-format
msgid ""
"<action>Remove all objects from the current hole.</action> (Only while "
"editing.)"
msgstr ""
"<action>Rimuove tutti gli oggetti dalla buca attuale</action> (Solamente "
"nella modalità modifica)"

#. Tag: menuchoice
#: index.docbook:383
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>R</keycap></keycombo></"
"shortcut> <guimenu>Hole</guimenu> <guimenuitem>Reset</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>R</keycap></keycombo> </"
"shortcut><guimenu>Buca</guimenu><guimenuitem>Ripristina</guimenuitem>"

#. Tag: para
#: index.docbook:390
#, no-c-format
msgid ""
"<action>Reset the current hole to its starting position</action>, so that "
"you can start over."
msgstr ""
"<action>Riporta la buca attuale alla posizione di partenza</action>, in modo "
"da ricominciare da capo."

#. Tag: menuchoice
#: index.docbook:396
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>I</keycap></keycombo> </"
"shortcut> <guimenu>Hole</guimenu> <guimenuitem>Show Info</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap></keycap></keycombo> </"
"shortcut><guimenu>Buca</guimenu><guimenuitem>Mostra Informazioni</"
"guimenuitem>"

#. Tag: action
#: index.docbook:403
#, no-c-format
msgid "Show information about objects on the current hole."
msgstr "Mostra informazioni sui vari oggetti presenti sul percorso."

#. Tag: menuchoice
#: index.docbook:408
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>Z</keycap></keycombo> </"
"shortcut> <guimenu>Hole</guimenu> <guimenuitem>Undo Shot</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>Z</keycap></keycombo> </"
"shortcut><guimenu>Buca</guimenu><guimenuitem>Annulla Colpo</guimenuitem>"

#. Tag: action
#: index.docbook:415
#, no-c-format
msgid "Undo the last shot you made."
msgstr "Annulla l'ultimo colpo."

