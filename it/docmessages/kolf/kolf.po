msgstr "<guimenu>Vai</guimenu><guisubmenu>Alla Buca</guisubmenu>"

#. Tag: para
#: index.docbook:432
#, no-c-format
msgid ""
"<action>Go directly to another hole within the course.</action> A list of "
"the hole numbers allows you to choose which hole you wish to go to."
msgstr ""
"<action>Vai direttamente ad un'altra buca all'interno del percorso</action> "
"Si aprirà una lista che ti permetterà di scegliere la buca."

#. Tag: menuchoice
#: index.docbook:439
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Right;</keycombo> </shortcut> "
"<guimenu>Go</guimenu> <guimenuitem>Next Hole</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Right;</keycombo> </shortcut> "
"<guimenu>Vai</guimenu><guimenuitem>Buca successiva</guimenuitem>"

