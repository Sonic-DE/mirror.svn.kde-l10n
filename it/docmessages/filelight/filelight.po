"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>+</keycap></keycombo> </"
"shortcut><guimenu>Visualizza</guimenu> <guimenuitem>Ingrandisci</guimenuitem>"

#. Tag: action
#: index.docbook:231
#, no-c-format
msgid "Increase the view of the filemap."
msgstr "Ingrandisci la visualizzazione della mappa dei file."

#. Tag: menuchoice
#: index.docbook:236
#, no-c-format
