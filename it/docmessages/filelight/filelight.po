"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>-</keycap></keycombo> </"
"shortcut><guimenu>Visualizza</guimenu> <guimenuitem>Rimpicciolisci</"
"guimenuitem>"

#. Tag: action
#: index.docbook:243
#, no-c-format
msgid "Decrease the view of the filemap."
msgstr "Rimpicciolisci la visualizzazione della mappa dei file."

#. Tag: title
#: index.docbook:249
#, no-c-format
msgid "The Go Menu"
msgstr "Il menu Vai"

#. Tag: menuchoice
#: index.docbook:251
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt;<keycap>Up</keycap></keycombo> </"
"shortcut> <guimenu>Go</guimenu> <guimenuitem>Up</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Alt;<keycap>↑</keycap></keycombo></"
"shortcut><guimenu>Vai</guimenu><guimenuitem>Su</guimenuitem>"

#. Tag: action
#: index.docbook:258
#, no-c-format
msgid "Moves you up one step in the filesystem to the parent folder."
msgstr "Si sposta in alto nel filesystem, nella cartella madre."

#. Tag: menuchoice
#: index.docbook:262
#, no-c-format
msgid "<guimenu>Go</guimenu> <guimenuitem>Back</guimenuitem>"
msgstr "<guimenu>Vai</guimenu> <guimenuitem>Indietro</guimenuitem>"

#. Tag: action
#: index.docbook:266
#, no-c-format
msgid "Moves you one step back in your browsing history of the filesystem."
msgstr ""
"Si sposta un passo indietro nella cronologia della navigazione del "
"filesystem."

#. Tag: menuchoice
#: index.docbook:270
#, no-c-format
msgid "<guimenu>Go</guimenu> <guimenuitem>Forward</guimenuitem>"
msgstr "<guimenu>Vai</guimenu> <guimenuitem>Avanti</guimenuitem>"

#. Tag: action
#: index.docbook:274
#, no-c-format
msgid "Moves you one step forward in your browsing history of the filesystem."
msgstr ""
"Si sposta un passo avanti nella cronologia della navigazione del filesystem."

#. Tag: para
#: index.docbook:279
#, no-c-format
msgid ""
"Additionally &filelight; has the common &kde; <guimenu>Settings</guimenu> "
