# | "1                                            \n"
# | "  - * - - - - - -         - - - - - - - -         - - - - - - - -       \n"
# | "  - * - - - - - -         - - - - - - - -         - - - - - - - -       \n"
# | "1 * * - - - - - -         - - - - - - - -         - O - - - - O -       \n"
# | "  - - O - - - - -         - - O - - - - -         - - * * * * - -\n"
# | "  - - - - - - - -         - - - * * * * * 2     3 * * * - - * - -\n"
# | "  - - - - - - - -         - - - * - - - -         - - - O - * - -      \n"
# | "  - - - - - - - -         - - - * - - - -         - - - - * * - -       \n"
# | "  - - - - - - - -         - - - * - - - -         - - - - * - O -       \n"
# | "                                2                         3"
#. Tag: screen
#: index.docbook:147
#, no-c-format
msgid ""
"1\n"
"  - * - - - - - -         - - - - - - - -         - - - - - - - -       \n"
