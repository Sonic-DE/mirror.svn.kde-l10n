#, no-c-format
msgid "New Task"
msgstr "Nuova attività"

#. Tag: guiicon
#: index.docbook:483
#, no-c-format
msgid "New Subtask"
msgstr "Nuova attività secondaria"

#. Tag: guiicon
#: index.docbook:484
#, no-c-format
msgid "Start"
msgstr "Avvia"

#. Tag: guiicon
#: index.docbook:485
#, no-c-format
msgid "Stop"
msgstr "Ferma"

#. Tag: guiicon
#: index.docbook:486
#, no-c-format
msgid "Delete"
msgstr "Elimina"

#. Tag: guiicon
#: index.docbook:487
#, no-c-format
msgid "Edit"
msgstr "Modifica"

#. Tag: guiicon
#: index.docbook:488
#, no-c-format
msgid "Open"
msgstr "Apri"

#. Tag: guiicon
#: index.docbook:489
#, no-c-format
msgid "Save"
msgstr "Salva"

#. Tag: para
#: index.docbook:492
#, no-c-format
msgid "The statusbar reports the name of the file where the data was saved."
msgstr ""
"La barra di stato mostra il nome del file dove sono stati salvati i dati."

