#. Tag: refpurpose
#: man-zonetab2pot.py.1.docbook:20
#, no-c-format
msgid "Converts a timezone list to a PO file template."
msgstr "Converte una lista di fusi orari in un file PO modello."

#. Tag: cmdsynopsis
#: man-zonetab2pot.py.1.docbook:24
#, no-c-format
msgid ""
"<command>zonetab2pot.py</command> <group><option><replaceable>timezone-list</"
"replaceable></option></group>"
msgstr ""
"<command>zonetab2pot.py</command> <group><option><replaceable>lista-fusi-"
"orari</replaceable></option></group>"

#. Tag: title
#: man-zonetab2pot.py.1.docbook:32
#, no-c-format
msgid "Description"
msgstr "Descrizione"

#. Tag: para
#: man-zonetab2pot.py.1.docbook:34
#, no-c-format
msgid ""
"<command>zonetab2pot.py</command> reads the timezone list given on the "
"command-line and converts it to a gettext message file (PO-file) template "
"containing the names of the individual timezones."
msgstr ""
"<command>zonetab2pot.py</command> legge la lista di fusi orari specificata "
"via riga di comando e la converte in un file di messaggi gettext (file PO) "
"modello contenente i nomi dei singoli fusi orari."

#. Tag: para
#: man-zonetab2pot.py.1.docbook:39
#, no-c-format
msgid ""
"The given timezone list should be in the same format as the system zone.tab. "
"If no timezone list is specified on the command-line, <filename>/usr/share/"
"zoneinfo/zone.tab</filename> will be used."
msgstr ""
"La lista di fusi orari specificata dovrebbe avere lo stesso formato del file "
"di sistema zone.tab. Se non viene specificata alcuna lista di fusi orari, "
"sarà usato <filename>/usr/share/zoneinfo/zone.tab</filename>."

#. Tag: para
#: man-zonetab2pot.py.1.docbook:43
#, no-c-format
msgid "The new PO-file template will be written to standard output."
msgstr "Il nuovo file PO modello sarà inviato sullo standard output."

#. Tag: para
#: man-zonetab2pot.py.1.docbook:45
#, no-c-format
