#. Tag: refpurpose
#: man-cvslastlog.1.docbook:20
#, no-c-format
msgid "Prints the log entry for the last commit for a file."
msgstr "Stampa la voce di log dell'ultimo deposito di un file."

#. Tag: cmdsynopsis
#: man-cvslastlog.1.docbook:24
#, no-c-format
msgid ""
"<command>cvslastlog</command> <group><option><replaceable>filename</"
"replaceable></option></group>"
msgstr ""
"<command>cvslastlog</command> <group><option><replaceable>nonefile</"
"replaceable></option></group>"

#. Tag: title
#: man-cvslastlog.1.docbook:32
#, no-c-format
msgid "Description"
msgstr "Descrizione"

#. Tag: para
#: man-cvslastlog.1.docbook:34
#, no-c-format
msgid ""
"<command>cvslastlog</command> shows the log associated with the last CVS "
"commit for the given file. It depends on the version of the local file, not "
"the one on the server."
msgstr ""
"<command>cvslastlog</command> mostra il log associato con l'ultimo deposito "
"di CVS del file specificato. Dipende dalla versione del file locale, non da "
"quella sul server."

#. Tag: para
#: man-cvslastlog.1.docbook:38
#, no-c-format
msgid "This utility is part of the &kde; Software Development Kit."
msgstr ""
"Questa applicazione è parte del pacchetto di sviluppo software di &kde;."

