#. Tag: title
#: man-cvslastchange.1.docbook:33
#, no-c-format
msgid "Description"
msgstr "Descrizione"

#. Tag: para
#: man-cvslastchange.1.docbook:35
#, no-c-format
msgid ""
"&cvslastchange; displays the last change committed to &CVS; for a file. It "
"uses <command>cvs diff</command> and <command>cvs log</command> to do this."
msgstr ""
"&cvslastchange; mostra l'ultima modifica di un file depositata su &CVS;. Usa "
"<command>cvs diff</command> e <command>cvs log</command> per far ciò."

#. Tag: para
#: man-cvslastchange.1.docbook:39
#, no-c-format
msgid "&cvslastchange; works on any &CVS; branch, not just HEAD."
msgstr ""
"&cvslastchange; funziona con qualsiasi ramo di &CVS;, non solo con HEAD."

#. Tag: para
#: man-cvslastchange.1.docbook:41
#, no-c-format
msgid "This utility is part of the &kde; Software Development Kit."
msgstr ""
"Questa applicazione è parte del pacchetto di sviluppo software di &kde;."

