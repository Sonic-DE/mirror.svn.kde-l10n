#~ msgid "Generic options:"
#~ msgstr "Opzioni generiche:"

#~ msgid "--help"
#~ msgstr "--help"

#~ msgid "Show help about options"
#~ msgstr "Mostra un aiuto sulle opzioni"

#~ msgid "--help-qt"
#~ msgstr "--help-qt"

#~ msgid "Show Qt specific options"
#~ msgstr "Mostra le opzioni specifiche per Qt"

#~ msgid "--help-kde"
#~ msgstr "--help-kde"

#~ msgid "Show KDE specific options"
#~ msgstr "Mostra le opzioni specifiche per KDE"

#~ msgid "--help-all"
#~ msgstr "--help-all"

#~ msgid "Show all options"
#~ msgstr "Mostra tutte le opzioni"

#~ msgid "Show author information"
#~ msgstr "Mostra le informazioni sull'autore"

#~ msgid "-v, --version"
#~ msgstr "-v, --version"

#~ msgid "Show version information"
#~ msgstr "Mostra le informazioni sulla versione"

#~ msgid "--license"
#~ msgstr "--license"

#~ msgid "Show license information"
#~ msgstr "Mostra le informazioni sulla licenza"

#~ msgid "<option>--</option>"
#~ msgstr "<option>--</option>"

#~ msgid "End of options"
#~ msgstr "Fine delle opzioni"

#~ msgid "KDE options:"
#~ msgstr "Opzioni per KDE:"

#~ msgid "--caption &lt;caption&gt;"
#~ msgstr "--caption &lt;caption&gt;"

#~ msgid "Use 'caption' as name in the titlebar"
#~ msgstr "Usa «caption» come nome per la barra del titolo"

#~ msgid "--icon &lt;icon&gt;"
#~ msgstr "--icon &lt;icon&gt;"

#~ msgid "Use 'icon' as the application icon"
#~ msgstr "Usa «icon» come icona dell'applicazione"

#~ msgid "--config &lt;filename&gt;"
#~ msgstr "--config &lt;filename&gt;"

#~ msgid "Use alternative configuration file"
#~ msgstr "Usa file di configurazione alternativi"

#~ msgid "--nocrashhandler"
#~ msgstr "--nocrashhandler"

#~ msgid "Disable crash handler, to get core dumps"
#~ msgstr "Disattiva la gestione dei crash, per ottenere i core dump"

#~ msgid "--waitforwm"
#~ msgstr "--waitforwm"

#~ msgid "Waits for a WM_NET compatible windowmanager"
#~ msgstr "Aspetta un window manager compatibile WM_NET"

#~ msgid "--style &lt;style&gt;"
#~ msgstr "--style &lt;style&gt;"

#~ msgid "sets the application GUI style"
#~ msgstr "imposta lo stile dell'interfaccia grafica dell'applicazione"

#~ msgid "--geometry &lt;geometry&gt;"
#~ msgstr "--geometry &lt;geometry&gt;"

#~ msgid ""
#~ "sets the client geometry of the main widget - see man X for the argument "
#~ "format"
#~ msgstr ""
#~ "imposta la geometria della finestra principale; vedi il manuale di X per "
#~ "il formato degli argomenti"

#~ msgid "Qt options:"
#~ msgstr "Opzioni per Qt:"

#~ msgid "--display &lt;displayname&gt;"
#~ msgstr "--display &lt;displayname&gt;"

#~ msgid "Use the X-server display 'displayname'"
#~ msgstr "Usa il display «nome_display» del server X"

#~ msgid "--session &lt;sessionId&gt;"
#~ msgstr "--session &lt;sessionId&gt;"

#~ msgid "Restore the application for the given 'sessionId'"
#~ msgstr "Ripristina l'applicazione per la sessione «sessionId»"

#~ msgid "--cmap"
#~ msgstr "--cmap"

#~ msgid ""
#~ "Causes the application to install a private color map on an 8-bit display"
#~ msgstr ""
#~ "Induce l'applicazione ad installare una mappa colori personalizzata in un "
#~ "display a 8 bit."

#~ msgid "--ncols &lt;count&gt;"
#~ msgstr "--ncols &lt;count&gt;"

#~ msgid ""
#~ "Limits the number of colors allocated in the color cube on an 8-bit "
#~ "display, if the application is using the QApplication::ManyColor color "
#~ "specification"
#~ msgstr ""
#~ "Limita il numero di colori allocati nel cubo di colori su uno schermo a 8 "
#~ "bit, se l'applicazione usa la specifica di colore QApplication::ManyColor"

#~ msgid "--nograb"
#~ msgstr "--nograb"

#~ msgid "tells Qt to never grab the mouse or the keyboard"
#~ msgstr "dice alle Qt di non catturare mai il mouse o la tastiera"

#~ msgid "--dograb"
#~ msgstr "--dograb"

#~ msgid ""
#~ "running under a debugger can cause an implicit -nograb, use -dograb to "
#~ "override"
#~ msgstr ""
#~ "l'esecuzione sotto un debugger può causare un implicito -nograb, usa -"
#~ "dograb per aggirare il problema"

#~ msgid "--sync"
#~ msgstr "--sync"

#~ msgid "switches to synchronous mode for debugging"
#~ msgstr "passa in modalità sincrona per il debug"

#~ msgid "--fn, --font &lt;fontname&gt;"
#~ msgstr "--fn, --font &lt;fontname&gt;"

#~ msgid "defines the application font"
#~ msgstr "definisce il carattere dell'applicazione"

#~ msgid "--bg, --background &lt;color&gt;"
#~ msgstr "--bg, --background &lt;color&gt;"

#~ msgid ""
#~ "sets the default background color and an application palette (light and "
#~ "dark shades are calculated)"
#~ msgstr ""
#~ "imposta il colore di sfondo predefinito e una tavolozza d'applicazione "
#~ "(vengono calcolate le sfumature chiare e scure)"

#~ msgid "--fg, --foreground &lt;color&gt;"
#~ msgstr "--fg, --foreground &lt;color&gt;"

#~ msgid "sets the default foreground color"
#~ msgstr "imposta il colore di primo piano predefinito"

#~ msgid "--btn, --button &lt;color&gt;"
#~ msgstr "--btn, --button &lt;color&gt;"

#~ msgid "sets the default button color"
#~ msgstr "imposta il colore dei pulsanti predefinito"

#~ msgid "--name &lt;name&gt;"
#~ msgstr "--name &lt;name&gt;"

#~ msgid "sets the application name"
#~ msgstr "imposta il nome dell'applicazione"

#~ msgid "--title &lt;title&gt;"
#~ msgstr "--title &lt;title&gt;"

#~ msgid "sets the application title (caption)"
#~ msgstr "imposta il titolo (didascalia) dell'applicazione"

#~ msgid "--visual TrueColor"
#~ msgstr "--visual TrueColor"

#~ msgid "forces the application to use a TrueColor visual on an 8-bit display"
#~ msgstr ""
#~ "impone all'applicazione di usare una visuale TrueColor su un display a 8 "
#~ "bit"

#~ msgid "--inputstyle &lt;inputstyle&gt;"
#~ msgstr "--inputstyle &lt;inputstyle&gt;"

#~ msgid ""
#~ "sets XIM (X Input Method) input style. Possible values are onthespot, "
#~ "overthespot, offthespot and root"
#~ msgstr ""
#~ "imposta lo stile di input XIM (X Input Method). I valori possibili sono "
#~ "onthespot, overthespot, offthespot e root"

#~ msgid "--im &lt;XIM server&gt;"
#~ msgstr "--im &lt;XIM server&gt;"

#~ msgid "set XIM server"
#~ msgstr "imposta il server XIM"

#~ msgid "--noxim"
#~ msgstr "--noxim"

#~ msgid "disable XIM"
#~ msgstr "disabilita XIM"

#~ msgid "--reverse"
#~ msgstr "--reverse"

#~ msgid "mirrors the whole layout of widgets"
#~ msgstr "rispecchia l'intera disposizione degli oggetti"

#~ msgid "--stylesheet"
#~ msgstr "--stylesheet"

#~ msgid ""
#~ "&lt;file.qss&gt; applies the Qt stylesheet to the application widgets"
#~ msgstr ""
#~ "&lt;file.qss&gt; applica il foglio di stile Qt agli elementi "
#~ "dell'applicazione"

