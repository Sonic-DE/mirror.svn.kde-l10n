"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>W</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Close</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>W</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Chiudi</guimenuitem>"

#. Tag: para
#: index.docbook:1783
#, no-c-format
msgid "<action>Close</action> current opened repository or working copy"
msgstr "<action>Chiude</action> il deposito corrente o la copia di lavoro"

#. Tag: menuchoice
#: index.docbook:1786
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>Q</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Quit</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>Q</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Esci</guimenuitem>"

#. Tag: para
#: index.docbook:1793
#, no-c-format
msgid "<action>Quits</action> &kdesvn;"
msgstr "<action>Esce</action> da &kdesvn;"

#. Tag: title
#: index.docbook:1799
#, no-c-format
msgid "The Bookmark Menu"
msgstr "Il menu Segnalibri"

#. Tag: para
#: index.docbook:1800
#, no-c-format
msgid ""
"See <ulink url=\"help:/konqueror/bookmarks.html\">&konqueror; help</ulink>."
msgstr ""
"Vedi <ulink url=\"help:/konqueror/bookmarks.html\">l'aiuto di &konqueror;</"
"ulink>."

#. Tag: title
#: index.docbook:1806
#, no-c-format
msgid "The Subversion Menu"
msgstr "Il menu Subversion"

#. Tag: title
#: index.docbook:1809
#, no-c-format
msgid "General subversion actions"
msgstr "Azioni generali di Subversion"

#. Tag: menuchoice
#: index.docbook:1812
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>L</keycap></keycombo></"
