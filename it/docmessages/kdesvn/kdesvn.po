"<guimenuitem>History of item</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>L</keycap></keycombo></"
"shortcut> <guimenu>Subversion</guimenu> <guisubmenu>Generale</guisubmenu> "
"<guimenuitem>Storia dell'elemento</guimenuitem>"

#. Tag: para
#: index.docbook:1819
#, no-c-format
msgid ""
"<action>Display</action> lifetime log of the currently selected item. Be "
"careful, this list may be really big!"
msgstr ""
"<action>Visualizza</action> il log completo per l'oggetto selezionato. Fai "
"attenzione, questa lista può essere davvero lunga!"

#. Tag: menuchoice
#: index.docbook:1824
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl; &Shift;<keycap>L</keycap></"
"keycombo></shortcut> <guimenu>Subversion</guimenu> <guisubmenu>General</"
"guisubmenu> <guimenuitem>History of item ignoring copies...</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl; &Shift;<keycap>L</keycap></"
"keycombo></shortcut> <guimenu>Subversion</guimenu> <guisubmenu>Generale</"
"guisubmenu> <guimenuitem>Storia dell'elemento ignorando le copie...</"
"guimenuitem>"

#. Tag: para
#: index.docbook:1830
#, no-c-format
msgid "Displays the history log of selected item without following copies."
msgstr ""
"Mostra lo storico dei log dell'elemento selezionato senza seguire le copie."

#. Tag: menuchoice
#: index.docbook:1833
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>I</keycap></keycombo></"
"shortcut> <guimenu>Subversion</guimenu> <guisubmenu>General</guisubmenu> "
"<guimenuitem>Details</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>I</keycap></keycombo></"
"shortcut> <guimenu>Subversion</guimenu> <guisubmenu>Generale</guisubmenu> "
"<guimenuitem>Dettagli</guimenuitem>"

#. Tag: para
#: index.docbook:1839
#, no-c-format
msgid "Displays detailed information about selected item(s)"
msgstr "Visualizza informazioni dettagliate sugli elementi selezionati"

#. Tag: menuchoice
#: index.docbook:1842
#, no-c-format
msgid ""
"<guimenu>Subversion</guimenu> <guisubmenu>General</guisubmenu> "
"<guimenuitem>Blame</guimenuitem>"
msgstr ""
"<guimenu>Subversion</guimenu> <guisubmenu>Generale</guisubmenu> "
"<guimenuitem>Traccia</guimenuitem>"

#. Tag: para
#: index.docbook:1847
#, no-c-format
msgid "Makes an annotated list over all checkins. That may consume time!"
msgstr ""
"Genera una lista annotata su tutti i checkin. Può richiedere molto tempo!"

#. Tag: menuchoice
#: index.docbook:1850
#, no-c-format
msgid ""
"<guimenu>Subversion</guimenu> <guisubmenu>General</guisubmenu> "
"<guimenuitem>Blame range</guimenuitem>"
msgstr ""
"<guimenu>Subversion</guimenu> <guisubmenu>Generale</guisubmenu> "
"<guimenuitem>Intervallo traccia</guimenuitem>"

#. Tag: para
#: index.docbook:1855
#, no-c-format
msgid "Annotate a range of commits for a file."
msgstr "Annota un intervallo di depositi per un file."

#. Tag: menuchoice
#: index.docbook:1858
#, no-c-format
msgid ""
"<guimenu>Subversion</guimenu> <guisubmenu>General</guisubmenu> "
"<guimenuitem>Cat head</guimenuitem>"
msgstr ""
"<guimenu>Subversion</guimenu> <guisubmenu>Generale</guisubmenu> "
"<guimenuitem>Mostra la testa</guimenuitem>"

#. Tag: para
#: index.docbook:1863
#, no-c-format
msgid ""
"Shows the content of the last committed version of that entry. (May be "
"different to working copy version if working on a WC!)"
msgstr ""
"Mostra il contenuto dell'ultima versione depositata di quell'elemento. (Può "
"essere diversa dalla versione della copia di lavoro se ci stai lavorando!)"

#. Tag: menuchoice
#: index.docbook:1866
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\"><keycap>F2</keycap></keycombo></"
"shortcut> <guimenu>Subversion</guimenu> <guisubmenu>General</guisubmenu> "
"<guimenuitem>Move</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\"><keycap>F2</keycap></keycombo></"
"shortcut> <guimenu>Subversion</guimenu> <guisubmenu>Generale</guisubmenu> "
"<guimenuitem>Sposta</guimenuitem>"

#. Tag: para
#: index.docbook:1872
#, no-c-format
msgid "Move or rename item inside working copy or in repository"
msgstr "Sposta o rinomina un elemento in una copia di lavoro o in un deposito"

#. Tag: menuchoice
#: index.docbook:1875
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>C</keycap></keycombo></"
"shortcut> <guimenu>Subversion</guimenu> <guisubmenu>General</guisubmenu> "
"<guimenuitem>Copy</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>C</keycap></keycombo></"
"shortcut> <guimenu>Subversion</guimenu> <guisubmenu>Generale</guisubmenu> "
"<guimenuitem>Copia</guimenuitem>"

#. Tag: para
#: index.docbook:1881
#, no-c-format
msgid "Copy item inside working copy or in repository"
msgstr "Copia un elemento nella copia di lavoro o in un deposito"

#. Tag: menuchoice
#: index.docbook:1884
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\"><keycap>Del</keycap></keycombo></"
"shortcut> <guimenu>Subversion</guimenu> <guisubmenu>General</guisubmenu> "
"<guimenuitem>Delete selected files/dirs</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\"><keycap>Canc</keycap></keycombo></"
"shortcut> <guimenu>Subversion</guimenu> <guisubmenu>General</guisubmenu> "
"<guimenuitem>Elimina i file e le cartelle selezionate</guimenuitem>"

#. Tag: para
#: index.docbook:1890
#, no-c-format
msgid ""
"Delete selected entries. If working in a working copy you must commit your "
"deletions afterwards."
msgstr ""
"Elimina le voci selezionate. Se stai lavorando su una copia locale devi poi "
"depositare le tue eliminazioni."

#. Tag: menuchoice
#: index.docbook:1893
#, no-c-format
msgid ""
"<guimenu>Subversion</guimenu> <guisubmenu>General</guisubmenu> "
"<guimenuitem>New folder</guimenuitem>"
msgstr ""
"<guimenu>Subversion</guimenu> <guisubmenu>Generale</guisubmenu> "
"<guimenuitem>Nuova cartella</guimenuitem>"

#. Tag: para
#: index.docbook:1898
#, no-c-format
msgid "Create a new folder."
msgstr "Crea una nuova cartella."

#. Tag: menuchoice
#: index.docbook:1901
#, no-c-format
msgid ""
"<guimenu>Subversion</guimenu> <guisubmenu>General</guisubmenu> "
"<guimenuitem>Import folders into current</guimenuitem>"
msgstr ""
"<guimenu>Subversion</guimenu> <guisubmenu>Generale</guisubmenu> "
"<guimenuitem>Importa cartelle nell'attuale</guimenuitem>"

#. Tag: para
#: index.docbook:1906
#, no-c-format
msgid "Select folders you want to import into the current selected directory"
msgstr ""
"Seleziona le cartelle che vuoi importare in quella attualmente selezionata"

#. Tag: menuchoice
#: index.docbook:1909
#, no-c-format
msgid ""
"<guimenu>Subversion</guimenu> <guisubmenu>General</guisubmenu> "
"<guimenuitem>Checkout a repository</guimenuitem>"
msgstr ""
"<guimenu>Subversion</guimenu> <guisubmenu>Generale</guisubmenu> "
"<guimenuitem>Esegui il checkout di un deposito</guimenuitem>"

#. Tag: para
#: index.docbook:1914
#, no-c-format
msgid "Creates a new working copy of a repository"
msgstr "Crea una nuova copia di lavoro di un deposito"

#. Tag: menuchoice
#: index.docbook:1917
#, no-c-format
msgid ""
"<guimenu>Subversion</guimenu> <guisubmenu>General</guisubmenu> "
"<guimenuitem>Export a repository</guimenuitem>"
msgstr ""
"<guimenu>Subversion</guimenu> <guisubmenu>Generale</guisubmenu> "
"<guimenuitem>Esporta un deposito</guimenuitem>"

#. Tag: para
#: index.docbook:1922
#, no-c-format
msgid ""
"Exports a repository to file system, &ie; creates a clean revision tree "
"without subversion information."
msgstr ""
"Esporta un deposito in un file system, &ie; crea un albero delle revisioni "
"pulito senza le informazioni di subversion."

#. Tag: menuchoice
#: index.docbook:1927
#, no-c-format
msgid ""
"<guimenu>Subversion</guimenu> <guisubmenu>General</guisubmenu> "
"<guimenuitem>Lock current items</guimenuitem>"
msgstr ""
"<guimenu>Subversion</guimenu> <guisubmenu>Generale</guisubmenu> "
"<guimenuitem>Blocca gli elementi correnti</guimenuitem>"

#. Tag: para
#: index.docbook:1932
#, no-c-format
msgid ""
"Mark current items as locked. Read the subversion handbook before using this!"
msgstr ""
"Segna gli elementi correnti come bloccati. Leggi il manuale di subversion "
"prima di farlo!"

#. Tag: menuchoice
#: index.docbook:1936
#, no-c-format
msgid ""
"<guimenu>Subversion</guimenu> <guisubmenu>General</guisubmenu> "
"<guimenuitem>Unlock current items</guimenuitem>"
msgstr ""
"<guimenu>Subversion</guimenu> <guisubmenu>Generale</guisubmenu> "
"<guimenuitem>Sblocca gli elementi correnti</guimenuitem>"

#. Tag: para
#: index.docbook:1941
#, no-c-format
msgid ""
"Remove locks on current items. Read the subversion handbook before using "
"this!"
msgstr ""
"Rimuove il blocco dagli elementi correnti. Leggi il manuale di subversion "
"prima di farlo!"

#. Tag: title
#: index.docbook:1947
#, no-c-format
msgid "<title>Working copy</title>"
msgstr "<title>Copia di lavoro</title>"

#. Tag: menuchoice
#: index.docbook:1949
#, no-c-format
msgid ""
"<guimenu>Subversion</guimenu> <guisubmenu>Working copy</guisubmenu> "
"<guimenuitem>Update to head</guimenuitem>"
msgstr ""
"<guimenu>Subversion</guimenu> <guisubmenu>Copia di lavoro</guisubmenu> "
"<guimenuitem>Aggiorna a HEAD</guimenuitem>"

#. Tag: para
#: index.docbook:1954
#, no-c-format
msgid "Update working copy to HEAD of repository"
msgstr "Aggiorna la copia locale alla HEAD del deposito"

#. Tag: menuchoice
#: index.docbook:1957
#, no-c-format
msgid ""
"<guimenu>Subversion</guimenu> <guisubmenu>Working copy</guisubmenu> "
"<guimenuitem>Update to revision...</guimenuitem>"
msgstr ""
"<guimenu>Subversion</guimenu> <guisubmenu>Copia di lavoro</guisubmenu> "
"<guimenuitem>Aggiorna alla revisione...</guimenuitem>"

#. Tag: para
#: index.docbook:1962
#, no-c-format
msgid "Update working copy to a specific revision of repository"
msgstr "Aggiorna la copia di lavoro ad una revisione specifica del deposito"

#. Tag: menuchoice
#: index.docbook:1965
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>#</keycap></keycombo></"
"shortcut> <guimenu>Subversion</guimenu> <guisubmenu>Working copy</"
"guisubmenu> <guimenuitem>Commit</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>#</keycap></keycombo></"
"shortcut> <guimenu>Subversion</guimenu> <guisubmenu>Copia di lavoro</"
"guisubmenu> <guimenuitem>Deposita</guimenuitem>"

#. Tag: para
#: index.docbook:1971
#, no-c-format
msgid "Commit changes inside working copy for selected items to repository."
msgstr ""
"Invia le modifiche degli oggetti selezionati nella copia di lavoro al "
"deposito."

#. Tag: menuchoice
#: index.docbook:1974
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>D</keycap></keycombo></"
"shortcut> <guimenu>Subversion</guimenu> <guisubmenu>Working copy</"
"guisubmenu> <guimenuitem>Diff local changes</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>D</keycap></keycombo></"
"shortcut> <guimenu>Subversion</guimenu> <guisubmenu>Copia di lavoro</"
"guisubmenu> <guimenuitem>Mostra le modifiche locali</guimenuitem>"

#. Tag: para
#: index.docbook:1980
#, no-c-format
msgid ""
"Display local changes as diff-output (without network access). This is the "
"difference only to last state the working copy was updated to, not against "
"the version in repository."
msgstr ""
"Visualizza le modifiche locali come output di confronto (senza l'accesso "
"alla rete). Queste sono semplicemente le differenze a cui la copia di lavoro "
"è stata aggiornata, non rispetto alla versione nel deposito."

#. Tag: menuchoice
#: index.docbook:1984
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>H</keycap></keycombo></"
"shortcut> <guimenu>Subversion</guimenu> <guisubmenu>Working copy</"
"guisubmenu> <guimenuitem>Diff against HEAD</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>H</keycap></keycombo></"
"shortcut> <guimenu>Subversion</guimenu> <guisubmenu>Copia di lavoro</"
"guisubmenu> <guimenuitem>Mostra le modifiche rispetto a HEAD</guimenuitem>"

#. Tag: para
#: index.docbook:1990
#, no-c-format
msgid "Diff's current working copy against head of repository."
msgstr ""
"Crea le differenze tra l'attuale copia di lavoro e la HEAD del deposito."

#. Tag: menuchoice
#: index.docbook:1993
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>P</keycap></keycombo></"
"shortcut> <guimenu>Subversion</guimenu> <guisubmenu>Working copy</"
"guisubmenu> <guimenuitem>Properties</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>P</keycap></keycombo></"
"shortcut> <guimenu>Subversion</guimenu> <guisubmenu>Copia di lavoro</"
"guisubmenu> <guimenuitem>Proprietà</guimenuitem>"

#. Tag: para
#: index.docbook:1999
#, no-c-format
msgid "View/Edit properties assigned with current entry."
msgstr "Visualizza/modifica le proprietà assegnate dell'attuale voce."

#. Tag: menuchoice
#: index.docbook:2002
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\"><keycap>Insert</keycap></keycombo></"
"shortcut> <guimenu>Subversion</guimenu> <guisubmenu>Working copy</"
"guisubmenu> <guimenuitem>Add selected files/dirs</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\"><keycap>Inserisci</keycap></keycombo></"
"shortcut> <guimenu>Subversion</guimenu> <guisubmenu>Copia di lavoro</"
"guisubmenu> <guimenuitem>Aggiungi i file e le cartelle selezionate</"
"guimenuitem>"

#. Tag: para
#: index.docbook:2008
#, no-c-format
msgid "Add selected files and/or folders to version control."
msgstr "Aggiunge i file e/o le cartelle selezionate al controllo di versione."

#. Tag: menuchoice
#: index.docbook:2011
#, no-c-format
msgid ""
"<guimenu>Subversion</guimenu> <guisubmenu>Working copy</guisubmenu> "
"<guimenuitem>Revert current changes</guimenuitem>"
msgstr ""
"<guimenu>Subversion</guimenu> <guisubmenu>Copia di lavoro</guisubmenu> "
"<guimenuitem>Annulla le attuali modifiche</guimenuitem>"

#. Tag: para
#: index.docbook:2016
#, no-c-format
msgid "Revert changes made in working copy and updates to last updated state."
msgstr ""
"Annulla le modifiche fatte alla copia di lavoro e aggiornala all'ultimo "
"stato aggiornato."

#. Tag: menuchoice
#: index.docbook:2019
#, no-c-format
msgid ""
"<guimenu>Subversion</guimenu> <guisubmenu>Working copy</guisubmenu> "
"<guimenuitem>Mark resolved</guimenuitem>"
msgstr ""
"<guimenu>Subversion</guimenu> <guisubmenu>Copia di lavoro</guisubmenu> "
"<guimenuitem>Marca come risolto</guimenuitem>"

#. Tag: para
#: index.docbook:2024
#, no-c-format
msgid "Mark conflicted items as not conflicted and remove associated files."
msgstr ""
"Segna come non in conflitto gli elementi in conflitto e rimuovi i file "
"associati."

#. Tag: menuchoice
#: index.docbook:2027
#, no-c-format
msgid ""
"<guimenu>Subversion</guimenu> <guisubmenu>Working copy</guisubmenu> "
"<guimenuitem>Merge two revisions</guimenuitem>"
msgstr ""
"<guimenu>Subversion</guimenu> <guisubmenu>Copia di lavoro</guisubmenu> "
"<guimenuitem>Unisci due revisioni</guimenuitem>"

#. Tag: para
#: index.docbook:2032
#, no-c-format
msgid "Merge two revisions of entries into working copy."
msgstr "Unisce due revisioni della voce nella copia di lavoro."

#. Tag: menuchoice
#: index.docbook:2035
#, no-c-format
msgid ""
"<guimenu>Subversion</guimenu> <guisubmenu>Working copy</guisubmenu> "
"<guimenuitem>Ignore/Unignore current item</guimenuitem>"
msgstr ""
"<guimenu>Subversion</guimenu> <guisubmenu>Copia di lavoro</guisubmenu> "
"<guimenuitem>Ignora / non ignorare l'elemento corrente</guimenuitem>"

#. Tag: para
#: index.docbook:2040
#, no-c-format
msgid ""
"Edit property of parent folder of the current item so that selected item "
"will be marked as ignored if not set, otherwise remove it from ignore list."
msgstr ""
"Modifica le proprietà della cartella genitore dell'elemento attuale, "
"cosicché l'elemento selezionato sarà marcato come ignorato se non impostato, "
"diversamente rimuovilo dalla lista degli ignorati."

#. Tag: menuchoice
#: index.docbook:2043
#, no-c-format
msgid ""
"<guimenu>Subversion</guimenu> <guisubmenu>Working copy</guisubmenu> "
"<guimenuitem>Cleanup</guimenuitem>"
msgstr ""
"<guimenu>Subversion</guimenu> <guisubmenu>Copia di lavoro</guisubmenu> "
"<guimenuitem>Pulizia</guimenuitem>"

#. Tag: para
#: index.docbook:2048
#, no-c-format
msgid "Clean up the working copy and remove (commit-)locks if any"
msgstr "Pulisce la copia di lavoro e rimuove i blocchi di invio, se ce ne sono"

#. Tag: menuchoice
#: index.docbook:2051
#, no-c-format
msgid ""
"<guimenu>Subversion</guimenu> <guisubmenu>Working copy</guisubmenu> "
"<guimenuitem>Switch repository</guimenuitem>"
msgstr ""
"<guimenu>Subversion</guimenu> <guisubmenu>Copia di lavoro</guisubmenu> "
"<guimenuitem>Cambia il deposito (\"switch\")</guimenuitem>"

#. Tag: para
#: index.docbook:2056
#, no-c-format
msgid "Switch the root of the current working copy."
msgstr "Cambia la radice dell'attuale copia di lavoro."

#. Tag: title
#: index.docbook:2061
#, no-c-format
msgid "<title>Repository</title>"
msgstr "<title>Deposito</title>"

#. Tag: menuchoice
#: index.docbook:2063
#, no-c-format
msgid ""
"<guimenu>Subversion</guimenu> <guisubmenu>Repository</guisubmenu> "
"<guimenuitem>Checkout current repository path</guimenuitem>"
msgstr ""
"<guimenu>Subversion</guimenu> <guisubmenu>Deposito</guisubmenu> "
"<guimenuitem>Esegui il checkout dell'attuale percorso del deposito</"
"guimenuitem>"

#. Tag: para
#: index.docbook:2068
#, no-c-format
msgid "Create a working copy from the current selected entry if a directory."
msgstr ""
"Crea una copia di lavoro dall'elemento attualmente selezionato, se è una "
"cartella."

#. Tag: menuchoice
#: index.docbook:2071
#, no-c-format
msgid ""
"<guimenu>Subversion</guimenu> <guisubmenu>Repository</guisubmenu> "
"<guimenuitem>Export current repository path</guimenuitem>"
msgstr ""
"<guimenu>Subversion</guimenu> <guisubmenu>Deposito</guisubmenu> "
"<guimenuitem>Esporta l'attuale percorso del deposito</guimenuitem>"

#. Tag: para
#: index.docbook:2076
#, no-c-format
msgid ""
"Create a clean copy on local file system from the current selected entry if "
"a directory."
msgstr ""
"Crea una copia di lavoro pulita dall'elemento attualmente selezionato in un "
"file system locale, se è una cartella."

#. Tag: title
#: index.docbook:2081
#, no-c-format
msgid "View actions"
msgstr "Azioni di visualizzazione"

#. Tag: menuchoice
#: index.docbook:2083
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\"><keycap>F5</keycap></keycombo></"
"shortcut> <guimenu>Subversion</guimenu> <guisubmenu>View</guisubmenu> "
"<guimenuitem>Refresh view</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\"><keycap>F5</keycap></keycombo></"
"shortcut> <guimenu>Subversion</guimenu> <guisubmenu>Visualizza</guisubmenu> "
"<guimenuitem>Aggiorna vista</guimenuitem>"

#. Tag: para
#: index.docbook:2088
#, no-c-format
msgid ""
"<action>Refresh</action> the current status of all displayed items. This "
"will list each item asked for to be displayed at current status."
msgstr ""
"<action>Aggiorna</action> lo stato attuale di tutti gli oggetti "
"visualizzati; questo elenca ciascun oggetto chiedendo di visualizzarlo nello "
"stato attuale."

#. Tag: menuchoice
#: index.docbook:2093
#, no-c-format
msgid ""
"<guimenu>Subversion</guimenu> <guisubmenu>View</guisubmenu> "
"<guimenuitem>Unfold File Tree / Fold File Tree</guimenuitem>"
msgstr ""
"<guimenu>Subversion</guimenu> <guisubmenu>Visualizza</guisubmenu> "
"<guimenuitem>Espandi l'albero dei file/Comprimi l'albero dei file</"
"guimenuitem>"

#. Tag: para
#: index.docbook:2098
#, no-c-format
msgid "Expand or collapse the repository tree view."
msgstr "Espande o contrae la vista dell'albero del deposito."

#. Tag: menuchoice
#: index.docbook:2103
#, no-c-format
msgid ""
"<guimenu>Subversion</guimenu> <guisubmenu>Log Cache</guisubmenu> "
"<guimenuitem>Stop updating the log cache</guimenuitem>"
msgstr ""
"<guimenu>Subversion</guimenu> <guisubmenu>Cache dei log</guisubmenu> "
"<guimenuitem>Ferma l'aggiornamento della cache dei log</guimenuitem>"

#. Tag: para
#: index.docbook:2108
#, no-c-format
msgid ""
"The log is cached and used to display the revision tree of a repository. "
"Depending on the Internet connection, size of the subversion repository and "
"history length this may take much time. Therefore you can stop updating the "
"cache using this action."
msgstr ""
"Il log è nella cache, e viene usato per visualizzare l'albero della "
"revisione di un deposito. A seconda della connessione internet, della "
"dimensione del deposito di Subversion e della lunghezza della cronologia può "
"volerci molto tempo, perciò potresti fermare l'aggiornamento della cache dei "
"log con questa azione."

#. Tag: menuchoice
#: index.docbook:2114
#, no-c-format
msgid ""
"<guimenu>Subversion</guimenu> <guimenuitem>Add ssh identities to ssh-agent</"
"guimenuitem>"
msgstr ""
"<guimenu>Subversion</guimenu> <guimenuitem>Aggiungi le identità ssh a ssh-"
"agent</guimenuitem>"

#. Tag: para
#: index.docbook:2118
#, no-c-format
msgid ""
"Store your SSH-key password for your current session so no further entering "
"of your password is needed."
msgstr ""
"Immagazzina la tua chiave SSH dell'attuale sessione, in modo che non sia più "
"necessario inserire la password."

#. Tag: title
#: index.docbook:2125
#, no-c-format
msgid "The Database Menu"
msgstr "Il menu Database"

#. Tag: menuchoice
#: index.docbook:2128
#, no-c-format
msgid ""
"<guimenu>Database</guimenu> <guimenuitem>Show database content</guimenuitem>"
msgstr ""
"<guimenu>Database</guimenu> <guimenuitem>Mostra il contenuto del database</"
"guimenuitem>"

#. Tag: para
#: index.docbook:2132
#, no-c-format
msgid ""
"Displays an overview about the cache database content for known repositories "
"and allows to delete the cache or repository and access to repository "
"settings."
msgstr ""
"Visualizza una panoramica del contenuto della cache del banca dati, per "
"conoscere i depositi e per permettere di eliminare la cache o i depositi ed "
"accedere alle impostazioni del deposito."

#. Tag: menuchoice
#: index.docbook:2137
#, no-c-format
msgid ""
"<guimenu>Database</guimenu> <guimenuitem>Settings for current repository</"
"guimenuitem>"
msgstr ""
"<guimenu>Database</guimenu> <guimenuitem>Impostazioni per il deposito "
"attuale</guimenuitem>"

#. Tag: para
#: index.docbook:2141
#, no-c-format
msgid ""
"Display a dialog to adapt the settings for the cache, logs and statistics."
msgstr ""
"Visualizza una finestra per adattare le impostazioni per la cache, per i log "
"e per le statistiche."

#. Tag: title
#: index.docbook:2148
#, no-c-format
msgid "The Settings and Help Menu"
msgstr "Il menu Impostazioni e Aiuto"

#. Tag: para
#: index.docbook:2149
#, no-c-format
msgid ""
"Apart from the common &kde; <guimenu>Settings</guimenu> and <guimenu>Help</"
"guimenu> menu items described in the <ulink url=\"help:/fundamentals/menus."
"html#menus-settings\">Settings Menu</ulink> and <ulink url=\"help:/"
"fundamentals/menus.html#menus-help\">Help Menu</ulink> of the &kde; "
"Fundamentals &kdesvn; this additional menu entry:"
msgstr ""
"Oltre ai comuni elementi del menu di &kde; <guimenu>Impostazioni</guimenu> "
"ed <guimenu>Aiuto</guimenu> che sono descritti nel <ulink url=\"help:/"
"fundamentals/menus.html#menus-settings\">menu Impostazioni</ulink> ed <ulink "
"url=\"help:/fundamentals/menus.html#menus-help\">Aiuto</ulink> dei "
"Fondamentali di &kde;, &kdesvn; ha queste voci di menu addizionali:"

#. Tag: menuchoice
#: index.docbook:2155
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Quick settings</guimenuitem>"
msgstr ""
"<guimenu>Settings</guimenu> <guimenuitem>Impostazioni rapide</guimenuitem>"

#. Tag: guimenuitem
#: index.docbook:2165
#, no-c-format
msgid "Load last opened URL on start"
msgstr "Carica l'ultimo URL aperto all'avvio"

#. Tag: para
#: index.docbook:2167
#, no-c-format
msgid "Reload last opened URL if no one is given on command line."
msgstr ""
"Ricarica l'ultimo URL aperto se non ne viene fornito nessuno da riga di "
"comando."

#. Tag: guimenuitem
#: index.docbook:2173
#, no-c-format
msgid "Logs follow node changes"
msgstr "I log seguono le modifiche ai nodi"

#. Tag: guimenuitem
#: index.docbook:2181
#, no-c-format
msgid "<guimenuitem>Display ignored files</guimenuitem>"
msgstr "<guimenuitem>Mostra i file ignorati</guimenuitem>"

#. Tag: para
#: index.docbook:2183
#, no-c-format
msgid "<para>Show items marked in subversion for ignore or not.</para>"
msgstr ""
"<para>Mostra gli elementi segnati in subversion come ignorati o meno.</para>"

#. Tag: guimenuitem
#: index.docbook:2189
#, no-c-format
msgid "Display unknown files"
msgstr "Mostra file sconosciuti"

#. Tag: para
#: index.docbook:2191
#, no-c-format
msgid "Show files not added to the subversion repository."
msgstr "Mostra i file che non sono stati aggiunti al deposito di subversion."

#. Tag: guimenuitem
#: index.docbook:2197
#, no-c-format
msgid "Hide unchanged files"
msgstr "Nascondi i file non modificati"

#. Tag: para
#: index.docbook:2199
#, no-c-format
msgid ""
"Use this action to show only changed files and provide a clear and concise "
"overview."
msgstr ""
"Usa quest'azione per mostrare solo i file modificati e per fornire una "
"panoramica chiara e coincisa."

#. Tag: guimenuitem
#: index.docbook:2205
#, no-c-format
msgid "Work online"
msgstr "Lavoro in linea"

#. Tag: para
#: index.docbook:2207
#, no-c-format
msgid ""
"Working offline the log cache will not be updated, therefore the cached log "
"may differ from real log."
msgstr ""
"Lavorando scollegati la cache dei log non verrà aggiornata, quindi i log "
"nella cache possono differire da quelli reali."

