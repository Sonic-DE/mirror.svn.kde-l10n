"<shortcut> <keycombo>&Shift;<keysym>F3</keysym></keycombo> </shortcut> "
"<guimenu>Modifica</guimenu> <guimenuitem>Trova precedente</guimenuitem>"

#. Tag: para
#: using-kturtle.docbook:293
#, no-c-format
msgid ""
"Use this to find the previous occurrence of the phrase you searched for."
msgstr ""
"Usalo per trovare l'occorrenza precedente della frase che stavi cercando."

#. Tag: menuchoice
#: using-kturtle.docbook:312
#, no-c-format
