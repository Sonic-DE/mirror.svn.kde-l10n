>Scegliere se le operazioni <link linkend="trackers"
>tracciate</link
> debbano essere tenute o no in conto</para
></listitem>
	    <listitem
><para
>Aprire il <link linkend="reports"
>rapporto</link
> relativo</para
></listitem>
	</itemizedlist
>		  
	</para>
