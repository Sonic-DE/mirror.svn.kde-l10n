#: src/android_defaults.notifyrc:2
msgctxt "Name"
msgid "Fatal Error"
msgstr "Хатои ҷиддӣ"

#: src/android_defaults.notifyrc:61
msgctxt "Comment"
msgid "There was a serious error causing the program to exit"
msgstr "Хатои ҷиддие рӯй дод, ки барномаро қатъ кард"

#: src/android_defaults.notifyrc:122
msgctxt "Name"
msgid "Notification"
msgstr "Огоҳинома"

#: src/android_defaults.notifyrc:180
msgctxt "Comment"
msgid "Something special happened in the program"
msgstr "Чизе махсус дар барнома рӯй дод"

#: src/android_defaults.notifyrc:240
msgctxt "Name"
msgid "Warning"
msgstr "Огоҳӣ"

#: src/android_defaults.notifyrc:298
msgctxt "Comment"
msgid "There was an error in the program which may cause problems"
msgstr "Хатое дар барнома рӯй дод, ки метавонад мушкилиеро ба вуҷуд орад"

#: src/android_defaults.notifyrc:358
msgctxt "Name"
msgid "Catastrophe"
msgstr "Садама"

#: src/android_defaults.notifyrc:415
msgctxt "Comment"
msgid "A very serious error occurred, at least causing the program to exit"
msgstr "Хатои хеле ҷиддӣ рӯй дод, ки ақаллан барномаро қатъ кард"
