#, no-c-format
msgid "Often used RGB combinations"
msgstr "Kombinime RGB që përdoren shpesh"

#. Tag: userinput
#: glossary.docbook:123
#, no-c-format
msgid "0,0,0"
msgstr "0,0,0"

#. Tag: userinput
#: glossary.docbook:124
#, no-c-format
msgid "255,255,255"
msgstr "255,255,255"

#. Tag: entry
#: glossary.docbook:124
#, no-c-format
msgid "white"
msgstr "e bardhë"

#. Tag: userinput
#: glossary.docbook:125
#, no-c-format
msgid "255,0,0"
msgstr "255,0,0"

#. Tag: userinput
#: glossary.docbook:126
#, no-c-format
msgid "150,0,0"
msgstr "150,0,0"

#. Tag: userinput
#: glossary.docbook:127
#, no-c-format
msgid "0,255,0"
msgstr "0,255,0"

#. Tag: entry
#: glossary.docbook:127
#, no-c-format
msgid "green"
msgstr "e gjelbër"

#. Tag: userinput
#: glossary.docbook:128
#, no-c-format
msgid "0,0,255"
msgstr "0,0,255"

#. Tag: entry
#: glossary.docbook:128
#, no-c-format
msgid "blue"
msgstr "blu"

#. Tag: userinput
#: glossary.docbook:129
#, no-c-format
msgid "0,255,255"
msgstr "0,255,255"

#. Tag: entry
#: glossary.docbook:129
#, no-c-format
msgid "light blue"
msgstr "blu e çelur"

#. Tag: userinput
#: glossary.docbook:130
#, no-c-format
msgid "255,0,255"
msgstr "255,0,255"

#. Tag: entry
#: glossary.docbook:130
#, no-c-format
msgid "pink"
msgstr "rozë"

#. Tag: userinput
#: glossary.docbook:131
#, no-c-format
msgid "255,255,0"
msgstr "255,255,0"

#. Tag: entry
#: glossary.docbook:131
#, no-c-format
msgid "yellow"
msgstr "e verdhë"

#. Tag: para
#: glossary.docbook:136
#, no-c-format
msgid ""
"Two commands need an RGB combination as input: these commands are "
"<userinput>canvascolor</userinput> and <userinput>pencolor</userinput>."
msgstr ""
"Dy komanda kërkojnë një kombinim RGB si të dhënë hyrëse; këto komanda janë "
"<userinput>ngjyrë_tabele</userinput> dhe <userinput>ngjyrë_lapsi</userinput>."

#. Tag: glossterm
#: glossary.docbook:140
#, no-c-format
msgid "sprite"
msgstr "figurina"

#. Tag: para
#: glossary.docbook:141
#, no-c-format
msgid ""
"A sprite is a small picture that can be moved around the screen. Our beloved "
"turtle, for instance, is a sprite."
msgstr ""
"Një figurinë është një foto e vogël që mund të lëvizet nëpër ekran. Breshka "
"jonë e dashur, për shembull, është një figurinë."

#. Tag: para
#: glossary.docbook:142
#, fuzzy, no-c-format
#| msgid ""
