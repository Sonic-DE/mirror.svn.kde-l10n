#, no-c-format
msgid ""
"The <userinput>sqrt</userinput> command is sued to find the square root of a "
"number, X."
msgstr ""
"Komanda <userinput>sqrt</userinput> përdoret për të gjetur rrënjën katrore "
"të një numri X."

#. Tag: term
#: programming-reference.docbook:452
#, no-c-format
msgid "<term>pi</term>"
msgstr "<term>pi</term>"

#. Tag: primary
#: programming-reference.docbook:452
#, no-c-format
