msgid "KCalc"
msgstr "KCalc"

#. (itstool) path: component/summary
#: org.kde.kcalc.appdata.xml:7
msgid "Scientific calculator"
msgstr "Makina Llogaritëse Shkencore"

#. (itstool) path: description/p
#: org.kde.kcalc.appdata.xml:12
msgid ""
"KCalc has everything you would expect from a scientific calculator, plus:"
msgstr "Makinë llogaritëse që ofron shumë funksione matematikore si  dhe"

#. (itstool) path: ul/li
#: org.kde.kcalc.appdata.xml:14
msgid "Trigonometric functions, logic operations and statistical calculations"
msgstr "funksione trigonometrike, operacione logjike dhe lloritje statistikore"

#. (itstool) path: ul/li
#: org.kde.kcalc.appdata.xml:15
msgid ""
"A results stack which enables convenient recall of previous calculation "
"results"
msgstr ""
"Një shirit i rezultateve që mundëson kthimin e vlerave llogaritjeve të "
"mëparshme"

#. (itstool) path: ul/li
#: org.kde.kcalc.appdata.xml:16
msgid "Precision is user-definable"
msgstr "Saktësi është e definuar nga përdoruesi"

#. (itstool) path: ul/li
#: org.kde.kcalc.appdata.xml:17
msgid "The display allows cut and paste of numbers"
msgstr "Pamja lejon kapjen dhe ngjitjen e numrave"

#. (itstool) path: ul/li
#: org.kde.kcalc.appdata.xml:18
msgid "The display colors and font are configurable, aiding usability"
msgstr ""
"Fontet the ngjyrat e pamjes mund të ndryshon, gjë që rritë përdorshmërinë"

#. (itstool) path: ul/li
#: org.kde.kcalc.appdata.xml:19
msgid "The use of key-bindings make it easy to use without a pointing device"
msgstr "Shkurtoret ju lehtësojnë përdorimin pa maus"

