msgid "Update"
msgstr "Përditësim"

#: src/tokodon.notifyrc:472
msgctxt "Comment"
msgid "Someone edited a post"
msgstr "Dikush përpunoi një postim"

#: src/tokodon.notifyrc:508
msgctxt "Name"
msgid "Poll"
msgstr "Pyetësor"

#: src/tokodon.notifyrc:540
msgctxt "Comment"
msgid "Someone's poll ended"
msgstr "Përfundoi pyetësori i dikujt"

#: src/tokodon.notifyrc:574
msgctxt "Name"
msgid "Status"
msgstr "Gjendje"

#: src/tokodon.notifyrc:606
msgctxt "Comment"
msgid "Someone posted a new status"
