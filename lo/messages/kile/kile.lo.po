msgid "\\label{key}"
msgstr "\\label{key}"

#: kilestdactions.cpp:288
#, kde-format
msgid "\\index{word}"
msgstr "\\index{word}"

#: kilestdactions.cpp:291
#, kde-format
msgid "\\footnote{text}"
msgstr "\\footnote{text}"

#: kilestdactions.cpp:296
#, kde-format
msgid ""
"This command generates an in-text citation to the reference associated with "
"the ref entry in the bib file\n"
"You can open the bib file with Kile to see all the available references"
msgstr ""
"ຄຳສັ່ງນີ້ສ້າງການອ້າງອີງໃນຂໍ້ຄວາມໄປຍັງ reference ທີ່ກ່ຽວຂ້ອງກັບລາຍການ ref "
"ໃນໄຟລ໌ bib\n"
"ທ່ານສາມາດເປີດໄຟລ໌ bib ດ້ວຍ Kile ເພື່ອເບິ່ງ references ທີ່ມີຢູ່ທັງໝົດ"

#: kilestdactions.cpp:298
#, kde-format
msgid "Underline - \\underline{}"
msgstr "ຂີດກ້ອງ - \\underline{}"

#: kilestdactions.cpp:303
#, kde-format
msgid "Smart Tabulator"
msgstr "Smart Tabulator"

#: kilestdactions.cpp:310
#, kde-format
msgid "Abstract - \\begin{abstract}"
msgstr "ບົດຄັດຫຍໍ້ - \\begin{abstract}"

#: kilestdactions.cpp:310
#, kde-format
msgid "Abstract"
msgstr "ບົດຄັດຫຍໍ້"

#: kilestdactions.cpp:313
#, kde-format
msgid ""
"\\begin{abstract}\n"
"text\n"
"\\end{abstract}\n"
"The abstract environment creates a title page, i.e. a page with no printed "
"page number or heading."
msgstr ""
"\\begin{abstract}\n"
"text\n"
"\\end{abstract}\n"
"ສະພາບແວດລ້ອມ abstract ສ້າງໜ້າຫົວຂໍ້, ເຊັ່ນ: "
"ໜ້າທີ່ບໍ່ມີເລກໜ້າຫຼືຫົວຂໍ້ພິມຢູ່."

#: kilestdactions.cpp:315
#, kde-format
msgid "Tabular* - \\begin{tabular*}"
msgstr "ຕາຕະລາງ* - \\begin{tabular*}"

#: kilestdactions.cpp:315
#, kde-format
msgid "Tabular*"
msgstr "ຕາຕະລາງ*"

#: kilestdactions.cpp:318
#, kde-format
msgid ""
"\\begin{tabular*}{width}[pos]{cols}\n"
"column 1 entry & column 2 entry ... & column n entry \\\\\n"
"...\n"
"\\end{tabular*}\n"
"This is an extended version of the tabular environment with an extra "
"parameter for the width. There must be rubber space between columns that can "
"stretch to fill out the specified width."
msgstr ""
"\\begin{tabular*}{width}[pos]{cols}\n"
"column 1 entry & column 2 entry ... & column n entry \\\\\n"
"...\n"
"\\end{tabular*}\n"
"ນີ້ແມ່ນເວີຊັນຂະຫຍາຍຂອງສະພາບແວດລ້ອມ tabular "
"ທີ່ມີພາລາມິເຕີພິເສດສຳລັບຄວາມກວ້າງ. "
"ຕ້ອງມີຍະຫວ່າງທີ່ຢືດຢຸ່ນໄດ້ລະຫວ່າງຖັນທີ່ສາມາດຢືດອອກເພື່ອໃຫ້ເຕັມຄວາມກວ້າງທີ່ລະບຸ."

#: kilestdactions.cpp:320
#, kde-format
msgid "Minipage - \\begin{minipage}"
msgstr "ໜ້ານ້ອຍ - \\begin{minipage}"

#: kilestdactions.cpp:320
#, kde-format
msgid "Minipage"
msgstr "ໜ້ານ້ອຍ"

#: kilestdactions.cpp:323
#, kde-format
msgid ""
"The minipage environment is similar to a \\parbox command. It takes the same "
"optional position argument and mandatory width argument. You may use other "
"paragraph-making environments inside a minipage."
msgstr ""
"ສະພາບແວດລ້ອມ minipage ຄ້າຍຄືກັບຄຳສັ່ງ \\parbox. "
"ມັນຮັບ argument ຕຳແໜ່ງທາງເລືອກ ແລະ argument ຄວາມກວ້າງທີ່ຈຳເປັນຄືກັນ. "
"ທ່ານສາມາດໃຊ້ສະພາບແວດລ້ອມສ້າງວັກອື່ນໆພາຍໃນ minipage ໄດ້."

#: kilestdactions.cpp:326
#, kde-format
msgid "Table of Figures - \\listoffigures"
msgstr "ສາລະບານຮູບ - \\listoffigures"

#: kilestdactions.cpp:326
#, kde-format
msgid "Table of Figures"
msgstr "ສາລະບານຮູບ"

#: kilestdactions.cpp:329
#, kde-format
msgid "Put this command where you want the list of figures to go."
msgstr "ໃສ່ຄຳສັ່ງນີ້ບ່ອນທີ່ທ່ານຕ້ອງການໃຫ້ລາຍການຮູບສະແດງ."

#: kilestdactions.cpp:331
#, kde-format
msgid "Table of Tables - \\listoftables"
msgstr "ສາລະບານຕາຕະລາງ - \\listoftables"

#: kilestdactions.cpp:331
#, kde-format
msgid "Table of Tables"
msgstr "ສາລະບານຕາຕະລາງ"

#: kilestdactions.cpp:334
#, kde-format
msgid "Put this command where you want the list of tables to go."
msgstr "ໃສ່ຄຳສັ່ງນີ້ບ່ອນທີ່ທ່ານຕ້ອງການໃຫ້ລາຍການຕາຕະລາງສະແດງ."

#: kilestdactions.cpp:336
#, kde-format
msgid "Generate Index - \\makeindex"
msgstr "ສ້າງດັດຊະນີ - \\makeindex"

#: kilestdactions.cpp:336
#, kde-format
msgid "Generate Index"
msgstr "ສ້າງດັດຊະນີ"

#: kilestdactions.cpp:339
#, kde-format
msgid "Put this command when you want to generate the raw index."
msgstr "ໃສ່ຄຳສັ່ງນີ້ເມື່ອທ່ານຕ້ອງການສ້າງດັດຊະນີດິບ."

#: kilestdactions.cpp:341
#, kde-format
msgid "Print Index - \\printindex"
msgstr "ພິມດັດຊະນີ - \\printindex"

#: kilestdactions.cpp:341
#, kde-format
msgid "Print Index"
msgstr "ພິມດັດຊະນີ"

#: kilestdactions.cpp:344
#, kde-format
msgid "Put this command when you want to print the formatted index."
msgstr "ໃສ່ຄຳສັ່ງນີ້ເມື່ອທ່ານຕ້ອງການພິມດັດຊະນີທີ່ຈັດຮູບແບບແລ້ວ."

#: kilestdactions.cpp:346
#, kde-format
msgid "Glossary - \\makeglossary"
msgstr "ອະທິບາຍຄຳສັບ - \\makeglossary"

#: kilestdactions.cpp:346
#, kde-format
msgid "Glossary"
msgstr "ອະທິບາຍຄຳສັບ"

#: kilestdactions.cpp:349
#, kde-format
msgid "Put this command when you want to print a glossary."
msgstr "ໃສ່ຄຳສັ່ງນີ້ເມື່ອທ່ານຕ້ອງການພິມຄຳອະທິບາຍຄຳສັບ."

#: kilestdactions.cpp:351
#, kde-format
msgid "Bibliography - \\begin{thebibliography}"
msgstr "ບັນນານຸກົມ - \\begin{thebibliography}"

#: kilestdactions.cpp:351 widgets/projectview.cpp:477
#, kde-format
msgid "Bibliography"
msgstr "ບັນນານຸກົມ"

#: kilestdactions.cpp:354
#, kde-format
msgid ""
"\\begin{thebibliography}{widest-label}\n"
"\\bibitem[label]{cite_key}\n"
"...\n"
"\\end{thebibliography}\n"
"\n"
"widest-label : Text that, when printed, is approximately as wide as the "
"widest item label produces by the \\bibitem commands\n"
"\\bibitem : Specify a bibliography item"
msgstr ""
"\\begin{thebibliography}{widest-label}\n"
"\\bibitem[label]{cite_key}\n"
"...\n"
"\\end{thebibliography}\n"
"\n"
"widest-label : ຂໍ້ຄວາມທີ່ເມື່ອພິມອອກມາແລ້ວ, "
"ຈະກວ້າງເທົ່າກັບປ້າຍຊື່ລາຍການທີ່ກວ້າງທີ່ສຸດທີ່ສ້າງໂດຍຄຳສັ່ງ \\bibitem\n"
"\\bibitem : ລະບຸລາຍການບັນນານຸກົມ"

#: kilestdactions.cpp:357
#, kde-format
msgid "Verbatim (show spaces) - \\begin{verbatim*}"
msgstr "Verbatim (ສະແດງຍະຫວ່າງ) - \\begin{verbatim*}"

#: kilestdactions.cpp:357
#, kde-format
msgid "Verbatim (show spaces)"
msgstr "Verbatim (ສະແດງຍະຫວ່າງ)"

#: kilestdactions.cpp:360
#, kde-format
msgid ""
"Environment that gets LaTeX to print exactly what you type in. In this "
"variant, spaces are printed in a special manner."
msgstr ""
"ສະພາບແວດລ້ອມທີ່ໃຫ້ LaTeX ພິມສິ່ງທີ່ທ່ານພິມລົງໄປແປະໆ. ໃນແບບນີ້, "
"ຍະຫວ່າງຈະຖືກພິມໃນແບບພິເສດ."

#: kilestdactions.cpp:362
#, kde-format
msgid "Embedded Code - \\verb||"
msgstr "Embedded Code - \\verb||"

#: kilestdactions.cpp:362
#, kde-format
msgid "Embedded Code"
msgstr "Embedded Code"

#: kilestdactions.cpp:364
#, kde-format
msgid "Macro form of the verbatim environment."
msgstr "ຮູບແບບ Macro ຂອງສະພາບແວດລ້ອມ verbatim."

#: kilestdactions.cpp:366
#, kde-format
msgid "Embedded Code (show spaces) - \\verb*||"
msgstr "Embedded Code (ສະແດງຍະຫວ່າງ) - \\verb*||"

#: kilestdactions.cpp:366
#, kde-format
msgid "Embedded Code (show spaces)"
msgstr "Embedded Code (ສະແດງຍະຫວ່າງ)"

#: kilestdactions.cpp:368
#, kde-format
msgid "Macro form of the verbatim* environment."
msgstr "ຮູບແບບ Macro ຂອງສະພາບແວດລ້ອມ verbatim*."

#: kilestdactions.cpp:371
#, kde-format
msgid "\"Small\" Vertical Space - \\smallskip"
msgstr "ຍະຫວ່າງລວງຕັ້ງ \"ນ້ອຍ\" - \\smallskip"

#: kilestdactions.cpp:371
#, kde-format
msgid "\"Small\" Vertical Space"
msgstr "ຍະຫວ່າງລວງຕັ້ງ \"ນ້ອຍ\""

#: kilestdactions.cpp:373
#, kde-format
msgid "The \\smallskip command adds a 'small' vertical space."
msgstr "ຄຳສັ່ງ \\smallskip ເພີ່ມຍະຫວ່າງລວງຕັ້ງ 'ນ້ອຍ'."

#: kilestdactions.cpp:375
#, kde-format
msgid "\\enskip"
msgstr "\\enskip"

#: kilestdactions.cpp:378
#, kde-format
msgid "Horizontal Variable Space - \\hfill"
msgstr "ຍະຫວ່າງລວງນອນແບບປ່ຽນແປງໄດ້ - \\hfill"

#: kilestdactions.cpp:378
#, kde-format
msgid "Horizontal Variable Space"
msgstr "ຍະຫວ່າງລວງນອນແບບປ່ຽນແປງໄດ້"

#: kilestdactions.cpp:381
#, kde-format
msgid ""
"The \\hfill fill command produces a \"rubber length\" which can stretch or "
"shrink horizontally. It will be filled with spaces."
msgstr ""
"ຄຳສັ່ງ \\hfill ສ້າງ \"rubber length\" "
"ທີ່ສາມາດຢືດຫຼືຫົດໄດ້ໃນລວງນອນ. ມັນຈະຖືກຕື່ມດ້ວຍຍະຫວ່າງ."

#: kilestdactions.cpp:383
#, kde-format
msgid "Horizontal Dots - \\dotfill"
msgstr "ຈຸດລວງນອນ - \\dotfill"

#: kilestdactions.cpp:383
#, kde-format
msgid "Horizontal Dots"
msgstr "ຈຸດລວງນອນ"

#: kilestdactions.cpp:386
#, kde-format
msgid ""
"The \\dotfill command produces a \"rubber length\" that produces dots "
"instead of just spaces."
msgstr ""
"ຄຳສັ່ງ \\dotfill ສ້າງ \"rubber length\" "
"ທີ່ສ້າງຈຸດແທນທີ່ຈະເປັນຍະຫວ່າງ."

#: kilestdactions.cpp:388
#, kde-format
msgid "Horizontal Rule - \\hrulefill"
msgstr "ເສັ້ນລວງນອນ - \\hrulefill"

#: kilestdactions.cpp:388
#, kde-format
msgid "Horizontal Rule"
msgstr "ເສັ້ນລວງນອນ"

#: kilestdactions.cpp:391
#, kde-format
msgid ""
"The \\hrulefill fill command produces a \"rubber length\" which can stretch "
"or shrink horizontally. It will be filled with a horizontal rule."
msgstr ""
"ຄຳສັ່ງ \\hrulefill ສ້າງ \"rubber length\" "
"ທີ່ສາມາດຢືດຫຼືຫົດໄດ້ໃນລວງນອນ. ມັນຈະຖືກຕື່ມດ້ວຍເສັ້ນລວງນອນ."

#: kilestdactions.cpp:393
#, kde-format
msgid "Vertical Variable Space - \\vfill"
msgstr "ຍະຫວ່າງລວງຕັ້ງແບບປ່ຽນແປງໄດ້ - \\vfill"

#: kilestdactions.cpp:393
#, kde-format
msgid "Vertical Variable Space"
msgstr "ຍະຫວ່າງລວງຕັ້ງແບບປ່ຽນແປງໄດ້"

#: kilestdactions.cpp:396
#, kde-format
msgid ""
"The \\vfill fill command produces a \"rubber length\" which can stretch or "
"shrink vertically."
msgstr ""
"ຄຳສັ່ງ \\vfill ສ້າງ \"rubber length\" "
"ທີ່ສາມາດຢືດຫຼືຫົດໄດ້ໃນລວງຕັ້ງ."

#: kilestdactions.cpp:398
#, kde-format
msgid "Horizontal Space - \\hspace{}"
msgstr "ຍະຫວ່າງລວງນອນ - \\hspace{}"

#: kilestdactions.cpp:398
#, kde-format
msgid "Horizontal Space"
msgstr "ຍະຫວ່າງລວງນອນ"

#: kilestdactions.cpp:401
#, kde-format
msgid ""
"The \\hspace command adds horizontal space. The length of the space can be "
"expressed in any terms that LaTeX understands, i.e., points, inches, etc. "
"You can add negative as well as positive space with an \\hspace command. "
"Adding negative space is like backspacing."
msgstr ""
"ຄຳສັ່ງ \\hspace ເພີ່ມຍະຫວ່າງລວງນອນ. ຄວາມຍາວຂອງຍະຫວ່າງສາມາດລະບຸໄດ້ໃນໜ່ວຍທີ່ "
"LaTeX ເຂົ້າໃຈ, ເຊັ່ນ: points, inches, ຯລຯ. "
"ທ່ານສາມາດເພີ່ມຍະຫວ່າງລົບແລະບວກດ້ວຍຄຳສັ່ງ \\hspace. ການເພີ່ມຍະຫວ່າງລົບຄືກັບການ "
"backspacing."

#: kilestdactions.cpp:403
#, kde-format
msgid "Horizontal Space (forced) - \\hspace*{}"
msgstr "ຍະຫວ່າງລວງນອນ (ບັງຄັບ) - \\hspace*{}"

#: kilestdactions.cpp:403
#, kde-format
msgid "Horizontal Space (forced)"
msgstr "ຍະຫວ່າງລວງນອນ (ບັງຄັບ)"

#: kilestdactions.cpp:406
#, kde-format
msgid ""
"The \\hspace* command adds horizontal space like the \\hspace command. LaTeX "
"removes horizontal space that comes at the end of a line. If you do not want "
"LaTeX to remove this space, include the optional * argument. Then the space "
"is never removed."
msgstr ""
"ຄຳສັ່ງ \\hspace* ເພີ່ມຍະຫວ່າງລວງນອນຄືກັບຄຳສັ່ງ \\hspace. LaTeX "
"ຈະລຶບຍະຫວ່າງລວງນອນທີ່ຢູ່ທ້າຍແຖວ. ຖ້າທ່ານບໍ່ຕ້ອງການໃຫ້ LaTeX ລຶບຍະຫວ່າງນີ້, "
"ໃຫ້ໃສ່ argument * ທາງເລືອກ. ຈາກນັ້ນຍະຫວ່າງຈະບໍ່ຖືກລຶບ."

#: kilestdactions.cpp:408
#, kde-format
msgid "Vertical Space - \\vspace{}"
msgstr "ຍະຫວ່າງລວງຕັ້ງ - \\vspace{}"

#: kilestdactions.cpp:408
#, kde-format
msgid "Vertical Space"
msgstr "ຍະຫວ່າງລວງຕັ້ງ"

#: kilestdactions.cpp:411
#, kde-format
msgid ""
"The \\vspace command adds vertical space. The length of the space can be "
"expressed in any terms that LaTeX understands, i.e., points, inches, etc. "
"You can add negative as well as positive space with an \\vspace command."
msgstr ""
"ຄຳສັ່ງ \\vspace ເພີ່ມຍະຫວ່າງລວງຕັ້ງ. ຄວາມຍາວຂອງຍະຫວ່າງສາມາດລະບຸໄດ້ໃນໜ່ວຍທີ່ "
"LaTeX ເຂົ້າໃຈ, ເຊັ່ນ: points, inches, ຯລຯ. "
"ທ່ານສາມາດເພີ່ມຍະຫວ່າງລົບແລະບວກດ້ວຍຄຳສັ່ງ \\vspace."

#: kilestdactions.cpp:413
#, kde-format
msgid "Vertical Space (forced) - \\vspace*{}"
msgstr "ຍະຫວ່າງລວງຕັ້ງ (ບັງຄັບ) - \\vspace*{}"

#: kilestdactions.cpp:413
#, kde-format
msgid "Vertical Space (forced)"
msgstr "ຍະຫວ່າງລວງຕັ້ງ (ບັງຄັບ)"

#: kilestdactions.cpp:416
#, kde-format
msgid ""
"The \\vspace* command adds vertical space like the \\vspace command. LaTeX "
"removes vertical space that comes at the end of a page. If you do not want "
"LaTeX to remove this space, include the optional * argument. Then the space "
"is never removed."
msgstr ""
"ຄຳສັ່ງ \\vspace* ເພີ່ມຍະຫວ່າງລວງຕັ້ງຄືກັບຄຳສັ່ງ \\vspace. LaTeX "
"ຈະລຶບຍະຫວ່າງລວງຕັ້ງທີ່ຢູ່ທ້າຍໜ້າ. ຖ້າທ່ານບໍ່ຕ້ອງການໃຫ້ LaTeX ລຶບຍະຫວ່າງນີ້, "
"ໃຫ້ໃສ່ argument * ທາງເລືອກ. ຈາກນັ້ນຍະຫວ່າງຈະບໍ່ຖືກລຶບ."

