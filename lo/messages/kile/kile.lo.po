msgstr "ບໍ່ໄດ້ເລືອກບັນນານຸກົມ."

#: kilestdtools.cpp:752
#, kde-format
msgid "No bibliographies found."
msgstr "ບໍ່ພົບບັນນານຸກົມ."

#: kilestdtools.cpp:788
#, kde-format
msgid ""
"Unable to find %1 or %2; if you are trying to view some other HTML file, go "
"to Settings->Configure Kile->Tools->ViewHTML->Advanced."
msgstr ""
"ບໍ່ສາມາດຊອກຫາ %1 ຫຼື %2; ຖ້າທ່ານກຳລັງພະຍາຍາມເບິ່ງໄຟລ໌ HTML ອື່ນ, ໃຫ້ໄປທີ່ ການຕັ້ງຄ່າ->ຕັ້ງຄ່າ Kile->ເຄື່ອງມື->ViewHTML->ຂັ້ນສູງ."

#: kiletool.cpp:57
#, kde-format
msgid "Could not change to the folder %1."
msgstr "ບໍ່ສາມາດປ່ຽນໄປໂຟນເດີ %1 ໄດ້."

#: kiletool.cpp:58
#, kde-format
msgid ""
"The folder %1 is not writable, therefore %2 will not be able to save its "
"results."
msgstr ""
"ໂຟນເດີ %1 ບໍ່ສາມາດຂຽນໃສ່ໄດ້, ດັ່ງນັ້ນ %2 ຈະບໍ່ສາມາດບັນທຶກຜົນໄດ້."

#: kiletool.cpp:59
#, kde-format
msgid ""
"The file %1/%2 does not exist. If this is unexpected, check the file "
"permissions."
msgstr ""
"ໄຟລ໌ %1/%2 ບໍ່ມີຢູ່. ຖ້ານີ້ຜິດປົກກະຕິ, ໃຫ້ກວດເບິ່ງສິດຂອງໄຟລ໌."

#: kiletool.cpp:60
#, kde-format
msgid ""
"The file %1/%2 is not readable. If this is unexpected, check the file "
"permissions."
msgstr ""
"ໄຟລ໌ %1/%2 ບໍ່ສາມາດອ່ານໄດ້. ຖ້ານີ້ຜິດປົກກະຕິ, ໃຫ້ກວດເບິ່ງສິດຂອງໄຟລ໌."

#: kiletool.cpp:61
#, kde-format
msgid ""
"Could not determine on which file to run %1, because there is no active "
"document."
msgstr ""
"ບໍ່ສາມາດກຳນົດໄດ້ວ່າຈະລັນ %1 ໃສ່ໄຟລ໌ໃດ, ເພາະວ່າບໍ່ມີເອກະສານທີ່ກຳລັງໃຊ້ງານຢູ່."

#: kiletool.cpp:62
#, kde-format
msgid "Could not determine the master file for this document."
msgstr "ບໍ່ສາມາດກຳນົດໄຟລ໌ຫຼັກສຳລັບເອກະສານນີ້ໄດ້."

#: kiletool.cpp:63
#, kde-format
msgid "Please save the untitled document first."
msgstr "ກະລຸນາບັນທຶກເອກະສານທີ່ບໍ່ມີຊື່ກ່ອນ."

#: kiletool.cpp:64
#, kde-format
msgid "The file %1 does not exist."
msgstr "ໄຟລ໌ %1 ບໍ່ມີຢູ່."

#: kiletool.cpp:65
#, kde-format
msgid "The file %1 is not readable."
msgstr "ໄຟລ໌ %1 ບໍ່ສາມາດອ່ານໄດ້."

#: kiletool.cpp:639
#, kde-format
msgid "The document %1 is not a LaTeX root document; continue anyway?"
msgstr "ເອກະສານ %1 ບໍ່ແມ່ນເອກະສານຮາກ LaTeX; ຕ້ອງການສືບຕໍ່ບໍ່?"

#: kiletool.cpp:639
#, kde-format
msgid "Continue?"
msgstr "ສືບຕໍ່?"

#: kiletool.cpp:651
#, kde-format
msgid "The file %1/%2 does not exist; did you compile the source file?"
msgstr "ໄຟລ໌ %1/%2 ບໍ່ມີຢູ່; ທ່ານໄດ້ຄອມໄພລ໌ໄຟລ໌ແຫຼ່ງຂໍ້ມູນແລ້ວບໍ່?"

#: kiletool.cpp:671
#, kde-format
msgid ""
"The current document is not associated to a project. Please activate a "
"document that is associated to the project you want to archive, then choose "
"Archive again."
msgstr ""
"ເອກະສານປັດຈຸບັນບໍ່ໄດ້ເຊື່ອມໂຍງກັບໂຄງການ. ກະລຸນາເປີດເອກະສານທີ່ເຊື່ອມໂຍງກັບໂຄງການທີ່ທ່ານຕ້ອງການຈັດເກັບ, ແລ້ວເລືອກ ຈັດເກັບ ອີກຄັ້ງ."

#: kiletool.cpp:675
#, kde-format
msgid "No files have been chosen for archiving."
msgstr "ບໍ່ມີໄຟລ໌ຖືກເລືອກສຳລັບການຈັດເກັບ."

