#: dialogs/configcheckerdialog.cpp:105
#, kde-format
msgid "System Check"
msgstr "ກວດສອບລະບົບ"

#: dialogs/configcheckerdialog.cpp:113
#, kde-format
msgid ""
"<p>This configuration assistant will check whether your system is set up "
"correctly to process LaTeX documents. It will also allow to fine-tune the "
"configuration of Kile while taking the results of the tests into account.</"
"p><p>It is recommended to run this assistant before using Kile for the first "
"time.</p><p>Please press 'Next' now to start the test procedure.</p>"
msgstr ""
"<p>ຕົວຊ່ວຍການຕັ້ງຄ່ານີ້ຈະກວດສອບວ່າລະບົບຂອງທ່ານຖືກຕັ້ງຄ່າຢ່າງຖືກຕ້ອງເພື່ອປະມວນຜົນເອກະສານ "
"LaTeX ຫຼື ບໍ່. ມັນຍັງຈະຊ່ວຍປັບແຕ່ງການຕັ້ງຄ່າຂອງ Kile ໂດຍຄຳນຶງເຖິງຜົນຂອງການທົດສອບ.</"
"p><p>ແນະນຳໃຫ້ແລ່ນຕົວຊ່ວຍນີ້ກ່ອນທີ່ຈະໃຊ້ Kile ເປັນຄັ້ງທຳອິດ.</p><p>ກະລຸນາກົດ 'ຕໍ່ໄປ' "
"ດຽວນີ້ເພື່ອເລີ່ມຂັ້ນຕອນການທົດສອບ.</p>"

#: dialogs/configcheckerdialog.cpp:124
#, kde-format
msgid "System Check & Configuration Assistant"
msgstr "ຕົວຊ່ວຍກວດສອບລະບົບ ແລະ ການຕັ້ງຄ່າ"

#: dialogs/configcheckerdialog.cpp:127
#, kde-format
msgid "Checking whether the system is set up correctly..."
msgstr "ກຳລັງກວດສອບວ່າລະບົບຖືກຕັ້ງຄ່າຢ່າງຖືກຕ້ອງຫຼືບໍ່..."

#: dialogs/configcheckerdialog.cpp:134
#, kde-format
msgctxt "%p is the percent value, % is the percent sign"
msgid "%p%"
msgstr "%p%"

#: dialogs/configcheckerdialog.cpp:148
#, kde-format
msgid "Configure the viewer tools to use the document viewer"
msgstr "ຕັ້ງຄ່າເຄື່ອງມືສະແດງຜົນເພື່ອໃຊ້ຕົວອ່ານເອກະສານ"

#: dialogs/configcheckerdialog.cpp:150
#, kde-format
msgid "Use the 'modern' configuration for the TeX, PDFTeX, and LaTeX tools"
msgstr "ໃຊ້ການຕັ້ງຄ່າ 'modern' ສຳລັບເຄື່ອງມື TeX, PDFTeX ແລະ LaTeX"

#: dialogs/configcheckerdialog.cpp:152
#, kde-format
msgid ""
"Use the 'modern' configuration for the PDFLaTeX, LuaLaTeX and XeLaTeX tools"
msgstr "ໃຊ້ການຕັ້ງຄ່າ 'modern' ສຳລັບເຄື່ອງມື PDFLaTeX, LuaLaTeX ແລະ XeLaTeX"

#: dialogs/configcheckerdialog.cpp:154
#, kde-format
msgid ""
"<br/>Please press 'Finish' now to accept the recommended configuration "
"changes."
msgstr "<br/>ກະລຸນາກົດ 'ສຳເລັດ' ດຽວນີ້ເພື່ອຍອມຮັບການປ່ຽນແປງການຕັ້ງຄ່າທີ່ແນະນຳ."

#: dialogs/configcheckerdialog.cpp:157
#, kde-format
msgid "Test Results"
msgstr "ຜົນການທົດສອບ"

#: dialogs/configcheckerdialog.cpp:232
#, kde-format
msgid ""
"The following <b>critical</b> tests did not succeed:<br/><br/>%1<br/><br/"
">Kile cannot function correctly on your system. Please consult the test "
"results<br/>to determine which programs have to be fixed."
msgstr ""
"ການທົດສອບທີ່ <b>ສຳຄັນ</b> ຕໍ່ໄປນີ້ບໍ່ສຳເລັດ:<br/><br/>%1<br/><br/>Kile "
"ບໍ່ສາມາດເຮັດວຽກຢ່າງຖືກຕ້ອງໃນລະບົບຂອງທ່ານ. ກະລຸນາເບິ່ງຜົນການທົດສອບ<br/>"
"ເພື່ອກຳນົດວ່າໂປຣແກຣມໃດທີ່ຕ້ອງໄດ້ຮັບການແກ້ໄຂ."

#: dialogs/configcheckerdialog.cpp:238
#, kde-format
msgid ""
"The following tests did not succeed:<br/><br/>%1<br/><br/>You will still be "
"able to use Kile; however, not all features are guaranteed to work."
msgstr ""
"ການທົດສອບຕໍ່ໄປນີ້ບໍ່ສຳເລັດ:<br/><br/>%1<br/><br/>ທ່ານຈະຍັງສາມາດໃຊ້ Kile ໄດ້; "
"ແນວໃດກໍ່ຕາມ, ບໍ່ຮັບປະກັນວ່າທຸກຟີເຈີຈະເຮັດວຽກໄດ້."

#: dialogs/configcheckerdialog.cpp:243
#, kde-format
msgid ""
"<b>No problems were detected. Kile will work correctly on your system.</b>"
msgstr "<b>ກວດບໍ່ພົບເຫັນບັນຫາ. Kile ຈະເຮັດວຽກຢ່າງຖືກຕ້ອງໃນລະບົບຂອງທ່ານ.</b>"

#: dialogs/configcheckerdialog.cpp:256
#, kde-format
msgid ""
"The embedded document viewer is available and live preview is supported."
msgstr "ມີຕົວອ່ານເອກະສານແບບຝັງຢູ່ ແລະ ຮອງຮັບການສະແດງຕົວຢ່າງສົດ."

#: dialogs/configcheckerdialog.cpp:259
#, kde-format
msgid ""
"The embedded document viewer is available, but the installed version of "
"PDFLaTeX is<br/><b>not compatible</b> with live preview."
msgstr ""
"ມີຕົວອ່ານເອກະສານແບບຝັງຢູ່, ແຕ່ເວີຊັນຂອງ PDFLaTeX ທີ່ຕິດຕັ້ງໄວ້<br/><b>ບໍ່ເຂົ້າກັນ</b> "
"ກັບການສະແດງຕົວຢ່າງສົດ."

#: dialogs/configcheckerdialog.cpp:267
#, kde-format
msgid ""
"The embedded document viewer is <b>not available</b> (as Okular is either "
"not available or the installed<br/>version is too old). Live preview is "
"hence not supported."
msgstr ""
"ຕົວອ່ານເອກະສານແບບຝັງ <b>ບໍ່ມີໃຫ້ໃຊ້ງານ</b> (ເນື່ອງຈາກ Okular ບໍ່ມີໃຫ້ໃຊ້ "
"ຫຼືເວີຊັນທີ່ຕິດຕັ້ງໄວ້<br/>ເກົ່າເກີນໄປ). ດັ່ງນັ້ນຈຶ່ງບໍ່ຮອງຮັບການສະແດງຕົວຢ່າງສົດ."

#: dialogs/configcheckerdialog.cpp:291
#, kde-format
msgid ""
"<br/><font color=\"#FF0000\"><b>The tests could not be finished correctly. "
"Please check the available disk space.</b></font>"
msgstr ""
"<br/><font color=\"#FF0000\"><b>ການທົດສອບບໍ່ສາມາດສຳເລັດໄດ້ຢ່າງຖືກຕ້ອງ. "
"ກະລຸນາກວດສອບພື້ນທີ່ດິດທີ່ຫວ່າງຢູ່.</b></font>"

