#. (itstool) path: component/name
#: org.kde.amarok.appdata.xml:17
msgid "Amarok"
msgstr "Amarok"

#. (itstool) path: component/summary
#: org.kde.amarok.appdata.xml:18
msgid "Rediscover your music"
msgstr "ຄົ້ນພົບເພງຂອງທ່ານອີກຄັ້ງ"

#. (itstool) path: description/p
#: org.kde.amarok.appdata.xml:20
msgid ""
"Amarok is a free, cross-platform, versatile, powerful and feature-rich music "
"player and collection manager."
msgstr "Amarok ແມ່ນໂປຣແກຣມຫຼິ້ນເພງ ແລະ ຈັດການຄັງເພງທີ່ແຈກຟຣີ, ຂ້າມແພລັດຟອມ, ອະເນກປະສົງ, ມີປະສິດທິພາບ ແລະ ຄຸນສົມບັດຄົບຖ້ວນ."

#. (itstool) path: description/p
#: org.kde.amarok.appdata.xml:21
msgid "Features:"
msgstr "ຄຸນສົມບັດ:"

#. (itstool) path: ul/li
#: org.kde.amarok.appdata.xml:23
msgid "Dynamic playlists matching different criteria"
msgstr "ລາຍການຫຼິ້ນແບບເຄື່ອນໄຫວທີ່ກົງກັບເງື່ອນໄຂຕ່າງໆ"

#. (itstool) path: ul/li
#: org.kde.amarok.appdata.xml:24
msgid "Collection managing with rating support"
msgstr "ການຈັດການຄັງເພງພ້ອມຮອງຮັບການໃຫ້ຄະແນນ"

#. (itstool) path: ul/li
#: org.kde.amarok.appdata.xml:25
msgid "Support for basic iPod, MTP and UMS music player devices"
msgstr "ຮອງຮັບອຸປະກອນຫຼິ້ນເພງ iPod ພື້ນຖານ, MTP ແລະ UMS"

#. (itstool) path: ul/li
#: org.kde.amarok.appdata.xml:26
msgid "Integrated Internet services: last.fm, Magnatune, Ampache and more."
msgstr "ບໍລິການອິນເຕີເນັດທີ່ເຊື່ອມຕໍ່ໄວ້: last.fm, Magnatune, Ampache ແລະ ອື່ນໆ."

#. (itstool) path: ul/li
#: org.kde.amarok.appdata.xml:27
msgid "Scripting support"
msgstr "ຮອງຮັບການຂຽນສະຄຣິບ"

#. (itstool) path: ul/li
#: org.kde.amarok.appdata.xml:28
msgid "Cover manager"
msgstr "ໂຕຈັດການຮູບໜ້າປົກ"

#. (itstool) path: ul/li
#: org.kde.amarok.appdata.xml:29
msgid "Replay gain support"
msgstr "ຮອງຮັບ Replay gain (ປັບລະດັບສຽງ)"

#. (itstool) path: screenshot/caption
