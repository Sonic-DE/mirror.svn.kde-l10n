#: core/app/views/stack/welcomepageview.cpp:98
#, kde-format
msgid "More than 1700 user-reports closed on bugzilla."
msgstr "ລາຍງານຈາກຜູ້ໃຊ້ຫຼາຍກວ່າ 1700 ລາຍການຖືກປິດໃນ bugzilla."

#: core/app/views/stack/welcomepageview.cpp:99
#, kde-format
msgid "Port code to Qt6 framework (code still compatible with Qt5 API)."
msgstr "ຍ້າຍໂຄ້ດໄປຍັງເຟຣມເວີກ Qt6 (ໂຄ້ດຍັງຄົງເຂົ້າກັນໄດ້ກັບ Qt5 API)."

#: core/app/views/stack/welcomepageview.cpp:100
#, kde-format
msgid ""
"Windows Installer is now compiled natively with Microsoft VCPKG tool-chain and use Qt6 and KF6 "
"frameworks."
msgstr "ຕົວຕິດຕັ້ງ Windows ຕອນນີ້ຖືກຄອມໄພລ໌ແບບ native ດ້ວຍ Microsoft VCPKG tool-chain ແລະ ໃຊ້ເຟຣມເວີກ Qt6 ແລະ KF6."

#: core/app/views/stack/welcomepageview.cpp:101
#, kde-format
msgid "Add JPEG-XL, WEBP, and AVIF export settings everywhere."
msgstr "ເພີ່ມການຕັ້ງຄ່າການສົ່ງອອກ JPEG-XL, WEBP ແລະ AVIF ໃນທຸກບ່ອນ."

#: core/app/views/stack/welcomepageview.cpp:102
#, kde-format
msgid "Add convert to lossless JPEG-XL, WEBP, and AVIF while importing from camera."
msgstr "ເພີ່ມການປ່ຽນເປັນ JPEG-XL, WEBP ແລະ AVIF ແບບບໍ່ເສຍຄຸນນະພາບ (lossless) ຂະນະນຳເຂົ້າຈາກກ້ອງຖ່າຍຮູບ."

#: core/app/views/stack/welcomepageview.cpp:103
#, kde-format
msgid "Add JPEG-XL; WEBP, and AVIF converters in Batch Queue Manager."
msgstr "ເພີ່ມຕົວແປງ JPEG-XL, WEBP ແລະ AVIF ໃນຕົວຈັດການຄິວແບບກຸ່ມ (Batch Queue Manager)."

#: core/app/views/stack/welcomepageview.cpp:104
#, kde-format
msgid ""
"Versioning: add support of JPEG-XL, HEIF, WEBP, and AVIF as lossless image format to store versioned "
"images in editor."
msgstr "ການຈັດການ Version: ເພີ່ມການຮອງຮັບ JPEG-XL, HEIF, WEBP ແລະ AVIF ເປັນຮູບແບບຮູບພາບທີ່ບໍ່ເສຍຄຸນນະພາບ ເພື່ອເກັບຮູບພາບທີ່ມີການຈັດການ version ໃນຕົວແກ້ໄຂ."

#: core/app/views/stack/welcomepageview.cpp:105
#, kde-format
msgid "Usability: add hamburger menu to tool-bar if main menu is hidden."
msgstr "ການໃຊ້ງານ: ເພີ່ມເມນູຮູບແຮມເບີເກີ (ສາມຂີດ) ໃສ່ແຖບເຄື່ອງມື ຖ້າເມນູຫຼັກຖືກເຊື່ອງໄວ້."

#: core/app/views/stack/welcomepageview.cpp:106
#, kde-format
msgid "Metadata: add new option to write metadata to files with ExifTool backend."
msgstr "Metadata: ເພີ່ມຕົວເລືອກໃໝ່ເພື່ອຂຽນ Metadata ລົງໃນໄຟລ໌ດ້ວຍ ExifTool backend."

#: core/app/views/stack/welcomepageview.cpp:107
#, kde-format
msgid ""
"Metadata: optional write metadata operations to DNG and RAW files are now always delegated to ExifTool "
"Backend."
msgstr "Metadata: ການປະຕິບັດການຂຽນ Metadata ໃສ່ໄຟລ໌ DNG ແລະ RAW ຕອນນີ້ຈະຖືກມອບໝາຍໃຫ້ ExifTool Backend ສະເໝີ."

#: core/app/views/stack/welcomepageview.cpp:108
#, kde-format
msgid "Metadata: optimize layout of Metadata Edit plugin for a better usability."
msgstr "Metadata: ປັບປຸງໂຄງສ້າງຂອງປລັກອິນແກ້ໄຂ Metadata ເພື່ອການໃຊ້ງານທີ່ດີຂຶ້ນ."

#: core/app/views/stack/welcomepageview.cpp:109
#, kde-format
msgid ""
"Metadata: add new options to save and load configuration profiles in Advanced Metadata Settings Panel."
msgstr "Metadata: ເພີ່ມຕົວເລືອກໃໝ່ໃນການບັນທຶກ ແລະ ໂຫຼດໂປຣໄຟລ໌ການຕັ້ງຄ່າໃນແຜງຕັ້ງຄ່າ Metadata ຂັ້ນສູງ."

#: core/app/views/stack/welcomepageview.cpp:110
#, kde-format
msgid ""
"Advanced Rename: add increment file counter to sequence numbering from with option [c] or [c,step]."
msgstr "ການປ່ຽນຊື່ຂັ້ນສູງ: ເພີ່ມຕົວນັບໄຟລ໌ທີ່ເພີ່ມຂຶ້ນໃສ່ການນັບລຳດັບດ້ວຍຕົວເລືອກ [c] ຫຼື [c,step]."

#: core/app/views/stack/welcomepageview.cpp:111
#, kde-format
msgid "Advanced Rename: add random text sequence numbering with option [r]."
msgstr "ການປ່ຽນຊື່ຂັ້ນສູງ: ເພີ່ມການນັບລຳດັບຂໍ້ຄວາມແບບສຸ່ມດ້ວຍຕົວເລືອກ [r]."

#: core/app/views/stack/welcomepageview.cpp:112
#, kde-format
msgid "Advanced Rename: add configurable first character for the unique modifier with {unique:n,c}."
msgstr "ການປ່ຽນຊື່ຂັ້ນສູງ: ເພີ່ມຕົວອັກສອນທຳອິດທີ່ສາມາດຕັ້ງຄ່າໄດ້ສຳລັບຕົວປ່ຽນທີ່ບໍ່ຊ້ຳກັນດ້ວຍ {unique:n,c}."

#: core/app/views/stack/welcomepageview.cpp:113
#, kde-format
msgid "Advanced Search: add search for items by number of face regions."
msgstr "ການຄົ້ນຫາຂັ້ນສູງ: ເພີ່ມການຄົ້ນຫາລາຍການໂດຍຈຳນວນພື້ນທີ່ໃບໜ້າ."

#: core/app/views/stack/welcomepageview.cpp:114
#, kde-format
msgid "Advanced Search: add search for items without face regions."
msgstr "ການຄົ້ນຫາຂັ້ນສູງ: ເພີ່ມການຄົ້ນຫາລາຍການທີ່ບໍ່ມີພື້ນທີ່ໃບໜ້າ."

#: core/app/views/stack/welcomepageview.cpp:115
#, kde-format
msgid "Collections: add support for cross-platform network paths."
msgstr "ຄໍເລັກຊັນ: ເພີ່ມການຮອງຮັບ path ເຄືອຂ່າຍແບບຂ້າມແພລັດຟອມ."

#: core/app/views/stack/welcomepageview.cpp:116
#, kde-format
msgid "Database: add support for SQLite WAL (Write-Ahead-Logging) mode."
msgstr "ຖານຂໍ້ມູນ: ເພີ່ມການຮອງຮັບໂໝດ SQLite WAL (Write-Ahead-Logging)."

#: core/app/views/stack/welcomepageview.cpp:117
#, kde-format
msgid "Add spell-checking support in caption text widget using KDE framework Sonnet component."
msgstr "ເພີ່ມການຮອງຮັບການກວດສອບການສະກົດຄຳໃນວິດເຈັດຂໍ້ຄວາມຄຳບັນຍາຍ ໂດຍໃຊ້ອົງປະກອບ Sonnet ຂອງເຟຣມເວີກ KDE."

#: core/app/views/stack/welcomepageview.cpp:118
#, kde-format
msgid "Add Spellcheck config panel in Settings/Miscellaneous for digiKam and Showfoto."
msgstr "ເພີ່ມແຜງຕັ້ງຄ່າການກວດສອບການສະກົດຄຳໃນ ການຕັ້ງຄ່າ/ເບັດຕະເລັດ ສຳລັບ digiKam ແລະ Showfoto."

#: core/app/views/stack/welcomepageview.cpp:119
#, kde-format
msgid "Add online translations support to Alternative Language text editor widget."
msgstr "ເພີ່ມການຮອງຮັບການແປພາສາອອນລາຍໃຫ້ກັບວິດເຈັດແກ້ໄຂຂໍ້ຄວາມພາສາທາງເລືອກ."

#: core/app/views/stack/welcomepageview.cpp:120
#, kde-format
msgid "Add Localize config panel in Settings/Miscellaneous for digiKam and Showfoto."
msgstr "ເພີ່ມແຜງຕັ້ງຄ່າ Localize ໃນ ການຕັ້ງຄ່າ/ເບັດຕະເລັດ ສຳລັບ digiKam ແລະ Showfoto."

#: core/app/views/stack/welcomepageview.cpp:121
#, kde-format
msgid "Add settings to list preferred alternative/translated languages in text edit widget."
msgstr "ເພີ່ມການຕັ້ງຄ່າເພື່ອສະແດງລາຍຊື່ພາສາທາງເລືອກ/ພາສາແປທີ່ຕ້ອງການໃນວິດເຈັດແກ້ໄຂຂໍ້ຄວາມ."

#: core/app/views/stack/welcomepageview.cpp:122
#, kde-format
msgid "Allow to use Global or Customized Image Quality Scanning settings everywhere."
msgstr "ອະນຸຍາດໃຫ້ໃຊ້ການຕັ້ງຄ່າການສະແກນຄຸນນະພາບຮູບພາບແບບ Global ຫຼື ແບບກຳນົດເອງໄດ້ທຸກບ່ອນ."

#: core/app/views/stack/welcomepageview.cpp:123
#, kde-format
msgid "Add Icon-View settings to customize Labels visibility over thumbnails."
msgstr "ເພີ່ມການຕັ້ງຄ່າ Icon-View ເພື່ອກຳນົດການເບິ່ງເຫັນປ້າຍກຳກັບເທິງຮູບຕົວຢ່າງ (thumbnails)."

#: core/app/views/stack/welcomepageview.cpp:124
#, kde-format
msgid "Add support for float16 (half float) images in the TIFF Loader."
msgstr "ເພີ່ມການຮອງຮັບຮູບພາບ float16 (half float) ໃນຕົວໂຫຼດ TIFF."

#: core/app/views/stack/welcomepageview.cpp:125
#, kde-format
msgid ""
"Add new maintenance tool to perform <a href=\"https://community.kde.org/GSoc/2022/StatusReports/"
"PhuocKhanhLe\">Aesthetic Detection to classify images using deep learning model</a>."
msgstr "ເພີ່ມເຄື່ອງມືບຳລຸງຮັກສາໃໝ່ເພື່ອປະຕິບັດ <a href=\"https://community.kde.org/GSoc/2022/StatusReports/PhuocKhanhLe\">ການກວດຈັບຄວາມງາມ ເພື່ອຈັດປະເພດຮູບພາບໂດຍໃຊ້ໂມເດວ deep learning</a>."

#: core/app/views/stack/welcomepageview.cpp:126
#, kde-format
msgid ""
"Add new tool <a href=\"https://community.kde.org/GSoC/2022/StatusReports/QuocHungTran\">to perform OCR "
"over scanned text</a>."
msgstr "ເພີ່ມເຄື່ອງມືໃໝ່ <a href=\"https://community.kde.org/GSoC/2022/StatusReports/QuocHungTran\">ເພື່ອປະຕິບັດ OCR ໃສ່ຂໍ້ຄວາມທີ່ສະແກນມາ</a>."

#: core/app/views/stack/welcomepageview.cpp:127
#, kde-format
msgid "Queue Manager: add new tool to assign pick label automatically by parsing image quality."
msgstr "Queue Manager: ເພີ່ມເຄື່ອງມືໃໝ່ເພື່ອກຳນົດປ້າຍກຳກັບການເລືອກ (pick label) ໂດຍອັດຕະໂນມັດ ໂດຍການວິເຄາະຄຸນນະພາບຮູບພາບ."

#: core/app/views/stack/welcomepageview.cpp:128
#, kde-format
msgid "Queue Manager: add new tool to assign rating, pick, and color labels in batch."
msgstr "Queue Manager: ເພີ່ມເຄື່ອງມືໃໝ່ເພື່ອກຳນົດຄະແນນ, ການເລືອກ ແລະ ປ້າຍກຳກັບສີແບບເປັນກຸ່ມ."

#: core/app/views/stack/welcomepageview.cpp:129
#, kde-format
msgid "Queue Manager: add new tool to assign titles and captions in batch."
msgstr "Queue Manager: ເພີ່ມເຄື່ອງມືໃໝ່ເພື່ອກຳນົດຫົວຂໍ້ ແລະ ຄຳບັນຍາຍແບບເປັນກຸ່ມ."

#: core/app/views/stack/welcomepageview.cpp:130
#, kde-format
msgid "Queue Manager: add new tool to run G'MIC filters in batch."
msgstr "Queue Manager: ເພີ່ມເຄື່ອງມືໃໝ່ເພື່ອລັນຟິວເຕີ G'MIC ແບບເປັນກຸ່ມ."

#: core/app/views/stack/welcomepageview.cpp:131
#, kde-format
msgid "Queue Manager: add new tool to perform auto-rotation based on content analysis using DNN."
msgstr "Queue Manager: ເພີ່ມເຄື່ອງມືໃໝ່ເພື່ອໝຸນຮູບພາບອັດຕະໂນມັດໂດຍອີງໃສ່ການວິເຄາະເນື້ອຫາໂດຍໃຊ້ DNN."

#: core/app/views/stack/welcomepageview.cpp:132
#, kde-format
msgid ""
"Documentation: <a href=\"https://docs.digikam.org/en/index.html\">Rewrite handbook</a> from DocBook to "
"Sphinx/ReStructuredText framework."
msgstr "ເອກະສານ: <a href=\"https://docs.digikam.org/en/index.html\">ຂຽນຄູ່ມືໃໝ່</a> ຈາກ DocBook ມາເປັນເຟຣມເວີກ Sphinx/ReStructuredText."

#: core/app/views/stack/welcomepageview.cpp:133
#, kde-format
msgid ""
"Add new maintenance and Queue manager tools to assign tag automatically to images using deep learning "
"neural network engine.<a href=\"https://community.kde.org/GSoc/2023/StatusReports/"
"QuocHungTran#Add_Automatic_Tags_Assignment_Tools_and_Improve_Face_Recognition_Engine_for_digiKam\">See "
"this GoSC-2023 report for details.</a>"
msgstr "ເພີ່ມເຄື່ອງມືບຳລຸງຮັກສາ ແລະ Queue Manager ໃໝ່ເພື່ອກຳນົດແທັກໃຫ້ຮູບພາບອັດຕະໂນມັດ ໂດຍໃຊ້ deep learning neural network engine. <a href=\"https://community.kde.org/GSoc/2023/StatusReports/QuocHungTran#Add_Automatic_Tags_Assignment_Tools_and_Improve_Face_Recognition_Engine_for_digiKam\">ເບິ່ງລາຍງານ GoSC-2023 ນີ້ສຳລັບລາຍລະອຽດ.</a>"

#: core/app/views/stack/welcomepageview.cpp:135
#, kde-format
msgid ""
"Update G'MIC-Qt tool to last version 3.5.0 and finalize macOS port and improve stability of plugin."
msgstr "ອັບເດດເຄື່ອງມື G'MIC-Qt ເປັນເວີຊັນລ່າສຸດ 3.5.0 ແລະ ເຮັດໃຫ້ພອດ macOS ສົມບູນ ແລະ ປັບປຸງຄວາມສະຖຽນຂອງປລັກອິນ."

#: core/app/views/stack/welcomepageview.cpp:136
#, kde-format
msgid "New G'MIC generic plugin working as layer mode from a stack of images."
msgstr "ປລັກອິນທົ່ວໄປ G'MIC ໃໝ່ທີ່ເຮັດວຽກເປັນໂໝດເລເຢີຈາກ stack ຂອງຮູບພາບ."

#: core/app/views/stack/welcomepageview.cpp:137
#, kde-format
msgid "Update Adobe DNG SDK to last 1.7.1 with JPEG-XL compression support."
msgstr "ອັບເດດ Adobe DNG SDK ເປັນເວີຊັນລ່າສຸດ 1.7.1 ພ້ອມຮອງຮັບການບີບອັດ JPEG-XL."

#: core/app/views/stack/welcomepageview.cpp:138
#, kde-format
msgid ""
"More compact icon-view thumbnails by using a simple horizontal line instead a frame to render Color "
"Labels."
msgstr "ຮູບຕົວຢ່າງ icon-view ທີ່ກະທັດຮັດຂຶ້ນ ໂດຍການໃຊ້ເສັ້ນນອນງ່າຍໆແທນກອບເພື່ອສະແດງປ້າຍກຳກັບສີ."

#: core/app/views/stack/welcomepageview.cpp:140
#, kde-format
msgid ""
"Adding YuNet DNN model to process faces detection and replace older SSD model. Adding Sface DNN model "
"to process face recognition and replace older OpenFace model. Both are faster and requires less memory "
"at run-time with better faces-management results."
msgstr "ເພີ່ມໂມເດວ YuNet DNN ເພື່ອປະມວນຜົນການກວດຈັບໃບໜ້າ ແລະ ປ່ຽນແທນໂມເດວ SSD ເກົ່າ. ເພີ່ມໂມເດວ Sface DNN ເພື່ອປະມວນຜົນການຈົດຈຳໃບໜ້າ ແລະ ປ່ຽນແທນໂມເດວ OpenFace ເກົ່າ. ທັງສອງໄວກວ່າ ແລະ ໃຊ້ໜ່ວຍຄວາມຈຳໜ້ອຍກວ່າໃນເວລາເຮັດວຽກ ພ້ອມຜົນການຈັດການໃບໜ້າທີ່ດີຂຶ້ນ."

#: core/app/views/stack/welcomepageview.cpp:143
#, kde-format
msgid "New option to scan image for recognize faces at startup."
msgstr "ຕົວເລືອກໃໝ່ໃນການສະແກນຮູບພາບເພື່ອຈົດຈຳໃບໜ້າຕອນເລີ່ມຕົ້ນ."

#: core/app/views/stack/welcomepageview.cpp:144
#, kde-format
msgid "New option to turn on/off OpenCL support with face management."
msgstr "ຕົວເລືອກໃໝ່ໃນການເປີດ/ປິດ ການຮອງຮັບ OpenCL ກັບການຈັດການໃບໜ້າ."

#: core/app/views/stack/welcomepageview.cpp:145
#, kde-format
msgid "Update internal RAW engine to last Libraw snapshot 2025-05-12."
msgstr "ອັບເດດ RAW engine ພາຍໃນເປັນ Libraw snapshot ລ່າສຸດ 2025-05-12."

#: core/app/views/stack/welcomepageview.cpp:146
#, kde-format
msgid ""
"New RAW camera supported: Canon EOS R6 Mark II, EOS R8, EOS R50, EOS R100, EOS Ra.Fujifilm GFX100-II, "
"X-T5, X-S20, X-H2, X-H2S.Hasselblad X2D-100c.Leica Q3, M11 Monochrom.Nikon Z30, Z8.OM Digital "
"OM-5.Panasonic DC-G9 II, DC-ZS200D / ZS220D, DC-TZ200D / TZ202D / TZ220D, DC-S5-II, DC-GH6.Sony A7C-"
"II, A7CR, ILCE-6700, ZV-1M2, ZV-E1, ILCE-7RM5 (A7R-V), ILME-FX30, DSC-HX95, A1.Multiple DJI and Skydio "
"drones.Multiple smartphones with DNG format recorded."
msgstr "ຮອງຮັບກ້ອງ RAW ໃໝ່: Canon EOS R6 Mark II, EOS R8, EOS R50, EOS R100, EOS Ra.Fujifilm GFX100-II, X-T5, X-S20, X-H2, X-H2S.Hasselblad X2D-100c.Leica Q3, M11 Monochrom.Nikon Z30, Z8.OM Digital OM-5.Panasonic DC-G9 II, DC-ZS200D / ZS220D, DC-TZ200D / TZ202D / TZ220D, DC-S5-II, DC-GH6.Sony A7C-II, A7CR, ILCE-6700, ZV-1M2, ZV-E1, ILCE-7RM5 (A7R-V), ILME-FX30, DSC-HX95, A1. ໂດຣນ DJI ແລະ Skydio ຫຼາຍລຸ້ນ. ໂທລະສັບສະຫຼາດຫຼາຍລຸ້ນທີ່ບັນທຶກຮູບແບບ DNG."

