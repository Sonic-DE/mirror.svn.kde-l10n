#: core/dplugins/bqm/convert/converttoavif/converttoavifplugin.cpp:57
#, kde-format
msgctxt "@info"
msgid "A tool to convert images to AVIF format"
msgstr "ເຄື່ອງມືສຳລັບປ່ຽນຮູບພາບເປັນຮູບແບບ AVIF"

#: core/dplugins/bqm/convert/converttoavif/converttoavifplugin.cpp:62
#, kde-kuit-format
msgctxt "@info"
msgid ""
"<para>This Batch Queue Manager tool can convert images data to AVIF format.</para><para>AV1 Image File "
"Format is an image file format specification for storing images or image sequences compressed with AV1 "
"in the ISOBMFF container format.</para><para>See details about this format from <link url='https://"
"en.wikipedia.org/wiki/AVIF'>this page</link>.</para>"
msgstr "<para>ເຄື່ອງມື Batch Queue Manager ນີ້ສາມາດປ່ຽນຂໍ້ມູນຮູບພາບເປັນຮູບແບບ AVIF ໄດ້.</para><para>AV1 Image File Format ແມ່ນຂໍ້ກຳນົດຮູບແບບໄຟລ໌ຮູບພາບສຳລັບຈັດເກັບຮູບພາບ ຫຼື ລຳດັບຮູບພາບທີ່ຖືກບີບອັດດ້ວຍ AV1 ໃນຮູບແບບ container ISOBMFF.</para><para>ເບິ່ງລາຍລະອຽດກ່ຽວກັບຮູບແບບນີ້ຈາກ <link url='https://en.wikipedia.org/wiki/AVIF'>ໜ້ານີ້</link>.</para>"

#: core/dplugins/bqm/convert/converttodng/converttodngplugin.cpp:42
#, kde-format
msgctxt "@title"
msgid "Convert RAW To DNG"
msgstr "ປ່ຽນ RAW ເປັນ DNG"

#: core/dplugins/bqm/convert/converttodng/converttodngplugin.cpp:57
#, kde-format
