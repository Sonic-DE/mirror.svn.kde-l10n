#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:220
#, kde-format
msgid "<b>No Lens Filter</b>:<p>Do not apply a lens filter when rendering the image.</p>"
msgstr "<b>ບໍ່ມີຟິວເຕີເລນ</b>:<p>ບໍ່ນຳໃຊ້ຟິວເຕີເລນເມື່ອສະແດງຜົນຮູບພາບ.</p>"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:223 core/libs/dimg/filters/bw/bwsepiasettings.cpp:309
#, kde-format
msgid "Green Filter"
msgstr "ຟິວເຕີສີຂຽວ"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:224
#, kde-format
msgid ""
"<b>Black & White with Green Filter</b>:<p>Simulate black and white film exposure using a green filter. "
"This is useful for all scenic shoots, especially portraits photographed against the sky.</p>"
msgstr ""
"<b>ຂາວດຳພ້ອມຟິວເຕີສີຂຽວ</b>:<p>ຈຳລອງການເປີດຮັບແສງຟິມຂາວດຳໂດຍໃຊ້ຟິວເຕີສີຂຽວ. "
"ອັນນີ້ເປັນປະໂຫຍດສຳລັບການຖ່າຍພາບທິວທັດທັງໝົດ, ໂດຍສະເພາະຮູບຄົນທີ່ຖ່າຍກັບທ້ອງຟ້າ.</p>"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:229
#, kde-format
msgid "Orange Filter"
msgstr "ຟິວເຕີສີສົ້ມ"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:230
#, kde-format
msgid ""
"<b>Black & White with Orange Filter</b>:<p>Simulate black and white film exposure using an orange "
"filter. This will enhance landscapes, marine scenes and aerial photography.</p>"
msgstr ""
"<b>ຂາວດຳພ້ອມຟິວເຕີສີສົ້ມ</b>:<p>ຈຳລອງການເປີດຮັບແສງຟິມຂາວດຳໂດຍໃຊ້ຟິວເຕີສີສົ້ມ. "
"ນີ້ຈະປັບປຸງພູມສັນຖານ, ສາກທາງທະເລ ແລະ ການຖ່າຍຮູບທາງອາກາດ.</p>"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:235
#, kde-format
msgid "Red Filter"
msgstr "ຟິວເຕີສີແດງ"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:236
#, kde-format
msgid ""
"<b>Black & White with Red Filter</b>:<p>Simulate black and white film exposure using a red filter. "
"This creates dramatic sky effects, and simulates moonlight scenes in the daytime.</p>"
msgstr ""
"<b>ຂາວດຳພ້ອມຟິວເຕີສີແດງ</b>:<p>ຈຳລອງການເປີດຮັບແສງຟິມຂາວດຳໂດຍໃຊ້ຟິວເຕີສີແດງ. "
"ນີ້ສ້າງຜົນກະທົບທ້ອງຟ້າທີ່ໜ້າຕື່ນເຕັ້ນ, ແລະ ຈຳລອງສາກແສງຈັນໃນເວລາກາງເວັນ.</p>"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:241
#, kde-format
msgid "Yellow Filter"
msgstr "ຟິວເຕີສີເຫຼືອງ"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:242
#, kde-format
msgid ""
"<b>Black & White with Yellow Filter</b>:<p>Simulate black and white film exposure using a yellow "
"filter. This has the most natural tonal correction, and improves contrast. Ideal for landscapes.</p>"
msgstr ""
"<b>ຂາວດຳພ້ອມຟິວເຕີສີເຫຼືອງ</b>:<p>ຈຳລອງການເປີດຮັບແສງຟິມຂາວດຳໂດຍໃຊ້ຟິວເຕີສີເຫຼືອງ. "
"ນີ້ມີການແກ້ໄຂໂທນສີທີ່ເປັນທຳມະຊາດທີ່ສຸດ, ແລະ ປັບປຸງຄວາມຄົມຊັດ. ເໝາະສຳລັບພູມສັນຖານ.</p>"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:247
#, kde-format
msgid "Yellow-Green Filter"
msgstr "ຟິວເຕີສີເຫຼືອງ-ຂຽວ"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:248
#, kde-format
msgid ""
"<b>Black & White with Yellow-Green Filter</b>:<p>Simulate black and white film exposure using a yellow-"
"green filter. A yellow-green filter is highly effective for outdoor portraits because red is rendered "
"dark while green appears lighter. Great for correcting skin tones, bringing out facial expressions in "
"close-ups and emphasizing the feeling of liveliness. This filter is highly effective for indoor "
"portraits under tungsten lighting.</p>"
msgstr ""
"<b>ຂາວດຳພ້ອມຟິວເຕີສີເຫຼືອງ-ຂຽວ</b>:<p>ຈຳລອງການເປີດຮັບແສງຟິມຂາວດຳໂດຍໃຊ້ຟິວເຕີສີເຫຼືອງ-"
"ຂຽວ. ຟິວເຕີສີເຫຼືອງ-ຂຽວມີປະສິດທິພາບສູງສຳລັບຮູບຄົນກາງແຈ້ງ ເພາະສີແດງຈະຖືກສະແດງຜົນເປັນສີເຂັ້ມ "
"ໃນຂະນະທີ່ສີຂຽວປະກົດວ່າອ່ອນກວ່າ. ດີສຳລັບການແກ້ໄຂໂທນສີຜິວ, "
"ເນັ້ນການສະແດງອອກຂອງໃບໜ້າໃນການຖ່າຍໄລຍະໃກ້ ແລະ ເນັ້ນຄວາມຮູ້ສຶກຂອງຊີວິດຊີວາ. "
"ຟິວເຕີນີ້ມີປະສິດທິພາບສູງສຳລັບຮູບຄົນໃນຮົ່ມພາຍໃຕ້ແສງໄຟ tungsten.</p>"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:255
#, kde-format
msgid "Blue Filter"
msgstr "ຟິວເຕີສີຟ້າ"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:256
#, kde-format
msgid ""
"<b>Black & White with Blue Filter</b>:<p>Simulate black and white film exposure using a blue filter. "
"This accentuates haze and fog. Used for dye transfer and contrast effects.</p>"
msgstr ""
"<b>ຂາວດຳພ້ອມຟິວເຕີສີຟ້າ</b>:<p>ຈຳລອງການເປີດຮັບແສງຟິມຂາວດຳໂດຍໃຊ້ຟິວເຕີສີຟ້າ. "
"ນີ້ເນັ້ນໝອກ ແລະ ຄວັນ. ໃຊ້ສຳລັບການຖ່າຍໂອນສີ ແລະ ຜົນກະທົບຄວາມຄົມຊັດ.</p>"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:261
#, kde-format
msgid "Strength:"
msgstr "ຄວາມແຮງ:"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:267
#, kde-format
msgid "Here, set the strength adjustment of the lens filter."
msgstr "ຢູ່ນີ້, ກຳນົດການປັບຄວາມແຮງຂອງຟິວເຕີເລນ."

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:278
#, kde-format
msgid "No Tone Filter"
msgstr "ບໍ່ມີຟິວເຕີໂທນສີ"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:279
#, kde-format
msgid "<b>No Tone Filter</b>:<p>Do not apply a tone filter to the image.</p>"
msgstr "<b>ບໍ່ມີຟິວເຕີໂທນສີ</b>:<p>ບໍ່ນຳໃຊ້ຟິວເຕີໂທນສີກັບຮູບພາບ.</p>"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:282
#, kde-format
msgid "Sepia Filter"
msgstr "ຟິວເຕີຊີເປຍ"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:283
#, kde-format
msgid ""
"<b>Black & White with Sepia Tone</b>:<p>Gives a warm highlight and mid-tone while adding a bit of "
"coolness to the shadows - very similar to the process of bleaching a print and re-developing in a "
"sepia toner.</p>"
msgstr ""
"<b>ຂາວດຳພ້ອມໂທນຊີເປຍ</b>:<p>ໃຫ້ໄຮໄລ້ທີ່ອົບອຸ່ນ ແລະ ໂທນກາງ ໃນຂະນະທີ່ເພີ່ມຄວາມເຢັນເລັກນ້ອຍໃຫ້ກັບເງົາ - "
"ຄ້າຍຄືກັນຫຼາຍກັບຂັ້ນຕອນການຟອກສີຮູບ ແລະ ລ້າງໃໝ່ໃນໂທນເນີຊີເປຍ.</p>"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:288
#, kde-format
msgid "Brown Filter"
msgstr "ຟິວເຕີສີນ້ຳຕານ"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:289
#, kde-format
msgid ""
"<b>Black & White with Brown Tone</b>:<p>This filter is more neutral than the Sepia Tone filter.</p>"
msgstr ""
"<b>ຂາວດຳພ້ອມໂທນສີນ້ຳຕານ</b>:<p>ຟິວເຕີນີ້ເປັນກາງຫຼາຍກວ່າຟິວເຕີໂທນຊີເປຍ.</p>"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:293
#, kde-format
msgid "Cold Filter"
msgstr "ຟິວເຕີເຢັນ"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:294
#, kde-format
msgid ""
"<b>Black & White with Cold Tone</b>:<p>Start subtly and replicate printing on a cold tone black and "
"white paper such as a bromide enlarging paper.</p>"
msgstr ""
"<b>ຂາວດຳພ້ອມໂທນເຢັນ</b>:<p>ເລີ່ມຕົ້ນຢ່າງອ່ອນໂຍນ ແລະ ຈຳລອງການພິມໃສ່ເຈ້ຍຂາວດຳໂທນເຢັນ ເຊັ່ນ "
"ເຈ້ຍຂະຫຍາຍ bromide.</p>"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:299
#, kde-format
msgid "Selenium Filter"
msgstr "ຟິວເຕີ Selenium"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:300
#, kde-format
msgid ""
"<b>Black & White with Selenium Tone</b>:<p>This effect replicates traditional selenium chemical toning "
"done in the darkroom.</p>"
msgstr ""
"<b>ຂາວດຳພ້ອມໂທນ Selenium</b>:<p>ຜົນກະທົບນີ້ຈຳລອງການປັບໂທນສີເຄມີ selenium "
"ແບບດັ້ງເດີມທີ່ເຮັດໃນຫ້ອງມືດ.</p>"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:304
#, kde-format
msgid "Platinum Filter"
msgstr "ຟິວເຕີ Platinum"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:305
#, kde-format
msgid ""
"<b>Black & White with Platinum Tone</b>:<p>This effect replicates traditional platinum chemical toning "
"done in the darkroom.</p>"
msgstr ""
"<b>ຂາວດຳພ້ອມໂທນ Platinum</b>:<p>ຜົນກະທົບນີ້ຈຳລອງການປັບໂທນສີເຄມີ platinum "
"ແບບດັ້ງເດີມທີ່ເຮັດໃນຫ້ອງມືດ.</p>"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:310
#, kde-format
msgid "<b>Black & White with greenish tint</b>:<p>This effect is also known as Verdante.</p>"
msgstr "<b>ຂາວດຳພ້ອມສີຂຽວອ່ອນ</b>:<p>ຜົນກະທົບນີ້ຍັງເປັນທີ່ຮູ້ຈັກໃນຊື່ Verdante.</p>"

