#: ktorrent/ktorrent.notifyrc:4
msgctxt "Comment"
msgid "KTorrent"
msgstr "KTorrent"

#: ktorrent/ktorrent.notifyrc:67
msgctxt "Name"
msgid "Torrent silently opened"
msgstr "ເປີດທໍເຣັ້ນແບບງຽບໆ"

#: ktorrent/ktorrent.notifyrc:117
msgctxt "Name"
msgid "Torrent stopped by error"
msgstr "ທໍເຣັ້ນຖືກຢຸດເນື່ອງຈາກມີຂໍ້ຜິດພາດ"

#: ktorrent/ktorrent.notifyrc:174
msgctxt "Name"
msgid "Torrent has finished downloading"
msgstr "ທໍເຣັ້ນດາວໂຫລດສຳເລັດແລ້ວ"

#: ktorrent/ktorrent.notifyrc:231
msgctxt "Name"
msgid "Maximum share ratio reached"
msgstr "ຮອດອັດຕາການແບ່ງປັນສູງສຸດແລ້ວ"

#: ktorrent/ktorrent.notifyrc:288
msgctxt "Name"
msgid "Maximum seed time reached"
msgstr "ຮອດເວລາປ່ອຍສູງສຸດແລ້ວ"

#: ktorrent/ktorrent.notifyrc:345
msgctxt "Name"
msgid "Disk space is running low"
msgstr "ເນື້ອທີ່ດິດໃກ້ຈະໝົດ"

#: ktorrent/ktorrent.notifyrc:402
msgctxt "Name"
msgid "Corrupted data has been found"
msgstr "ພົບຂໍ້ມູນເສຍຫາຍ"

#: ktorrent/ktorrent.notifyrc:460
msgctxt "Name"
msgid "Torrent cannot be enqueued"
msgstr "ບໍ່ສາມາດຈັດຄິວທໍເຣັ້ນໄດ້"

#: ktorrent/ktorrent.notifyrc:517
msgctxt "Name"
msgid "Torrent cannot be started"
msgstr "ບໍ່ສາມາດເລີ່ມທໍເຣັ້ນໄດ້"

#: ktorrent/ktorrent.notifyrc:574
msgctxt "Name"
msgid "Torrent cannot be loaded silently"
msgstr "ບໍ່ສາມາດໂຫລດທໍເຣັ້ນແບບງຽບໆໄດ້"

#: ktorrent/ktorrent.notifyrc:631
msgctxt "Name"
msgid "DHT is not enabled"
msgstr "ບໍ່ໄດ້ເປີດໃຊ້ງານ DHT"

#: ktorrent/ktorrent.notifyrc:686
msgctxt "Name"
msgid "Event generated by plugin"
msgstr "ເຫດການຖືກສ້າງຂຶ້ນໂດຍປລັກອິນ"

#: ktorrent/ktorrent.notifyrc:738
msgctxt "Name"
msgid "Magnet link download started"
msgstr "ເລີ່ມດາວໂຫລດລິງກ໌ Magnet ແລ້ວ"

#: ktorrent/ktorrent.notifyrc:789
msgctxt "Name"
msgid "Magnet link copied to clipboard"
msgstr "ກັອບປີ້ລິງກ໌ Magnet ໄປໃສ່ຄລິບບອດແລ້ວ"

#: ktorrent/org.kde.ktorrent.desktop:2
msgctxt "Name"
msgid "KTorrent"
msgstr "KTorrent"

#: ktorrent/org.kde.ktorrent.desktop:66
msgctxt "GenericName"
msgid "BitTorrent Client"
msgstr "ໂປຣແກຣມ BitTorrent"

#: ktorrent/org.kde.ktorrent.desktop:137
msgctxt "Comment"
msgid "A BitTorrent program by KDE"
msgstr "ໂປຣແກຣມ BitTorrent ໂດຍ KDE"
