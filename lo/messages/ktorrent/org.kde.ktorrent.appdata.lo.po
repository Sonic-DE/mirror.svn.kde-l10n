#. (itstool) path: component/name
#: org.kde.ktorrent.appdata.xml:10
msgid "KTorrent"
msgstr "KTorrent"

#. (itstool) path: component/summary
#: org.kde.ktorrent.appdata.xml:11
msgid "BitTorrent Client"
msgstr "ໂປຣແກຣມລູກຂ່າຍ BitTorrent"

#. (itstool) path: description/p
#: org.kde.ktorrent.appdata.xml:13
msgid ""
"KTorrent is a BitTorrent application by KDE which allows you to download "
"files using the BitTorrent protocol. It enables you to run multiple torrents "
"at the same time and comes with extended features to make it a full-featured "
"client for BitTorrent."
msgstr "KTorrent ແມ່ນໂປຣແກຣມ BitTorrent ໂດຍ KDE ເຊິ່ງຊ່ວຍໃຫ້ທ່ານສາມາດດາວໂຫຼດໄຟລ໌ໂດຍໃຊ້ໂປຣໂຕຄໍ BitTorrent ໄດ້. ມັນຊ່ວຍໃຫ້ທ່ານແລ່ນທໍເຣັ້ນໄດ້ຫຼາຍອັນໃນເວລາດຽວກັນ ແລະ ມາພ້ອມກັບຄຸນສົມບັດເສີມຕ່າງໆ ເພື່ອໃຫ້ມັນເປັນໂປຣແກຣມລູກຂ່າຍທີ່ຄົບເຄື່ອງສຳລັບ BitTorrent."

#. (itstool) path: description/p
#: org.kde.ktorrent.appdata.xml:18
msgid "Features:"
msgstr "ຄຸນສົມບັດ:"

#. (itstool) path: ul/li
#: org.kde.ktorrent.appdata.xml:20
msgid "Queuing of torrents"
msgstr "ການຈັດຄິວທໍເຣັ້ນ"

#. (itstool) path: ul/li
#: org.kde.ktorrent.appdata.xml:21
msgid "Global and per torrent speed limits"
msgstr "ການຈຳກັດຄວາມໄວແບບລວມ ແລະ ແບບແຕ່ລະທໍເຣັ້ນ"

#. (itstool) path: ul/li
#: org.kde.ktorrent.appdata.xml:22
msgid "Previewing of certain file types, build in (video and audio)"
msgstr "ການເບິ່ງຕົວຢ່າງໄຟລ໌ບາງປະເພດທີ່ມີມາໃນໂຕ (ວິດີໂອ ແລະ ສຽງ)"

#. (itstool) path: ul/li
#: org.kde.ktorrent.appdata.xml:23
msgid "Importing of partially or fully downloaded files"
msgstr "ການນຳເຂົ້າໄຟລ໌ທີ່ດາວໂຫຼດແລ້ວບາງສ່ວນ ຫຼື ຄົບຖ້ວນ"

#. (itstool) path: ul/li
#: org.kde.ktorrent.appdata.xml:24
msgid "File prioritization for multi-file torrents"
msgstr "ການຈັດຄວາມສຳຄັນຂອງໄຟລ໌ສຳລັບທໍເຣັ້ນທີ່ມີຫຼາຍໄຟລ໌"

#. (itstool) path: ul/li
#: org.kde.ktorrent.appdata.xml:25
msgid "Selective downloading for multi-file torrents"
msgstr "ການເລືອກດາວໂຫຼດສຳລັບທໍເຣັ້ນທີ່ມີຫຼາຍໄຟລ໌"

#. (itstool) path: ul/li
#: org.kde.ktorrent.appdata.xml:26
msgid ""
"Kick/ban peers with an additional IP Filter dialog for list/edit purposes"
msgstr "ເຕະ/ແບນ peer ດ້ວຍກ່ອງໂຕ້ຕອບການກັ່ນຕອງ IP ເພີ່ມເຕີມ ສຳລັບຈຸດປະສົງໃນການສະແດງລາຍຊື່/ແກ້ໄຂ"

#. (itstool) path: ul/li
#: org.kde.ktorrent.appdata.xml:27
msgid "UDP tracker support"
msgstr "ຮອງຮັບ UDP tracker"

#. (itstool) path: ul/li
#: org.kde.ktorrent.appdata.xml:28
msgid "Support for private trackers and torrents"
msgstr "ຮອງຮັບ tracker ແລະ ທໍເຣັ້ນສ່ວນຕົວ"

#. (itstool) path: ul/li
#: org.kde.ktorrent.appdata.xml:29
msgid "Support for µTorrent's peer exchange"
msgstr "ຮອງຮັບການແລກປ່ຽນ peer ຂອງ µTorrent"

#. (itstool) path: ul/li
#: org.kde.ktorrent.appdata.xml:30
msgid "Support for protocol encryption (compatible with Azureus)"
msgstr "ຮອງຮັບການເຂົ້າລະຫັດໂປຣໂຕຄໍ (ໃຊ້ຮ່ວມກັບ Azureus ໄດ້)"

#. (itstool) path: ul/li
#: org.kde.ktorrent.appdata.xml:31
msgid "Support for creating trackerless torrents"
msgstr "ຮອງຮັບການສ້າງທໍເຣັ້ນແບບບໍ່ມີ tracker"

#. (itstool) path: ul/li
#: org.kde.ktorrent.appdata.xml:32
msgid "Support for distributed hash tables (DHT, the Mainline version)"
msgstr "ຮອງຮັບຕາຕະລາງແຮຊແບບກະຈາຍ (DHT, ເວີຊັນ Mainline)"

#. (itstool) path: ul/li
#: org.kde.ktorrent.appdata.xml:33
msgid ""
"Support for UPnP to automatically forward ports on a LAN with dynamic "
"assigned hosts"
msgstr "ຮອງຮັບ UPnP ເພື່ອສົ່ງຕໍ່ພອດໂດຍອັດຕະໂນມັດໃນ LAN ທີ່ມີໂຮສທີ່ຖືກກຳນົດແບບໄດນາມິກ"

#. (itstool) path: ul/li
#: org.kde.ktorrent.appdata.xml:34
msgid "Support for webseeds"
msgstr "ຮອງຮັບ webseeds"

#. (itstool) path: ul/li
#: org.kde.ktorrent.appdata.xml:35
msgid "System tray integration"
msgstr "ການເຊື່ອມໂຍງກັບຖາດລະບົບ (System tray)"

#. (itstool) path: ul/li
#: org.kde.ktorrent.appdata.xml:36
msgid "Tracker authentication support"
msgstr "ຮອງຮັບການຢືນຢັນຕົວຕົນກັບ tracker"

#. (itstool) path: ul/li
#: org.kde.ktorrent.appdata.xml:37
msgid "Connection through a proxy"
msgstr "ການເຊື່ອມຕໍ່ຜ່ານ proxy"

#. (itstool) path: description/p
#: org.kde.ktorrent.appdata.xml:39
msgid ""
"In addition to the built-in functionalities, there are some plugins "
"available for KTorrent."
msgstr "ນອກເໜືອໄປຈາກຟັງຊັນທີ່ມີມາໃນໂຕແລ້ວ, ຍັງມີປັລກອິນຈຳນວນໜຶ່ງສຳລັບ KTorrent."
