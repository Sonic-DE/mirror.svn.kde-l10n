#: faces/systemmonitor-faces.knsrc:2
msgctxt "Name"
msgid "System monitor Sensor Display Styles"
msgstr "Estils de visualització del sensor al monitor del sistema"

#: faces/systemmonitor-presets.knsrc:2
msgctxt "Name"
msgid "System monitor Sensor Presets"
msgstr "Valors predefinits del sensor al monitor del sistema"

#: processcore/actions.actions:2
msgctxt "Name"
msgid "KSysGuard"
msgstr "KSysGuard"

#: processcore/actions.actions:82
msgctxt "Name"
msgid "Kill or stop etc a process"
msgstr "Mata o para un procés"

#: processcore/actions.actions:148
msgctxt "Description"
msgid "Sends a given signal to a given process"
msgstr "Envia un senyal determinat a un procés indicat"

#: processcore/actions.actions:218
msgctxt "Name"
msgid "Change the priority of a process"
msgstr "Canvia la prioritat d'un procés"

#: processcore/actions.actions:286
msgctxt "Description"
msgid "Change the niceness of a given process"
msgstr "Canvia la prioritat «niceness» d'un procés indicat"

#: processcore/actions.actions:355
msgctxt "Name"
msgid "Change IO Scheduler and priority"
msgstr "Canvia el planificador d'E/S i la prioritat"

#: processcore/actions.actions:420
msgctxt "Description"
msgid "Change how the read and writes of a given process are prioritized"
msgstr ""
"Canvia com es prioritzen les lectures i les escriptures d'un procés indicat"

#: processcore/actions.actions:487
msgctxt "Name"
msgid "Change CPU Scheduler and priority"
msgstr "Canvia el planificador de la CPU i la prioritat"

#: processcore/actions.actions:552
msgctxt "Description"
msgid ""
"Change which CPU scheduler is to schedule the running of a given process"
msgstr ""
"Canvia el planificador de la CPU que planificarà l'execució d'un procés "
"indicat"
