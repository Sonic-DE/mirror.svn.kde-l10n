#: kaccess/kaccess.desktop:3
msgctxt "Name"
msgid "Accessibility"
msgstr "Accessibilitat"

#: kaccess/kaccess.notifyrc:3
msgctxt "Comment"
msgid "Accessibility"
msgstr "Accessibilitat"

#: kaccess/kaccess.notifyrc:99
msgctxt "Name"
msgid "A modifier key has become active"
msgstr "Alguna tecla modificadora ha esdevingut activa"

#: kaccess/kaccess.notifyrc:180
msgctxt "Comment"
msgid ""
"A modifier key (e.g. Shift or Ctrl) has changed its state and is now active"
msgstr ""
"Ha canviat l'estat d'una tecla modificadora (p. ex., «Majús» o «Ctrl») i ara "
"està activa"

#: kaccess/kaccess.notifyrc:260
msgctxt "Name"
msgid "A modifier key has become inactive"
msgstr "Alguna tecla modificadora ha esdevingut inactiva"

#: kaccess/kaccess.notifyrc:341
msgctxt "Comment"
msgid ""
"A modifier key (e.g. Shift or Ctrl) has changed its state and is now inactive"
msgstr ""
"Ha canviat l'estat d'una tecla modificadora (p. ex., «Majús» o «Ctrl») i ara "
"està inactiva"

#: kaccess/kaccess.notifyrc:421
msgctxt "Name"
msgid "A modifier key has been locked"
msgstr "S'ha fixat alguna tecla modificadora"

#: kaccess/kaccess.notifyrc:502
msgctxt "Comment"
msgid ""
"A modifier key (e.g. Shift or Ctrl) has been locked and is now active for "
"all of the following keypresses"
msgstr ""
"S'ha fixat alguna tecla modificadora (p. ex., «Majús» o «Ctrl») i ara està "
"activa per a totes les tecles que es premen a continuació"

#: kaccess/kaccess.notifyrc:582
msgctxt "Name"
msgid "A lock key has been activated"
msgstr "S'ha activat alguna tecla de fixació"

#: kaccess/kaccess.notifyrc:663
msgctxt "Comment"
msgid ""
"A lock key (e.g. Caps Lock or Num Lock) has changed its state and is now "
"active"
msgstr ""
"Alguna tecla de fixació (p. ex., «Bloq Majús» o «Bloq Núm») ha canviat el "
"seu estat i ara està activa"

#: kaccess/kaccess.notifyrc:743
msgctxt "Name"
msgid "A lock key has been deactivated"
msgstr "S'ha desactivat alguna tecla de fixació"

#: kaccess/kaccess.notifyrc:824
msgctxt "Comment"
msgid ""
"A lock key (e.g. Caps Lock or Num Lock) has changed its state and is now "
"inactive"
msgstr ""
"Alguna tecla de fixació (p. ex., «Bloq Majús» o «Bloq Núm») ha canviat el "
"seu estat i ara està inactiva"

#: kaccess/kaccess.notifyrc:905
msgctxt "Name"
msgid "Sticky keys has been enabled or disabled"
msgstr "Les tecles permanents s'han activat o desactivat"

#: kaccess/kaccess.notifyrc:985
msgctxt "Comment"
msgid "Sticky keys has been enabled or disabled"
msgstr "Les tecles permanents s'han activat o desactivat"

#: kaccess/kaccess.notifyrc:1069
msgctxt "Name"
msgid "Slow keys has been enabled or disabled"
msgstr "Les tecles lentes s'han activat o desactivat"

#: kaccess/kaccess.notifyrc:1148
msgctxt "Comment"
msgid "Slow keys has been enabled or disabled"
msgstr "Les tecles lentes s'han activat o desactivat"

#: kaccess/kaccess.notifyrc:1231
msgctxt "Name"
msgid "Bounce keys has been enabled or disabled"
msgstr "Les tecles de repetició s'han activat o desactivat"

#: kaccess/kaccess.notifyrc:1309
msgctxt "Comment"
msgid "Bounce keys has been enabled or disabled"
msgstr "Les tecles de repetició s'han activat o desactivat"

#: kaccess/kaccess.notifyrc:1390
msgctxt "Name"
msgid "Mouse keys has been enabled or disabled"
msgstr "Les tecles del ratolí s'han activat o desactivat"

#: kaccess/kaccess.notifyrc:1470
msgctxt "Comment"
msgid "Mouse keys has been enabled or disabled"
msgstr "Les tecles del ratolí s'han activat o desactivat"

