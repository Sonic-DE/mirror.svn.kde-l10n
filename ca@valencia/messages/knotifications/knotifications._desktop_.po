#: src/android_defaults.notifyrc:2
msgctxt "Name"
msgid "Fatal Error"
msgstr "Error fatal"

#: src/android_defaults.notifyrc:61
msgctxt "Comment"
msgid "There was a serious error causing the program to exit"
msgstr "S'ha produït un error seriós que ha provocat l'eixida del programa"

#: src/android_defaults.notifyrc:122
msgctxt "Name"
msgid "Notification"
msgstr "Notificació"

#: src/android_defaults.notifyrc:180
msgctxt "Comment"
msgid "Something special happened in the program"
msgstr "Alguna cosa especial ha passat en el programa"

#: src/android_defaults.notifyrc:240
msgctxt "Name"
msgid "Warning"
msgstr "Avís"

#: src/android_defaults.notifyrc:298
msgctxt "Comment"
msgid "There was an error in the program which may cause problems"
msgstr "S'ha produït un error en el programa que pot provocar problemes"

#: src/android_defaults.notifyrc:358
msgctxt "Name"
msgid "Catastrophe"
msgstr "Catàstrofe"

#: src/android_defaults.notifyrc:415
msgctxt "Comment"
msgid "A very serious error occurred, at least causing the program to exit"
msgstr ""
"S'ha produït un error molt seriós, com a mínim ha provocat l'eixida del "
"programa"
