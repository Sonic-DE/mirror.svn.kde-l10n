#: kclock-runner.desktop:5
msgctxt "Name|plasma runner"
msgid "Clock"
msgstr "Rellotge"

#: kclock-runner.desktop:39
msgctxt "Comment"
msgid "Find timers and start/stop them"
msgstr "Busca temporitzadors i els inicia/para"

#: kclock-runner.desktop:84
msgctxt "X-Plasma-Runner-Syntax-Descriptions"
msgid ""
"Finds timers whose name match :q:,Lists all timers and allows to start/stop "
"them.,Lists all alarms and allows to enable/disable them."
msgstr ""
"Troba temporitzadors el nom dels quals coincidisca amb :q:,Llista tots els "
"temporitzadors i permet iniciar/parar-los.,Llista totes les alarmes i permet "
"activar i desactivar-les."

#: org.kde.kclockd-autostart.desktop:53
msgctxt "Comment"
msgid "A simple clock application in Kirigami."
msgstr "Una aplicació senzilla de rellotge creada amb Kirigami."

#: org.kde.kclock.desktop.in:54
msgctxt "Comment"
msgid "Set alarms and timers, use a stopwatch, and manage world clocks"
msgstr ""
"Establiu alarmes i temporitzadors, utilitzeu un cronòmetre i gestioneu els "
"rellotges mundials"

#: org.kde.kclock.desktop.in:101
msgctxt "Keywords"
msgid "kclock;timer;stopwatch;alarm;timezone;time zone;world clock;"
msgstr ""
"kclock;temporitzador;cronòmetre;alarma;zona horària;fus horari;rellotge del "
"món;"

