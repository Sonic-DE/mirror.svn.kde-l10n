#: kclockd.notifyrc:57
msgctxt "Name"
msgid "Timer finished"
msgstr "El temporitzador ha finalitzat"

#: kclockd.notifyrc:100
msgctxt "Comment"
msgid "Your timer has finished!"
msgstr "El temporitzador ha finalitzat!"

#: kclockd.notifyrc:148
