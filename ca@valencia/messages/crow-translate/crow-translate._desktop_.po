#: data/org.kde.CrowTranslate.desktop.in:3
msgctxt "Name"
msgid "Crow Translate"
msgstr "Crow Translate"

#: data/org.kde.CrowTranslate.desktop.in:31
msgctxt "GenericName"
msgid "Translator"
msgstr "Traductor"

#: data/org.kde.CrowTranslate.desktop.in:63
msgctxt "Comment"
msgid ""
"A simple and lightweight translator that allows to translate and speak the "
"selected text using Mozhi"
msgstr ""
"Un traductor senzill i lleuger que permet traduir i llegir el text "
"seleccionat utilitzant Mozhi"

#: data/org.kde.CrowTranslate.desktop.in:91
msgctxt "Keywords"
msgid "google;yandex;deepl;duckduckgo;libre';mymemory;reverso;text-to-speech;"
msgstr ""
"google;yandex;deepl;duckduckgo;libre;mymemory;reverso;text-to-speech;text a "
"veu;"

#: data/org.kde.CrowTranslate.desktop.in:132
msgctxt "Name"
msgid "Translate selected text"
msgstr "Traduïx el text seleccionat"

#: data/org.kde.CrowTranslate.desktop.in:165
msgctxt "Name"
msgid "Speak selected text"
msgstr "Llig el text seleccionat"

#: data/org.kde.CrowTranslate.desktop.in:197
msgctxt "Name"
msgid "Speak translation of selected text"
msgstr "Llig la traducció del text seleccionat"

#: data/org.kde.CrowTranslate.desktop.in:229
msgctxt "Name"
msgid "Stop text speaking"
msgstr "Para la pronunciació del text"

#: data/org.kde.CrowTranslate.desktop.in:261
msgctxt "Name"
msgid "Show main window"
msgstr "Mostra la finestra principal"

#: data/org.kde.CrowTranslate.desktop.in:296
msgctxt "Name"
msgid "Translate selected text and copy to clipboard"
msgstr "Traduïx el text seleccionat i el copia a dins del porta-retalls"

#: data/org.kde.CrowTranslate.desktop.in:327
msgctxt "Name"
msgid "Recognize text in screen area"
msgstr "Reconeix text en una àrea de la pantalla"

#: data/org.kde.CrowTranslate.desktop.in:359
msgctxt "Name"
msgid "Translate text in screen area"
msgstr "Traduïx text en una àrea de la pantalla"

#: data/org.kde.CrowTranslate.desktop.in:391
msgctxt "Name"
msgid "Toggle the option to negate (invert) the captured image before OCR"
msgstr ""
"Canvia l'opció de fer el negatiu (inversió) de la imatge capturada abans "
"d'OCR"
