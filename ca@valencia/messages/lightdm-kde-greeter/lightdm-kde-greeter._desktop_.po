#: greeter/lightdm-kde-greeter.desktop:5
msgctxt "Name"
msgid "LightDM KDE Greeter"
msgstr "Pantalla de benvinguda de KDE de LightDM"

#: greeter/lightdm-kde-greeter.desktop:38
msgctxt "Comment"
msgid "This runs the KDE greeter, it should only be run from LightDM"
msgstr ""
"Açò executa la pantalla de benvinguda de KDE, només s'ha d'executar des de "
"LightDM"

#: greeter/lightdm-kde-greeter-x11.desktop:5
msgctxt "Name"
msgid "LightDM KDE Greeter (X11)"
msgstr "Pantalla de benvinguda de KDE de LightDM (X11)"

#: greeter/lightdm-kde-greeter-x11.desktop:31
msgctxt "Comment"
msgid ""
"This runs the KDE greeter (X11 session), it should only be run from LightDM"
msgstr ""
"Açò executa la pantalla de benvinguda de KDE (sessió X11), només s'ha "
"d'executar des de LightDM"

