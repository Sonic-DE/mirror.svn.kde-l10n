#, kde-format
msgctxt "Longer description in about page"
msgid ""
"<p>KomoDo is a todo manager that uses todo.txt specification. It parses any "
"compliant todo.txt files and turns them into easy to use list of tasks.</p>"
msgstr ""
"<p>KomoDo és un gestor de tasques pendents que utilitza l'especificació "
"«todo.txt». Analitza qualsevol fitxer que complisca «todo.txt» i els "
"convertix en una llista de tasques fàcil d'utilitzar.</p>"

