#. (itstool) path: component/name
#: org.kde.filelight.appdata.xml:10
msgid "Filelight"
msgstr "Filelight"

#. (itstool) path: component/summary
#: org.kde.filelight.appdata.xml:11
msgid "Show disk usage and delete unused files"
msgstr "Mostra l'ús del disc i suprimix els fitxers sense ús"

#. (itstool) path: description/p
#: org.kde.filelight.appdata.xml:13
msgid ""
"Filelight is an application to visualize the disk usage on your computer by "
"showing folders using an easy-to-understand view of concentric rings. "
"Filelight makes it simple to free up space!"
msgstr ""
"Filelight és una aplicació per a visualitzar l'ús del disc en l'ordinador "
"que mostra l'ús de les carpetes amb una visualització d'anells concèntrics "
"fàcil d'entendre. Filelight facilita alliberar espai!"

#. (itstool) path: description/p
#: org.kde.filelight.appdata.xml:16
msgid "Features:"
msgstr "Característiques:"

#. (itstool) path: ul/li
#: org.kde.filelight.appdata.xml:18
msgid "Scan local, remote, or removable disks"
msgstr "Explora discs locals, remots o extraïbles"

#. (itstool) path: ul/li
#: org.kde.filelight.appdata.xml:19
msgid "View detailed information about files and folders"
msgstr "Visualització d'informació detallada quant a fitxers i carpetes"

#. (itstool) path: ul/li
#: org.kde.filelight.appdata.xml:20
msgid "Delete files or folders that are taking up too much space"
msgstr "Suprimiu el fitxer o carpetes que ocupen massa espai"

#. (itstool) path: ul/li
#: org.kde.filelight.appdata.xml:21
msgid "Integration into the Dolphin, Konqueror, and Krusader file managers"
msgstr "Integració en els gestors de fitxers Dolphin, Konqueror i Krusader"

#. (itstool) path: ul/li
#: org.kde.filelight.appdata.xml:22
msgid "Configurable color schemes"
msgstr "Esquemes de color configurables"
