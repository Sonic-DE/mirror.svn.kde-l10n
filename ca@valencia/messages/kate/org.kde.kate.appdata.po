#. (itstool) path: component/name
#: org.kde.kate.appdata.xml:7
msgid "Kate"
msgstr "Kate"

#. (itstool) path: component/summary
#: org.kde.kate.appdata.xml:8
msgid "Advanced text editor"
msgstr "Editor de text avançat"

#. (itstool) path: description/p
#: org.kde.kate.appdata.xml:10
msgid ""
"Kate is a fast multi-document, multi-view text editor for programmers by "
"KDE. It features stuff like LSP (Language Server Protocol) support, "
"projects, multiple cursors and selections, git integration, folder wide "
"search, horizontal and vertical splits, vi mode, syntax highlighting for "
"300+ languages, built-in terminal, dynamic word wrap and much more. It is "
"available on Linux, BSD, Windows and MacOS."
msgstr ""
"Kate és un editor de text ràpid multidocument i multivista per a "
"programadors creat per la comunitat KDE. Compta amb suport de LSP (Protocol "
"de Servidor de Llenguatge, «Language Server Protocol»), projectes, cursors i "
"seleccions múltiples, integració de Git, busca ampliada de carpetes, "
"divisions horitzontals i verticals, mode de vi, ressaltat de sintaxi per a "
"més de 300 llenguatges, terminal integrat, ajust dinàmic de paraules i molt "
"més. Està disponible en Linux, BSD, Windows i macOS."

