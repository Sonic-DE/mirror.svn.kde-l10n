#. Tag: title
#: index.docbook:10
#, no-c-format
msgid "The &khelpcenter;"
msgstr "&khelpcenter;"

#. Tag: corpauthor
#: index.docbook:12
#, no-c-format
msgid "The &kde; Team"
msgstr "L'equip de &kde;"

#. Tag: trans_comment
#: index.docbook:13
#, no-c-format
msgid "ROLES_OF_TRANSLATORS"
msgstr "&traductor.Antoni.Bella;"

