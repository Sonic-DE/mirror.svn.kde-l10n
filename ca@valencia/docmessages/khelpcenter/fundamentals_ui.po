"Un <emphasis role=\"bold\"><link linkend=\"visualdict-list-box\">quadro de "
"llista</link></emphasis>"

#. Tag: para
#: ui.docbook:279
#, no-c-format
msgid ""
"A pair of <emphasis role=\"bold\"><link linkend=\"visualdict-radio-button"
"\">Radio Buttons</link></emphasis>"
msgstr ""
