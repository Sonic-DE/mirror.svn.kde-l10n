#. (itstool) path: component/name
#: org.kde.dragonplayer.appdata.xml:9
msgid "Dragon Player"
msgstr "Dragon Player"

#. (itstool) path: component/summary
#: org.kde.dragonplayer.appdata.xml:10
msgid "Play video files and streams"
msgstr "Videobestanden en streams afspelen"

#. (itstool) path: description/p
#: org.kde.dragonplayer.appdata.xml:12
msgid ""
"Dragon Player is a video player focusing on simplicity instead of features. "
"Its easy-to-use interface is designed to get out of your way and simply play "
"your video files and streams."
msgstr ""
"Dragon Player is een videospeler met de focus op eenvoud in plaats van "
"functies. Zijn gemakkelijk te gebruiken interface is ontworpen om niet in de "
"weg te zitten en gewoon videobestanden en streams af te spelen."

#. (itstool) path: description/p
#: org.kde.dragonplayer.appdata.xml:15
msgid "Features:"
msgstr "Mogelijkheden:"

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:17
msgid ""
"Click to play or pause, and double-click to enter or exit full screen mode."
msgstr ""
"Klik om af te spelen of te pauzeren en dubbelklik om modus volledig scherm "
"in of uit te gaan."

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:18
msgid ""
"Choose the subtitle language, and automatically load the right one for your "
"language, if possible."
msgstr ""
"Kies de taal van de ondertitels en laad automatisch de juiste voor uw taal, "
"indien mogelijk."

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:19
msgid "Choose the audio track."
msgstr "Kies de audiotrack."

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:20
msgid "Choose the video track."
msgstr "Kies de videotrack."

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:21
msgid "Adjust the volume by scrolling."
msgstr "Pas het volume aan door te schuiven."

#~ msgid "Video player with focus on simplicity"
#~ msgstr "Videospeler met focus op eenvoud"

#~ msgid "Simple Interface"
#~ msgstr "Eenvoudig interface"

#~ msgid ""
#~ "Resuming videos: Starts playing a video where you were watching it last "
#~ "time"
#~ msgstr ""
#~ "Video's hervatten: begin met het afspelen van een video waar u de laatste "
#~ "keer deze bekeek"

#~ msgid ""
#~ "Support for subtitles: Automatically loads subtitles with the matching "
#~ "name"
#~ msgstr ""
#~ "Ondersteuning voor ondertitels: automatisch ondertitels laden met de "
#~ "overeenkomstige naam"

#~ msgid "Video display settings (brightness, contrast)"
#~ msgstr "Instellingen voor het scherm (helderheid, contrast)"

#~ msgid ""
#~ "Due to using Solid and Phonon DragonPlayer is independent of any "
#~ "multimedia framework or hardware abstraction layer"
#~ msgstr ""
#~ "Omdat DragonPlayer Solid en Phonon gebruikt is het onafhankelijk van elk "
#~ "multimediaframework of hardware-abstractielaag"

#~ msgid "Supports playing CDs and DVDs"
#~ msgstr "Ondersteunt afspelen van cd's en dvd's"
