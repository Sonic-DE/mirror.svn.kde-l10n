#. (itstool) path: component/name
#: org.kde.ktechlab.appdata.xml:11
msgid "KTechlab"
msgstr "KTechlab"

#. (itstool) path: component/summary
#: org.kde.ktechlab.appdata.xml:12
msgid "IDE for microcontrollers and electronics"
msgstr "IDE (ontwikkelomgeving) voor microcontrollers en elektronica"

#. (itstool) path: description/p
#: org.kde.ktechlab.appdata.xml:14
msgid ""
"KTechlab is an IDE for microcontrollers and electronics designed to be as "
"easy to use and unintrusive as possible."
msgstr ""
"KTechlab is een IDE (ontwikkelomgeving) voor microcontrollers en elektronica "
"ontworpen voor gemakkelijk gebruik en zo weinig opdringerig als mogelijk."

#. (itstool) path: description/p
#: org.kde.ktechlab.appdata.xml:17
msgid "Features:"
msgstr "Kenmerken:"

#. (itstool) path: ul/li
#: org.kde.ktechlab.appdata.xml:19
msgid "Wide range of components with editable characteristics"
msgstr "Brede reeks van componenten met bewerkbare karakteristieken"

#. (itstool) path: ul/li
#: org.kde.ktechlab.appdata.xml:20
msgid "Visual editor for circuits"
msgstr "Visuele bewerker voor schakelingen"

#. (itstool) path: ul/li
#: org.kde.ktechlab.appdata.xml:21
msgid "Context help for the components"
msgstr "Contexthulp voor de componenten"

#. (itstool) path: ul/li
#: org.kde.ktechlab.appdata.xml:22
msgid "Two modes of connector routing: automatic and manual"
msgstr "Twee manieren van routering van verbindingen: automatisch en handmatig"

#. (itstool) path: ul/li
#: org.kde.ktechlab.appdata.xml:23
msgid ""
"Several ways to define the PIC logic: assembly code, Microbe (own high level "
"programming language) code, C code, and visual FlowCode"
msgstr ""
"Verschillende manieren om de PIC-logica te definiëren: assembly code, "
"Microbe (eigen hoog niveau programmeertaal) code, C code en visuele FlowCode"

#. (itstool) path: ul/li
#: org.kde.ktechlab.appdata.xml:24
msgid "Interconversion of the programming code between supported languages"
msgstr "Onderlinge conversie van de programmeercode tussen ondersteunde talen"

#. (itstool) path: ul/li
#: org.kde.ktechlab.appdata.xml:25
msgid "Inbuilt debugger"
msgstr "Ingebouwde debugger"

#. (itstool) path: ul/li
#: org.kde.ktechlab.appdata.xml:26
msgid "Simulation with oscilloscope and probes"
msgstr "Simulatie met oscilloscope en probes"

#. (itstool) path: ul/li
#: org.kde.ktechlab.appdata.xml:27
msgid "Uploading the assembly code to PIC using hardware programmer"
msgstr "Uploaden van de assembly code naar PIC met hardware programmeerder"

