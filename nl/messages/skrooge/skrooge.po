#: plugins/skrooge/skrooge_operation/skgoperationplugin.cpp:639
#, kde-format
msgctxt "Description of a tips"
msgid "<p>… you can press +, -, CTRL + or CTRL - to quickly change dates.</p>"
msgstr ""
"<p>… u kunt +, -, CTRL + or CTRL - indrukken om snel datums te wijzigen.</p>"

#: plugins/skrooge/skrooge_operation/skgoperationplugin.cpp:640
#, kde-format
msgctxt "Description of a tips"
msgid ""
"<p>… you can update many <a href=\"skg://skrooge_operation_plugin"
"\">transactions</a> in one shot.</p>"
msgstr ""
"<p>… u vele <a href=\"skg://skrooge_operation_plugin\">transacties</a> in "
"een keer kan uitvoeren.</p>"

#: plugins/skrooge/skrooge_operation/skgoperationplugin.cpp:642
#, kde-format
msgctxt "Description of a tips"
msgid ""
"<p>… you can double click on an <a href=\"skg://skrooge_operation_plugin"
"\">operation</a> to show or edit sub transactions.</p>"
msgstr ""
"<p>… door dubbelklikken op een <a href=\"skg://skrooge_operation_plugin"
"\">transactie</a> de sub-transacties veranderen of tonen.</p>"

#: plugins/skrooge/skrooge_operation/skgoperationplugin.cpp:645
#, kde-format
msgctxt "Description of a tips"
msgid ""
"<p>… you can duplicate an <a href=\"skg://skrooge_operation_plugin"
"\">operation</a> including complex transactions (split, grouped, …).</p>"
msgstr ""
"<p>… een <a href=\"skg://skrooge_operation_plugin\">transactie</a> kan "
"dupliceren inclusief complexe transacties (gesplitste, gegroepeerde, …).</p>"

#: plugins/skrooge/skrooge_operation/skgoperationplugin.cpp:646
#, kde-format
msgctxt "Description of a tips"
msgid ""
"<p>… you can create template of <a href=\"skg://skrooge_operation_plugin"
"\">transactions</a>.</p>"
msgstr ""
"<p>… sjablonen van <a href=\"skg://skrooge_operation_plugin\">transacties</"
"a> kan maken.</p>"

#: plugins/skrooge/skrooge_operation/skgoperationplugin.cpp:647
#, kde-format
msgctxt "Description of a tips"
msgid ""
"<p>… you can group and ungroup <a href=\"skg://skrooge_operation_plugin"
"\">transactions</a>.</p>"
msgstr ""
"<p>… <a href=\"skg://skrooge_operation_plugin\">transacties</a> kan "
"groeperen en groeperen ongedaan maken.</p>"

#: plugins/skrooge/skrooge_operation/skgoperationplugin.cpp:649
#, kde-format
msgctxt "Description of a tips"
msgid ""
"<p>… you have to indicate the sign of an <a href=\"skg://"
"skrooge_operation_plugin\">operation</a> only if you want to force it, else "
"it will be determined automatically with the <a href=\"skg://"
"skrooge_category_plugin\">category</a>.</p>"
msgstr ""
"<p>… u moet het teken van een <a href=\"skg://skrooge_operation_plugin"
"\">transactie</a> alleen aangeven als u het wilt afdwingen, anders zal het "
"automatisch door de <a href=\"skg://skrooge_category_plugin\">categorie</a> "
"worden bepaald.</p>"

