#. (itstool) path: component/name
#: org.kde.accountwizard.appdata.xml:9
msgid "Account Wizard"
msgstr "Accountassistent"

#. (itstool) path: component/summary
#: org.kde.accountwizard.appdata.xml:10
msgid "Configure accounts"
msgstr "Accounts configureren"

#. (itstool) path: description/p
#: org.kde.accountwizard.appdata.xml:12
msgid ""
"Accountwizard allows to edit, create, delete accounts. Accountwizard "
"supports IMAP/POP3/Kolab account type. Account information can be found by "
"using ispd service."
msgstr ""
"Accountassistent biedt het bewerken, aanmaken, verwijderen van accounts. "
"Accountassistent ondersteunt het IMAP/POP3/Kolab accounttype. "
"Accountinformatie is te vinden door de ispd-service te gebruiken."

#~ msgid "Accountwizard allows to edit, create, delete accounts."
#~ msgstr ""
#~ "Accountassistent biedt het bewerken, aanmaken, verwijderen van accounts."
