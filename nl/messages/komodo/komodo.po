#: src/main.cpp:49
#, kde-format
msgctxt "Longer description in about page"
msgid ""
"<p>KomoDo is a todo manager that uses todo.txt specification. It parses any "
"compliant todo.txt files and turns them into easy to use list of tasks.</p>"
msgstr ""
"<p>KomoDo is een todo-beheerder die todo.txt specificaties gebruikt. Het "
"ontleedt elke compliant todo.txt bestanden en zet ze om in een gemakkelijk "
"te gebruiken lijst met taken.</p>"

