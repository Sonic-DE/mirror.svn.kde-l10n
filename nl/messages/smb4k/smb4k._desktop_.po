msgctxt "Name"
msgid "Opening file failed"
msgstr "Openen van bestand is mislukt"

#: core/smb4k.notifyrc:1568
msgctxt "Comment"
msgid "A file could not be opened"
msgstr "Een bestand kon niet worden geopend"

#: core/smb4k.notifyrc:1611
msgctxt "Name"
msgid "Reading file failed"
msgstr "Lezen van bestand is mislukt"

#: core/smb4k.notifyrc:1649
msgctxt "Comment"
msgid "A file could not be read"
msgstr "Een bestand kon niet worden gelezen"

