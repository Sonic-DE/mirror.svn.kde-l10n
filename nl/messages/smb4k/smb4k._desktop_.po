msgstr "Een map kon niet worden aangemaakt"

#: core/smb4k.notifyrc:1774
msgctxt "Name"
msgid "Process error"
msgstr "Procesfout"

#: core/smb4k.notifyrc:1814
msgctxt "Comment"
msgid "A process error occurred"
msgstr "Er deed zich een procesfout voor"

#: core/smb4k.notifyrc:1857
msgctxt "Name"
msgid "Action failed"
msgstr "Actie is mislukt"

#: core/smb4k.notifyrc:1897
msgctxt "Comment"
msgid "A KAuth action failed"
msgstr "Een KAuth-actie is mislukt"

#: core/smb4k.notifyrc:1939
msgctxt "Name"
msgid "Invalid URL"
msgstr "Ongeldig URL-adres"

#: core/smb4k.notifyrc:1980
msgctxt "Comment"
msgid "An invalid URL was passed"
msgstr "Een ongeldige URL is doorgegeven"

#: core/smb4k.notifyrc:2022
msgctxt "Name"
msgid "Network communication failed"
msgstr "Netwerkcommunicatie is mislukt"

#: core/smb4k.notifyrc:2057
msgctxt "Comment"
msgid "A network related action could not be performed or failed"
msgstr ""
"Een aan het netwerk gerelateerde actie kon niet worden uitgevoerd of is "
"mislukt"

#: core/smb4k.notifyrc:2097
msgctxt "Name"
msgid "Zeroconf error"
msgstr "Zeroconf-fout"

#: core/smb4k.notifyrc:2130
msgctxt "Comment"
msgid "An error with the Zeroconf daemon occurred"
msgstr "Er is een fout opgetreden met de daemon Zeroconf"

#: core/smb4k.notifyrc:2167
msgctxt "Name"
msgid "Keychain error"
msgstr "Fout in sleutelketting"

#: core/smb4k.notifyrc:2196
msgctxt "Comment"
msgid ""
"An error occurred while reading the login credentials from the secure storage"
msgstr ""
"Er was een fout bij lezen van de aanmeldgegevens uit de beveiligde opslag"

#: helpers/smb4kmounthelper.actions:2
msgctxt "Name"
msgid "Mount action"
msgstr "Aankoppelactie"

#: helpers/smb4kmounthelper.actions:39
