#: core/smb4k.notifyrc:3 smb4k/org.kde.smb4k.desktop:3
msgctxt "Name"
msgid "Smb4K"
msgstr "Smb4K"

#: core/smb4k.notifyrc:44 smb4k/org.kde.smb4k.desktop:80
msgctxt "Comment"
msgid "Advanced Network Neighborhood Browser"
msgstr "Geavanceerde browser voor de netwerkomgeving"

#: core/smb4k.notifyrc:87
msgctxt "Name"
msgid "Notification"
msgstr "Melding"

#: core/smb4k.notifyrc:128
msgctxt "Comment"
msgid "The user is notified about an action"
msgstr "De gebruiker is op de hoogte gesteld van een actie"

#: core/smb4k.notifyrc:169
msgctxt "Name"
msgid "Warning"
msgstr "Waarschuwing"

#: core/smb4k.notifyrc:210
msgctxt "Comment"
msgid "A warning is shown to the user"
msgstr "Er is een waarschuwing getoond aan de gebruiker"

#: core/smb4k.notifyrc:252
msgctxt "Name"
msgid "Error"
msgstr "Fout"

#: core/smb4k.notifyrc:293
msgctxt "Comment"
msgid "An error message is shown to the user"
msgstr "Er is een foutmelding getoond aan de gebruiker"

#: core/smb4k.notifyrc:333
msgctxt "Name"
msgid "Share mounted"
msgstr "Share aangekoppeld"

#: core/smb4k.notifyrc:371
msgctxt "Comment"
msgid "A share has been mounted"
msgstr "Een gedeelde map is aangekoppeld"

#: core/smb4k.notifyrc:413
msgctxt "Name"
msgid "Share unmounted"
msgstr "Share afgekoppeld"

#: core/smb4k.notifyrc:451
msgctxt "Comment"
msgid "A share has been unmounted"
msgstr "Een gedeelde map is afgekoppeld"

#: core/smb4k.notifyrc:493
msgctxt "Name"
msgid "Shares mounted"
msgstr "Shares aangekoppeld"

