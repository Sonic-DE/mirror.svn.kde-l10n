msgctxt "Comment"
msgid "Multiple shares have been mounted"
msgstr "Meerdere gedeelde mappen zijn aangekoppeld"

#: core/smb4k.notifyrc:573
msgctxt "Name"
msgid "Shares unmounted"
msgstr "Shares afgekoppeld"

#: core/smb4k.notifyrc:611
msgctxt "Comment"
msgid "Multiple shares have been unmounted"
msgstr "Meerdere gedeelde mappen zijn afgekoppeld"

#: core/smb4k.notifyrc:653
msgctxt "Name"
msgid "Migrating login credentials"
msgstr "Aanmeldgegevens worden gemigreerd"

#: core/smb4k.notifyrc:682
msgctxt "Comment"
msgid ""
"The login credentials are migrated to the new format and the active password "
"manager"
msgstr ""
"De aanmeldgegevens zijn gemigreerd naar het nieuwe formaat en de actieve "
"wachtwoordbeheerder"

#: core/smb4k.notifyrc:714
msgctxt "Name"
msgid "Mimetype not supported"
msgstr "Mimetype wordt niet ondersteund"

#: core/smb4k.notifyrc:752
msgctxt "Comment"
msgid "The mimetype of the file that is to be printed is not supported"
msgstr ""
"Het mimetype van het bestand dat afgedrukt moet worden wordt niet ondersteund"

#: core/smb4k.notifyrc:794
msgctxt "Name"
msgid "Bookmark exists"
msgstr "Bladwijzer bestaat al"

