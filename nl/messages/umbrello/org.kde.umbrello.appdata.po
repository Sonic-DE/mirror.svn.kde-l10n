msgid "Features:"
msgstr "Kenmerken:"

#. (itstool) path: ul/li
#: org.kde.umbrello.appdata.xml:19
msgid "Supported formats: XMI"
msgstr "Ondersteunde formaten: XMI"

#. (itstool) path: ul/li
#: org.kde.umbrello.appdata.xml:20
msgid ""
"Several type of diagrams supported: use case, class, sequence, "
"communication, state, activity, component, deployment, entity relationship"
msgstr ""
"Verschillende typen diagrammen worden ondersteund: use case, klassen, "
"volgorde, communicatie, status, activiteit, component, toepassing, relaties "
"tussen eenheden"

