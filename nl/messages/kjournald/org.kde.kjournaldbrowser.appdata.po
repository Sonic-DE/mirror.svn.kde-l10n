#. (itstool) path: component/name
#: org.kde.kjournaldbrowser.appdata.xml:14
msgid "Journald Browser"
msgstr "Browser van journald"

#. (itstool) path: component/summary
#: org.kde.kjournaldbrowser.appdata.xml:15
msgid "Browser for journald databases"
msgstr "Browser voor journald-databases"

#. (itstool) path: description/p
#: org.kde.kjournaldbrowser.appdata.xml:17
msgid ""
"Journald-browser is a reference implementation of the kjournald library and "
"provides a flexible tool to browse in local, remote and offline journald "
"databases."
msgstr ""
"Journald-browser is een referentie implementatie van de kjournald "
"bibliotheek en biedt een flexibel hulpmiddel om te bladeren in lokale "
"journald-databases of op afstand en offline."

