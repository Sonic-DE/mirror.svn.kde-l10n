#. (itstool) path: component/name
#: org.kde.plasma.disks.metainfo.xml:11
msgid "Plasma Disks"
msgstr "Plasma-schijven"

#. (itstool) path: component/summary
#: org.kde.plasma.disks.metainfo.xml:12
msgid "Hard disk health monitoring for KDE Plasma"
msgstr "Monitoren van welzijn van vaste schijf voor KDE Plasma"

#. (itstool) path: description/p
#: org.kde.plasma.disks.metainfo.xml:14
msgid ""
"Plasma Disks monitors S.M.A.R.T. data of disks and alerts the user when "
"signs of imminent failure appear."
msgstr ""
"Plasma Disks monitort S.M.A.R.T. gegevens van schijven en waarschuwt de "
"gebruiker wanneer tekenen van driegend falen verschijnen."

#. (itstool) path: screenshot/caption
#: org.kde.plasma.disks.metainfo.xml:19
msgid "The Plasma Disks Info Center module showing the state of devices."
msgstr "De module Plasma Disks Info Center laat de status van apparaten zien."

