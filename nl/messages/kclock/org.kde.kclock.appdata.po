msgstr "Pagina met timers"

#. (itstool) path: screenshot/caption
#: org.kde.kclock.appdata.xml:45
msgid "Timer page"
msgstr "Pagina met timer"

#. (itstool) path: screenshot/caption
#: org.kde.kclock.appdata.xml:49
msgid "Stopwatch page"
msgstr "Pagina met stopwatch"

#. (itstool) path: screenshot/caption
