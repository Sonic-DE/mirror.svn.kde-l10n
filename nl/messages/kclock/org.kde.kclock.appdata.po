msgid "Mobile view"
msgstr "Beeld op mobiel"

#. (itstool) path: screenshot/caption
#: org.kde.kclock.appdata.xml:37
msgid "Desktop view"
msgstr "Beeld op bureaublad"

#. (itstool) path: screenshot/caption
