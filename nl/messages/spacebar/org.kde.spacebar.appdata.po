msgid "SMS/MMS messaging client"
msgstr "Client voor SMS/MMS berichten"

#. (itstool) path: description/p
#: org.kde.spacebar.appdata.xml:12
msgid ""
"Spacebar is a SMS/MMS messaging client. It allows you to send text messages, "
"pictures and other files over a cellular network."
msgstr ""
"Spacebar is een SMS/MMS client voor verzenden van berichten. Het biedt u het "
"zenden van tekstberichten, plaatjes en andere bestanden over een cellulair "
"netwerk."

#~ msgid "KDE Community"
#~ msgstr "KDE-gemeenschap"

#~ msgid ""
#~ "Spacebar is a telepathy client for Plasma Mobile, that is primarily "
#~ "written for sending and receiving SMS/MMS."
#~ msgstr ""
#~ "Spacebar is een client van telepathy voor Plasma Mobile, die primair is "
#~ "geschreven voor het verzenden en ontvangen van SMS/MMS."
