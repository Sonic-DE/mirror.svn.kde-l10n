msgid "File Manager"
msgstr "Bestandsbeheerder"

#. (itstool) path: description/p
#: org.kde.krusader.appdata.xml:13
msgid ""
"Krusader is an advanced twin panel (commander style) file manager for KDE "
"Plasma and other desktops in the *nix world"
msgstr ""
"Krusader is een geavanceerde, twee-paneel (commander-stijl) "
"bestandsbeheerder voor KDE Plasma en andere bureaubladen in de *nix-wereld"

