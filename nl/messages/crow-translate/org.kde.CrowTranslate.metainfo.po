#. (itstool) path: component/summary
#: org.kde.CrowTranslate.metainfo.xml:14
msgid "Application that allows you to translate and speak text using Mozhi"
msgstr ""
"Toepassing die het vertalen en uitspreken van tekst biedt met gebruik van "
"Mozhi."

#. (itstool) path: description/p
#: org.kde.CrowTranslate.metainfo.xml:18
msgid ""
"Application written in C++ / Qt that allows you to translate and speak text "
"using Mozhi."
msgstr ""
"Toepassing geschreven in C++ / Qt die het vertalen en uitspreken van tekst "
"biedt met gebruik van Mozhi."

#. (itstool) path: description/p
#: org.kde.CrowTranslate.metainfo.xml:19
msgid "Features:"
msgstr "Mogelijkheden:"

#. (itstool) path: ul/li
#: org.kde.CrowTranslate.metainfo.xml:21
msgid ""
"Multiple translation engines provided by Mozhi (some instances can disable "
"specific engines)*"
msgstr ""
"Meerdere vertaal-engines geleverd door Mozhi (sommige exemplaren kunnen "
"specifieke engines uitschakelen)*"

#. (itstool) path: ul/li
#: org.kde.CrowTranslate.metainfo.xml:22
