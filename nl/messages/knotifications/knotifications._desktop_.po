#: src/android_defaults.notifyrc:2
msgctxt "Name"
msgid "Fatal Error"
msgstr "Fatale fout"

#: src/android_defaults.notifyrc:61
msgctxt "Comment"
msgid "There was a serious error causing the program to exit"
msgstr "Er deed zich een serieuze fout voor die het programma deed afsluiten"

#: src/android_defaults.notifyrc:122
msgctxt "Name"
msgid "Notification"
msgstr "Melding"

#: src/android_defaults.notifyrc:180
msgctxt "Comment"
msgid "Something special happened in the program"
msgstr "Er gebeurde iets bijzonders in het programma"

#: src/android_defaults.notifyrc:240
msgctxt "Name"
msgid "Warning"
msgstr "Waarschuwing"

#: src/android_defaults.notifyrc:298
msgctxt "Comment"
msgid "There was an error in the program which may cause problems"
msgstr ""
"Er deed zich een fout voor in het programma dat problemen kan veroorzaken"

#: src/android_defaults.notifyrc:358
msgctxt "Name"
msgid "Catastrophe"
msgstr "Catastrofe"

#: src/android_defaults.notifyrc:415
msgctxt "Comment"
msgid "A very serious error occurred, at least causing the program to exit"
msgstr ""
"Er deed zich een serieuze fout voor dat er op zijn minst voor zorgde dat het "
"programma werd afgesloten"
