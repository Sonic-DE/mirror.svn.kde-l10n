#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:161
msgid "Performance improvements in Dynamic view"
msgstr "Verbeteringen van prestaties in dynamische weergave"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:162
msgid "Dynamic view action bar rewritten to be inline to content"
msgstr ""
"Actiebalk van dynamische weergave herschreven om inline te zijn met inhoud"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:163
msgid "Allow setting non-current location in default forecasts page"
msgstr ""
"Sta toe om een ​​niet-huidige locatie in te stellen op de pagina met "
"standaardvoorspellingen."

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:164
msgid "Added ability to fetch temperature units from system locale"
msgstr ""
"Mogelijkheid toegevoegd om temperatuureenheden op te halen uit de "
"taalinstelling van het systeem."

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:165
msgid "Fixed timezone format not being correctly read for local location time"
msgstr ""
"Het probleem is opgelost waarbij de tijdzone-indeling niet correct werd "
"uitgelezen voor de lokale tijd."

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:176
msgid "Rewrote the weather plasmoid"
msgstr "De weer-plasmoid is herschreven"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:177
msgid "Use inline page indicator for flat mode forecasts"
msgstr ""
"Gebruik de inline pagina-indicator voor voorspellingen in vlakke modus."

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:178
msgid "Fix location ordering not persisting"
msgstr "Het probleem met de niet-behoudende locatievolgorde is opgelost."

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:187
msgid "Reworked the locations page to better handle long location names"
msgstr ""
"De pagina met locaties is opnieuw bewerkt om lange locatienamen beter te "
"verwerken."

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:188
msgid "Add maximum width to dynamic forecast to better deal with widescreen"
msgstr ""
"Voeg de maximale breedte toe aan de dynamische voorspelling om beter om te "
"gaan met breedbeeldschermen."

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:189
msgid "Remove plasmoid (it is being reworked!)"
msgstr "Plasmoid verwijderen (het wordt opnieuw bewerkt!)"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:190
msgid "Fixed default page not being loaded when new locations are added"
msgstr ""
"Opgelost: de standaardpagina werd niet geladen wanneer nieuwe locaties "
"werden toegevoegd."

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:191
msgid "Unify application settings location"
msgstr "De locatie van de toepassingsinstellingen eenduidig maken"

#. (itstool) path: ul/li
