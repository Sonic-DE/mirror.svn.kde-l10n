msgid "Zeroconf Support"
msgstr "Ondersteuning van Zeroconf"

#. (itstool) path: component/summary
#: org.kde.kio_zeroconf.metainfo.xml:10
msgid "Browse local network services in Dolphin's Network page"
msgstr "Bladeren in lokale netwerkservices in de netwerkpagina van Dolphin"

#. (itstool) path: description/p
#: org.kde.kio_zeroconf.metainfo.xml:12
msgid ""
"Adds an entry to Dolphin's Network page to show local services such as "
"printers which advertise themselves with DNSSD (called Avahi or Bonjour by "
"other projects)."
msgstr ""
"Voegt een item toe aan de netwerkpagina van Dolphin om lokale services te "
"tonen zoals printers die zichzelf adverteren met DNSSD (Avahi of Bonjour "
"genoemd door andere projecten)."
