#. (itstool) path: component/name
#: org.kde.ksirk.appdata.xml:10
msgid "KsirK"
msgstr "KsirK"

#. (itstool) path: component/summary
#: org.kde.ksirk.appdata.xml:11
msgid "World Domination Strategy Game"
msgstr "Werelddominatie-strategiespel"

#. (itstool) path: description/p
#: org.kde.ksirk.appdata.xml:13
msgid ""
"KsirK is a computerized version of the well known strategic board game Risk. "
"The goal of the game is simply to conquer the world by attacking your "
"neighbors with your armies."
msgstr ""
"KsirK is een gecomputeriseerde versie van het welbekende strategische "
"bordspel Risk. Het doel van het spel is eenvoudig de wereld veroveren door "
"uw buren aan te vallen met uw legers."

#. (itstool) path: description/p
#: org.kde.ksirk.appdata.xml:17
msgid "Features:"
msgstr "Mogelijkheden:"

#. (itstool) path: ul/li
#: org.kde.ksirk.appdata.xml:19
msgid "Support for 1-6 human or computer (AI) players"
msgstr "Ondersteuning voor 1-6 menselijke of computer(AI)spelers"

#. (itstool) path: ul/li
#: org.kde.ksirk.appdata.xml:20
msgid "Multi-player gaming over a network"
msgstr "Met meerdere speler spelen over een netwerk"

#. (itstool) path: ul/li
#: org.kde.ksirk.appdata.xml:21
msgid "You can easily create new skins with SVG graphics and the skin editor"
msgstr ""
"U kunt gemakkelijk nieuwe skins with maken met SVG graphics en de skin-editor"

#. (itstool) path: ul/li
#: org.kde.ksirk.appdata.xml:22
msgid "Hot New Stuff support. You can easily download and install new skins"
msgstr ""
"Ondersteuning door Vers-van-de-pers. U kunt gemakkelijk nieuwe skins "
"downloaden en installeren"

