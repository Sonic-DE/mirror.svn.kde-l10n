msgid "Kodaskanna"
msgstr "Kodaskanna"

#. (itstool) path: component/summary
#: org.kde.kodaskanna.appdata.xml:14
msgid "A multi-format 1D/2D code scanner"
msgstr "Een multi-format 1D/2D codescanner"

#. (itstool) path: description/p
#: org.kde.kodaskanna.appdata.xml:16
msgid ""
"Kodaskanna is a utility for reading data from 1D/2D codes (e.g. QR codes or "
"bar codes) and making the data available for further processing."
msgstr ""
"Kodaskanna is een hulpmiddel om gegevens uit 1D/2D codes te lezen (bijv. QR- "
"of barcodes) en de gegevens beschikbaar te maken voor verdere bewerking."
