#: modules/account/metadata.json
msgctxt "Description"
msgid "Allow the user to set the account name."
msgstr "Sta de gebruiker toe om de accountnaam in te stellen."

#: modules/cellular/metadata.json
msgctxt "Description"
msgid "Allow the user to configure the cellular network."
msgstr "Sta de gebruiker toe het cellulaire netwerk te configureren."

#: modules/finished/metadata.json
msgctxt "Description"
msgid ""
"Shown when the initial system setup is completed, and the user can commit "
"the changes."
msgstr ""
"Getoond wanneer de initiële opzet van het systeem is voltooid en de "
"gebruiker de wijzigingen kan vastzetten (commit)."

#: modules/hostname/metadata.json
msgctxt "Description"
msgid "Allow the user to set the system hostname."
msgstr "Sta de gebruiker toe om de hostnaam van het systeem in te stellen."

#: modules/keyboard/metadata.json
msgctxt "Description"
msgid "Allow the user to choose the keyboard layout."
msgstr "Sta de gebruiker toe om de toetsenbordindeling te kiezen."

#: modules/language/metadata.json
msgctxt "Description"
msgid "Allow the user to set the system language."
msgstr "Sta de gebruiker toe om de systeemtaal in te stellen."

#: modules/prepare/metadata.json
msgctxt "Description"
msgid "Allows the user to configure the environment before using it."
msgstr ""
"Staat de gebruiker toe de omgeving te configureren alvorens het te gebruiken."

#: modules/time/metadata.json
msgctxt "Description"
msgid "Allow the user to set the timezone."
msgstr "Sta de gebruiker toe om de tijdzone in te stellen."

#: modules/wifi/metadata.json
msgctxt "Description"
msgid "Allow the user to connect to a Wi-Fi network."
msgstr "Sta de gebruiker toe om met een Wi-Fi netwerk te verbinden."

