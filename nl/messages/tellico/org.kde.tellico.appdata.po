#. (itstool) path: component/name
#: org.kde.tellico.appdata.xml:9
msgid "Tellico"
msgstr "Tellico"

#. (itstool) path: component/summary
#: org.kde.tellico.appdata.xml:10
msgid "Collection Manager"
msgstr "Collectiebeheer"

#. (itstool) path: description/p
#: org.kde.tellico.appdata.xml:12
msgid ""
"Tellico is an application for organizing your collections. It provides "
"default templates for books, bibliographies, videos, music, video games, "
"coins, stamps, trading cards, comic books, and wines. It allows you to enter "
"your collection in a catalogue database, saving many different properties "
"like title, author, etc."
msgstr ""
"Tellico is een toepassing voor het organiseren van uw verzamelingen. Het "
"biedt standaard sjablonen voor boeken, bibliografieën, video's, muziek, "
"videogames, munten, postzegels, visitekaartjes, strips en wijnen. Het stelt "
"u in staat om uw verzameling in een catalogusdatabase in te voeren, waarin "
"veel verschillende eigenschappen, zoals titel, auteur, etc. opgeslagen "
"kunnen worden."

#. (itstool) path: description/p
#: org.kde.tellico.appdata.xml:17
msgid "Features:"
msgstr "Mogelijkheden:"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:19
msgid ""
"Supports default collections of books, bibliographic entries, videos, music, "
"video games, comic books, coins, stamps, trading cards, wines, board games, "
"and file catalogs"
msgstr ""
"Ondersteunt standaard verzamelingen van boeken, bibliografie-items, video's, "
"muziek, videogames, strips, munten, postzegels, visitekaartjes, wijnen, "
"bordspellen en catalogs van bestanden"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:20
msgid "Supports user-defined custom collections"
msgstr "Ondersteunt gebruikergedefinieerde eigen verzamelingen"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:21
msgid ""
"Supports any number of user-defined fields, of several different types: "
"text, paragraph, list, checkbox, number, URL, date, images, and combinations"
msgstr ""
"Ondersteunt elk aantal gebruikergedefinieerde velden met verscheidene "
"verschillende types: tekst, paragraaf, lijst, keuzevakje, aantal, URL, "
"datum, afbeelding en combinaties"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:22
msgid "Handles entries with multiple authors, genres, keywords, etc"
msgstr "Behandelt items met meerdere auteurs, genres, zoektermen, etc."

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:23
msgid "Automatically formats titles and names"
msgstr "Deelt automatisch titels en namen in"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:24
msgid "Supports collection searching and view filtering"
msgstr "Ondersteunt zoeken in verzamelingen en filtering op weergave"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:25
msgid "Sorts and groups collection by various properties"
msgstr "Sorteert en groepeert verzameling door verschillende eigenschappen"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:26
msgid "Allows customizable entry templates through XSLT"
msgstr "Staat aanpasbare sjablonen van items toe via XSLT"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:27
msgid "Imports MODS, Bibtex, RIS, CSV, PDF metadata, and many other formats"
msgstr ""
"Importeert MODS, Bibtex, RIS, CSV, PDF metadata en vele andere formaten"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:28
msgid "Exports to Bibtex, ONIX, CSV, HTML, and other formats"
