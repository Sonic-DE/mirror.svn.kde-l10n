"<guimenuitem>Recalculate Document</guimenuitem>"
msgstr ""
"<shortcut><keysym>F9</keysym></shortcut> <guimenu>Hulpmiddelen</"
"guimenu><guimenuitem>Document opnieuw berekenen</guimenuitem>"

#. Tag: action
#: commands.docbook:936
#, no-c-format
msgid "Recalculate all sheets."
msgstr "Berekent de formules op alle werkbladen opnieuw."

#. Tag: menuchoice
#: commands.docbook:952
#, no-c-format
msgid ""
