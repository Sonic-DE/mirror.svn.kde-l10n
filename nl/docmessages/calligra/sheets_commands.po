#: commands.docbook:418
#, no-c-format
msgid "The View Menu"
msgstr "Het menu Beeld"

#. Tag: menuchoice
#: commands.docbook:423
#, no-c-format
msgid "<guimenu>View</guimenu> <guimenuitem>New View</guimenuitem>"
