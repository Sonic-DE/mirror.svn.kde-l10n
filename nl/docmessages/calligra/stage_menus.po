#~ msgid ""
#~ "Allows you to alter the background to your presentation slides. Your "
#~ "options are <guilabel>Color/Gradient</guilabel>, (which lets you set "
#~ "either a plain color or one of many gradients) or <guilabel>Picture</"
#~ "guilabel>, which gives a dialog box to find the picture you want. Set the "
#~ "<guilabel>View mode:</guilabel> for this picture to <guilabel>Scaled</"
#~ "guilabel>, <guilabel>Centered</guilabel>, or <guilabel>Tiled</guilabel>."
