#~ msgid ""
#~ "An object that is on top will cover, either partially or fully depending "
#~ "on its size, all other objects beneath it. Meanwhile an object on the "
#~ "bottom of the stack may not be visible at all, as it is covered up by "
#~ "other objects. An object in the middle may be partially covered by other "
#~ "objects, while partially covering yet more objects itself."
#~ msgstr ""
