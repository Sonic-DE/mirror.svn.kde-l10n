#~ msgid "<guimenu>Edit</guimenu> Menu"
#~ msgstr "Het menu <guimenu>Bewerken</guimenu>"

#~ msgid "<guimenu>Edit</guimenu> <guimenuitem>Duplicate Slide</guimenuitem>"
#~ msgstr ""
#~ "<guimenu>Bewerken</guimenu> <guimenuitem>Dia dupliceren</guimenuitem>"

#~ msgid ""
#~ "<guimenu>Edit</guimenu> <guimenuitem>Duplicate Object...</guimenuitem>"
#~ msgstr ""
#~ "<guimenu>Bewerken</guimenu> <guimenuitem>Object dupliceren...</"
#~ "guimenuitem>"

#~ msgid ""
#~ "Create a duplicate of the currently selected object. A dialog will "
#~ "display allowing you to set some options for the duplicate, &eg; if it "
#~ "should be rotated, or scaled, or offset to a new position on the slide."
#~ msgstr ""
#~ "Maakt een duplicaat van het geselecteerde object. Er verschijnt een "
#~ "dialoogvenster waarin u enkele opties voor het duplicaat in kunt stellen. "
#~ "U kunt het object roteren, van grootte veranderen of verplaatsen."

#~ msgid "<guimenu>View</guimenu> Menu"
#~ msgstr "Het menu <guimenu>Beeld</guimenu>"

#~ msgid ""
#~ "<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>W</keycap></"
#~ "keycombo></shortcut> <guimenu>View</guimenu> <guimenuitem>Close All "
#~ "Views</guimenuitem>"
#~ msgstr ""
#~ "<shortcut><keycombo action=\"simul\">&Ctrl;&Shift;<keycap>W</keycap></"
#~ "keycombo></shortcut> <guimenu>Beeld</guimenu><guimenuitem>Alle weergaven "
#~ "sluiten</guimenuitem>"

#~ msgid ""
#~ "<action>Close all views on the presentation.</action> You will be given a "
#~ "chance to save any changes, or to cancel closing."
#~ msgstr ""
#~ "<action>Sluit alle weergaven van de presentatie.</action> Als er nog niet-"
#~ "opgeslagen wijzigingen zijn, kunt u deze alsnog opslaan of het sluiten "
#~ "annuleren."

#~ msgid "<guimenu>View</guimenu> <guimenuitem>Split View</guimenuitem>"
#~ msgstr ""
#~ "<guimenu>Beeld</guimenu> <guimenuitem>Weergave splitsen</guimenuitem>"

#~ msgid ""
#~ "<action>Splits the window into two (or more) views on the same "
#~ "presentation.</action> The default split is horizontal."
#~ msgstr ""
#~ "<action>Splitst het venster in twee (of meer) deelvensters met dezelfde "
#~ "presentatie.</action> De standaardoriëntatie is horizontaal."

#~ msgid "<guimenu>View</guimenu> <guimenuitem>Remove View</guimenuitem>"
#~ msgstr ""
#~ "<guimenu>Beeld</guimenu> <guimenuitem>Deelvenster verwijderen</"
#~ "guimenuitem>"

#~ msgid ""
#~ "<action>Close only the currently active view</action>. The presentation, "
#~ "and any other views you have open, remain open, and any changes you have "
#~ "made remain unsaved."
#~ msgstr ""
#~ "<action>Sluit het huidige deelvenster.</action> De presentatie, en elk "
#~ "ander deelvenster, blijft open. Wijzigingen worden niet automatisch "
#~ "opgeslagen."

#~ msgid ""
#~ "<guimenu>View</guimenu> <guisubmenu>Splitter Orientation</guisubmenu>"
#~ msgstr ""
#~ "<guimenu>Beeld</guimenu><guisubmenu>Splitser-oriëntatie</guisubmenu>"

#~ msgid ""
#~ "<action>Toggle the split view</action> between <guimenuitem>Horizontal</"
#~ "guimenuitem> (the default) and <guimenuitem>Vertical</guimenuitem>."
#~ msgstr ""
#~ "<action>Schakelt de oriëntatie van de deelvensters</action> tussen "
#~ "<guimenuitem>Horizontaal</guimenuitem> (de standaard) en "
#~ "<guimenuitem>Verticaal</guimenuitem>."

#~ msgid ""
#~ "<action>Toggle the display of the sidebar</action> where you can see an "
#~ "overview of all the slides in your presentation."
#~ msgstr ""
#~ "<action>Toont of verbergt het paneel</action> waarin het overzicht staat "
#~ "van alle dia's in de presentatie."

#~ msgid "<guimenu>View</guimenu> <guimenuitem>Show Notebar</guimenuitem>"
#~ msgstr ""
#~ "<guimenu>Beeld</guimenu> <guimenuitem>Notitiebalk tonen</guimenuitem>"

#~ msgid ""
#~ "<action>Toggle the display of the notebar</action> where you can see an "
#~ "overview of all the notes in your presentation."
#~ msgstr ""
#~ "<action>Toont of verbergt het paneel</action> waarin het overzicht staat "
#~ "van alle notities in de presentatie."

#~ msgid "<guimenu>View</guimenu> <guimenuitem>Slide Master</guimenuitem>"
#~ msgstr "<guimenu>Beeld</guimenu> <guimenuitem>Basisdia</guimenuitem>"

#~ msgid ""
#~ "<guimenu>View</guimenu> <guimenuitem>Formatting Characters</guimenuitem>"
#~ msgstr ""
#~ "<guimenu>Beeld</guimenu> <guimenuitem>Niet-afdrukbare tekens</guimenuitem>"

#~ msgid ""
#~ "Show a visual representation of <quote>non-printing characters</quote>, "
#~ "such as tabs and paragraph markers. This can be a useful aid to precisely "
#~ "positioning text."
#~ msgstr ""
#~ "Toont <quote>niet-afdrukbare tekens</quote>, zoals tabstops en alinea-"
#~ "einden. Dit kan een handig hulpmiddel zijn wanneer u de tekst op een "
#~ "bepaalde positie wilt plaatsen."

#~ msgid ""
#~ "This item can be toggled. If enabled, formatting characters are visible; "
#~ "if disabled, they are not."
#~ msgstr ""
#~ "Dit item kan in- en uitgeschakeld worden. Als het ingeschakeld is, zijn "
#~ "de tekens zichtbaar, als het uitgeschakeld is. zijn ze niet zichtbaar."

#~ msgid "<guimenu>View</guimenu> <guimenuitem>Guide Lines</guimenuitem>"
#~ msgstr "<guimenu>Beeld</guimenu><guimenuitem>Hulplijnen</guimenuitem>"

#~ msgid "<guimenu>View</guimenu> <guimenuitem>Add Guide Line...</guimenuitem>"
#~ msgstr ""
#~ "<guimenu>Beeld</guimenu><guimenuitem>Hulplijn toevoegen...</guimenuitem>"

#~ msgid ""
#~ "Opens a dialog to select the <guilabel>Orientation</guilabel> "
#~ "(<guilabel>Horizontal</guilabel> or <guilabel>Vertical</guilabel>) and "
#~ "choose a <guilabel>Position:</guilabel>"
#~ msgstr ""
#~ "Er verschijnt een dialoogvenster waarin u de <guilabel>Oriëntatie</"
#~ "guilabel> (<guilabel>Horizontaal</guilabel> of <guilabel>Verticaal</"
#~ "guilabel>) en de <guilabel>Positie:</guilabel> kunt instellen."

