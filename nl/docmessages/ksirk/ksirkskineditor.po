msgstr ""
"Elke nationaliteit die in de <literal>onu</literal>-groep voor komt, elke "
"nationaliteit heeft zijn eigen groep waarvan het label de naam van de "
"nationaliteit is. De tabel hieronder geeft een lijst met items van deze "
"groepen."

#. Tag: title
#: index.docbook:291
#, no-c-format
msgid "Nationality entries"
msgstr "De onderdelen van de nationaliteit-groep"

#. Tag: entry
#: index.docbook:302
#, no-c-format
msgid "The name of the nationality (&eg; <literal>Japan</literal>)."
msgstr "De naam van de nationaliteit (&eg; <literal>Japan</literal>)."

#. Tag: literal
#: index.docbook:305
#, no-c-format
msgid "leader"
msgstr "leider"

#. Tag: entry
#: index.docbook:306
#, no-c-format
