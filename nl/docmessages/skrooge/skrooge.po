msgstr "Het menu Instellingen"

#. Tag: para
#: index.docbook:977
#, no-c-format
msgid "<guimenuitem>Show Menubar</guimenuitem>: To show or hide the menu"
msgstr ""
"<guimenuitem>Menubalk tonen</guimenuitem>: om het menu te tonen of te "
"verbergen"

#. Tag: para
#: index.docbook:978
#, no-c-format
