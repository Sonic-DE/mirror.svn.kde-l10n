msgstr ""
"<guimenuitem>Ongebruikte begunstigden verwijderen</guimenuitem>: zoals de "
"titel aangeeft"

#. Tag: para
#: index.docbook:962
#, no-c-format
msgid "<guimenuitem>Delete unused categories</guimenuitem>: As per the title"
msgstr ""
"<guimenuitem>Ongebruikte categorieën verwijderen</guimenuitem>: zoals de "
"titel aangeeft"

#. Tag: para
#: index.docbook:963
#, no-c-format
