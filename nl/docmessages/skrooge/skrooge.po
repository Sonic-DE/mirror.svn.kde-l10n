#. Tag: para
#: index.docbook:942
#, no-c-format
msgid "<guimenuitem>Open very old transactions</guimenuitem>: As per the title"
msgstr ""
"<guimenuitem>Zeer oude transacties openen</guimenuitem>: zoals de titel "
"aangeeft"

