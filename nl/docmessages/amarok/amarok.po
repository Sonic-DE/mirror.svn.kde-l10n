msgstr "<guilabel>Media afspelen...</guilabel>"

#. Tag: para
#: index.docbook:6984
#, no-c-format
msgid "Opens a media file to be played."
msgstr "Open een af te spelen mediumbestand."

#. Tag: keycombo
#: index.docbook:6987 index.docbook:8153
#, no-c-format
msgid "&Ctrl;<keycap>O</keycap>"
msgstr "&Ctrl;<keycap>O</keycap>"

