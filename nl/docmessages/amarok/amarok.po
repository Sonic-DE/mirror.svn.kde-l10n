#: index.docbook:3300
#, no-c-format
msgid "Ampache configuration"
msgstr "Ampache configuratie"

#. Tag: para
#: index.docbook:3301
#, no-c-format
msgid ""
"If you have access to a remote <guilabel>Ampache</guilabel> music server, "
"click <inlinemediaobject> <imageobject> <imagedata fileref=\"Icon-configure."
