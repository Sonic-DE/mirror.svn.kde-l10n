#: index.docbook:7921
#, no-c-format
msgid ""
"To control &amarok; from the console, type <userinput>amarok --help-all</"
"userinput> for a current complete list of available commands."
msgstr ""
"Om &amarok; vanaf de console te besturen, typt u <userinput>amarok --help-"
"all</userinput> voor een nu geldige complete lijst van beschikbare "
"commando's."

