"<link linkend=\"organize-collection\">Verzameling organiseren</link>&nbsp;"

#. Tag: para
#: index.docbook:3608 index.docbook:3635
#, no-c-format
msgid "<link linkend=\"remote-collections\">Remote Collections</link>&nbsp;"
msgstr ""
"<link linkend=\"remote-collections\">Verzamelingen op afstand</link>&nbsp;"

#. Tag: para
#: index.docbook:3610 index.docbook:3636 index.docbook:4171
#, no-c-format
msgid "<link linkend=\"ampache\">Ampache</link>&nbsp;"
msgstr "<link linkend=\"ampache\">Ampache</link>&nbsp;"

