#. Tag: title
#: index.docbook:9
#, no-c-format
msgid "ldap"
msgstr "ldap"

#. Tag: author
#: index.docbook:12
#, no-c-format
msgid "&Lauri.Watts; &Lauri.Watts.mail;"
