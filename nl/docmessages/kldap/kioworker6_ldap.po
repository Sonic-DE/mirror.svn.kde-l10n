#. Tag: trans_comment
#: index.docbook:13
#, no-c-format
msgid "ROLES_OF_TRANSLATORS"
msgstr "&Otto.Bruggeman;&Rinse.Devries;"

#. Tag: para
#: index.docbook:17
#, no-c-format
msgid ""
"<acronym>ldap</acronym> is the lightweight directory access protocol. It "
"provides access to an X.500 directory, or to a stand-alone <acronym>LDAP</"
"acronym> server."
msgstr ""
"<acronym>ldap</acronym> is het lichtgewicht directory acces protocol. Het "
"biedt toegang tot een X.500-directory of naar een alleenstaande "
"<acronym>LDAP</acronym>-server."

#. Tag: para
#: index.docbook:21
#, no-c-format
msgid "You can use the ldap KIO worker as follows:"
msgstr "U kunt de ldap KIO-worker als volgt gebruiken:"

#. Tag: para
#: index.docbook:23
#, no-c-format
msgid ""
"<userinput>ldap://host:port/ou=People,o=where,c=de??sub</userinput> for a "
"subtree-query"
msgstr ""
"<userinput>ldap://host:poort/ou=People,o=waar,c=de??sub</userinput> voor een "
"zoekopdracht in een sub-boomstructuur"

#. Tag: para
#: index.docbook:26
#, no-c-format
msgid ""
"or <userinput>ldap://host:port/cn=MM,ou=People,o=where,c=de??base</"
"userinput> for a complete branch."
msgstr ""
"of <userinput>ldap://host:poort/cn=MM,ou=People,o=waar,c=de??basis</"
"userinput> voor een complete boomstructuur."
