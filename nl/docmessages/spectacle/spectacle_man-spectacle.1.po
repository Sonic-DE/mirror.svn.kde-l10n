#. Tag: title
#: man-spectacle.1.docbook:35
#, no-c-format
msgid "Description"
msgstr "Beschrijving"

#. Tag: para
#: man-spectacle.1.docbook:36
#, no-c-format
msgid ""
"<command>spectacle</command> is a simple application for capturing desktop "
"screenshots. It can capture images of the entire desktop, a single monitor, "
"the currently active window, the window currently under the mouse, or a "
"rectangular region of the screen. The images can then be annotated, printed, "
"sent to other applications for manipulation, or quickly be saved as-is."
msgstr ""
"<command>spectacle</command> is een eenvoudige toepassing voor het opnemen "
"van schermafbeeldingen van het bureaublad. Het kan afbeeldingen van het "
"gehele bureaublad, een enkele monitor, het nu actieve venster, het venster "
"nu onder de muis of een rechthoekig gebied van het scherm. De afbeelding kan "
"dan geannoteerd, afgedrukt worden, naar een andere toepassing voor bewerking "
"worden verzonden of snel worden opgeslagen zoals deze nu is."

#. Tag: title
#: man-spectacle.1.docbook:40
#, no-c-format
msgid "Spectacle options"
msgstr "Opties voor Spectacle"

#. Tag: option
#: man-spectacle.1.docbook:44
#, no-c-format
msgid "-h, --help"
msgstr "-h, --help"

#. Tag: para
#: man-spectacle.1.docbook:46
#, no-c-format
msgid "Displays help on commandline options."
msgstr "Help tonen over de opties voor de opdrachtregel."

#. Tag: option
#: man-spectacle.1.docbook:51
#, no-c-format
msgid "--help-all"
msgstr "--help-all"

#. Tag: para
#: man-spectacle.1.docbook:53
#, no-c-format
msgid "Displays help including Qt specific options."
msgstr "Help tonen inclusief Qt specifieke opties."

#. Tag: option
#: man-spectacle.1.docbook:58
#, no-c-format
msgid "-v, --version"
msgstr "-v, --version"

#. Tag: para
#: man-spectacle.1.docbook:60
#, no-c-format
msgid "Displays version information."
msgstr "Toont versie-informatie."

#. Tag: option
#: man-spectacle.1.docbook:65
#, no-c-format
msgid "-f, --fullscreen"
msgstr "-f, --fullscreen"

#. Tag: para
#: man-spectacle.1.docbook:67
#, no-c-format
msgid "Capture the entire desktop (default)."
msgstr "Opname van het gehele bureaublad (standaard)."

#. Tag: option
#: man-spectacle.1.docbook:72
#, no-c-format
msgid "--scaled"
msgstr "--scaled"

#. Tag: para
#: man-spectacle.1.docbook:74
#, no-c-format
msgid ""
"When used with <option>-f</option>/<option>--fullscreen</option>, capture "
"all screens scaled to the same size. Has no effect without <option>-f</"
"option>."
msgstr ""
"Bij gebruik met <option>-f</option>/<option>--fullscreen</option> worden "
"alle schermen op dezelfde grootte vastgelegd. Heeft geen effect zonder "
"<option>-f</option>."

#. Tag: option
#: man-spectacle.1.docbook:79
#, no-c-format
msgid "-m, --current"
msgstr "-m, --current"

#. Tag: para
#: man-spectacle.1.docbook:81
#, no-c-format
msgid "Capture the current monitor."
msgstr "Opname van de huidige monitor."

#. Tag: option
#: man-spectacle.1.docbook:86
#, no-c-format
msgid "-a, --activewindow"
msgstr "-a, --activewindow"

#. Tag: para
#: man-spectacle.1.docbook:88
#, no-c-format
msgid "Capture the active window."
msgstr "Opname van het actieve venster."

#. Tag: option
#: man-spectacle.1.docbook:93
#, no-c-format
msgid "-u, --windowundercursor"
msgstr "-u, --windowundercursor"

#. Tag: para
#: man-spectacle.1.docbook:95
#, no-c-format
msgid ""
"Capture the window currently under the cursor, including parents of pop-up "
"menus."
msgstr ""
"Opname van het huidige venster onder de cursor, inclusief hoofdvenster van "
"pop-up-menu's."

#. Tag: option
#: man-spectacle.1.docbook:100
#, no-c-format
msgid "-t, --transientonly"
msgstr "-t, --transientonly"

#. Tag: para
#: man-spectacle.1.docbook:102
#, no-c-format
msgid ""
"Capture the window currently under the cursor, excluding parents of pop-up "
"menus."
msgstr ""
"Opname van het huidige venster onder de cursor, zonder hoofdvenster van pop-"
"up-menu's."

#. Tag: option
#: man-spectacle.1.docbook:107
#, no-c-format
msgid "-r, --region"
msgstr "-r, --region"

#. Tag: para
#: man-spectacle.1.docbook:109
#, no-c-format
msgid "Capture a rectangular region of the screen."
msgstr "Opname van een rechthoekig gebied op het scherm."

#. Tag: option
#: man-spectacle.1.docbook:114
#, no-c-format
msgid "-l, --launchonly"
msgstr "-l, --launchonly"

#. Tag: para
#: man-spectacle.1.docbook:116
#, no-c-format
msgid "Launch Spectacle without taking a screenshot."
msgstr "Spectacle starten zonder een schermafdruk te maken."

#. Tag: option
#: man-spectacle.1.docbook:121
#, no-c-format
msgid "-g, --gui"
msgstr "-g, --gui"

#. Tag: para
#: man-spectacle.1.docbook:123
#, no-c-format
msgid "Start in GUI mode (default)."
msgstr "In modus GUI beginnen (standaard)."

#. Tag: option
#: man-spectacle.1.docbook:128
#, no-c-format
msgid "-b, --background"
msgstr "-b, --background"

#. Tag: para
#: man-spectacle.1.docbook:130
#, no-c-format
msgid "Take a screenshot and exit without showing the GUI."
msgstr "Een schermafdruk nemen en beëindigen zonder de GUI te tonen."

#. Tag: option
#: man-spectacle.1.docbook:135
#, no-c-format
msgid "-s, --dbus"
msgstr "-s, --dbus"

#. Tag: para
#: man-spectacle.1.docbook:137
#, no-c-format
msgid "Start in DBus-Activation mode."
msgstr "In DBus-activeringsmodus starten."

#. Tag: option
#: man-spectacle.1.docbook:142
#, no-c-format
msgid "-n, --nonotify"
msgstr "-n, --nonotify"

#. Tag: para
#: man-spectacle.1.docbook:144
#, no-c-format
msgid ""
"In background mode, do not pop up a notification when the screenshot is "
"taken."
msgstr ""
"In achtergrondmodus, laat geen melding zien wanneer de schermafdruk is "
"genomen."

#. Tag: option
#: man-spectacle.1.docbook:149
#, no-c-format
msgid "-o, --output <replaceable>fileName</replaceable>"
msgstr "-o, --output <replaceable>bestandsnaam</replaceable>"

#. Tag: para
#: man-spectacle.1.docbook:151
#, no-c-format
msgid ""
"In background mode, save image to specified file <replaceable>fileName</"
"replaceable>."
msgstr ""
"In achtergrondmodus, stuur afbeelding naar naar gespecificeerd bestand "
"<replaceable>bestandsnaam</replaceable>."

#. Tag: option
#: man-spectacle.1.docbook:156
#, no-c-format
msgid "-d, --delay <replaceable>delayMsec</replaceable>"
msgstr "-d, --delay <replaceable>vertragingmsec</replaceable>"

#. Tag: para
#: man-spectacle.1.docbook:158
#, no-c-format
msgid "In background mode, delay before taking the shot (in milliseconds)."
msgstr ""
"In achtergrondmodus, vertragen alvorens de opname te maken (in "
"milliseconden)."

#. Tag: option
#: man-spectacle.1.docbook:163
#, no-c-format
msgid "-c, --copy-image"
msgstr "-c, --copy-image"

#. Tag: para
#: man-spectacle.1.docbook:165
#, no-c-format
msgid ""
"In background mode, copy screenshot only to clipboard, unless -o is also "
"used."
msgstr ""
"In achtergrondmodus, kopieer schermafdruk alleen naar klembord, tenzij -o "
"ook wordt gebruikt."

#. Tag: option
#: man-spectacle.1.docbook:170
#, no-c-format
msgid "-C, --copy-path"
msgstr "-C, --copy-path"

#. Tag: para
#: man-spectacle.1.docbook:172
#, no-c-format
msgid "In background mode, copy screenshot file path to clipboard."
msgstr ""
"In achtergrondmodus, kopieer bestandspad van schermafdruk naar klembord."

#. Tag: option
#: man-spectacle.1.docbook:177
#, no-c-format
msgid "-w, --onclick"
msgstr "-w, --onclick"

#. Tag: para
#: man-spectacle.1.docbook:179
#, no-c-format
msgid "Wait for a click before taking screenshot. Invalidates delay.."
msgstr ""
"Wacht op een klik alvorens een schermafdruk te nemen. Maakt vertraging "
"ongeldig.."

#. Tag: option
#: man-spectacle.1.docbook:184
#, no-c-format
msgid "-i, --new-instance"
msgstr "-i, --new-instance"

#. Tag: para
#: man-spectacle.1.docbook:186
#, no-c-format
msgid "Starts a new GUI instance of spectacle without registering to DBus."
msgstr ""
"Begint een nieuw GUI-exemplaar van spectacle zonder registratie bij DBus."

#. Tag: option
#: man-spectacle.1.docbook:191
#, no-c-format
msgid "-p, --pointer"
msgstr "-p, --pointer"

#. Tag: para
#: man-spectacle.1.docbook:193
#, no-c-format
msgid "In background mode, include pointer in the screenshot."
msgstr "In achtergrondmodus, aanwijzer meenemen in de schermafdruk."

#. Tag: option
#: man-spectacle.1.docbook:198
#, no-c-format
msgid "-e, --no-decoration"
msgstr "-e, --no-decoration"

#. Tag: para
#: man-spectacle.1.docbook:200
#, no-c-format
msgid ""
"In background mode, do not include window decorations in the screenshot."
msgstr ""
"In achtergrondmodus, geen vensterdecoraties meenemen in de schermafdruk."

#. Tag: option
#: man-spectacle.1.docbook:205
#, no-c-format
msgid "-E, --edit-existing <replaceable>existingFileName</replaceable>"
msgstr "-E, --edit-existing <replaceable>existingFileName</replaceable>"

#. Tag: para
#: man-spectacle.1.docbook:207
#, no-c-format
msgid "Open and edit existing screenshot file."
msgstr "Bestaand schermafdrukbestand openen en bewerken."

