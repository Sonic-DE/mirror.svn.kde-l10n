msgstr "<guimenu>Spel</guimenu> <guimenuitem>Vlootoverzicht…</guimenuitem>"

#. Tag: para
#: index.docbook:285
#, no-c-format
msgid ""
"<action>Opens a window</action> to display detailed information for all "
"fleets."
msgstr ""
"<action>Opent een venster</action> om gedetailleerde informatie over alle "
"vloten te tonen."

#. Tag: menuchoice
