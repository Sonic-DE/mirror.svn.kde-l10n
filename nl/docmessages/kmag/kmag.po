"verbergen</guimenuitem>"

#. Tag: para
#: index.docbook:415 index.docbook:482
#, no-c-format
msgid "Show or hide the mouse cursor in the magnified image."
msgstr "Toont of verbergt de muisaanwijzer in het vergrote gebied."

#. Tag: menuchoice
#: index.docbook:419
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> <keycap>F7</keycap></keycombo> </"
