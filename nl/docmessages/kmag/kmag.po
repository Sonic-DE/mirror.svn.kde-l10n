#. Tag: para
#: index.docbook:427 index.docbook:487
#, no-c-format
msgid "The &kmagnifier; window stays on top of other windows."
msgstr "Het venster van &kmagnifier; blijft boven andere vensters."

#. Tag: para
#: index.docbook:431
#, no-c-format
msgid ""
"Additionally &kmagnifier; has the common &kde; <guimenu>Settings</guimenu> "
"and <guimenu>Help</guimenu> menu items, for more information read the "
"sections about the <ulink url=\"help:/fundamentals/menus.html#menus-settings"
"\">Settings Menu</ulink> and <ulink url=\"help:/fundamentals/menus."
"html#menus-help\">Help Menu</ulink> of the &kde; Fundamentals."
msgstr ""
"Bovendien heeft &kmagnifier; de gezamenlijke menu-items van &kde; "
"<guimenu>Instellingen</guimenu> en <guimenu>Help</guimenu>, voor meer "
"informatie lees de secties over de <ulink url=\"help:/fundamentals/menus."
"html#menus-settings\">Menu-instellingen</ulink> en <ulink url=\"help:/"
"fundamentals/menus.html#menus-help\">Menu Help</ulink> van &kde;-"
"fundamentals."

#. Tag: title
#: index.docbook:442
#, no-c-format
msgid "Command Reference"
msgstr "Commandoreferentie"

#. Tag: para
#: index.docbook:444
#, no-c-format
msgid ""
"&kmagnifier; automatically uses all your default shortcuts for saving file, "
"opening new window, printing, starting/stopping refresh (reload button in "
"&konqueror;), zoom-in, zoom-out &etc;"
msgstr ""
"&kmagnifier; gebruikt automatisch al uw standaard sneltoetsen voor bestand "
"opslaan, nieuw venster openen, afdrukken, verversen starten/stoppen (knop "
"opnieuw/laden lossen in &konqueror;, inzoomen, uitzoomen, &etc;"

#. Tag: title
#: index.docbook:449
#, no-c-format
msgid "Default Keyboard Shortcuts"
msgstr "Standaardsneltoetsen"

#. Tag: keycombo
#: index.docbook:453
#, no-c-format
msgid "&Ctrl;<keycap>S</keycap>"
msgstr "&Ctrl;<keycap>S</keycap>"

#. Tag: para
#: index.docbook:454
#, no-c-format
msgid "This will save the contents of the zoom window to a file."
msgstr "Slaat de inhoud van het zoomvenster op naar een bestand."

#. Tag: keycap
#: index.docbook:459
#, no-c-format
msgid "<keycap>F2</keycap>"
msgstr "<keycap>F2</keycap>"

#. Tag: para
#: index.docbook:460
#, no-c-format
msgid "Switch to \"Follow Mouse Mode\"."
msgstr "Schakelt over naar de \"Muis volgen-modus\"."

#. Tag: keycap
#: index.docbook:464
#, no-c-format
msgid "<keycap>F3</keycap>"
msgstr "<keycap>F3</keycap>"

#. Tag: para
#: index.docbook:465
#, no-c-format
msgid "Switch to \"Selection Window Mode\"."
msgstr "Schakelt over naar de \"Selectievenstermodus\"."

#. Tag: keycap
#: index.docbook:469
#, no-c-format
msgid "<keycap>F4</keycap>"
msgstr "<keycap>F4</keycap>"

#. Tag: para
#: index.docbook:470
#, no-c-format
msgid "Switch to \"Whole Screen Mode\"."
msgstr "Schakelt over naar de \"Gehele scherm-modus\"."

#. Tag: keycap
#: index.docbook:474
#, no-c-format
msgid "<keycap>F5</keycap>"
msgstr "<keycap>F5</keycap>"

#. Tag: para
#: index.docbook:475
#, no-c-format
msgid ""
"This will start the refresh of the zoom window if it is stopped, or stops "
"the refresh of the zoom window if the refresh is currently on."
msgstr ""
"Start het verversen van het zoomvenster als het uit staat, of stopt het "
"verversen van het zoomvenster als verversen aan staat."

#. Tag: keycap
#: index.docbook:481
#, no-c-format
msgid "<keycap>F6</keycap>"
msgstr "<keycap>F6</keycap>"

#. Tag: keycap
#: index.docbook:486
#, no-c-format
msgid "<keycap>F7</keycap>"
msgstr "<keycap>F7</keycap>"

#. Tag: keycombo
#: index.docbook:491
#, no-c-format
msgid "&Ctrl;<keycap>N</keycap>"
msgstr "&Ctrl;<keycap>N</keycap>"

#. Tag: para
#: index.docbook:492
#, no-c-format
msgid "This will open a new &kmagnifier; window."
msgstr "Dit opent een nieuw &kmagnifier;-venster"

#. Tag: keycombo
#: index.docbook:495
#, no-c-format
msgid "&Ctrl;<keycap>P</keycap>"
msgstr "&Ctrl;<keycap>P</keycap>"

#. Tag: para
#: index.docbook:496
#, no-c-format
msgid ""
"This will open the print dialog for printing the contents of the zoom window."
msgstr ""
"Opent het printerdialoogvenster om de inhoud van het zoomvenster af te "
"drukken."

#. Tag: keycombo
#: index.docbook:500
#, no-c-format
msgid "&Ctrl;<keycap>C</keycap>"
msgstr "&Ctrl;<keycap>C</keycap>"

#. Tag: para
#: index.docbook:501
#, no-c-format
msgid "This will copy the zoom window contents to the clipboard."
msgstr "Kopieert de inhoud van het zoomvenster naar het klembord."

#. Tag: keycombo
#: index.docbook:506
#, no-c-format
msgid "&Ctrl;<keycap>M</keycap>"
msgstr "&Ctrl;<keycap>M</keycap>"

#. Tag: para
#: index.docbook:507
#, no-c-format
msgid "Show/Hide the menubar."
msgstr "Toont/verbergt de menubalk"

#. Tag: keycombo
#: index.docbook:511
#, no-c-format
msgid "&Ctrl;<keycap>-</keycap>"
msgstr "&Ctrl;<keycap>-</keycap>"

#. Tag: para
#: index.docbook:512
#, no-c-format
msgid "Zoom out"
msgstr "Uitzoomen"

#. Tag: keycombo
#: index.docbook:515
#, no-c-format
msgid "&Ctrl;<keycap>+</keycap>"
msgstr "&Ctrl;<keycap>+</keycap>"

#. Tag: para
#: index.docbook:516
#, no-c-format
msgid "Zoom in"
msgstr "Inzoomen"

#. Tag: keycombo
#: index.docbook:519
#, no-c-format
msgid "&Ctrl;<keycap>Q</keycap>"
msgstr "&Ctrl;<keycap>Q</keycap>"

#. Tag: para
#: index.docbook:520
#, no-c-format
msgid "Quits the application."
msgstr "Sluit de toepassing af"

