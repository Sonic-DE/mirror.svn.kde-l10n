#~ msgstr "--style &lt;stijl&gt;"

#~ msgid "sets the application GUI style"
#~ msgstr "Bepaalt de GUI-stijl van de toepassing"

#~ msgid "--geometry &lt;geometry&gt;"
#~ msgstr "--geometry &lt;geometrie&gt;"

#~ msgid ""
#~ "sets the client geometry of the main widget - see man X for the argument "
#~ "format"
#~ msgstr ""
#~ "stelt de clientafmeting van het hoofdwidget in - zie de manpagina's van X "
#~ "voor de argumentopmaak"

#~ msgid "--display &lt;displayname&gt;"
#~ msgstr "--display &lt;schermnaam&gt;"

#~ msgid "Use the X-server display 'displayname'"
#~ msgstr "Gebruik de X-serverdisplay 'displayname'"

#~ msgid "--session &lt;sessionId&gt;"
#~ msgstr "--session &lt;sessie-id&gt;"

#~ msgid "Restore the application for the given 'sessionId'"
#~ msgstr "De toepassing herstellen voor de gegeven 'sessionId'"

#~ msgid "--cmap"
#~ msgstr "--cmap"

#~ msgid ""
#~ "Causes the application to install a private color map on an 8-bit display"
#~ msgstr ""
#~ "Zorgt ervoor dat de toepassing een privé-kleurenschema op een 8-bit "
#~ "scherm gebruikt."

#~ msgid "--ncols &lt;count&gt;"
#~ msgstr "--ncols &lt;aantal&gt;"

#~ msgid ""
#~ "Limits the number of colors allocated in the color cube on an 8-bit "
#~ "display, if the application is using the QApplication::ManyColor color "
#~ "specification"
#~ msgstr ""
#~ "Beperkt het aantal toegekende kleuren in de kleurkubus op een 8-bit "
#~ "scherm, als de applicatie de kleurspecificatie QApplication::ManyColor "
