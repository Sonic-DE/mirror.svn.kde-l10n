#~ msgid "--nograb"
#~ msgstr "--nograb"

#~ msgid "tells Qt to never grab the mouse or the keyboard"
#~ msgstr "Vertelt Qt dat deze nooit de muis of toetsenbord mag overnemen"

#~ msgid "--dograb"
#~ msgstr "--dograb"

#~ msgid ""
#~ "running under a debugger can cause an implicit -nograb, use -dograb to "
#~ "override"
#~ msgstr ""
#~ "onder een debugger draaien kan een impliciete -nograb veroorzaken, "
#~ "gebruik -dograb om te forceren."

#~ msgid "--sync"
#~ msgstr "--sync"

#~ msgid "switches to synchronous mode for debugging"
#~ msgstr "Gaat over naar de synchrone modus voor het debuggen"

#~ msgid "--fn, --font &lt;fontname&gt;"
#~ msgstr "--fn, --font &lt;lettertypenaam&gt;"

#~ msgid "defines the application font"
#~ msgstr "Definieert het lettertype voor de toepassingen"

#~ msgid "--bg, --background &lt;color&gt;"
#~ msgstr "--bg, --background &lt;kleur&gt;"

#~ msgid ""
#~ "sets the default background color and an application palette (light and "
#~ "dark shades are calculated)"
#~ msgstr ""
#~ "stelt de standaard achtergrondkleur in en een toepassingspalet (lichte en "
#~ "donkere tinten worden berekend)"

#~ msgid "--fg, --foreground &lt;color&gt;"
#~ msgstr "--fg, --foreground &lt;kleur&gt;"

#~ msgid "sets the default foreground color"
#~ msgstr "Bepaalt de standaard kleur van de voorgrond"

#~ msgid "--btn, --button &lt;color&gt;"
#~ msgstr "--btn, --button &lt;kleur&gt;"

#~ msgid "sets the default button color"
#~ msgstr "Bepaalt de standaard kleur van de knoppen"

#~ msgid "--name &lt;name&gt;"
#~ msgstr "--name &lt;naam&gt;"

#~ msgid "sets the application name"
#~ msgstr "Bepaalt de naam van de toepassing"

#~ msgid "--title &lt;title&gt;"
#~ msgstr "--title &lt;titel&gt;"

#~ msgid "sets the application title (caption)"
#~ msgstr "bepaalt de titel van de toepassing (caption)"

#~ msgid "--visual TrueColor"
#~ msgstr "--visual TrueColor"

#~ msgid "forces the application to use a TrueColor visual on an 8-bit display"
#~ msgstr ""
#~ "dwingt de toepassing om een TrueColor uiterlijk op een 8-bits scherm te "
#~ "gebruiken."

#~ msgid "--inputstyle &lt;inputstyle&gt;"
#~ msgstr "--inputstyle &lt;invoerstijl&gt;"

#~ msgid ""
#~ "sets XIM (X Input Method) input style. Possible values are onthespot, "
#~ "overthespot, offthespot and root"
#~ msgstr ""
#~ "stelt de XIM (X Input Method)-invoermethode in. Mogelijke waarden zijn "
#~ "\"onthespot\", \"overthespot\", \"offthespot\" en \"root\" (allen zonder "
#~ "aanhalingstekens)."

#~ msgid "--im &lt;XIM server&gt;"
#~ msgstr "--im &lt;XIM-server&gt;"

#~ msgid "set XIM server"
#~ msgstr "XIM-server instellen"

#~ msgid "--noxim"
#~ msgstr "--noxim"

#~ msgid "disable XIM"
#~ msgstr "XIM uitschakelen"

#~ msgid "--reverse"
#~ msgstr "--reverse"

#~ msgid "mirrors the whole layout of widgets"
#~ msgstr "spiegelt de hele opmaak van widgets"

#~ msgid "--stylesheet &lt;file.qss&gt;"
#~ msgstr "--stylesheet &lt;bestand.qss&gt;"

#~ msgid "applies the Qt stylesheet to the application widgets"
#~ msgstr "past de Qt-stijlbladen toe op programmawidgets"

