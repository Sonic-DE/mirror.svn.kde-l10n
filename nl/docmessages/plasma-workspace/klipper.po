#~ "(<keycombo action=\"simul\">&Alt;<keycap>D</keycap></keycombo>, "
#~ "<keycap>S</keycap>)."
#~ msgstr ""
#~ "Om het &klipper;-widget uit te schakelen, maakt u de activering ongedaan "
