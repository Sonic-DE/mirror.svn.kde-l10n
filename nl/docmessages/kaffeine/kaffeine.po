msgstr "<action>Maakt een nieuwe afspeellijst aan</action>."

#. Tag: menuchoice
#: index.docbook:1274
#, no-c-format
msgid "<guimenu>Playlist</guimenu> <guimenuitem>Rename</guimenuitem>"
msgstr "<guimenu>Afspeellijst</guimenu> <guimenuitem>Hernoemen</guimenuitem>"

#. Tag: para
#: index.docbook:1279
#, no-c-format
msgid "<action>Rename the current playlist</action>."
msgstr "<action>De huidige afspeellijst hernoemen</action>."

#. Tag: menuchoice
#: index.docbook:1284
#, no-c-format
msgid "<guimenu>Playlist</guimenu> <guimenuitem>Remove</guimenuitem>"
msgstr "<guimenu>Afspeellijst</guimenu> <guimenuitem>Verwijderen</guimenuitem>"

#. Tag: para
#: index.docbook:1289
#, no-c-format
msgid "<action>Remove the current playlist</action>."
msgstr "<action>De huidige afspeellijst verwijderen</action>."

#. Tag: menuchoice
#: index.docbook:1294
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>S</keycap></keycombo> </"
"shortcut> <guimenu>Playlist</guimenu> <guimenuitem>Save</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>S</keycap></keycombo> </"
"shortcut> <guimenu>Afspeellijst</guimenu> <guimenuitem>Opslaan</guimenuitem>"

#. Tag: para
#: index.docbook:1302
#, no-c-format
msgid "<action>Save the current playlist</action>."
msgstr "<action>De huidige afspeellijst opslaan</action>."

#. Tag: menuchoice
#: index.docbook:1307
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>S</keycap></"
"keycombo> </shortcut> <guimenu>Playlist</guimenu> <guimenuitem>Save As...</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>S</keycap></"
"keycombo> </shortcut> <guimenu>Afspeellijst</guimenu> <guimenuitem>Opslaan "
"als...</guimenuitem>"

#. Tag: para
#: index.docbook:1315
#, no-c-format
msgid "<action>Save the current playlist with a new name</action>."
msgstr "<action>De huidige afspeellijst opslaan met een nieuwe naam</action>."

#. Tag: title
#: index.docbook:1323
#, no-c-format
msgid "The Television Menu"
msgstr "Het televisiemenu"

#. Tag: menuchoice
#: index.docbook:1328
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"><keycap>C</keycap></keycombo> </"
"shortcut> <guimenu>Television</guimenu> <guimenuitem>Channels</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"><keycap>C</keycap></keycombo> </"
"shortcut> <guimenu>Televisie</guimenu> <guimenuitem>Kanalen</guimenuitem>"

#. Tag: action
#: index.docbook:1336
#, no-c-format
msgid ""
"A settings panel will appear for <action>set the channels</action> "
"corresponding to your area. See <link linkend=\"dtv-channel-setup\">Digital "
"TV channel setup</link> section for more details."
msgstr ""
"Er zal een instellingenpaneel verschijnen voor <action>instellen van de de "
"kanalen</action> overeenkomend met uw gebied. Zie de sectie <link linkend="
"\"dtv-channel-setup\">Instellingen Digitale TV-kanalen</link> voor meer "
"details."

#. Tag: menuchoice
#: index.docbook:1341
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"><keycap>G</keycap></keycombo> </"
"shortcut> <guimenu>Television</guimenu> <guimenuitem>Program Guide</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"><keycap>G</keycap></keycombo> </"
"shortcut> <guimenu>Televisie</guimenu> <guimenuitem>Programmagids</"
"guimenuitem>"

#. Tag: para
#: index.docbook:1349
#, no-c-format
msgid ""
"A window will appear for <action>manage the program guide</action>. See "
"<link linkend=\"program-guide\">Program Guide</link> section for more "
"details."
msgstr ""
"Er zal een venster verschijnen voor <action>de programmagids beheren</"
"action>. Zie de sectie <link linkend=\"program-guide\">Programmagids</link> "
"voor meer details."

#. Tag: menuchoice
#: index.docbook:1354
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"><keycap>O</keycap></keycombo> </"
"shortcut> <guimenu>Television</guimenu> <guimenuitem>OSD</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"><keycap>O</keycap></keycombo> </"
"shortcut> <guimenu>Televisie</guimenu> <guimenuitem>OSD</guimenuitem>"

#. Tag: para
#: index.docbook:1362
#, no-c-format
msgid ""
"<action>Show the on screen display infobox on the playback window during "
"three seconds</action> with program guide information on the current and "
"next program. Double-clicking on it to see extended information about the "
"current program, and then click again to remove this infobox. See <ulink url="
"\"https://en.wikipedia.org/wiki/On-screen_display\">Wikipedia</ulink> "
"article for more details."
msgstr ""
"<action>Toont het on-screen informatievak op het afspeelvenster gedurende "
"drie seconden</action> met informatie uit de programmagids over het huidige "
