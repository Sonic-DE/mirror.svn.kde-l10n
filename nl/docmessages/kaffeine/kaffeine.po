"<shortcut> <keycombo action=\"simul\">&Right;</keycombo> </shortcut> "
"<guimenu>Playback</guimenu> <guisubmenu>Skip</guisubmenu> <guimenuitem>Skip "
"15s Forward</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Right;</keycombo> </shortcut> "
"<guimenu>Afspelen</guimenu> <guisubmenu>Overslaan</guisubmenu> "
"<guimenuitem>15s vooruit overslaan</guimenuitem>"

#. Tag: para
#: index.docbook:1163
#, no-c-format
msgid "<action>It goes 15 seconds forward</action>."
msgstr "<action>Het gaat 15 seconden vooruit</action>."

#. Tag: menuchoice
#: index.docbook:1168
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Shift;&Right;</keycombo> </shortcut> "
"<guimenu>Playback</guimenu> <guisubmenu>Skip</guisubmenu> <guimenuitem>Skip "
"60s Forward</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Shift;&Right;</keycombo> </shortcut> "
"<guimenu>Afspelen</guimenu> <guisubmenu>Overslaan</guisubmenu> "
"<guimenuitem>60s vooruit overslaan</guimenuitem>"

#. Tag: para
#: index.docbook:1177
#, no-c-format
msgid "<action>It goes 60 seconds forward</action>."
msgstr "<action>Het gaat 60 seconden vooruit</action>."

#. Tag: menuchoice
#: index.docbook:1186
#, no-c-format
msgid "<guimenu>Playback</guimenu> <guimenuitem>DVD Menu</guimenuitem>"
msgstr "<guimenu>Afspelen</guimenu> <guimenuitem>DVD-menu</guimenuitem>"

#. Tag: para
#: index.docbook:1191
#, no-c-format
msgid ""
"<action>Start with the original &DVD; graphic menu</action>. That is "
"explored using the cursor keys and the mouse. See <ulink url=\"https://en."
"wikipedia.org/wiki/DVD-Video\">Wikipedia</ulink> article for more details."
msgstr ""
"<action>Start met het originele &DVD; grafische menu</action>. Dat kan "
"bekeken worden met de cursortoetsen en de muis. Zie het <ulink url=\"https://"
"en.wikipedia.org/wiki/DVD-Video\">Wikipedia</ulink> artikel voor meer "
"details."

#. Tag: menuchoice
#: index.docbook:1196
#, no-c-format
msgid "<guimenu>Playback</guimenu> <guimenuitem>Title</guimenuitem>"
msgstr "<guimenu>Afspelen</guimenu> <guimenuitem>Titel</guimenuitem>"

#. Tag: para
#: index.docbook:1200
#, no-c-format
msgid ""
"<action>The &DVD; content is divided into titles to easy navigation</"
"action>. From here you can go directly."
msgstr ""
"<action>De inhoud van de &DVD; is opgedeeld in titels om gemakkelijk te "
"navigeren</action>. Vanaf hier kunt u er direct naar toe."

#. Tag: menuchoice
#: index.docbook:1206
#, no-c-format
msgid "<guimenu>Playback</guimenu> <guimenuitem>Chapter</guimenuitem>"
msgstr "<guimenu>Afspelen</guimenu> <guimenuitem>Hoofdstuk</guimenuitem>"

#. Tag: para
#: index.docbook:1210
#, no-c-format
msgid ""
"<action>The &DVD; content is divided into chapters to easy navigation</"
"action>. From here you can go directly."
msgstr ""
"<action>De inhoud van de &DVD; is opgedeeld in hoofdstukken om gemakkelijk "
"te navigeren</action>. Vanaf hier kunt u er direct naar toe."

#. Tag: menuchoice
#: index.docbook:1216
#, no-c-format
msgid "<guimenu>Playback</guimenu> <guimenuitem>Angle</guimenuitem>"
msgstr "<guimenu>Afspelen</guimenu> <guimenuitem>Hoek</guimenuitem>"

#. Tag: para
#: index.docbook:1220
#, no-c-format
msgid ""
"<action>A variant of the chapters: it is possible that they have included "
"several versions</action> (called <quote>angles</quote>) of certain scenes. "
"From here you can go directly."
msgstr ""
"<action>Een variant van de hoofdstukken: het is mogelijk dat er "
"verschillende versies zijn ingevoegd</action> (genaamd <quote>hoeken</"
"quote>) van bepaalde scènes. Vanaf hier kunt u er direct heen."

#. Tag: title
#: index.docbook:1229
#, no-c-format
msgid "The Playlist Menu"
msgstr "Het menu Afspeellijst"

