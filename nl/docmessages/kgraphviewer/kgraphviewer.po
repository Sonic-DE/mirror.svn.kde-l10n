#. Tag: title
#: index.docbook:75
#, no-c-format
msgid "Introduction"
msgstr "Inleiding"

#. Tag: para
#: index.docbook:77
#, no-c-format
msgid ""
"&kgraphviewer; is a &graphviz; &dot; graph viewer. The &graphviz; programs "
"are free-software layout engines for graphs. &kgraphviewer; displays the "
"graphs in a modern, user-friendly &GUI;. It has the following features:"
msgstr ""
"&kgraphviewer; is een &graphviz; &dot; graph viewer. De &graphviz; "
"programma's is vrije-software voor opmaak-engines voor grafieken. "
"&kgraphviewer; toont de grafieken met behulp van een modern "
"gebruikersvriendelijke &GUI; Het heeft de volgende mogelijkheden:"

#. Tag: screeninfo
#: index.docbook:80
#, no-c-format
msgid "Here is a screenshot of &kgraphviewer;"
msgstr "Hier is een schermafdruk van &kgraphviewer;"

