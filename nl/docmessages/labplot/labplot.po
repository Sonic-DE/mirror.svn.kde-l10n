"methode van Laczos."

#. Tag: entry
#: index.docbook:1922
#, no-c-format
msgid "fact(n)"
msgstr "fact(n)"

#. Tag: action
#: index.docbook:1922
#, no-c-format
msgid "factorial n!"
msgstr "n faculteit, n!"

