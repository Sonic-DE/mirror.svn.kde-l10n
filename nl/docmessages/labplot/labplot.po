#: index.docbook:1914
#, no-c-format
msgid "Fj(j,x)"
msgstr "Fj(j,x)"

#. Tag: action
#: index.docbook:1914
#, no-c-format
msgid ""
"complete Fermi-Dirac integral with an index of j, F<subscript>j</"
"subscript>(x) = (1/&Gamma;(j+1)) &int;<subscript>0</"
"subscript><superscript>&infin;</superscript> (t<superscript>j</superscript> /"
"(exp(t-x)+1)) dt"
msgstr ""
"complete Fermi-Dirac integraal met index j, F<subscript>j</subscript>(x) = "
"(1/&Gamma;(j+1)) &int;<subscript>0</subscript><superscript>&infin;</"
"superscript> (t<superscript>j</superscript> /(exp(t-x)+1)) dt"

#. Tag: entry
#: index.docbook:1915
#, no-c-format
msgid "Fmhalf(x)"
msgstr "Fmhalf(x)"

#. Tag: action
#: index.docbook:1915
#, no-c-format
msgid "complete Fermi-Dirac integral F<subscript>-1/2</subscript>(x)"
msgstr "complete Fermi-Dirac integraal F<subscript>-1/2</subscript>(x)"

#. Tag: entry
#: index.docbook:1916
#, no-c-format
msgid "Fhalf(x)"
msgstr "Fhalf(x)"

#. Tag: action
#: index.docbook:1916
#, no-c-format
msgid "complete Fermi-Dirac integral F<subscript>1/2</subscript>(x)"
msgstr "complete Fermi-Dirac integraal F<subscript>1/2</subscript>(x)"

#. Tag: entry
#: index.docbook:1917
#, no-c-format
msgid "F3half(x)"
msgstr "F3half(x)"

