msgstr ""
"(exp(x)-1)/x met gebruik van een algoritme dat voor kleine waarden van x "
"nauwkeurig is"

#. Tag: entry
#: index.docbook:1898
#, no-c-format
msgid "exprel2(x)"
msgstr "exprel2(x)"

#. Tag: action
#: index.docbook:1898
#, no-c-format
msgid ""
"2(exp(x)-1-x)/x<superscript>2</superscript> using an algorithm that is "
"accurate for small x"
msgstr ""
"2(exp(x)-1-x)/x<superscript>2</superscript> met een algoritme dat nauwkeurig "
"is voor kleine waarden van x"

#. Tag: entry
#: index.docbook:1899
#, no-c-format
msgid "expreln(n,x)"
msgstr "expreln(n,x)"

#. Tag: action
#: index.docbook:1899
#, no-c-format
msgid ""
"n-relative exponential, which is the n-th generalization of the functions "
"`exprel'"
msgstr ""
"n-relatieve exponentiële functie, die de n-de generalisatie is van de "
"`exprel'-functies"

#. Tag: entry
#: index.docbook:1900
#, no-c-format
msgid "E1(x)"
msgstr "E1(x)"

#. Tag: action
#: index.docbook:1900
#, no-c-format
msgid ""
"exponential integral E<subscript>1</subscript>(x), E<subscript>1</"
"subscript>(x) := Re &int;<subscript>1</subscript><superscript>&infin;</"
"superscript> exp(-xt)/t dt"
msgstr ""
"exponentiële integraal E<subscript>1</subscript>(x), E<subscript>1</"
"subscript>(x) := Re &int;<subscript>1</subscript><superscript>&infin;</"
"superscript> exp(-xt)/t dt"

#. Tag: entry
#: index.docbook:1901
#, no-c-format
msgid "E2(x)"
msgstr "E2(x)"

#. Tag: action
#: index.docbook:1901
#, no-c-format
msgid ""
"second-order exponential integral E<subscript>2</subscript>(x), "
"E<subscript>2</subscript>(x) := Re &int;<subscript>1</"
"subscript><superscript>&infin;</superscript> exp(-xt)/t<superscript>2</"
"superscript> dt"
msgstr ""
"tweede orde exponentiële integraal E<subscript>2</subscript>(x), "
"E<subscript>2</subscript>(x) := Re &int;<subscript>1</"
"subscript><superscript>&infin;</superscript> exp(-xt)/t<superscript>2</"
"superscript> dt"

#. Tag: entry
#: index.docbook:1902
#, no-c-format
msgid "En(x)"
msgstr "En(x)"

#. Tag: action
#: index.docbook:1902
#, no-c-format
msgid ""
"exponential integral E_n(x) of order n, E<subscript>n</subscript>(x) := Re "
"&int;<subscript>1</subscript><superscript>&infin;</superscript> exp(-xt)/"
"t<superscript>n</superscript> dt)"
msgstr ""
"exponentiële integraal E_n(x) van orde n, E<subscript>n</subscript>(x) := Re "
"&int;<subscript>1</subscript><superscript>&infin;</superscript> exp(-xt)/"
"t<superscript>n</superscript> dt)"

#. Tag: entry
#: index.docbook:1903
#, no-c-format
msgid "Ei(x)"
msgstr "Ei(x)"

#. Tag: action
#: index.docbook:1903
#, no-c-format
msgid ""
"exponential integral E_i(x), Ei(x) := PV(&int;<subscript>-x</"
"subscript><superscript>&infin;</superscript> exp(-t)/t dt)"
msgstr ""
"exponentiële integraal E_i(x), Ei(x) := PV(&int;<subscript>-x</"
"subscript><superscript>&infin;</superscript> exp(-t)/t dt)"

#. Tag: entry
#: index.docbook:1904
#, no-c-format
msgid "shi(x)"
msgstr "shi(x)"

#. Tag: action
#: index.docbook:1904
#, no-c-format
msgid ""
"Shi(x) = &int;<subscript>0</subscript><superscript>x</superscript> sinh(t)/t "
"dt"
msgstr ""
"Shi(x) = &int;<subscript>0</subscript><superscript>x</superscript> sinh(t)/t "
"dt"

#. Tag: entry
#: index.docbook:1905
#, no-c-format
msgid "chi(x)"
msgstr "chi(x)"

#. Tag: action
#: index.docbook:1905
#, no-c-format
msgid ""
"integral Chi(x) := Re[ &gamma;<subscript>E</subscript> + log(x) + &int;"
"<subscript>0</subscript><superscript>x</superscript> (cosh[t]-1)/t dt ]"
msgstr ""
"integraal Chi(x) := Re[ &gamma;<subscript>E</subscript> + log(x) + &int;"
"<subscript>0</subscript><superscript>x</superscript> (cosh[t]-1)/t dt ]"

#. Tag: entry
#: index.docbook:1906
#, no-c-format
msgid "Ei3(x)"
msgstr "Ei3(x)"

#. Tag: action
#: index.docbook:1906
#, no-c-format
msgid ""
"exponential integral Ei<subscript>3</subscript>(x) = &int;<subscript>0</"
"subscript><superscript>x</superscript> exp(-t<superscript>3</superscript>) "
"dt for x &gt;= 0"
msgstr ""
"exponentiële integraal Ei<subscript>3</subscript>(x) = &int;<subscript>0</"
"subscript><superscript>x</superscript> exp(-t<superscript>3</superscript>) "
"dt voor x &gt;= 0"

#. Tag: entry
#: index.docbook:1907
#, no-c-format
msgid "si(x)"
msgstr "si(x)"

#. Tag: action
#: index.docbook:1907
#, no-c-format
msgid ""
"Sine integral Si(x) = &int;<subscript>0</subscript><superscript>x</"
"superscript> sin(t)/t dt"
msgstr ""
"Sinus integraal Si(x) = &int;<subscript>0</subscript><superscript>x</"
"superscript> sin(t)/t dt"

#. Tag: entry
#: index.docbook:1908
#, no-c-format
msgid "ci(x)"
msgstr "ci(x)"

#. Tag: action
#: index.docbook:1908
#, no-c-format
msgid ""
"Cosine integral Ci(x) = -&int;<subscript>x</subscript><superscript>&infin;</"
"superscript> cos(t)/t dt for x &gt; 0"
msgstr ""
"Cosinus integraal Ci(x) = -&int;<subscript>x</subscript><superscript>&infin;"
"</superscript> cos(t)/t dt voor x &gt; 0"

#. Tag: entry
#: index.docbook:1909
#, no-c-format
msgid "atanint(x)"
msgstr "atanint(x)"

#. Tag: action
#: index.docbook:1909
#, no-c-format
msgid ""
"Arctangent integral AtanInt(x) = &int;<subscript>0</"
"subscript><superscript>x</superscript> arctan(t)/t dt"
msgstr ""
"Arctangens integraal AtanInt(x) = &int;<subscript>0</"
"subscript><superscript>x</superscript> arctan(t)/t dt"

#. Tag: entry
#: index.docbook:1910
#, no-c-format
msgid "Fm1(x)"
msgstr "Fm1(x)"

#. Tag: action
#: index.docbook:1910
#, no-c-format
msgid ""
"complete Fermi-Dirac integral with an index of -1, F<subscript>-1</"
"subscript>(x) = e<superscript>x</superscript> / (1 + e<superscript>x</"
"superscript>)"
msgstr ""
"complete Fermi-Dirac integraal met index -1, F<subscript>-1</subscript>(x) = "
"e<superscript>x</superscript> / (1 + e<superscript>x</superscript>)"

#. Tag: entry
#: index.docbook:1911
#, no-c-format
msgid "F0(x)"
msgstr "F0(x)"

#. Tag: action
#: index.docbook:1911
#, no-c-format
msgid ""
"complete Fermi-Dirac integral with an index of 0, F<subscript>0</"
"subscript>(x) = ln(1 + e<superscript>x</superscript>)"
msgstr ""
"complete Fermi-Dirac integraal met index 0, F<subscript>0</subscript>(x) = "
"ln(1 + e<superscript>x</superscript>)"

#. Tag: entry
#: index.docbook:1912
#, no-c-format
msgid "F1(x)"
msgstr "F1(x)"

#. Tag: action
#: index.docbook:1912
#, no-c-format
msgid ""
"complete Fermi-Dirac integral with an index of 1, F<subscript>1</"
"subscript>(x) = &int;<subscript>0</subscript><superscript>&infin;</"
"superscript> (t /(exp(t-x)+1)) dt"
msgstr ""
"complete Fermi-Dirac integraal met index 1, F<subscript>1</subscript>(x) = "
"&int;<subscript>0</subscript><superscript>&infin;</superscript> (t /(exp(t-"
"x)+1)) dt"

#. Tag: entry
#: index.docbook:1913
#, no-c-format
msgid "F2(x)"
msgstr "F2(x)"

#. Tag: action
#: index.docbook:1913
#, no-c-format
msgid ""
"complete Fermi-Dirac integral with an index of 2, F<subscript>2</"
"subscript>(x) = (1/2) &int;<subscript>0</subscript><superscript>&infin;</"
"superscript> (t<superscript>2</superscript> /(exp(t-x)+1)) dt"
msgstr ""
"complete Fermi-Dirac integraal met index 2, F<subscript>2</subscript>(x) = "
"(1/2) &int;<subscript>0</subscript><superscript>&infin;</superscript> "
"(t<superscript>2</superscript> /(exp(t-x)+1)) dt"

