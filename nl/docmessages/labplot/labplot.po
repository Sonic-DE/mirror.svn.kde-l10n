#, no-c-format
msgid ""
"Gegenbauer polynomial C<superscript>&lambda;</superscript><subscript>3</"
"subscript>(x)"
msgstr ""
"Gegenbauer veelterm C<superscript>&lambda;</superscript><subscript>3</"
"subscript>(x)"

#. Tag: entry
