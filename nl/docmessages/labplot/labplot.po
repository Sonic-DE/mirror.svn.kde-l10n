msgstr "logaritme van de Beta Functie, log(B(a,b)) voor a &gt; 0, b &gt; 0"

#. Tag: entry
#: index.docbook:1937
#, no-c-format
msgid "betainc(a,b,x)"
msgstr "betainc(a,b,x)"

#. Tag: action
#: index.docbook:1937
#, no-c-format
msgid ""
"normalize incomplete Beta function B_x(a,b)/B(a,b) for a &gt; 0, b &gt; 0"
msgstr ""
"genormaliseerde incomplete Beta functie B_x(a,b)/B(a,b) voor a &gt; 0, b "
"&gt; 0"

