"Beta Function, B(a,b) = &Gamma;(a) &Gamma;(b)/&Gamma;(a+b) for a &gt; 0, b "
"&gt; 0"
msgstr ""
"Beta Functie, B(a,b) = &Gamma;(a) &Gamma;(b)/&Gamma;(a+b) voor a &gt; 0, b "
"&gt; 0"

#. Tag: entry
#: index.docbook:1936
#, no-c-format
msgid "lnbeta(a,b)"
msgstr "lnbeta(a,b)"

