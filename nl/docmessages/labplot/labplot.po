#: index.docbook:1917
#, no-c-format
msgid "complete Fermi-Dirac integral F<subscript>3/2</subscript>(x)"
msgstr "complete Fermi-Dirac integraal F<subscript>3/2</subscript>(x)"

#. Tag: entry
#: index.docbook:1918
#, no-c-format
msgid "Finc0(x,b)"
msgstr "Finc0(x,b)"

