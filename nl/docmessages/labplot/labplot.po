#: index.docbook:1929
#, no-c-format
msgid ""
"Pochhammer symbol (a)<subscript>x</subscript> := &Gamma;(a + x)/&Gamma;(x)"
msgstr ""
"Pochhammer symbool (a)<subscript>x</subscript> := &Gamma;(a + x)/&Gamma;(x)"

