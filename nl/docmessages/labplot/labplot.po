#: index.docbook:1920
#, no-c-format
msgid "gammastar(x)"
msgstr "gammastar(x)"

#. Tag: action
#: index.docbook:1920
#, no-c-format
msgid ""
"regulated Gamma Function &Gamma;<superscript>*</superscript>(x) for x &gt; 0"
msgstr ""
"regulated Gamma Function &Gamma;<superscript>*</superscript>(x) for x &gt; 0"

