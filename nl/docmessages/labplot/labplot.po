#: index.docbook:1934
#, no-c-format
msgid ""
"complementary normalized incomplete Gamma Function P(a,x) = 1/&Gamma;(a) "
"&int;<subscript>0</subscript><superscript>x</superscript> t<superscript>a-1</"
"superscript> exp(-t) dt for a &gt; 0, x &gt;= 0"
msgstr ""
"complementaire genormaliseerde incomplete Gamma Function P(a,x) = 1/&Gamma;"
"(a) &int;<subscript>0</subscript><superscript>x</superscript> "
"t<superscript>a-1</superscript> exp(-t) dt voor a &gt; 0, x &gt;= 0"

#. Tag: entry
#: index.docbook:1935
#, no-c-format
