#. Tag: para
#: index.docbook:36
#, no-c-format
msgid ""
"&atlantik; is a client for playing &Monopoly;-like board games on the "
"&monopd; network."
msgstr ""
"&atlantik; is een client voor het spelen van &Monopoly;-achtige bordspellen "
"op het &monopd;-netwerk."

#. Tag: keyword
#: index.docbook:44
#, no-c-format
msgid "<keyword>KDE</keyword>"
msgstr "<keyword>KDE</keyword>"

#. Tag: keyword
#: index.docbook:45
#, no-c-format
msgid "network client"
msgstr "netwerkclient"

#. Tag: keyword
#: index.docbook:46
#, no-c-format
