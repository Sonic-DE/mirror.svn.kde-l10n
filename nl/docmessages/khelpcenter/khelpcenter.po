#~ msgid ""
#~ "Boolean syntax lets you use the operators <literal>AND</literal>, "
#~ "<literal>OR</literal> and <literal>NOT</literal> to create complex "
#~ "searches. Some examples:"
#~ msgstr ""
#~ "Booleaanse syntaxis laat u de operators <literal>AND</literal>, "
#~ "<literal>OR</literal> en <literal>NOT</literal> gebruiken om complexe "
#~ "zoekopdrachten te maken. Enige voorbeelden:"

#~ msgid "cat and dog"
#~ msgstr "kat and hond"

#~ msgid ""
#~ "Searches for pages which have both the words <userinput>cat</userinput> "
#~ "and <userinput>dog</userinput> in them. Pages with only one or the other "
#~ "will not be returned."
#~ msgstr ""
#~ "Zoeken naar pagina's die zowel de woorden <userinput>kat</userinput> als "
#~ "<userinput>hond</userinput> bevatten. Pagina's met slechts het ene of het "
#~ "andere zullen niet worden teruggegeven."

#~ msgid "cat not dog"
#~ msgstr "kat not hond"

#~ msgid ""
#~ "Searches for pages with <userinput>cat</userinput> in them, but only "
#~ "returns the ones that don't have the word <userinput>dog</userinput> in "
#~ "them."
#~ msgstr ""
#~ "Zoeken naar pagina's met <userinput>kat</userinput> er in, maar geeft "
#~ "deze alleen die niet het woord <userinput>hond</userinput> bevatten."

#~ msgid "cat or (dog not nose)"
#~ msgstr "kat or (hond not neus)"

#~ msgid ""
#~ "Searches for pages which contain <userinput>cat</userinput>, and for "
#~ "pages which contain <userinput>dog</userinput> but don't contain "
#~ "<userinput>nose</userinput>. Pages which contain both <userinput>cat</"
#~ "userinput> and <userinput>nose</userinput> would be returned, pages "
#~ "containing all three words would not."
#~ msgstr ""
#~ "Zoeken naar pagina's die <userinput>kat</userinput> bevatten en naar "
#~ "pagina's die <userinput>hond</userinput> bevatten maar niet "
#~ "<userinput>neus</userinput>. Pagina's die zowel <userinput>kat</"
#~ "userinput> als <userinput>neus</userinput> bevatten zouden worden "
#~ "teruggegeven, pagina's met alle drie woorden niet."

