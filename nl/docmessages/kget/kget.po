msgstr "<screeninfo>Schermafdruk van &kget; Laten-vallen-doel</screeninfo>"

#. Tag: phrase
#: index.docbook:87
#, no-c-format
msgid "<phrase>Screenshot of &kget; drop target</phrase>"
msgstr "<phrase>Schermafdruk van &kget; Laten-vallen-doel</phrase>"

#. Tag: title
#: index.docbook:93
#, no-c-format
msgid "&kget; Drop Target options"
msgstr "De opties van het &kget; Laten-vallen-doel"

#. Tag: para
#: index.docbook:94
#, no-c-format
msgid "Right click on the drop target to see the options."
msgstr "Rechtsklikken op het laten-vallen-doel laat de opties zien."

#. Tag: menuchoice
#: index.docbook:101
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>R</keycap></keycombo> </"
"shortcut> <guimenuitem>Start / Resume All</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>R</keycap></keycombo> </"
"shortcut> <guimenuitem>Alles starten/hervatten</guimenuitem>"

#. Tag: action
#: index.docbook:110
#, no-c-format
msgid ""
"To start a download or resume all the pending downloads. The shortcut for "
"doing this is <keycombo action=\"simul\">&Ctrl;<keycap>R</keycap></keycombo>"
msgstr ""
"Om een download te starten of alle wachtende downloads verder te laten gaan. "
"De sneltoets om dit te doen is <keycombo action=\"simul\">&Ctrl;<keycap>R</"
"keycap></keycombo>"

#. Tag: guimenuitem
#: index.docbook:118
#, no-c-format
msgid "Show/Hide Main Window"
msgstr "Hoofdvenster tonen/verbergen"

#. Tag: action
#: index.docbook:123
#, no-c-format
msgid "This option shows or minimizes the main window to the system tray."
msgstr "Deze optie toont of minimaliseert het hoofdvenster in het systeemvak."

#. Tag: guimenuitem
#: index.docbook:130
#, no-c-format
msgid "Sticky"
msgstr "Vastgezet"

#. Tag: action
#: index.docbook:135
#, no-c-format
msgid "Makes the &kget; drop target undraggable."
msgstr "Maakt dat het valdoel van &kget; niet meer versleept worden."

#. Tag: guimenuitem
#: index.docbook:143
#, no-c-format
msgid "Quit &kget;"
msgstr "Beëindig &kget;"

#. Tag: action
#: index.docbook:148 index.docbook:698
#, no-c-format
msgid "Quits &kget;"
msgstr "Beëindigt &kget;"

