#: index.docbook:74
#, no-c-format
msgid "&kget; Drop Target"
msgstr "&kget; Laten-vallen-doel"

#. Tag: para
#: index.docbook:76
#, no-c-format
msgid "The &kget; Drop Target has four options."
msgstr "Het &kget; Doel-laten-vallen heeft vier opties."

#. Tag: screeninfo
#: index.docbook:81
#, no-c-format
