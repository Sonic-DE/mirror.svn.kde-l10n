msgstr "Instellingenvenster van &kget;"

#. Tag: menuchoice
#: index.docbook:160
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Configure &kget;</guimenuitem>"
msgstr ""
"<guimenu>Instellingen</guimenu> <guimenuitem>&kget; instellen</guimenuitem>"

#. Tag: action
#: index.docbook:164
#, no-c-format
msgid "Opens the &kget; configuration window"
msgstr "Opent het instellingenvenster van &kget;"

