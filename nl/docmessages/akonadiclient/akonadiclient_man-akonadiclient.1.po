#: man-akonadiclient.1.docbook:444
#, no-c-format
msgid "-l, --list"
msgstr "-l, --list"

#. Tag: para
#: man-akonadiclient.1.docbook:445
#, no-c-format
msgid "List all agents"
msgstr "Toon alle agents"

#. Tag: option
#: man-akonadiclient.1.docbook:449
#, no-c-format
msgid "-s, --setstate <replaceable>state</replaceable>"
msgstr "-s, --setstate <replaceable>status</replaceable>"

#. Tag: para
#: man-akonadiclient.1.docbook:450
#, no-c-format
msgid ""
"Set the state for specified agents. Valid states are 'offline' and 'online'."
msgstr ""
"Stelt de status in van gespecificeerde agents. Geldige statussen zijn "
"'offline' en 'online'."

#. Tag: option
#: man-akonadiclient.1.docbook:454
#, no-c-format
msgid "-g, --getstate"
msgstr "-g, --getstate"

#. Tag: para
#: man-akonadiclient.1.docbook:455
#, no-c-format
msgid "Get the state for specified agents"
msgstr "Haal de status van gespecificeerde agents op"

#. Tag: option
#: man-akonadiclient.1.docbook:459
#, no-c-format
msgid "-i, --info"
msgstr "-i, --info"

#. Tag: para
#: man-akonadiclient.1.docbook:460
#, no-c-format
msgid "Show information about the specified agents"
msgstr "Toon informatie over de gespecificeerde agents"

#. Tag: option
#: man-akonadiclient.1.docbook:464
#, no-c-format
msgid "-r, --restart"
msgstr "-r, --restart"

#. Tag: para
#: man-akonadiclient.1.docbook:465
#, no-c-format
msgid "Restarts the specified agents"
msgstr "Start de gespecificeerde agents opnieuw op"

#. Tag: option
#: man-akonadiclient.1.docbook:478
#, no-c-format
msgid "help"
msgstr "help"

#. Tag: para
#: man-akonadiclient.1.docbook:480
#, no-c-format
msgid "akonadiclient help [COMMAND]"
msgstr "akonadiclient help [OPDRACHT]"

#. Tag: para
#: man-akonadiclient.1.docbook:481
#, no-c-format
msgid ""
"Displays help for COMMAND. If COMMAND is not specified then it lists all the "
"available commands"
msgstr ""
"Toont help voor OPDRACHT. Als OPDRACHT niet is gespecificeerd toon dat alle "
"beschikbare opdrachten"

#. Tag: option
#: man-akonadiclient.1.docbook:486
#, no-c-format
msgid "shell"
msgstr "shell"

#. Tag: para
#: man-akonadiclient.1.docbook:488
#, no-c-format
msgid "akonadiclient shell"
msgstr "akonadiclient shell"

#. Tag: para
#: man-akonadiclient.1.docbook:489
#, no-c-format
msgid "Enter commands in an interactive shell"
msgstr "Voer opdrachten in in een interactieve shell"

#. Tag: title
#: man-akonadiclient.1.docbook:497
#, no-c-format
msgid "Examples"
msgstr "Voorbeelden"

#. Tag: para
#: man-akonadiclient.1.docbook:498
#, no-c-format
msgid ""
"<emphasis role=\"bold\">akonadiclient list /</emphasis> - Lists all the "
"collections under the root collection"
msgstr ""
"<emphasis role=\"bold\">akonadiclient list /</emphasis> - Toon alle "
"verzamelingen onder de hoofdverzameling"

#. Tag: para
#: man-akonadiclient.1.docbook:499
#, no-c-format
msgid ""
"<emphasis role=\"bold\">akonadiclient export /Notes notes.xml</emphasis> - "
"Exports all the items and sub-collections of the /Notes collection to the "
"file 'notes.xml'"
msgstr ""
"<emphasis role=\"bold\">akonadiclient export /Notes notes.xml</emphasis> - "
"Exporteert alle items en subverzamelingen van de /Notes-verzameling naar het "
"bestand 'notes.xml'"

#. Tag: para
#: man-akonadiclient.1.docbook:500
#, no-c-format
msgid ""
"<emphasis role=\"bold\">akonadiclient agents -l</emphasis> - Lists all agents"
msgstr ""
"<emphasis role=\"bold\">akonadiclient agents -l</emphasis> - toon alle agents"

#. Tag: para
#: man-akonadiclient.1.docbook:501
#, no-c-format
msgid ""
"<emphasis role=\"bold\">akonadiclient add /Notes note.txt</emphasis> - Adds "
"the contents of the file note.txt as an item in the collection /Notes"
msgstr ""
"<emphasis role=\"bold\">akonadiclient add /Notes note.txt</emphasis> - Voegt "
"de inhoud van het bestand note.txt toe aan een item in de verzameling /Notes"

#. Tag: para
#: man-akonadiclient.1.docbook:502
#, no-c-format
msgid ""
"<emphasis role=\"bold\">akonadiclient add -m application/x-vnd.akonadi."
"calendar.todo /Todos todo.ics</emphasis> - Adds the contents of the file "
"todo.ics as a TODO calendar entry in the collection /Todos"
msgstr ""
"<emphasis role=\"bold\">akonadiclient add -m application/x-vnd.akonadi."
"calendar.todo /Todos todo.ics</emphasis> - Voegt de inhoud van het bestand "
"todo.ics toe als een TODO-agenda-item in de verzameling /Todos"

#~ msgid "2014-08-17"
#~ msgstr "2014-08-17"

#~ msgid ""
#~ "Import an XML file inside the collection specified by PARENT. If the "
#~ "collection already exists, its contents are merged with the contents of "
#~ "the collection in the XML file."
#~ msgstr ""
#~ "Een XML-bestand in de verzameling gespecificeerd door OUDER importeren. "
#~ "Als de verzameling al bestaat, wordt zijn inhoud gemengd met de inhoud "
#~ "van de verzameling in het XML-bestand."
