msgstr "2019-02-22"

#. Tag: releaseinfo
#: man-kdiff3.1.docbook:14
#, no-c-format
msgid "kdiff3 1.8"
msgstr "kdiff3 1.8"

#. Tag: manvolnum
#: man-kdiff3.1.docbook:19
