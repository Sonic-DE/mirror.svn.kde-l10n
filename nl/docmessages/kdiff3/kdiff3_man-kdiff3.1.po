#. Tag: title
#: man-kdiff3.1.docbook:54
#, no-c-format
msgid "Description"
msgstr "Beschrijving"

#. Tag: para
#: man-kdiff3.1.docbook:55
#, no-c-format
msgid "Compares two or three input files or folders."
msgstr "Vergelijkt twee of drie invoerbestanden of mappen."

#. Tag: title
#: man-kdiff3.1.docbook:60
#, no-c-format
msgid "Options"
msgstr "Opties"

#. Tag: option
#: man-kdiff3.1.docbook:63
#, no-c-format
msgid "-u, --ignore"
msgstr "-u, --ignore"

#. Tag: para
#: man-kdiff3.1.docbook:64 man-kdiff3.1.docbook:70 man-kdiff3.1.docbook:76
#: man-kdiff3.1.docbook:82
#, no-c-format
msgid "Ignored. (User defined.)"
msgstr "Genegeerd. (Gebruiker gedefinieerd)."

#. Tag: option
#: man-kdiff3.1.docbook:69
#, no-c-format
msgid "--query"
msgstr "--query"

#. Tag: option
#: man-kdiff3.1.docbook:75
#, no-c-format
msgid "--html"
msgstr "--html"

#. Tag: option
#: man-kdiff3.1.docbook:81
#, no-c-format
msgid "--abort"
msgstr "--abort"

#. Tag: option
#: man-kdiff3.1.docbook:87
#, no-c-format
msgid "-m, --merge"
msgstr "-m, --merge"

#. Tag: para
#: man-kdiff3.1.docbook:88
#, no-c-format
msgid "Merge the input."
msgstr "Invoer samenvoegen."

#. Tag: term
#: man-kdiff3.1.docbook:93
#, no-c-format
msgid "<option>-b, --base</option> <replaceable>file</replaceable>"
msgstr "<option>-b, --base</option> <replaceable>bestand</replaceable>"

#. Tag: para
#: man-kdiff3.1.docbook:94
#, no-c-format
msgid "Explicit base file. For compatibility with certain tools."
msgstr ""
"Expliciet basisbestand. Voor compatibiliteit met sommige hulpprogramma's."

#. Tag: term
#: man-kdiff3.1.docbook:99
#, no-c-format
msgid "<option>-o, --output</option> <replaceable>file</replaceable>"
msgstr "<option>-o, --output</option> <replaceable>bestand</replaceable>"

#. Tag: para
#: man-kdiff3.1.docbook:100
#, no-c-format
msgid "Output file. Implies -m. &eg;: -o newfile.txt"
msgstr "Uitvoerbestand. Houd in -m. &eg;: -o nieuwbestand.txt"

#. Tag: term
#: man-kdiff3.1.docbook:105
#, no-c-format
msgid "<option>--out</option> <replaceable>file</replaceable>"
msgstr "<option>--out</option> <replaceable>bestand</replaceable>"

#. Tag: para
#: man-kdiff3.1.docbook:106
#, no-c-format
msgid "Output file, again. (For compatibility with certain tools.)"
msgstr ""
"Uitvoerbestand, opnieuw (voor compatibiliteit met sommige hulpprogramma's)."

#. Tag: option
#: man-kdiff3.1.docbook:111
#, no-c-format
msgid "--auto"
msgstr "--auto"

#. Tag: para
#: man-kdiff3.1.docbook:112
#, no-c-format
msgid ""
"No GUI if all conflicts are auto-solvable. (Needs <option>-o</option> "
"<replaceable>file</replaceable>)"
msgstr ""
"Geen grafisch venster als alle conflicten automatisch oplosbaar zijn. (Heeft "
"'-o bestand' nodig)."

#. Tag: option
#: man-kdiff3.1.docbook:118
#, no-c-format
msgid "--noauto"
msgstr "--noauto"

#. Tag: para
#: man-kdiff3.1.docbook:119
#, no-c-format
msgid "Ignore --auto and always show GUI."
msgstr "--auto negeren en altijd GUI tonen."

#. Tag: term
#: man-kdiff3.1.docbook:124
#, no-c-format
msgid "<option>--L1</option> <replaceable>alias1</replaceable>"
msgstr "<option>--L1</option> <replaceable>alias1</replaceable>"

#. Tag: para
#: man-kdiff3.1.docbook:125
#, no-c-format
msgid "Visible name replacement for input file 1 (base)."
msgstr "Zichtbare naamvervanging voor invoerbestand 1 (basis)."

#. Tag: term
#: man-kdiff3.1.docbook:130
#, no-c-format
msgid "<option>--L2</option> <replaceable>alias2</replaceable>"
msgstr "<option>--L2</option> <replaceable>alias2</replaceable>"

#. Tag: para
#: man-kdiff3.1.docbook:131
#, no-c-format
msgid "Visible name replacement for input file 2."
msgstr "Zichtbare naamvervanging voor invoerbestand 2."

#. Tag: term
#: man-kdiff3.1.docbook:136
#, no-c-format
msgid "<option>--L3</option> <replaceable>alias3</replaceable>"
msgstr "<option>--L3</option> <replaceable>alias3</replaceable>"

#. Tag: para
#: man-kdiff3.1.docbook:137
#, no-c-format
msgid "Visible name replacement for input file 3."
msgstr "Zichtbare naamvervanging voor invoerbestand 3."

#. Tag: term
#: man-kdiff3.1.docbook:142
#, no-c-format
msgid "<option>-L, --fname</option> <replaceable>alias</replaceable>"
msgstr "<option>-L, --fname</option> <replaceable>alias</replaceable>"

#. Tag: para
#: man-kdiff3.1.docbook:143
#, no-c-format
msgid "Alternative visible name replacement. Supply this once for every input."
msgstr ""
"Alternatieve zichtbare naamvervanging. Ditmaal voor elke invoer opgeven."

#. Tag: term
#: man-kdiff3.1.docbook:148
#, no-c-format
msgid "<option>--cs</option> <replaceable>string</replaceable>"
msgstr "<option>--cs</option> <replaceable>tekenreeks</replaceable>"

#. Tag: para
#: man-kdiff3.1.docbook:149
#, no-c-format
msgid ""
"Override a config setting. Use once for every setting. &eg;: <option>--cs</"
"option> <replaceable>AutoAdvance=1</replaceable>."
msgstr ""
"Omzeil een instelling in de configuratie. Gebruik dit eenmalig voor elke "
"instelling. &eg; <option>--cs</option> <replaceable>AutoAdvance=1</"
"replaceable>."

#. Tag: option
#: man-kdiff3.1.docbook:155
#, no-c-format
msgid "--confighelp"
msgstr "--confighelp"

#. Tag: para
#: man-kdiff3.1.docbook:156
#, no-c-format
msgid "Show list of config settings and current values."
msgstr "Een lijst tonen met instellingen en huidige waarden."

#. Tag: term
#: man-kdiff3.1.docbook:161
#, no-c-format
msgid "<option>--config</option> <replaceable>file</replaceable>"
msgstr "<option>--config</option> <replaceable>bestand</replaceable>"

#. Tag: para
#: man-kdiff3.1.docbook:162
#, no-c-format
msgid "Use a different config file."
msgstr "Een ander configuratiebestand gebruiken."

#. Tag: replaceable
#: man-kdiff3.1.docbook:167
#, no-c-format
msgid "File1"
msgstr "Bestand1"

#. Tag: para
#: man-kdiff3.1.docbook:168
#, no-c-format
msgid "file1 to open (base, if not specified via --<option>base</option>)"
msgstr ""
"bestand1 om te openen (basis, indien niet gespecificeerd via --<option>base</"
"option>)"

#. Tag: replaceable
#: man-kdiff3.1.docbook:173
#, no-c-format
msgid "File2"
msgstr "Bestand2"

#. Tag: para
#: man-kdiff3.1.docbook:174
#, no-c-format
msgid "file2 to open"
msgstr "Tweede bestand om te openen"

#. Tag: replaceable
#: man-kdiff3.1.docbook:179
#, no-c-format
msgid "File3"
msgstr "Bestand3"

#. Tag: para
#: man-kdiff3.1.docbook:180
#, no-c-format
msgid "file3 to open"
msgstr "Derde bestand om te openen"

#. Tag: title
#: man-kdiff3.1.docbook:189
#, no-c-format
msgid "See Also"
msgstr "Zie ook"

#. Tag: member
#: man-kdiff3.1.docbook:191
#, no-c-format
msgid ""
"More detailed user documentation is available from <ulink url=\"help:/"
"kdiff3\">help:/kdiff3</ulink> (either enter this &URL; into &konqueror;, or "
"run <userinput><command>khelpcenter</command> <parameter>help:/kdiff3</"
"parameter></userinput>)."
msgstr ""
"Meer uitgebreide informatie vindt u in <ulink url=\"help:/kdiff3\">help:/"
"kdiff3</ulink> (voer deze &URL; in in &konqueror; of voer "
"<userinput><command>khelpcenter</command> <parameter>help:/kdiff3</"
"parameter></userinput> uit)"

