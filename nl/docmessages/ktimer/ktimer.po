#. Tag: para
#: index.docbook:34
#, no-c-format
msgid ""
"&ktimer; is an application that lets you start an application after a "
"certain amount of time has passed."
msgstr ""
"&ktimer; is een toepassing die u in staat stelt een toepassing op te starten "
"na een bepaalde hoeveelheid tijd."

#. Tag: keyword
#: index.docbook:41
#, no-c-format
msgid "<keyword>KDE</keyword>"
msgstr "<keyword>KDE</keyword>"

