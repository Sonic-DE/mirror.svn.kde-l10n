#: index.docbook:47
#, no-c-format
msgid "ergonomic"
msgstr "ergonomisch"

#. Tag: keyword
#: index.docbook:48
#, no-c-format
msgid "tendonitis"
msgstr "tendinitis"

#. Tag: keyword
#: index.docbook:49
#, no-c-format
