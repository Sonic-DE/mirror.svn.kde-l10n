#. Tag: para
#: index.docbook:36
#, no-c-format
msgid ""
"&kmousetool; clicks the mouse whenever the mouse cursor pauses briefly. It "
"was designed to help those with repetitive strain injuries, for whom "
"pressing buttons hurts."
msgstr ""
"&kmousetool; klikt de muis als de muisaanwijzer even stilstaat. Het is "
"ontwikkeld als hulp voor mensen met rsi, voor wie het pijnlijk is om de "
"knoppen in te drukken."

#. Tag: keyword
#: index.docbook:44
#, no-c-format
msgid "<keyword>KDE</keyword>"
msgstr "<keyword>KDE</keyword>"

