#. Tag: para
#: index.docbook:4456
#, no-c-format
msgid ""
"The &kmail; identity to use as the sender of the email. If empty, the "
"sender's email address will be that configured in &kalarm;'s <link linkend="
"\"preferences-email\">Email preferences</link>."
msgstr ""
"De te gebruiken identiteit van &kmail; als de afzender van de e-mail. Indien "
"leeg, zal het e-mailadres van de afzender dat in de <link linkend="
"\"preferences-email\">E-mailvoorkeuren</link> in &kalarm; is ingesteld "
"worden gebruikt."

#. Tag: parameter
#: index.docbook:4464
#, no-c-format
msgid "addresses"
msgstr "adressen"

#. Tag: para
#: index.docbook:4466
#, no-c-format
msgid "A comma separated list of recipients' email addresses."
msgstr "Een door kommagescheiden lijst met e-mailadressen van ontvangers."

#. Tag: parameter
#: index.docbook:4471
#, no-c-format
msgid "subject"
msgstr "onderwerp"

#. Tag: para
#: index.docbook:4473
#, no-c-format
msgid "Specifies the subject line of the email."
msgstr "Specificeert de regel met het onderwerp van de e-mail."

#. Tag: para
#: index.docbook:4480
#, no-c-format
msgid "Specifies the email message body."
msgstr "Specificeert de inhoud van het e-mailbericht."

#. Tag: parameter
#: index.docbook:4485
#, no-c-format
msgid "attachments"
msgstr "bijlagen"

#. Tag: para
#: index.docbook:4487
#, no-c-format
