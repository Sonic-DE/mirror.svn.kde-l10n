"<shortcut> <keycombo action=\"simul\"> &Ctrl;&Shift; <keycap>J</keycap></"
"keycombo> </shortcut> <guimenu>Ga</guimenu> <guimenuitem>Terugspringspunt "
"hier instellen</guimenuitem>"

