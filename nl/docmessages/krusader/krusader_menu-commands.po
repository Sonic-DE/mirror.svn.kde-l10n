msgstr "<guimenu>Beeld</guimenu> <guimenuitem>Uitzoomen</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:806
#, no-c-format
msgid "Decrease the view scale."
msgstr "Verkleint de weergave."

#. Tag: menuchoice
#: menu-commands.docbook:811
#, no-c-format
