msgstr "Bestandsnamen omzetten naar hoofdletters/kleine letters"

#. Tag: para
#: menu-commands.docbook:222
#, no-c-format
msgid "Adding numbers to filenames"
msgstr "Cijfers aan bestandsnamen toevoegen"

#. Tag: para
#: menu-commands.docbook:225
#, no-c-format
msgid "Finding and replacing parts of the filename"
msgstr "Gedeeltes van bestandsnaam zoeken en vervangen"

#. Tag: para
#: menu-commands.docbook:229
#, no-c-format
msgid "Renaming MP3/OGG Vorbis files based on their ID3 tags"
msgstr "Hernoemt MP3/OGG Vorbis bestanden gebaseerd op hun ID3 tags"

#. Tag: para
#: menu-commands.docbook:233
#, no-c-format
msgid "Setting access and modification dates"
msgstr "Toegangsdatums en wijzigingsdatums instellen"

#. Tag: para
#: menu-commands.docbook:236
#, no-c-format
msgid "Changing permissions and file ownership"
msgstr "Toegangsrechten en bestandseigendom wijzigen"

#. Tag: para
#: menu-commands.docbook:239
#, no-c-format
msgid "A plugin API which allows you to extend KRename's features"
msgstr "Een plugin API waarmee u de mogelijkheden van KRename kan uitbreiden"

#. Tag: para
#: menu-commands.docbook:243
#, no-c-format
msgid "Renaming folders recursively"
msgstr "Mappen recursief hernoemen"

#. Tag: para
#: menu-commands.docbook:246
#, no-c-format
msgid "Support for KFilePlugins"
msgstr "Ondersteuning voor KFilePlugins"

#. Tag: para
#: menu-commands.docbook:249
#, no-c-format
msgid "Undo renaming"
msgstr "Hernoemen ongedaan maken"

#. Tag: para
#: menu-commands.docbook:252
#, no-c-format
msgid "And many more...."
msgstr "En nog veel meer..."

#. Tag: menuchoice
#: menu-commands.docbook:259
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Create Checksum...</guimenuitem>"
