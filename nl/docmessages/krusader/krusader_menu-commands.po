msgstr ""
"<shortcut> <keycombo action=\"simul\"> &Ctrl;&Alt; <keycap>T</keycap></"
"keycombo> </shortcut> <guimenu>Instellingen</guimenu> "
"<guimenuitem>Terminalemulator tonen</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1663
