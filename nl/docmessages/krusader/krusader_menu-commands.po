#. Tag: title
#: menu-commands.docbook:14
#, no-c-format
msgid "File Menu"
msgstr "Menu Bestand"

#. Tag: menuchoice
#: menu-commands.docbook:18
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Shift; <keycap>F4</keycap></keycombo> "
"</shortcut> <guimenu>File</guimenu> <guimenuitem>New Text File...</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Shift; <keycap>F4</keycap></keycombo> "
"</shortcut> <guimenu>Bestand</guimenu> <guimenuitem>Nieuw tekstbestand...</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:28
#, no-c-format
msgid ""
"Creates a new text file in the current folder, unless another folder is "
"specified. The new file is opened for editing after it is created."
msgstr ""
"Creëert een nieuw tekstbestand in de geselecteerde map, tenzij u een andere "
"map opgeeft. Het nieuwe bestand is na de aanmaak voor bewerking geopend."

#. Tag: menuchoice
#: menu-commands.docbook:35
#, no-c-format
msgid ""
"<shortcut> <keycap>F7</keycap> </shortcut> <guimenu>File</guimenu> "
"<guimenuitem>New Folder</guimenuitem>"
msgstr ""
"<shortcut> <keycap>F7</keycap> </shortcut> <guimenu>Bestand</guimenu> "
"<guimenuitem>Nieuwe map</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:44
#, no-c-format
msgid "Creates a new folder in the current folder."
msgstr "Maakt een nieuwe map aan in de huidige map."

#. Tag: menuchoice
#: menu-commands.docbook:50
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> &Alt;&Ctrl; <keycap>S</keycap></"
"keycombo> </shortcut> <guimenu>File</guimenu> <guimenuitem>New Symlink...</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> &Alt;&Ctrl; <keycap>S</keycap></"
"keycombo> </shortcut> <guimenu>Bestand</guimenu> <guimenuitem>Nieuwe "
"symbolische koppeling...</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:61
#, no-c-format
msgid "Creates a symbolic link to the currently selected file."
msgstr "Creëert een symbolische koppeling in de geselecteerde map"

#. Tag: menuchoice
#: menu-commands.docbook:67
#, no-c-format
msgid ""
"<shortcut> <keycap>F3</keycap> </shortcut> <guimenu>File</guimenu> "
"<guimenuitem>View File</guimenuitem>"
msgstr ""
"<shortcut> <keycap>F3</keycap> </shortcut> <guimenu>Bestand</guimenu> "
"<guimenuitem>Bestand bekijken</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:76
#, no-c-format
msgid ""
"Opens the currently selected file for <link linkend=\"kredit\">viewing</"
"link>."
msgstr ""
"Opent het geselecteerde bestand voor <link linkend=\"kredit\">weergave</"
"link>."

#. Tag: menuchoice
#: menu-commands.docbook:82
#, no-c-format
msgid ""
"<shortcut> <keycap>F4</keycap> </shortcut> <guimenu>File</guimenu> "
"<guimenuitem>Edit File</guimenuitem>"
msgstr ""
"<shortcut> <keycap>F4</keycap> </shortcut> <guimenu>Bestand</guimenu> "
"<guimenuitem>Bestand bewerken</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:91
#, no-c-format
msgid ""
"Opens the currently selected file for <link linkend=\"kredit\">editing</"
"link>."
msgstr ""
"Opent het geselecteerde bestand voor <link linkend=\"kredit\">bewerken</"
"link>."

#. Tag: menuchoice
#: menu-commands.docbook:97
#, no-c-format
msgid ""
"<shortcut> <keycap>F5</keycap> </shortcut> <guimenu>File</guimenu> "
"<guimenuitem>Copy to other panel</guimenuitem>"
msgstr ""
"<shortcut> <keycap>F5</keycap> </shortcut> <guimenu>Bestand</guimenu> "
"<guimenuitem>Naar ander paneel kopiëren</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:106
#, no-c-format
msgid "Copy the currently selected files or folders to the other panel."
msgstr "Kopieert de geselecteerde bestanden of mappen naar het andere paneel."

#. Tag: menuchoice
#: menu-commands.docbook:112
#, no-c-format
msgid ""
"<shortcut> <keycap>F6</keycap> </shortcut> <guimenu>File</guimenu> "
"<guimenuitem>Move</guimenuitem>"
msgstr ""
"<shortcut> <keycap>F6</keycap> </shortcut> <guimenu>Bestand</guimenu> "
"<guimenuitem>Verplaatsen</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:121
#, no-c-format
msgid ""
"Opens a dialog to <link linkend=\"copying\">move</link> the currently "
"selected files or folders to a specified location."
msgstr ""
"Opent een dialoog voor het <link linkend=\"copying\">verplaatsen</link> van "
"de gemarkeerde bestanden of mappen naar een opgegeven locatie."

#. Tag: menuchoice
#: menu-commands.docbook:128
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift; <keycap>P</keycap></"
"keycombo> </shortcut> <guimenu>File</guimenu> <guimenuitem>Pack...</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift; <keycap>P</keycap></"
"keycombo> </shortcut> <guimenu>Bestand</guimenu> <guimenuitem>Inpakken...</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:138
#, no-c-format
msgid ""
"Creates a <link linkend=\"pack-archive\">new archive</link> of all the "
"selected files and folders in the active panel."
msgstr ""
"Creëert een <link linkend=\"pack-archive\">nieuw archief</link> met alle "
"gemarkeerde bestanden en mappen in het actieve paneel."

#. Tag: menuchoice
#: menu-commands.docbook:146
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift; <keycap>U</keycap></"
"keycombo> </shortcut> <guimenu>File</guimenu> <guimenuitem>Unpack...</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift; <keycap>U</keycap></"
"keycombo> </shortcut> <guimenu>Bestand</guimenu> <guimenuitem>Uitpakken...</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:156
#, no-c-format
msgid ""
"<link linkend=\"unpacking-archives\">Unpacks</link> all the selected files "
"in the active panel."
msgstr ""
"<link linkend=\"unpacking-archives\">Pakt uit</link> alle gemarkeerde "
"bestanden in het actieve paneel."

#. Tag: menuchoice
#: menu-commands.docbook:163
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift; <keycap>E</keycap></"
"keycombo> </shortcut> <guimenu>File</guimenu> <guimenuitem>Test Archive</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift; <keycap>E</keycap></"
"keycombo> </shortcut> <guimenu>Bestand</guimenu> <guimenuitem>Archief "
"testen</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:173
#, no-c-format
msgid "<link linkend=\"test-archive\">Tests archive</link> for corruption."
msgstr "<link linkend=\"test-archive\">Tests het archief</link> op corruptie."

#. Tag: menuchoice
#: menu-commands.docbook:180
#, no-c-format
msgid ""
"<guimenu>File</guimenu> <guimenuitem>Compare by Content...</guimenuitem>"
msgstr ""
"<guimenu>Bestand</guimenu> <guimenuitem>Op inhoud vergelijken...</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:186
#, no-c-format
msgid ""
"Compares two current files by content - one from each panel via an external "
"graphical diff utility. By default &kompare; is used, but you can also use "
"&eg; <ulink url=\"http://furius.ca/xxdiff/\"><application>xxdiff</"
"application></ulink> or <ulink url=\"https://apps.kde.org/"
"kdiff3\"><application>KDiff3</application></ulink> , change it in the <link "
"linkend=\"konfig-dependencies\">Konfigurator Dependencies page</link>."
msgstr ""
"Vergelijkt twee gemarkeerde bestanden op inhoud - een van elk paneel via een "
"extern grafisch diff programma. Standaard is dit &kompare;, maar u kunt ook  "
"&eg; <ulink url=\"http://furius.ca/xxdiff/\"><application>xxdiff</"
"application></ulink> of <ulink url=\"https://apps.kde.org/kdiff3/"
"\"><application>KDiff3</application></ulink> gebruiken, u kunt het wijzigen "
"in de <link linkend=\"konfig-dependencies\">Pagina voor afhankelijkheden in "
"Konfigurator</link>."

#. Tag: menuchoice
#: menu-commands.docbook:196
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Shift; <keycap>F2</keycap></keycombo> "
"</shortcut> <guimenu>File</guimenu> <guimenuitem>Multi Rename...</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Shift; <keycap>F2</keycap></keycombo> "
"</shortcut> <guimenu>Bestand</guimenu> <guimenuitem>Meervoudig hernoemen...</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:206
#, no-c-format
msgid ""
"This menu option starts <ulink url=\"hhttps://apps.kde.org/krename"
"\"><application>Krename</application></ulink>, a very powerful external "
"batch renamer."
msgstr ""
"Dit keuzemenu start <ulink url=\"https://apps.kde.org/krename/"
"\"><application>Krename</application></ulink>, een zeer krachtig extern "
"batch hernoem-programma."

#. Tag: title
#: menu-commands.docbook:209
#, no-c-format
msgid "Krename Features"
msgstr "Mogelijkheden van Krename"

#. Tag: para
#: menu-commands.docbook:211
#, no-c-format
msgid "Renaming a list of files based on a set of expressions"
msgstr "Een verzameling bestanden hernoemen op basis van een set regels"

#. Tag: para
#: menu-commands.docbook:215
#, no-c-format
msgid "Copying/moving a list of files to another folder"
msgstr "Een verzameling bestanden kopiëren/verplaatsen naar een andere map"

#. Tag: para
#: menu-commands.docbook:219
#, no-c-format
