#. Tag: title
#: diskusage.docbook:8
#, no-c-format
msgid "<title>Disk Usage</title>"
msgstr "<title>Schijfgebruik</title>"

#. Tag: primary
#: diskusage.docbook:10
#, no-c-format
msgid "<primary>Disk Usage</primary>"
msgstr "<primary>Schijfgebruik</primary>"

#. Tag: para
#: diskusage.docbook:12
#, no-c-format
msgid ""
"The Disk Usage is based on the code of &filelight;. The Disk Usage shows you "
"how your disk space is being used by a graphical representation of your file "
"system. The following presentations are possible:"
msgstr ""
"De code van Schijfgebruik is gebaseerd op de code van &filelight;. "
"Schijfgebruik toont in een grafische weergave van uw bestandssysteem hoeveel "
"schijf ruimte in gebruik is. De volgende presentatievormen zijn mogelijk:"

#. Tag: para
#: diskusage.docbook:18
#, no-c-format
msgid "Line view"
msgstr "Lijn weergave"

#. Tag: para
#: diskusage.docbook:21
#, no-c-format
msgid "Detailed view"
msgstr "Detail weergave"

#. Tag: para
#: diskusage.docbook:24
#, no-c-format
msgid ""
"<application>Filelight</application> view: as a set of concentric segmented-"
"rings"
msgstr ""
"<application>Filelight</application> weergave: als een verzameling van "
"concentrische gesegmenteerde ringen"

#. Tag: para
#: diskusage.docbook:28
#, no-c-format
msgid ""
"Choose <menuchoice> <guimenu>Tools</guimenu> <guimenuitem>Disk Usage...</"
"guimenuitem> </menuchoice> or <keycombo action=\"simul\">&Alt;&Shift; "
"<keycap>S</keycap></keycombo> to start this feature in a separate window, or "
"open it inside the <link linkend=\"sidebar\">Sidebar</link>."
msgstr ""
"Selecteer <menuchoice> <guimenu>Hulpmiddelen</guimenu> "
"<guimenuitem>Schijfgebruik...</guimenuitem> </menuchoice> of <keycombo "
"action=\"simul\">&Alt;&Shift; <keycap>S</keycap></keycombo> om dit onderdeel "
"in een apart venster te starten, of open het in de <link linkend=\"sidebar"
"\">Zijbalk</link>."

#. Tag: para
#: diskusage.docbook:38
#, no-c-format
msgid "Disk Usage Keybindings, right click menu."
msgstr "Sneltoetsen voor schijfgebruik, contextmenu."

#. Tag: para
#: diskusage.docbook:41
#, no-c-format
msgid "<keycap>Del</keycap>: Delete"
msgstr "<keycap>Del</keycap>: Verwijderen"

#. Tag: para
#: diskusage.docbook:45
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Ctrl; <keycap>E</keycap></keycombo>: Exclude"
msgstr ""
"<keycombo action=\"simul\">&Ctrl; <keycap>E</keycap></keycombo>: Uitsluiten"

#. Tag: para
#: diskusage.docbook:50
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Shift; <keycap>Arrow Up</keycap></keycombo>: Up "
"one folder"
msgstr ""
"<keycombo action=\"simul\">&Shift; <keycap>Pijl omhoog</keycap></keycombo>: "
"Eén map omhoog"

#. Tag: para
#: diskusage.docbook:55
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Ctrl; <keycap>N</keycap></keycombo>: new search"
msgstr ""
"<keycombo action=\"simul\">&Ctrl; <keycap>N</keycap></keycombo>: Nieuwe "
"zoekopdracht"

#. Tag: para
#: diskusage.docbook:60
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Ctrl; <keycap>R</keycap></keycombo>: refresh"
msgstr ""
"<keycombo action=\"simul\">&Ctrl; <keycap>R</keycap></keycombo>: Verversen"

#. Tag: para
#: diskusage.docbook:65
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Ctrl; <keycap>I</keycap></keycombo>: include all"
msgstr ""
