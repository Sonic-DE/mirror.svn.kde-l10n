#. Tag: para
#: diskusage.docbook:70
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Shift; <keycap>Arrow Down</keycap></keycombo>: "
"step into"
msgstr ""
"<keycombo action=\"simul\">&Shift; <keycap>Pijl omlaag</keycap></keycombo>: "
"Instappen"

