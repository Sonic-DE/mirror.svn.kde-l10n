#. Tag: para
#: index.docbook:35
#, no-c-format
msgid ""
"&kmouth; is an application that enables persons that cannot speak to let "
"their computers speak."
msgstr ""
"&kmouth; is een toepassing die mensen die niet kunnen praten in staat stelt "
"de computer te laten praten."

#. Tag: keyword
#: index.docbook:42
#, no-c-format
msgid "<keyword>KDE</keyword>"
msgstr "<keyword>KDE</keyword>"

#. Tag: keyword
