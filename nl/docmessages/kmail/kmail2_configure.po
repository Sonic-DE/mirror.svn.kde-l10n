#~ "<option>--file <replaceable>/path/to/kmail2rc</replaceable> --group "
#~ "Reader --key ShowUserAgent true</option></userinput>"
#~ msgstr ""
#~ "<prompt>&percnt;</prompt> <userinput><command>kwriteconfig</command> "
#~ "<option>--file <replaceable>/path/to/kmail2rc</replaceable> --group "
#~ "Reader --key ShowUserAgent true</option></userinput>"

#~ msgid "Reply or forward using &HTML; if present"
#~ msgstr "Antwoorden of doorsturen met &HTML;, indien aanwezig"

#~ msgid ""
#~ "Select this option to enable <link linkend=\"filter-logging\">mail filter "
#~ "logging</link>. This plugin is disabled by default. This &kmail; feature "
#~ "appears to be a built-in function; my testing shows that mail filter "
#~ "logging will work both with and without this \"plugin\"."
#~ msgstr ""
#~ "Deze optie selecteren om <link linkend=\"filter-logging\">e-"
#~ "mailfilterlogging</link> in te schakelen. Deze plug-in is standaard "
#~ "uitgeschakeld. Deze functie van &kmail; lijkt ingebouwd te zijn; mijn "
#~ "testen toont dat loggen van e-mail filteren zowel werkt met als zonder "
#~ "deze \"plug-in\"."

