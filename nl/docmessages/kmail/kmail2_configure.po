#~ msgstr "Certificaat- &amp; sleutelbosbijlagen"

#~ msgid ""
#~ "If you would like to have &kmail; to <guilabel>Automatically import keys "
#~ "and certificate</guilabel> from incoming messages for decryption, select "
#~ "this option."
#~ msgstr ""
#~ "Als u graag wilt dat in &kmail; de keuze <guilabel>Sleutels en "
#~ "certificaten automatisch importeren</guilabel> actief is, activeer deze "
#~ "dan."

#~ msgid "If unsure, leave the option checked."
