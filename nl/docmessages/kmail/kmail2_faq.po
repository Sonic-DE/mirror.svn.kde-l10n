#~ "<markup>:0fw\n"
#~ " | bogofilter -e -p\n"
#~ "\n"
#~ "0e\n"
#~ " { EXITCODE=75 HOST }\n"
#~ "\n"
#~ "0:\n"
#~ " * ^X-Bogosity: Spam, tests=bogofilter\n"
#~ " ${MAILDIR}.INBOX.a-Spam/\n"
#~ "\n"
#~ "0e\n"
#~ " { EXITCODE=75 HOST }\n"
#~ "\n"
#~ "0:\n"
#~ " * ^X-Bogosity: Unsure, tests=bogofilter\n"
#~ " ${MAILDIR}.INBOX.a-Unsure/\n"
#~ "\n"
#~ "0e\n"
#~ " { EXITCODE=75 HOST }\n"
#~ " </markup>"
#~ msgstr ""
#~ "<markup>:0fw\n"
#~ " | bogofilter -e -p\n"
#~ "\n"
#~ "0e\n"
#~ " { EXITCODE=75 HOST }\n"
#~ "\n"
#~ "0:\n"
#~ " * ^X-Bogosity: Spam, tests=bogofilter\n"
#~ " ${MAILDIR}.INBOX.a-Spam/\n"
#~ "\n"
#~ "0e\n"
#~ " { EXITCODE=75 HOST }\n"
#~ "\n"
#~ "0:\n"
#~ " * ^X-Bogosity: Unsure, tests=bogofilter\n"
#~ " ${MAILDIR}.INBOX.a-Onzeker/\n"
#~ "\n"
#~ "0e\n"
#~ " { EXITCODE=75 HOST }\n"
#~ " </markup>"

