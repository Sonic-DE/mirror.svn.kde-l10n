#: man-kf6options.7.docbook:85
#, no-c-format
msgid ""
"Man page originally written by &Lauri.Watts; &Lauri.Watts.mail; for kdelibs4"
msgstr ""
"Manpagina oorspronkelijk geschreven door &Lauri.Watts; &Lauri.Watts.mail; "
"voor kdelibs4"

#. Tag: para
#: man-kf6options.7.docbook:86
#, no-c-format
msgid "Updated to &frameworks; 5 by &Burkhard.Lueck; &Burkhard.Lueck.mail;"
msgstr ""
"Bijgewerkt naar &frameworks; door &Burkhard.Lueck; &Burkhard.Lueck.mail;"

