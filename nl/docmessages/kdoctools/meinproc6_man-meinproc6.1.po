#. Tag: cmdsynopsis
#: man-meinproc6.1.docbook:56
#, no-c-format
msgid ""
"<command>meinproc6</command> <arg choice=\"opt\">-h, --help</arg> <arg "
"choice=\"opt\">-v, --version</arg> <arg choice=\"opt\">--cache<replaceable> "
"file</replaceable></arg> <arg choice=\"opt\">--check</arg> <arg choice=\"opt"
"\">--srcdir<replaceable> dir</replaceable></arg> <arg choice=\"opt\">--param "
"<replaceable>key</replaceable>=<replaceable>value</replaceable></arg> "
"<group> <group> <arg>-o</arg> <arg>--output</arg> </group> <replaceable> "
"file</replaceable> </group> <arg choice=\"opt\">--stdout</arg> <arg choice="
"\"opt\">--stylesheet<replaceable> xsl</replaceable></arg> <arg choice=\"plain"
"\">docbook_file</arg>"
msgstr ""
"<command>meinproc6</command> <arg choice=\"opt\">-h, --help</arg> <arg "
"choice=\"opt\">-v, --version</arg> <arg choice=\"opt\">--cache<replaceable> "
"bestand</replaceable></arg> <arg choice=\"opt\">--check</arg> <arg choice="
"\"opt\">--srcdir<replaceable> map</replaceable></arg> <arg choice=\"opt\">--"
"param <replaceable>sleutelwoord</replaceable>=<replaceable>waarde</"
"replaceable></arg> <group> <group> <arg>-o</arg> <arg>--output</arg> </"
"group> <replaceable> bestand</replaceable> </group> <arg choice=\"opt\">--"
"stdout</arg> <arg choice=\"opt\">--stylesheet<replaceable> xsl</"
"replaceable></arg> <arg choice=\"plain\">docbook_bestand</arg>"

