"\">QGuiApplication documentation</ulink> and <ulink url=\"https://doc.qt.io/"
"qt-6/qcommandlineparser.html\">QCommandLineParser documentation</ulink>."
msgstr ""
"De informatie voor deze manpagina komen uit <ulink url=\"https://doc.qt.io/"
"qt-6/qapplication.html#QApplication\">QApplication documentatie</ulink>, "
"<ulink url=\"https://doc.qt.io/qt-6/qguiapplication.html#QGuiApplication"
"\">QGuiApplication documentatie</ulink> en <ulink url=\"https://doc.qt.io/"
"qt-6/qcommandlineparser.html\">QCommandLineParser documentatie</ulink>."

#~ msgid "Qt 5.4"
#~ msgstr "Qt 5.4"

#~ msgid "qt5options User's Manual"
#~ msgstr "Gebruikershandleiding van qt5options"

#~ msgid "><option>-v --version</option>"
#~ msgstr "><option>-v --version</option>"

#~ msgid "2014-03-04"
#~ msgstr "2014-03-04"

#~ msgid "Frameworks 5.0"
#~ msgstr "Frameworks 5.0"

#~ msgid ""
#~ "<command><replaceable>Qt application</replaceable></command> <arg choice="
#~ "\"opt\">Qt Generic Options</arg>"
#~ msgstr ""
#~ "<command><replaceable>Qt-applicatie</replaceable></command> <arg choice="
#~ "\"opt\">Qt-algemene opties</arg>"

#~ msgid "<option>--display</option> <parameter>displayname</parameter>"
#~ msgstr "<option>--display</option> <parameter>schermnaam</parameter>"

#~ msgid "Use the X-server display <parameter>displayname</parameter>."
#~ msgstr "Gebruik de X-serverdisplay <parameter>schermnaam</parameter>."

#~ msgid "<option>--session</option> <parameter>sessionId</parameter>"
#~ msgstr "<option>--session</option> <parameter>sessie-id</parameter>"

#~ msgid "--cmap"
#~ msgstr "--cmap"

#~ msgid ""
#~ "Causes the application to install a private color map on an 8-bit display."
#~ msgstr ""
#~ "Zorgt ervoor dat de toepassing een privé-kleurenschema op een 8-bit "
#~ "weergave gebruikt."

#~ msgid "<option>--ncols</option> <parameter>count</parameter>"
#~ msgstr "<option>--ncols</option> <parameter>aantal</parameter>"

#~ msgid ""
#~ "Limits the number of colors allocated in the color cube on an 8-bit "
#~ "display, if the application is using the <methodname>QApplication::"
#~ "ManyColor</methodname> color specification."
#~ msgstr ""
#~ "Beperkt het aantal toegekende kleuren in de kleurkubus op een 8-bit "
#~ "scherm, als de applicatie de kleurspecificatie <methodname>QApplication::"
#~ "ManyColor</methodname> gebruikt."

#~ msgid "--nograb"
#~ msgstr "--nograb"

#~ msgid "Tells &Qt; to never grab the mouse or the keyboard."
#~ msgstr "Vertelt &Qt; dat deze nooit de muis of toetsenbord mag overnemen."

#~ msgid "--dograb"
#~ msgstr "--dograb"

#~ msgid ""
#~ "Running under a debugger can cause an implicit <option>--nograb</option>, "
#~ "use <option>--dograb</option> to override."
#~ msgstr ""
#~ "Onder een debugger draaien kan een impliciete <option>-nograb</option> "
#~ "veroorzaken, gebruik <option>-dograb</option> om te overschrijven."

#~ msgid "--sync"
#~ msgstr "--sync"

#~ msgid "Switches to synchronous mode for debugging."
#~ msgstr "Gaat over naar de synchrone modus voor het debuggen."

#~ msgid ""
#~ "<option>--fn</option>,<option>--font</option> <parameter>fontname</"
#~ "parameter>"
#~ msgstr ""
#~ "<option>--fn</option>, <option>--font</option> <parameter>lettertypenaam</"
#~ "parameter>"

#~ msgid "Defines the application font."
#~ msgstr "Het lettertype van de toepassing instellen."

#~ msgid ""
#~ "<option>--bg</option>,<option>--background</option> <parameter>color</"
#~ "parameter>"
#~ msgstr ""
#~ "<option>--bg</option>,<option>--background</option> <parameter>kleur</"
#~ "parameter>"

#~ msgid ""
#~ "Sets the default background color and an application palette (light and "
#~ "dark shades are calculated)."
#~ msgstr ""
#~ "Stelt de standaard achtergrondkleur in en een toepassingspalet (lichte en "
#~ "donkere tinten worden berekend)."

#~ msgid ""
#~ "<option>--fg</option>,<option>--foreground</option> <parameter>color</"
#~ "parameter>"
#~ msgstr ""
#~ "<option>--fg</option>, <option>--foreground</option> <parameter>kleur</"
#~ "parameter>"

#~ msgid "Sets the default foreground color"
#~ msgstr "De standaard voorgrondkleur instellen"

#~ msgid ""
#~ "<option>--btn</option>,<option>--button</option> <parameter>color</"
#~ "parameter>"
#~ msgstr ""
#~ "<option>--btn</option>, <option>--button</option> <parameter>kleur</"
#~ "parameter>"

#~ msgid "<option>--name</option> <parameter>name</parameter>"
#~ msgstr "<option>--name</option> <parameter>naam</parameter>"

#~ msgid "<option>--title</option> <parameter>title</parameter>"
#~ msgstr "<option>--title</option> <parameter>titel</parameter>"

#~ msgid "<option>--visual</option> <parameter>TrueColor</parameter>"
#~ msgstr "<option>--visual</option> <parameter>TrueColor</parameter>"

#~ msgid ""
#~ "Forces the application to use a <parameter>TrueColor</parameter> visual "
#~ "on an 8-bit display."
#~ msgstr ""
#~ "Dwingt de toepassing om een <parameter>TrueColor</parameter> uiterlijk op "
#~ "een 8-bits scherm te gebruiken."

#~ msgid "<option>--inputstyle</option> <parameter>inputstyle</parameter>"
#~ msgstr "<option>--inputstyle</option> <parameter>invoerstijl</parameter>"

#~ msgid ""
#~ "Sets XIM (X Input Method) input style. Possible values are "
#~ "<parameter>onthespot</parameter>, <parameter>overthespot</parameter>, "
#~ "<parameter>offthespot</parameter> and <parameter>root</parameter>."
#~ msgstr ""
#~ "Stelt de XIM (X Input Method)-invoermethode in. Mogelijke waarden zijn "
#~ "<parameter>onthespot</parameter>, <parameter>overthespot</parameter>, "
#~ "<parameter>offthespot</parameter> en <parameter>root</parameter>."

#~ msgid "<option>--im</option> <parameter>XIM server</parameter>"
