#, no-c-format
msgid "The &infocenter;"
msgstr "Het &infocenter;"

#. Tag: author
#: index.docbook:13
#, no-c-format
msgid "&Mike.McBride; &Mike.McBride.mail;"
msgstr "&Mike.McBride; &Mike.McBride.mail;"

#. Tag: trans_comment
#: index.docbook:14
#, no-c-format
msgid "ROLES_OF_TRANSLATORS"
