#: index.docbook:306
#, no-c-format
msgid "Put the following lines in this file using your favorite text editor:"
msgstr ""
"De volgende regels in dit bestand zetten met uw favoriete tekstbewerker:"

#. Tag: programlisting
#: index.docbook:307
#, no-c-format
msgid ""
"[KMahjonggLayout]\n"
"Name=<replaceable>name_of_your_layout</replaceable>\n"
"Description=<replaceable>description_of_your_layout</replaceable>\n"
"VersionFormat=1\n"
"Author=<replaceable>your_name</replaceable>\n"
"AuthorEmail=<replaceable>your_email</replaceable>\n"
"FileName=<replaceable>name_of_your_layout</replaceable>.layout"
msgstr ""
"[KMahjonggLayout]\n"
"Name=<replaceable>naam_van_uw_indeling</replaceable>\n"
"Description=<replaceable>Beschrijving_van_uw_indeling</replaceable>\n"
"VersionFormat=1\n"
"Author=<replaceable>Uw_naam</replaceable>\n"
"AuthorEmail=<replaceable>uw_e-mailadres</replaceable>\n"
"FileName=<replaceable>naam_van_uw_indeling</replaceable>.layout"

#. Tag: para
#: index.docbook:308
