#. Tag: menuchoice
#: index.docbook:371
#, no-c-format
msgid ""
"<shortcut><keycap>F</keycap></shortcut> <guimenu>View</guimenu> "
"<guimenuitem>Rotate View Counterclockwise</guimenuitem>"
msgstr ""
"<shortcut><keycap>F</keycap></shortcut> <guimenu>Beeld</guimenu> "
"<guimenuitem>Blik naar beneden verplaatsen</guimenuitem>"

