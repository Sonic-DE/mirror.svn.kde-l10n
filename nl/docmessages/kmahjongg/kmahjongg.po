#: index.docbook:415
#, no-c-format
msgid "<phrase>Configure Dialog</phrase>"
msgstr "<phrase>Dialoog voor instellen</phrase>"

#. Tag: para
#: index.docbook:420
#, no-c-format
msgid ""
"<menuchoice><guimenu>Settings</guimenu><guimenuitem>Configure &kmahjongg;…</"
"guimenuitem></menuchoice> opens the <guilabel>Configure - &kmahjongg;</"
"guilabel> dialog."
msgstr ""
"Met <menuchoice><guimenu>Instellingen</guimenu><guimenuitem>&kmahjongg; "
"instellen…</guimenuitem></menuchoice> opent de dialoog "
"<guilabel>Configureren - &kmahjongg;</guilabel>."

#. Tag: title
#: index.docbook:422
#, no-c-format
msgid "General options"
msgstr "Algemene opties"

#. Tag: guilabel
#: index.docbook:425
#, no-c-format
msgid "Blink matching tiles when first one is selected"
msgstr ""
"Bij elkaar passende stenen laten knipperen als de eerste steen is "
"geselecteerd"

#. Tag: para
#: index.docbook:426
#, no-c-format
msgid ""
"This setting will make the game highlight the selected tile on mouse click, "
"and flash any matching tiles that have a free side at each move. No "
"additional tiles will be highlighted if there are no matching tiles with a "
"free side."
msgstr ""
"Bij deze instelling zal een steen worden gemarkeerd als erop wordt geklikt, "
"en ook elke andere vrijliggende steen die erbij past laten knipperen, indien "
"aanwezig."

#. Tag: guilabel
#: index.docbook:431
#, no-c-format
msgid "Generate solvable games"
msgstr "Oplosbare spellen genereren"

