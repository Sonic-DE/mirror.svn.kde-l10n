"shortcut> <guimenu>Zet</guimenu> <guimenuitem>Positie laden</guimenuitem>"

#. Tag: action
#: index.docbook:180
#, no-c-format
msgid "Loads the most recently saved position."
msgstr "Laadt de laatst opgeslagen positie."

#. Tag: menuchoice
#: index.docbook:184
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>S</keycap></keycombo> </"
"shortcut> <guimenu>Move</guimenu> <guimenuitem>Save Position</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>S</keycap></keycombo> </"
"shortcut><guimenu>Zet</guimenu> <guimenuitem>Positie opslaan</guimenuitem>"

