#. Tag: title
#: menus.docbook:2
#, no-c-format
msgid "Command Reference"
msgstr "Overzicht van de opdrachten"

#. Tag: title
#: menus.docbook:13
#, no-c-format
msgid "The Main &tellico; Window"
msgstr "Het hoofdvenster van &tellico;"

#. Tag: para
#: menus.docbook:15
#, no-c-format
msgid ""
"Each menu item is discussed below. When there is a keyboard shortcut that "
"performs a menu item function, the default shortcut is listed with the menu "
"item."
msgstr ""
"Alle functies in het menu worden hieronder beschreven. Wanneer voor een "
"bepaalde functie een sneltoets beschikbaar is, zal de standaard sneltoets "
"vermeld worden."

#. Tag: title
#: menus.docbook:20
#, no-c-format
msgid "The File Menu"
msgstr "Het menu Bestand"

#. Tag: menuchoice
#: menus.docbook:27
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>New</guimenuitem>"
msgstr "<guimenu>Bestand</guimenu> <guimenuitem>Nieuw</guimenuitem>"

#. Tag: para
#: menus.docbook:34
#, no-c-format
msgid ""
"This command <action>creates a new collection</action>. &tellico; supports "
"<link linkend=\"collection-types\">12 default collection types</link> along "
"with an empty user-defined custom collection. Any custom-saved collection "
"templates will also be available."
msgstr ""
"Deze opdracht <action>maakt een nieuwe verzameling</action>. &tellico; "
"ondersteunt <link linkend=\"collection-types\">12 standaard typen "
"verzamelingen</link> naast een lege gebruikergedefinieerde aangepaste "
"verzameling. Elke zelf opgeslagen verzameling van sjablonen zal ook "
"beschikbaar zijn."

#. Tag: menuchoice
#: menus.docbook:40
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>O</keycap></keycombo> </shortcut> "
"<guimenu>File</guimenu> <guimenuitem>Open...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>O</keycap></keycombo> </"
"shortcut> <guimenu>Bestand</guimenu> <guimenuitem>Openen...</guimenuitem>"

#. Tag: para
#: menus.docbook:50
#, no-c-format
msgid "This command <action>opens a &tellico; file</action>."
msgstr "Deze opdracht <action>opent een &tellico;-bestand</action>."

#. Tag: menuchoice
#: menus.docbook:56
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Open Recent</guimenuitem>"
msgstr "<guimenu>Bestand</guimenu> <guimenuitem>Recent geopend</guimenuitem>"

#. Tag: para
#: menus.docbook:63
#, no-c-format
msgid ""
"This command <action>opens a file</action> from a submenu that contains a "
"list of recently opened files."
msgstr ""
"Deze opdracht <action>opene een bestand</action> uit een submenu die een "
"lijst met recent geopende bestanden bevat."

#. Tag: menuchoice
#: menus.docbook:70
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>S</keycap></keycombo> </shortcut> "
"<guimenu>File</guimenu> <guimenuitem>Save...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>S</keycap></keycombo> </"
"shortcut> <guimenu>Bestand</guimenu> <guimenuitem>Opslaan</guimenuitem>"

#. Tag: para
#: menus.docbook:80
#, no-c-format
msgid ""
"This command <action>saves the collection</action>. If the file is "
"<emphasis>Untitled</emphasis> then <guimenuitem>Save...</guimenuitem> is "
"equivalent to <guimenuitem>Save As</guimenuitem>. It is only enabled when "
"the collection has been modified."
msgstr ""
"Deze opdracht <action>slaat de verzameling op</action>. Als het bestand "
"<emphasis>geen titel</emphasis> heeft dan is <guimenuitem>Opslaan...</"
"guimenuitem> gelijk aan <guimenuitem>Opslaan als</guimenuitem>. Het is "
"alleen ingeschakeld wanneer de verzameling is gewijzigd."

#. Tag: menuchoice
#: menus.docbook:89
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;&Shift;<keycap>S</keycap></keycombo> </shortcut> "
"<guimenu>File</guimenu> <guimenuitem>Save As...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;&Shift;<keycap>S</keycap></keycombo> </shortcut> "
"<guimenu>Bestand</guimenu> <guimenuitem>Opslaan als...</guimenuitem>"

#. Tag: para
#: menus.docbook:99
#, no-c-format
msgid "This command <action>saves the collection to a new file</action>."
msgstr ""
"Deze opdracht <action>slaat de verzameling in een nieuw bestand op</action>."

#. Tag: menuchoice
#: menus.docbook:105
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Save As Template...</guimenuitem>"
msgstr ""
"<guimenu>Bestand</guimenu> <guimenuitem>Opslaan als sjabloon...</guimenuitem>"

#. Tag: para
#: menus.docbook:112
#, no-c-format
msgid ""
"This command <action>saves the collection as a new template</action>. Only "
"the fields are saved, and the custom collection type can be created via the "
"<guimenuitem>New Collection</guimenuitem> command."
msgstr ""
"Deze opdracht <action>slaat de verzameling op als een nieuw sjabloon</"
"action>. Alleen worden de velden opgeslagen en het eigen type verzameling "
"kan aangemaakt worden via het commando <guimenuitem>Nieuwe verzameling</"
"guimenuitem>."

#. Tag: menuchoice
#: menus.docbook:118
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>P</keycap></keycombo> </shortcut> "
"<guimenu>File</guimenu> <guimenuitem>Print...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>P</keycap></keycombo> </"
"shortcut> <guimenu>Bestand</guimenu> <guimenuitem>Afdrukken...</guimenuitem>"

#. Tag: para
#: menus.docbook:128
#, no-c-format
msgid ""
"This command <action>prints the collection</action>. Printing options may be "
"set in the <interface>Configuration Dialog</interface>."
msgstr ""
"Deze opdracht <action>drukt de verzameling af</action>. Afdrukopties kunnen "
"ingesteld worden in de <interface>Instellingendialoog</interface>."

#. Tag: menuchoice
#: menus.docbook:134
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Print Preview</guimenuitem>"
msgstr ""
"<guimenu>Bestand</guimenu> <guimenuitem>Voorbeeld afdrukken</guimenuitem>"

#. Tag: para
#: menus.docbook:141
#, no-c-format
msgid ""
"This command <action>shows a preview of the printed collection</action>."
msgstr ""
"Deze opdracht <action>toont een voorbeeld van de af te drukken verzameling</"
"action>"

#. Tag: menuchoice
#: menus.docbook:147
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Import</guimenuitem>"
msgstr "<guimenu>Bestand</guimenu> <guimenuitem>Importeren</guimenuitem>"

#. Tag: para
#: menus.docbook:154
#, no-c-format
msgid ""
"This command <action>imports data from another file</action>. &tellico; can "
"import data from a number of <link linkend=\"importing\">other formats</"
"link>."
msgstr ""
"Deze opdracht <action>importeert gegevens uit een ander bestand</action>. "
"&tellico; kan gegevens importeren uit een aantal <link linkend=\"importing"
"\">andere formaten</link>."

#. Tag: menuchoice
#: menus.docbook:160
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Export</guimenuitem>"
msgstr "<guimenu>Bestand</guimenu> <guimenuitem>Exporteren</guimenuitem>"

#. Tag: para
#: menus.docbook:167
#, no-c-format
msgid ""
"This command <action>exports the collection to another format</action>. "
"&tellico; can export data to a number of <link linkend=\"exporting\">other "
"formats</link>."
msgstr ""
"Deze opdracht <action>exporteert gegevens naar een ander formaat</action> "
"&tellico; kan gegevens exporteren naar een aantal <link linkend=\"exporting"
"\">andere formaten</link>."

#. Tag: menuchoice
#: menus.docbook:173
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>Q</keycap></keycombo> </shortcut> "
"<guimenu>File</guimenu> <guimenuitem>Quit</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>Q</keycap></keycombo> </"
"shortcut> <guimenu>Bestand</guimenu> <guimenuitem>Afsluiten</guimenuitem>"

#. Tag: para
#: menus.docbook:183
#, no-c-format
msgid ""
"This command <action>closes the &tellico; window</action>. If the collection "
"has unsaved changes, you will be prompted to save them before continuing."
msgstr ""
"Deze opdracht <action>sluit het venster van &tellico;</action>. Als de "
"verzameling niet opgeslagen wijzigingen bevat zult u worden gevraagd om ze "
"op te slaan alvorens door te gaan."

#. Tag: title
#: menus.docbook:193
#, no-c-format
msgid "The Edit Menu"
msgstr "Het menu Bewerken"

#. Tag: menuchoice
#: menus.docbook:201
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>Z</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Undo</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>Z</keycap></keycombo> </"
"shortcut> <guimenu>Bewerken</guimenu> <guimenuitem>Ongedaan maken</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:211
#, no-c-format
msgid ""
"This command <action>undoes the previous action</action>. Not all actions "
"are supported by Undo."
msgstr ""
"Deze opdracht <action>maakt de vorige actie ongedaan</action>. Niet alle "
"acties worden door Ongedaan maken ondersteund."

#. Tag: menuchoice
#: menus.docbook:217
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;&Shift;<keycap>Z</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Redo</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;&Shift;<keycap>Z</keycap></keycombo> </shortcut> "
"<guimenu>Bewerken</guimenu> <guimenuitem>Opnieuw</guimenuitem>"

#. Tag: para
#: menus.docbook:227
#, no-c-format
msgid "This command <action>reverts a previous Undo</action>."
msgstr ""
"Deze opdracht <action>draait de vorige Ongedaan maken weer terug</action>."

#. Tag: menuchoice
#: menus.docbook:233
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>X</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Cut</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>X</keycap></keycombo> </"
"shortcut> <guimenu>Bewerken</guimenu> <guimenuitem>Knippen</guimenuitem>"

#. Tag: para
#: menus.docbook:243
#, no-c-format
msgid ""
"This command <action>removes the selected text</action>, if any, and "
"<action>places a copy of the removed text in the clipboard</action>."
msgstr ""
"Deze opdracht <action>verwijdert de geselecteerde tekst</action>, indien "
"aanwezig, en <action>plaats een kopie van de verwijderde tekst in het "
"klembord</action>."

#. Tag: menuchoice
#: menus.docbook:249
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>C</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Copy</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>C</keycap></keycombo> </"
"shortcut> <guimenu>Bewerken</guimenu> <guimenuitem>Kopiëren</guimenuitem>"

#. Tag: para
#: menus.docbook:259
#, no-c-format
msgid ""
"This command <action>copies the selected text</action>, if any, to the "
"clipboard."
msgstr ""
"Deze opdracht <action>kopieert de geselecteerde tekst</action>, indien "
"aanwezig, naar het klembord."

#. Tag: menuchoice
#: menus.docbook:265
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>V</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Paste</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>V</keycap></keycombo> </"
"shortcut> <guimenu>Bewerken</guimenu> <guimenuitem>Plakken</guimenuitem>"

#. Tag: para
#: menus.docbook:275
#, no-c-format
msgid ""
"This command <action>pastes the text in the clipboard</action>, if any, into "
"the editor at the cursor position."
msgstr ""
"Deze opdracht <action>plakt de tekst in het klembord</action>, indien "
"aanwezig, naar de editor op de positie van de cursor."

#. Tag: menuchoice
#: menus.docbook:281
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>A</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Select All</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>A</keycap></keycombo> </"
"shortcut> <guimenu>Bewerken</guimenu> <guimenuitem>Alles selecteren</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:291
#, no-c-format
msgid ""
"This command <action>selects all the entries</action> in the collection, in "
"the <interface>Column View</interface>."
msgstr ""
"Deze opdracht <action>selecteert alle items</action> in de verzameling, in "
"de <interface>Kolomweergave</interface>."

#. Tag: menuchoice
#: menus.docbook:297
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;&Shift;<keycap>A</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Deselect</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>A</keycap></"
"keycombo> </shortcut> <guimenu>Bewerken</guimenu> <guimenuitem>Selecteren "
"ongedaan maken</guimenuitem>"

#. Tag: para
#: menus.docbook:307
#, no-c-format
msgid ""
"This command <action>deselects all the entries</action> in the collection."
msgstr ""
"Deze opdracht <action>maakt de selectie van alle items</action> in de "
"verzameling ongedaan"

#. Tag: menuchoice
#: menus.docbook:313
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>I</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Internet Search...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>I</keycap></keycombo> </shortcut> "
"<guimenu>Bewerken</guimenu> <guimenuitem>Zoeken in het internet...</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:323
#, no-c-format
msgid ""
"This command <action>opens the <interface>Internet Search Dialog</"
"interface></action> to search for and import entries from various Internet "
"sites, including <ulink url=\"http://amazon.com\">Amazon.com</ulink>."
msgstr ""
"Deze opdracht <action>opent de <interface>Internet zoekdialoog</interface></"
"action> om te zoeken naar items uit verschillende internetsites en ze te "
"importeren, inclusief <ulink url=\"http://amazon.com\">Amazon.com</ulink>."

#. Tag: menuchoice
#: menus.docbook:329
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>J</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Advanced Filter...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>J</keycap></keycombo> </shortcut> "
"<guimenu>Bewerken</guimenu> <guimenuitem>Uitgebreid filter...</guimenuitem>"

#. Tag: para
#: menus.docbook:339
#, no-c-format
msgid ""
"This command <action>opens the <interface>Advanced Filter Dialog</"
"interface></action>."
msgstr ""
"Deze opdracht <action>opent de <interface>uitgebreide filterdialoog</"
"interface></action>."

#. Tag: title
#: menus.docbook:350
#, no-c-format
msgid "The Collection Menu"
msgstr "Het menu Verzameling"

#. Tag: menuchoice
#: menus.docbook:357
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>N</keycap></keycombo> </shortcut> "
"<guimenu>Collection</guimenu> <guimenuitem>New Entry</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>N</keycap></keycombo> </shortcut> "
"<guimenu>Verzameling</guimenu> <guimenuitem>Nieuw item</guimenuitem>"

#. Tag: para
#: menus.docbook:367
#, no-c-format
msgid ""
"This command <action>opens the <interface>Entry Editor</interface> to edit a "
"new entry</action>."
msgstr ""
"Deze opdracht <action>opent de <interface>Itembewerker</interface> om een "
"nieuw item te bewerken</action>."

#. Tag: menuchoice
#: menus.docbook:373
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>E</keycap></keycombo> </shortcut> "
"<guimenu>Collection</guimenu> <guimenuitem>Edit Entry</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>E</keycap></keycombo> </shortcut> "
"<guimenu>Verzameling</guimenu> <guimenuitem>Item bewerken</guimenuitem>"

#. Tag: para
#: menus.docbook:383
#, no-c-format
msgid ""
"This command <action>opens the <interface>Entry Editor</interface> to edit "
"the selected entries</action>."
msgstr ""
"Deze opdracht <action>opent de <interface>Itembewerker</interface> om de "
"geselecteerde items te bewerken</action>."

#. Tag: menuchoice
#: menus.docbook:389
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>Y</keycap></keycombo> </shortcut> "
"<guimenu>Collection</guimenu> <guimenuitem>Duplicate Entry</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>Y</keycap></keycombo> </shortcut> "
"<guimenu>Verzameling</guimenu> <guimenuitem>Item dupliceren</guimenuitem>"

#. Tag: para
#: menus.docbook:399
#, no-c-format
msgid ""
"This command <action>copies, or duplicates, the selected entries</action> as "
"new entries in the collection."
msgstr ""
"Deze opdracht <action>kopieert of dupliceert de geselecteerde items</action> "
"als nieuwe items in de verzameling."

#. Tag: menuchoice
#: menus.docbook:405
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>D</keycap></keycombo> </shortcut> "
"<guimenu>Collection</guimenu> <guimenuitem>Delete Entry</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>D</keycap></keycombo> </shortcut> "
"<guimenu>Verzameling</guimenu> <guimenuitem>Item verwijderen</guimenuitem>"

#. Tag: para
#: menus.docbook:415
#, no-c-format
msgid "This command <action>deletes the selected entries</action>."
msgstr "Deze opdracht <action>verwijdert de geselecteerde items</action>."

#. Tag: menuchoice
#: menus.docbook:421
#, no-c-format
msgid "<guimenu>Collection</guimenu> <guimenuitem>Merge Entries</guimenuitem>"
msgstr ""
"<guimenu>Verzameling</guimenu> <guimenuitem>Items samenvoegen</guimenuitem>"

#. Tag: para
#: menus.docbook:433
#, no-c-format
msgid "This command <action>merges the selected entries</action>."
msgstr "Deze opdracht <action>voegt de geselecteerde items samen</action>."

#. Tag: menuchoice
#: menus.docbook:439
#, no-c-format
msgid "<guimenu>Collection</guimenu> <guimenuitem>Update Entry</guimenuitem>"
msgstr ""
"<guimenu>Verzameling</guimenu> <guimenuitem>Item bijwerken</guimenuitem>"

#. Tag: para
#: menus.docbook:446
#, no-c-format
msgid ""
"This menu contains a list of all available data sources, and can be used to "
"automatically query the source and <action>update the selected entries</"
"action>."
msgstr ""
"Dit menu bevat een lijst met alle beschikbare gegevensbronnen en kan "
"gebruikt worden om automatisch de bron af te vragen en <action>de "
"geselecteerde items bij te werken</action>."

#. Tag: menuchoice
#: menus.docbook:453
#, no-c-format
msgid "<guimenu>Collection</guimenu> <guimenuitem>Check-out</guimenuitem>"
msgstr "<guimenu>Collectie</guimenu> <guimenuitem>Check-out</guimenuitem>"

#. Tag: para
#: menus.docbook:460
#, no-c-format
msgid ""
"This command <action>opens a dialog box for loaning the selected entries.</"
"action>."
msgstr ""
"Deze opdracht <action>opent een dialoogvak voor lenen van de geselecteerde "
"items.</action>."

#. Tag: menuchoice
#: menus.docbook:466
#, no-c-format
msgid "<guimenu>Collection</guimenu> <guimenuitem>Check-in</guimenuitem>"
msgstr "<guimenu>Collection</guimenu> <guimenuitem>Check-in</guimenuitem>"

#. Tag: para
#: menus.docbook:473
#, no-c-format
msgid ""
"This command <action>checks-in any of the selected entries which are "
"currently on-loan</action>."
msgstr ""
"Deze opdracht <action>checkt elk van de geselecteerde items in die nu "
"geleend zijn</action>."

#. Tag: menuchoice
#: menus.docbook:479
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>R</keycap></keycombo> </shortcut> "
"<guimenu>Collection</guimenu> <guimenuitem>Rename Collection</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>R</keycap></keycombo> </shortcut> "
"<guimenu>Collectie</guimenu> <guimenuitem>Collectie hernoemen</guimenuitem>"

#. Tag: para
#: menus.docbook:489
#, no-c-format
msgid ""
"This command <action>opens a dialog box for renaming the collection</action>."
msgstr ""
"Deze opdracht <action>opent een dialoogvak voor hernoemen van de collectie</"
"action>"

#. Tag: menuchoice
#: menus.docbook:495
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>U</keycap></keycombo> </shortcut> "
"<guimenu>Collection</guimenu> <guimenuitem>Collection Fields...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>U</keycap></keycombo> </shortcut> "
"<guimenu>Collectie</guimenu> <guimenuitem>Collectievelden...</guimenuitem>"

#. Tag: para
#: menus.docbook:505
#, no-c-format
msgid ""
"This command <action>opens the <interface>Collection Fields Dialog</"
"interface></action>."
msgstr ""
"Deze opdracht <action>opent de <interface>Dialoog voor Collectievelden</"
"interface></action>."

#. Tag: menuchoice
#: menus.docbook:511
#, no-c-format
msgid ""
"<guimenu>Collection</guimenu> <guimenuitem>Generate Reports...</guimenuitem>"
msgstr ""
"<guimenu>Collectie</guimenu> <guimenuitem>Rapporten genereren...</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:518
#, no-c-format
msgid ""
"This command <action>opens the <interface>Report Dialog</interface></action> "
"for generating reports about the collection."
msgstr ""
"Deze opdracht <action>opent de <interface>Rapportdialoog</interface></"
"action> voor het genereren van rapporten over de collectie."

#. Tag: menuchoice
#: menus.docbook:524
#, no-c-format
msgid ""
"<guimenu>Collection</guimenu> <guisubmenu>Bibliography</guisubmenu> "
"<guimenuitem>Convert to Bibliography</guimenuitem>"
msgstr ""
"<guimenu>Verzameling</guimenu> <guisubmenu>Bibliografie</guisubmenu> "
"<guimenuitem>Naar bibliografie converteren</guimenuitem>"

#. Tag: para
#: menus.docbook:532
#, no-c-format
msgid ""
"This command <action>converts a book collection to a bibliography</action> "
"by adding certain fields necessary for Bibtex export, and it is only enabled "
"when a book collection is open."
msgstr ""
"Deze opdracht <action>converteert een boekenverzameling naar een "
"bibliografie</action> door bepaalde velden noodzakelijk voor exporteren naar "
"Bibtex en deze is alleen ingeschakeld wanneer een boekenverzameling is "
"geopend."

#. Tag: menuchoice
#: menus.docbook:538
#, no-c-format
msgid ""
"<guimenu>Collection</guimenu> <guisubmenu>Bibliography</guisubmenu> "
"<guimenuitem>String Macros...</guimenuitem>"
msgstr ""
"<guimenu>Verzameling</guimenu> <guisubmenu>Bibliografie</guisubmenu> "
"<guimenuitem>Macro's voor tekenreeksen...</guimenuitem>"

#. Tag: para
#: menus.docbook:546
#, no-c-format
msgid ""
"This command <action>opens a dialog box for editing the Bibtex string "
"macros</action> in the collection. It is only enabled when editing a "
"bibliography."
msgstr ""
"Deze opdracht <action>opent een dialoogvak voor bewerken van de Bibtex "
"tekenreeksmacro's</action> in de verzameling. Het is alleen ingeschakeld "
"wanneer een bibliografie wordt bewerkt."

#. Tag: menuchoice
#: menus.docbook:552
#, no-c-format
msgid ""
"<guimenu>Collection</guimenu> <guisubmenu>Bibliography</guisubmenu> "
"<guimenuitem>Check for Duplicate Keys</guimenuitem>"
msgstr ""
"<guimenu>Verzameling</guimenu> <guisubmenu>Bibliografie</guisubmenu> "
"<guimenuitem>Op dubbele sleutelwoorden controleren</guimenuitem>"

#. Tag: para
#: menus.docbook:560
#, no-c-format
msgid ""
"This command <action>checks for duplicate Bibtex keys</action> and can "
"filter the collection to show the entries with duplicated keys."
msgstr ""
"Deze opdracht <action>controleert op duplicaten van Bibtex-sleutels</action> "
"en kan de verzameling filteren om de items met dubbele sleutels te tonen."

#. Tag: menuchoice
#: menus.docbook:566
#, no-c-format
msgid ""
"<guimenu>Collection</guimenu> <guisubmenu>Bibliography</guisubmenu> "
"<guimenuitem>Copy Bibtex to Clipboard</guimenuitem>"
msgstr ""
"<guimenu>Verzameling</guimenu> <guisubmenu>Bibliografie</guisubmenu> "
"<guimenuitem>Bibtex naar klembord kopiëren</guimenuitem>"

#. Tag: para
#: menus.docbook:574
#, no-c-format
msgid ""
"This command <action>copies a Bibtex citation</action> to the clipboard so "
"that it can pasted in a LaTeX document."
msgstr ""
"Deze opdracht <action>kopieert een Bibtex citatie</action> naar het klembord "
"zodat het in een LaTeX-document kan worden geplakt."

#. Tag: menuchoice
#: menus.docbook:580
#, no-c-format
msgid ""
"<guimenu>Collection</guimenu> <guisubmenu>Bibliography</guisubmenu> "
"<guimenuitem>Cite Entry in Lyx</guimenuitem>"
msgstr ""
"<guimenu>Verzameling</guimenu> <guisubmenu>Bibliografie</guisubmenu> "
"<guimenuitem>Item in Lyx citeren</guimenuitem>"

#. Tag: para
#: menus.docbook:588
#, no-c-format
msgid ""
"This command <action>sends a citation for the selected entries</action> to "
"the so-called <emphasis><link linkend=\"hidden-bibtex-options\">lyxpipe</"
"link></emphasis> for use in <application>LyX</application>, "
"<application>Kile</application>, or other LaTeX applications. It is only "
"enabled when editing a bibliography."
msgstr ""
"Deze opdracht <action>stuurt een citaat voor de geselecteerde items</action> "
"naar de zogenaamde <emphasis><link linkend=\"hidden-bibtex-options"
"\">lyxpipe</link></emphasis> voor gebruik in <application>LyX</application>, "
"<application>Kile</application> of een andere LaTeX toepassing. Het is "
"alleen ingeschakeld bij bewerken van een bibliografie."

#. Tag: title
#: menus.docbook:599
#, no-c-format
msgid "The Settings and Help Menu"
msgstr "De menu's Instellingen en Help"

#. Tag: para
#: menus.docbook:601
#, no-c-format
msgid ""
"Apart from the common &kde; Settings and Help menus described in the <ulink "
"url=\"help:/fundamentals/menus.html\">Menu</ulink> chapter of the &kde; "
"Fundamentals documentation &tellico; has these application specific menu "
"entries:"
msgstr ""
"Naast de standaard &kde;-menu's <guimenu>Instellingen</guimenu> en "
"<guimenu>Help</guimenu> zoals beschreven in het hoofdstuk <ulink url=\"help:/"
"fundamentals/menus.html\">Menu</ulink> van de documentatie in &kde; "
"Fundamentals heeft &tellico; specifieke menu-items van het programma:"

#. Tag: menuchoice
#: menus.docbook:609
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Show Group View</guimenuitem>"
msgstr ""
"<guimenu>Instellingen</guimenu> <guimenuitem>Groepsweergave tonen</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:616
#, no-c-format
msgid ""
"This command <action>toggles the display of the <interface>Group View</"
"interface></action>."
msgstr ""
"Deze opdracht <action>schakelt het tonen van de <interface>Groepsweergave</"
"interface> om</action>."

#. Tag: menuchoice
#: menus.docbook:622
#, no-c-format
msgid ""
"<guimenu>Settings</guimenu> <guimenuitem>Show Entry Editor</guimenuitem>"
msgstr ""
"<guimenu>Instellingen</guimenu> <guimenuitem>Itembewerker tonen</guimenuitem>"

#. Tag: para
#: menus.docbook:629
#, no-c-format
msgid ""
"This command <action>toggles the display of the <interface>Entry Editor</"
"interface></action>."
msgstr ""
"Deze opdracht <action>schakelt het tonen van de <interface>Itembewerker</"
"interface> om</action>."

#. Tag: menuchoice
#: menus.docbook:635
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Group Selection</guimenuitem>"
msgstr ""
"<guimenu>Instellingen</guimenu> <guimenuitem>Selectie van groepen</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:642
#, no-c-format
msgid ""
"This command <action>changes the field used to group the entries</action> in "
"the collection."
msgstr ""
"Deze opdracht <action>wijzigt het veld gebruikt voor het groeperen van de "
"items</action> in de collectie."

#. Tag: menuchoice
#: menus.docbook:648
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Lock Layout</guimenuitem>"
msgstr ""
"<guimenu>Instellingen</guimenu> <guimenuitem>Indeling vergrendelen</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:655
#, no-c-format
msgid ""
"This command <action>locks the layout</action> such that the various "
"collection views cannot be moved. Unlocking the layout allows the user to "
"rearrange them."
msgstr ""
"Deze opdracht <action>vergrendelt de indeling</action> zodat de "
"verschillende weergaven van verzamelingen niet verplaatst kunnen worden. De "
"indeling ontgrendelen biedt de gebruiker ze opnieuw te arrangeren."

#. Tag: menuchoice
#: menus.docbook:661
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Reset Layout</guimenuitem>"
msgstr ""
"<guimenu>Instellingen</guimenu> <guimenuitem>Indeling resetten</guimenuitem>"

#. Tag: para
#: menus.docbook:668
#, no-c-format
msgid ""
"This command <action>resets the layout</action> to the default view, which "
"may be helpful if the various views become hidden or collapsed."
msgstr ""
"Deze opdracht <action>reset de indeling</action> naar de standaard weergave, "
"die behulpzaam kan zijn als de verschillende weergaven verborgen of "
"ingevouwen worden."

#. Tag: menuchoice
#: menus.docbook:674
#, no-c-format
msgid "<guimenu>Help</guimenu> <guimenuitem>Show Log</guimenuitem>"
msgstr "<guimenu>Help</guimenu> <guimenuitem>Log tonen</guimenuitem>"

#. Tag: para
#: menus.docbook:681
#, no-c-format
msgid ""
"When the <userinput>tellico --log</userinput> option is used, this command "
"shows the diagnostic log."
msgstr ""
"Wanneer de optie <userinput>tellico --log</userinput> wordt gebruikt, zal "
"deze opdracht de diagnostische log tonen."

