#. Tag: title
#: reportsgeneratorview.docbook:2
#, no-c-format
msgid "<title>Description</title>"
msgstr "<title>Beschrijving</title>"

#. Tag: para
#: reportsgeneratorview.docbook:3
#, no-c-format
msgid ""
"The Reports Generator View is used to add and generate reports in Open "
"Document Text (odt) format."
msgstr ""
"Het Beeld van Rapportengenerator wordt gebruikt om rapporten toe te voegen "
"en te genereren in Open Document Text (odt) formaat."

#. Tag: para
#: reportsgeneratorview.docbook:4
#, no-c-format
msgid ""
"The reports can be based on the supplied report templates, or you can <link "
"linkend=\"creating-odt-report-templates\">write your own templates</link>."
msgstr ""
"De rapporten kunnen gebaseerd zijn op de geleverde rapportsjablonen of u "
"kunt <link linkend=\"creating-odt-report-templates\">uw eigen sjablonen "
"schrijven</link>."

#. Tag: guilabel
#: reportsgeneratorview.docbook:24
#, no-c-format
msgid "Column"
msgstr "Kolom"

#. Tag: guilabel
#: reportsgeneratorview.docbook:25 reportsgeneratorview.docbook:81
#, no-c-format
msgid "<guilabel>Description</guilabel>"
msgstr "<guilabel>Beschrijving</guilabel>"

#. Tag: para
#: reportsgeneratorview.docbook:31
#, no-c-format
msgid "Name"
msgstr "Naam"

#. Tag: para
#: reportsgeneratorview.docbook:34
#, no-c-format
msgid "A name of your choice"
msgstr "Een door u gekozen naam"

#. Tag: para
#: reportsgeneratorview.docbook:39
#, no-c-format
msgid "Report Template"
msgstr "Rapportsjabloon"

#. Tag: para
#: reportsgeneratorview.docbook:42
#, no-c-format
msgid ""
"Path to the report template file. You can select one of the supplied "
"standard templates or you can enter the filename of a template you provide "
"yourself."
msgstr ""
"Pad naar het rapportsjabloonbestand. U kunt een van de geleverde standaard "
"sjablonen selecteren of u kunt de bestandsnaam van een sjabloon die u zelf "
"hebt gemaakt invoeren."

#. Tag: para
#: reportsgeneratorview.docbook:47
#, no-c-format
msgid "Report File"
msgstr "Rapportbestand"

#. Tag: para
#: reportsgeneratorview.docbook:50
#, no-c-format
msgid "The name of the file that will be generated."
msgstr "De naam van het bestand dat zal worden gegenereerd."

#. Tag: para
#: reportsgeneratorview.docbook:55
#, no-c-format
msgid "<para>Add</para>"
msgstr "<para>Toevoegen</para>"

#. Tag: para
#: reportsgeneratorview.docbook:58
#, no-c-format
msgid ""
"Information that can be added to the report file name to distinguish it from "
"previously generated versions. This can be:"
msgstr ""
"Informatie die toegevoegd kan worden aan de rapportbestandsnaam om het te "
"onderscheiden van eerder gegenereerde versies. Dit kan zijn:"

#. Tag: para
#: reportsgeneratorview.docbook:60
#, no-c-format
msgid "<emphasis>Nothing</emphasis>; use the filename as is"
msgstr "<emphasis>Niets</emphasis>; gebruik de bestandsnaam zoals deze is"

#. Tag: para
#: reportsgeneratorview.docbook:61
#, no-c-format
msgid "<emphasis>Number</emphasis>; add a sequence number to the file name"
msgstr ""
"<emphasis>Nummer</emphasis>; voeg een volgnummer toe aan de bestandsnaam"

#. Tag: para
#: reportsgeneratorview.docbook:62
#, no-c-format
msgid "<emphasis>Date</emphasis>; add the current date to the file name"
msgstr ""
"<emphasis>Datum</emphasis>; voeg de huidige datum toe aan de bestandsnaam"

#. Tag: title
#: reportsgeneratorview.docbook:71
#, no-c-format
msgid "Toolbar"
msgstr "Werkbalk"

#. Tag: para
#: reportsgeneratorview.docbook:72
#, no-c-format
msgid "The toolbar provides the means to add, remove and generate reports."
msgstr ""
"De werkbalk biedt de middelen om rapporten toe te voegen, te verwijderen en "
"te genereren."

#. Tag: guilabel
#: reportsgeneratorview.docbook:79
#, no-c-format
msgid "Button"
msgstr "Knop"

#. Tag: guilabel
#: reportsgeneratorview.docbook:80
#, no-c-format
msgid "Shortcut"
msgstr "Sneltoets"

