#. Tag: para
#: introduction.docbook:2
#, no-c-format
msgid "Features include:"
msgstr "Functies omvatten:"

#. Tag: para
#: introduction.docbook:5
#, no-c-format
msgid ""
"Task management using the <link linkend=\"task-editor\">Task Editor</"
"link>&nbsp;"
msgstr ""
"Taakbeheer met de <link linkend=\"task-editor\">Takenbewerker</link>&nbsp;"

#. Tag: para
#: introduction.docbook:6
#, no-c-format
msgid "Work breakdown structure with configurable WBS codes"
msgstr "Structuur voor opsplitsing werktaken met te configureren WBS codes"

#. Tag: para
#: introduction.docbook:7
#, no-c-format
msgid "Tasks, summary tasks, and milestones"
msgstr "Taken, samenvatting van taken en mijlpalen"

#. Tag: para
#: introduction.docbook:8
#, no-c-format
msgid "Different types of time constraints"
msgstr "Verschillende typen beperkingen in tijd"

#. Tag: para
#: introduction.docbook:9
#, no-c-format
msgid "Different types of dependencies."
msgstr "Verschillende typen afhankelijkheden."

#. Tag: para
#: introduction.docbook:12
#, no-c-format
msgid ""
"Resource management using the <link linkend=\"resource-editor\">Resource "
"Editor</link>&nbsp;"
msgstr ""
"Hulpbronbeheer met de <link linkend=\"resource-editor\">Hulpbronbewerker</"
"link>&nbsp;"

#. Tag: para
#: introduction.docbook:13
#, no-c-format
msgid "Resource breakdown structure"
msgstr "Structuur voor opsplitsing hulpbronnen"

#. Tag: para
#: introduction.docbook:14
#, no-c-format
msgid "Working- and material resource types"
msgstr "Typen werk- en materiaalhulpbronnen"

#. Tag: para
#: introduction.docbook:15
#, no-c-format
msgid "Resource allocation on group level"
msgstr "Hulpbrontoewijzing op groepsniveau"

#. Tag: para
#: introduction.docbook:16
#, no-c-format
msgid "Resource teams"
msgstr "Hulpbronteams"

#. Tag: para
#: introduction.docbook:19
#, no-c-format
msgid ""
"Work time &amp; vacation definition using the <link linkend=\"work-and-"
"vacation-editor\">Work and Vacation Editor</link>&nbsp;"
msgstr ""
"Definitie van werktijd &amp; vacatie met de <link linkend=\"work-and-"
"vacation-editor\">Bewerker voor werk en vacatie</link>&nbsp;"

#. Tag: para
#: introduction.docbook:20
#, no-c-format
msgid ""
"Cost management using the <link linkend=\"cost-breakdown-structure-editor"
"\">Cost Breakdown Structure Editor</link>&nbsp;"
msgstr ""
"Kostenbeheer met de <link linkend=\"cost-breakdown-structure-editor"
"\">Bewerker voor opbreken van kostenstructuur</link>&nbsp;"

#. Tag: para
#: introduction.docbook:21
#, no-c-format
msgid "Earned value management"
msgstr "Beheer van verdiende waarde"

#. Tag: para
#: introduction.docbook:22
#, no-c-format
msgid ""
"Project scheduling using the <link linkend=\"schedules-editor\">Schedules "
"Editor</link>&nbsp;"
msgstr ""
"Projectplanning met de <link linkend=\"schedules-editor\">Bewerker voor "
"planning</link>&nbsp;"

#. Tag: para
#: introduction.docbook:23
#, no-c-format
msgid "Schedule forward from start time or backward from finish time"
msgstr "Vooruit plannen vanaf begintijd of achteruit vanaf eindtijd"

#. Tag: para
#: introduction.docbook:24
#, no-c-format
msgid "Allow or avoid resource overbooking"
msgstr "Overboeken van hulpbron toestaan of vermijden"

#. Tag: para
#: introduction.docbook:25
#, no-c-format
msgid ""
"PERT distribution with optimistic-, pessimistic-, and most likely estimates"
msgstr ""
"PERT distributie met optimistische, pessimistische en meest waarschijnlijke "
"schattingen"

#. Tag: para
#: introduction.docbook:26
#, no-c-format
msgid ""
"Multiple schedules with a possibility to schedule from current progress "
"information"
msgstr ""
"Meerdere planningen met een mogelijkheid om te plannen vanaf de huidige "
"informatie over voorgang"

#. Tag: para
#: introduction.docbook:29
#, no-c-format
msgid ""
"Task tracking using the <link linkend=\"task-execution-view\">Task Execution "
"View</link> or <link linkend=\"task-status-view\">Task Status View</"
"link>&nbsp;"
msgstr ""
"Volgen van taken met de <link linkend=\"task-execution-view\">Weergave van "
"uitvoering van taken</link> of <link linkend=\"task-status-view\">Weergave "
"van taakstatus</link>&nbsp;"

#~ msgid "Introduction"
#~ msgstr "Inleiding"
