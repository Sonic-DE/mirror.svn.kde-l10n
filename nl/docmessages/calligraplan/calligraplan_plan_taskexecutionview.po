#. Tag: title
#: taskexecutionview.docbook:2
#, no-c-format
msgid "<title>Description</title>"
msgstr "<title>Beschrijving</title>"

#. Tag: para
#: taskexecutionview.docbook:3
#, no-c-format
msgid ""
"The Task Execution View is used to inspect task performance information."
msgstr ""
"Het beeld van taakuitvoering wordt gebruikt om informatie over "
"taakprestaties te inspecteren."

#. Tag: title
#: taskexecutionview.docbook:20
#, no-c-format
msgid "Data"
msgstr "Gegevens"

#. Tag: para
#: taskexecutionview.docbook:27
#, no-c-format
msgid ""
"Progress information can be edited in-line as described <link linkend="
"\"using-the-views\">here</link> or by using the task progress dialog."
msgstr ""
"Voortgangsinformatie kan in-line bewerkt worden zoals <link linkend=\"using-"
"the-views\">hier</link> beschreven of door de taakvoortgangsdialoog te "
"gebruiken."

