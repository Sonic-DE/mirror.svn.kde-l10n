#. Tag: title
#: resourceassignmentview.docbook:2
#, no-c-format
msgid "<title>Description</title>"
msgstr "<title>Beschrijving</title>"

#. Tag: para
#: resourceassignmentview.docbook:3
#, no-c-format
msgid ""
"The Resource Assignment View displays the scheduled task-resource "
"assignments in a table."
msgstr ""
"De weergave van hulpbrontoewijzingen toont de geplande toekenningen van "
"taakhulpbronnen in een tabel."

#. Tag: para
#: resourceassignmentview.docbook:5
#, no-c-format
msgid "This view can severely impact performance in large projects."
msgstr ""
"Deze weergave kan een ernstige aanslag op de prestaties hebben in grote "
"projecten."

#. Tag: title
#: resourceassignmentview.docbook:26
#, no-c-format
msgid "Data"
msgstr "Gegevens"

#. Tag: para
#: resourceassignmentview.docbook:27
#, no-c-format
msgid "The following columns are displayed as default:"
msgstr "De volgende kolommen worden standaard getoond:"

#. Tag: guilabel
#: resourceassignmentview.docbook:34
#, no-c-format
msgid "Column"
msgstr "Kolom"

#. Tag: guilabel
#: resourceassignmentview.docbook:35
#, no-c-format
msgid "<guilabel>Description</guilabel>"
msgstr "<guilabel>Beschrijving</guilabel>"

#. Tag: para
#: resourceassignmentview.docbook:41
#, no-c-format
msgid "Name"
msgstr "Naam"

#. Tag: para
#: resourceassignmentview.docbook:44
#, no-c-format
msgid "The name of the object (Resource group, resource, task)"
msgstr "De naam van het object (hulpbrongroep, hulpbron, taak)"

#. Tag: para
#: resourceassignmentview.docbook:49
#, no-c-format
msgid "Total"
msgstr "Totaal"

#. Tag: para
#: resourceassignmentview.docbook:52
#, no-c-format
msgid "The total assignment for a resource"
msgstr "De totale toekenning voor een hulpbron"

#. Tag: para
#: resourceassignmentview.docbook:57
#, no-c-format
msgid "Dates"
msgstr "Datums"

#. Tag: para
#: resourceassignmentview.docbook:60
#, no-c-format
msgid ""
"The total assignments for a resource per day and the assignments for the "
"resource per task."
msgstr ""
"De totale toekenning voor een hulpbron per dag en de toekenningen voor de "
"hulpbron per taak."

#. Tag: title
#: resourceassignmentview.docbook:67
#, no-c-format
msgid "Editing data"
msgstr "Gegevens bewerken "

#. Tag: para
#: resourceassignmentview.docbook:68
#, no-c-format
msgid "The task description and progress can be edited using the context menu."
msgstr ""
"De taakbeschrijving en voortgang kan bewerkt worden met het contextmenu."

