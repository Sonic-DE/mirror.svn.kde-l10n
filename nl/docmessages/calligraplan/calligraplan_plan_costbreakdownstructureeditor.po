#. Tag: title
#: costbreakdownstructureeditor.docbook:2
#, no-c-format
msgid "<title>Description</title>"
msgstr "<title>Beschrijving</title>"

#. Tag: para
#: costbreakdownstructureeditor.docbook:3
#, no-c-format
msgid ""
"The Cost Breakdown Structure Editor is used to create, edit, and delete "
"accounts."
msgstr ""
"De bewerker voor Structuur voor opsplitsing kosten wordt gebruikt om "
"accounts aan te maken, te bewerken en te verwijderen."

#. Tag: para
#: costbreakdownstructureeditor.docbook:19
#, no-c-format
msgid ""
"Accounts can be connected to by tasks and resources to accumulate costs from "
"those tasks and resources."
msgstr ""
"Accounts kunnen verbonden worden door taken en hulpbronnen om kosten uit die "
"taken en hulpbronnen te accumuleren."

#. Tag: para
#: costbreakdownstructureeditor.docbook:21
#, no-c-format
msgid ""
"The default account accumulates costs incurred from tasks that are not "
"connected to an account."
msgstr ""
"Het standaard account accumuleert kosten komend van taken die niet verbonden "
"zijn met een account."

#. Tag: title
#: costbreakdownstructureeditor.docbook:24
#, no-c-format
msgid "Toolbar"
msgstr "Werkbalk"

#. Tag: para
#: costbreakdownstructureeditor.docbook:25
#, no-c-format
msgid "The toolbar provides the means to create and delete accounts:"
msgstr ""
"De werkbalk biedt de middelen om accounts aan te maken en te verwijderen:"

#. Tag: guilabel
#: costbreakdownstructureeditor.docbook:32
#, no-c-format
msgid "Button"
msgstr "Knop"

#. Tag: guilabel
#: costbreakdownstructureeditor.docbook:33
#, no-c-format
msgid "Shortcut"
msgstr "Sneltoets"

#. Tag: guilabel
#: costbreakdownstructureeditor.docbook:34
#: costbreakdownstructureeditor.docbook:86
#, no-c-format
msgid "<guilabel>Description</guilabel>"
msgstr "<guilabel>Beschrijving</guilabel>"

#. Tag: para
#: costbreakdownstructureeditor.docbook:40
#, no-c-format
msgid "Add Account"
msgstr "Account toevoegen"

#. Tag: keycombo
#: costbreakdownstructureeditor.docbook:43
#, no-c-format
msgid "&Ctrl;<keycap>I</keycap>"
msgstr "&Ctrl;<keycap>I</keycap>"

#. Tag: para
#: costbreakdownstructureeditor.docbook:46
#, no-c-format
msgid ""
"Button to create an account. The new account is inserted after the selected "
"account. If no account is selected, the new account is appended at the top "
"level."
msgstr ""
"Knop om een account aan te maken. Het nieuwe account wordt ingevoegd na het "
"geselecteerde account. Als geen account is geselecteerd wordt het nieuwe "
"account toegevoegd aan het hoogste niveau."

#. Tag: para
#: costbreakdownstructureeditor.docbook:51
#, no-c-format
msgid "Add Subaccount"
msgstr "Subaccount toevoegen"

#. Tag: keycombo
#: costbreakdownstructureeditor.docbook:54
#, no-c-format
msgid "&Ctrl;&Shift;<keycap>I</keycap>"
msgstr "&Ctrl;&Shift;<keycap>I</keycap>"

#. Tag: para
#: costbreakdownstructureeditor.docbook:57
#, no-c-format
msgid ""
"Button to create a sub-account. The new account is appended as a child to "
"selected account."
msgstr ""
"Knop om een sub-account aan te maken. Het nieuwe account is toegevoegd als "
"een afgeleide van het geselecteerde account."

#. Tag: para
#: costbreakdownstructureeditor.docbook:62
#, no-c-format
msgid "<para>Delete</para>"
msgstr "<para>Verwijderen</para>"

#. Tag: keycap
#: costbreakdownstructureeditor.docbook:65
#, no-c-format
msgid "<keycap>Delete</keycap>"
msgstr "<keycap>Verwijderen</keycap>"

#. Tag: para
#: costbreakdownstructureeditor.docbook:68
#, no-c-format
msgid "Deletes the selected account."
msgstr "Verwijdert het geselecteerde account."

#. Tag: title
#: costbreakdownstructureeditor.docbook:75
#, no-c-format
msgid "Editing data"
msgstr "Gegevens bewerken "

#. Tag: para
#: costbreakdownstructureeditor.docbook:76
#, no-c-format
msgid ""
"Data can be edited inline as described <link linkend=\"using-the-views"
"\">here</link>."
msgstr ""
"Gegevens kunnen inline bewerkt worden zoals <link linkend=\"using-the-views"
"\">hier</link> beschreven."

