#. Tag: title
#: resourceassignmentganttview.docbook:2
#, no-c-format
msgid "<title>Description</title>"
msgstr "<title>Beschrijving</title>"

#. Tag: para
#: resourceassignmentganttview.docbook:3
#, no-c-format
msgid ""
"The Resource Assignment Gantt View displays the scheduled task-resource "
"assignments in a Gantt chart."
msgstr ""
"De Ganttweergave van hulpbrontoewijzingen toont de geplande toekenningen van "
"taakhulpbronnen in een Gantt-grafiek."

#. Tag: title
#: resourceassignmentganttview.docbook:24
#, no-c-format
msgid "Data"
msgstr "Gegevens"

#. Tag: para
#: resourceassignmentganttview.docbook:25
#, no-c-format
msgid "The following columns are displayed as default:"
msgstr "De volgende kolommen worden standaard getoond:"

#. Tag: guilabel
#: resourceassignmentganttview.docbook:32
#, no-c-format
msgid "Column"
msgstr "Kolom"

#. Tag: guilabel
#: resourceassignmentganttview.docbook:33
#, no-c-format
msgid "<guilabel>Description</guilabel>"
msgstr "<guilabel>Beschrijving</guilabel>"

#. Tag: para
#: resourceassignmentganttview.docbook:39
#, no-c-format
msgid "Name"
msgstr "Naam"

#. Tag: para
#: resourceassignmentganttview.docbook:42
#, no-c-format
msgid "The name of the object (Resource group, resource, task)"
msgstr "De naam van het object (hulpbrongroep, hulpbron, taak)"

#. Tag: para
#: resourceassignmentganttview.docbook:47
#, no-c-format
msgid "Type"
msgstr "Type"

#. Tag: para
#: resourceassignmentganttview.docbook:50
#, no-c-format
msgid "Object type"
msgstr "Objecttype"

#. Tag: para
#: resourceassignmentganttview.docbook:55
#, no-c-format
msgid "Start Time"
msgstr "Starttijd"

#. Tag: para
#: resourceassignmentganttview.docbook:58
#, no-c-format
msgid "The start of the assignment"
msgstr "De start van de toekenning"

#. Tag: para
#: resourceassignmentganttview.docbook:63
#, no-c-format
msgid "End Time"
msgstr "Eindtijd"

#. Tag: para
#: resourceassignmentganttview.docbook:66
#, no-c-format
msgid "The end of the assignment"
msgstr "Het einde van de toekenning"

#. Tag: title
#: resourceassignmentganttview.docbook:73
#, no-c-format
msgid "Editing data"
msgstr "Gegevens bewerken "

#. Tag: para
#: resourceassignmentganttview.docbook:74
#, no-c-format
msgid "The task description and progress can be edited using the context menu."
msgstr ""
"De taakbeschrijving en voortgang kan bewerkt worden met het contextmenu."

#. Tag: title
#: resourceassignmentganttview.docbook:77
#, no-c-format
msgid "Configuration"
msgstr "Configuratie"

#. Tag: para
#: resourceassignmentganttview.docbook:84
#, no-c-format
msgid ""
"Using the context menu, the view can be configured using the configure "
"dialog."
msgstr ""
"Met het contextmenu kan de weergave geconfigureerd worden met de "
"configuratiedialoog."

#. Tag: para
#: resourceassignmentganttview.docbook:84
#, no-c-format
msgid "The configure dialog enables you to select which columns to display."
msgstr ""
"De configuratiedialoog biedt u het selecteren van welke kolommen te tonen."

#. Tag: phrase
#: resourceassignmentganttview.docbook:97
#, no-c-format
msgid "<phrase>Configuration Dialog</phrase>"
msgstr "<phrase>Configuratiedialoog</phrase>"

