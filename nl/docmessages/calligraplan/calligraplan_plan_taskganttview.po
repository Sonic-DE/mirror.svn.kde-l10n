#. Tag: title
#: taskganttview.docbook:2
#, no-c-format
msgid "<title>Description</title>"
msgstr "<title>Beschrijving</title>"

#. Tag: para
#: taskganttview.docbook:3
#, no-c-format
msgid "The Gantt view is used to show tasks in a timeline."
msgstr "De Gantt-weergave wordt gebruikt om taken in een tijdlijn te tonen."

#. Tag: phrase
#: taskganttview.docbook:14
#, no-c-format
msgid "<phrase>Gantt View</phrase>"
msgstr "<phrase>Ganttweergave</phrase>"

#. Tag: para
#: taskganttview.docbook:17
#, no-c-format
msgid "<para>Gantt View</para>"
msgstr "<para>Ganttweergave</para>"

#. Tag: title
#: taskganttview.docbook:23
#, no-c-format
msgid "Editing data"
msgstr "Gegevens bewerken "

#. Tag: para
#: taskganttview.docbook:24
#, no-c-format
msgid "Task description and progress can be edited using the context menu."
msgstr "Taakbeschrijving en voortgang kan bewerkt worden met het contextmenu."

#. Tag: para
#: taskganttview.docbook:26
#, no-c-format
msgid "The following columns are displayed as default:"
msgstr "De volgende kolommen worden standaard getoond:"

#. Tag: guilabel
#: taskganttview.docbook:33
#, no-c-format
msgid "Column"
msgstr "Kolom"

#. Tag: guilabel
#: taskganttview.docbook:34
#, no-c-format
msgid "<guilabel>Description</guilabel>"
msgstr "<guilabel>Beschrijving</guilabel>"

#. Tag: para
#: taskganttview.docbook:40
#, no-c-format
msgid "Name"
msgstr "Naam"

#. Tag: para
#: taskganttview.docbook:43
#, no-c-format
msgid "The name of the task."
msgstr "De naam van de taak."

#. Tag: para
#: taskganttview.docbook:48
#, no-c-format
msgid "Start Time"
msgstr "Starttijd"

#. Tag: para
#: taskganttview.docbook:51
#, no-c-format
msgid "The scheduled start time."
msgstr "De geplande starttijd."

#. Tag: para
#: taskganttview.docbook:56
#, no-c-format
msgid "End Time"
msgstr "Eindtijd"

#. Tag: para
#: taskganttview.docbook:59
#, no-c-format
msgid "The scheduled end time."
msgstr "De geplande eindtijd."

#. Tag: para
#: taskganttview.docbook:64
#, no-c-format
msgid "% Completed"
msgstr "% voltooid"

#. Tag: para
#: taskganttview.docbook:67
#, no-c-format
