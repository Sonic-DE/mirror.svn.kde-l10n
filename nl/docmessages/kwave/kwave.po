#. Tag: title
#: index.docbook:2589
#, no-c-format
msgid "&no-i18n-cmd_delete;"
msgstr "&no-i18n-cmd_delete;"

#. Tag: title
#: index.docbook:2591
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_delete;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_delete;</command>()"

#. Tag: para
#: index.docbook:2592
#, no-c-format
msgid ""
"Deletes the currently selected range of samples. If the selection is empty, "
"this command does nothing. Affects all tracks."
msgstr ""
"Verwijdert de nu geselecteerde reeks samples. Als de selectie leeg is, doet "
"dit commando niets. Betreft alle tracks."

#. Tag: title
#: index.docbook:2601
#, no-c-format
msgid "&no-i18n-cmd_delete_track;"
msgstr "&no-i18n-cmd_delete_track;"

#. Tag: title
#: index.docbook:2603
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_delete_track;</"
"command>(<replaceable>index</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_delete_track;</"
"command>(<replaceable>index</replaceable>)"

#. Tag: para
#: index.docbook:2604
#, no-c-format
msgid ""
"Deletes a track, identified by its index (starting from zero). If no track "
"with the given index exists, this command exits with an error."
msgstr ""
"Verwijdert een track, geïdentificeerd door zijn index (beginnend vanaf nul). "
"Als geen track met de gegeven index bestaat, dan eindigt dit commando met "
"een fout."

#. Tag: entry
#: index.docbook:2610 index.docbook:2733 index.docbook:2772 index.docbook:2800
#: index.docbook:3563 index.docbook:3577 index.docbook:3592
#, no-c-format
msgid "<parameter>index</parameter>:"
msgstr "<parameter>index</parameter>:"

#. Tag: entry
#: index.docbook:2610
#, no-c-format
msgid "index of the track to delete, starting with 0"
msgstr "index van de te verwijderen track, beginnend met 0"

#. Tag: title
#: index.docbook:2615
#, no-c-format
msgid "&no-i18n-cmd_dump_metadata;"
msgstr "&no-i18n-cmd_dump_metadata;"

#. Tag: title
#: index.docbook:2617
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_dump_metadata;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_dump_metadata;</"
"command>()"

#. Tag: para
#: index.docbook:2618
#, no-c-format
msgid ""
"Prints a list of all meta data entries to the console, for diagnostic "
"purposes. (Only available when &kwave; has been compiled with the option "
"<literal>WITH_DEBUG</literal> switched on)."
msgstr ""
"Toont een lijst met alle metagegevensitems op het console, voor diagnostiek. "
"(Alleen beschikbaar wanneer &kwave; gecompileerd is met de optie "
"<literal>WITH_DEBUG</literal> ingeschakeld)."

#. Tag: title
#: index.docbook:2627
#, no-c-format
msgid "&no-i18n-tag;e"
msgstr "&no-i18n-tag;e"

#. Tag: title
#: index.docbook:2630
#, no-c-format
msgid "&no-i18n-cmd_expandtolabel;"
msgstr "&no-i18n-cmd_expandtolabel;"

#. Tag: title
#: index.docbook:2632
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_expandtolabel;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_expandtolabel;</"
"command>()"

#. Tag: para
#: index.docbook:2633
#, no-c-format
msgid ""
"Expands the current selection to the labels left and right from the current "
"selection borders. If the border of selection already is on a label, it "
"stays unchanged. If there is no label left or right of the current "
"selection, it will be expanded to the start or end of the file."
msgstr ""
"Expandeert de huidige selectie tot de labels links en rechts van de huidige "
"selectieranden. Als de rand van de selectie al op een label staat, blijft "
"het ongewijzigd. Als er geen label meer is naar links of recht van de "
"huidige selectie, zal het geëxpandeerd worden naar het begin of einde van "
"het bestand."

#. Tag: title
#: index.docbook:2644
#, no-c-format
msgid "&no-i18n-tag;f"
msgstr "&no-i18n-tag;f"

#. Tag: title
#: index.docbook:2647
#, no-c-format
msgid "&no-i18n-cmd_fileinfo;"
msgstr "&no-i18n-cmd_fileinfo;"

#. Tag: title
#: index.docbook:2649
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_fileinfo;</"
"command>(<replaceable>index</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_fileinfo;</"
"command>(<replaceable>index</replaceable>)"

#. Tag: para
#: index.docbook:2650
#, no-c-format
msgid "Set a file info entry to a new value."
msgstr "Stelt een item met bestandsinformatie in op een nieuwe waarde."

#. Tag: entry
#: index.docbook:2655
#, no-c-format
msgid "<parameter>keyword</parameter>:"
msgstr "<parameter>trefwoord</parameter>:"

#. Tag: entry
#: index.docbook:2655
#, no-c-format
msgid "keyword of the entry"
msgstr "trefwoord van het item"

#. Tag: entry
#: index.docbook:2656
#, no-c-format
msgid "<parameter>value</parameter>:"
msgstr "<parameter>waarde</parameter>:"

#. Tag: entry
#: index.docbook:2656
#, no-c-format
msgid "value of the entry"
msgstr "waarde van het item"

#. Tag: title
#: index.docbook:2661
#, no-c-format
msgid "&no-i18n-cmd_forward;"
msgstr "&no-i18n-cmd_forward;"

#. Tag: title
#: index.docbook:2663
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_forward;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_forward;</command>()"

#. Tag: para
#: index.docbook:2664
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Forward</guibutton> toolbar button. If the "
"playback is currently running, it skips forward by 1/10 of the visible "
"range. If the playback is not running, this does the same as the command "
"<command>&no-i18n-cmd_view_scroll_right;</command>()."
msgstr ""
"Komt overeen met de knop op de werkbalk <guibutton>Voorwaarts</guibutton>. "
"Als het afspelen nu bezig is, springt het voorwaarts met 1/10 van de "
"zichtbare reeks. Als het afspelen niet bezig is, doet dit hetzelfde als het "
"commando <command>&no-i18n-cmd_view_scroll_right;</command>()."

#. Tag: para
#: index.docbook:2673
#, no-c-format
msgid ""
"<link linkend=\"cmd_sect_view_scroll_right\"><command>&no-i18n-tag;&no-i18n-"
"cmd_view_scroll_right;</command>()</link>, <link linkend=\"cmd_sect_rewind"
"\"><command>&no-i18n-tag;&no-i18n-cmd_rewind;</command>()</link>"
msgstr ""
"<link linkend=\"cmd_sect_view_scroll_right\"><command>&no-i18n-tag;&no-i18n-"
"cmd_view_scroll_right;</command>()</link>, <link linkend=\"cmd_sect_rewind"
"\"><command>&no-i18n-tag;&no-i18n-cmd_rewind;</command>()</link>"

#. Tag: title
#: index.docbook:2681
#, no-c-format
msgid "&no-i18n-tag;g"
msgstr "&no-i18n-tag;g"

#. Tag: title
#: index.docbook:2684
#, no-c-format
msgid "&no-i18n-cmd_goto;"
msgstr "&no-i18n-cmd_goto;"

#. Tag: title
#: index.docbook:2686
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_goto;</command>(<replaceable>pos</"
"replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_goto;</command>(<replaceable>pos</"
"replaceable>)"

#. Tag: para
#: index.docbook:2687
#, no-c-format
msgid ""
"Sets the cursor to the given position and makes it visible in current view. "
"After this the selection has zero length."
msgstr ""
"Zet de cursor op de gegeven positie en maakt het zichtbaar in de huidige "
"weergave. Hierna heeft de selectie de lengte nul."

#. Tag: entry
#: index.docbook:2693 index.docbook:2711 index.docbook:2756
#, no-c-format
msgid "<parameter>pos</parameter>:"
msgstr "<parameter>pos</parameter>:"

#. Tag: entry
#: index.docbook:2693
#, no-c-format
msgid "position in samples where to go to"
msgstr "positie in samples waar naar toe te gaan"

#. Tag: title
#: index.docbook:2698
#, no-c-format
msgid "&no-i18n-tag;i"
msgstr "&no-i18n-tag;i"

#. Tag: title
#: index.docbook:2701
#, no-c-format
msgid "&no-i18n-cmd_insert_at;"
msgstr "&no-i18n-cmd_insert_at;"

#. Tag: title
#: index.docbook:2703
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_insert_at;</"
"command>(<replaceable>pos</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_insert_at;</"
"command>(<replaceable>pos</replaceable>)"

#. Tag: para
#: index.docbook:2704
#, no-c-format
msgid ""
"Inserts the content of the clipboard at the given position, like the command "
"<command>&no-i18n-cmd_paste;</command>(). If the clipboard is currently "
"empty, this function does nothing."
msgstr ""
"Voegt de inhoud van het klembord in op de gegeven positie, zoals het "
"commando <command>&no-i18n-cmd_paste;</command>(). Als het klembord nu leeg "
"is, doet deze functie niets."

#. Tag: entry
#: index.docbook:2711
#, no-c-format
msgid "position in samples where to insert"
msgstr "positie in samples waar in te voegen"

#. Tag: title
#: index.docbook:2719
#, no-c-format
msgid "&no-i18n-cmd_insert_track;"
msgstr "&no-i18n-cmd_insert_track;"

#. Tag: title
#: index.docbook:2721
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_insert_track;</"
"command>(<replaceable>index</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_insert_track;</"
"command>(<replaceable>index</replaceable>)"

#. Tag: para
#: index.docbook:2722
#, no-c-format
msgid ""
"Inserts a new track at the given index, using the current length and sample "
"rate settings of the signal. If the index is higher than or equal to the "
"current number of tracks, it will be appended as the last track, same as by "
"the command <command>&no-i18n-cmd_add_track;</command>(). The index of all "
"existing tracks at and after the given index will be incremented by one."
msgstr ""
"Voeg een nieuwe track toe op de gegeven index, met gebruik van de huidige "
"instellingen voor lengte en samplesnelheid van het signaal. Als de index "
"hoger is dan of gelijk aan het huidige aantal tracks, zal het achtergevoegd "
"worden als de laatste track, hetzelfde als bij het commando <command>&no-"
"i18n-cmd_add_track;</command>(). De index van alle bestaande tracks op en na "
"de gegeven index zal met één opgehoogd worden."

#. Tag: entry
#: index.docbook:2733
#, no-c-format
msgid "index of the track to insert, starting with 0"
msgstr "index van de te in te voegen track, beginnend met 0"

#. Tag: link
#: index.docbook:2737
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_add_track;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_add_track;</command>()"

#. Tag: title
#: index.docbook:2743
#, no-c-format
msgid "&no-i18n-tag;l"
msgstr "&no-i18n-tag;l"

#. Tag: title
#: index.docbook:2746
#, no-c-format
msgid "&no-i18n-cmd_label_add;"
msgstr "&no-i18n-cmd_label_add;"

#. Tag: title
#: index.docbook:2748
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_label_add;</"
"command>(<replaceable>pos</replaceable>[,<replaceable>text</replaceable>])"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_label_add;</"
"command>(<replaceable>pos</replaceable>[,<replaceable>tekst</replaceable>])"

#. Tag: para
#: index.docbook:2749
#, no-c-format
msgid ""
"Add a new label at a given position. If the given position already contains "
"a label, then this command does nothing. The label can be given an optional "
"description."
msgstr ""
"Voeg een nieuw label toe op een gegeven positie. Als de gegeven positie al "
"een label bevat, dan doet dit commando niets. Het label kan optioneel een "
"beschrijving krijgen."

#. Tag: entry
#: index.docbook:2756
#, no-c-format
msgid "position in samples where to insert the label"
msgstr "positie in samples waar het label in te voegen"

#. Tag: entry
#: index.docbook:2757 index.docbook:3055
#, no-c-format
msgid "<parameter>text</parameter>:"
msgstr "<parameter>tekst</parameter>:"

#. Tag: entry
#: index.docbook:2757
#, no-c-format
msgid "some descriptive text (optional)"
msgstr "enige beschrijvende tekst (optioneel)"

#. Tag: title
#: index.docbook:2762
#, no-c-format
msgid "&no-i18n-cmd_label_delete;"
msgstr "&no-i18n-cmd_label_delete;"

#. Tag: title
#: index.docbook:2764
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_label_delete;</"
"command>(<replaceable>index</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_label_delete;</"
"command>(<replaceable>index</replaceable>)"

#. Tag: para
#: index.docbook:2765
#, no-c-format
msgid ""
"Deletes a label, identified by its index (starting from zero), or all labels "
"when using the special value -1 as index. If no label with the given index "
"exists, this command does nothing."
msgstr ""
"Verwijdert een label, geïdentificeerd door zijn index (beginnend vanaf nul) "
"of alle labels bij gebruik van de speciale waarde -1 als index. Als geen "
"label met de gegeven index bestaat, dan doet dit commando niets."

#. Tag: entry
#: index.docbook:2772
#, no-c-format
msgid ""
"index of the label to delete, starting with 0 or -1 to delete all labels"
msgstr ""
"index van het te verwijderen label, beginnend met 0 of -1 om alle labels te "
"verwijderen"

#. Tag: title
#: index.docbook:2778
#, no-c-format
msgid "&no-i18n-cmd_label_edit;"
msgstr "&no-i18n-cmd_label_edit;"

#. Tag: screeninfo
#: index.docbook:2780 index.docbook:4379 index.docbook:4419 index.docbook:4564
#: index.docbook:4923 index.docbook:5231 index.docbook:5424 index.docbook:5460
#: index.docbook:5550 index.docbook:5643 index.docbook:5706 index.docbook:5750
#: index.docbook:5868 index.docbook:5943 index.docbook:6061 index.docbook:6154
#: index.docbook:6460 index.docbook:6685 index.docbook:6799 index.docbook:6810
#: index.docbook:6948 index.docbook:7002
#, no-c-format
msgid "Screenshot"
msgstr "Schermafdruk"

#. Tag: phrase
#: index.docbook:2786
#, no-c-format
msgid "Screenshot of the label editing dialog"
msgstr "Schermafbeelding van de dialoog voor bewerking van het label"

#. Tag: title
#: index.docbook:2791
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_label_edit;</"
"command>(<replaceable>index</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_label_edit;</"
"command>(<replaceable>index</replaceable>)"

#. Tag: para
#: index.docbook:2792
#, no-c-format
msgid ""
"Opens a dialog window in which the user can edit the position and the "
"description of a label, which is identified by its index (starting from "
"zero). If no label with the given index exists, this command does nothing."
msgstr ""
"Opent een dialoogvenster waarin de gebruiker de positie en de beschrijving "
"van een label kan bewerken, die geïdentificeerd wordt door zijn index "
"(beginnend vanaf nul). Als geen label met de gegeven index bestaat, dan doet "
"dit commando niets."

#. Tag: entry
#: index.docbook:2800
#, no-c-format
msgid "index of the label to edit, starting with 0"
msgstr "index van de te bewerken label, begint met 0"

#. Tag: title
#: index.docbook:2805
#, no-c-format
msgid "&no-i18n-cmd_loadbatch;"
msgstr "&no-i18n-cmd_loadbatch;"

#. Tag: title
#: index.docbook:2807
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_loadbatch;</"
"command>(<replaceable>filename</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_loadbatch;</"
"command>(<replaceable>bestandsnaam</replaceable>)"

#. Tag: para
#: index.docbook:2808
#, no-c-format
msgid ""
"Opens a &kwave; script file and processes the commands in it. Uses the "
"context of the currently opened file or the current main window if no file "
"is loaded."
msgstr ""
"Opent een scriptbestand van &kwave; en verwerkt de commando's erin. Gebruikt "
"de context van het nu geopende bestand of het huidige hoofdvenster als er "
"geen bestand is geladen."

#. Tag: entry
#: index.docbook:2815 index.docbook:3138 index.docbook:3164 index.docbook:3460
#: index.docbook:3493 index.docbook:4234
#, no-c-format
msgid "<parameter>filename</parameter>:"
msgstr "<parameter>bestandsnaam</parameter>:"

#. Tag: entry
#: index.docbook:2816
#, no-c-format
msgid "name of the kwave script file including path and extension"
msgstr "naam van het scriptbestand van kwave inclusief pad en extensie"

#. Tag: title
#: index.docbook:2821
#, no-c-format
msgid "&no-i18n-cmd_loop;"
msgstr "&no-i18n-cmd_loop;"

#. Tag: title
#: index.docbook:2823
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_loop;</command>()"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_loop;</command>()"

#. Tag: para
#: index.docbook:2824
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Loop</guibutton> toolbar button. Starts the "
"playback (if it is not already running) and lets it play in a loop."
msgstr ""
"Komt overeen met het de knop in de werkbalk <guibutton>Lus</guibutton>. "
"Start het afspelen (als het niet al actief is) en laat het afspelen in een "
"lus."

#. Tag: link
#: index.docbook:2832
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_playback_start;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_playback_start;</command>()"

#. Tag: title
#: index.docbook:2838
#, no-c-format
msgid "&no-i18n-tag;m"
msgstr "&no-i18n-tag;m"

#. Tag: title
#: index.docbook:2841
#, no-c-format
msgid "&no-i18n-cmd_menu;"
msgstr "&no-i18n-cmd_menu;"

#. Tag: title
#: index.docbook:2843
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_menu;</command> "
"(<replaceable>command</replaceable>, <replaceable>path</replaceable>, "
"[<replaceable>hotkey</replaceable>], [<replaceable>id</replaceable>])"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_menu;</command> "
"(<replaceable>commando</replaceable>, <replaceable>pad</replaceable>, "
"[<replaceable>sneltoets</replaceable>], [<replaceable>id</replaceable>])"

#. Tag: para
#: index.docbook:2849
#, no-c-format
msgid ""
"This is a very powerful command, which is used to add a new entry to the "
"menu or to modify an existing entry. It determines which <emphasis>command</"
"emphasis> is executed when the menu entry is activated, which "
"<emphasis>icon</emphasis> is shown in the menu and which <emphasis>hotkey</"
"emphasis> is used. Each menu entry can be <emphasis>disabled</emphasis> or "
"<emphasis>hidden</emphasis>, can be assigned a unique <emphasis>id</"
"emphasis> and can also join a <emphasis>menu group</emphasis>."
msgstr ""
"Dit is een erg krachtig commando, dat gebruikt wordt om een nieuw item aan "
"het menu toe te voegen of om een bestaand item te wijzigen. Het bepaalt welk "
"<emphasis>commando</emphasis> wordt uitgevoerd wanneer het menu-item wordt "
"geactiveerd, welk <emphasis>pictogram</emphasis> in het menu wordt getoond "
"en welke <emphasis>sneltoets</emphasis> wordt gebruikt. Elk menu-item kan "
"<emphasis>uitgeschakeld</emphasis> worden of <emphasis>verborgen</emphasis>, "
"kan een unieke <emphasis>id</emphasis> krijgen en kan ook mee doen in een "
"<emphasis>menugroep</emphasis>."

#. Tag: para
#: index.docbook:2860
#, no-c-format
msgid "You normally do not need this command within a &kwave; script!"
msgstr "Normaal hebt u dit commando niet nodig binnen een &kwave;-script!"

#. Tag: entry
#: index.docbook:2867
#, no-c-format
msgid ""
"A text command (including parameters) or a command list that will be "
"executed when the menu entry gets activated. If a menu entry does not have a "
"corresponding command (for example if it is a sub menu and not menu entry), "
"you should use the special command <command>ignore</command>()."
msgstr ""
"Een tekstcommando (inclusief parameters) of een commandolijst die zal worden "
"uitgevoerd wanneer het menu-item wordt geactiveerd. Als een menu-item geen "
"bijbehorend commando heeft (bijvoorbeeld als het een submenu is en geen menu-"
"item), dan zou u het speciale commando <command>ignore</command>() moeten "
"gebruiken."

#. Tag: entry
#: index.docbook:2876
#, no-c-format
msgid "<parameter>path</parameter>:"
msgstr "<parameter>pad</parameter>:"

#. Tag: entry
#: index.docbook:2877
#, no-c-format
msgid ""
"The path within the menu, using a <quote><token>/</token></quote> as "
"separator. The last part of the path can be a <emphasis>sub command</"
"emphasis> which modifies some property of the menu entry (see <link linkend="
"\"menu_sub_commands\">below</link>). The last portion of the path (that is "
"not a sub command) produces a menu entry, the parts before produce the main "
"menu entry or sub menus that lead to it. Main menu entries or sub menus are "
"automatically created when a menu entry is created, you do not need them "
"manually."
msgstr ""
"Het pad in het menu, met gebruik van <quote><token>/</token></quote> als "
"scheidingsteken. He laatste deel van het pad kan een <emphasis>subcommando</"
"emphasis> zijn die enige eigenschappen van het menu-item wijzigt (zie <link "
"linkend=\"menu_sub_commands\">onderstaand</link>). Het laatste deel van het "
"pad (dat geen subcommando is) produceert een menu-item, de delen ervoor "
"produceren het hoofdmenu-item of submenu's die er toe leiden. Hoofdmenu-"
"items of submenu's worden automatisch aangemaakt wanneer een menu-item wordt "
"aangemaakt, u hoeft dat niet handmatig te doen."

#. Tag: entry
#: index.docbook:2890
#, no-c-format
msgid "<parameter>hotkey</parameter>:"
msgstr "<parameter>sneltoets</parameter>:"

#. Tag: entry
#: index.docbook:2891
#, no-c-format
msgid ""
"A bitmask that consists of a combination of predefined <emphasis>keys</"
"emphasis> and <emphasis>modifiers</emphasis>, concatenated with a "
"<quote><token>+</token></quote>. The <emphasis>key</emphasis> can be either "
"a digit, an upper case letter, a function key (<quote>F1</quote> ... "
"<quote>F12</quote>) or any other key name understood by the Qt class "
"<quote><literal>QKeySequence</literal></quote>, including key names for "
"predefined actions (like for example <quote><literal>::Copy</literal></"
"quote>). Typical <emphasis>modifiers</emphasis> are <quote><literal>SHIFT</"
"literal></quote>, <quote><literal>ALT</literal></quote> and "
"<quote><literal>CTRL</literal></quote>."
msgstr ""
"Een bitmasker bestaat uit een combinatie van voorgedefinieerde "
"<emphasis>sleutels</emphasis> en <emphasis>modifiers</emphasis>, "
"geconcateneerd met een <quote><token>+</token></quote>. De "
"<emphasis>sleutel</emphasis> kan ofwel een cijfer, een hoofdletter, een "
"functietoets (<quote>F1</quote> ... <quote>F12</quote>) of elke andere "
"sleutelnaam begrepen door de Qt klasse <quote><literal>QKeySequence</"
"literal></quote>, inclusief sleutelnamen voor voorgedefinieerde acties "
"(zoals bijvoorbeeld <quote><literal>::Copy</literal></quote>). Typische "
"<emphasis>modifiers</emphasis> zijn <quote><literal>SHIFT</literal></quote>, "
"<quote><literal>ALT</literal></quote> en <quote><literal>CTRL</literal></"
"quote>."

#. Tag: entry
#: index.docbook:2909
#, no-c-format
msgid "<parameter>id</parameter>:"
msgstr "<parameter>id</parameter>:"

#. Tag: entry
#: index.docbook:2910
#, no-c-format
msgid ""
"A unique id that can be internally used to identify this menu entry or "
"menu / sub menu. Only uppercase letters, digits and <quote><literal>_</"
"literal></quote> should be used and it should start with "
"<quote><literal>ID_</literal></quote>. It is in your own responsibility to "
"make sure that the same id is not used twice."
msgstr ""
"Een unieke id die intern gebruikt kan worden om dit menu-item of menu / "
"submenu te identificeren. Alleen hoofdletters, cijfers en <quote><literal>_</"
"literal></quote> moeten gebruikt worden en het moet beginnen met "
"<quote><literal>ID_</literal></quote>. Het is uw eigen verantwoordelijkheid "
"om na te gaan dat dezelfde id niet twee keer wordt gebruikt."

#. Tag: title
#: index.docbook:2920
#, no-c-format
msgid "Sub Commands"
msgstr "Subcommando's"

#. Tag: entry
#: index.docbook:2922
#, no-c-format
msgid "<command>&no-i18n-tag;#checkable</command>:"
msgstr "<command>&no-i18n-tag;#checkable</command>:"

#. Tag: entry
#: index.docbook:2923
#, no-c-format
msgid ""
"Makes the menu entry <emphasis>checkable</emphasis>, so that it can be "
"switched on or off."
msgstr ""
"Maakt het menu-item <emphasis>te activeren</emphasis>, zodat het aan en uit "
"geschakeld kan worden."

#. Tag: entry
#: index.docbook:2928
#, no-c-format
msgid "<command>&no-i18n-tag;#disabled</command>:"
msgstr "<command>&no-i18n-tag;#uitgeschakeld</command>:"

#. Tag: entry
#: index.docbook:2929
#, no-c-format
msgid "<emphasis>Disables</emphasis> the menu, sub menu or menu entry."
msgstr "<emphasis>Schakelt uit</emphasis> het menu, submenu of menu-item."

#. Tag: entry
#: index.docbook:2933
#, no-c-format
msgid "<command>&no-i18n-tag;#enabled</command>:"
msgstr "<command>&no-i18n-tag;#enabled</command>:"

#. Tag: entry
#: index.docbook:2934
#, no-c-format
msgid "<emphasis>Enables</emphasis> the menu, sub menu or menu entry."
msgstr "<emphasis>Schakelt in</emphasis> het menu, submenu of menu-item."

#. Tag: entry
#: index.docbook:2938
#, no-c-format
msgid "<command>#exclusive</command>(<replaceable>group</replaceable>):"
msgstr "<command>#exclusive</command>(<replaceable>groep</replaceable>):"

#. Tag: entry
#: index.docbook:2939
#, no-c-format
msgid ""
"Adds the menu entry to an <emphasis>exclusive</emphasis> "
"<emphasis><replaceable>group</replaceable></emphasis> (one of many "
"selection). The group that is given as parameter should not be used for any "
"other purpose. Only one entry within that group can be selected at a time."
msgstr ""
"Voegt het menu-item toe aan een <emphasis>exclusieve</emphasis> "
"<emphasis><replaceable>groep</replaceable></emphasis> (een van vele "
"selecties). De groep die gegeven is als parameter zou niet gebruikt mogen "
"worden voor wat voor doel dan ook. Slechts één item in die groep kan "
"geselecteerd op een bepaald moment geselecteerd worden."

#. Tag: entry
#: index.docbook:2947
#, no-c-format
msgid "<command>#group</command>(<replaceable>list</replaceable>):"
msgstr "<command>#group</command>(<replaceable>lijst</replaceable>):"

#. Tag: para
#: index.docbook:2948
#, no-c-format
msgid ""
"Adds the menu, sub menu or menu entry to one or more a <emphasis>groups</"
"emphasis>, so that the application can enable/disable a bunch of menu "
"entries without need to know all their unique ids. Multiple groups can be "
"passed as a list with a <quote><literal>,</literal></quote> as separator. "
"Group names have to start with a <quote><literal>@</literal></quote>. The "
"following groups are predefined:"
msgstr ""
"Voegt het menu, submenu of menu-item toe aan een of meer <emphasis>groepen</"
"emphasis>, zodat de toepassing heel wat menu-items kan in-/uitschakelen "
"zonder de noodzaak om van allen hun unieke id's te weten. Meerdere groepen "
"kunnen naar een lijst worden doorgegeven met een <quote><literal>,</"
"literal></quote> als scheidingsteken. Groepsnamen moeten beginnen met een "
"<quote><literal>@</literal></quote>. De volgende groepen zijn "
"voorgedefinieerd:"

#. Tag: term
#: index.docbook:2959
#, no-c-format
msgid "<command>&no-i18n-tag;@CLIPBOARD</command>:"
msgstr "<command>&no-i18n-tag;@CLIPBOARD</command>:"

#. Tag: para
#: index.docbook:2961
#, no-c-format
msgid "Only enabled when the clipboard is not empty."
msgstr "Alleen ingeschakeld als het klembord niet leeg is."

#. Tag: term
#: index.docbook:2967
#, no-c-format
msgid "<command>&no-i18n-tag;@LABELS</command>:"
msgstr "<command>&no-i18n-tag;@LABELS</command>:"

#. Tag: para
#: index.docbook:2969
#, no-c-format
msgid "Only enabled when the current signal contains at least one label."
msgstr "Alleen ingeschakeld als het huidige signaal minstens één label bevat."

#. Tag: term
#: index.docbook:2976
#, no-c-format
msgid "<command>&no-i18n-tag;@NOT_CLOSED</command>:"
msgstr "<command>&no-i18n-tag;@NOT_CLOSED</command>:"

#. Tag: para
#: index.docbook:2978
#, no-c-format
msgid ""
"Enabled when the current signal is not closed (the signal might be empty or "
"zero length)."
msgstr ""
"Ingeschakeld als het huidige signaal niet gesloten is (het signaal kan leeg "
"zijn of een nul lengte hebben)."

#. Tag: term
#: index.docbook:2985
#, no-c-format
msgid "<command>&no-i18n-tag;@SELECTION</command>:"
msgstr "<command>&no-i18n-tag;@SELECTION</command>:"

#. Tag: para
#: index.docbook:2987
#, no-c-format
msgid ""
"Enabled when the selection is not empty (more than one sample is selected)."
msgstr ""
"Ingeschakeld als de selectie niet leeg is (meer dan één sample is "
"geselecteerd)."

#. Tag: term
#: index.docbook:2994
#, no-c-format
msgid "<command>&no-i18n-tag;@SIGNAL</command>:"
msgstr "<command>&no-i18n-tag;@SIGNAL</command>:"

#. Tag: para
#: index.docbook:2996
#, no-c-format
msgid ""
"Enabled when there is some signal loaded and it is not empty or zero length."
msgstr ""
"Ingeschakeld als er enig signaal is geladen en het is niet leeg of een "
"lengte nul heeft)."

#. Tag: entry
#: index.docbook:3005
#, no-c-format
msgid "<command>&no-i18n-tag;#hidden</command>:"
msgstr "<command>&no-i18n-tag;#hidden</command>:"

#. Tag: entry
#: index.docbook:3006
#, no-c-format
msgid "<emphasis>Hides</emphasis> the menu, sub menu or menu entry."
msgstr "<emphasis>Verberg</emphasis> het menu, submenu of menu-item."

#. Tag: entry
#: index.docbook:3009
#, no-c-format
msgid "<command>#icon</command>(<replaceable>name</replaceable>):"
msgstr "<command>#icon</command>(<replaceable>naam</replaceable>):"

#. Tag: entry
#: index.docbook:3010
#, no-c-format
msgid ""
"Assigns an <emphasis>icon</emphasis> to the menu entry. The icon "
"<emphasis><replaceable>name</replaceable></emphasis> should correspond to an "
"icon file (without path and file extension) that is installed on the system "
"or with &kwave;."
msgstr ""
"Kent een <emphasis>pictogram</emphasis> toe aan het menu-item. De "
"<emphasis><replaceable>naam</replaceable></emphasis> van het pictogram moet "
"corresponderen met een pictogrambestand (zonder pad en bestandsextensie) dat "
"in het systeem is geïnstalleerd of met &kwave;."

#. Tag: entry
#: index.docbook:3018
#, no-c-format
msgid ""
"<command>#listmenu</command>(<replaceable>id</replaceable>,"
"<replaceable>command</replaceable>):"
msgstr ""
"<command>#listmenu</command>(<replaceable>id</replaceable>,"
"<replaceable>commando</replaceable>):"

#. Tag: entry
#: index.docbook:3019
#, no-c-format
msgid ""
"Inserts a placeholder for a list of menu entries into a sub menu. The unique "
"<emphasis><replaceable>id</replaceable></emphasis> specified in this sub "
"command is used to add/remove or clear the list of menu entries. The "
"<emphasis><replaceable>command</replaceable></emphasis> parameter has to "
"contain <quote><literal>%1</literal></quote> as parameter, which will be "
"replaced with the text of the menu entry when it is activated. This sub "
"command is internally used for the list of recent files, list of tracks and "
"window list."
msgstr ""
"Voegt een plaatshouder in voor een lijst met menu-items in een submenu. De "
"unieke <emphasis><replaceable>id</replaceable></emphasis> gespecificeerd in "
"dit subcommando wordt gebruikt om de lijst met menu-items toe te voegen, te "
"verwijderen of te wissen. De parameter <emphasis><replaceable>commando</"
"replaceable></emphasis> moet <quote><literal>%1</literal></quote> als "
"parameter bevatten, die vervangen zal worden door de tekst van het menu-item "
"wanneer het wordt geactiveerd. Dit subcommando wordt intern gebruikt voor de "
"lijst met recente bestanden, lijst met tracks en vensterlijst."

#. Tag: entry
#: index.docbook:3033
#, no-c-format
msgid "<command>&no-i18n-tag;#separator</command>:"
msgstr "<command>&no-i18n-tag;#separator</command>:"

#. Tag: entry
#: index.docbook:3034
#, no-c-format
msgid "Inserts a separator into a sub menu."
msgstr "Voeg een scheidingsteken in in een submenu."

#. Tag: title
#: index.docbook:3044
#, no-c-format
msgid "&no-i18n-cmd_msgbox;"
msgstr "&no-i18n-cmd_msgbox;"

#. Tag: title
#: index.docbook:3046
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_msgbox;</command>(<replaceable>text</"
"replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_msgbox;</command>(<replaceable>tekst</"
"replaceable>)"

#. Tag: para
#: index.docbook:3047
#, no-c-format
msgid ""
"Shows a message box with some <emphasis><replaceable>text</replaceable></"
"emphasis> and the two buttons <guibutton>OK</guibutton> (returns without "
"error code) and <guibutton>Cancel</guibutton> (returns and error code). You "
"can use this command to give the user a possibility to abort a running "
"script."
msgstr ""
"Toont een berichtvak met enige <emphasis><replaceable>tekst</replaceable></"
"emphasis> en de twee knoppen <guibutton>OK</guibutton> (keert terug zonder "
"foutcode) en <guibutton>Annuleren</guibutton> (keert terug met foutcode). U "
"kunt dit commando gebruiken om de gebruiker een mogelijkheid te geven om een "
"actief script af te breken."

#. Tag: entry
#: index.docbook:3056
#, no-c-format
msgid ""
"A message that will be shown in the message box, should contain a question "
"that can be answered with <guibutton>OK</guibutton> or <guibutton>Cancel</"
"guibutton>."
msgstr ""
"Een bericht dat getoond zal worden in het berichtvak, zou een vraag moeten "
"bevatten die beantwoord kan worden met <guibutton>OK</guibutton> of "
"<guibutton>Annuleren</guibutton>"

#. Tag: title
#: index.docbook:3066
#, no-c-format
msgid "&no-i18n-tag;n"
msgstr "&no-i18n-tag;n"

#. Tag: title
#: index.docbook:3069
#, no-c-format
msgid "&no-i18n-cmd_newsignal;"
msgstr "&no-i18n-cmd_newsignal;"

#. Tag: title
#: index.docbook:3071
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_newsignal;</"
"command>( <replaceable>samples</replaceable>, <replaceable>rate</"
"replaceable>, <replaceable>bits</replaceable>, <replaceable>tracks</"
"replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_newsignal;</"
"command>( <replaceable>samples</replaceable>, <replaceable>snelheid</"
"replaceable>, <replaceable>bits</replaceable>, <replaceable>tracks</"
"replaceable>)"

#. Tag: para
#: index.docbook:3077
#, no-c-format
msgid ""
"Creates a new signal, with a given length in <emphasis><replaceable>samples</"
"replaceable></emphasis>, a <emphasis><replaceable>rate</replaceable></"
"emphasis> in samples per second (floating point number), a number of "
"<emphasis><replaceable>bits</replaceable></emphasis> per sample and number "
"of <emphasis><replaceable>tracks</replaceable></emphasis>. You can calculate "
"the length in samples by multiplying the desired length in seconds with the "
"sample rate."
msgstr ""
"Maakt een nieuw signaal, met een gegeven lengte in "
"<emphasis><replaceable>samples</replaceable></emphasis>, een "
"<emphasis><replaceable>snelheid</replaceable></emphasis> in samples per "
"seconde (drijvendekommagetal), een aantal <emphasis><replaceable>bits</"
"replaceable></emphasis> per sample en aantal <emphasis><replaceable>tracks</"
"replaceable></emphasis>. U kunt de lengte berekenen in samples door de "
"gewenste lengte in seconden te vermenigvuldigen met de samplesnelheid."

#. Tag: entry
#: index.docbook:3089
#, no-c-format
msgid "<parameter>samples</parameter>:"
msgstr "<parameter>samples</parameter>:"

#. Tag: entry
#: index.docbook:3090
#, no-c-format
msgid "Length of the signal in samples."
msgstr "Lengte van het signaal in samples."

#. Tag: entry
#: index.docbook:3091
#, no-c-format
msgid "<parameter>rate</parameter>:"
msgstr "<parameter>snelheid</parameter>:"

#. Tag: entry
#: index.docbook:3092
#, no-c-format
msgid "<entry>Sample rate in samples per second.</entry>"
msgstr "<entry>Samplesnelheid in samples per seconde.</entry>"

#. Tag: entry
#: index.docbook:3093
#, no-c-format
msgid "<parameter>bits</parameter>:"
msgstr "<parameter>bits</parameter>:"

#. Tag: entry
#: index.docbook:3094
#, no-c-format
msgid ""
"Number of bits per sample, must not be zero, should be a number from 8...32."
msgstr ""
"Aantal bits per sample, mag niet nul zijn, zou een getal van 8...32 moeten "
"zijn."

#. Tag: entry
#: index.docbook:3096
#, no-c-format
msgid "<parameter>tracks</parameter>:"
msgstr "<parameter>tracks</parameter>:"

#. Tag: entry
#: index.docbook:3097
#, no-c-format
msgid "Number of tracks."
msgstr "Aantal tracks."

#. Tag: title
#: index.docbook:3102
#, no-c-format
msgid "&no-i18n-cmd_next;"
msgstr "&no-i18n-cmd_next;"

#. Tag: title
#: index.docbook:3104
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_next;</command>()"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_next;</command>()"

#. Tag: para
#: index.docbook:3105
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Next</guibutton> toolbar button. If the "
"playback is currently running, it skips forward to the next label. If the "
"playback is not running, this does the same as the command <command>&no-i18n-"
"cmd_view_scroll_next_label;</command>()."
msgstr ""
"Komt overeen met de knop op de werkbalk <guibutton>Volgende</guibutton>. Als "
"het afspelen nu bezig is, springt het voorwaarts naar het volgende label. "
"Als het afspelen niet bezig is, doet dit hetzelfde als het commando "
"<command>&no-i18n-cmd_view_scroll_next_label;</command>()."

#. Tag: para
#: index.docbook:3114
#, no-c-format
msgid ""
"<link linkend=\"cmd_sect_view_scroll_next_label\"><command>&no-i18n-tag;&no-"
"i18n-cmd_view_scroll_next_label;</command>()</link>, <link linkend="
"\"cmd_sect_prev\"><command>&no-i18n-tag;&no-i18n-cmd_prev;</command>()</link>"
msgstr ""
"<link linkend=\"cmd_sect_view_scroll_next_label\"><command>&no-i18n-tag;&no-"
"i18n-cmd_view_scroll_next_label;</command>()</link>, <link linkend="
"\"cmd_sect_prev\"><command>&no-i18n-tag;&no-i18n-cmd_prev;</command>()</link>"

#. Tag: title
#: index.docbook:3122
#, no-c-format
msgid "&no-i18n-tag;o"
msgstr "&no-i18n-tag;o"

#. Tag: title
#: index.docbook:3125
#, no-c-format
msgid "&no-i18n-cmd_open;"
msgstr "&no-i18n-cmd_open;"

#. Tag: title
#: index.docbook:3127
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_open;</"
"command>([<replaceable>filename</replaceable>])"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_open;</"
"command>([<replaceable>bestandsnaam</replaceable>])"

#. Tag: para
#: index.docbook:3128
#, no-c-format
msgid ""
"Opens a file, which can be either a sound file or a &kwave; script. If no "
"file name is passed, then a dialog window will be opened that allows to "
"select an existing file. Depending on the &GUI; mode the file will be opened "
"in the context of a new sub-window (MDI and tab) or in a new main window "
"(SDI, if there was already something loaded)."
msgstr ""
"Opent een bestand, dat ofwel een geluidsbestand of een &kwave; script kan "
"zijn. Als geen bestandsnaam wordt doorgegeven zal een dialoogvenster geopend "
"worden dat het selecteren van een bestaand bestand mogelijk maakt. "
"Afhankelijk van de &GUI;-modus zal het bestand geopend worden in de context "
"van een nieuw subvenster (MDI en tabblad) of in een nieuw hoofdvenster (SDI, "
"als er al iets was geladen)."

#. Tag: entry
#: index.docbook:3139
#, no-c-format
msgid "name of a file including path and extension"
msgstr "naam van een bestand inclusief pad en extensie"

#. Tag: link
#: index.docbook:3143 index.docbook:3332
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_close;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_close;</command>()"

#. Tag: title
#: index.docbook:3149
#, no-c-format
msgid "&no-i18n-cmd_openrecent;"
msgstr "&no-i18n-cmd_openrecent;"

#. Tag: title
#: index.docbook:3151
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_openrecent;</"
"command>(<replaceable>filename</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_openrecent;</"
"command>(<replaceable>bestandsnaam</replaceable>)"

#. Tag: para
#: index.docbook:3152
#, no-c-format
msgid ""
"Practically the same as the command <command>&no-i18n-cmd_open;</command>(), "
"but intended to be used internally for the list of recently opened files in "
"the menu <menuchoice> <guimenu>File</guimenu><guimenu>Open Recent</guimenu> "
"</menuchoice>. In this command the parameter <replaceable>filename</"
"replaceable> is not optional."
msgstr ""
"Praktisch hetzelfde als het commando <command>&no-i18n-cmd_open;</"
"command>(), maar bedoelt om intern gebruikt te worden voor de lijst met "
"recent geopende bestanden in het menu <menuchoice> <guimenu>Bestand</"
"guimenu><guimenu>Recent openen</guimenu> </menuchoice>. In dit commando is "
"de parameter <replaceable>bestandsnaam</replaceable> niet optioneel."

#. Tag: entry
#: index.docbook:3165
#, no-c-format
msgid "entry of the list of recently opened files"
msgstr "item in de lijst met recent geopende bestanden"

#. Tag: link
#: index.docbook:3169
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_open;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_open;</command>()"

#. Tag: title
#: index.docbook:3175
#, no-c-format
msgid "&no-i18n-tag;p"
msgstr "&no-i18n-tag;p"

#. Tag: title
#: index.docbook:3178
#, no-c-format
msgid "&no-i18n-cmd_paste;"
msgstr "&no-i18n-cmd_paste;"

#. Tag: title
#: index.docbook:3180
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_paste;</command>()"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_paste;</command>()"

#. Tag: para
#: index.docbook:3181
#, no-c-format
msgid ""
"Replaces the current selection with the content of the clipboard. If the "
"clipboard is empty, this command does nothing. The sample rate of the "
"inserted data is adjusted to match the sample rate of the current signal if "
"necessary. Only enabled tracks are affected, disabled tracks remain "
"unchanged. Please be aware that this might produce a time shift between "
"enabled and disabled tracks! If the number of tracks of the clipboard data "
"differs from the number of enabled tracks, then the data is mixed to be "
"spread equally over all selected tracks."
msgstr ""
"Vervangt de huidige selectie door de inhoud van het klembord. Als het "
"klembord leeg is, doet dit commando niets. De samplesnelheid van het "
"ingevoegde gegeven wordt aangepast om overeen te komen met de samplesnelheid "
"van het huidige signaal indien noodzakelijk. Alleen ingeschakelde tracks "
"worden gewijzigd, uitgeschakelde tracks blijven ongewijzigd. Wees u er van "
"bewust dat dit een tijdverschuiving kan beteken tussen ingeschakelde en "
"uitgeschakelde tracks! Als het aantal tracks van de klembordgegevens "
"verschilt van het aantal ingeschakelde tracks, dan worden de gegevens gemixt "
"om gelijkelijk verspreid te worden over alle geselecteerde tracks."

#. Tag: link
#: index.docbook:3196
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_copy;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_copy;</command>()"

#. Tag: title
#: index.docbook:3202
#, no-c-format
msgid "&no-i18n-cmd_pause;"
msgstr "&no-i18n-cmd_pause;"

#. Tag: para
#: index.docbook:3205
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Pause</guibutton> toolbar button and lets the "
"playback pause if it is currently running, or continue if it is currently "
"paused."
msgstr ""
"Komt overeen met het de knop <guibutton>Pauze</guibutton> op de werkbalk en "
"laat het afspelen pauzeren als er nu wordt afgespeeld of doorgegaan als het "
"nu is gepauzeerd."

#. Tag: link
#: index.docbook:3213
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_continue;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_continue;</command>()"

#. Tag: title
#: index.docbook:3219
#, no-c-format
msgid "&no-i18n-cmd_playback_start;"
msgstr "&no-i18n-cmd_playback_start;"

#. Tag: title
#: index.docbook:3221
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_playback_start;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_playback_start;</"
"command>()"

#. Tag: para
#: index.docbook:3222
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Start</guibutton> toolbar button and lets the "
"playback start if it is currently paused."
msgstr ""
"Komt overeen met het de knop <guibutton>Begin</guibutton> op de werkbalk en "
"laat het afspelen beginnen als het is nu is gepauzeerd."

#. Tag: title
#: index.docbook:3230
#, no-c-format
msgid "&no-i18n-cmd_plugin;"
msgstr "&no-i18n-cmd_plugin;"

#. Tag: title
#: index.docbook:3232
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_plugin;</command>(<replaceable>name</"
"replaceable>, [<replaceable>parameter</replaceable> ...])"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_plugin;</command>(<replaceable>name</"
"replaceable>, [<replaceable>parameter</replaceable> ...])"

#. Tag: para
#: index.docbook:3233
#, no-c-format
msgid ""
"Executes a plugin, with an optional list of parameters. If no parameter list "
"is given, then the setup function of the plugin will be called, using the "
"parameters of the previous invocation or default parameters as input "
"(normally shows a setup dialog, depending on the plugin). Please refer to "
"the chapter about <link linkend=\"plugins\">plugins</link> for a description "
"of the various plugins."
msgstr ""
"Voert een plug-in uit, met een optionele lijst parameters. Als geen "
"parameterlijst is gegeven, zal de instellingenfunctie van de plug-in worden "
"aangeroepen, met de parameters van de vorige aanroep of standaard parameters "
"als invoer (toont normaal een instellingendialoog, afhankelijk van de plug-"
"in). Kijk in het hoofdstuk over <link linkend=\"plugins\">plug-ins</link> "
"voor een beschrijving van de verschillende plug-ins."

#. Tag: entry
#: index.docbook:3244 index.docbook:3268 index.docbook:3290
#, no-c-format
msgid "<parameter>name</parameter>:"
msgstr "<parameter>naam</parameter>:"

#. Tag: entry
#: index.docbook:3245 index.docbook:3269 index.docbook:3291
#, no-c-format
msgid "the (internal) name of a &kwave; plugin"
msgstr "de (interne) naam van een plug-in van &kwave;"

#. Tag: entry
#: index.docbook:3246 index.docbook:3270 index.docbook:3292
#, no-c-format
msgid "<parameter>parameter</parameter>:"
msgstr "<parameter>parameter</parameter>:"

#. Tag: entry
#: index.docbook:3247 index.docbook:3293
#, no-c-format
msgid "a list of parameters understood by the plugin (optional)"
msgstr "een lijst parameters begrepen door de plug-in (optioneel)"

#. Tag: para
#: index.docbook:3250
#, no-c-format
msgid ""
"<link linkend=\"cmd_sect_plugin_execute\"><command>&no-i18n-tag;&no-i18n-"
"cmd_plugin_execute;</command>()</link>, <link linkend=\"cmd_sect_plugin_setup"
"\"><command>&no-i18n-tag;&no-i18n-cmd_plugin_setup;</command>()</link>"
msgstr ""
"<link linkend=\"cmd_sect_plugin_execute\"><command>&no-i18n-tag;&no-i18n-"
"cmd_plugin_execute;</command>()</link>, <link linkend=\"cmd_sect_plugin_setup"
"\"><command>&no-i18n-tag;&no-i18n-cmd_plugin_setup;</command>()</link>"

#. Tag: title
#: index.docbook:3258
#, no-c-format
msgid "&no-i18n-cmd_plugin_execute;"
msgstr "&no-i18n-cmd_plugin_execute;"

#. Tag: title
#: index.docbook:3260
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_plugin_execute;</"
"command>(<replaceable>name</replaceable>, [<replaceable>parameter</"
"replaceable> ...])"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_plugin_execute;</"
"command>(<replaceable>naam</replaceable>, [<replaceable>parameter</"
"replaceable> ...])"

#. Tag: para
#: index.docbook:3261
#, no-c-format
msgid ""
"Similar to the command <command>&no-i18n-cmd_plugin;</command>(), but "
"without calling the setup function of the plugin if no parameters were "
"passed."
msgstr ""
"Vergelijkbaar met het commando <command>&no-i18n-cmd_plugin;</command>(), "
"maar zonder aanroepen van de setup-functie van de plug-in als er geen "
"parameters zijn doorgegeven."

#. Tag: entry
#: index.docbook:3271
#, no-c-format
msgid "a list of parameters understood by the plugin"
msgstr "een lijst parameters begrepen door de plug-in"

#. Tag: title
#: index.docbook:3276
#, no-c-format
msgid "&no-i18n-cmd_plugin_setup;"
msgstr "&no-i18n-cmd_plugin_setup;"

#. Tag: title
#: index.docbook:3278
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_plugin_setup;</"
"command>(<replaceable>name</replaceable>, [<replaceable>parameter</"
"replaceable> ...])"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_plugin_setup;</"
"command>(<replaceable>naam</replaceable>, [<replaceable>parameter</"
"replaceable> ...])"

#. Tag: para
#: index.docbook:3279
#, no-c-format
msgid ""
"Calls the <emphasis>setup</emphasis> function of a plugin, with an optional "
"list of parameters. If no parameter list is given, the parameters of the "
"previous invocation or default parameters will be used as input. This "
"normally shows a setup dialog, depending on the plugin. Please refer to the "
"chapter about <link linkend=\"plugins\">plugins</link> for a description of "
"the various plugins."
msgstr ""
"Roept de <emphasis>instellingen</emphasis>-functie van een plug-in aan, met "
"een optionele lijst parameters. Als geen parameterlijst is gegeven, zullen "
"de parameters van de vorige keer aanroepen of standaard parameters worden "
"gebruikt als invoer. Dit toont normaal een instellingendialoog, afhankelijk "
"van de plug-in. Kijk in het hoofdstuk over <link linkend=\"plugins\">plug-"
"ins</link> voor een beschrijving van de verschillende plug-ins."

#. Tag: title
#: index.docbook:3298
#, no-c-format
msgid "&no-i18n-cmd_prev;"
msgstr "&no-i18n-cmd_prev;"

#. Tag: title
#: index.docbook:3300
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_prev;</command>()"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_prev;</command>()"

#. Tag: para
#: index.docbook:3301
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Previous</guibutton> toolbar button. If the "
"playback is currently running, it skips back to the previous label or start "
"of the selection. If the playback is not running, this does the same as the "
"command <command>&no-i18n-cmd_view_scroll_prev_label;</command>()."
msgstr ""
"Komt overeen met de knop op de werkbalk <guibutton>Vorige</guibutton>. Als "
"het afspelen nu actief is, springt het terug naar het vorige label of begin "
"van de selectie. Als het afspelen niet actief is, doet dit hetzelfde als het "
"commando <command>&no-i18n-cmd_view_scroll_prev_label;</command>()."

#. Tag: para
#: index.docbook:3310
#, no-c-format
msgid ""
"<link linkend=\"cmd_sect_view_scroll_next_label\"><command>&no-i18n-tag;&no-"
"i18n-cmd_view_scroll_prev_label;</command>()</link>, <link linkend="
"\"cmd_sect_next\"><command>&no-i18n-tag;&no-i18n-cmd_next;</command>()</link>"
msgstr ""
"<link linkend=\"cmd_sect_view_scroll_next_label\"><command>&no-i18n-tag;&no-"
"i18n-cmd_view_scroll_prev_label;</command>()</link>, <link linkend="
"\"cmd_sect_next\"><command>&no-i18n-tag;&no-i18n-cmd_next;</command>()</link>"

#. Tag: title
#: index.docbook:3318
#, no-c-format
msgid "&no-i18n-tag;q"
msgstr "&no-i18n-tag;q"

#. Tag: title
#: index.docbook:3321
#, no-c-format
msgid "&no-i18n-cmd_quit;"
msgstr "&no-i18n-cmd_quit;"

#. Tag: title
#: index.docbook:3323
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_quit;</command>()"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_quit;</command>()"

#. Tag: para
#: index.docbook:3324
#, no-c-format
msgid ""
"Closes the current main window, including all sub-windows. In SDI mode this "
"is the same as the command <command>&no-i18n-cmd_close;</command>()."
msgstr ""
"Sluit het huidige hoofdvenster, inclusief alle subvensters. In modus SDI is "
"dit hetzelfde als het commando <command>&no-i18n-cmd_close;</command>()."

#. Tag: title
#: index.docbook:3338
#, no-c-format
msgid "&no-i18n-tag;r"
msgstr "&no-i18n-tag;r"

#. Tag: title
#: index.docbook:3341
#, no-c-format
msgid "&no-i18n-cmd_redo;"
msgstr "&no-i18n-cmd_redo;"

#. Tag: title
#: index.docbook:3343
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_redo;</command>()"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_redo;</command>()"

#. Tag: para
#: index.docbook:3344
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Redo</guibutton> toolbar button and repeats "
"one operation that has been reverted with <command>&no-i18n-cmd_undo;</"
"command>()."
msgstr ""
"Komt overeen met de knop op de werkbalk <guibutton>Opnieuw</guibutton> en "
"herhaalt één bewerking die is teruggedraaid met <command>&no-i18n-cmd_undo;</"
"command>()."

#. Tag: link
#: index.docbook:3352 index.docbook:3368 index.docbook:3826
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_undo;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_undo;</command>()"

#. Tag: title
#: index.docbook:3358
#, no-c-format
msgid "&no-i18n-cmd_redo_all;"
msgstr "&no-i18n-cmd_redo_all;"

#. Tag: title
#: index.docbook:3360
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_redo_all;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_redo_all;</command>()"

#. Tag: para
#: index.docbook:3361
#, no-c-format
msgid ""
"Similar to <command>&no-i18n-cmd_redo;</command>(), but re-does as many "
"operations as possible."
msgstr ""
"Vergelijkbaar met <command>&no-i18n-cmd_redo;</command>(), maar doet opnieuw "
"zoveel bewerkingen als mogelijk."

#. Tag: title
#: index.docbook:3374
#, no-c-format
msgid "&no-i18n-cmd_reenable_dna;"
msgstr "&no-i18n-cmd_reenable_dna;"

#. Tag: title
#: index.docbook:3376
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_reenable_dna;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_reenable_dna;</command>()"

#. Tag: para
#: index.docbook:3377
#, no-c-format
msgid ""
"Some message boxes offer the possibility to prevent them from appearing "
"again (<quote>do not ask again</quote>). This command makes all of them "
"appear again."
msgstr ""
"Sommige berichtvakken bieden de mogelijkheid om te voorkomen dat ze opnieuw "
"verschijnen (<quote>niet opnieuw vragen</quote>). Dit commando zorgt er voor "
"dat ze opnieuw verschijnen."

#. Tag: title
#: index.docbook:3386
#, no-c-format
msgid "&no-i18n-cmd_reset_toolbars;"
msgstr "&no-i18n-cmd_reset_toolbars;"

#. Tag: title
#: index.docbook:3388
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_reset_toolbars;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_reset_toolbars;</"
"command>()"

#. Tag: para
#: index.docbook:3389
#, no-c-format
msgid ""
"Resets all toolbar settings, like location, icon size and text location back "
"to defaults."
msgstr ""
"Zet alle instellingen van de werkbalk, zoals locatie, pictogramgrootte en "
"tekstlocatie terug naar standaarden."

#. Tag: title
#: index.docbook:3397
#, no-c-format
msgid "&no-i18n-cmd_revert;"
msgstr "&no-i18n-cmd_revert;"

#. Tag: title
#: index.docbook:3399
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_revert;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_revert;</command>()"

#. Tag: para
#: index.docbook:3400
#, no-c-format
msgid ""
"Reverts the currently loaded file back to the last saved state, discarding "
"all changes that are not saved."
msgstr ""
"Herstelt het nu geladen bestand terug naar de laatst opgeslagen status, met "
"verwerpen van alle wijzigingen die niet zijn opgeslagen."

#. Tag: title
#: index.docbook:3408
#, no-c-format
msgid "&no-i18n-cmd_rewind;"
msgstr "&no-i18n-cmd_rewind;"

#. Tag: title
#: index.docbook:3410
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_rewind;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_rewind;</command>()"

#. Tag: para
#: index.docbook:3411
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Rewind</guibutton> toolbar button. If the "
"playback is currently running, it skips backward by 1/10 of the visible "
"range. If the playback is not running, this does the same as the command "
"<command>&no-i18n-cmd_view_scroll_left;</command>()."
msgstr ""
"Komt overeen met de knop op de werkbalk <guibutton>Terugdraaien</guibutton>. "
"Als het afspelen nu bezig is, springt het terug met 1/10 van de zichtbare "
"reeks. Als het afspelen niet bezig is, doet dit hetzelfde als het commando "
"<command>&no-i18n-cmd_view_scroll_left;</command>()."

#. Tag: para
#: index.docbook:3420
#, no-c-format
msgid ""
"<link linkend=\"cmd_sect_view_scroll_left\"><command>&no-i18n-tag;&no-i18n-"
"cmd_view_scroll_left;</command>()</link>, <link linkend=\"cmd_sect_forward"
"\"><command>&no-i18n-tag;&no-i18n-cmd_forward;</command>()</link>"
msgstr ""
"<link linkend=\"cmd_sect_view_scroll_left\"><command>&no-i18n-tag;&no-i18n-"
"cmd_view_scroll_left;</command>()</link>, <link linkend=\"cmd_sect_forward"
"\"><command>&no-i18n-tag;&no-i18n-cmd_forward;</command>()</link>"

#. Tag: title
#: index.docbook:3428
#, no-c-format
msgid "&no-i18n-tag;s"
msgstr "&no-i18n-tag;s"

#. Tag: title
#: index.docbook:3431
#, no-c-format
msgid "&no-i18n-cmd_save;"
msgstr "&no-i18n-cmd_save;"

#. Tag: title
#: index.docbook:3433
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_save;</command>()"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_save;</command>()"

#. Tag: para
#: index.docbook:3434
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Save</guibutton> toolbar button. Saves the "
"current file if it has modifications. If the file does not already have a "
"name (&eg; a file that has just been created and does not yet have a file "
"name), this command does the same as <command>&no-i18n-cmd_saveas;</"
"command>()."
msgstr ""
"Komt overeen met de knop <guibutton>Opslaan</guibutton> op de werkbalk. "
"Slaat het huidige bestand op als het wijzigingen bevat. Als het bestand nog "
"geen naam heeft (&eg; een bestand dat zojuist is aangemaakt en nog geen "
"bestandsnaam heeft), doet dit commando hetzelfde als <command>&no-i18n-"
"cmd_saveas;</command>()."

#. Tag: link
#: index.docbook:3444
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_saveas;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_saveas;</command>()"

#. Tag: title
#: index.docbook:3450
#, no-c-format
msgid "&no-i18n-cmd_saveas;"
msgstr "&no-i18n-cmd_saveas;"

#. Tag: title
#: index.docbook:3452
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_saveas;</"
"command>([<replaceable>filename</replaceable>])"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_saveas;</"
"command>([<replaceable>bestandsnaam</replaceable>])"

#. Tag: para
#: index.docbook:3453
#, no-c-format
msgid ""
"Saves the currently opened file under a given file name. If no file name is "
"given as parameter, a dialog will be shown to select the directory and to "
"enter a file name."
msgstr ""
"Slaat het nu geopende bestand op onder een gegeven bestandsnaam. Als geen "
"bestandsnaam als parameter is gegeven zal er een dialoog verschijnen om de "
"map te selecteren en een bestandsnaam in te voeren."

#. Tag: entry
#: index.docbook:3461
#, no-c-format
msgid "file name for saving (optional)"
msgstr "Bestandsnaam voor opslaan (optioneel)"

#. Tag: title
#: index.docbook:3466
#, no-c-format
msgid "&no-i18n-cmd_saveselect;"
msgstr "&no-i18n-cmd_saveselect;"

#. Tag: title
#: index.docbook:3468
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_saveselect;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_saveselect;</command>()"

#. Tag: para
#: index.docbook:3469
#, no-c-format
msgid ""
"This command does the same as <command>&no-i18n-cmd_save;</command>(), but "
"saves only the currently selected range and the activated tracks instead of "
"the whole file."
msgstr ""
"Dit commando doet hetzelfde als <command>&no-i18n-cmd_save;</command>(), "
"maar slaat alleen de nu geselecteerde reeks op en de geactiveerde tracks in "
"plaats van het gehele bestand."

#. Tag: link
#: index.docbook:3477
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_save;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_save;</command>()"

#. Tag: title
#: index.docbook:3483
#, no-c-format
msgid "&no-i18n-cmd_select_gui_type;"
msgstr "&no-i18n-cmd_select_gui_type;"

#. Tag: title
#: index.docbook:3485
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_select_gui_type;</"
"command>(<replaceable>mode</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_select_gui_type;</"
"command>(<replaceable>modus</replaceable>)"

#. Tag: para
#: index.docbook:3486
#, no-c-format
msgid ""
"Select a &GUI; mode, which can be either SDI, MDI or Tab mode. Please be "
"aware that this change will immediately take effect!"
msgstr ""
"Selecteer een &GUI;-modus, die of SDI, MDI of Tab kan zijn. Let erop dat "
"deze wijziging onmiddellijk effect zal hebben!"

#. Tag: entry
#: index.docbook:3494
#, no-c-format
msgid ""
"name of the mode, must be either <quote>SDI</quote>, <quote>MDI</quote> or "
"<quote>TAB</quote>."
msgstr ""
"naam van de modus, moet of <quote>SDI</quote>, <quote>MDI</quote> of "
"<quote>TAB</quote> zijn."

#. Tag: title
#: index.docbook:3502
#, no-c-format
msgid "&no-i18n-cmd_select_track_all;"
msgstr "&no-i18n-cmd_select_track_all;"

#. Tag: title
#: index.docbook:3504 index.docbook:3521
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_select_track_all;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_select_track_all;</"
"command>()"

#. Tag: para
#: index.docbook:3505
#, no-c-format
msgid ""
"Mark all tracks <quote>enabled</quote>. This is the same as calling the "
"command <command>&no-i18n-tag;&no-i18n-cmd_select_track_on;</command>() for "
"all existing tracks."
msgstr ""
"Markeert alle tracks als <quote>ingeschakeld</quote> Dit is hetzelfde als "
"het commando <command>&no-i18n-tag;&no-i18n-cmd_select_track_on;</command>() "
"aanroepen voor alle bestaande tracks."

#. Tag: link
#: index.docbook:3513
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_select_track_on;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_select_track_on;</command>()"

#. Tag: title
#: index.docbook:3519
#, no-c-format
msgid "&no-i18n-cmd_select_track_invert;"
msgstr "&no-i18n-cmd_select_track_invert;"

#. Tag: para
#: index.docbook:3522
#, no-c-format
msgid ""
"Invert the <quote>enabled</quote> state of all tracks. This is the same as "
"calling the command <command>&no-i18n-cmd_select_track_toggle;</command>() "
"for all existing tracks."
msgstr ""
"Inverteert de status <quote>ingeschakeld</quote> van alle tracks. Dit is "
"hetzelfde als het commando <command>&no-i18n-cmd_select_track_toggle;</"
"command>() aanroepen voor alle bestaande tracks."

#. Tag: link
#: index.docbook:3531
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_select_track_toggle;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_select_track_toggle;</command>()"

#. Tag: title
#: index.docbook:3537
#, no-c-format
msgid "&no-i18n-cmd_select_track_none;"
msgstr "&no-i18n-cmd_select_track_none;"

#. Tag: title
#: index.docbook:3539
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_select_track_none;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_select_track_none;</"
"command>()"

#. Tag: para
#: index.docbook:3540
#, no-c-format
msgid ""
"Mark all tracks <quote>disabled</quote>. This is the same as calling the "
"command <command>&no-i18n-cmd_select_track_off;</command>() for all existing "
"tracks."
msgstr ""
"Markeert alle tracks als <quote>uitgeschakeld</quote>. Dit is hetzelfde als "
"het commando <command>&no-i18n-cmd_select_track_off;</command>() aanroepen "
"voor alle bestaande tracks."

#. Tag: link
#: index.docbook:3548
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_select_track_off;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_select_track_off;</command>()"

#. Tag: title
#: index.docbook:3554
#, no-c-format
msgid "&no-i18n-cmd_select_track_off;"
msgstr "&no-i18n-cmd_select_track_off;"

#. Tag: title
#: index.docbook:3556
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_select_track_off;</"
"command>(<replaceable>index</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_select_track_off;</"
"command>(<replaceable>index</replaceable>)"

#. Tag: para
#: index.docbook:3557
#, no-c-format
msgid ""
"Disables a single track, so that it does not get affected by most operations."
msgstr ""
"Schakelt een enkele track uit, zodat de meeste bewerkingen daarop niet "
"worden toegepast."

#. Tag: entry
#: index.docbook:3564 index.docbook:3578 index.docbook:3593
#, no-c-format
msgid "index of the track, starting with zero"
msgstr "index van de track, beginnend bij nul"

#. Tag: title
#: index.docbook:3569
#, no-c-format
msgid "&no-i18n-cmd_select_track_on;"
msgstr "&no-i18n-cmd_select_track_on;"

#. Tag: title
#: index.docbook:3571
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_select_track_on;</"
"command>(<replaceable>index</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_select_track_on;</"
"command>(<replaceable>index</replaceable>)"

#. Tag: para
#: index.docbook:3572
#, no-c-format
msgid "Enables a single track, so that it gets affected by all operations."
msgstr ""
"Schakelt een enkele track in, zodat deze alle bewerkingen daarop worden "
"toegepast."

#. Tag: title
#: index.docbook:3583
#, no-c-format
msgid "&no-i18n-cmd_select_track_toggle;"
msgstr "&no-i18n-cmd_select_track_toggle;"

#. Tag: title
#: index.docbook:3585
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_select_track_toggle;</"
"command>(<replaceable>index</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_select_track_toggle;</"
"command>(<replaceable>index</replaceable>)"

#. Tag: para
#: index.docbook:3586
#, no-c-format
msgid ""
"Enables a track if it is currently disabled, or disables it if it is "
"currently enabled."
msgstr ""
"Schakelt een track in als deze nu is uitgeschakeld of schakelt deze uit als "
"deze nu is ingeschakeld."

#. Tag: title
#: index.docbook:3598
#, no-c-format
msgid "&no-i18n-cmd_selectall;"
msgstr "&no-i18n-cmd_selectall;"

#. Tag: title
#: index.docbook:3600
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectall;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectall;</command>()"

#. Tag: para
#: index.docbook:3601
#, no-c-format
msgid ""
"Selects the range of the whole signal, from the first to the last sample."
msgstr ""
"Selecteert het bereik van het gehele signaal, van de eerste tot de laatste "
"sample."

#. Tag: title
#: index.docbook:3609
#, no-c-format
msgid "&no-i18n-cmd_selectnext;"
msgstr "&no-i18n-cmd_selectnext;"

#. Tag: title
#: index.docbook:3611
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectnext;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectnext;</command>()"

#. Tag: para
#: index.docbook:3612
#, no-c-format
msgid ""
"Selects a range of samples that starts right after the current selection, "
"using the same length as the current selection. The selection is "
"automatically clipped to the end of the signal. For example: if you have "
"selected samples 1000 ... 1019, then the result will be a selection from "
"sample 1020 ... 1039."
msgstr ""
"Selecteert een reeks samples die starten direct achter de huidige selectie "
"en dezelfde lengte gebruiken als de huidige selectie. De selectie wordt "
"automatisch afgesneden aan het eind van het signaal. Bijvoorbeeld: als u de "
"samples 1000 ... 1019 hebt geselecteerd, dan zal het resultaat een selectie "
"van sample 1020 ... 1039 zijn."

#. Tag: link
#: index.docbook:3622
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_selectprev;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_selectprev;</command>()"

#. Tag: title
#: index.docbook:3628
#, no-c-format
msgid "&no-i18n-cmd_selectnextlabels;"
msgstr "&no-i18n-cmd_selectnextlabels;"

#. Tag: title
#: index.docbook:3630
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectnextlabels;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectnextlabels;</"
"command>()"

#. Tag: para
#: index.docbook:3631
#, no-c-format
msgid ""
"Selects a range of samples between the next two labels after the current "
"selection. If nothing is selected, it selects from the start of the signal "
"up to the first label. Otherwise the left border of the new selection will "
"be the position of first label after the selection (or the last label if "
"there are no more labels right from the selection), and the right border of "
"the new selection will be the first label after the left border of the new "
"selection (or the end of the signal if there is none). This command returns "
"an error when there are no labels at all."
msgstr ""
"Selecteert een reeks samples tussen de volgende twee labels na de huidige "
"selectie. Als er niets is geselecteerd, selecteert het vanaf het begin van "
"het signaal tot het eerste label. Anders zal de linker rand van de nieuwe "
"selectie in de positie van het eerste label na de selectie zijn (of het "
"laatste label als er geen labels meer zijn rechts van de selectie), en de "
"rechter rand van de nieuwe selectie zal het eerste label na de linker rand "
"van de nieuwe selectie zijn (of het eind van het signaal als er geen is). "
"Dit commando geeft een fout terug wanneer er helemaal geen labels zijn."

#. Tag: link
#: index.docbook:3645
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_selectprevlabels;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_selectprevlabels;</command>()"

#. Tag: title
#: index.docbook:3651
#, no-c-format
msgid "&no-i18n-cmd_selectnone;"
msgstr "&no-i18n-cmd_selectnone;"

#. Tag: title
#: index.docbook:3653
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectnone;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectnone;</command>()"

#. Tag: para
#: index.docbook:3654
#, no-c-format
msgid "Resets the selection to zero length."
msgstr "Stelt de selectie terug op lengte nul."

#. Tag: title
#: index.docbook:3661
#, no-c-format
msgid "&no-i18n-cmd_selectprev;"
msgstr "&no-i18n-cmd_selectprev;"

#. Tag: title
#: index.docbook:3663
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectprev;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectprev;</command>()"

#. Tag: para
#: index.docbook:3664
#, no-c-format
msgid ""
"Selects a range of samples that starts left from the current selection, "
"using the same length as the current selection. The selection is "
"automatically clipped to the start of the signal. For example: if you have "
"selected samples 1000 ... 1019, then the result will be a selection from "
"sample 980 ... 999."
msgstr ""
"Selecteert een reeks samples die starten links vanaf de huidige selectie en "
"dezelfde lengte gebruiken als de huidige selectie. De selectie wordt "
"automatisch afgesneden aan het begin van het signaal. Bijvoorbeeld: als u de "
"samples 1000 ... 1019 hebt geselecteerd, dan zal het resultaat een selectie "
"van sample 980 ... 999 zijn."

#. Tag: link
#: index.docbook:3674
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_selectnext;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_selectnext;</command>()"

#. Tag: title
#: index.docbook:3680
#, no-c-format
msgid "&no-i18n-cmd_selectprevlabels;"
msgstr "&no-i18n-cmd_selectprevlabels;"

#. Tag: title
#: index.docbook:3682
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectprevlabels;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectprevlabels;</"
"command>()"

#. Tag: para
#: index.docbook:3683
#, no-c-format
msgid ""
"Selects a range of samples between the previous two labels before the "
"current selection. If nothing is selected, it selects from the start of the "
"signal up to the first label. Otherwise the right border of the new "
"selection will be the position of first label before the selection (or the "
"first label if there are no more labels left from the selection), and the "
"left border of the new selection will be the first label before the right "
"border of the new selection (or the start of the signal if there is none). "
"This command returns an error when there are no labels at all."
msgstr ""
"Selecteert een reeks samples tussen de vorige twee labels voor de huidige "
"selectie. Als er niets is geselecteerd, selecteert het vanaf het begin van "
"het signaal tot het eerste label. Anders zal de rechter rand van de nieuwe "
"selectie op de positie staan van het eerste label voor de selectie (of het "
"eerste label als er geen labels meer zijn overgebleven uit de selectie) en "
"de linker rand van de nieuwe selectie zal het eerste label voor de rechter "
"rand zijn van de nieuwe selectie (of het begin van het signaal als ere geen "
"is). Dit commando geeft een fout terug wanneer er helemaal geen labels zijn."

#. Tag: link
#: index.docbook:3697
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_selectnextlabels;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_selectnextlabels;</command>()"

#. Tag: title
#: index.docbook:3703
#, no-c-format
msgid "&no-i18n-cmd_selecttoleft;"
msgstr "&no-i18n-cmd_selecttoleft;"

#. Tag: title
#: index.docbook:3705
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selecttoleft;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selecttoleft;</command>()"

#. Tag: para
#: index.docbook:3706
#, no-c-format
msgid ""
"Sets the start of the selection to the start of the signal, the end of the "
"current selection stays unchanged."
msgstr ""
"Stelt het begin van de selectie in op het begin van het signaal, het eind "
"van de huidige selectie blijft ongewijzigd."

#. Tag: link
#: index.docbook:3713
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_selecttoright;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_selecttoright;</command>()"

#. Tag: title
#: index.docbook:3719
#, no-c-format
msgid "&no-i18n-cmd_selecttoright;"
msgstr "&no-i18n-cmd_selecttoright;"

#. Tag: title
#: index.docbook:3721
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selecttoright;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selecttoright;</"
"command>()"

#. Tag: para
#: index.docbook:3722
#, no-c-format
msgid ""
"Sets the end of the selection to the end of the signal, the start of the "
"current selection stays unchanged."
msgstr ""
"Stelt het eind van de selectie in op het eind van het signaal, het begin van "
"de huidige selectie blijft ongewijzigd."

#. Tag: link
#: index.docbook:3729
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_selecttoleft;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_selecttoleft;</command>()"

#. Tag: title
#: index.docbook:3735
#, no-c-format
msgid "&no-i18n-cmd_selectvisible;"
msgstr "&no-i18n-cmd_selectvisible;"

#. Tag: title
#: index.docbook:3737
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectvisible;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectvisible;</"
"command>()"

#. Tag: para
#: index.docbook:3738
#, no-c-format
msgid "Selects the range of samples that is visible in the current window."
msgstr "Selecteert de reeks samples die zichtbaar zijn in het huidige venster."

#. Tag: title
#: index.docbook:3746
#, no-c-format
msgid "&no-i18n-cmd_start;"
msgstr "&no-i18n-cmd_start;"

#. Tag: title
#: index.docbook:3748
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_start;</command>()"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_start;</command>()"

#. Tag: para
#: index.docbook:3749
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Start</guibutton> toolbar button and lets the "
"playback start from the beginning of the selection or continue if it is "
"currently paused."
msgstr ""
"Komt overeen met het de knop <guibutton>Begin</guibutton> op de werkbalk en "
"laat het afspelen beginnen vanaf het begin van de selectie of doorgaan als "
"het is nu is gepauzeerd."

#. Tag: link
#: index.docbook:3757
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_stop;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_stop;</command>()"

#. Tag: title
#: index.docbook:3763
#, no-c-format
msgid "&no-i18n-cmd_stop;"
msgstr "&no-i18n-cmd_stop;"

#. Tag: title
#: index.docbook:3765
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_stop;</command>()"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_stop;</command>()"

#. Tag: para
#: index.docbook:3766
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Stop</guibutton> toolbar button and lets the "
"playback stop if it is currently running."
msgstr ""
"Komt overeen met het de knop <guibutton>Stop</guibutton> op de werkbalk en "
"laat het afspelen stoppen als er nu wordt afgespeeld."

#. Tag: link
#: index.docbook:3773
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_start;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_start;</command>()"

#. Tag: title
#: index.docbook:3779
#, no-c-format
msgid "&no-i18n-cmd_sync;"
msgstr "&no-i18n-cmd_sync;"

#. Tag: title
#: index.docbook:3781
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_sync;</command>()"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_sync;</command>()"

#. Tag: para
#: index.docbook:3782
#, no-c-format
msgid ""
"Waits until all commands which have been started asynchronously have "
"finished. If nothing is currently queued for delayed execution this command "
"has no effect."
msgstr ""
"Wacht totdat alle commando's die asynchroon zijn gestart zijn geëindigd. Als "
"er nu niets in de wachtrij staat voor vertraagde uitvoering dan heeft dit "
"commando geen effect."

#. Tag: link
#: index.docbook:3790
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_delayed;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_delayed;</command>()"

#. Tag: title
#: index.docbook:3797
#, no-c-format
msgid "&no-i18n-tag;u"
msgstr "&no-i18n-tag;u"

#. Tag: title
#: index.docbook:3800
#, no-c-format
msgid "&no-i18n-cmd_undo;"
msgstr "&no-i18n-cmd_undo;"

#. Tag: title
#: index.docbook:3802
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_undo;</command>()"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_undo;</command>()"

#. Tag: para
#: index.docbook:3803
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Undo</guibutton> toolbar button and reverts "
"the last operation."
msgstr ""
"Komt overeen met de knop op de werkbalk <guibutton>Ongedaan maken</"
"guibutton> en keert de laatste bewerking om."

#. Tag: link
#: index.docbook:3810
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_redo;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_redo;</command>()"

#. Tag: title
#: index.docbook:3816
#, no-c-format
msgid "&no-i18n-cmd_undo_all;"
msgstr "&no-i18n-cmd_undo_all;"

#. Tag: title
#: index.docbook:3818
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_undo_all;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_undo_all;</command>()"

#. Tag: para
#: index.docbook:3819
#, no-c-format
msgid ""
"Similar to <command>&no-i18n-tag;&no-i18n-cmd_undo;</command>(), but reverts "
"as many operations as possible."
msgstr ""
"Vergelijkbaar met <command>&no-i18n-tag;&no-i18n-cmd_undo;</command>(), maar "
"draait zoveel mogelijke bewerkingen terug."

#. Tag: title
#: index.docbook:3832
#, no-c-format
msgid "&no-i18n-tag;v"
msgstr "&no-i18n-tag;v"

#. Tag: title
#: index.docbook:3835
#, no-c-format
msgid "&no-i18n-cmd_view_scroll_end;"
msgstr "&no-i18n-cmd_view_scroll_end;"

#. Tag: title
#: index.docbook:3837
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_end;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_end;</"
"command>()"

#. Tag: para
#: index.docbook:3838
#, no-c-format
msgid "Scrolls the current view to the <emphasis>end</emphasis> of the signal."
msgstr ""
"Schuift de huidige weergave tot het <emphasis>einde</emphasis> van het "
"signaal."

#. Tag: link
#: index.docbook:3842
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_start;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_start;</command>()"

#. Tag: title
#: index.docbook:3848
#, no-c-format
msgid "&no-i18n-cmd_view_scroll_left;"
msgstr "&no-i18n-cmd_view_scroll_left;"

#. Tag: title
#: index.docbook:3850
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_left;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_left;</"
"command>()"

#. Tag: para
#: index.docbook:3851
#, no-c-format
msgid ""
"Scrolls the current view by 1/10 of the currently visible range towards the "
"start of the signal. If the start of the signal is reached the visible area "
"starts at offset zero."
msgstr ""
"Schuift de huidige weergave met 1/10 van de huidige zichtbare reeks in de "
"richting van het begin van het signaal. Als het begin van het signaal is "
"bereikt begint het zichtbare gebied starts bij offset nul."

#. Tag: link
#: index.docbook:3859
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_right;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_right;</command>()"

#. Tag: title
#: index.docbook:3865
#, no-c-format
msgid "&no-i18n-cmd_view_scroll_next;"
msgstr "&no-i18n-cmd_view_scroll_next;"

#. Tag: title
#: index.docbook:3867
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_next;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_next;</"
"command>()"

#. Tag: para
#: index.docbook:3868
#, no-c-format
msgid ""
"Scrolls the current view towards the end of the signal by the currently "
"visible range."
msgstr ""
"Schuift de huidige weergave in de richting van het einde van het signaal met "
"de nu zichtbare reeks."

#. Tag: link
#: index.docbook:3875
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_prev;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_prev;</command>()"

#. Tag: title
#: index.docbook:3881
#, no-c-format
msgid "&no-i18n-cmd_view_scroll_next_label;"
msgstr "&no-i18n-cmd_view_scroll_next_label;"

#. Tag: title
#: index.docbook:3883
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_next_label;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_next_label;</"
"command>()"

#. Tag: para
#: index.docbook:3884
#, no-c-format
msgid ""
"Scrolls right and tries to show the next label centered in the view. If "
"there was no label right from the current position, it will scroll to the "
"end of the signal."
msgstr ""
"Schuift naar rechts en probeert het volgende label gecentreerd in de "
"weergave te tonen. Als er geen label rechts van de huidige positie was, zal "
"het schuiven naar het eind van het signaal."

#. Tag: link
#: index.docbook:3892
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_prev_label;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_prev_label;</command>()"

#. Tag: title
#: index.docbook:3898
#, no-c-format
msgid "&no-i18n-cmd_view_scroll_prev;"
msgstr "&no-i18n-cmd_view_scroll_prev;"

#. Tag: title
#: index.docbook:3900
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_prev;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_prev;</"
"command>()"

#. Tag: para
#: index.docbook:3901
#, no-c-format
msgid ""
"Scrolls the current view towards the start of the signal by the currently "
"visible range."
msgstr ""
"Schuift de huidige weergave in de richting van het begin van het signaal met "
"de nu zichtbare reeks."

#. Tag: link
#: index.docbook:3908
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_next;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_next;</command>()"

#. Tag: title
#: index.docbook:3914
#, no-c-format
msgid "&no-i18n-cmd_view_scroll_prev_label;"
msgstr "&no-i18n-cmd_view_scroll_prev_label;"

#. Tag: title
#: index.docbook:3916
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_prev_label;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_prev_label;</"
"command>()"

#. Tag: para
#: index.docbook:3917
#, no-c-format
msgid ""
"Scrolls left and tries to show the previous label centered in the view. If "
"there was no label left from the current position, it will scroll to the "
"start of the signal."
msgstr ""
"Schuift naar links en probeert het vorige label gecentreerd in de weergave "
"te tonen. Als er geen label links van de huidige positie was, zal het "
"schuiven naar het begin van het signaal."

#. Tag: link
#: index.docbook:3925
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_next_label;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_next_label;</command>()"

#. Tag: title
#: index.docbook:3931
#, no-c-format
msgid "&no-i18n-cmd_view_scroll_right;"
msgstr "&no-i18n-cmd_view_scroll_right;"

#. Tag: title
#: index.docbook:3933
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_right;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_right;</"
"command>()"

#. Tag: para
#: index.docbook:3934
#, no-c-format
msgid ""
"Scrolls the current view by 1/10 of the currently visible range towards the "
"end of the signal. If the end of the signal is reached the visible area ends "
"at the end of the signal."
msgstr ""
"Schuift de huidige weergave met 1/10 van de huidige zichtbare reeks in de "
"richting van het eind van het signaal. Als het eind van het signaal is "
"bereikt begint het zichtbare gebied eindigen aan het eind van het signaal."

#. Tag: link
#: index.docbook:3942
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_left;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_left;</command>()"

#. Tag: title
#: index.docbook:3948
#, no-c-format
msgid "&no-i18n-cmd_view_scroll_start;"
msgstr "&no-i18n-cmd_view_scroll_start;"

#. Tag: title
#: index.docbook:3950
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_start;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_start;</"
"command>()"

#. Tag: para
#: index.docbook:3951
#, no-c-format
msgid "Scrolls the current view to the start of the signal."
msgstr "Schuift de huidige weergave naar het begin van het signaal."

#. Tag: link
#: index.docbook:3955
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_end;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_end;</command>()"

#. Tag: title
#: index.docbook:3961
#, no-c-format
msgid "&no-i18n-cmd_view_zoom_all;"
msgstr "&no-i18n-cmd_view_zoom_all;"

#. Tag: title
#: index.docbook:3963
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_zoom_all;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_zoom_all;</"
"command>()"

#. Tag: para
#: index.docbook:3964
#, no-c-format
msgid ""
"Adjusts the zoom factor so that the complete signal is visible in the "
"current view."
msgstr ""
"Past de zoomfactor aan zodat het complete signaal zichtbaar is in de huidige "
"weergave."

#. Tag: title
#: index.docbook:3972
#, no-c-format
msgid "&no-i18n-cmd_view_zoom_in;"
msgstr "&no-i18n-cmd_view_zoom_in;"

#. Tag: title
#: index.docbook:3974
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_view_zoom_in;</"
"command>([<replaceable>position</replaceable>])"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_view_zoom_in;</"
"command>([<replaceable>positie</replaceable>])"

#. Tag: para
#: index.docbook:3975
#, no-c-format
msgid ""
"Reduces the zoom factor (in samples per pixel) by 30%, so that more details "
"get visible. If a <replaceable>position</replaceable> is given, it tries to "
"show that position centered in the current view, otherwise the center of the "
"view before the zoom change is used for centering. The minimum zoom factor "
"is limited to a minimum of five samples per width of the view."
msgstr ""
"Reduceert de zoomfactor (in samples per pixel) met 30%, zodat meer details "
"zichtbaar worden. Als een <replaceable>positie</replaceable> is gegeven, "
"probeert het om die positie gecentreerd in de huidige weergave te tonen, "
"anders wordt het centrum van de weergave voor de wijziging van de zoomfactor "
"gebruikt als centrum. De minimale zoomfactor is beperkt tot een minimum van "
"vijf samples per breedte van de weergave."

#. Tag: entry
#: index.docbook:3987 index.docbook:4024
#, no-c-format
msgid "<parameter>position</parameter>:"
msgstr "<parameter>positie</parameter>:"

#. Tag: entry
#: index.docbook:3988
#, no-c-format
msgid "a zero based position in samples to center the view (optional)"
msgstr ""
"een op nul gebaseerde positie in samples om de weergave te centreren "
"(optioneel)"

#. Tag: link
#: index.docbook:3992
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_view_zoom_out;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_view_zoom_out;</command>()"

#. Tag: title
#: index.docbook:3998
#, no-c-format
msgid "&no-i18n-cmd_view_zoom_normal;"
msgstr "&no-i18n-cmd_view_zoom_normal;"

#. Tag: title
#: index.docbook:4000
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_zoom_normal;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_zoom_normal;</"
"command>()"

#. Tag: para
#: index.docbook:4001
#, no-c-format
msgid ""
"Sets the zoom factor to one pixel per sample (factor 1.0) and tries to keep "
"the previous center of the view."
msgstr ""
"Stelt de zoomfactor in op één pixel per sample (factor 1,0) en probeert het "
"vorige centrum van de weergave te behouden."

#. Tag: title
#: index.docbook:4009
#, no-c-format
msgid "&no-i18n-cmd_view_zoom_out;"
msgstr "&no-i18n-cmd_view_zoom_out;"

#. Tag: title
#: index.docbook:4011
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_view_zoom_out;"
"([<replaceable>position</replaceable>])</command>"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_view_zoom_out;([<replaceable>positie</"
"replaceable>])</command>"

#. Tag: para
#: index.docbook:4012
#, no-c-format
msgid ""
"Increases the zoom factor (in samples per pixel) by 30%, so that less "
"details get visible. If a <replaceable>position</replaceable> is given, it "
"tries to show that position centered in the current view, otherwise the "
"center of the view before the zoom change is used for centering. The maximum "
"zoom factor is limited to the number of samples of the complete signal and "
"the width of the view."
msgstr ""
"Verhoogt de zoomfactor (in samples per pixel) met 30%, zodat minder details "
"zichtbaar worden. Als een <replaceable>positie</replaceable> is gegeven, "
"probeert het om die positie gecentreerd in de huidige weergave te tonen, "
"anders wordt het centrum van de weergave voor de wijziging van de zoomfactor "
"gebruikt als centrum. De maximale zoomfactor is beperkt tot het aantal "
"samples van het complete signaal en de breedte van de weergave."

#. Tag: entry
#: index.docbook:4025
#, no-c-format
msgid "a zero based position is samples to center the view (optional)"
msgstr ""
"een op nul gebaseerde positie in samples om de weergave te centreren "
"(optioneel)"

#. Tag: link
#: index.docbook:4029
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_view_zoom_in;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_view_zoom_in;</command>()"

#. Tag: title
#: index.docbook:4035
#, no-c-format
msgid "&no-i18n-cmd_view_zoom_selection;"
msgstr "&no-i18n-cmd_view_zoom_selection;"

#. Tag: title
#: index.docbook:4037
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_zoom_selection;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_zoom_selection;</"
"command>()"

#. Tag: para
#: index.docbook:4038
#, no-c-format
msgid ""
"Adjusts the view (zoom factor and start of visible area) so that it matches "
"the current selection. This command does nothing if the selection is empty."
msgstr ""
"Pas de weergave aan (zoomfactor en begin van zichtbare gebied) zodat het "
"overeenkomst met de huidige selectie. Dit commando doet niets als de "
"selectie leeg is."

#. Tag: title
#: index.docbook:4047
#, no-c-format
msgid "&no-i18n-tag;w"
msgstr "&no-i18n-tag;w"

#. Tag: title
#: index.docbook:4050
#, no-c-format
msgid "&no-i18n-cmd_window_activate;"
msgstr "&no-i18n-cmd_window_activate;"

#. Tag: title
#: index.docbook:4052
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_activate;</"
"command>(<replaceable>title</replaceable>])"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_activate;</"
"command>(<replaceable>titel</replaceable>])"

#. Tag: para
#: index.docbook:4053
#, no-c-format
msgid ""
"Activates a sub-window, identified by its window <replaceable>title</"
"replaceable>. If the sub-window is minimized it will be restored. Only "
"available if in MDI and Tab mode. This command is internally used by the "
"<guisubmenu>Window</guisubmenu> menu."
msgstr ""
"Activeert een subvenster, geïdentificeerd door zijn "
"venster<replaceable>titel</replaceable>. Als het subvenster is "
"geminimaliseerd zal het worden hersteld. Slechts beschikbaar indien in MDI "
"en tabbladmodus. Dit commando wordt intern gebruikt door het "
"<guisubmenu>Venster</guisubmenu>menu."

#. Tag: entry
#: index.docbook:4061
#, no-c-format
msgid "<parameter>title</parameter>:"
msgstr "<parameter>titel</parameter>:"

#. Tag: entry
#: index.docbook:4062
#, no-c-format
msgid "the title of the sub-window that should be activated"
msgstr "de titel van het subvenster dat geactiveerd moet worden"

#. Tag: title
#: index.docbook:4067
#, no-c-format
msgid "&no-i18n-cmd_window_cascade;"
msgstr "&no-i18n-cmd_window_cascade;"

#. Tag: title
#: index.docbook:4069
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_cascade;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_cascade;</"
"command>()"

#. Tag: para
#: index.docbook:4070
#, no-c-format
msgid ""
"Cascades all sub-windows when in MDI mode. All sub-windows that are "
"currently minimized stay minimized, they will not be restored."
msgstr ""
"Zet alle subvensters achter elkaar wanneer in MDI-modus. Alle subvensters "
"die nu zijn geminimaliseerd blijven geminimaliseerd, ze zullen niet hersteld "
"worden."

#. Tag: title
#: index.docbook:4078
#, no-c-format
msgid "&no-i18n-cmd_window_click;"
msgstr "&no-i18n-cmd_window_click;"

#. Tag: title
#: index.docbook:4080
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_click;</"
"command>( <replaceable>class</replaceable>, <replaceable>x</replaceable>, "
"<replaceable>y</replaceable> )"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_click;</"
"command>( <replaceable>klasse</replaceable>, <replaceable>x</replaceable>, "
"<replaceable>y</replaceable> )"

#. Tag: para
#: index.docbook:4085
#, no-c-format
msgid ""
"Sends a mouse click event to window, identified by its <replaceable>class</"
"replaceable> name. The event will only be sent to the first window that has "
"the given class name, therefore you should make sure that you have only one "
"instance of the given window when this command gets executed."
msgstr ""
"Stuurt een muisklikgebeurtenis naar venster, geïdentificeerd door zijn "
"<replaceable>klasse</replaceable>naam. De gebeurtenis zal alleen verzonden "
"worden naar het eerste venster dat de gegeven klassenaam heeft, u zou dus na "
"moeten gaan dat u slechts één exemplaar van het gegeven venster hebt wanneer "
"dit commando wordt uitgevoerd."

#. Tag: entry
#: index.docbook:4095 index.docbook:4119 index.docbook:4153 index.docbook:4204
#: index.docbook:4232 index.docbook:4257
#, no-c-format
msgid "<parameter>class</parameter>:"
msgstr "<parameter>klasse</parameter>:"

#. Tag: entry
#: index.docbook:4096 index.docbook:4120 index.docbook:4154 index.docbook:4205
#: index.docbook:4233 index.docbook:4258
#, no-c-format
msgid "name of the window class"
msgstr "naam van de vensterklasse"

#. Tag: entry
#: index.docbook:4097 index.docbook:4155
#, no-c-format
msgid "<parameter>x</parameter>:"
msgstr "<parameter>x</parameter>:"

#. Tag: entry
#: index.docbook:4098 index.docbook:4156
#, no-c-format
msgid "x position, relative to the left border of the window (in pixels)"
msgstr "x-positie, relatief tot de linkerrand van het venster (in pixels)"

#. Tag: entry
#: index.docbook:4099 index.docbook:4157
#, no-c-format
msgid "<parameter>y</parameter>:"
msgstr "<parameter>y</parameter>:"

#. Tag: entry
#: index.docbook:4100 index.docbook:4158
#, no-c-format
msgid "y position, relative to the top border of the window (in pixels)"
msgstr "y-positie, relatief tot de bovenrand van het venster (in pixels)"

#. Tag: title
#: index.docbook:4105
#, no-c-format
msgid "&no-i18n-cmd_window_close;"
msgstr "&no-i18n-cmd_window_close;"

#. Tag: title
#: index.docbook:4107
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_close;</"
"command>( <replaceable>class</replaceable> )"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_close;</"
"command>( <replaceable>klasse</replaceable> )"

#. Tag: para
#: index.docbook:4110
#, no-c-format
msgid ""
"Closes a window, identified by its <replaceable>class</replaceable> name. "
"Only the first window that has the given class name will be closed, "
"therefore you should make sure that you have only one instance of the given "
"window when this command gets executed."
msgstr ""
"Sluit een venster, geïdentificeerd door zijn <replaceable>klasse</"
"replaceable>naam. Alleen het eerste venster dat de gegeven klassenaam heeft "
"zal gesloten worden, u zou dus na moeten gaan dat u slechts één exemplaar "
"van het gegeven venster hebt wanneer dit commando wordt uitgevoerd."

#. Tag: title
#: index.docbook:4125
#, no-c-format
msgid "&no-i18n-cmd_window_minimize;"
msgstr "&no-i18n-cmd_window_minimize;"

#. Tag: title
#: index.docbook:4127
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-cmd_window_minimize;</command>"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-cmd_window_minimize;</command>"

#. Tag: para
#: index.docbook:4128
#, no-c-format
msgid ""
"Minimizes the currently active sub-window when in MDI mode or the current "
"toplevel window when in SDI or Tab mode."
msgstr ""
"Minimaliseert het huidige actieve subvenster indien in MDI-modus of het "
"huidige hoofdvenster indien in SDI- of tabbladmodus."

#. Tag: title
#: index.docbook:4136
#, no-c-format
msgid "&no-i18n-cmd_window_mousemove;"
msgstr "&no-i18n-cmd_window_mousemove;"

#. Tag: title
#: index.docbook:4138
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_resize;</"
"command>( <replaceable>class</replaceable>, <replaceable>x</replaceable>, "
"<replaceable>y</replaceable> )"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_resize;</"
"command>( <replaceable>klasse</replaceable>, <replaceable>x</replaceable>, "
"<replaceable>y</replaceable> )"

#. Tag: para
#: index.docbook:4143
#, no-c-format
msgid ""
"Sends a mouse move event to window, identified by its <replaceable>class</"
"replaceable> name. The event will only be sent to the first window that has "
"the given class name, therefore you should make sure that you have only one "
"instance of the given window when this command gets executed."
msgstr ""
"Stuurt een muisverplaatsinggebeurtenis naar venster, geïdentificeerd door "
"zijn <replaceable>klasse</replaceable>naam. De gebeurtenis zal alleen "
"verzonden worden naar het eerste venster dat de gegeven klassenaam heeft, u "
"zou dus na moeten gaan dat u slechts één exemplaar van het gegeven venster "
"hebt wanneer dit commando wordt uitgevoerd."

#. Tag: title
#: index.docbook:4163
#, no-c-format
msgid "&no-i18n-cmd_window_next_sub;"
msgstr "&no-i18n-cmd_window_next_sub;"

#. Tag: title
#: index.docbook:4165
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_next_sub;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_next_sub;</"
"command>()"

#. Tag: para
#: index.docbook:4166
#, no-c-format
msgid ""
"Activates the <emphasis>next</emphasis> sub-window when in MDI or Tab mode. "
"If the next sub-window is minimized it will be restored."
msgstr ""
"Activeert het <emphasis>volgende</emphasis> subvenster indien in MDI- of Tab-"
"modus. Als het volgende subvenster is geminimaliseerd zal het worden "
"hersteld."

#. Tag: title
#: index.docbook:4174
#, no-c-format
msgid "&no-i18n-cmd_window_prev_sub;"
msgstr "&no-i18n-cmd_window_prev_sub;"

#. Tag: title
#: index.docbook:4176
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_prev_sub;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_prev_sub;</"
"command>()"

#. Tag: para
#: index.docbook:4177
#, no-c-format
msgid ""
"Activates the <emphasis>previous</emphasis> sub-window when in MDI or Tab "
"mode. If the previous sub-window is minimized it will be restored."
msgstr ""
"Activeert het <emphasis>vorige</emphasis> subvenster indien in MDI- of "
"Tabmodus. Als het vorige subvenster is geminimaliseerd zal het worden "
"hersteld."

#. Tag: title
#: index.docbook:4185
#, no-c-format
msgid "&no-i18n-cmd_window_resize;"
msgstr "&no-i18n-cmd_window_resize;"

#. Tag: title
#: index.docbook:4187
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_resize;</"
"command>( <replaceable>class</replaceable>, <replaceable>width</"
"replaceable>, <replaceable>height</replaceable> )"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_resize;</"
"command>( <replaceable>klasse</replaceable>, <replaceable>breedte</"
"replaceable>, <replaceable>hoogte</replaceable> )"

#. Tag: para
#: index.docbook:4192
#, no-c-format
msgid ""
"Changes the size of a window, identified by its <replaceable>class</"
"replaceable> name to a new <replaceable>width</replaceable> and "
"<replaceable>height</replaceable>. The change will only be applied to the "
"first window that has the given class name, therefore you should make sure "
"that you have only one instance of the given window when this command gets "
"executed."
msgstr ""
"Wijzigt de grootte van een venster, geïdentificeerd door zijn "
"<replaceable>klasse</replaceable>naam naar een nieuwe <replaceable>breedte</"
"replaceable> en <replaceable>hoogte</replaceable>. De wijziging zal alleen "
"worden toegepast op het eerste venster dat de gegeven klassenaam heeft, u "
"zou dus na moeten gaan dat u slechts één exemplaar van het gegeven venster "
"hebt wanneer dit commando wordt uitgevoerd."

#. Tag: entry
#: index.docbook:4206
#, no-c-format
msgid "<parameter>width</parameter>:"
msgstr "<parameter>breedte</parameter>:"

#. Tag: entry
#: index.docbook:4207
#, no-c-format
msgid "new width of the window (in pixels)"
msgstr "nieuwe breedte van het venster (in pixels)"

#. Tag: entry
#: index.docbook:4208
#, no-c-format
msgid "<parameter>height</parameter>:"
msgstr "<parameter>hoogte</parameter>:"

#. Tag: entry
#: index.docbook:4209
#, no-c-format
msgid "new height of the window (in pixels)"
msgstr "nieuwe hoogte van het venster (in pixels)"

#. Tag: title
#: index.docbook:4214
#, no-c-format
msgid "&no-i18n-cmd_window_screenshot;"
msgstr "&no-i18n-cmd_window_screenshot;"

#. Tag: title
#: index.docbook:4216
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_screenshot;</"
"command>( <replaceable>class</replaceable>, <replaceable>filename</"
"replaceable> )"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_screenshot;</"
"command>( <replaceable>class</replaceable>, <replaceable>bestandsnaam</"
"replaceable> )"

#. Tag: para
#: index.docbook:4220
#, no-c-format
msgid ""
"Takes a screenshot of a window, identified by its <replaceable>class</"
"replaceable> and saves it to a file. The screenshot will be taken from the "
"first window that has the given class name, therefore you should make sure "
"that you have only one instance of the given window when this command gets "
"executed. Currently the format of the file is hardcoded and has to be "
"<literal>*.png</literal>."
msgstr ""
"Maakt een schermafdruk van een venster, geïdentificeerd door zijn "
"<replaceable>klasse</replaceable> en wordt opgeslagen in een bestand. De "
"schermafdruk zal genomen worden van het eerste venster dat de gegeven "
"klassenaam heeft, u zou dus na moeten gaan dat u slechts één exemplaar van "
"het gegeven venster hebt wanneer dit commando wordt uitgevoerd. Op dit "
"moment is het formaat van het bestand hard gecodeerd en moet <literal>*.png</"
"literal> zijn."

#. Tag: entry
#: index.docbook:4235
#, no-c-format
msgid ""
"name of the file to save the screenshot, must have the extension <literal>*."
"png</literal>"
msgstr ""
"naam van het bestand waarin de schermafdruk wordt opgeslagen, moet de "
"extensie <literal>*.png</literal> hebben"

#. Tag: title
#: index.docbook:4241
#, no-c-format
msgid "&no-i18n-cmd_window_sendkey;"
msgstr "&no-i18n-cmd_window_sendkey;"

#. Tag: title
#: index.docbook:4243
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_sendkey;</"
"command>( <replaceable>class</replaceable>, <replaceable>key code</"
"replaceable> )"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_sendkey;</"
"command>( <replaceable>klasse</replaceable>, <replaceable>toetscode</"
"replaceable> )"

#. Tag: para
#: index.docbook:4247
#, no-c-format
msgid ""
"Sends a key press and release event to a window, identified by its "
"<replaceable>class</replaceable> name. The key will only be sent to the "
"first window that has the given class name, therefore you should make sure "
"that you have only one instance of the given window when this command gets "
"executed."
msgstr ""
"Stuurt het indrukken van een toets naar een venster, geïdentificeerd door "
"zijn <replaceable>klasse</replaceable>naam. De toetscode zal alleen "
"verzonden worden naar het eerste venster dat de gegeven klassenaam heeft, u "
"zou dus na moeten gaan dat u slechts één exemplaar van het gegeven venster "
"hebt wanneer dit commando wordt uitgevoerd."

#. Tag: entry
#: index.docbook:4259
#, no-c-format
msgid "<parameter>key code</parameter>:"
msgstr "<parameter>toetscode</parameter>:"

#. Tag: entry
#: index.docbook:4260
#, no-c-format
msgid ""
"the key code that should be sent, using the same syntax as used for setting "
"up menus"
msgstr ""
"de toetscode die verzonden moet worden, met gebruik van dezelfde syntaxis "
"als gebruikt voor instellen van menu's"

#. Tag: para
#: index.docbook:4264
#, no-c-format
msgid ""
"Description of the parameter <link linkend=\"cmd_menu_param_hotkey"
"\"><parameter>hotkey</parameter></link> of the <command>&no-i18n-cmd_menu;</"
"command>() command."
msgstr ""
"Beschrijving van de parameter <link linkend=\"cmd_menu_param_hotkey"
"\"><parameter>sneltoets</parameter></link> van het commando <command>&no-"
"i18n-cmd_menu;</command>()."

#. Tag: title
#: index.docbook:4273
#, no-c-format
msgid "&no-i18n-cmd_window_tile;"
msgstr "&no-i18n-cmd_window_tile;"

#. Tag: title
#: index.docbook:4275
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_tile;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_tile;</command>()"

#. Tag: para
#: index.docbook:4276
#, no-c-format
msgid ""
"Tiles all sub-windows when in MDI mode, using some scheme of &plasma;. All "
"sub-windows that are currently minimized stay minimized, they will not be "
"restored."
msgstr ""
"Maakt van alle subvensters tegels wanneer in MDI-modus, met gebruik van een "
"schema van &plasma;. Alle subvensters die nu zijn geminimaliseerd blijven "
"geminimaliseerd, ze zullen niet hersteld worden."

#. Tag: title
#: index.docbook:4285
#, no-c-format
msgid "&no-i18n-cmd_window_tile_vertical;"
msgstr "&no-i18n-cmd_window_tile_vertical;"

#. Tag: title
#: index.docbook:4287
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_tile_vertical;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_tile_vertical;</"
"command>()"

#. Tag: para
#: index.docbook:4288
#, no-c-format
msgid ""
"Tiles all sub-windows vertically when in MDI mode. All windows that are "
"currently minimized stay minimized, they will not be restored."
msgstr ""
"Zet alle tegels van subvensters verticaal wanneer in MDI-modus. Alle "
"subvensters die nu zijn geminimaliseerd blijven geminimaliseerd, ze zullen "
"niet hersteld worden."

