#~ msgid "2009-11-18"
#~ msgstr "2009-11-18"

#~ msgid "Create root/affix combinations not in dictionary"
#~ msgstr "Probeer van onbekende woorden de stam te vinden"

#~ msgid ""
#~ "Selecting this option allows the spell checker to register as "
#~ "<quote>correct</quote> combinations of root words with suffixes or "
#~ "prefixes even if the particular combination is not listed in its "
#~ "dictionary database of words."
#~ msgstr ""
#~ "Met deze optie mag de spellingcontrole combinaties van bekende stammen en "
#~ "voor- of achtervoegsels goedkeuren zelfs als de combinatie zelf niet in "
#~ "het woordenboek voorkomt."

#~ msgid "Consider run-together words as spelling errors"
#~ msgstr "Beschouw samengevoegde woorden als spelfouten"

#~ msgid "Dictionary:"
#~ msgstr "Woordenboek:"

#~ msgid "Encoding:"
#~ msgstr "Codering:"

