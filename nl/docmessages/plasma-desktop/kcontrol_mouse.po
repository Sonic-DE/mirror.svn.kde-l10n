#~ msgid ""
#~ "Not all devices support all capabilities (typically cordless devices do "
#~ "not provide resolution switching, and of course only cordless devices "
#~ "support cordless status reporting), so some parts of the tab will not be "
#~ "enabled for some mouse types."
