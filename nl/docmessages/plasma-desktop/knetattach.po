#. Tag: para
#: index.docbook:41
#, no-c-format
msgid ""
"&knetattach; is a wizard which makes it easier to integrate your network "
"resources with your &kde; Desktop."
msgstr ""
"&knetattach; is een assistent die het gemakkelijker maakt om netwerkbronnen "
"met het &kde;-bureaublad te integreren."

#. Tag: keyword
#: index.docbook:52
#, no-c-format
msgid "<keyword>KDE</keyword>"
msgstr "<keyword>KDE</keyword>"

