#. Tag: refpurpose
#: man-zonetab2pot.py.1.docbook:20
#, no-c-format
msgid "Converts a timezone list to a PO file template."
msgstr "Converteert een tijdzonelijst naar een sjabloon voor een po-bestand"

#. Tag: cmdsynopsis
#: man-zonetab2pot.py.1.docbook:24
#, no-c-format
msgid ""
"<command>zonetab2pot.py</command> <group><option><replaceable>timezone-list</"
"replaceable></option></group>"
msgstr ""
"<command>zonetab2pot.py</command> <group><option><replaceable>tijdzonelijst</"
"replaceable></option></group>"

#. Tag: title
#: man-zonetab2pot.py.1.docbook:32
#, no-c-format
msgid "Description"
msgstr "Beschrijving"

#. Tag: para
#: man-zonetab2pot.py.1.docbook:34
#, no-c-format
msgid ""
"<command>zonetab2pot.py</command> reads the timezone list given on the "
"command-line and converts it to a gettext message file (PO-file) template "
"containing the names of the individual timezones."
msgstr ""
"<command>zonetab2pot.py</command> leest de tijdzonelijst gegeven op de "
"commandoregel en converteert het naar een gettext-message-bestand (PO-"
"sjabloonbestand) die de namen bevat van de individuele tijdzones."

#. Tag: para
#: man-zonetab2pot.py.1.docbook:39
#, no-c-format
msgid ""
"The given timezone list should be in the same format as the system zone.tab. "
"If no timezone list is specified on the command-line, <filename>/usr/share/"
"zoneinfo/zone.tab</filename> will be used."
msgstr ""
"De gegeven tijdzonelijst zou in hetzelfde formaat moeten zijn als de zone."
"tab van het systeem. Als er geen tijdzonelijst is gespecificeerd op de "
"commandoregel, dan wordt <filename>/usr/share/zoneinfo/zone.tab</filename> "
"gebruikt."

#. Tag: para
#: man-zonetab2pot.py.1.docbook:43
#, no-c-format
msgid "The new PO-file template will be written to standard output."
msgstr ""
"Het nieuwe PO-sjabloonbestand zal naar standaard uitvoer worden geschreven."

#. Tag: para
#: man-zonetab2pot.py.1.docbook:45
#, no-c-format
msgid "This utility is part of the KDE Software Development Kit."
msgstr ""
"Dit hulpmiddel is een onderdeel van het software-ontwikkelpakket van &kde;."

