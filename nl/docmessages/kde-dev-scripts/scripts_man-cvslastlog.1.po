#. Tag: refpurpose
#: man-cvslastlog.1.docbook:20
#, no-c-format
msgid "Prints the log entry for the last commit for a file."
msgstr "Toont de logregel voor de laatste 'commit' van een bestand."

#. Tag: cmdsynopsis
#: man-cvslastlog.1.docbook:24
#, no-c-format
msgid ""
"<command>cvslastlog</command> <group><option><replaceable>filename</"
"replaceable></option></group>"
msgstr ""
"<command>cvslastlog</command> <group><option><replaceable>bestandsnaam</"
"replaceable></option></group>"

#. Tag: title
#: man-cvslastlog.1.docbook:32
#, no-c-format
msgid "Description"
msgstr "Beschrijving"

#. Tag: para
#: man-cvslastlog.1.docbook:34
#, no-c-format
msgid ""
"<command>cvslastlog</command> shows the log associated with the last CVS "
"commit for the given file. It depends on the version of the local file, not "
"the one on the server."
msgstr ""
"<command>cvslastlog</command> toont de logregel behorende bij de laatste "
"'cvs commit' voor het gegeven bestand. Het hangt af van de versie van het "
"lokale bestand, niet van die op de server."

#. Tag: para
#: man-cvslastlog.1.docbook:38
#, no-c-format
msgid "This utility is part of the &kde; Software Development Kit."
msgstr ""
"Dit hulpmiddel is een onderdeel van het software-ontwikkelpakket van &kde;."

