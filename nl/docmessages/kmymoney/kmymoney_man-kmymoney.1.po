#. Tag: title
#: man-kmymoney.1.docbook:121
#, no-c-format
msgid "Description"
msgstr "Beschrijving"

#. Tag: para
#: man-kmymoney.1.docbook:123
#, no-c-format
msgid ""
"&kmymoney; is the Personal Finance Manager by &kde;. It provides the "
"functions required to balance your checkbooks, manage your personal loans "
"and categories your incomes and expenses using a checkbook style graphical "
"user interface."
msgstr ""
"&kmymoney; is de Persoonlijke financiënbeheerder door &kde;. Het biedt de "
"functies vereist voor bijhouden van uw betalingen, het beheren van uw "
"persoonlijke leningen en stopt uw inkomsten en uitgaven in categorieën met "
"grafisch gebruikersinterface in de stijl van boekje met checks."

#. Tag: title
#: man-kmymoney.1.docbook:131
#, no-c-format
msgid "Options"
msgstr "Opties"

#. Tag: option
#: man-kmymoney.1.docbook:136
#, no-c-format
msgid "--lang"
msgstr "--lang"

#. Tag: para
#: man-kmymoney.1.docbook:138
#, no-c-format
msgid "Language to be used"
msgstr "Te gebruiken taal"

#. Tag: option
#: man-kmymoney.1.docbook:143
#, no-c-format
msgid "<option>-n</option>"
msgstr "<option>-n</option>"

#. Tag: para
#: man-kmymoney.1.docbook:145
#, no-c-format
msgid "Do not open last used file"
msgstr "Laatst gebruikte bestand niet openen"

#. Tag: option
#: man-kmymoney.1.docbook:150
#, no-c-format
msgid "--timers"
msgstr "--timers"

#. Tag: para
#: man-kmymoney.1.docbook:152
#, no-c-format
msgid "Enable performance timers"
msgstr "Schakel prestatietimers in"

#. Tag: option
#: man-kmymoney.1.docbook:157
#, no-c-format
msgid "--nocatch"
msgstr "--nocatch"

#. Tag: para
#: man-kmymoney.1.docbook:159
#, no-c-format
msgid "Do not globally catch uncaught exceptions"
msgstr "Opgevangen uitzonderingen niet globaal opvangen"

#. Tag: option
#: man-kmymoney.1.docbook:164
#, no-c-format
msgid "--trace"
msgstr "--trace"

#. Tag: para
#: man-kmymoney.1.docbook:166
#, no-c-format
msgid ""
"Turn on program traces. This option is only available when &kmymoney; is "
"compiled in debug mode."
msgstr ""
"Zet programmatraces aan. Deze optie is alleen beschikbaar wanneer &kmymoney; "
"gecompileerd is in modus debug."

#. Tag: option
#: man-kmymoney.1.docbook:174
#, no-c-format
msgid "--dump-actions"
msgstr "--dump-actions"

#. Tag: para
#: man-kmymoney.1.docbook:176
#, no-c-format
msgid ""
"Dump the names of all defined QAction objects to stdout and quit. This "
"option is only available when &kmymoney; is compiled in debug mode."
msgstr ""
"Dump de namen van alle gedefinieerde QAction-objecten naar stdout en stop. "
"Deze optie is alleen beschikbaar wanneer &kmymoney; gecompileerd is in modus "
"debug."

#. Tag: title
#: man-kmymoney.1.docbook:189
