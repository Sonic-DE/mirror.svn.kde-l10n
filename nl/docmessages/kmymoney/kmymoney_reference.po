msgstr ""
"<guimenu>Bestand</guimenu><guimenuitem>Persoonlijke gegevens...</guimenuitem>"

#. Tag: para
#: reference.docbook:156
#, no-c-format
msgid "Allows to edit personal data."
msgstr "Laat persoonlijke gegevens bewerken."

#. Tag: menuchoice
#: reference.docbook:161
#, no-c-format
msgid "<guimenu>File</guimenu><guimenuitem>File information...</guimenuitem>"
msgstr ""
"<guimenu>Bestand</guimenu><guimenuitem>Bestandsinformatie..</guimenuitem>"

