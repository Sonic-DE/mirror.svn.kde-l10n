#. Tag: para
#: index.docbook:33
#, no-c-format
msgid ""
"&kwrite; is a text editor by &kde; allowing you to edit one file at the time "
"per window."
msgstr ""
"&kwrite; is een tekstbewerker door &kde; waarmee u per venster één bestand "
"tegelijk kunt bewerken."

#. Tag: keyword
#: index.docbook:37
#, no-c-format
msgid "<keyword>KDE</keyword>"
msgstr "<keyword>KDE</keyword>"

