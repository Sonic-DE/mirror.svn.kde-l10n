#~ msgid ""
#~ "To extend the standard scripting API with own functions and prototypes "
#~ "simply create a new file in the KDE's local configuration folder "
#~ "<filename>$KDEHOME/share/apps/katepart/libraries</filename> and include "
#~ "it into your script using:"
