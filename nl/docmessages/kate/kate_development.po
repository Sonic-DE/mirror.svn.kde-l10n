#~ msgid "&pate; Python Plugins"
#~ msgstr "&pate; Python-plug-ins"

#~ msgid ""
#~ "<link linkend=\"pate\">&pate; Plugins</link> also allow you to extend the "
#~ "functionality of &kate; in any way you like, using the Python programming "
#~ "language."
#~ msgstr ""
#~ "<link linkend=\"pate\">&pate; plug-ins</link> stellen u ook in staat om "
#~ "de functionaliteit van &kate; uit te breiden op elke manier die u wilt, "
