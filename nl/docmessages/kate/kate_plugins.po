msgstr "[textDocument/rename] Huidige symbool hernoemen."

#. Tag: menuchoice
#: plugins.docbook:2435
#, no-c-format
msgid "<guimenu>LSP Client</guimenu> <guisubmenu>Quick Fix</guisubmenu>"
msgstr ""
"<guimenu>LSP-client</guimenu> <guisubmenu>Snelle reparatie</guisubmenu>"

#. Tag: para
#: plugins.docbook:2440
#, no-c-format
msgid ""
"[textDocument/codeAction, workspace/executeCommand] Computes and applies a "
"quick fix for a diagnostic on current position (or line)."
msgstr ""
"[textDocument/codeAction, workspace/executeCommand] Berekent en past een "
"snelle reparatie toe voor een diagnose op de huidige positie (of regel)."

#. Tag: menuchoice
#: plugins.docbook:2446
#, no-c-format
msgid ""
"<guimenu>LSP Client</guimenu> <guisubmenu>Show selected completion "
"documentation</guisubmenu>"
msgstr ""
"<guimenu>LSP-client</guimenu> <guisubmenu>Geselecteerde voltooide "
"documentatie tonen</guisubmenu>"

#. Tag: para
#: plugins.docbook:2451
#, no-c-format
msgid "Show documentation for a selected item in the completion list."
msgstr ""
"Documentatie voor een geselecteerd item tonen in de lijst met voltooingen."

#. Tag: menuchoice
#: plugins.docbook:2456
#, no-c-format
msgid ""
"<guimenu>LSP Client</guimenu> <guisubmenu>Enable signature help with auto "
"completion</guisubmenu>"
msgstr ""
"<guimenu>LSP-client</guimenu> <guisubmenu>hulp bij handtekening met "
"automatische aanvulling inschakelen</guisubmenu>"

#. Tag: para
#: plugins.docbook:2461
#, no-c-format
