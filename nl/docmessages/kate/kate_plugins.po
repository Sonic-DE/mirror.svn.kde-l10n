msgid "&MIME; type"
msgstr "&MIME;-type"

#. Tag: entry
#: plugins.docbook:1115
#, no-c-format
msgid "&kparts; plugin"
msgstr "&kparts;-plug-in"

#. Tag: entry
#: plugins.docbook:1118
#, no-c-format
msgid "&Markdown; text"
msgstr "&Markdown;-tekst"

#. Tag: entry
#: plugins.docbook:1118
#, no-c-format
msgid "KMarkdownWebViewPart or OkularPart"
msgstr "KMarkdownWebViewPart of OkularPart"

#. Tag: entry
#: plugins.docbook:1121
#, no-c-format
msgid "&SVG; image"
msgstr "&SVG;-afbeelding"

#. Tag: entry
#: plugins.docbook:1121
#, no-c-format
msgid "SVGPart"
msgstr "SVGPart"

#. Tag: entry
#: plugins.docbook:1124
#, no-c-format
msgid "&Qt; UI files"
msgstr "&Qt; UI bestanden"

#. Tag: entry
#: plugins.docbook:1124
#, no-c-format
msgid "KUIViewerPart"
msgstr "KUIViewerPart"

#. Tag: entry
#: plugins.docbook:1127
#, no-c-format
msgid "&DOT; graph files"
msgstr "&DOT;-graph bestanden"

#. Tag: entry
#: plugins.docbook:1127
#, no-c-format
msgid "KGraphviewerPart"
msgstr "KGraphviewerPart"

#. Tag: menuchoice
#: plugins.docbook:1139
#, no-c-format
msgid ""
"<guimenu>View</guimenu><guisubmenu>Tool Views</guisubmenu> <guimenuitem>Show "
"Preview</guimenuitem>"
msgstr ""
"<guimenu>Beeld</guimenu> <guisubmenu>Hulpmiddelenweergaven</guisubmenu> "
"<guimenuitem>Voorbeeld tonen</guimenuitem>"

#. Tag: para
#: plugins.docbook:1144
#, no-c-format
msgid "Toggle the display of &kate;'s Document preview in a sidebar."
msgstr "Toont of verbergt het Documentvoorbeeld van &kate; in een zijbalk"

#. Tag: title
#: plugins.docbook:1151 plugins.docbook:1255 plugins.docbook:3094
#, no-c-format
msgid "Interface"
msgstr "Interface"

#. Tag: para
#: plugins.docbook:1152
#, no-c-format
msgid "The buttons at the top of the preview window provide these actions:"
msgstr "De knoppen bovenaan het voorbeeldvenster biedt deze acties:"

#. Tag: para
#: plugins.docbook:1156
#, no-c-format
msgid ""
"Lock the preview to a given document. Selecting this option ensures that if "
"switching the focus to the view of another document in the same &kate; "
"window, the preview will not follow to that document, but keep previewing "
"this document."
msgstr ""
"Het voorbeeld vergrendelen van een gegeven document. Deze optie selecteren "
"verzekert dat als de focus wordt omgeschakeld naar het beeld van een ander "
"document in hetzelfde &kate; venster, dat het voorbeeld niet volgt naar dat "
"document, maar het voorbeeld van dit document blijft tonen."

#. Tag: para
#: plugins.docbook:1162
#, no-c-format
msgid ""
"Enable or disable updates of the preview of the current document content"
msgstr ""
"Schakelt in of uit het bijwerken van het voorbeeld van de huidige inhoud van "
"het document"

#. Tag: para
#: plugins.docbook:1165
#, no-c-format
msgid "Manually update the preview of the current document content"
msgstr ""
"Werk handmatig het voorbeeld van de huidige inhoud van het document bij"

#. Tag: para
#: plugins.docbook:1168
#, no-c-format
msgid "A dropdown menu with actions from the &kparts; plugin"
msgstr "Een afrolmenu met acties uit de &kparts;-plug-in"

#. Tag: title
#: plugins.docbook:1177
#, no-c-format
msgid "Document Switcher Plugin"
msgstr "Plug-in voor document wisselen"

#. Tag: menuchoice
#: plugins.docbook:1185
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Tab;</keycombo> </shortcut> "
"<guimenu>View</guimenu> <guisubmenu>Last Used Views</guisubmenu>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Tab;</keycombo> </shortcut> "
"<guimenu>Beeld</guimenu> <guisubmenu>Laatst gebruikte weergaven</guisubmenu>"

#. Tag: menuchoice
#: plugins.docbook:1192
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;&Tab;</keycombo> </"
"shortcut> <guimenu>View</guimenu> <guisubmenu>Last Used Views (Reverse)</"
"guisubmenu>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;&Tab;</keycombo> </"
"shortcut> <guimenu>Beeld</guimenu> <guisubmenu>Laatst gebruikte weergaven "
"(omgekeerd)</guisubmenu>"

#. Tag: para
#: plugins.docbook:1201
#, no-c-format
msgid "<action>Opens</action> a list with the last viewed documents:"
msgstr "<action>Opent</action> een lijst met de laatst bekeken documenten:"

#. Tag: screeninfo
#: plugins.docbook:1204
#, no-c-format
msgid "Last viewed documents"
msgstr "Laatst bekeken documenten"

#. Tag: para
#: plugins.docbook:1210
#, no-c-format
msgid ""
"Keep the &Ctrl; key pressed and use the &Tab; key to cycle forward through "
"the list. Additionally press the &Shift; key to reverse the direction."
msgstr ""
"Houd de toets &Ctrl; ingedrukt en gebruik de toets &Tab; om voorwaarts door "
"de lijst te gaan. Druk ook de toets &Shift; in om de richting om te keren."

#. Tag: para
#: plugins.docbook:1214
#, no-c-format
msgid ""
"Keep the shortcut <keycombo action=\"simul\">&Ctrl;&Tab;</keycombo> pressed "
"and can use the &Up;, &Down;, &Home; or &End; keys to navigate in the list. "
"Pressing a char key consecutively will cycle through all items with the "
"first matching in the list. If you release the shortcut keys the view will "
"switch to the selected document in the list."
msgstr ""
"Houd de sneltoets <keycombo action=\"simul\">&Ctrl;&Tab;</keycombo> "
"ingedrukt en u kunt de toetsen &Up;, &Down;, &Home; of &End; gebruiken om in "
"de lijst te navigeren. Vervolgens drukken op een tekentoets zal u door alle "
"items laten lopen waarvan het eerste teken in the lijst overeenkomt. Als u "
"de sneltoetsen loslaat zal de weergave springen naar het geselecteerde "
"document in de lijst."

#. Tag: title
#: plugins.docbook:1232
#, no-c-format
msgid "File System Browser"
msgstr "Bestandssysteembrowser"

#. Tag: para
#: plugins.docbook:1234
#, no-c-format
msgid ""
"The File System Browser is a folder viewer, allowing you to open files from "
"a displayed folder in the current frame."
msgstr ""
"In de bestandssysteembrowser kunt u de inhoud van mappen bekijken en "
"bestanden uit een geopende map in het huidige frame openen."

#. Tag: menuchoice
#: plugins.docbook:1242
#, no-c-format
msgid ""
"<guimenu>View</guimenu><guisubmenu>Tool Views</guisubmenu> <guimenuitem>Show "
"Filesystem Browser</guimenuitem>"
msgstr ""
"<guimenu>Beeld</guimenu><guisubmenu>Hulpmiddelenweergaven</guisubmenu> "
"<guimenuitem>Bestandssysteembrowser tonen</guimenuitem>"

#. Tag: para
#: plugins.docbook:1247
#, no-c-format
msgid "Toggle the display of &kate;'s Filesystem Browser."
msgstr "Toont of verbergt de Bestandssysteembrowser van &kate;"

#. Tag: para
#: plugins.docbook:1257
#, no-c-format
msgid ""
"From the top down, the Filesystem Browser consists of the following elements:"
msgstr ""
"De Bestandssysteembrowser heeft, van boven naar beneden, de volgende "
"elementen:"

#. Tag: term
#: plugins.docbook:1262
#, no-c-format
msgid "A Toolbar"
msgstr "Een werkbalk"

#. Tag: para
#: plugins.docbook:1264
#, no-c-format
msgid "This contains standard navigations tool buttons:"
msgstr "Deze bevat de standaard navigatieknoppen:"

#. Tag: guiicon
#: plugins.docbook:1267
#, no-c-format
msgid "Back"
msgstr "Terug"

#. Tag: para
#: plugins.docbook:1268
#, no-c-format
msgid ""
"Causes the folder view to <command>cd</command> to the previously displayed "
"folder in the history. This button is disabled, if there is no previous item."
msgstr ""
"Wanneer u op deze knop klikt, wordt het commando <command>cd</command> naar "
"de vorige map in de geschiedenis uitgevoerd. Deze knop is niet beschikbaar "
"als er geen vorig item is."

#. Tag: guiicon
#: plugins.docbook:1272
#, no-c-format
msgid "Forward"
msgstr "Vooruit"

#. Tag: para
#: plugins.docbook:1273
#, no-c-format
msgid ""
"Causes the folder view to <command>cd</command> to the next folder in the "
"history. This button is disabled, if there is no next folder."
msgstr ""
"Wanneer u op deze knop klikt, wordt het commando <command>cd</command> naar "
"de volgende map in de geschiedenis uitgevoerd. Deze knop is niet beschikbaar "
"als er geen volgend item is."

#. Tag: guiicon
#: plugins.docbook:1282
#, no-c-format
msgid "Bookmarks"
msgstr "Bladwijzers"

#. Tag: para
#: plugins.docbook:1283
#, no-c-format
msgid ""
"Opens a submenu to edit or add bookmarks and to add a new bookmark folder."
msgstr ""
"Opent een submenu om bladwijzers te bewerken en toe te voegen en een nieuwe "
"map voor bladwijzers."

#. Tag: guiicon
#: plugins.docbook:1286
#, no-c-format
msgid "Current Document Folder"
msgstr "Map van huidig document"

#. Tag: para
#: plugins.docbook:1287
#, no-c-format
msgid ""
"This button will cause the folder view to <command>cd</command> to the "
"folder of the currently active document if possible. This button is "
"disabled, if the active document is a new, unsaved file, or the folder in "
"which it resides can not be decided."
msgstr ""
"Wanneer u op deze knop klikt, wordt het commando <command>cd</command> naar "
"de map waarin het huidige document zich bevindt (indien mogelijk) "
"uitgevoerd. Deze knop is niet beschikbaar als het document een nieuw, "
"onopgeslagen bestand is of als de map waarin het bestand zich bevindt niet "
"bepaald kan worden."

#. Tag: guiicon
#: plugins.docbook:1294
#, no-c-format
msgid "Options"
msgstr "Opties"

#. Tag: guimenuitem
#: plugins.docbook:1298
#, no-c-format
msgid "Short View"
msgstr "Beknopte weergave"

#. Tag: para
#: plugins.docbook:1299
#, no-c-format
msgid "Displays only the filenames."
msgstr "Alleen bestandsnamen tonen"

#. Tag: guimenuitem
#: plugins.docbook:1302
#, no-c-format
msgid "Detailed View"
msgstr "Gedetailleerde weergave"

#. Tag: para
#: plugins.docbook:1303
#, no-c-format
msgid ""
"Displays <guilabel>Name</guilabel>, <guilabel>Date</guilabel> and "
"<guilabel>Size</guilabel> of the files."
msgstr ""
"<guilabel>Naam</guilabel>, <guilabel>Datum</guilabel> en <guilabel>Grootte</"
"guilabel> van de bestanden tonen."

#. Tag: guimenuitem
#: plugins.docbook:1307
#, no-c-format
msgid "Tree View"
msgstr "Boomstructuurweergave"

#. Tag: para
#: plugins.docbook:1308
#, no-c-format
msgid "Like Short View, but folders can be expanded to view their contents."
msgstr ""
"Zoals Beknopte weergave, maar mappen kunnen worden uitgevouwen om hun inhoud "
"te bekijken."

#. Tag: guimenuitem
#: plugins.docbook:1311
#, no-c-format
msgid "Detailed Tree View"
msgstr "Gedetailleerde boomweergave"

#. Tag: para
#: plugins.docbook:1312
#, no-c-format
msgid ""
"This also allows folders to be expanded, but displays the additional columns "
"available in Detailed View."
msgstr ""
"Dit stelt u ook in staat om mappen uit te vouwen, maar toont extra kolommen "
"beschikbaar in Gedetailleerde weergave."

#. Tag: guimenuitem
#: plugins.docbook:1316
#, no-c-format
msgid "Show Hidden Files"
msgstr "Verborgen bestanden tonen"

#. Tag: para
#: plugins.docbook:1317
#, no-c-format
msgid "Displays files normally hidden by your &OS;."
msgstr "Toont bestanden die normaal verborgen zijn door uw &OS;."

#. Tag: guimenuitem
#: plugins.docbook:1320
#, no-c-format
msgid "Automatically synchronize with current document"
msgstr "Automatisch synchroniseren met huidig document"

#. Tag: para
#: plugins.docbook:1321
#, no-c-format
msgid ""
"When this option is enabled the filesystem browser will automatically "
"<command>cd</command> to the folder of the document currently open in the "
"editing area every time it changes."
msgstr ""
"Wanneer deze optie is ingeschakeld zal de bestandssysteembrowser automatisch "
"een <command>cd</command> uitvoeren naar de map van het document dat nu "
"geopend is in het bewerkingsgebied elke keer als het wijzigt."

#. Tag: term
#: plugins.docbook:1332
#, no-c-format
msgid "A Location Entry"
msgstr "Een locatie-item"

#. Tag: para
#: plugins.docbook:1334
#, no-c-format
msgid ""
"This displays a breadcrumb navigation to the currently open folder, "
"similarly to &dolphin;. You can click on a any folder to browse to it, or "
"click on one of the arrows to the left of a folder to select any folders "
"beneath it. You may also select from your list of Places by clicking the "
"leftmost icon in the breadcrumb navigation, which displays an icon that "
"represents your current Place."
msgstr ""
"Dit toont een broodkruimelnavigatie naar de huidige geopende map, zoals in "
"&dolphin;. U kunt op elke map klikken om het door te bladeren of klik op een "
"van de pijlen, links van de map, om een onderliggende map te selecteren. U "
"kunt ook uit Plaatsen kiezen door op het meest linkse pictogram in de "
"broodkruimelnavigatie te klikken, die een pictogram toont die uw huidige "
"Plaats toont."

#. Tag: para
#: plugins.docbook:1340
#, no-c-format
msgid ""
"You can also click to the right of the breadcrumbs to change them to a text "
"box where you can type the path of a folder to browse. The &URL; entry "
"maintains a list of previously typed paths. To choose one, use the arrow "
"button to the right of the entry."
msgstr ""
"U kunt ook rechts van de broodkruimels klikken on ze te wijzigen waar u het "
"pad naar een map, die u wilt zien, kunt intypen. Het &URL;-invoerveld houdt "
"een lijst bij van eerder ingetypte paden. Klik op de pijlknop rechts van het "
"invoerveld om een pad te kiezen."

#. Tag: para
#: plugins.docbook:1344
#, no-c-format
msgid ""
"The &URL; entry has folder auto-completion. The completion method can be set "
"using the &RMB; menu of the text entry."
msgstr ""
"Het &URL;-invoerveld maakt gebruik van automatische aanvulling. De methode "
"kan ingesteld worden in het contextmenu dat verschijnt wanneer u met de "
"&RMB; op de tekst klikt."

#. Tag: term
#: plugins.docbook:1351
#, no-c-format
msgid "A Folder View"
msgstr "Een mapweergave"

#. Tag: para
#: plugins.docbook:1352
#, no-c-format
msgid "This is a standard &kde; folder view."
msgstr "Dit is een standaard mapweergave van &kde;."

#. Tag: term
#: plugins.docbook:1356
#, no-c-format
msgid "A Filter Entry"
msgstr "Een filterinvoerveld"

#. Tag: para
#: plugins.docbook:1358
#, no-c-format
msgid ""
"The Filter entry allows you to enter a filter for the files displayed in the "
"folder view. The filter uses standard globs; patterns must be separated by "
"white space. Example: <userinput>*.cpp *.h *.moc</userinput>"
msgstr ""
"In het filterinvoerveld kunt u het filter voor de bestanden die u wilt zien "
"intypen. Het filter gebruikt de standaard jokertekens; items moeten worden "
"gescheiden door een spatie. Voorbeeld: <userinput>*.cpp *.h *.moc</userinput>"

#. Tag: para
#: plugins.docbook:1362
#, no-c-format
msgid "To display all files, enter a single asterisk <userinput>*</userinput>."
msgstr ""
"Om alle bestanden te kunnen zien, typt u een enkele asterisk <userinput>*</"
"userinput> in."

#. Tag: para
#: plugins.docbook:1364
#, no-c-format
msgid ""
"The filter entry saves the last 10 filters entered between sessions. To use "
"one, press the arrow button on the right of the entry and select the desired "
"filter string. You can disable the filter by pressing the <guibutton>Clear "
"text</guibutton> button to the left of the autocompletion arrow button."
msgstr ""
"Het filterinvoerveld houdt een lijst bij van de laatste tien filters. Klik "
"op de pijlknop rechts van het invoerveld om het gewenste filter te kiezen. U "
"kunt het filter uitschakelen door op de knop <guibutton>Tekst wissen</"
"guibutton> te klikken links van de pijlknop voor automatisch aanvullen."

#. Tag: para
#: plugins.docbook:1379
#, no-c-format
msgid ""
"This plugin can be configured on the <guilabel>Filesystem Browser</guilabel> "
"page of <link linkend=\"configuring-kate-configdialog\">&kate;'s "
"configuration</link>."
msgstr ""
"Deze plugin kan worden geconfigureerd op de pagina "
"<guilabel>Bestandssysteembrowser</guilabel> van <link linkend=\"configuring-"
"kate-configdialog\">instellingen van &kate;</link>."

#. Tag: guilabel
#: plugins.docbook:1384
#, no-c-format
msgid "Toolbar"
msgstr "Werkbalk"

#. Tag: para
#: plugins.docbook:1385
#, no-c-format
msgid ""
"Configure the buttons on the Filesystem Browser toolbar by moving the ones "
"you want enabled to the <guilabel>Selected Actions</guilabel> list, and "
"order them using the arrow buttons at the side of the list."
msgstr ""
"Stel deze knoppen in op de werkbalk van de Bestandssysteembrowser door "
"diegene, die u wil inschakelen, te verplaatsen naar de lijst "
"<guilabel>Geselecteerde acties</guilabel> en sorteer ze met de pijlknoppen "
"naast de lijst."

#. Tag: title
#: plugins.docbook:1396
#, no-c-format
msgid "The Documents List"
msgstr "De documentenlijst"

#. Tag: primary
#: plugins.docbook:1401
#, no-c-format
msgid "Documents list"
msgstr "Documentenlijst"

#. Tag: para
#: plugins.docbook:1401
#, no-c-format
msgid ""
"The documents list displays a list of all documents currently open in "
"&kate;. Modified files will have a small <guiicon>floppy disk</guiicon> icon "
"on their left to indicate that state."
msgstr ""
"De documentenlijst toont een lijst met alle bestanden die momenteel in "
"&kate; geopend zijn. Gewijzigde bestanden worden gemarkeerd met een "
"<guiicon>diskette</guiicon>-pictogram links van de naam om de status aan te "
"geven."

#. Tag: para
#: plugins.docbook:1406
#, no-c-format
msgid "On the top the Documents list has a toolbar with the following buttons:"
msgstr ""
"Bovenaan deze lijst met documenten is een werkbalk met de volgende knoppen:"

#. Tag: member
#: plugins.docbook:1409
#, no-c-format
msgid ""
"<guiicon><inlinemediaobject><imageobject><imagedata fileref=\"document-"
"new-22.png\" format=\"PNG\"/></imageobject></inlinemediaobject></guiicon> "
"Create new document"
msgstr ""
"<guiicon><inlinemediaobject><imageobject><imagedata fileref=\"document-"
"new-22.png\" format=\"PNG\"/></imageobject></inlinemediaobject></guiicon> "
"Nieuw document aanmaken"

#. Tag: member
#: plugins.docbook:1412
#, no-c-format
msgid ""
"<guiicon><inlinemediaobject><imageobject><imagedata fileref=\"document-"
"open-22.png\" format=\"PNG\"/></imageobject></inlinemediaobject></guiicon> "
"Open an existing document"
msgstr ""
"<guiicon><inlinemediaobject><imageobject><imagedata fileref=\"document-"
"open-22.png\" format=\"PNG\"/></imageobject></inlinemediaobject></guiicon> "
"Open een bestaand document"

#. Tag: member
#: plugins.docbook:1415
#, no-c-format
msgid ""
"<guiicon><inlinemediaobject><imageobject><imagedata fileref=\"go-up-22.png\" "
"format=\"PNG\"/></imageobject></inlinemediaobject></guiicon> Previous "
"Document"
msgstr ""
"<guiicon><inlinemediaobject><imageobject><imagedata fileref=\"go-up-22.png\" "
"format=\"PNG\"/></imageobject></inlinemediaobject></guiicon> Vorig document"

#. Tag: member
#: plugins.docbook:1418
#, no-c-format
msgid ""
"<guiicon><inlinemediaobject><imageobject><imagedata fileref=\"go-down-22.png"
"\" format=\"PNG\"/></imageobject></inlinemediaobject></guiicon> Next Document"
msgstr ""
"<guiicon><inlinemediaobject><imageobject><imagedata fileref=\"go-down-22.png"
"\" format=\"PNG\"/></imageobject></inlinemediaobject></guiicon> Volgend "
"document"

#. Tag: member
#: plugins.docbook:1421
#, no-c-format
msgid ""
"<guiicon><inlinemediaobject><imageobject><imagedata fileref=\"document-"
"save-22.png\" format=\"PNG\"/></imageobject></inlinemediaobject></guiicon> "
"Save the current document"
msgstr ""
"<guiicon><inlinemediaobject><imageobject><imagedata fileref=\"document-"
"save-22.png\" format=\"PNG\"/></imageobject></inlinemediaobject></guiicon> "
"Het huidige document opslaan"

#. Tag: member
#: plugins.docbook:1424
#, no-c-format
msgid ""
"<guiicon><inlinemediaobject><imageobject><imagedata fileref=\"document-save-"
"as-22.png\" format=\"PNG\"/></imageobject></inlinemediaobject></guiicon> "
"Save the current document under a new name"
msgstr ""
"<guiicon><inlinemediaobject><imageobject><imagedata fileref=\"document-save-"
"as-22.png\" format=\"PNG\"/></imageobject></inlinemediaobject></guiicon> Sla "
"het huidige document op onder een nieuwe naam"

#. Tag: para
#: plugins.docbook:1429
#, no-c-format
msgid ""
"By default, the Documents list appears in <guimenuitem>Tree Mode</"
"guimenuitem>, which displays the folder structure surrounding all currently "
"open documents. Also available is <guimenuitem>List Mode</guimenuitem>, "
"which displays a simple list of all open documents. You can switch modes by "
"right-clicking on the list and selecting from the <guisubmenu>View Mode</"
"guisubmenu> menu."
msgstr ""
"Standaard wordt de documentenlijst in <guimenuitem>Boomstructuurmodus</"
"guimenuitem> getoond, die de mappenstructuur rond alle nu geopende "
"documenten toont. Ook is de <guimenuitem>Lijstmodus</guimenuitem> "
"beschikbaar, die een eenvoudige lijst met alle open documenten toont. U kunt "
"van modus wisselen door rechts te klikken op de lijst en een keuze te maken "
"uit het menu <guisubmenu>Weergavemodus</guisubmenu> menu."

#. Tag: para
#: plugins.docbook:1436
#, no-c-format
msgid ""
"If two or more files with the same name (located in different folders) are "
"open in <guimenuitem>List Mode</guimenuitem>, the names of the second will "
"be prepended <quote>(2)</quote> and so on. The tool-tip for the file will "
"display its full name including the path, allowing you to choose the desired "
"one."
msgstr ""
"Als er twee of meer bestanden met dezelfde naam (in verschillende mappen) "
"geopend zijn in <guimenuitem>Modus Lijst</guimenuitem>, wordt de naam van "
"het tweede bestand aangeduid met <quote>(2)</quote>, enzovoort. In de "
"tekstballon wordt de volledige naam met het pad vermeld, zodat u het "
"gewenste bestand kunt vinden."

#. Tag: para
#: plugins.docbook:1440
#, no-c-format
msgid ""
"To display a document in the currently active frame, click the document name "
"in the list."
msgstr ""
"Om een document in het momenteel actieve frame weer te geven, klikt u op de "
"naam in de bestandenlijst."

#. Tag: para
#: plugins.docbook:1443
#, no-c-format
msgid ""
"The context menu has some common actions from the <guimenu>File</guimenu> "
"menu."
msgstr ""
"Het contextmenu heeft enige gemeenschappelijke acties uit het menu "
"<guimenu>Bestand</guimenu>."

#. Tag: para
#: plugins.docbook:1445
#, no-c-format
msgid ""
"Additionally there are filemanager actions to rename or delete the file. "
"With <guimenuitem>Copy Location</guimenuitem> you can copy the full path of "
"the document to the clipboard."
msgstr ""
"Daarnaast zijn er bestandsbeheerderacties om het bestand te hernoemen of te "
"verwijderen. Met <guimenuitem>Locatie kopiëren</guimenuitem> kunt u het "
"volledige pad van het document naar het klembord kopiëren."

#. Tag: para
#: plugins.docbook:1449
#, no-c-format
msgid ""
"You can sort the list in a few different ways by right clicking the list and "
"selecting from the <guisubmenu>Sort By</guisubmenu> menu. The options are:"
msgstr ""
"U kunt de lijst op verschillende manieren sorteren door in de lijst rechts "
"te klikken en <guisubmenu>Sorteren op</guisubmenu> in het contextmenu te "
"kiezen. U kunt kiezen uit de volgende opties:"

#. Tag: guimenuitem
#: plugins.docbook:1456
#, no-c-format
msgid "Document Name"
msgstr "Documentnaam"

#. Tag: para
#: plugins.docbook:1457
#, no-c-format
msgid "Lists the documents alphabetically by their name."
msgstr "Sorteert de documenten alfabetisch op naam"

#. Tag: guimenuitem
#: plugins.docbook:1461
#, no-c-format
msgid "Document Path"
msgstr "Documentenpad"

#. Tag: para
#: plugins.docbook:1462
#, no-c-format
msgid "Lists the documents alphabetically by the path to them."
msgstr "Sorteert de documenten alfabetisch op het pad ernaar."

#. Tag: guimenuitem
#: plugins.docbook:1466
#, no-c-format
msgid "Opening Order"
msgstr "Volgorde van openen"

#. Tag: para
#: plugins.docbook:1467
#, no-c-format
msgid "Lists the documents in the order of opening."
msgstr "Sorteert de documenten in de volgorde waarin ze geopend zijn."

#. Tag: para
#: plugins.docbook:1474
#, no-c-format
msgid ""
"The document list will per default visualize your history by shading the "
"entries for the most recent documents with a background color. If the "
"document was edited, an extra color is blended in. The most recent document "
"has the strongest color, so that you can easily find the documents you are "
"working on. This feature can be disabled in the <link linkend=\"config-"
"dialog-documents\">Documents</link> page of the configuration dialog."
msgstr ""
"De documentenlijst zal standaard de geschiedenis bijhouden door de bestanden "
"die het laatst geopend zijn een achtergrondkleur te geven. Als het document "
"bewerkt is, wordt er een extra kleur aan toegevoegd. Het document dat het "
"laatst geopend is heeft de sterkste achtergrondkleur, zodat u gemakkelijk de "
"documenten waar u aan werkt kun vinden. Deze functie kan uitgeschakeld "
"worden door<link linkend=\"config-dialog-documents\">Documenten</link> in "
"het dialoogvenster \"Instellingen\"."

#. Tag: para
#: plugins.docbook:1481
#, no-c-format
msgid ""
"The default location of the document list in the &kate; window is to the "
"left of the editing area."
msgstr ""
"De standaardlocatie van de documentenlijst in het venster van &kate; is "
"links van het bewerker-gedeelte."

#. Tag: menuchoice
#: plugins.docbook:1492
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Up;</keycombo> </shortcut> "
"<guimenu>View</guimenu> <guimenuitem>Previous Document</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Alt;&Up;</keycombo> </shortcut> "
"<guimenu>Beeld</guimenu> <guimenuitem>Vorig document</guimenuitem>"

#. Tag: para
#: plugins.docbook:1500
#, no-c-format
msgid ""
"Opens the document displayed above the currently open document in the "
"Documents list."
msgstr ""
"Opent het document getoond boven het huidige geopende document in de "
"Documentenlijst."

#. Tag: menuchoice
#: plugins.docbook:1505
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Down;</keycombo> </shortcut> "
"<guimenu>View</guimenu> <guimenuitem>Next Document</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Alt;&Up;</keycombo> </shortcut> "
"<guimenu>Beeld</guimenu> <guimenuitem>Volgend document</guimenuitem>"

#. Tag: para
#: plugins.docbook:1513
#, no-c-format
msgid ""
"Opens the document displayed below the currently open document in the "
"Documents list."
msgstr ""
"Opent het document getoond onder het huidige geopende document in de "
"Documentenlijst."

#. Tag: menuchoice
#: plugins.docbook:1518
#, no-c-format
msgid "<guimenu>View</guimenu> <guimenuitem>Show Active</guimenuitem>"
msgstr "<guimenu>Beeld</guimenu> <guimenuitem>Actieve tonen</guimenuitem>"

#. Tag: para
#: plugins.docbook:1523
#, no-c-format
msgid "Displays the currently open document in the Documents list."
msgstr "Toont het huidige geopende document in de Documentenlijst."

#. Tag: guilabel
#: plugins.docbook:1536
#, no-c-format
msgid "Background Shading"
msgstr "Achtergrondschaduw"

#. Tag: para
#: plugins.docbook:1537
#, no-c-format
msgid ""
"This section allows you to enable or disable the background shading "
"visualization of your recent activity, and choose which colors to use if "
"enabled."
msgstr ""
"Deze sectie stelt u in staat om de visualisatie van de achtergrondschaduwvan "
"uw recente activiteit in of uit te schakelen en te kiezen welke kleuren te "
"gebruiken indien ingeschakeld."

#. Tag: guilabel
#: plugins.docbook:1543
#, no-c-format
msgid "Sort By"
msgstr "Sorteren op"

#. Tag: para
#: plugins.docbook:1544
#, no-c-format
msgid ""
"Set how you want the document list sorted. This can be set from the &RMB; "
"menu in the document list as well."
msgstr ""
"Stelt in hoe u de lijst met documenten wilt hebben gesorteerd. Dit kan ook "
"gezet worden met het &RMB; menu in de lijst met documenten."

#. Tag: guilabel
#: plugins.docbook:1549
#, no-c-format
msgid "View Mode"
msgstr "Weergavemodus"

#. Tag: para
#: plugins.docbook:1550
#, no-c-format
msgid ""
"This provides two options that effect the display of the Documents tool "
"view. The <guilabel>Tree View</guilabel> option will display the documents "
"in a tree underneath the folders they are in, while the <guilabel>List View</"
"guilabel> option will display a flat list of documents."
msgstr ""
"Dit biedt twee opties die invloed hebben op de weergave van het hulpmiddel "
"voor documenten. De optie <guilabel>Boomstructuurweergave</guilabel> zal de "
"documenten tonen in een boomstructuur onder de mappen waarin ze zich "
"bevinden, terwijl de optie <guilabel>Lijstweergave</guilabel> een vlakke "
"lijst met documenten laat zien."

#. Tag: guilabel
#: plugins.docbook:1558
#, no-c-format
msgid "Show Full Path"
msgstr "Volledig pad tonen"

#. Tag: para
#: plugins.docbook:1559
#, no-c-format
msgid ""
"When Tree View and this option are enabled, the folder entries displayed in "
"the Documents tool view will display the full filesystem path to the folder "
"in addition to the name of the folder. It has no effect in List View."
msgstr ""
"Wanneer Boomstructuurweergave en deze optie zijn ingeschakeld, zullen de "
"mappen in het hulpmiddel voor documentweergave getoond worden met het "
"volledige pad in het bestandssysteem naar de map naast de naam van de map. "
"Het heeft geen effect in de Lijstweergave."

#. Tag: guilabel
#: plugins.docbook:1566
#, no-c-format
msgid "Show Toolbar"
msgstr "Werkbalk tonen"

#. Tag: para
#: plugins.docbook:1567
#, no-c-format
msgid ""
"When Tree View and this option are enabled, a toolbar with actions like "
"<guibutton>Save</guibutton> is displayed above the list of documents. "
"Uncheck this option if the toolbar should be hidden."
msgstr ""
"Wanneer broomstructuurweergave en deze optie zijn ingeschakeld zal een "
"werkbalk getoond worden met acties zoals <guibutton>Opslaan</guibutton> "
"boven de lijst met documenten. Deze optie deactiveren, als de werkbalk "
"verborgen moet zijn."

#. Tag: guilabel
#: plugins.docbook:1574
#, no-c-format
msgid "Show Close Button"
msgstr "Sluitknop tonen"

#. Tag: para
#: plugins.docbook:1575
#, no-c-format
msgid ""
"When this option is enabled, &kate; will show a close button for opened "
"documents on hover."
msgstr ""
"Wanneer deze optie ingeschakeld is, zal &kate; een sluitknop voor geopende "
"documenten bij erboven zweven tonen."

#. Tag: author
#: plugins.docbook:1589 plugins.docbook:3424
#, no-c-format
msgid "<firstname>Martin</firstname> <surname>Gergov</surname>"
msgstr "<firstname>Martin</firstname> <surname>Gergov</surname>"

#. Tag: title
#: plugins.docbook:1593
#, no-c-format
msgid "&gdb; Plugin"
msgstr "&gdb;-plug-in"

#. Tag: para
#: plugins.docbook:1598
#, no-c-format
msgid ""
"&kate;'s &gdb; plugin provides a simple frontend to any debugger that "
"supports the <ulink url=\"https://microsoft.github.io/debug-adapter-protocol/"
"\">Debugger Adapter Protocol</ulink>. In particular, that includes the GNU "
"Project Debugger, aka GDB, as <ulink url=\"https://sourceware.org/gdb/"
"current/onlinedocs/gdb.html/Debugger-Adapter-Protocol.html\">outlined here</"
"ulink>."
msgstr ""
"De &gdb;-plug-in van &kate; levert een eenvoudige frontend voor elke "
"debugger die het <ulink url=\"https://microsoft.github.io/debug-adapter-"
"protocol/\">Debugger Adapter Protocol</ulink> ondersteunt. Speciaal, die de "
"GNU Project Debugger omvat, aka GDB, als <ulink url=\"https://sourceware.org/"
"gdb/current/onlinedocs/gdb.html/Debugger-Adapter-Protocol.html\">hier "
"aangegeven</ulink>."

#. Tag: para
#: plugins.docbook:1606
#, no-c-format
msgid ""
"Previous experience with &gdb; is strongly recommended. For more information "
"on using &gdb;, visit <ulink url=\"https://www.gnu.org/software/gdb/\">the "
"&gdb; website</ulink>."
msgstr ""
"Eerdere ervaring met &gdb; is zeer aanbevolen. Voor meer informatie over het "
"gebruik van &gdb; bezoekt u <ulink url=\"https://www.gnu.org/software/gdb/"
"\">de website van &gdb;</ulink>."

#. Tag: para
#: plugins.docbook:1611
#, no-c-format
msgid ""
"You can enable the &gdb; plugin in <link linkend=\"config-dialog-plugins"
"\">the Plugins section of &kate;'s configuration</link>."
msgstr ""
"U kunt de &gdb;-plug-in inschakelen in <link linkend=\"config-dialog-plugins"
"\">de sectie met plug-ins in de instellingen van &kate;</link>."

#. Tag: para
#: plugins.docbook:1616
#, no-c-format
msgid ""
"If you compile using &gcc;/<command>g++</command> you might want to use the "
"<command><parameter>-ggdb</parameter></command> command line argument."
msgstr ""
"Als u compileert met &gcc;/<command>g++</command> dan zou u het argument op "
"de opdrachtregel <command><parameter>-ggdb</parameter></command> willen "
"gebruiken."

#. Tag: para
#: plugins.docbook:1621
#, no-c-format
msgid ""
"After these preparations are made, open the source file in &kate;, select "
"the \"debugger profile\", enter the path to the executable in the "
"<guilabel>Settings</guilabel> tab of the <guilabel>Debug View</guilabel> "
"tool view, and select <menuchoice><guimenu>Debug</guimenu><guimenuitem>Start "
"Debugging</guimenuitem></menuchoice> from the menu to get started."
msgstr ""
"Nadat deze voorbereidingen zijn gedaan, opent u het bestand met de broncode "
"in &kate;, selecteer het \"debuggerprofiel\", voer het pad naar het "
"uitvoerbare programma in in het tabblad <guilabel>Instellingen</guilabel> "
"van de hulpmiddelenweergave <guilabel>Debugweergave</guilabel> en selecteert "
"u <menuchoice><guimenu>Debug</guimenu><guimenuitem>Debugging starten</"
"guimenuitem></menuchoice> uit het menu om te beginnen."

#. Tag: para
#: plugins.docbook:1628
#, no-c-format
msgid ""
"The \"debugger profile\" selects the DAP server to use (e.g. GDB) and the "
"way in which to launch this server. A typical case is to have the server "
"launch a process as specified above, but it may also attach to a running "
"process (in which case a PID will have to be specified rather than an "
"executable). There may also be other modes which are specific to the "
"language and DAP server. See also later for additional background and "
"configuration details on this."
msgstr ""
"Het \"debuggerprofiel\" selecteert de te gebruiken DAP-server (bijv. GDB) en "
"de manier waarop deze server te starten. Een typisch geval is om de server "
"een proces te laten starten zoals boven gespecificeerd, maar het kan ook "
"aankoppelen aan een actief proces (in welk geval een PID gespecificeerd moet "
"worden in plaats van een uitvoerbaar programma). Er kunnen ook andere modi "
"zijn die specifiek zijn voor de taal en de DAP-server. Zie ook later voor "
"extra achtergrond en configuratiedetails hierover."

#. Tag: title
#: plugins.docbook:1640
#, no-c-format
msgid "Menu and Toolbar Structure"
msgstr "Structuur van menu en werkbalk"

#. Tag: para
#: plugins.docbook:1642
#, no-c-format
msgid ""
"All of these options are available in &kate;'s menus, and many are available "
"on the Debug toolbar as well."
msgstr ""
"Al deze opties zijn beschikbaar in de menu's van &kate; en er zijn er ook "
"veel beschikbaar op de werkbalk Debug."

#. Tag: menuchoice
#: plugins.docbook:1648
#, no-c-format
msgid ""
"<guimenu>View</guimenu><guisubmenu>Tool View</guisubmenu><guimenuitem>Show "
"Debug View</guimenuitem>"
msgstr ""
"<guimenu>Beeld</guimenu><guisubmenu>Hulpmiddelenweergaven</"
"guisubmenu><guimenuitem>Debugweergave tonen</guimenuitem>"

#. Tag: para
#: plugins.docbook:1651
#, no-c-format
msgid ""
"Shows a tool view containing &gdb; output, the &gdb; command line used, and "
"other settings."
msgstr ""
"Toont een hulpmiddelenweergave met &gdb;-uitvoer, de gebruikte opdrachtregel "
"van &gdb; en andere instellingen."

#. Tag: menuchoice
#: plugins.docbook:1656
#, no-c-format
msgid ""
"<guimenu>View</guimenu><guisubmenu>Tool View</guisubmenu><guimenuitem>Show "
"Locals and Stack</guimenuitem>"
msgstr ""
"<guimenu>Beeld</guimenu> <guisubmenu>Hulpmiddelenweergave</guisubmenu> "
"<guimenuitem>Localen en stack tonen</guimenuitem>"

#. Tag: para
#: plugins.docbook:1659
#, no-c-format
msgid ""
"Shows a list of all currently loaded variables and their values and a &gdb; "
"backtrace."
msgstr ""
"Toont een lijst met alle nu geladen variabelen en hun waarden en een &gdb; "
"backtrace."

#. Tag: menuchoice
#: plugins.docbook:1664
#, no-c-format
msgid "<guimenu>Debug</guimenu><guisubmenu>Targets</guisubmenu>"
msgstr "<guimenu>Debug</guimenu><guisubmenu>Doelen</guisubmenu>"

#. Tag: para
#: plugins.docbook:1667
#, no-c-format
msgid "A submenu containing a list of targets (executables)."
msgstr "Een submenu die een lijst met doelen bevat (uitvoerbare programma's)."

#. Tag: menuchoice
#: plugins.docbook:1672
#, no-c-format
msgid "<guimenu>Debug</guimenu><guimenuitem>Start Debugging</guimenuitem>"
msgstr ""
"<guimenu>Debug</guimenu><guimenuitem>Met debuggen beginnen</guimenuitem>"

#. Tag: para
#: plugins.docbook:1675
#, no-c-format
msgid "Starts &gdb; with a target."
msgstr "Start &gdb; met een doel."

#. Tag: menuchoice
#: plugins.docbook:1679
#, no-c-format
msgid ""
"<guimenu>Debug</guimenu><guimenuitem>Kill / Stop Debugging</guimenuitem>"
msgstr ""
"<guimenu>Debug</guimenu><guimenuitem>Afbreken / Stoppen van debugging</"
"guimenuitem>"

#. Tag: para
#: plugins.docbook:1682
#, no-c-format
msgid "Stops &gdb;."
msgstr "Stopt &gdb;."

#. Tag: menuchoice
#: plugins.docbook:1686
#, no-c-format
msgid "<guimenu>Debug</guimenu><guimenuitem>Restart Debugging</guimenuitem>"
msgstr ""
"<guimenu>Debug</guimenu><guimenuitem>Debugging opnieuw starten</guimenuitem>"

#. Tag: para
#: plugins.docbook:1689
#, no-c-format
msgid "Restarts &gdb;."
msgstr "Start &gdb; opnieuw."

#. Tag: menuchoice
#: plugins.docbook:1693
#, no-c-format
msgid ""
"<guimenu>Debug</guimenu><guimenuitem>Toggle Breakpoint / Break</guimenuitem>"
msgstr ""
"<guimenu>Debug</guimenu><guimenuitem>Breekpunt omschakelen</guimenuitem>"

#. Tag: para
#: plugins.docbook:1696
#, no-c-format
msgid "Set a breakpoint at the current cursor position."
msgstr "Een breekpunt op de huidige cursorpositie instellen."

#. Tag: menuchoice
#: plugins.docbook:1701
#, no-c-format
msgid "<guimenu>Debug</guimenu><guimenuitem>Step In</guimenuitem>"
msgstr "<guimenu>Debug</guimenu><guimenuitem>Instappen</guimenuitem>"

#. Tag: para
#: plugins.docbook:1704
#, no-c-format
msgid "Execute the present statement (function call will be debugged)."
msgstr "Het huidige statement uitvoeren (functie-aanroep zal worden gedebugd)."

#. Tag: menuchoice
#: plugins.docbook:1709
#, no-c-format
msgid "<guimenu>Debug</guimenu><guimenuitem>Step Over</guimenuitem>"
msgstr "<guimenu>Debug</guimenu><guimenuitem>Overslaan</guimenuitem>"

#. Tag: para
#: plugins.docbook:1712
#, no-c-format
msgid "Execute the present statement (function call will not be debugged)."
msgstr ""
"Het huidige statement uitvoeren (functie-aanroep zal niet worden gedebugd)."

#. Tag: menuchoice
#: plugins.docbook:1717
#, no-c-format
msgid "<guimenu>Debug</guimenu><guimenuitem>Step Out</guimenuitem>"
msgstr "<guimenu>Debug</guimenu><guimenuitem>Uitstappen</guimenuitem>"

#. Tag: para
#: plugins.docbook:1720
#, no-c-format
msgid "Resumes execution until the program that is executing terminates."
msgstr "Uitvoering hernemen totdat het programma in uitvoering zich beëindigd."

#. Tag: menuchoice
#: plugins.docbook:1725
#, no-c-format
msgid "<guimenu>Debug</guimenu><guimenuitem>Move PC</guimenuitem>"
msgstr "<guimenu>Debug</guimenu><guimenuitem>PC verplaatsen</guimenuitem>"

#. Tag: para
#: plugins.docbook:1728
#, no-c-format
msgid "Move program counter (next execution)."
msgstr "Programcounter (PC) verplaatsen (volgende uitvoeren)."

#. Tag: menuchoice
#: plugins.docbook:1732
#, no-c-format
msgid "<guimenu>Debug</guimenu><guimenuitem>Run To Cursor</guimenuitem>"
msgstr ""
"<guimenu>Debug</guimenu><guimenuitem>Uitvoeren tot de cursor</guimenuitem>"

#. Tag: para
#: plugins.docbook:1735
#, no-c-format
msgid "Runs the program until it reaches current cursor position."
msgstr "Voert het programma uit totdat het de huidige cursorpositie bereikt."

#. Tag: menuchoice
#: plugins.docbook:1740
#, no-c-format
msgid "<guimenu>Debug</guimenu><guimenuitem>Continue</guimenuitem>"
msgstr "<guimenu>Debug</guimenu><guimenuitem>Doorgaan</guimenuitem>"

#. Tag: para
#: plugins.docbook:1743
#, no-c-format
msgid ""
"Ignores any breakpoints and executes program until it terminates "
"(successfully or not)."
msgstr ""
"Negeert elk breekpunt en voert het programma uit totdat het zich beëindigd "
"(al of niet met succes)."

#. Tag: menuchoice
#: plugins.docbook:1748
#, no-c-format
msgid "<guimenu>Debug</guimenu><guimenuitem>Print Value</guimenuitem>"
msgstr "<guimenu>Debug</guimenu><guimenuitem>Waarde afdrukken</guimenuitem>"

#. Tag: para
#: plugins.docbook:1751
#, no-c-format
msgid ""
"Prints the value of the variable that the cursor is currently pointing to."
msgstr "Drukt de waarde van de variabele af waar de cursor nu naar wijst."

#. Tag: menuchoice
#: plugins.docbook:1756
#, no-c-format
msgid ""
"<guimenu>Settings</guimenu><guisubmenu>Toolbars Shown</"
"guisubmenu><guimenuitem>&gdb; Plugin</guimenuitem>"
msgstr ""
"<guimenu>Instellingen</guimenu><guisubmenu>Getoonde werkbalken</"
"guisubmenu><guimenuitem>&gdb;-plug-in</guimenuitem>"

#. Tag: para
#: plugins.docbook:1759
#, no-c-format
msgid "Display the debugging toolbar."
msgstr "De debug-werkbalk tonen."

#. Tag: title
#: plugins.docbook:1767
#, no-c-format
msgid "Debug View"
msgstr "Debugweergave"

#. Tag: para
#: plugins.docbook:1769
#, no-c-format
msgid "The <guilabel>Debug View</guilabel> tool view consists of several tabs:"
msgstr ""
"Het hulpmiddel <guilabel>Debugweergave</guilabel> heeft een aantal tabbladen:"

#. Tag: guilabel
#: plugins.docbook:1775
#, no-c-format
msgid "&gdb; Output"
msgstr "&gdb;-uitvoer"

#. Tag: para
#: plugins.docbook:1777
#, no-c-format
msgid "Contains output from &gdb; and a &gdb; command line."
msgstr "Bevat uitvoer van &gdb; en een &gdb;-commandoregel."

#. Tag: screeninfo
#: plugins.docbook:1780
#, no-c-format
msgid "The Output Tab"
msgstr "Het tabblad Uitvoer"

#. Tag: phrase
#: plugins.docbook:1783
#, no-c-format
msgid "The Output tab."
msgstr "Het tabblad Uitvoer."

#. Tag: para
#: plugins.docbook:1784
#, no-c-format
msgid ""
"The <guilabel>Output</guilabel> tab displaying the output from a debugging "
"session."
msgstr ""
"Het tabblad <guilabel>Uitvoer</guilabel> toont de uitvoer van een debug-"
"sessie."

#. Tag: guilabel
#: plugins.docbook:1793
#, no-c-format
msgid "Settings"
msgstr "Instellingen"

#. Tag: guilabel
#: plugins.docbook:1798
#, no-c-format
msgid "Executable"
msgstr "Uitvoerbaar programma"

#. Tag: para
#: plugins.docbook:1799
#, no-c-format
msgid "Path to the target (executable) for debugging."
msgstr "Pad naar het doel (uitvoerbaar programma) voor debugging."

#. Tag: para
#: plugins.docbook:1804
#, no-c-format
msgid "The current working directory provided to the target."
msgstr "De huidige werkmap geleverd aan het doel."

#. Tag: guilabel
#: plugins.docbook:1809
#, no-c-format
msgid "Arguments"
msgstr "Argumenten"

#. Tag: para
#: plugins.docbook:1810
#, no-c-format
msgid "Arguments passed to the program."
msgstr "Argumenten aan het programma gegeven."

#. Tag: guilabel
#: plugins.docbook:1814
#, no-c-format
msgid "Keep focus"
msgstr "Focus behouden"

#. Tag: para
#: plugins.docbook:1815
#, no-c-format
msgid "Keeps focus on the &gdb; command line."
msgstr "De focus op de &gdb;-commandoregel houden."

#. Tag: guilabel
#: plugins.docbook:1819
#, no-c-format
msgid "Redirect IO"
msgstr "IO omleiden"

#. Tag: para
#: plugins.docbook:1820
#, no-c-format
msgid ""
"Opens a new <guilabel>IO</guilabel> tab in the <guilabel>Debug View</"
"guilabel> where you can view output and provide input to the running program."
msgstr ""
