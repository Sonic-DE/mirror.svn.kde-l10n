#. Tag: para
#: plugins.docbook:1897 plugins.docbook:3735
#, no-c-format
msgid ""
"Special thanks to Google Code-In 2011 participant Martin Gergov for writing "
"much of this section."
msgstr ""
"Speciale dank gaat naar de deelnemer van Google Code-In 2011 Martin Gergov "
"voor het schrijven van veel van deze sectie."

#. Tag: para
#: plugins.docbook:1905
#, no-c-format
msgid ""
"The plugin's configuration page defines the \"debugger profiles\" which can "
"be selected. The default configuration (JSON) is shown there, and it can be "
"\"overlayed\" by a user provided of similar form. An example excerpt is as "
"follows:"
msgstr ""
"De configuratiepagina van de plugin definieert de \"debuggerprofielen\" die "
"geselecteerd kunnen worden. De standaard configuratie (JSON) is daar getoond "
"en daar kan een door de gebruiker geleverde van gelijke vorm overheen gelegd "
"worden. Een voorbeeld is als volgt:"

#. Tag: screen
#: plugins.docbook:1911
#, no-c-format
msgid ""
"{\n"
"    \"dap\": {\n"
"        \"debugpy\": {\n"
"            \"url\": \"https://github.com/microsoft/debugpy\",\n"
"            \"run\": {\n"
"                \"command\": [\"python\", \"-m\", \"debugpy\", \"--listen\", "
"\"${#run.port}\", \"--wait-for-client\"],\n"
"                \"port\": 0,\n"
"                \"supportsSourceRequest\": false\n"
"            },\n"
"            \"configurations\": {\n"
"                \"launch\": {\n"
"                    \"commandArgs\": [\"${file}\", \"${args|list}\"],\n"
"                    \"request\": {\n"
"                        \"command\": \"attach\",\n"
"                        \"stopOnEntry\": true,\n"
"                        \"redirectOutput\": true\n"
"                    }\n"
"                },\n"
"                \"attach\": {\n"
"                    \"commandArgs\": [\"--pid\", \"${pid}\"],\n"
"                    \"request\": {\n"
"                        \"command\": \"attach\",\n"
"                        \"stopOnEntry\": true,\n"
"                        \"redirectOutput\": true\n"
"                    }\n"
"                },\n"
"        },\n"
"        \"gdb\": {\n"
"            \"url\": \"gdb\",\n"
"            \"run\": {\n"
"                \"command\": [\n"
"                    \"gdb\",\n"
"                    \"-i\",\n"
"                    \"dap\"\n"
"                ],\n"
"                \"redirectStderr\": true,\n"
"                \"redirectStdout\": true,\n"
"                \"supportsSourceRequest\": true\n"
"            },\n"
"            \"configurations\": {\n"
"                \"launch (debug)\": {\n"
"                    \"request\": {\n"
"                        \"command\": \"launch\",\n"
"                        \"mode\": \"debug\",\n"
"                        \"program\": \"${file}\",\n"
"                        \"args\": \"${args|list}\",\n"
"                        \"cwd\": \"${workdir}\"\n"
"                    }\n"
"                }\n"
"            }\n"
"        }\n"
"    }\n"
"}"
msgstr ""
"{\n"
"    \"dap\": {\n"
"        \"debugpy\": {\n"
"            \"url\": \"https://github.com/microsoft/debugpy\",\n"
"            \"run\": {\n"
"                \"command\": [\"python\", \"-m\", \"debugpy\", \"--listen\", "
"\"${#run.port}\", \"--wait-for-client\"],\n"
"                \"port\": 0,\n"
"                \"supportsSourceRequest\": false\n"
"            },\n"
"            \"configurations\": {\n"
"                \"launch\": {\n"
"                    \"commandArgs\": [\"${file}\", \"${args|list}\"],\n"
"                    \"request\": {\n"
"                        \"command\": \"attach\",\n"
"                        \"stopOnEntry\": true,\n"
"                        \"redirectOutput\": true\n"
"                    }\n"
"                },\n"
"                \"attach\": {\n"
"                    \"commandArgs\": [\"--pid\", \"${pid}\"],\n"
"                    \"request\": {\n"
"                        \"command\": \"attach\",\n"
"                        \"stopOnEntry\": true,\n"
"                        \"redirectOutput\": true\n"
"                    }\n"
"                },\n"
"        },\n"
"        \"gdb\": {\n"
"            \"url\": \"gdb\",\n"
"            \"run\": {\n"
"                \"command\": [\n"
"                    \"gdb\",\n"
"                    \"-i\",\n"
"                    \"dap\"\n"
"                ],\n"
"                \"redirectStderr\": true,\n"
"                \"redirectStdout\": true,\n"
"                \"supportsSourceRequest\": true\n"
"            },\n"
"            \"configurations\": {\n"
"                \"launch (debug)\": {\n"
"                    \"request\": {\n"
"                        \"command\": \"launch\",\n"
"                        \"mode\": \"debug\",\n"
"                        \"program\": \"${file}\",\n"
"                        \"args\": \"${args|list}\",\n"
"                        \"cwd\": \"${workdir}\"\n"
"                    }\n"
"                }\n"
"            }\n"
"        }\n"
"    }\n"
"}"

#. Tag: para
#: plugins.docbook:1913
#, no-c-format
msgid ""
"Each of the entries in <literal>configurations</literal> is combined with "
"the <literal>run</literal> data and forms a \"profile\". This specifies the "
"DAP server to launch along with its arguments, where the latter are specific "
"to the profile (<literal>commandArgs</literal>). The other parts specify the "
"DAP protocol request (<literal>launch</literal> or <literal>attach</"
"literal>), along with DAP specific extensions."
msgstr ""
"Elk van de items in de <literal>configuraties</literal> wordt gecombineerd "
"met de <literal>run</literal> gegevens en vormt een \"profiel\". Dit "
"specificeert de DAP-server om samen met zijn argumenten te starten, waar de "
"laatsten specifiek zijn voor het profiel (<literal>commandArgs</literal>). "
"De andere delen specificeren het DAP-protocolverzoek (<literal>starten</"
"literal> of <literal>aankoppelen</literal>), samen met DAP-specifieke "
"extensies."

#. Tag: para
#: plugins.docbook:1922
#, no-c-format
msgid ""
"Of course, the specified server should be installed (and typically also in "
"<literal>PATH</literal> for proper execution)."
msgstr ""
"Natuurlijk zou de gespecificeerde server geïnstalleerd moeten zijn (en "
"typisch ook in <literal>PATH</literal> voor juiste uitvoering)."

#. Tag: para
#: plugins.docbook:1927
#, no-c-format
msgid ""
"Various stages of override/merge are applied; user configuration (loaded "
"from file) overrides (internal) default configuration, and the \"dap\" entry "
"in <literal>.kateproject</literal> project configuration in turn overrides."
msgstr ""
"Verschillende stadia van overschrijven/mengen worden toegepast; "
"gebruikersconfiguratie (geladen uit bestand) overschrijft (interne) "
"standaard configuratie en het \"dap\" item in de <literal>.kateproject</"
"literal> projectconfiguratie overschrijft op zijn beurt."

#. Tag: title
#: plugins.docbook:1936 plugins.docbook:2892
#, no-c-format
msgid "Execution environment setup"
msgstr "Opzet uitvoeromgeving"

#. Tag: para
#: plugins.docbook:1938
#, no-c-format
msgid ""
"More background and specifics can be found in the <link linkend=\"lspclient-"
"exec\">LSP Client Execution environment</link> section below. But suffice it "
"to say here it may be needed to run the debuggee process (and the DAP "
"server) in a \"special environment\", whether merely defined by environment "
"variables or some container (providing the required dependencies and "
"circumstances for proper execution)."
msgstr ""
"Meer achtergrond en specifieke zaken zijn te vinden in de onderstaande "
"sectie <link linkend=\"lspclient-exec\">LSP Client uitvoeromgeving</link>. "
"Maar het is voldoende om hier te zeggen dat het nodig kan zijn om het "
"debugproces (en de DAP-server) in een \"speciale omgeving\" uit te voeren, "
"ofwel hoofdzakelijk gedefinieerd door omgevingsvariabelen of een container "
"(die de vereiste afhankelijkheden en omstandigheden voor juiste uitvoering "
"leveren)."

#. Tag: para
#: plugins.docbook:1947
#, no-c-format
msgid ""
"Similar to the example in the referenced section, the following "
"configuration may be provided in a <literal>.kateproject</literal>."
msgstr ""
"Gelijk als in het voorbeeld in de gerefereerde sectie, kan de volgende "
"configuratie geleverd zijn in een <literal>.kateproject</literal>."

#. Tag: screen
#: plugins.docbook:1952
#, no-c-format
msgid ""
"{\n"
"    // this may also be an array of objects\n"
"    \"exec\": {\n"
"        \"hostname\": \"foobar\"\n"
"        // the command could also be an array of string\n"
"        \"prefix\": \"podman exec -i foobarcontainer\",\n"
"        \"mapRemoteRoot\": true,\n"
"        \"pathMappings\": [\n"
"            // either of the following forms are possible\n"
"            // a more automagic alternative exists as well, see referenced "
"section\n"
"            [ \"/dir/on/host\", \"/mounted/in/container\" ]\n"
"            { \"localRoot\": \"/local/dir\", \"remoteRoot\": \"/remote/dir"
"\" }\n"
"        ]\n"
"    },\n"
"    \"dap\": {\n"
"        \"debugpy\": {\n"
"            \"run\": {\n"
"                // in this section, it applies to all configurations\n"
"                // this will match/join with the above object\n"
"                \"exec\": { \"hostname\": \"foobar\" },\n"
"                // if server is connected to,\n"
"                // optionally specify explicit port (which is suitable "
"published/forwarded)\n"
"                \"port\": 5678,\n"
"                // the server may then also have to accept more than "
"localhost\n"
"                \"host\": \"0.0.0.0\"\n"
"            }\n"
"        }\n"
"    }\n"
"}"
msgstr ""
"{\n"
"    // dit kan ook een array van objecten zijn\n"
"    \"exec\": {\n"
"        \"hostname\": \"foobar\"\n"
"        // het commando zou ook een array van tekenreeksen kunnen zijn\n"
"        \"prefix\": \"podman exec -i foobarcontainer\",\n"
"        \"mapRemoteRoot\": true,\n"
"        \"pathMappings\": [\n"
"            // elk van de volgende vormen zijn mogelijk\n"
"            // een meer auto-magisch alternatief bestaat ook, zie sectie "
"waarnaar verwezen wordt\n"
"            [ \"/dir/on/host\", \"/mounted/in/container\" ]\n"
"            { \"localRoot\": \"/local/dir\", \"remoteRoot\": \"/remote/dir"
"\" }\n"
"        ]\n"
"    },\n"
"    \"dap\": {\n"
"        \"debugpy\": {\n"
"            \"run\": {\n"
"                // in deze sectie, is het op alle configuraties van "
"toepassing\n"
"                // dit zal overeen komen/meedoen met het bovenstaande "
"object\n"
"                \"exec\": { \"hostname\": \"foobar\" },\n"
"                // als server er mee is verbonden,\n"
"                //  specificeer expliciet de poort (die geschikt is "
"gepubliceerd/doorgestuurd)\n"
"                \"port\": 5678,\n"
"                // de server kan dan ook meer dan localhost moeten "
"accepteren\n"
"                \"host\": \"0.0.0.0\"\n"
"            }\n"
"        }\n"
"    }\n"
"}"

#. Tag: para
#: plugins.docbook:1954
#, no-c-format
msgid ""
"The referenced section should be consulted for details, but in essence the "
"<literal>prefix</literal> will be prepended before the DAP server command "
"line specified elsewhere. The effect is that the server is run within the "
"specified container and then in turn also the launched process. The "
"<literal>pathMapping</literal> arranges for transformation of filepaths "
"between editor's view and DAP server (container) view, e.g. when dealing "
"with setting of breakpoints or handling of reported backtraces. Note that "
"such mapping is optional and may or may not be useful. When dealing with C/C+"
"+ code that is compiled on \"host\", the symbol info references source files "
"on host which do not exist at all in the other environment. However, in "
"other scripted (e.g. python) circumstances, actual runtime files are "
"referenced (on the other environment)."
msgstr ""
"De sectie waarnaar gerefereerd zou geconsulteerd moeten worden voor details, "
"maar in essentie zal het <literal>voorvoegsel</literal> voorgevoegd worden "
"alvorens de opdrachtregel van de DAP-server elders wordt gespecificeerd. Het "
"effect is dat de server draait in de gespecificeerde container en daarna op "
"zijn beurt ook het gestarte proces. De <literal>pathMapping</literal> zorgt "
"voor transformatie van bestandspaden tussen weergave van de bewerker en de "
"weergave van de DAP-server (container), bijv. wanneer gewerkt wordt met "
"instelling van breakpoints of behandeling van gerapporteerde backtraces. "
"Merk op dat zulke koppeling optioneel is en al dan niet nuttig kan zijn. Bij "
"werken met C/C++ code die op de \"host\" is gecompileerd, refereert de "
"symboleninformatie van bronbestanden op de host die helemaal niet bestaat in "
"de andere omgeving. Echter, in andere gescripte (bijv. python) "
"omstandigheden, worden actuele runtime bestanden gerefereerd (op de andere "
"omgeving)."

#. Tag: para
#: plugins.docbook:1969
#, no-c-format
msgid "The following must evidently be kept in mind."
msgstr "Het volgende moet duidelijk in gedachten gehouden worden."

#. Tag: para
#: plugins.docbook:1975
#, no-c-format
msgid ""
"The DAP server must be present in the environment/container, which must be "
"configured to support proper debugger operation (so, if needed, privileged, "
"capabilities)."
msgstr ""
"De DAP-server moet aanwezig zijn in de omgeving/container, die "
"geconfigureerd moet zijn om de debuggerbewerking juist te ondersteunen (dus, "
"indien nodig, geprivilegieerd, mogelijkheden)."

#. Tag: para
#: plugins.docbook:1981
#, no-c-format
msgid ""
"Communication between editor and DAP must be possible. In case of a "
"container, the latter should either use host networking, or provide a "
"suitable mapped/published port along with corresponding config snippet as in "
"above example (as an auto-selected one in case of port 0 would not make it "
"through)."
msgstr ""
"Communicatie tussen bewerker en DAP moet mogelijk zijn. In het geval van een "
"container zou de laatste ofwel hostnetwerking moeten gebruiken of een "
"geschikte gekoppelde/gepubliceerde poort samen met een bijbehorend "
"configuratiefragment zoals in bovenstaand voorbeeld (omdat een automatisch "
"geselecteerde poort als poort 0 niet door komt)."

#. Tag: para
#: plugins.docbook:1988
#, no-c-format
msgid ""
"A specified executable/PID should be in \"container\" perspective, as well "
"as any (debuggee executable) arguments."
msgstr ""
"Een gespecificeerd uitvoerbaar bestand/PID zou in het perspectief van de "
"\"container\" , evenals elk argument (debuggee uitvoerbaar bestand)."

#. Tag: para
#: plugins.docbook:1995
#, no-c-format
msgid ""
"Also, as in the LSP case, some environment variables are set; "
"<literal>KATE_EXEC_PLUGIN</literal> is set to <literal>dap</literal>, "
"<literal>KATE_EXEC_SERVER</literal> is set to the debugger/language type (e."
"g. <literal>python</literal>) and <literal>KATE_EXEC_PROFILE</literal> is "
"set to the configuration entry (e.g. <literal>launch</literal>)."
msgstr ""
"Ook, als in het LSP-geval, enige omgevingsvariabelen zijn gezet; "
"<literal>KATE_EXEC_PLUGIN</literal> is gezet op <literal>dap</literal>, "
"<literal>KATE_EXEC_SERVER</literal> is gezet op het debugger-/taaltype "
"(bijv. <literal>python</literal>) en <literal>KATE_EXEC_PROFILE</literal> is "
"gezet op het configuratie-item (bijv. <literal>launch</literal>)."

#. Tag: title
#: plugins.docbook:2014
#, no-c-format
msgid "Project Plugin"
msgstr "Projectplug-in"

#. Tag: para
#: plugins.docbook:2019
#, no-c-format
msgid ""
"The basic idea of the Project plugin is to have a structured list of files "
"belonging to the project with the following properties:"
msgstr ""
"Her basis idee van de projectplug-in is om een gestructureerde lijst met "
"bestanden te hebben die bij het project behoren met de volgende "
"eigenschappen:"

#. Tag: para
#: plugins.docbook:2023
#, no-c-format
msgid "Provide a structured view of the files"
msgstr "Bied een gestructureerde weergave van de bestanden"

#. Tag: para
#: plugins.docbook:2024
#, no-c-format
msgid "Make it easy and very fast to open and switch projects"
msgstr ""
"Maak het gemakkelijk en zeer snel om projecten te openen en naar om te "
"schakelen "

#. Tag: para
#: plugins.docbook:2025
#, no-c-format
msgid "Support search and replace for a project"
msgstr "Zoeken en vervangen voor een project ondersteunen"

#. Tag: para
#: plugins.docbook:2026
#, no-c-format
msgid "Provide simple auto completion"
msgstr "Eenvoudige automatische aanvulling bieden"

#. Tag: para
#: plugins.docbook:2027
#, no-c-format
msgid "Make it simple to quickly open files in the project"
msgstr "Het eenvoudig maken om snel bestanden te openen in het project"

#. Tag: para
#: plugins.docbook:2028
#, no-c-format
msgid "Support for building the project"
msgstr "Ondersteuning voor het bouwen van het project"

#. Tag: title
#: plugins.docbook:2033
#, no-c-format
msgid "Structured View of the Files"
msgstr "Gestructureerde weergave van de bestanden"

#. Tag: para
#: plugins.docbook:2035
#, no-c-format
msgid ""
"Once the Project plugin is loaded in the &kate; configuration page, open a "
"file in a project and a sidebar appears that lists all projects as well as "
"the project files as follows:"
msgstr ""
"Nadat de project-plug-in is geladen in de instellingenpagina van &kate;, "
"open dan een bestand in een project en er verschijnt een zijbalk met een "
"lijst van alle projecten evenals de projectbestanden als volgt:"

#. Tag: screeninfo
#: plugins.docbook:2040
#, no-c-format
msgid "Project View"
msgstr "Projectweergave"

#. Tag: para
#: plugins.docbook:2046
#, no-c-format
msgid ""
"As you can see, the currently active project is <quote>Kate</quote>, and its "
"contents is listed in the tree view. Clicking on files in the tree view "
"opens the file in the editor. Further, a context menu is provided with which "
"you can open files with other applications, such as a <filename class="
"\"extension\">.ui</filename> file with Qt Designer."
msgstr ""
"Zoals u kunt zien is het nu actieve project <quote>Kate</quote> en zijn "
"inhoud wordt getoond in de boomstructuur. Klikken op bestanden in de "
"boomstructuur opent het bestand in de bewerker. Verder wordt er een "
"contextmenu getoond waarmee u bestanden kunt openen met andere toepassingen, "
"zoals een <filename class=\"extension\">.ui</filename> bestand met Qt "
"Designer."

#. Tag: para
#: plugins.docbook:2050
#, no-c-format
msgid ""
"You can filter the items by typing parts of the file name you are looking "
"for into the search bar at the bottom of the list."
msgstr ""
"U kunt de items filteren door delen van de bestandsnaam waarnaar u zoekt in "
"de zoekbalk aan de onderkant van de lijst in te typen."

#. Tag: title
#: plugins.docbook:2055
#, no-c-format
msgid "Switching Projects"
msgstr "Omschakelen van projecten"

#. Tag: para
#: plugins.docbook:2057
#, no-c-format
msgid ""
"The idea is that you never have to open a project manually, this is even not "
"supported at all. Hence, what happens if you open a file, the Project plugin "
"quickly scans the folder and its parent folders for a <filename>."
"kateproject</filename> file. If found, the project is automatically loaded."
msgstr ""
"Het idee is dat u nooit een project handmatig hoeft te openen, dit wordt "
"zelfs helemaal niet ondersteund. Dus, wat gebeurt er als u een bestand "
"opent, dan scant de project-plug-in snel de map en zijn bovenliggende mappen "
"naar een <filename>.kateproject</filename> bestand. Indien gevonden, zal het "
"project automatisch worden geladen."

#. Tag: para
#: plugins.docbook:2062
#, no-c-format
msgid ""
"Furthermore, if you open another document in &kate;, that belongs to another "
"project, the Project plugin automatically switches the current project. So "
"intuitively, always the correct project is active. Of course, you can also "
"switch the currently active project using the combo box."
msgstr ""
"Verder zal, als u een ander document in &kate; opent, dat behoort bij een "
"ander project, de project-plug-in automatisch het huidige project "
"omschakelen. Dus is intuïtief altijd het juiste project actief. Natuurlijk "
"kunt u ook het nu actieve project omschakelen met de keuzelijst."

#. Tag: title
#: plugins.docbook:2070
#, no-c-format
msgid "Search and Replace in Projects"
msgstr "Zoeken en vervangen in projecten"

#. Tag: para
#: plugins.docbook:2072
#, no-c-format
msgid ""
"&kate; has a Search and Replace plugin that shows up in the bottom sidebar. "
"If a project is loaded, open the Search and Replace sidebar, and switch to "
"the mode to search and replace in the current project:"
msgstr ""
"&kate; heeft een plug-in voor zoeken vervangen die verschijnt in de onderste "
"zijbalk. Als een project is geladen, open dan de zijbalk zoeken en vervangen "
"en schakel om naar de modus om te zoeken en te vervangen in het huidige "
"project:"

#. Tag: screeninfo
#: plugins.docbook:2077
#, no-c-format
msgid "Search in Projects"
msgstr "Zoeken in projecten"

#. Tag: title
#: plugins.docbook:2086
#, no-c-format
msgid "Simple Auto Completion"
msgstr "Eenvoudige automatische aanvulling"

#. Tag: para
#: plugins.docbook:2088
#, no-c-format
msgid ""
"With the knowledge of all files belonging to a project, the Project plugin "
"provides simple auto completion facilities based on CTags. If a project is "
"initially opened, CTags parses all project files in a background thread and "
"saves the CTags information to <filename class=\"directory\">/tmp</"
"filename>. This file then is used to populate the auto completion popup in "
"&kate;."
msgstr ""
"Met de kennis van alle bestanden behorende tot een project, biedt de project-"
"plug-in eenvoudige mogelijkheden voor automatisch aanvullen gebaseerd op "
"CTags. Als een project initieel is geopend, ontleed CTags alle "
"projectbestanden in een achtergrond thread en slaat de CTags-informatie op "
"in <filename class=\"directory\">/tmp</filename>. Dit bestand wordt daarna "
"gebruikt om de pop-up voor automatische aanvulling popup in &kate; te "
"bevolken."

#. Tag: para
#: plugins.docbook:2094
#, no-c-format
msgid ""
"In contrast, without this auto completion, &kate; is only capable of showing "
"auto completion items based on the words in the current file. So the auto "
"completion provided by the Project plugin is much more powerful."
msgstr ""
"In tegenstelling hiermee, zonder deze automatische aanvulling, is &kate; "
"alleen in staat om items voor automatische aanvulling gebaseerd op de "
"woorden in het huidige bestand. De automatische aanvulling geleverd door de "
"project-plug-in is veel krachtiger."

#. Tag: screeninfo
#: plugins.docbook:2099
#, no-c-format
msgid "Completion in Projects"
msgstr "Aanvullen in projecten"

#. Tag: para
#: plugins.docbook:2105
#, no-c-format
msgid ""
"If CTags is missing, a passive popup warns you about this issue. It is also "
"noteworthy, that the CTags file in <filename class=\"directory\">/tmp</"
"filename> is cleaned up when &kate; exits, so the plugin does not pollute "
"any folder with unwanted files."
msgstr ""
"Als CTags ontbreken zal een passieve pop-up u hierover waarschuwen. Het is "
"ook goed op te merken dat het CTags bestand in <filename class=\"directory"
"\">/tmp</filename> gewist wordt wanneer &kate; eindigt, de plug-in vervuilt "
"dus geen enkele map met ongewenste bestanden."

#. Tag: title
#: plugins.docbook:2112
#, no-c-format
msgid "Support for Building the Project"
msgstr "Ondersteuning voor het bouwen van het project"

#. Tag: para
#: plugins.docbook:2114
#, no-c-format
msgid ""
"Another feature is to have support for the <link linkend=\"projects-build-"
"support\">Build Plugin</link>, so that it automatically is configured "
"correctly."
msgstr ""
"Een andere functie is het hebben van ondersteuning voor de <link linkend="
"\"projects-build-support\">Bouw-plug-in</link>, zodat het automatisch juist "
"is geconfigureerd."

#. Tag: title
#: plugins.docbook:2120
#, no-c-format
msgid "Creating Projects"
msgstr "Projecten aanmaken"

#. Tag: title
#: plugins.docbook:2124
#, no-c-format
msgid "Loading Projects Automatically"
msgstr "Projecten automatisch laden"

#. Tag: para
#: plugins.docbook:2126
#, no-c-format
msgid ""
"The Project plugin has an auto-loading feature. You can read the file list "
"from the version control system. To this end, auto-loading for the "
"respective version control system needs to be enabled in the settings "
"(enabled by default):"
msgstr ""
"De project-plug-in heeft een functie automatisch laden. U kunt de lijst met "
"bestanden in uit het versiecontrolesysteem. Op dit moment moet automatisch "
"laden voor de respectievelijke versiecontrolesysteem worden ingeschakeld in "
"de instellingen (standaard ingeschakeld):"

#. Tag: screeninfo
#: plugins.docbook:2132
#, no-c-format
msgid "Project Plugin Configuration"
msgstr "Instellingen van project-plug-in"

#. Tag: title
#: plugins.docbook:2141
#, no-c-format
msgid "Creating Projects Manually"
msgstr "Projecten handmatig aanmaken"

#. Tag: para
#: plugins.docbook:2142
#, no-c-format
msgid ""
"You just have to create a <filename>.kateproject</filename> file in the root "
"folder of the project. For instance, the <quote>Kate</quote> <filename>."
"kateproject</filename> file looks like this:"
msgstr ""
"U hoeft alleen maar een bestand <filename>.kateproject</filename> in de "
"hoofdmap van het project aan te maken. Bijvoorbeeld het <filename>."
"kateproject</filename> bestand van <quote>Kate</quote> ziet er uit zoals dit:"

#. Tag: screen
#: plugins.docbook:2147
#, no-c-format
msgid ""
"{\n"
"  \"name\": \"Kate\",\n"
"  \"files\": [\n"
"    {\n"
"      \"git\": 1\n"
"    }\n"
"  ]\n"
"}"
msgstr ""
"{\n"
"  \"name\": \"Kate\",\n"
"  \"files\": [\n"
"    {\n"
"      \"git\": 1\n"
"    }\n"
"  ]\n"
"}"

#. Tag: para
#: plugins.docbook:2149
#, no-c-format
msgid ""
"The file content is written in &JSON; syntax. The project name is "
"<quote>Kate</quote>, and the files contained in should be read from &git;."
msgstr ""
"De inhoud van het bestand is in de &JSON;-syntaxis geschreven. De "
"projectnaam is <quote>Kate</quote> en de bestanden erin zouden uit &git; "
"gelezen moeten worden."

#. Tag: para
#: plugins.docbook:2153
#, no-c-format
msgid ""
"Also supported instead of <literal>git</literal> is subversion through "
"<literal>svn</literal> and mercurial through <literal>hg</literal>. If you "
"do not want to read files from a version control system, you can just invoke "
"kate from command line as: <screen>\n"
"kate /path/to/folder\n"
"</screen> or you can tell it to recursively load files from directories as "
"follows:"
msgstr ""
"Ook wordt in plaats van <literal>git</literal> subversion ondersteund via "
"<literal>svn</literal> en mercurial via <literal>hg</literal>. Als u geen "
"bestanden wilt lezen uit een versiecontrolesysteem, dan kunt u kate "
"aanroepen vanaf de opdrachtregel als: <screen>\n"
"kate /pad/naar/map/\n"
"</screen> of kunt u het vertellen om bestanden recursief te laden uit mappen "
"als volgt:"

#. Tag: screen
#: plugins.docbook:2162
#, no-c-format
msgid ""
"{\n"
"  \"name\": \"Kate\",\n"
"  \"files\": [\n"
"    {\n"
"      \"directory\": \"kate\",\n"
"      \"filters\": [\n"
"        \"*.cpp\",\n"
"        \"*.h\",\n"
"        \"*.ui\",\n"
"        \"CMakeLists.txt\",\n"
"        \"Find*.cmake\"\n"
"      ],\n"
"      \"recursive\": 1,\n"
"      \"hidden\": 1\n"
"    }\n"
"  ],\n"
"  \"exclude_patterns\" : [\n"
"    \"^build/.*\"\n"
"  ]\n"
"}"
msgstr ""
"{\n"
"  \"name\": \"Kate\",\n"
"  \"files\": [\n"
"    {\n"
"      \"directory\": \"kate\",\n"
"      \"filters\": [\n"
"        \"*.cpp\",\n"
"        \"*.h\",\n"
"        \"*.ui\",\n"
"        \"CMakeLists.txt\",\n"
"        \"Find*.cmake\"\n"
"      ],\n"
"      \"recursive\": 1,\n"
"      \"hidden\": 1\n"
"    }\n"
"  ],\n"
"  \"exclude_patterns\" : [\n"
"    \"^build/.*\"\n"
"  ]\n"
"}"

#. Tag: para
#: plugins.docbook:2164
#, no-c-format
msgid ""
"Here, subfolders and filters define what’s part of the project. You can also "
"mix version control and files based on filters. Hidden files will not be "
"retrieved if the option <code>\"hidden\"</code> is 0. <code>"
"\"exclude_patterns\"</code> is a list of regex patterns that can be used to "
"exclude folders and files from the project tree. In this example, All files "
"and folders in a directory <filename>build</filename> from the root will be "
"excluded."
msgstr ""
"Submappen en filters definiëren hier wat onderdeel is van het project. U "
"kunt ook controle op versie en bestanden gebaseerd op filters mengen. "
"Verborgen bestanden zullen niet opgehaald worden als de optie <code>\"hidden"
"\"</code> 0 is. <code>\"exclude_patterns\"</code> is een lijst met regex "
"patronen die gebruikt kunnen worden om mappen en bestanden uit te sluiten "
"van de projectboom. In dit voorbeeld zullen alle bestanden en mappen in een "
"map <filename>build</filename> in de hoofdmap uitgesloten worden."

#. Tag: para
#: plugins.docbook:2173
#, no-c-format
msgid ""
"If you want to add support for the building, you can write a <filename>."
"kateproject</filename> like this:"
msgstr ""
"Als u ondersteuning voor bouwen wilt toevoegen, dan kunt u een <filename>."
"kateproject</filename> schrijven zoals dit:"

#. Tag: screen
#: plugins.docbook:2176
#, no-c-format
msgid ""
"{\n"
"  \"name\": \"Kate\",\n"
"  \"files\": [\n"
"    {\n"
"      \"git\": 1\n"
"    }\n"
"  ],\n"
"  \"build\": {\n"
"    \"directory\": \"build\",\n"
"    \"build\": \"make all\",\n"
"    \"clean\": \"make clean\",\n"
"    \"install\": \"make install\",\n"
"    \"targets\": [\n"
"      {\n"
"        \"name\": \"all\",\n"
"        \"build_cmd\": \"ninja\"\n"
"        \"run_cmd\": \"./bin/kate\"\n"
"      },\n"
"      {\n"
"        \"name\": \"kate\",\n"
"        \"build_cmd\": \"ninja kate-bin\"\n"
"      }\n"
"    ]\n"
"  }\n"
"}"
msgstr ""
"{\n"
"  \"name\": \"Kate\",\n"
"  \"files\": [\n"
"    {\n"
"      \"git\": 1\n"
"    }\n"
"  ],\n"
"  \"build\": {\n"
"    \"directory\": \"build\",\n"
"    \"build\": \"make all\",\n"
"    \"clean\": \"make clean\",\n"
"    \"install\": \"make install\",\n"
"    \"targets\": [\n"
"      {\n"
"        \"name\": \"all\",\n"
"        \"build_cmd\": \"ninja\"\n"
"        \"run_cmd\": \"./bin/kate\"\n"
"      },\n"
"      {\n"
"        \"name\": \"kate\",\n"
"        \"build_cmd\": \"ninja kate-bin\"\n"
"      }\n"
"    ]\n"
"  }\n"
"}"

#. Tag: para
#: plugins.docbook:2178
#, no-c-format
msgid ""
"The targets specified above will then appear in the <link linkend=\"kate-"
"application-plugin-build\">Build Plugin </link> under <emphasis role=\"bold"
"\"> \"Project Plugin Targets\"</emphasis>. If the <code>\"targets\"</code> "
"array is specified then <code>\"build\"</code>, <code>\"clean\"</code> and "
"<code>\"install\"</code> are ignored. Each element in the array specifies a "
"target. <code>\"name\"</code> is the name of the target, <code>\"build_cmd"
"\"</code> will be used to build the target, <code>\"run_cmd\"</code> will be "
"used to run the target. Most important of all is <code>\"directory\"</code>, "
"this is where the commands will be executed."
msgstr ""
"De bovenstaand gespecificeerde doelen zullen daarna verschijnen in de <link "
"linkend=\"kate-application-plugin-build\">Bouwplug-in </link> onder "
"<emphasis role=\"bold\"> \"Projectplug-in doelen\"</emphasis>. Als het <code>"
"\"doelen\"</code> array is gespecificeerd dan worden <code>\"build\"</code>, "
"<code>\"clean\"</code> en <code>\"install\"</code> genegeerd. Elk element in "
"het array specificeert een doel. <code>\"name\"</code> is de naam van het "
"doel, <code>\"build_cmd\"</code> zal gebruikt worden om het doel te bouwen, "
"<code>\"run_cmd\"</code> zal gebruikt worden om het doel uit te voeren. Het "
"belangrijkste van alles is <code> \"directory\"</code>, dit is waar de "
"commando's uitgevoerd zullen worden."

#. Tag: para
#: plugins.docbook:2186
#, no-c-format
msgid ""
"In case you have a <filename>.kateproject</filename> file tracked by a "
"control version system, but you need to tweak the configuration for a "
"particular workspace, you can save those changes to a separated file named "
"<filename>.kateproject.local</filename>. The content of this file will take "
"precedence over <filename>.kateproject</filename>."
msgstr ""
"In het geval dat u een bestand <filename>.kateproject</filename> hebt "
"gevolgd door een versiecontrolesysteem, maar u wilt de configuratie voor een "
"specifieke werkruimte aanpassen, dan kunt u die wijzigingen opslaan in een "
"apart bestand genaamd <filename>.kateproject.local</filename>. De inhoud van "
"dit bestand gaat boven die in <filename>.kateproject</filename>."

#. Tag: title
#: plugins.docbook:2199
#, no-c-format
msgid "<title>Current Project</title>"
msgstr "<title>Huidige project</title>"

#. Tag: para
#: plugins.docbook:2201
#, no-c-format
msgid ""
"Using <menuchoice><shortcut><keycombo action=\"simul\">&Alt;<keycap>1</"
"keycap></keycombo></shortcut> <guimenu>Projects</guimenu><guimenuitem>Go To</"
"guimenuitem></menuchoice> you can open the <guilabel>Current Project</"
"guilabel> view at the bottom of the editor window with four tabs:"
msgstr ""
"Met <menuchoice><shortcut><keycombo action=\"simul\">&Alt;<keycap>1</"
"keycap></keycombo></shortcut> <guimenu>Projecten</guimenu><guimenuitem>Ga "
"naar</guimenuitem></menuchoice> kunt u de weergave van het <guilabel>Huidige "
"Project</guilabel> onderaan het bewerkingsvenster openen met vier tabbladen:"

#. Tag: screeninfo
#: plugins.docbook:2206
#, no-c-format
msgid "<screeninfo>Current Project</screeninfo>"
msgstr "<screeninfo>Huidige project</screeninfo>"

#. Tag: guimenu
#: plugins.docbook:2216
#, no-c-format
msgid "Terminal Panel"
msgstr "Terminalpaneel"

#. Tag: para
#: plugins.docbook:2219
#, no-c-format
msgid ""
"A <link linkend=\"kate-application-plugin-konsole\">Terminal emulator</link> "
"starting in the root folder of the project."
msgstr ""
"Een <link linkend=\"kate-application-plugin-konsole\">Terminalemulator</"
"link> starten in de hoofdmap van het project."

#. Tag: guimenu
#: plugins.docbook:2226
#, no-c-format
msgid "Code Index"
msgstr "Code-index"

#. Tag: para
#: plugins.docbook:2229
#, no-c-format
msgid ""
"Entering characters into the search bar will start the search and display "
"matching names of functions, classes, symbols &etc; together with kind, "
"filename and line number."
msgstr ""
"Tekens invoeren in de zoekbalk zal het zoeken starten en overeenkomende "
"namen van van functies, klassen, symbolen &etc; tonen samen met soort, "
"bestandsnaam en regelnummer."

#. Tag: guimenu
#: plugins.docbook:2237
#, no-c-format
msgid "Code Analysis"
msgstr "Code analyse"

#. Tag: para
#: plugins.docbook:2240
#, no-c-format
msgid ""
"Click <guilabel>Start Analysis</guilabel> to run a static code analysis for "
"the C and C++ using <command>cppcheck</command> and to generate a report "
"showing filename, line number, severity (style, warning &etc;) and the issue "
"found."
msgstr ""
"Klik op <guilabel>Analyse starten</guilabel> om een statische analyse van "
"broncode voor C en C++ met <command>cppcheck</command> uit te voeren en om "
"een rapport te maken met bestandsnaam, regelnummer, ernst (stijl, "
"waarschuwing &etc;) en de gevonden problemen."

#. Tag: guimenu
#: plugins.docbook:2249
#, no-c-format
msgid "Notes"
msgstr "Notities"

#. Tag: para
#: plugins.docbook:2252
#, no-c-format
msgid ""
"Text entered in this tab will be saved in the file <filename>.kateproject."
"notes</filename>."
msgstr ""
"Ingevoerde tekst in dit tabblad zal opgeslagen worden in het bestand "
"<filename>.kateproject.notes</filename>."

#. Tag: title
#: plugins.docbook:2262
#, no-c-format
msgid "The Projects Menu"
msgstr "Het menu Projecten"

#. Tag: para
#: plugins.docbook:2264
#, no-c-format
msgid ""
"The <guimenu>Projects</guimenu> menu allows you to switch between currently "
"open projects. It is displayed by the Project plugin."
msgstr ""
"Het menu <guimenu>Projecten</guimenu> stelt u in staat om te schakelen "
"tussen nu open projecten. Het wordt getoond door de plug-in Project."

#. Tag: menuchoice
#: plugins.docbook:2270
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Alt;&Left;</keycombo> </"
"shortcut> <guimenu>Projects</guimenu> <guimenuitem>Back</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Alt;&Left;</keycombo> </"
"shortcut> <guimenu>Projecten</guimenu> <guimenuitem>Terug</guimenuitem>"

#. Tag: para
#: plugins.docbook:2278
#, no-c-format
msgid "Switch to the previous project."
msgstr "Schakel naar het vorige project."

#. Tag: menuchoice
#: plugins.docbook:2283
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Alt;&Right;</keycombo> </"
"shortcut> <guimenu>Projects</guimenu> <guimenuitem>Forward</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Alt;&Right;</keycombo> </"
"shortcut> <guimenu>Projecten</guimenu> <guimenuitem>Verder</guimenuitem>"

#. Tag: para
#: plugins.docbook:2291
#, no-c-format
msgid "Switch to the next project."
msgstr "Schakel naar het volgende project."

#. Tag: menuchoice
#: plugins.docbook:2296
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt;<keycap>1</keycap></keycombo> </"
"shortcut> <guimenu>Projects</guimenu><guimenuitem>Go To</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt;<keycap>1</keycap></keycombo> </"
"shortcut> <guimenu>Projecten</guimenu><guimenuitem>Ga naar</guimenuitem>"

#. Tag: para
#: plugins.docbook:2303
#, no-c-format
msgid ""
"Open the <guilabel>Current Project</guilabel> view at the bottom of the "
"editor window."
msgstr ""
"Open de weergave <guilabel>Huidig project</guilabel> onderaan het "
"bewerkingsvenster."

#. Tag: title
#: plugins.docbook:2320
#, no-c-format
msgid "LSP Client Plugin"
msgstr "LSP-clientplug-in"

#. Tag: para
#: plugins.docbook:2322
#, no-c-format
msgid ""
"The LSP Client plugin provides many language features such as code "
"completion, code navigation or finding references based on the <ulink url="
"\"https://microsoft.github.io/language-server-protocol/\">Language Server "
"Protocol</ulink>."
msgstr ""
"De LSP-clientplug-in biedt vele talenfuncties zoals codeaanvulling, "
"codenavigatie of het zoeken naar verwijzingen gebaseerd op het <ulink url="
"\"https://microsoft.github.io/language-server-protocol/"
"\">Talenserverprotocol</ulink>."

#. Tag: para
#: plugins.docbook:2325
#, no-c-format
msgid ""
"Once you have enabled the LSP Client in the plugin page, a new page called "
"LSP Client will appear in your &kate; configuration dialog."
msgstr ""
"Als u eenmaal de LSP-client in de plug-inpagina hebt ingeschakeld, zal een "
"nieuwe pagina, genaamd LSP-client, verschijnen in de instellingendialoog van "
"&kate;."

#. Tag: para
#: plugins.docbook:2332
#, no-c-format
msgid ""
"If appropriate, a corresponding LSP command is also mentioned in the "
"explanation below, the documentation of which may then provide additional "
"background and interpretation, though it may vary depending on the actual "
"language. The phrase 'current symbol' refers to the symbol corresponding to "
"the current cursor position, as so determined by the language and server "
"implementation."
msgstr ""
"Indien van toepassing, een overeenkomstig LSP-commando wordt ook genoemd in "
"de onderstaande uitleg, waarvan de documentatie dan misschien extra "
"achtergrond en interpretatie biedt, hoewel het kan variëren afhankelijk van "
"de actuele taal. De uitdrukking 'huidig symbool' verwijst naar het symbool "
"overeenkomend met de huidige cursorpositie, zoals bepaalt door de "
"implementatie van taal en server."

#. Tag: menuchoice
#: plugins.docbook:2344
#, no-c-format
msgid "<guimenu>LSP Client</guimenu> <guisubmenu>Go to Definition</guisubmenu>"
msgstr ""
"<guimenu>LSP-client</guimenu> <guisubmenu>Ga naar definitie</guisubmenu>"

#. Tag: para
#: plugins.docbook:2349
#, no-c-format
msgid "[textDocument/definition] Go to current symbol definition."
msgstr "[textDocument/definition] Ga naar huidige symbooldefinitie."

#. Tag: menuchoice
#: plugins.docbook:2354
#, no-c-format
msgid ""
"<guimenu>LSP Client</guimenu> <guisubmenu>Go to Declaration</guisubmenu>"
msgstr ""
"<guimenu>LSP-client</guimenu> <guisubmenu>Ga naar declaratie</guisubmenu>"

#. Tag: para
#: plugins.docbook:2359
#, no-c-format
msgid "[textDocument/declaration] Go to current symbol declaration."
msgstr "[textDocument/declaration] Ga naar huidige symbooldefinitie."

#. Tag: menuchoice
#: plugins.docbook:2364
#, no-c-format
msgid ""
"<guimenu>LSP Client</guimenu> <guisubmenu>Go to Type Definition</guisubmenu>"
msgstr ""
"<guimenu>LSP-client</guimenu> <guisubmenu>Ga naar type-definitie</guisubmenu>"

#. Tag: para
#: plugins.docbook:2369
#, no-c-format
msgid "[textDocument/typeDefinition] Go to current symbol type definition."
msgstr "[textDocument/typeDefinition] Ga naar huidige symbooltypedefinitie."

#. Tag: menuchoice
#: plugins.docbook:2374
#, no-c-format
msgid "<guimenu>LSP Client</guimenu> <guisubmenu>Find References</guisubmenu>"
msgstr ""
"<guimenu>LSP-client</guimenu> <guisubmenu>Referenties zoeken</guisubmenu>"

#. Tag: para
#: plugins.docbook:2379
#, no-c-format
msgid "[textDocument/references] Find references to current symbol."
msgstr "[textDocument/references] Zoek naar referenties naar huidige symbool."

#. Tag: menuchoice
#: plugins.docbook:2384
#, no-c-format
msgid ""
"<guimenu>LSP Client</guimenu> <guisubmenu>Find Implementations</guisubmenu>"
msgstr ""
"<guimenu>LSP-client</guimenu> <guisubmenu>Implementaties zoeken</guisubmenu>"

#. Tag: para
#: plugins.docbook:2389
#, no-c-format
msgid "[textDocument/implementation] Find implementations of current symbol."
msgstr ""
"[textDocument/implementation] implementaties van huidige symbool zoeken."

#. Tag: menuchoice
#: plugins.docbook:2394
#, no-c-format
msgid "<guimenu>LSP Client</guimenu> <guisubmenu>Highlight</guisubmenu>"
msgstr "<guimenu>LSP-client</guimenu> <guisubmenu>Accentueren</guisubmenu>"

#. Tag: para
#: plugins.docbook:2399
#, no-c-format
msgid ""
"[textDocument/documentHighlight] Highlight current symbol references in "
"current document."
msgstr ""
"[textDocument/documentHighlight] Huidige symboolreferenties accentueren in "
"huidige document."

#. Tag: menuchoice
#: plugins.docbook:2404
#, no-c-format
msgid "<guimenu>LSP Client</guimenu> <guisubmenu>Hover</guisubmenu>"
msgstr "<guimenu>LSP-client</guimenu> <guisubmenu>Er boven zweven</guisubmenu>"

#. Tag: para
