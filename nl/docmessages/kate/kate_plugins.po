"huidige document of huidige selectie."

#. Tag: menuchoice
#: plugins.docbook:2425
#, no-c-format
msgid "<guimenu>LSP Client</guimenu> <guisubmenu>Rename</guisubmenu>"
msgstr "<guimenu>LSP-client</guimenu> <guisubmenu>Hernoemen</guisubmenu>"

#. Tag: para
