#~ msgid ""
#~ "function rangeCommand(command, def) {\n"
#~ "    if (view.selectedText().length > 0) {\n"
#~ "        return command.replace(\"%%1\", view.selectedText());\n"
#~ "    } else {\n"
#~ "        return command.replace(\"%%1\", def);\n"
#~ "    }\n"
#~ "}"
#~ msgstr ""
#~ "function rangeCommand(command, def) {\n"
#~ "    if (view.selectedText().length > 0) {\n"
#~ "        return command.replace(\"%%1\", view.selectedText());\n"
#~ "    } else {\n"
#~ "        return command.replace(\"%%1\", def);\n"
#~ "    }\n"
#~ "}"

