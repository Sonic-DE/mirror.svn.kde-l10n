#~ msgstr ""
#~ "Een plugin, die zen-codering doet zoals keuze-voltooiing>. Voor meer "
#~ "informatie zie <ulink url=\"http://en.wikipedia.org/wiki/Zen_Coding\">Zen-"
#~ "codering</ulink>."

#~ msgid ""
#~ "This plugin allows you to insert any readable file at the cursor "
