#. Tag: para
#: index.docbook:71
#, no-c-format
msgid "Logic, Board"
msgstr "Lógica, Tabuleiro"

#. Tag: title
#: index.docbook:74
#, no-c-format
msgid "Number of possible players:"
msgstr "Número de jogadores possíveis:"

#. Tag: para
#: index.docbook:74
#, no-c-format
