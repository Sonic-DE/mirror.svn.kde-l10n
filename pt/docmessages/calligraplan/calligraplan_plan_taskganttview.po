#. Tag: title
#: taskganttview.docbook:2
#, no-c-format
msgid "<title>Description</title>"
msgstr "<title>Descrição</title>"

#. Tag: para
#: taskganttview.docbook:3
#, no-c-format
msgid "The Gantt view is used to show tasks in a timeline."
msgstr "A Área do Gantt é usada para mostrar as tarefas de forma cronológica."

#. Tag: phrase
#: taskganttview.docbook:14
#, no-c-format
msgid "<phrase>Gantt View</phrase>"
msgstr "<phrase>Área do Gantt</phrase>"

#. Tag: para
#: taskganttview.docbook:17
#, no-c-format
msgid "<para>Gantt View</para>"
msgstr "<para>Área do Gantt</para>"

#. Tag: title
#: taskganttview.docbook:23
#, no-c-format
msgid "Editing data"
msgstr "Editar os dados"

#. Tag: para
#: taskganttview.docbook:24
#, no-c-format
msgid "Task description and progress can be edited using the context menu."
msgstr ""
"A descrição e o progresso da tarefa poderão ser editados com o menu de "
"contexto."

#. Tag: para
#: taskganttview.docbook:26
#, no-c-format
msgid "The following columns are displayed as default:"
msgstr "São apresentadas as seguintes colunas por omissão:"

#. Tag: guilabel
#: taskganttview.docbook:33
#, no-c-format
msgid "Column"
msgstr "Coluna"

#. Tag: guilabel
#: taskganttview.docbook:34
#, no-c-format
msgid "<guilabel>Description</guilabel>"
msgstr "<guilabel>Descrição</guilabel>"

#. Tag: para
#: taskganttview.docbook:40
#, no-c-format
msgid "Name"
msgstr "Nome"

#. Tag: para
#: taskganttview.docbook:43
#, no-c-format
msgid "The name of the task."
msgstr "O nome da tarefa."

#. Tag: para
#: taskganttview.docbook:48
#, no-c-format
msgid "Start Time"
msgstr "Hora Inicial"

#. Tag: para
#: taskganttview.docbook:51
#, no-c-format
msgid "The scheduled start time."
msgstr "A hora de início agendada."

#. Tag: para
#: taskganttview.docbook:56
#, no-c-format
msgid "End Time"
msgstr "Hora Final"

#. Tag: para
#: taskganttview.docbook:59
#, no-c-format
msgid "The scheduled end time."
msgstr "A hora de fim agendada."

#. Tag: para
#: taskganttview.docbook:64
#, no-c-format
msgid "% Completed"
msgstr "% Completa"

#. Tag: para
#: taskganttview.docbook:67
#, no-c-format
msgid "Completion"
msgstr "Completação"

#. Tag: title
#: taskganttview.docbook:74
#, no-c-format
msgid "Configuration"
msgstr "Configuração"

#. Tag: para
#: taskganttview.docbook:81
#, no-c-format
msgid ""
"Using the context menu, the view can be configured using the configure "
"dialog."
msgstr ""
"Se usar o menu de contexto, a área pode ser configuradas se usar a janela de "
"configuração."

#. Tag: para
#: taskganttview.docbook:82
#, no-c-format
msgid ""
"The configure dialog enables you to tailor the amount of information the "
"view displays to fit your needs."
msgstr ""
"A janela de configuração permite-lhe ajustar a quantidade de informação que "
"a área apresenta de acordo com as suas necessidades."

