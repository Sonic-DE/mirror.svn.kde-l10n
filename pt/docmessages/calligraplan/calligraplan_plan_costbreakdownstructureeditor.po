msgstr "<guilabel>Descrição</guilabel>"

#. Tag: para
#: costbreakdownstructureeditor.docbook:40
#, no-c-format
msgid "Add Account"
msgstr "Adicionar uma Conta"

#. Tag: keycombo
#: costbreakdownstructureeditor.docbook:43
#, no-c-format
msgid "&Ctrl;<keycap>I</keycap>"
msgstr "&Ctrl;<keycap>I</keycap>"

#. Tag: para
#: costbreakdownstructureeditor.docbook:46
#, no-c-format
msgid ""
"Button to create an account. The new account is inserted after the selected "
"account. If no account is selected, the new account is appended at the top "
"level."
msgstr ""
"Botão para criar uma conta. A nova conta será inserida a seguir à "
"seleccionada. Se não estiver seleccionada nenhuma conta, a conta nova será "
"adicionada ao nível de topo."

#. Tag: para
#: costbreakdownstructureeditor.docbook:51
#, no-c-format
msgid "Add Subaccount"
msgstr "Adicionar uma Sub-Conta"

#. Tag: keycombo
#: costbreakdownstructureeditor.docbook:54
#, no-c-format
msgid "&Ctrl;&Shift;<keycap>I</keycap>"
msgstr "&Ctrl;&Shift;<keycap>I</keycap>"

#. Tag: para
#: costbreakdownstructureeditor.docbook:57
#, no-c-format
msgid ""
"Button to create a sub-account. The new account is appended as a child to "
"selected account."
msgstr ""
"Botão para criar uma sub-conta. A nova conta será adicionada como filha da "
"conta seleccionada."

#. Tag: para
#: costbreakdownstructureeditor.docbook:62
#, no-c-format
msgid "<para>Delete</para>"
msgstr "<para>Apagar</para>"

#. Tag: keycap
#: costbreakdownstructureeditor.docbook:65
#, no-c-format
msgid "<keycap>Delete</keycap>"
msgstr "<keycap>Delete</keycap>"

#. Tag: para
#: costbreakdownstructureeditor.docbook:68
#, no-c-format
msgid "Deletes the selected account."
msgstr "Apaga a conta seleccionada."

#. Tag: title
#: costbreakdownstructureeditor.docbook:75
#, no-c-format
msgid "Editing data"
msgstr "Editar os dados"

#. Tag: para
#: costbreakdownstructureeditor.docbook:76
#, no-c-format
msgid ""
"Data can be edited inline as described <link linkend=\"using-the-views"
"\">here</link>."
msgstr ""
"Os dados poderão ser editados no local como descrito <link linkend=\"using-"
"the-views\">aqui</link>."

