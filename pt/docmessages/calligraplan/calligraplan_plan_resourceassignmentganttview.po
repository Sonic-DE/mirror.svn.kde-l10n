#. Tag: title
#: resourceassignmentganttview.docbook:2
#, no-c-format
msgid "<title>Description</title>"
msgstr "<title>Descrição</title>"

#. Tag: para
#: resourceassignmentganttview.docbook:3
#, no-c-format
msgid ""
"The Resource Assignment Gantt View displays the scheduled task-resource "
"assignments in a Gantt chart."
msgstr ""
"O Diagrama de Gantt de Atribuição de Recursos mostra as atribuições de "
"recursos às tarefas agendadas, sob a forma de um diagrama de Gantt."

#. Tag: title
#: resourceassignmentganttview.docbook:24
#, no-c-format
msgid "Data"
msgstr "Dados"

#. Tag: para
#: resourceassignmentganttview.docbook:25
#, no-c-format
msgid "The following columns are displayed as default:"
msgstr "São apresentadas as seguintes colunas por omissão:"

#. Tag: guilabel
#: resourceassignmentganttview.docbook:32
#, no-c-format
msgid "Column"
msgstr "Coluna"

#. Tag: guilabel
#: resourceassignmentganttview.docbook:33
#, no-c-format
msgid "<guilabel>Description</guilabel>"
msgstr "<guilabel>Descrição</guilabel>"

#. Tag: para
#: resourceassignmentganttview.docbook:39
#, no-c-format
msgid "Name"
msgstr "Nome"

#. Tag: para
#: resourceassignmentganttview.docbook:42
#, no-c-format
msgid "The name of the object (Resource group, resource, task)"
msgstr "O nome do objecto (Grupo de recursos, recurso, tarefa)"

#. Tag: para
#: resourceassignmentganttview.docbook:47
#, no-c-format
msgid "Type"
msgstr "Tipo"

#. Tag: para
#: resourceassignmentganttview.docbook:50
#, no-c-format
msgid "Object type"
msgstr "Tipo do objecto"

#. Tag: para
#: resourceassignmentganttview.docbook:55
#, no-c-format
msgid "Start Time"
msgstr "Hora Inicial"

#. Tag: para
#: resourceassignmentganttview.docbook:58
#, no-c-format
msgid "The start of the assignment"
msgstr "O início da atribuição"

#. Tag: para
#: resourceassignmentganttview.docbook:63
#, no-c-format
msgid "End Time"
msgstr "Hora Final"

#. Tag: para
#: resourceassignmentganttview.docbook:66
#, no-c-format
msgid "The end of the assignment"
msgstr "O fim da atribuição"

#. Tag: title
#: resourceassignmentganttview.docbook:73
#, no-c-format
msgid "Editing data"
msgstr "Editar os dados"

#. Tag: para
#: resourceassignmentganttview.docbook:74
#, no-c-format
msgid "The task description and progress can be edited using the context menu."
msgstr ""
"A descrição e a evolução da tarefa podem ser editadas com o menu de contexto."

#. Tag: title
#: resourceassignmentganttview.docbook:77
#, no-c-format
msgid "Configuration"
msgstr "Configuração"

#. Tag: para
#: resourceassignmentganttview.docbook:84
#, no-c-format
msgid ""
"Using the context menu, the view can be configured using the configure "
"dialog."
msgstr ""
"Se usar o menu de contexto, a área pode ser configuradas se usar a janela de "
"configuração."

#. Tag: para
#: resourceassignmentganttview.docbook:84
#, no-c-format
msgid "The configure dialog enables you to select which columns to display."
msgstr ""
"A janela de configuração permite-lhe seleccionar quais as colunas a mostrar."

#. Tag: phrase
#: resourceassignmentganttview.docbook:97
#, no-c-format
msgid "<phrase>Configuration Dialog</phrase>"
msgstr "<phrase>Janela de Configuração</phrase>"

