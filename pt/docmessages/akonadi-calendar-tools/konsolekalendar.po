msgstr ""
"<option>--end-time</option> <replaceable>&nbsp;hora-final</replaceable>"

#. Tag: entry
#: index.docbook:563
#, no-c-format
msgid "End at this time [HH:MM]. Default end-time for viewing is 17:00."
msgstr ""
"Termina nesta hora [HH:MM]. O valor por omissão para a visualização é as "
