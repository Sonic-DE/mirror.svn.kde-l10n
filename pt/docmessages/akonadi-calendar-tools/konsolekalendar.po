msgstr "Adiciona o sumário ao evento (funciona com adicionar e modificar)."

#. Tag: entry
#: index.docbook:583
#, no-c-format
msgid ""
"<option>--description</option> <replaceable>&nbsp;description</replaceable>"
msgstr ""
"<option>--description</option> <replaceable>&nbsp;descrição</replaceable>"

#. Tag: entry
#: index.docbook:585
#, no-c-format
msgid "Add description to event (works with add and change)."
msgstr "Adiciona a descrição ao evento (funciona com adicionar e modificar)."

#. Tag: entry
#: index.docbook:588
#, no-c-format
msgid "<option>--location</option> <replaceable>&nbsp;location</replaceable>"
msgstr ""
"<option>--location</option> <replaceable>&nbsp;localização</replaceable>"

#. Tag: entry
#: index.docbook:590
#, no-c-format
msgid "Add location to event (works with add and change)."
msgstr "Adiciona a localização ao evento (funciona com adicionar e modificar)."

#. Tag: entry
#: index.docbook:593
#, no-c-format
msgid "<option>--calendar</option> <replaceable>&nbsp;id</replaceable>"
msgstr "<option>--calendar</option> <replaceable>&nbsp;id</replaceable>"

#. Tag: entry
#: index.docbook:595
#, no-c-format
msgid "Specify a calendar to use."
msgstr "Indica um calendário a utilizar."

#. Tag: para
#: index.docbook:596
#, no-c-format
msgid "If not specified then your default &korganizer; resource is used."
