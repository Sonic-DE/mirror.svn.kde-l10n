msgstr "Opções de exportação:"

#. Tag: entry
#: index.docbook:602
#, no-c-format
msgid ""
"<option>--export-type</option> <replaceable>&nbsp;export-type</replaceable>"
msgstr ""
"<option>--export-type</option> <replaceable>&nbsp;tipo-de-exportação</"
"replaceable>"

#. Tag: entry
#: index.docbook:604
#, no-c-format
msgid "Export file type. Default export file type is Text"
msgstr ""
"O tipo do ficheiro de exportação. O tipo de exportação por omissão é o Texto"

#. Tag: entry
#: index.docbook:608
#, no-c-format
