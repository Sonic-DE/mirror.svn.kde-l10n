#: features.docbook:26
#, no-c-format
msgid "Filled polygons"
msgstr "Polígonos preenchidos"

#. Tag: para
#: features.docbook:27
#, no-c-format
msgid "Painting"
msgstr "Pintura"

#. Tag: para
#: features.docbook:28
#, no-c-format
msgid "Lines"
msgstr "Linhas"

#. Tag: para
#: features.docbook:29
#, no-c-format
msgid "Erasing stitches, knots and backstitches"
msgstr "Remoção de pontos, nós e pontos traseiros"

