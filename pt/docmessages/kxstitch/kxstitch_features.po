#: features.docbook:30
#, no-c-format
msgid "Color selection from existing stitches"
msgstr "Selecção de cores dos pontos existentes"

#. Tag: para
#: features.docbook:31
#, no-c-format
msgid "Swapping two colors"
msgstr "Troca de duas cores"

