#: features.docbook:33
#, no-c-format
msgid "Text with user defined fonts and sizes"
msgstr "Texto com tamanhos e tipos de letra definidos pelo utilizador"

#. Tag: para
#: features.docbook:34
#, no-c-format
msgid "Cut, copy and paste of rectangular areas."
msgstr "Cortar, copiar e colar áreas rectangulares."

#. Tag: para
#: features.docbook:35
#, no-c-format
msgid "Unlimited undo and redo"
msgstr "Operações 'desfazer' e 'refazer' ilimitadas"

#. Tag: para
#: features.docbook:36
#, no-c-format
msgid "Mirroring, horizontally and vertically."
msgstr "Espelho horizontal e vertical."

#. Tag: para
#: features.docbook:37
#, no-c-format
msgid "Rotation, 90, 180 and 270 degrees anti clockwise."
msgstr "Rotação em 90, 180, 270 graus e no sentido anti-horário."

#. Tag: para
#: features.docbook:38
#, no-c-format
msgid "Resizing of the canvas"
msgstr "Mudança de tamanho da tela"

#. Tag: para
#: features.docbook:40
#, no-c-format
msgid "Extend canvas left, top, right, bottom"
msgstr "Estender a tela para a esquerda, direita, cima ou baixo"

#. Tag: para
#: features.docbook:41
#, no-c-format
msgid "Cropping canvas to pattern"
msgstr "Recortar a tela ao padrão"

#. Tag: para
#: features.docbook:42
#, no-c-format
msgid "Cropping canvas to selection"
msgstr "Recortar a tela à selecção"

#. Tag: para
#: features.docbook:43
#, no-c-format
msgid "Inserting rows and columns"
msgstr "Inserir linhas e colunas"

#. Tag: para
#: features.docbook:44
#, no-c-format
msgid "Center the pattern on the canvas"
msgstr "Centrar o padrão na tela"

#. Tag: para
#: features.docbook:47
#, no-c-format
msgid "Conversion between floss schemes"
msgstr "Conversão entre esquemas de novelos"

#. Tag: para
#: features.docbook:50
#, no-c-format
msgid "Use of standard floss pallets, DMC, Anchor, etc."
msgstr "Usar paletas-padrão de novelos, como a DMC, a Anchor, etc."

#. Tag: para
#: features.docbook:51
#, no-c-format
msgid "Create customized floss pallets"
msgstr "Criar paletas de novelos personalizadas"

#. Tag: para
#: features.docbook:52
#, no-c-format
msgid "Create new colors for any floss pallet"
msgstr "Criar novas cores para qualquer paleta de novelos"

#. Tag: para
#: features.docbook:53
#, no-c-format
msgid "Save / Load current palette"
msgstr "Gravar / Carregar a paleta actual"

#. Tag: para
#: features.docbook:54
#, no-c-format
msgid "Use of standard stitches"
msgstr "Usar pontos-padrão"

#. Tag: para
#: features.docbook:55
#, no-c-format
msgid "Pattern library manager"
msgstr "Gestor da biblioteca de padrões"

#. Tag: para
#: features.docbook:57
#, no-c-format
msgid "Create new library patterns"
msgstr "Criar novos padrões nas bibliotecas"

#. Tag: para
#: features.docbook:58
#, no-c-format
msgid "Insert library patterns into a design"
msgstr "Inserir padrões da biblioteca num desenho"

#. Tag: para
#: features.docbook:59
#, no-c-format
msgid "Drag and drop from the library to the pattern"
msgstr "Arrastar e largar da biblioteca no padrão"

#. Tag: para
#: features.docbook:60
#, no-c-format
msgid "Drag and drop from one library to another"
msgstr "Arrastar e largar de uma biblioteca para outra"

#. Tag: para
#: features.docbook:61
#, no-c-format
msgid "Assign key press to patterns for use with the Alphabet tool"
msgstr "Atribuir teclas a padrões para usar com a ferramenta do Alfabeto"

#. Tag: para
#: features.docbook:64
#, no-c-format
msgid "Free use of backstitching"
msgstr "Utilização livre de pontos traseiros"

#. Tag: para
#: features.docbook:65
#, no-c-format
msgid "Printing of completed patterns and floss keys"
msgstr "Impressão dos padrões completos e das chaves dos novelos"

#. Tag: para
#: features.docbook:67
#, no-c-format
msgid "Pattern image"
msgstr "Imagem do padrão"

#. Tag: para
#: features.docbook:68
#, no-c-format
msgid "Instructions"
msgstr "Instruções"

#. Tag: para
#: features.docbook:69
#, no-c-format
msgid "Floss key and stitch summary"
msgstr "Resumo de chaves de novelos e dos pontos"

#. Tag: para
#: features.docbook:70
#, no-c-format
msgid "Pattern chart with page map"
msgstr "Gráfico de padrões com o mapa da página"

#. Tag: para
#: features.docbook:71
#, no-c-format
msgid "Text boxes"
msgstr "Campos de texto"

#. Tag: para
#: features.docbook:74
#, no-c-format
msgid "Mapping of symbols to flosses"
msgstr "Associação de símbolos aos novelos"

#. Tag: para
#: features.docbook:75
#, no-c-format
msgid "Specify the number of threads for stitches and backstitches"
msgstr "Indicar o número de fios para os pontos e pontos traseiros"

#. Tag: para
#: features.docbook:76
#, no-c-format
msgid "Calibration of floss colors"
msgstr "Calibração das cores dos novelos"

