#. Tag: title
#: features.docbook:2
#, no-c-format
msgid "Features"
msgstr "Características"

#. Tag: para
#: features.docbook:3
#, no-c-format
msgid "The current feature list and other planned features is shown here."
msgstr ""
"A lista de funcionalidades actuais e de outras planeadas é apresentada aqui."

#. Tag: para
#: features.docbook:5
#, no-c-format
msgid "Creation of new patterns"
msgstr "Criação de novos padrões"

#. Tag: para
#: features.docbook:7
#, no-c-format
msgid "User defined size"
msgstr "Tamanho definido pelo utilizador"

#. Tag: para
#: features.docbook:8
#, no-c-format
msgid "Selection of material color"
msgstr "Selecção da cor do material"

#. Tag: para
#: features.docbook:9
#, no-c-format
msgid "Insertion of a background images for tracing"
msgstr "Inserção de imagens de fundo para ajuda"

#. Tag: para
#: features.docbook:10
#, no-c-format
msgid "Importing of various image formats"
msgstr "Importação de vários formatos de imagens"

#. Tag: para
#: features.docbook:11
#, no-c-format
msgid "Importing options allow"
msgstr "As opções de importação permitem"

#. Tag: para
#: features.docbook:13
#, no-c-format
msgid "Limiting the number of colors"
msgstr "Limitar o número de cores"

