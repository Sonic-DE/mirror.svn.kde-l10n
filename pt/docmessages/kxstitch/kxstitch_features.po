#: features.docbook:22
#, no-c-format
msgid "Editing of existing patterns, Editing tools will include"
msgstr "Edição dos padrões existentes. As ferramentas de edição irão incluir"

#. Tag: para
#: features.docbook:24
#, no-c-format
msgid "Open and filled rectangles"
msgstr "Rectângulos vazios e preenchidos"

