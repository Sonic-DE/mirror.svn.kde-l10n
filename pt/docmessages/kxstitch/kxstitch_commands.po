#. Tag: action
#: commands.docbook:100
#, no-c-format
msgid "Limit selections to the currently selected color"
msgstr "Limita as selecção apenas à cor seleccionada de momento"

#. Tag: menuchoice
#: commands.docbook:102
#, no-c-format
msgid ""
"<guisubmenu>Selection Masks</guisubmenu><guimenuitem>Exclude Backstitches</"
"guimenuitem>"
msgstr ""
"<guisubmenu>Máscaras de Selecção</guisubmenu><guimenuitem>Excluir os Pontos "
