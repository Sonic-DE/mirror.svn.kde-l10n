#. Tag: title
#: man-kdiff3.1.docbook:8
#, no-c-format
msgid "KDiff3 User's Manual"
msgstr "Manual de Utilizador do KDiff3"

#. Tag: author
#: man-kdiff3.1.docbook:9
#, no-c-format
msgid ""
"<firstname>Burkhard</firstname><surname>Lueck</surname> <contrib>KDiff3 man "
"page.</contrib> &Burkhard.Lueck.mail;"
msgstr ""
"<firstname>Burkhard</firstname><surname>Lueck</surname> <contrib>Página de "
"manual do KDiff3.</contrib> &Burkhard.Lueck.mail;"

#. Tag: date
#: man-kdiff3.1.docbook:13
#, no-c-format
msgid "2019-02-22"
msgstr "2019-02-22"

#. Tag: releaseinfo
#: man-kdiff3.1.docbook:14
#, no-c-format
msgid "kdiff3 1.8"
msgstr "kdiff3 1.8"

#. Tag: manvolnum
#: man-kdiff3.1.docbook:19
#, no-c-format
msgid "<manvolnum>1</manvolnum>"
msgstr "<manvolnum>1</manvolnum>"

#. Tag: refpurpose
#: man-kdiff3.1.docbook:24
#, no-c-format
msgid "Tool for Comparison and Merge of Files and Folders"
msgstr "Ferramenta para Comparação e Junção de Ficheiros e Pastas"

#. Tag: cmdsynopsis
#: man-kdiff3.1.docbook:28
#, no-c-format
msgid ""
"<command>kdiff3</command> <arg choice=\"opt\"><option>-u, --ignore</option></"
"arg> <arg choice=\"opt\"><option>--query</option></arg> <arg choice=\"opt"
"\"><option>--html</option></arg> <arg choice=\"opt\"><option>--abort</"
"option></arg> <arg choice=\"opt\"><option>-m, --merge</option></arg> <arg "
"choice=\"opt\"><option>-b, --base</option> <replaceable>file</replaceable></"
"arg> <arg choice=\"opt\"><option>-o, --output</option> <replaceable>file</"
"replaceable></arg> <arg choice=\"opt\"><option>--out</option> "
"<replaceable>file</replaceable></arg> <arg choice=\"opt\"><option>--noauto</"
"option></arg> <arg choice=\"opt\"><option>--auto</option></arg> <arg choice="
"\"opt\"><option>--L1</option> <replaceable>alias1</replaceable></arg> <arg "
"choice=\"opt\"><option>--L2</option> <replaceable>alias2</replaceable></arg> "
"<arg choice=\"opt\"><option>--L3</option> <replaceable>alias3</replaceable></"
"arg> <arg choice=\"opt\"><option>-L, --fname</option> <replaceable>alias</"
"replaceable></arg> <arg choice=\"opt\"><option>--cs</option> "
"<replaceable>string</replaceable></arg> <arg choice=\"opt\"><option>--"
"confighelp</option></arg> <arg choice=\"opt\"><option>--config</option> "
"<replaceable>file</replaceable></arg> <arg choice=\"opt"
"\"><option><replaceable>File1</replaceable></option></arg> <arg choice=\"opt"
"\"><option><replaceable>File2</replaceable></option></arg> <arg choice=\"opt"
"\"><option><replaceable>File3</replaceable></option></arg>"
msgstr ""
"<command>kdiff3</command> <arg choice=\"opt\"><option>-u, --ignore</option></"
"arg> <arg choice=\"opt\"><option>--query</option></arg> <arg choice=\"opt"
"\"><option>--html</option></arg> <arg choice=\"opt\"><option>--abort</"
"option></arg> <arg choice=\"opt\"><option>-m, --merge</option></arg> <arg "
"choice=\"opt\"><option>-b, --base</option> <replaceable>ficheiro</"
"replaceable></arg> <arg choice=\"opt\"><option>-o, --output</option> "
"<replaceable>ficheiro</replaceable></arg> <arg choice=\"opt\"><option>--out</"
"option> <replaceable>ficheiro</replaceable></arg> <arg choice=\"opt"
"\"><option>--noauto</option></arg> <arg choice=\"opt\"><option>--auto</"
"option></arg> <arg choice=\"opt\"><option>--L1</option> <replaceable>nome1</"
"replaceable></arg> <arg choice=\"opt\"><option>--L2</option> "
"<replaceable>nome2</replaceable></arg> <arg choice=\"opt\"><option>--L3</"
"option> <replaceable>nome3</replaceable></arg> <arg choice=\"opt\"><option>-"
"L, --fname</option> <replaceable>nome</replaceable></arg> <arg choice=\"opt"
"\"><option>--cs</option> <replaceable>texto</replaceable></arg> <arg choice="
"\"opt\"><option>--confighelp</option></arg> <arg choice=\"opt\"><option>--"
"config</option> <replaceable>ficheiro</replaceable></arg> <arg choice=\"opt"
"\"><option><replaceable>Ficheiro1</replaceable></option></arg> <arg choice="
"\"opt\"><option><replaceable>Ficheiro2</replaceable></option></arg> <arg "
"choice=\"opt\"><option><replaceable>Ficheiro3</replaceable></option></arg>"

#. Tag: title
#: man-kdiff3.1.docbook:54
#, no-c-format
msgid "Description"
msgstr "Descrição"

#. Tag: para
#: man-kdiff3.1.docbook:55
#, no-c-format
msgid "Compares two or three input files or folders."
msgstr "Compara dois ou três ficheiros ou pastas de entrada."

#. Tag: title
#: man-kdiff3.1.docbook:60
#, no-c-format
msgid "Options"
msgstr "Opções"

#. Tag: option
#: man-kdiff3.1.docbook:63
#, no-c-format
msgid "-u, --ignore"
msgstr "-u, --ignore"

#. Tag: para
#: man-kdiff3.1.docbook:64 man-kdiff3.1.docbook:70 man-kdiff3.1.docbook:76
#: man-kdiff3.1.docbook:82
#, no-c-format
msgid "Ignored. (User defined.)"
msgstr "Ignorado. (Definido pelo utilizador.)"

#. Tag: option
#: man-kdiff3.1.docbook:69
#, no-c-format
msgid "--query"
msgstr "--query"

#. Tag: option
#: man-kdiff3.1.docbook:75
#, no-c-format
msgid "--html"
msgstr "--html"

#. Tag: option
#: man-kdiff3.1.docbook:81
#, no-c-format
msgid "--abort"
msgstr "--abort"

#. Tag: option
#: man-kdiff3.1.docbook:87
#, no-c-format
msgid "-m, --merge"
msgstr "-m, --merge"

#. Tag: para
#: man-kdiff3.1.docbook:88
#, no-c-format
msgid "Merge the input."
msgstr "Juntar a entrada."

#. Tag: term
#: man-kdiff3.1.docbook:93
#, no-c-format
msgid "<option>-b, --base</option> <replaceable>file</replaceable>"
msgstr "<option>-b, --base</option> <replaceable>ficheiro</replaceable>"

#. Tag: para
#: man-kdiff3.1.docbook:94
#, no-c-format
msgid "Explicit base file. For compatibility with certain tools."
msgstr ""
"Ficheiro de base explícito. Para a compatibilidade com certas ferramentas."

#. Tag: term
#: man-kdiff3.1.docbook:99
#, no-c-format
msgid "<option>-o, --output</option> <replaceable>file</replaceable>"
msgstr "<option>-o, --output</option> <replaceable>ficheiro</replaceable>"

#. Tag: para
#: man-kdiff3.1.docbook:100
#, no-c-format
msgid "Output file. Implies -m. &eg;: -o newfile.txt"
msgstr "Ficheiro de saída. Implica o '-m'. &eg;: -o novo-ficheiro.txt"

#. Tag: term
#: man-kdiff3.1.docbook:105
#, no-c-format
msgid "<option>--out</option> <replaceable>file</replaceable>"
msgstr "<option>--out</option> <replaceable>ficheiro</replaceable>"

#. Tag: para
#: man-kdiff3.1.docbook:106
#, no-c-format
msgid "Output file, again. (For compatibility with certain tools.)"
msgstr ""
"Ficheiro de saída, de novo. (para a compatibilidade com certas ferramentas)"

#. Tag: option
#: man-kdiff3.1.docbook:111
#, no-c-format
msgid "--auto"
msgstr "--auto"

#. Tag: para
#: man-kdiff3.1.docbook:112
#, no-c-format
msgid ""
"No GUI if all conflicts are auto-solvable. (Needs <option>-o</option> "
"<replaceable>file</replaceable>)"
msgstr ""
"Sem interface gráfica, caso todos os conflitos se resolvam automaticamente. "
"(Necessita da opção <option>-o</option> <replaceable>ficheiro</replaceable>)"

#. Tag: option
#: man-kdiff3.1.docbook:118
#, no-c-format
msgid "--noauto"
msgstr "--noauto"

#. Tag: para
#: man-kdiff3.1.docbook:119
#, no-c-format
msgid "Ignore --auto and always show GUI."
msgstr "Ignora o --auto e mostra sempre a interface."

#. Tag: term
#: man-kdiff3.1.docbook:124
#, no-c-format
msgid "<option>--L1</option> <replaceable>alias1</replaceable>"
msgstr "<option>--L1</option> <replaceable>nome1</replaceable>"

#. Tag: para
#: man-kdiff3.1.docbook:125
#, no-c-format
msgid "Visible name replacement for input file 1 (base)."
msgstr "Substituição do nome visível para o ficheiro de entrada 1 (base)."

#. Tag: term
#: man-kdiff3.1.docbook:130
#, no-c-format
msgid "<option>--L2</option> <replaceable>alias2</replaceable>"
msgstr "<option>--L2</option> <replaceable>nome2</replaceable>"

#. Tag: para
#: man-kdiff3.1.docbook:131
#, no-c-format
msgid "Visible name replacement for input file 2."
msgstr "Substituição do nome visível para o ficheiro de entrada 2."

#. Tag: term
#: man-kdiff3.1.docbook:136
#, no-c-format
msgid "<option>--L3</option> <replaceable>alias3</replaceable>"
msgstr "<option>--L3</option> <replaceable>nome3</replaceable>"

#. Tag: para
#: man-kdiff3.1.docbook:137
#, no-c-format
msgid "Visible name replacement for input file 3."
msgstr "Substituição do nome visível para o ficheiro de entrada 3."

#. Tag: term
#: man-kdiff3.1.docbook:142
#, no-c-format
msgid "<option>-L, --fname</option> <replaceable>alias</replaceable>"
msgstr "<option>-L, --fname</option> <replaceable>nome</replaceable>"

#. Tag: para
#: man-kdiff3.1.docbook:143
#, no-c-format
msgid "Alternative visible name replacement. Supply this once for every input."
msgstr ""
"Substituição alternativa do nome visível. Indique isto para cada entrada."

#. Tag: term
#: man-kdiff3.1.docbook:148
#, no-c-format
msgid "<option>--cs</option> <replaceable>string</replaceable>"
msgstr "<option>--cs</option> <replaceable>texto</replaceable>"

#. Tag: para
#: man-kdiff3.1.docbook:149
#, no-c-format
msgid ""
"Override a config setting. Use once for every setting. &eg;: <option>--cs</"
"option> <replaceable>AutoAdvance=1</replaceable>."
msgstr ""
"Substitui uma opção de configuração. Use uma vez para cada opção. &eg;: "
"<option>--cs</option> <replaceable>AutoAdvance=1</replaceable>."

#. Tag: option
#: man-kdiff3.1.docbook:155
#, no-c-format
msgid "--confighelp"
msgstr "--confighelp"

#. Tag: para
#: man-kdiff3.1.docbook:156
#, no-c-format
msgid "Show list of config settings and current values."
msgstr "Mostra uma lista das opções de configuração e os valores actuais."

#. Tag: term
#: man-kdiff3.1.docbook:161
#, no-c-format
msgid "<option>--config</option> <replaceable>file</replaceable>"
msgstr "<option>--config</option> <replaceable>ficheiro</replaceable>"

#. Tag: para
#: man-kdiff3.1.docbook:162
#, no-c-format
msgid "Use a different config file."
msgstr "Usar um ficheiro de configuração diferente."

#. Tag: replaceable
#: man-kdiff3.1.docbook:167
#, no-c-format
msgid "File1"
msgstr "Ficheiro1"

#. Tag: para
#: man-kdiff3.1.docbook:168
#, no-c-format
msgid "file1 to open (base, if not specified via --<option>base</option>)"
msgstr ""
"o ficheiro 1 a abrir (a base, se não for definida explicitamente através do "
"--<option>base</option>)"

#. Tag: replaceable
#: man-kdiff3.1.docbook:173
#, no-c-format
msgid "File2"
msgstr "Ficheiro2"

#. Tag: para
#: man-kdiff3.1.docbook:174
#, no-c-format
msgid "file2 to open"
msgstr "o ficheiro 2 a abrir"

#. Tag: replaceable
#: man-kdiff3.1.docbook:179
#, no-c-format
msgid "File3"
msgstr "Ficheiro3"

#. Tag: para
#: man-kdiff3.1.docbook:180
#, no-c-format
msgid "file3 to open"
msgstr "o ficheiro 3 a abrir"

#. Tag: title
#: man-kdiff3.1.docbook:189
#, no-c-format
msgid "See Also"
msgstr "Veja Também"

#. Tag: member
#: man-kdiff3.1.docbook:191
#, no-c-format
msgid ""
"More detailed user documentation is available from <ulink url=\"help:/"
"kdiff3\">help:/kdiff3</ulink> (either enter this &URL; into &konqueror;, or "
"run <userinput><command>khelpcenter</command> <parameter>help:/kdiff3</"
"parameter></userinput>)."
msgstr ""
"Está disponível mais alguma documentação detalhada em <ulink url=\"help:/"
"kdiff3\">help:/kdiff3</ulink> (tanto pode indicar este &URL; no &konqueror;, "
"como executar <userinput><command>khelpcenter</command> <parameter>help:/"
"kdiff3</parameter></userinput>)."

