msgstr "Opta por iniciar um ataque com um exército."

#. Tag: filename
#: index.docbook:559
#, no-c-format
msgid "attackTwo.png"
msgstr "attackTwo.png"

#. Tag: entry
#: index.docbook:560
#, no-c-format
msgid "Chooses to start an attack with two armies."
msgstr "Opta por iniciar um ataque com dois exércitos."

#. Tag: filename
#: index.docbook:564
#, no-c-format
msgid "attackThree.png"
msgstr "attackThree.png"

#. Tag: entry
#: index.docbook:565
#, no-c-format
msgid "Chooses to start an attack with three armies."
msgstr "Opta por iniciar um ataque com três exércitos."

#. Tag: filename
#: index.docbook:569
#, no-c-format
msgid "defendOne.png"
msgstr "defendOne.png"

#. Tag: entry
#: index.docbook:570
#, no-c-format
msgid "Chooses to defend an attacked country with one army."
msgstr "Opta por defender um país atacado com um exército."

#. Tag: filename
#: index.docbook:574
#, no-c-format
msgid "defendTwo.png"
msgstr "defendTwo.png"

#. Tag: entry
#: index.docbook:575
#, no-c-format
msgid "Chooses to defend an attacked country with two armies."
msgstr "Opta por defender um país atacado com dois exércitos."

#. Tag: filename
#: index.docbook:579
#, no-c-format
msgid "moveArmies.png"
msgstr "moveArmies.png"

#. Tag: entry
#: index.docbook:580
#, no-c-format
msgid ""
"Chooses to start the moving of armies between two countries (last action in "
"the turn)."
msgstr ""
"Opta por iniciar o movimento de exércitos entre dois países (última acção da "
"jogada)."

#. Tag: title
#: index.docbook:589
#, no-c-format
msgid "The Sounds folder"
msgstr "A pasta 'Sounds'"

#. Tag: para
