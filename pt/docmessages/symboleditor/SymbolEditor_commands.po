#, no-c-format
msgid "Saves the library under a new name"
msgstr "Grava a biblioteca com um novo nome"

#. Tag: guimenuitem
#: commands.docbook:31
#, no-c-format
msgid "Save Symbol"
msgstr "Gravar o Símbolo"

#. Tag: listitem
#: commands.docbook:32
#, no-c-format
msgid ""
"<simpara><action>Save the symbol being edited</action></simpara> <simpara>If "
"the symbol being edited was selected from the library, saving will update "
"that symbol. If it is a new symbol, it will be appended to the library and "
"subsequent saves will append another new symbol to the library. </simpara>"
msgstr ""
"<simpara><action>Grava o símbolo a ser editado de momento</action></simpara> "
"<simpara>Se o símbolo a ser editado foi seleccionado a partir da biblioteca, "
"a gravação irá actualizar esse símbolo. Se for um símbolo novo, será "
"adicionado à biblioteca e as gravações subsequentes irão adicionar um novo "
"símbolo à biblioteca.</simpara>"

#. Tag: guimenuitem
#: commands.docbook:39
#, no-c-format
msgid "Save Symbol as New"
msgstr "Gravar o Símbolo como Novo"

#. Tag: listitem
#: commands.docbook:40
#, no-c-format
msgid ""
"<simpara><action>Save the symbol being edited as a new symbol</action></"
"simpara> <simpara>When a symbol is saved as new it will be appended to the "
"library regardless of it having originally been selected from the library "
"for editing. Subsequent saves will append another new symbol to the library. "
"</simpara>"
msgstr ""
"<simpara><action>Grava o símbolo a ser editado como um novo símbolo</"
"action></simpara> <simpara>Quando um novo símbolo for gravado como novo, ele "
"será adicionado à biblioteca, independentemente de ter sido originalmente "
"seleccionado a partir da biblioteca para edição. As gravações subsequentes "
"irão adicionar outro símbolo novo à biblioteca.</simpara>"

#. Tag: guimenuitem
#: commands.docbook:47
#, no-c-format
msgid "Import Library"
msgstr "Importar uma Biblioteca"

#. Tag: action
#: commands.docbook:48
#, no-c-format
msgid ""
"Import a library appending the contained symbols into the current library"
msgstr ""
"Importa uma biblioteca, adicionando os símbolos contidos à biblioteca actual"

