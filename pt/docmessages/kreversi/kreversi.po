#, no-c-format
msgid ""
"Each player automatically has two stones placed in the center four squares "
"of the board in the following pattern:"
msgstr ""
"Cada jogador tem automaticamente dois discos colocados automaticamente nos "
"quatro quadrados do centro do tabuleiro, com o seguinte padrão:"

#. Tag: screeninfo
#: index.docbook:129
#, no-c-format
msgid "<screeninfo>&kreversi; opening position</screeninfo>"
msgstr "<screeninfo>Posição de abertura do &kreversi;</screeninfo>"

