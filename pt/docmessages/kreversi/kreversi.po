#: index.docbook:133
#, no-c-format
msgid "Board Layout"
msgstr "Disposição do Tabuleiro"

#. Tag: interface
#: index.docbook:139
#, no-c-format
msgid "Menu Bar"
msgstr "Barra de Menu"

#. Tag: para
#: index.docbook:140
#, no-c-format
msgid ""
"The <interface>Menu Bar</interface> contains several choices of drop-down "
"menus. These are <guimenu>Game</guimenu>, <guimenu>Move</guimenu>, "
"<guimenu>View</guimenu>, <guimenu>Settings</guimenu> and <guimenu>Help</"
"guimenu>. Click with the &LMB; or <keycombo action=\"simul\">&Alt;"
"<keycap>the underlined letter</keycap></keycombo> to show the drop-down menu."
msgstr ""
"A <interface>Barra de Menu</interface> contém várias opções de menu. Estas "
"são a <guimenu>Jogo</guimenu>, a <guimenu>Mover</guimenu>, a <guimenu>Ver</"
"guimenu>, a <guimenu>Configuração</guimenu> e a <guimenu>Ajuda</guimenu>. Se "
"carregar com o &LMB; ou fizer <keycombo action=\"simul\">&Alt;<keycap>a "
"tecla sublinhada</keycap></keycombo>, irá abrir o menu correspondente."

#. Tag: interface
#: index.docbook:148
#, no-c-format
msgid "Toolbar"
msgstr "Barra de Ferramentas"

