#. Tag: para
#: basic-functions.docbook:278
#, no-c-format
msgid ""
"<link linkend=\"krusearcher\">KruSearcher</link> Search results file list "
"(<keycap>F3</keycap> View, <keycap>F4</keycap> Edit)"
msgstr ""
"<link linkend=\"krusearcher\">KruSearcher</link> Lista de ficheiros dos "
"resultados da pesquisa (<keycap>F3</keycap> Ver, <keycap>F4</keycap> Editar)"

#. Tag: para
#: basic-functions.docbook:283
#, no-c-format
msgid "<link linkend=\"mount-man\">MountMan</link> (unmount, format...)"
msgstr "<link linkend=\"mount-man\">MountMan</link> (desmontar, formatar...)"

#. Tag: para
#: basic-functions.docbook:287
#, no-c-format
msgid "<link linkend=\"synchronizer\">Synchronize Folders</link> File List"
msgstr ""
"Lista de Ficheiros em <link linkend=\"synchronizer\">Sincronizar as Pastas</"
