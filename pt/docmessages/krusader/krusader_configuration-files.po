msgstr ""
"Este é um ficheiro binário que guarda o <link linkend=\"konfig-color"
"\">Esquema de Cores</link>."

#. Tag: para
#: configuration-files.docbook:144
#, no-c-format
msgid "Location: <filename>/usr/share/krusader/foo.color</filename>"
msgstr "Localização: <filename>/usr/share/krusader/xpto.color</filename>"
