"&lt;action name=\"edit_copy\"/&gt;\n"
"&lt;action name=\"edit_paste\"/&gt;\n"
"&lt;separator/&gt;\n"
"&lt;action name=\"edit_find\"/&gt;\n"
"&lt;/menu&gt;\n"
