#: commands.docbook:47
#, no-c-format
msgid ""
"<action>Open an existing document</action> by selecting it from a combo box "
"of recently used files."
msgstr ""
"<action>Abre um documento existente</action> seleccionado de uma caixa de "
"ficheiros utilizados recentemente."

#. Tag: menuchoice
#: commands.docbook:52
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>S</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Save</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>S</keycap></keycombo> </"
"shortcut> <guimenu>Ficheiro</guimenu> <guimenuitem>Gravar</guimenuitem>"

