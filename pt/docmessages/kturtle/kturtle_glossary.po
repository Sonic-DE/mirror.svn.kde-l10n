msgstr "255,0,0"

#. Tag: userinput
#: glossary.docbook:126
#, no-c-format
msgid "150,0,0"
msgstr "150,0,0"

#. Tag: userinput
#: glossary.docbook:127
#, no-c-format
msgid "0,255,0"
msgstr "0,255,0"

#. Tag: entry
#: glossary.docbook:127
#, no-c-format
msgid "green"
msgstr "verde"

#. Tag: userinput
#: glossary.docbook:128
#, no-c-format
msgid "0,0,255"
msgstr "0,0,255"

#. Tag: entry
#: glossary.docbook:128
#, no-c-format
msgid "blue"
msgstr "azul"

#. Tag: userinput
#: glossary.docbook:129
#, no-c-format
msgid "0,255,255"
msgstr "0,255,255"

#. Tag: entry
#: glossary.docbook:129
#, no-c-format
msgid "light blue"
msgstr "azul claro"

#. Tag: userinput
#: glossary.docbook:130
#, no-c-format
