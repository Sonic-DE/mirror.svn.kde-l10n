msgid "D(phi,k,n)"
msgstr "D(phi,k,n)"

#. Tag: action
#: index.docbook:1883
#, no-c-format
msgid "incomplete elliptic integral D(phi,k,n)"
msgstr "integral elíptico incompleto D(phi,k,n)"

#. Tag: entry
#: index.docbook:1884
#, no-c-format
msgid "RC(x,y)"
msgstr "RC(x,y)"

#. Tag: action
#: index.docbook:1884
#, no-c-format
msgid "incomplete elliptic integral RC(x,y)"
msgstr "integral elíptico incompleto RC(x,y)"

#. Tag: entry
#: index.docbook:1885
#, no-c-format
msgid "RD(x,y,z)"
msgstr "RD(x,y,z)"

#. Tag: action
#: index.docbook:1885
#, no-c-format
msgid "incomplete elliptic integral RD(x,y,z)"
msgstr "integral elíptico incompleto RD(x,y,z)"

#. Tag: entry
#: index.docbook:1886
#, no-c-format
msgid "RF(x,y,z)"
msgstr "RF(x,y,z)"

#. Tag: action
#: index.docbook:1886
#, no-c-format
msgid "incomplete elliptic integral RF(x,y,z)"
msgstr "integral elíptico incompleto RF(x,y,z)"

#. Tag: entry
#: index.docbook:1887
#, no-c-format
msgid "RJ(x,y,z)"
msgstr "RJ(x,y,z)"

#. Tag: action
#: index.docbook:1887
#, no-c-format
msgid "incomplete elliptic integral RJ(x,y,z,p)"
msgstr "integral elíptico incompleto RJ(x,y,z,p)"

#. Tag: entry
#: index.docbook:1888
#, no-c-format
msgid "erf(x)"
msgstr "erf(x)"

#. Tag: action
#: index.docbook:1888
#, no-c-format
msgid ""
"error function erf(x) = 2/&radic;&pi; &int;<subscript>0</"
"subscript><superscript>x</superscript> exp(-t<superscript>2</superscript>) dt"
msgstr ""
"função de erro erf(x) = 2/&radic;&pi; &int;<subscript>0</"
"subscript><superscript>x</superscript> exp(-t<superscript>2</superscript>) dt"

#. Tag: entry
#: index.docbook:1889
#, no-c-format
msgid "erfc(x)"
msgstr "erfc(x)"

#. Tag: action
#: index.docbook:1889
#, no-c-format
msgid ""
"complementary error function erfc(x) = 1 - erf(x) = 2/&radic;&pi; &int;"
"<subscript>x</subscript><superscript>&infin;</superscript> exp(-"
"t<superscript>2</superscript>) dt"
msgstr ""
"função de erro complementar erfc(x) = 1 - erf(x) = 2/&radic;&pi; &int;"
"<subscript>x</subscript><superscript>&infin;</superscript> exp(-"
"t<superscript>2</superscript>) dt"

#. Tag: entry
#: index.docbook:1890
#, no-c-format
msgid "log_erfc(x)"
msgstr "log_erfc(x)"

#. Tag: action
#: index.docbook:1890
#, no-c-format
msgid "logarithm of the complementary error function log(erfc(x))"
msgstr "logaritmo da função de erro complementar log(erfc(x))"

#. Tag: entry
#: index.docbook:1891
#, no-c-format
msgid "erf_Z(x)"
msgstr "erf_Z(x)"

#. Tag: action
#: index.docbook:1891
#, no-c-format
msgid ""
"Gaussian probability function Z(x) = (1/(2&pi;)) exp(-x<superscript>2</"
"superscript>/2)"
msgstr ""
"função de probabilidade Gaussiana Z(x) = (1/(2&pi;)) exp(-x<superscript>2</"
"superscript>/2)"

#. Tag: entry
#: index.docbook:1892
#, no-c-format
msgid "erf_Q(x)"
msgstr "erf_Q(x)"

#. Tag: action
#: index.docbook:1892
#, no-c-format
msgid ""
"upper tail of the Gaussian probability function Q(x) = (1/(2&pi;)) &int;"
"<subscript>x</subscript><superscript>&infin;</superscript> exp(-"
"t<superscript>2</superscript>/2) dt"
msgstr ""
"extremo superior da função de probabilidade Gaussiana Q(x) = (1/(2&pi;)) "
"&int;<subscript>x</subscript><superscript>&infin;</superscript> exp(-"
"t<superscript>2</superscript>/2) dt"

#. Tag: entry
#: index.docbook:1893
#, no-c-format
msgid "hazard(x)"
msgstr "hazard(x)"

#. Tag: action
#: index.docbook:1893
#, no-c-format
msgid "hazard function for the normal distribution"
msgstr "função de risco da distribuição normal"

#. Tag: entry
#: index.docbook:1894
#, no-c-format
msgid "exp(x)"
msgstr "exp(x)"

#. Tag: action
#: index.docbook:1894
#, no-c-format
msgid "Exponential, base e"
msgstr "Expoente de base 'e'"

#. Tag: entry
#: index.docbook:1895
#, no-c-format
msgid "expm1(x)"
msgstr "expm1(x)"

#. Tag: action
#: index.docbook:1895
#, no-c-format
msgid "exp(x)-1"
msgstr "exp(x)-1"

#. Tag: entry
#: index.docbook:1896
#, no-c-format
msgid "exp_mult(x,y)"
msgstr "exp_mult(x,y)"

#. Tag: action
#: index.docbook:1896
#, no-c-format
msgid ""
"exponentiate x and multiply by the factor y to return the product y exp(x)"
msgstr ""
"expoente de 'x' e multiplicação pelo factor 'y' para devolver o produto 'y "
"exp(x)'"

#. Tag: entry
#: index.docbook:1897
#, no-c-format
msgid "exprel(x)"
msgstr "exprel(x)"

#. Tag: action
#: index.docbook:1897
#, no-c-format
msgid "(exp(x)-1)/x using an algorithm that is accurate for small x"
msgstr "(exp(x)-1)/x, usando um algoritmo que é preciso para um 'x' pequeno"

#. Tag: entry
#: index.docbook:1898
#, no-c-format
msgid "exprel2(x)"
msgstr "exprel2(x)"

#. Tag: action
#: index.docbook:1898
#, no-c-format
msgid ""
"2(exp(x)-1-x)/x<superscript>2</superscript> using an algorithm that is "
"accurate for small x"
msgstr ""
"2(exp(x)-1-x)/x<superscript>2</superscript>, usando um algoritmo de precisão "
"para um 'x' pequeno"

#. Tag: entry
#: index.docbook:1899
#, no-c-format
msgid "expreln(n,x)"
msgstr "expreln(n,x)"

#. Tag: action
#: index.docbook:1899
#, no-c-format
msgid ""
"n-relative exponential, which is the n-th generalization of the functions "
"`exprel'"
msgstr ""
"exponencial em relação a 'n', o que é a n-ésima generalização da função "
"`exprel'"

#. Tag: entry
#: index.docbook:1900
#, no-c-format
msgid "E1(x)"
msgstr "E1(x)"

#. Tag: action
#: index.docbook:1900
#, no-c-format
msgid ""
"exponential integral E<subscript>1</subscript>(x), E<subscript>1</"
"subscript>(x) := Re &int;<subscript>1</subscript><superscript>&infin;</"
"superscript> exp(-xt)/t dt"
msgstr ""
"integral do expoente E<subscript>1</subscript>(x), E<subscript>1</"
"subscript>(x) := Re &int;<subscript>1</subscript><superscript>&infin;</"
"superscript> exp(-xt)/t dt"

#. Tag: entry
#: index.docbook:1901
#, no-c-format
msgid "E2(x)"
msgstr "E2(x)"

#. Tag: action
#: index.docbook:1901
#, no-c-format
msgid ""
"second-order exponential integral E<subscript>2</subscript>(x), "
"E<subscript>2</subscript>(x) := Re &int;<subscript>1</"
"subscript><superscript>&infin;</superscript> exp(-xt)/t<superscript>2</"
"superscript> dt"
msgstr ""
"integral da exponencial de segunda ordem E<subscript>2</subscript>(x), "
"E<subscript>2</subscript>(x) := Re &int;<subscript>1</"
"subscript><superscript>&infin;</superscript> exp(-xt)/t<superscript>2</"
"superscript> dt"

#. Tag: entry
#: index.docbook:1902
#, no-c-format
msgid "En(x)"
msgstr "En(x)"

#. Tag: action
#: index.docbook:1902
#, no-c-format
msgid ""
"exponential integral E_n(x) of order n, E<subscript>n</subscript>(x) := Re "
"&int;<subscript>1</subscript><superscript>&infin;</superscript> exp(-xt)/"
"t<superscript>n</superscript> dt)"
msgstr ""
"integral da exponencial de n-ésima ordem E_n(x), E<subscript>n</"
"subscript>(x) := Re &int;<subscript>1</subscript><superscript>&infin;</"
"superscript> exp(-xt)/t<superscript>n</superscript> dt)"

#. Tag: entry
#: index.docbook:1903
#, no-c-format
msgid "Ei(x)"
msgstr "Ei(x)"

#. Tag: action
#: index.docbook:1903
#, no-c-format
msgid ""
"exponential integral E_i(x), Ei(x) := PV(&int;<subscript>-x</"
"subscript><superscript>&infin;</superscript> exp(-t)/t dt)"
msgstr ""
"integral da exponencial E_i(x), Ei(x) := PV(&int;<subscript>-x</"
"subscript><superscript>&infin;</superscript> exp(-t)/t dt)"

#. Tag: entry
#: index.docbook:1904
#, no-c-format
msgid "shi(x)"
msgstr "shi(x)"

#. Tag: action
#: index.docbook:1904
#, no-c-format
msgid ""
"Shi(x) = &int;<subscript>0</subscript><superscript>x</superscript> sinh(t)/t "
"dt"
msgstr ""
"Shi(x) = &int;<subscript>0</subscript><superscript>x</superscript> sinh(t)/t "
"dt"

#. Tag: entry
#: index.docbook:1905
#, no-c-format
msgid "chi(x)"
msgstr "chi(x)"

#. Tag: action
#: index.docbook:1905
#, no-c-format
msgid ""
"integral Chi(x) := Re[ &gamma;<subscript>E</subscript> + log(x) + &int;"
"<subscript>0</subscript><superscript>x</superscript> (cosh[t]-1)/t dt ]"
msgstr ""
"integral de Chi(x) := Re[ &gamma;<subscript>E</subscript> + log(x) + &int;"
"<subscript>0</subscript><superscript>x</superscript> (cosh[t]-1)/t dt ]"

#. Tag: entry
#: index.docbook:1906
#, no-c-format
msgid "Ei3(x)"
msgstr "Ei3(x)"

#. Tag: action
#: index.docbook:1906
#, no-c-format
msgid ""
"exponential integral Ei<subscript>3</subscript>(x) = &int;<subscript>0</"
"subscript><superscript>x</superscript> exp(-t<superscript>3</superscript>) "
"dt for x &gt;= 0"
msgstr ""
"integral da exponencial Ei<subscript>3</subscript>(x) = &int;<subscript>0</"
"subscript><superscript>x</superscript> exp(-t<superscript>3</superscript>) "
"dt for x &gt;= 0"

#. Tag: entry
#: index.docbook:1907
#, no-c-format
msgid "si(x)"
msgstr "si(x)"

#. Tag: action
#: index.docbook:1907
#, no-c-format
msgid ""
"Sine integral Si(x) = &int;<subscript>0</subscript><superscript>x</"
"superscript> sin(t)/t dt"
msgstr ""
"Integral do seno Si(x) = &int;<subscript>0</subscript><superscript>x</"
"superscript> sin(t)/t dt"

#. Tag: entry
#: index.docbook:1908
#, no-c-format
msgid "ci(x)"
msgstr "ci(x)"

#. Tag: action
#: index.docbook:1908
#, no-c-format
msgid ""
"Cosine integral Ci(x) = -&int;<subscript>x</subscript><superscript>&infin;</"
"superscript> cos(t)/t dt for x &gt; 0"
msgstr ""
"Integral do coseno Ci(x) = -&int;<subscript>x</subscript><superscript>&infin;"
"</superscript> cos(t)/t dt para x &gt; 0"

#. Tag: entry
#: index.docbook:1909
#, no-c-format
msgid "atanint(x)"
msgstr "atanint(x)"

#. Tag: action
#: index.docbook:1909
#, no-c-format
msgid ""
"Arctangent integral AtanInt(x) = &int;<subscript>0</"
"subscript><superscript>x</superscript> arctan(t)/t dt"
msgstr ""
"Integral da arco-tangente AtanInt(x) = &int;<subscript>0</"
"subscript><superscript>x</superscript> arctan(t)/t dt"

#. Tag: entry
#: index.docbook:1910
#, no-c-format
msgid "Fm1(x)"
msgstr "Fm1(x)"

#. Tag: action
#: index.docbook:1910
#, no-c-format
msgid ""
"complete Fermi-Dirac integral with an index of -1, F<subscript>-1</"
"subscript>(x) = e<superscript>x</superscript> / (1 + e<superscript>x</"
"superscript>)"
msgstr ""
"Integral completo de Fermi-Dirac com um índice -1, F<subscript>-1</"
"subscript>(x) = e<superscript>x</superscript> / (1 + e<superscript>x</"
"superscript>)"

#. Tag: entry
#: index.docbook:1911
#, no-c-format
msgid "F0(x)"
msgstr "F0(x)"

#. Tag: action
#: index.docbook:1911
#, no-c-format
msgid ""
"complete Fermi-Dirac integral with an index of 0, F<subscript>0</"
"subscript>(x) = ln(1 + e<superscript>x</superscript>)"
msgstr ""
"Integral completo de Fermi-Dirac com um índice 0, F<subscript>0</"
"subscript>(x) = ln(1 + e<superscript>x</superscript>)"

#. Tag: entry
#: index.docbook:1912
#, no-c-format
msgid "F1(x)"
msgstr "F1(x)"

#. Tag: action
#: index.docbook:1912
#, no-c-format
msgid ""
"complete Fermi-Dirac integral with an index of 1, F<subscript>1</"
"subscript>(x) = &int;<subscript>0</subscript><superscript>&infin;</"
"superscript> (t /(exp(t-x)+1)) dt"
msgstr ""
"Integral completo de Fermi-Dirac com um índice 1, F<subscript>1</"
"subscript>(x) = &int;<subscript>0</subscript><superscript>&infin;</"
"superscript> (t /(exp(t-x)+1)) dt"

#. Tag: entry
#: index.docbook:1913
#, no-c-format
msgid "F2(x)"
msgstr "F2(x)"

#. Tag: action
#: index.docbook:1913
#, no-c-format
msgid ""
"complete Fermi-Dirac integral with an index of 2, F<subscript>2</"
"subscript>(x) = (1/2) &int;<subscript>0</subscript><superscript>&infin;</"
"superscript> (t<superscript>2</superscript> /(exp(t-x)+1)) dt"
msgstr ""
"Integral completo de Fermi-Dirac com um índice 2, F<subscript>2</"
"subscript>(x) = (1/2) &int;<subscript>0</subscript><superscript>&infin;</"
"superscript> (t<superscript>2</superscript> /(exp(t-x)+1)) dt"

#. Tag: entry
#: index.docbook:1914
#, no-c-format
msgid "Fj(j,x)"
msgstr "Fj(j,x)"

#. Tag: action
#: index.docbook:1914
#, no-c-format
msgid ""
"complete Fermi-Dirac integral with an index of j, F<subscript>j</"
"subscript>(x) = (1/&Gamma;(j+1)) &int;<subscript>0</"
"subscript><superscript>&infin;</superscript> (t<superscript>j</superscript> /"
"(exp(t-x)+1)) dt"
msgstr ""
"Integral completo de Fermi-Dirac com um índice 'j', F<subscript>j</"
"subscript>(x) = (1/&Gamma;(j+1)) &int;<subscript>0</"
"subscript><superscript>&infin;</superscript> (t<superscript>j</superscript> /"
"(exp(t-x)+1)) dt"

#. Tag: entry
#: index.docbook:1915
#, no-c-format
msgid "Fmhalf(x)"
msgstr "Fmhalf(x)"

#. Tag: action
#: index.docbook:1915
#, no-c-format
msgid "complete Fermi-Dirac integral F<subscript>-1/2</subscript>(x)"
msgstr "Integral completo de Fermi-Dirac F<subscript>-1/2</subscript>(x)"

#. Tag: entry
#: index.docbook:1916
#, no-c-format
msgid "Fhalf(x)"
msgstr "Fhalf(x)"

#. Tag: action
#: index.docbook:1916
#, no-c-format
msgid "complete Fermi-Dirac integral F<subscript>1/2</subscript>(x)"
msgstr "Integral completo de Fermi-Dirac F<subscript>1/2</subscript>(x)"

#. Tag: entry
#: index.docbook:1917
#, no-c-format
msgid "F3half(x)"
msgstr "F3half(x)"

#. Tag: action
#: index.docbook:1917
#, no-c-format
msgid "complete Fermi-Dirac integral F<subscript>3/2</subscript>(x)"
msgstr "Integral completo de Fermi-Dirac F<subscript>3/2</subscript>(x)"

#. Tag: entry
#: index.docbook:1918
#, no-c-format
msgid "Finc0(x,b)"
msgstr "Finc0(x,b)"

#. Tag: action
#: index.docbook:1918
#, no-c-format
msgid ""
"incomplete Fermi-Dirac integral with an index of zero, F<subscript>0</"
"subscript>(x,b) = ln(1 + e<superscript>b-x</superscript>) - (b-x)"
msgstr ""
"Integral incompleto de Fermi-Dirac com um índice 0, F<subscript>0</"
"subscript>(x,b) = ln(1 + e<superscript>b-x</superscript>) - (b-x)"

#. Tag: entry
#: index.docbook:1919
#, no-c-format
msgid "lngamma(x)"
msgstr "lngamma(x)"

#. Tag: action
#: index.docbook:1919
#, no-c-format
msgid "logarithm of the Gamma function"
msgstr "logaritmo da função Gamma"

#. Tag: entry
#: index.docbook:1920
#, no-c-format
msgid "gammastar(x)"
msgstr "gammastar(x)"

#. Tag: action
#: index.docbook:1920
#, no-c-format
msgid ""
"regulated Gamma Function &Gamma;<superscript>*</superscript>(x) for x &gt; 0"
msgstr ""
"Função Gamma regulada &Gamma;<superscript>*</superscript>(x) para x &gt; 0"

#. Tag: entry
#: index.docbook:1921
#, no-c-format
msgid "gammainv(x)"
msgstr "gammainv(x)"

#. Tag: action
#: index.docbook:1921
#, no-c-format
msgid ""
"reciprocal of the gamma function, 1/&Gamma;(x) using the real Lanczos method."
msgstr ""
"inversa da função Gamma, 1/&Gamma;(x), usando o método real de Lanczos."

#. Tag: entry
#: index.docbook:1922
#, no-c-format
msgid "fact(n)"
msgstr "fact(n)"

#. Tag: action
#: index.docbook:1922
#, no-c-format
msgid "factorial n!"
msgstr "factorial n!"

#. Tag: entry
#: index.docbook:1923
#, no-c-format
msgid "doublefact(n)"
msgstr "doublefact(n)"

#. Tag: action
#: index.docbook:1923
#, no-c-format
msgid "double factorial n!! = n(n-2)(n-4)..."
msgstr "duplo factorial n!! = n(n-2)(n-4)..."

#. Tag: entry
#: index.docbook:1924
#, no-c-format
msgid "lnfact(n)"
msgstr "lnfact(n)"

#. Tag: action
#: index.docbook:1924
#, no-c-format
msgid "logarithm of the factorial of n, log(n!)"
msgstr "logaritmo do factorial de 'n', log(n!)"

#. Tag: entry
#: index.docbook:1925
#, no-c-format
msgid "lndoublefact(n)"
msgstr "lndoublefact(n)"

#. Tag: action
#: index.docbook:1925
#, no-c-format
msgid "logarithm of the double factorial log(n!!)"
msgstr "logaritmo do duplo factorial log(n!!)"

#. Tag: entry
#: index.docbook:1926
#, no-c-format
msgid "choose(n,m)"
msgstr "choose(n,m)"

#. Tag: action
#: index.docbook:1926
#, no-c-format
msgid "combinatorial factor `n choose m' = n!/(m!(n-m)!)"
msgstr "factor combinatório `combinações n-a-m' = n!/(m!(n-m)!)"

#. Tag: entry
#: index.docbook:1927
#, no-c-format
msgid "lnchoose(n,m)"
msgstr "lnchoose(n,m)"

#. Tag: action
#: index.docbook:1927
#, no-c-format
msgid "logarithm of `n choose m'"
msgstr "logaritmo `combinações n-a-m'"

#. Tag: entry
#: index.docbook:1928
#, no-c-format
msgid "taylor(n,x)"
msgstr "taylor(n,x)"

#. Tag: action
#: index.docbook:1928
#, no-c-format
msgid ""
"Taylor coefficient x<superscript>n</superscript> / n! for x >= 0, n >= 0"
msgstr ""
"Coeficiente de Taylor x<superscript>n</superscript> / n! para x >= 0, n >= 0"

#. Tag: entry
#: index.docbook:1929
#, no-c-format
msgid "poch(a,x)"
msgstr "poch(a,x)"

#. Tag: action
#: index.docbook:1929
#, no-c-format
msgid ""
"Pochhammer symbol (a)<subscript>x</subscript> := &Gamma;(a + x)/&Gamma;(x)"
msgstr ""
"Símbolo de Pochhammer (a)<subscript>x</subscript> := &Gamma;(a + x)/&Gamma;"
"(x)"

#. Tag: entry
#: index.docbook:1930
#, no-c-format
msgid "lnpoch(a,x)"
msgstr "lnpoch(a,x)"

#. Tag: action
#: index.docbook:1930
#, no-c-format
msgid ""
"logarithm of the Pochhammer symbol (a)<subscript>x</subscript> := &Gamma;(a "
"+ x)/&Gamma;(x)"
msgstr ""
"logaritmo do símbolo de Pochhammer (a)<subscript>x</subscript> := &Gamma;(a "
"+ x)/&Gamma;(x)"

#. Tag: entry
#: index.docbook:1931
#, no-c-format
msgid "pochrel(a,x)"
msgstr "pochrel(a,x)"

#. Tag: action
#: index.docbook:1931
#, no-c-format
msgid ""
"relative Pochhammer symbol ((a,x) - 1)/x where (a,x) = (a)<subscript>x</"
"subscript> := &Gamma;(a + x)/&Gamma;(a)"
msgstr ""
"símbolo de Pochhammer relativo ((a,x) - 1)/x onde (a,x) = (a)<subscript>x</"
"subscript> := &Gamma;(a + x)/&Gamma;(a)"

#. Tag: entry
#: index.docbook:1932
#, no-c-format
msgid "gammainc(a,x)"
msgstr "gammainc(a,x)"

#. Tag: action
#: index.docbook:1932
#, no-c-format
msgid ""
"incomplete Gamma Function &Gamma;(a,x) = &int;<subscript>x</"
"subscript><superscript>&infin;</superscript> t<superscript>a-1</superscript> "
"exp(-t) dt for a &gt; 0, x &gt;= 0"
msgstr ""
"Função Gamma incompleta &Gamma;(a,x) = &int;<subscript>x</"
"subscript><superscript>&infin;</superscript> t<superscript>a-1</superscript> "
"exp(-t) dt para a &gt; 0, x &gt;= 0"

#. Tag: entry
#: index.docbook:1933
#, no-c-format
msgid "gammaincQ(a,x)"
msgstr "gammaincQ(a,x)"

#. Tag: action
#: index.docbook:1933
#, no-c-format
msgid ""
"normalized incomplete Gamma Function P(a,x) = 1/&Gamma;(a) &int;"
"<subscript>x</subscript><superscript>&infin;</superscript> "
"t<superscript>a-1</superscript> exp(-t) dt for a &gt; 0, x &gt;= 0"
msgstr ""
"Função Gamma incompleta normalizada P(a,x) = 1/&Gamma;(a) &int;<subscript>x</"
"subscript><superscript>&infin;</superscript> t<superscript>a-1</superscript> "
"exp(-t) dt para a &gt; 0, x &gt;= 0"

#. Tag: entry
