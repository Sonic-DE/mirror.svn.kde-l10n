msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>S</keycap></keycombo> </"
"shortcut> <guimenu>Ficheiro</guimenu> <guimenuitem>Gravar a Imagem Como...</"
"guimenuitem>"

#. Tag: para
#: index.docbook:230
#, no-c-format
msgid "Saves the zoomed view to an image file."
msgstr "Grava a imagem ampliada para um ficheiro."

#. Tag: menuchoice
#: index.docbook:234
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>P</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Print...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>P</keycap></keycombo> </"
"shortcut> <guimenu>Ficheiro</guimenu> <guimenuitem>Imprimir...</guimenuitem>"

#. Tag: para
#: index.docbook:242
#, no-c-format
msgid "Prints the current zoomed view."
msgstr "Imprime a área ampliada no momento."

#. Tag: menuchoice
#: index.docbook:246
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>Q</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Quit</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>Q</keycap></keycombo> </"
"shortcut> <guimenu>Ficheiro</guimenu> <guimenuitem>Sair</guimenuitem>"

#. Tag: para
#: index.docbook:254
#, no-c-format
msgid "Quits the application"
msgstr "Sai da aplicação"

#. Tag: title
#: index.docbook:260
#, no-c-format
msgid "The Edit Menu"
msgstr "O Menu Editar"

#. Tag: menuchoice
#: index.docbook:265
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>C</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Copy</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>C</keycap></keycombo> </"
"shortcut> <guimenu>Editar</guimenu> <guimenuitem>Copiar</guimenuitem>"

#. Tag: para
#: index.docbook:273
#, no-c-format
msgid ""
"Copy the current zoomed view to the clipboard which you can paste in other "
"applications."
msgstr ""
"Copia a área ampliada de momento para a área de transferência, a qual poderá "
"ser colada noutras aplicações."

#. Tag: title
#: index.docbook:280
#, no-c-format
msgid "The View Menu"
msgstr "O Menu Ver"

#. Tag: menuchoice
#: index.docbook:285
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> <keycap>F5</keycap></keycombo> </"
"shortcut> <guimenu>View</guimenu> <guimenuitem>Start/Stop</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> <keycap>F5</keycap></keycombo> </"
"shortcut> <guimenu>Ver</guimenu> <guimenuitem>Iniciar/Parar</guimenuitem>"

#. Tag: para
#: index.docbook:293
#, no-c-format
msgid ""
"Start/Stop updating of the display. Stopping the update will zero the "
"processing power required (CPU usage)"
msgstr ""
"Inicia/pára a actualização da área visualizada. A interrupção da "
"actualização irá reduzir a zero o poder de processamento necessário "
"(utilização de CPU)"

#. Tag: menuchoice
#: index.docbook:299
#, no-c-format
msgid "<guimenu>View</guimenu> <guimenuitem>Zoom</guimenuitem>"
msgstr "<guimenu>Ver</guimenu> <guimenuitem>Ampliação</guimenuitem>"

#. Tag: para
#: index.docbook:303
#, no-c-format
msgid "Select the zoom factor."
msgstr "Seleccione o factor de aplicação."

#. Tag: menuchoice
#: index.docbook:307
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>-</keycap></keycombo> </"
"shortcut> <guimenu>View</guimenu> <guimenuitem>Zoom Out</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>-</keycap></keycombo> </"
"shortcut> <guimenu>Ver</guimenu> <guimenuitem>Reduzir</guimenuitem>"

#. Tag: para
#: index.docbook:315
#, no-c-format
msgid "Click on this button to zoom-out on the selected region."
msgstr "Carregue neste botão para reduzir a região seleccionado."

#. Tag: menuchoice
#: index.docbook:319
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>+</keycap></keycombo> </"
"shortcut> <guimenu>View</guimenu> <guimenuitem>Zoom In</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>+</keycap></keycombo> </"
"shortcut> <guimenu>Ver</guimenu> <guimenuitem>Ampliar</guimenuitem>"

#. Tag: para
#: index.docbook:327
#, no-c-format
msgid "Click on this button to zoom-in on the selected region."
msgstr "Carregue neste botão para ampliar a região seleccionada."

#. Tag: menuchoice
#: index.docbook:331
#, no-c-format
msgid "<guimenu>View</guimenu> <guimenuitem>Rotation</guimenuitem>"
msgstr "<guimenu>Ver</guimenu> <guimenuitem>Rotação</guimenuitem>"

#. Tag: para
#: index.docbook:335
#, no-c-format
msgid ""
"Select the rotation degree (<guimenuitem>No Rotation (0 Degrees)</"
"guimenuitem>, <guimenuitem>Left (90 Degrees)</guimenuitem>, "
"<guimenuitem>Upside Down (180 Degrees)</guimenuitem>, <guimenuitem>Right "
"(270 Degrees)</guimenuitem>."
msgstr ""
"Seleccione o ângulo de rotação (<guimenuitem>Sem Rotação (0 Graus)</"
"guimenuitem>, <guimenuitem>Esquerda (90 Graus)</guimenuitem>, "
"<guimenuitem>De Cima para Baixo (180 Graus)</guimenuitem>, "
"<guimenuitem>Direita (270 Graus)</guimenuitem>."

#. Tag: menuchoice
#: index.docbook:341
#, no-c-format
msgid "<guimenu>View</guimenu> <guimenuitem>Refresh</guimenuitem>"
msgstr "<guimenu>Ver</guimenu> <guimenuitem>Actualizar</guimenuitem>"

#. Tag: para
#: index.docbook:345
#, no-c-format
msgid ""
"Select the refresh rate (<guimenuitem>Very Low</guimenuitem>, "
"<guimenuitem>Low</guimenuitem>, <guimenuitem>Medium</guimenuitem>, "
"<guimenuitem>High</guimenuitem>, <guimenuitem>Very High</guimenuitem>). The "
"higher the rate, the more computing power (CPU) will be needed."
msgstr ""
"Seleccione a taxa de actualização (<guimenuitem>Muito Baixa</guimenuitem>, "
"<guimenuitem>Baixa</guimenuitem>, <guimenuitem>Média</guimenuitem>, "
"<guimenuitem>Alta</guimenuitem>, <guimenuitem>Muito Alta</guimenuitem>). "
"Quanto maior a taxa, maior capacidade de processamento (CPU) será necessária."

#. Tag: menuchoice
#: index.docbook:353
#, no-c-format
msgid "<guimenu>View</guimenu> <guisubmenu>Colors</guisubmenu>"
msgstr "<guimenu>Ver</guimenu> <guimenuitem>Cores</guimenuitem>"

#. Tag: para
#: index.docbook:357
#, no-c-format
msgid ""
"Select different color vision deficiencies to simulate color blindness. This "
"is not useful for people with color blindness, but good for designing "
"accessible interfaces."
msgstr ""
"Selecciona as diferentes deficiências de visão das cores para simular o "
"daltonismo. Não é útil para as pessoas daltónicas, mas é bom para desenhar "
"interfaces acessíveis."

#. Tag: title
#: index.docbook:366
#, no-c-format
msgid "The Settings Menu"
msgstr "O Menu Configuração"

#. Tag: menuchoice
#: index.docbook:371
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> <keycap>F2</keycap></keycombo> </"
"shortcut> <guimenu>Settings</guimenu> <guimenuitem>Follow Mouse Mode</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> <keycap>F2</keycap></keycombo> </"
"shortcut> <guimenu>Configuração</guimenu> <guimenuitem>Modo de Seguimento do "
"Rato</guimenuitem>"

#. Tag: para
#: index.docbook:379
#, no-c-format
msgid ""
"In this mode the area around the mouse cursor is shown in a normal window."
msgstr ""
"Neste modo, a área em torno do cursor do rato é ampliada numa janela normal."

#. Tag: menuchoice
#: index.docbook:383
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> <keycap>F3</keycap></keycombo> </"
"shortcut> <guimenu>Settings</guimenu> <guimenuitem>Selection Window Mode</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> <keycap>F3</keycap></keycombo> </"
"shortcut> <guimenu>Configuração</guimenu> <guimenuitem>Modo da Janela de "
"Selecção</guimenuitem>"

#. Tag: para
#: index.docbook:391
#, no-c-format
msgid ""
"In this mode a selection window is opened. The selected area is shown in a "
"normal window."
msgstr ""
"Neste modo, é aberta uma janela de selecção. A área seleccionada é então "
"mostrada numa janela normal."

#. Tag: menuchoice
#: index.docbook:395
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> <keycap>F4</keycap></keycombo> </"
"shortcut> <guimenu>Settings</guimenu> <guimenuitem>Whole Screen Mode</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> <keycap>F4</keycap></keycombo> </"
"shortcut> <guimenu>Configuração</guimenu> <guimenuitem>Modo de Ecrã "
"Completo</guimenuitem>"

#. Tag: para
#: index.docbook:403
#, no-c-format
msgid "In this mode the whole screen is magnified in the zoom window."
msgstr ""
"Neste modo, a área em torno do cursor do rato é ampliada na janela de "
"ampliação."

#. Tag: menuchoice
#: index.docbook:407
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> <keycap>F6</keycap></keycombo> </"
"shortcut> <guimenu>Settings</guimenu> <guimenuitem>Hide Mouse Cursor</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> <keycap>F6</keycap></keycombo> </"
"shortcut> <guimenu>Configuração</guimenu> <guimenuitem>Esconder o Cursor do "
"Rato</guimenuitem>"

#. Tag: para
#: index.docbook:415 index.docbook:482
#, no-c-format
msgid "Show or hide the mouse cursor in the magnified image."
msgstr "Mostra ou esconde o cursor do rato numa imagem ampliada."

#. Tag: menuchoice
#: index.docbook:419
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> <keycap>F7</keycap></keycombo> </"
"shortcut> <guimenu>Settings</guimenu> <guimenuitem>Stays On Top</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> <keycap>F7</keycap></keycombo> </"
"shortcut> <guimenu>Configuração</guimenu> <guimenuitem>Fica no Topo</"
"guimenuitem>"

#. Tag: para
#: index.docbook:427 index.docbook:487
#, no-c-format
msgid "The &kmagnifier; window stays on top of other windows."
msgstr "A janela do &kmagnifier; fica por cima de todas as outras."

#. Tag: para
#: index.docbook:431
#, no-c-format
msgid ""
"Additionally &kmagnifier; has the common &kde; <guimenu>Settings</guimenu> "
"and <guimenu>Help</guimenu> menu items, for more information read the "
"sections about the <ulink url=\"help:/fundamentals/menus.html#menus-settings"
"\">Settings Menu</ulink> and <ulink url=\"help:/fundamentals/menus."
"html#menus-help\">Help Menu</ulink> of the &kde; Fundamentals."
msgstr ""
"Para além disso, o &kmagnifier; tem os menus de <guimenu>Configuração</"
"guimenu> e <guimenu>Ajuda</guimenu> normais do &kde;; para mais informações, "
"leia as secções acerca dos menus de <ulink url=\"help:/fundamentals/menus."
"html#menus-settings\">Configuração</ulink> e <ulink url=\"help:/fundamentals/"
"menus.html#menus-help\">Ajuda</ulink> dos Fundamentos do &kde;."

#. Tag: title
#: index.docbook:442
#, no-c-format
msgid "Command Reference"
msgstr "Referência de Comandos"

#. Tag: para
#: index.docbook:444
#, no-c-format
msgid ""
"&kmagnifier; automatically uses all your default shortcuts for saving file, "
"opening new window, printing, starting/stopping refresh (reload button in "
"&konqueror;), zoom-in, zoom-out &etc;"
msgstr ""
"O &kmagnifier; usa automaticamente todos os seus atalhos predefinidos para "
"gravar um ficheiro, abrir uma nova janela, imprimir, parar/iniciar a "
"actualização (botão de actualização do &konqueror;), ampliar, reduzir, &etc;"

#. Tag: title
#: index.docbook:449
#, no-c-format
msgid "Default Keyboard Shortcuts"
msgstr "Atalhos de Teclado Predefinidos"

#. Tag: keycombo
#: index.docbook:453
#, no-c-format
msgid "&Ctrl;<keycap>S</keycap>"
msgstr "&Ctrl;<keycap>S</keycap>"

#. Tag: para
#: index.docbook:454
#, no-c-format
msgid "This will save the contents of the zoom window to a file."
msgstr "Isto irá gravar o conteúdo da janela de ampliação num ficheiro."

#. Tag: keycap
#: index.docbook:459
#, no-c-format
msgid "<keycap>F2</keycap>"
msgstr "<keycap>F2</keycap>"

#. Tag: para
#: index.docbook:460
#, no-c-format
msgid "Switch to \"Follow Mouse Mode\"."
msgstr "Muda para o \"Modo de Seguimento do Rato\"."

#. Tag: keycap
#: index.docbook:464
#, no-c-format
msgid "<keycap>F3</keycap>"
msgstr "<keycap>F3</keycap>"

#. Tag: para
#: index.docbook:465
#, no-c-format
msgid "Switch to \"Selection Window Mode\"."
msgstr "Muda para o \"Modo da Janela de Selecção\"."

#. Tag: keycap
#: index.docbook:469
#, no-c-format
msgid "<keycap>F4</keycap>"
msgstr "<keycap>F4</keycap>"

#. Tag: para
#: index.docbook:470
#, no-c-format
msgid "Switch to \"Whole Screen Mode\"."
msgstr "Muda para o \"Modo de Ecrã Completo\"."

#. Tag: keycap
#: index.docbook:474
#, no-c-format
msgid "<keycap>F5</keycap>"
msgstr "<keycap>F5</keycap>"

#. Tag: para
#: index.docbook:475
#, no-c-format
msgid ""
"This will start the refresh of the zoom window if it is stopped, or stops "
"the refresh of the zoom window if the refresh is currently on."
msgstr ""
"Isto irá iniciar o refrescamento ou actualização da janela de ampliação se "
"estiver parada ou pára a mesma actualização se estiver activada no momento."

#. Tag: keycap
#: index.docbook:481
#, no-c-format
msgid "<keycap>F6</keycap>"
msgstr "<keycap>F6</keycap>"

#. Tag: keycap
#: index.docbook:486
#, no-c-format
msgid "<keycap>F7</keycap>"
msgstr "<keycap>F7</keycap>"

#. Tag: keycombo
#: index.docbook:491
#, no-c-format
msgid "&Ctrl;<keycap>N</keycap>"
msgstr "&Ctrl;<keycap>N</keycap>"

#. Tag: para
#: index.docbook:492
#, no-c-format
msgid "This will open a new &kmagnifier; window."
msgstr "Isto irá abrir uma janela nova do &kmagnifier;."

#. Tag: keycombo
#: index.docbook:495
#, no-c-format
msgid "&Ctrl;<keycap>P</keycap>"
msgstr "&Ctrl;<keycap>P</keycap>"

#. Tag: para
#: index.docbook:496
#, no-c-format
msgid ""
"This will open the print dialog for printing the contents of the zoom window."
msgstr ""
"Isto irá abrir a janela de impressão para imprimir o conteúdo da janela de "
"ampliação."

#. Tag: keycombo
#: index.docbook:500
#, no-c-format
msgid "&Ctrl;<keycap>C</keycap>"
msgstr "&Ctrl;<keycap>C</keycap>"

#. Tag: para
#: index.docbook:501
#, no-c-format
msgid "This will copy the zoom window contents to the clipboard."
msgstr ""
"Isto irá copiar o conteúdo da janela de ampliação para a área de "
"transferência."

#. Tag: keycombo
#: index.docbook:506
#, no-c-format
msgid "&Ctrl;<keycap>M</keycap>"
msgstr "&Ctrl;<keycap>M</keycap>"

#. Tag: para
#: index.docbook:507
#, no-c-format
msgid "Show/Hide the menubar."
msgstr "Mostra ou esconde a barra do menu."

#. Tag: keycombo
#: index.docbook:511
#, no-c-format
msgid "&Ctrl;<keycap>-</keycap>"
msgstr "&Ctrl;<keycap>-</keycap>"

#. Tag: para
#: index.docbook:512
#, no-c-format
msgid "Zoom out"
msgstr "Reduzir"

#. Tag: keycombo
#: index.docbook:515
#, no-c-format
msgid "&Ctrl;<keycap>+</keycap>"
msgstr "&Ctrl;<keycap>+</keycap>"

#. Tag: para
#: index.docbook:516
#, no-c-format
msgid "Zoom in"
msgstr "Ampliar"

#. Tag: keycombo
#: index.docbook:519
#, no-c-format
msgid "&Ctrl;<keycap>Q</keycap>"
msgstr "&Ctrl;<keycap>Q</keycap>"

#. Tag: para
#: index.docbook:520
#, no-c-format
msgid "Quits the application."
msgstr "Sai da aplicação."

