"</screeninfo>"

#. Tag: phrase
#: index.docbook:1424
#, no-c-format
msgid ""
"<phrase>A screenshot of &kaddressbook;'s <quote>Tools</quote> menu.</phrase>"
msgstr ""
"<phrase>Uma imagem do menu <quote>Ferramentas</quote> do &kaddressbook;.</"
