"<personname> <firstname>Rajko</firstname> <surname>Albrecht</surname> </"
"personname> <email>ral@alwins-world.de</email>"
msgstr ""
"<personname> <firstname>Rajko</firstname> <surname>Albrecht</surname> </"
"personname> <email>ral@alwins-world.de</email>"

#. Tag: date
#: man-kdesvn.1.docbook:14
#, no-c-format
msgid "2016-05-22"
msgstr "2016-05-22"

#. Tag: releaseinfo
#: man-kdesvn.1.docbook:15
#, no-c-format
msgid "kdesvn 2.1.0"
msgstr "kdesvn 2.1.0"

#. Tag: manvolnum
#: man-kdesvn.1.docbook:20
#, no-c-format
msgid "<manvolnum>1</manvolnum>"
msgstr "<manvolnum>1</manvolnum>"

#. Tag: refpurpose
#: man-kdesvn.1.docbook:25
#, no-c-format
msgid ""
"<refpurpose>A Subversion client by KDE (standalone application)</refpurpose>"
msgstr ""
"<refpurpose>Um cliente de Subversion para o KDE (aplicação autónoma)</"
"refpurpose>"

#. Tag: cmdsynopsis
#: man-kdesvn.1.docbook:29
#, no-c-format
msgid ""
"<command>kdesvn</command> <arg choice=\"opt\"><replaceable>options</"
"replaceable></arg> <arg choice=\"plain\"><replaceable>exec</replaceable></"
"arg> <arg choice=\"plain\"><replaceable>&lt;command&gt;</replaceable></arg> "
"<arg choice=\"opt\"><replaceable>URL</replaceable></arg>"
msgstr ""
"<command>kdesvn</command> <arg choice=\"opt\"><replaceable>opções</"
"replaceable></arg> <arg choice=\"plain\"><replaceable>executável</"
"replaceable></arg> <arg choice=\"plain\"><replaceable>&lt;comando&gt;</"
"replaceable></arg> <arg choice=\"opt\"><replaceable>URL</replaceable></arg>"

#. Tag: title
#: man-kdesvn.1.docbook:39
#, no-c-format
msgid "Description"
msgstr "Descrição"

#. Tag: para
#: man-kdesvn.1.docbook:40
#, no-c-format
msgid "<para>A Subversion client by KDE (standalone application)</para>"
msgstr "<para>Um cliente de Subversion para o KDE (aplicação autónoma)</para>"

#. Tag: title
#: man-kdesvn.1.docbook:43
#, no-c-format
msgid "Options"
msgstr "Opções"

#. Tag: title
#: man-kdesvn.1.docbook:45
#, no-c-format
msgid "Arguments:"
msgstr "Argumentos:"

#. Tag: term
#: man-kdesvn.1.docbook:48
#, no-c-format
msgid "<emphasis>exec</emphasis> &lt;command&gt;"
msgstr "<emphasis>exec</emphasis> &lt;comando&gt;"

#. Tag: para
#: man-kdesvn.1.docbook:49
#, no-c-format
msgid ""
"Execute subversion command (\"exec help\" for more information, opens KDE "
"Help Center)"
msgstr ""
"Executa um comando do Subversion (\"exec help\" para mais informações; abre "
"o Centro de Ajuda do KDE)"

#. Tag: emphasis
#: man-kdesvn.1.docbook:53
#, no-c-format
msgid "<emphasis>URL</emphasis>"
msgstr "<emphasis>URL</emphasis>"

#. Tag: para
#: man-kdesvn.1.docbook:55
#, no-c-format
msgid "Path to local working copy or a repository."
msgstr "Localização da cópia local ou um repositório."

#. Tag: title
#: man-kdesvn.1.docbook:61
#, no-c-format
msgid "Options:"
msgstr "Opções:"

#. Tag: option
#: man-kdesvn.1.docbook:64
#, no-c-format
msgid "-r startrev[:endrev]"
msgstr "-r ver-inicial[:ver-final]"

#. Tag: para
#: man-kdesvn.1.docbook:66
#, no-c-format
msgid "Execute single subversion command on specific revision(-range)"
msgstr ""
"Executa um único comando de Subversion para uma dada versão ou intervalo de "
"versões"

#. Tag: option
#: man-kdesvn.1.docbook:70
#, no-c-format
msgid "<option>-R</option>"
msgstr "<option>-R</option>"

#. Tag: para
#: man-kdesvn.1.docbook:72
#, no-c-format
msgid "Ask for revision when executing single command"
msgstr "Perguntar pela versão ao executar um único comando"

#. Tag: option
#: man-kdesvn.1.docbook:76
#, no-c-format
msgid "<option>-f</option>"
msgstr "<option>-f</option>"

#. Tag: para
#: man-kdesvn.1.docbook:78
#, no-c-format
msgid "Force operation"
msgstr "Forçar a operação"

#. Tag: option
#: man-kdesvn.1.docbook:82
#, no-c-format
msgid "-o &lt;file&gt;"
msgstr "-o &lt;ficheiro&gt;"

#. Tag: para
#: man-kdesvn.1.docbook:84
#, no-c-format
msgid ""
"Save output of subversion command (eg <quote>cat</quote>) into file &lt;"
"file&gt;"
msgstr ""
"Gravar o resultado do comando do Subversion (p.ex., <quote>cat</quote>) no "
"ficheiro &lt;ficheiro&gt;"

#. Tag: option
#: man-kdesvn.1.docbook:88
#, no-c-format
msgid "-l &lt;number&gt;"
msgstr "-l &lt;número&gt;"

#. Tag: para
#: man-kdesvn.1.docbook:90
#, no-c-format
msgid "Limit log output to &lt;number&gt;"
msgstr "Limita o resultado do registo a &lt;número&gt;"

#. Tag: title
#: man-kdesvn.1.docbook:99
#, no-c-format
msgid "Example"
msgstr "Exemplo"

#. Tag: para
#: man-kdesvn.1.docbook:100
#, no-c-format
msgid "kdesvn file:///<replaceable>path/to/local/working/copy</replaceable>"
msgstr "kdesvn file:///<replaceable>pasta/da/cópia/local</replaceable>"

#. Tag: para
#: man-kdesvn.1.docbook:101
#, no-c-format
msgid "kdesvn http://<replaceable>remote/svn/project/trunk</replaceable>"
msgstr "kdesvn http://<replaceable>projecto/remoto/svn/trunk</replaceable>"

#. Tag: title
#: man-kdesvn.1.docbook:105
#, no-c-format
msgid "See Also"
msgstr "Veja Também"

#. Tag: member
#: man-kdesvn.1.docbook:107
#, no-c-format
msgid ""
"Full user documentation is available through the &khelpcenter;. You can also "
"enter the &URL; <emphasis>help:/kdesvn/</emphasis> directly into &konqueror; "
"or you can run <emphasis>`khelpcenter help:/kdesvn/'</emphasis> from the "
"command-line."
msgstr ""
"A documentação completa do utilizador está disponível no &khelpcenter;. "
"Também poderá indicar o &URL; <emphasis>help:/kdesvn/</emphasis> "
"directamente no &konqueror; ou poderá executar <emphasis>`khelpcenter help:/"
"kdesvn/'</emphasis> a partir da linha de comandos."

