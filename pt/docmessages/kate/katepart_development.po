"&lt;!DOCTYPE language SYSTEM \"language.dtd\"\n"
"[\n"
"        &lt;!ENTITY referencia    \"[A-Za-z_:][\\w.:_-]*\"&gt;\n"
"]&gt;"

#. Tag: para
