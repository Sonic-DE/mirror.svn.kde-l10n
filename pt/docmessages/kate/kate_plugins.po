#. Tag: para
#: plugins.docbook:55
#, no-c-format
msgid ""
"<link linkend=\"kate-application-plugin-colored-brackets\">Colored Brackets</"
"link> - Colored brackets for readability"
msgstr ""
"<link linkend=\"kate-application-plugin-colored-brackets\">Parêntesis "
