#. Tag: title
#: plugins.docbook:363
#, no-c-format
msgid "Run Shell Script"
msgstr "Executar um Programa da Linha de Comandos"

#. Tag: term
#: plugins.docbook:366
#, no-c-format
msgid ""
"Starts an external konsole in which the current document is executed. The "
"script needs to state the interpreter in the first line via a shebang "
"<userinput>#!/path/interpreter</userinput>."
msgstr ""
"Inicia um Konsole externo, no qual será executado o documento actual. O "
"programa precisa de detectar o interpretador na primeira linha através da "
"sequência <userinput>#!/local/do/interpretador</userinput>."

#. Tag: para
#: plugins.docbook:369
#, no-c-format
msgid "<userinput>Name</userinput>: Run Shell Script"
msgstr "<userinput>Nome</userinput>: Executar um Programa da Linha de Comandos"

#. Tag: para
