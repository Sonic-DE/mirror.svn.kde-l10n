#. Tag: title
#: plugins.docbook:345
#, no-c-format
msgid "git blame"
msgstr "git blame"

#. Tag: term
#: plugins.docbook:348
#, no-c-format
msgid "Starts git blame to easily follow git changes in the current file."
msgstr ""
"Inicia o 'git blame' para seguir facilmente as alterações do Git no ficheiro "
"actual."

#. Tag: para
#: plugins.docbook:350
#, no-c-format
msgid "<userinput>Name</userinput>: git blame"
msgstr "<userinput>Nome</userinput>: git blame"

#. Tag: para
#: plugins.docbook:351
#, no-c-format
