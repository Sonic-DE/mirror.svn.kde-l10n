#, no-c-format
msgid "Close all open documents."
msgstr "Fecha todos os documentos abertos."

#. Tag: para
#: advanced.docbook:815
#, no-c-format
msgid "Save and close the current document."
msgstr "Grava e fecha o documento actual."

#. Tag: para
#: advanced.docbook:820
#, no-c-format
msgid "Save and close all currently open documents."
msgstr "Grava e fecha todos os documentos abertos de momento."

#. Tag: para
#: advanced.docbook:825
#, no-c-format
msgid "Save and close the current document only if it has changed."
msgstr "Grava e fecha o documento actual, somente se tiver sido alterado."

#. Tag: para
