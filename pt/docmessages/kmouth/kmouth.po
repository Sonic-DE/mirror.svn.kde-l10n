"<guimenu>Ficheiro</guimenu> <guimenuitem>Abrir como Histórico...</"
"guimenuitem>"

#. Tag: action
#: index.docbook:432
#, no-c-format
msgid "Opens a text file into as history of spoken sentences."
msgstr "Abre um ficheiro de texto como um histórico de frases faladas."

#. Tag: menuchoice
#: index.docbook:435
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>S</keycap></keycombo> </shortcut> "
"<guimenu>File</guimenu> <guimenuitem>Save History As...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>S</keycap></keycombo> </shortcut> "
"<guimenu>Ficheiro</guimenu> <guimenuitem>Gravar o Histórico Como...</"
"guimenuitem>"

#. Tag: action
#: index.docbook:442
#, no-c-format
msgid "Saves the history into a text file."
msgstr "Grava o histórico num ficheiro de texto."

#. Tag: menuchoice
#: index.docbook:445
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>P</keycap></keycombo> </shortcut> "
"<guimenu>File</guimenu> <guimenuitem>Print History...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>P</keycap></keycombo> </shortcut> "
"<guimenu>Ficheiro</guimenu> <guimenuitem>Imprimir o Histórico...</"
"guimenuitem>"

#. Tag: action
#: index.docbook:452
#, no-c-format
msgid "Prints the history."
msgstr "Imprime o histórico."

