"shortcut> <guimenu>Jogo</guimenu><guimenuitem>Sair</guimenuitem>"

#. Tag: para
#: index.docbook:124
#, no-c-format
msgid "<action>Close</action> &atlantik;."
msgstr "<action>Fecha</action> o &atlantik;."

