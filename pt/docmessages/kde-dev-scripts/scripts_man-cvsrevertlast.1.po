msgid "Revert files in CVS by one version"
msgstr "Reverte os ficheiros no CVS para a versão anterior"

#. Tag: cmdsynopsis
#: man-cvsrevertlast.1.docbook:24
#, no-c-format
msgid ""
"<command>cvsrevertlast</command> <group><option><replaceable>filename</"
"replaceable></option></group>"
