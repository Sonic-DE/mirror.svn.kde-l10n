#. Tag: refpurpose
#: man-cvslastchange.1.docbook:22
#, no-c-format
msgid "Display the last change committed to &CVS; for a file"
msgstr ""
"Mostra a última alteração enviada ('committed') para o &CVS; de um ficheiro"

#. Tag: cmdsynopsis
#: man-cvslastchange.1.docbook:26
#, no-c-format
msgid "&cvslastchange; <group><replaceable>file</replaceable></group>"
msgstr "&cvslastchange; <group><replaceable>ficheiro</replaceable></group>"

#. Tag: title
#: man-cvslastchange.1.docbook:33
#, no-c-format
msgid "Description"
msgstr "Descrição"

#. Tag: para
#: man-cvslastchange.1.docbook:35
#, no-c-format
msgid ""
"&cvslastchange; displays the last change committed to &CVS; for a file. It "
"uses <command>cvs diff</command> and <command>cvs log</command> to do this."
msgstr ""
"O &cvslastchange; mostra a última alteração de um ficheiro enviada "
"('committed') para o &CVS;. Ele usa o <command>cvs diff</command> e o "
"<command>cvs log</command> para o fazer."

#. Tag: para
#: man-cvslastchange.1.docbook:39
#, no-c-format
msgid "&cvslastchange; works on any &CVS; branch, not just HEAD."
msgstr ""
"O &cvslastchange; funciona em qualquer ramificação do &CVS;, não só no HEAD."

#. Tag: para
#: man-cvslastchange.1.docbook:41
#, no-c-format
