#, no-c-format
msgid "<link linkend=\"image-emboss\">Emboss</link>"
msgstr "<link linkend=\"image-emboss\">Gravar</link>"

#. Tag: link
#: index.docbook:1086
#, no-c-format
msgid "<link linkend=\"image-flatten\">Flatten</link>"
msgstr "<link linkend=\"image-flatten\">Aplanar</link>"

#. Tag: link
#: index.docbook:1087
#, no-c-format
msgid "<link linkend=\"image-flip\">Flip (upside down)</link>"
msgstr "<link linkend=\"image-flip\">Inverter (baixo para cima)</link>"

#. Tag: link
#: index.docbook:1088
#, no-c-format
msgid "<link linkend=\"image-invert\">Invert</link>"
msgstr "<link linkend=\"image-invert\">Inverter</link>"

#. Tag: link
#: index.docbook:1089
#, no-c-format
msgid "<link linkend=\"image-reduce-colors\">Reduce Colors</link>"
msgstr "<link linkend=\"image-reduce-colors\">Reduzir as Cores</link>"

#. Tag: link
#: index.docbook:1090
#, no-c-format
msgid "<link linkend=\"image-grayscale\">Reduce to Grayscale</link>"
msgstr "<link linkend=\"image-grayscale\">Reduzir para Tons de Cinzento</link>"

#. Tag: link
#: index.docbook:1091
#, no-c-format
msgid ""
"<link linkend=\"image-monochrome\">Reduce to Monochrome (Dithered)</link>"
msgstr ""
"<link linkend=\"image-monochrome\">Reduzir para Monocromático (Rasterizado)</"
"link>"

#. Tag: link
#: index.docbook:1092
#, no-c-format
msgid "<link linkend=\"image-mirror\">Mirror (horizontally)</link>"
msgstr "<link linkend=\"image-mirror\">Espelho (horizontal)</link>"

#. Tag: link
#: index.docbook:1093
#, no-c-format
msgid "<link linkend=\"image-resize-scale\">Resize / Scale</link>"
msgstr "<link linkend=\"image-resize-scale\">Redimensionar</link>"

#. Tag: link
