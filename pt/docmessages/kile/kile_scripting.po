msgstr ""
"Insere marcadores de comentários para tornar o texto seleccionado ou a linha "
"actual um comentário."

#. Tag: synopsis
#: scripting.docbook:1207
#, no-c-format
msgid "void document.uncomment();"
msgstr "void document.uncomment();"

#. Tag: para
#: scripting.docbook:1208
#, no-c-format
