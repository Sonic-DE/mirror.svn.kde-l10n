msgstr ""
"Preferências do &krdc; - página de <guilabel>Valores por Omissão do VNC</"
"guilabel>"

#. Tag: phrase
#: index.docbook:475
#, no-c-format
msgid "&krdc; preferences - <guilabel>VNC Defaults</guilabel> profiles tab"
msgstr ""
"Preferências do &krdc; - página dos perfis dos <guilabel>Valores por Omissão "
"do VNC</guilabel>"

#. Tag: screeninfo
#: index.docbook:484
#, no-c-format
msgid "&krdc; preferences - <guilabel>RDP Defaults</guilabel> tab"
msgstr ""
"Preferências do &krdc; - página de <guilabel>Valores por Omissão do RDP</"
"guilabel>"

#. Tag: phrase
#: index.docbook:490
#, no-c-format
msgid "&krdc; preferences - <guilabel>RDP Defaults</guilabel> profiles tab"
msgstr ""
"Preferências do &krdc; - página dos perfis de <guilabel>Valores por Omissão "
"do RDP</guilabel>"

#. Tag: title
#: index.docbook:503
#, no-c-format
msgid "Questions and Answers"
msgstr "Perguntas e Respostas"

#. Tag: para
#: index.docbook:518
#, no-c-format
msgid "Why does <acronym>RDP</acronym> support not work?"
msgstr "Porque é que o suporte de <acronym>RDP</acronym> não funciona?"

#. Tag: para
#: index.docbook:521
#, no-c-format
msgid ""
"<acronym>RDP</acronym> support in &krdc; depends on xfreerdp (FreeRDP). Make "
"sure that you have installed this runtime dependency."
msgstr ""
"O suporte de <acronym>RDP</acronym> do &krdc; depende do "
"'xfreerdp' (FreeRDP). Certifique-se que instalou esta dependência de "
"execução."

