#. Tag: title
#: details-forecast.docbook:255
#, no-c-format
msgid "Summary Tab"
msgstr "Página de Resumo"

#. Tag: para
#: details-forecast.docbook:256
#, fuzzy, no-c-format
#| msgid "The Summary tab is split vertically into two halves."
