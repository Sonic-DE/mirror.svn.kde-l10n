#. Tag: title
#: man-kmymoney.1.docbook:121
#, no-c-format
msgid "Description"
msgstr "Descrição"

#. Tag: para
#: man-kmymoney.1.docbook:123
#, no-c-format
msgid ""
"&kmymoney; is the Personal Finance Manager by &kde;. It provides the "
"functions required to balance your checkbooks, manage your personal loans "
"and categories your incomes and expenses using a checkbook style graphical "
"user interface."
msgstr ""
"O &kmymoney; é o Gestor de Finanças Pessoais do &kde;. Ele fornece as "
"funções necessárias para consolidar os seus livros de cheques, gerir os seus "
"empréstimos pessoais e classificar as suas receitas e despesas, usando uma "
"interface gráfica semelhante a um livro de cheques."

#. Tag: title
#: man-kmymoney.1.docbook:131
#, no-c-format
msgid "Options"
msgstr "Opções"

#. Tag: option
#: man-kmymoney.1.docbook:136
#, no-c-format
msgid "--lang"
msgstr "--lang"

#. Tag: para
#: man-kmymoney.1.docbook:138
#, no-c-format
msgid "Language to be used"
msgstr "A língua a usar"

#. Tag: option
#: man-kmymoney.1.docbook:143
#, no-c-format
msgid "<option>-n</option>"
msgstr "<option>-n</option>"

#. Tag: para
#: man-kmymoney.1.docbook:145
#, no-c-format
msgid "Do not open last used file"
msgstr "Não abrir o último ficheiro usado"

#. Tag: option
#: man-kmymoney.1.docbook:150
#, no-c-format
msgid "--timers"
msgstr "--timers"

#. Tag: para
#: man-kmymoney.1.docbook:152
#, no-c-format
msgid "Enable performance timers"
msgstr "Activa os temporizadores de performance"

#. Tag: option
#: man-kmymoney.1.docbook:157
#, no-c-format
msgid "--nocatch"
msgstr "--nocatch"

#. Tag: para
#: man-kmymoney.1.docbook:159
#, no-c-format
msgid "Do not globally catch uncaught exceptions"
msgstr "Não recolhe a nível global as excepções não-capturadas"

#. Tag: option
#: man-kmymoney.1.docbook:164
#, no-c-format
msgid "--trace"
msgstr "--trace"

#. Tag: para
#: man-kmymoney.1.docbook:166
#, no-c-format
msgid ""
"Turn on program traces. This option is only available when &kmymoney; is "
"compiled in debug mode."
msgstr ""
"Activa o registo de chamadas do programa. Esta opção só está disponível "
"quando o &kmymoney; está compilado no modo de depuração."

#. Tag: option
#: man-kmymoney.1.docbook:174
#, no-c-format
msgid "--dump-actions"
msgstr "--dump-actions"

#. Tag: para
#: man-kmymoney.1.docbook:176
#, no-c-format
msgid ""
"Dump the names of all defined QAction objects to stdout and quit. This "
"option is only available when &kmymoney; is compiled in debug mode."
msgstr ""
"Apresenta os nomes de todos os objectos QAction definidos para o 'stdout' e "
"sai. Esta opção só está disponível quando o &kmymoney; está compilado no "
"modo de depuração."

