#. Tag: refpurpose
#: man-kded6.8.docbook:41
#, no-c-format
msgid "&kde; daemon - triggers Sycoca database updates when needed."
msgstr ""
"servidor do &kde; - despoleta as actualizações da base de dados Sycoca "
"quando for necessário."

#. Tag: title
#: man-kded6.8.docbook:45
#, no-c-format
msgid "Synopsis"
msgstr "Sintaxe"

#. Tag: cmdsynopsis
#: man-kded6.8.docbook:47
#, fuzzy, no-c-format
#| msgid "<command>kded5</command> <arg choice=\"opt\">--check</arg>"
