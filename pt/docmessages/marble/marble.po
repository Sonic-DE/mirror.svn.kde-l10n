msgstr "Este é um item flutuante que apresenta um mapa de visão global."

#. Tag: guilabel
#: index.docbook:1138
#, no-c-format
msgid "Photos"
msgstr "Fotografias"

#. Tag: para
#: index.docbook:1139
#, no-c-format
msgid ""
"Automatically downloads images from around the world in preference to their "
"popularity."
msgstr ""
"Transfere automaticamente as imagens de todo o mundo, por ordem de "
"preferência da sua popularidade."

#. Tag: guilabel
#: index.docbook:1143
#, no-c-format
msgid "Places"
msgstr "Locais"

#. Tag: para
#: index.docbook:1144
#, no-c-format
msgid ""
"Displays trending <ulink url=\"https://foursquare.com/\">Foursquare</ulink> "
