msgstr "Atmosfera"

#. Tag: para
#: index.docbook:1052
#, no-c-format
msgid "Displays atmosphere effects."
msgstr "Mostra os efeitos da atmosfera."

#. Tag: guilabel
#: index.docbook:1056
#, no-c-format
