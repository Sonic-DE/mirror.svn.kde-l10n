msgstr ""
"Mostra os locais na moda no <ulink url=\"https://foursquare.com/"
"\">Foursquare</ulink>."

#. Tag: guilabel
#: index.docbook:1148
#, no-c-format
msgid "Position Marker"
msgstr "Marcador da Posição"

#. Tag: para
#: index.docbook:1149
#, no-c-format
msgid ""
"Draws a marker at the current <ulink url=\"https://en.wikipedia.org/wiki/"
"Global_Positioning_System\">GPS</ulink> position."
msgstr ""
"Desenha um marcador na posição actual do <ulink url=\"https://en.wikipedia."
"org/wiki/Global_Positioning_System\">GPS</ulink>."

#. Tag: guilabel
#: index.docbook:1153
#, no-c-format
msgid "Postal Codes"
msgstr "Códigos Postais"

#. Tag: para
#: index.docbook:1154
#, no-c-format
msgid ""
"Shows <ulink url=\"https://en.wikipedia.org/wiki/Postal_code\">postal codes</"
"ulink> of the area on the map."
msgstr ""
"Mostra os <ulink url=\"https://en.wikipedia.org/wiki/Postal_code\">códigos "
"postais</ulink> da área no mapa."

#. Tag: guilabel
#: index.docbook:1158
#, no-c-format
msgid "Routing"
msgstr "Trajecto"

#. Tag: para
#: index.docbook:1159
#, no-c-format
msgid ""
"Displays the <link linkend=\"routing\">routing information</link> and "
"navigation controls."
msgstr ""
"<action>Mostra</action> a janela de <link linkend=\"routing\">configuração "
"do trajecto</link> e dos controlos de navegação."

#. Tag: guilabel
#: index.docbook:1163
#, no-c-format
msgid "Satellites"
msgstr "Satélites"

#. Tag: para
#: index.docbook:1164
#, no-c-format
msgid ""
"Displays the Earth and other planets natural and artificial satellites and "
"their orbits."
msgstr ""
"Mostra os satélites naturais e artificiais da Terra e dos outros planetas, "
"bem como as suas órbitas."

#. Tag: guilabel
#: index.docbook:1168
#, no-c-format
msgid "Scale Bar"
msgstr "Barra de Escala"

#. Tag: para
#: index.docbook:1169
#, no-c-format
