msgstr "Bússola"

#. Tag: para
#: index.docbook:1057
#, no-c-format
msgid "Shows a compass in the map."
msgstr "Mostra uma bússola no mapa."

#. Tag: guilabel
#: index.docbook:1061
#, no-c-format
msgid "Coordinate Grid"
msgstr "Grelha de Coordenadas"

#. Tag: para
#: index.docbook:1062
#, no-c-format
msgid ""
