#. Tag: screen
#: man-kbookmarkmerger.1.docbook:83
#, no-c-format
msgid ""
"joe@hal9000:~> <command>kbookmarkmerger <filename>/usr/local/extra-"
"bookmarks</filename></command>"
msgstr ""
"ze@hal9000:~> <command>kbookmarkmerger <filename>/usr/local/favoritos-extra</"
"filename></command>"

#. Tag: para
#: man-kbookmarkmerger.1.docbook:84
#, no-c-format
msgid ""
"Merges all bookmark files stored in <filename>/usr/local/extra-bookmarks</"
"filename> into joe's list of bookmarks."
msgstr ""
"Reune todos os ficheiros de favoritos guardados em <filename>/usr/local/"
"favoritos-extra</filename> à lista de favoritos do Zé."

