#, no-c-format
msgid "--author"
msgstr "--author"

#. Tag: para
#: man-kpat.6.docbook:119
#, no-c-format
msgid "Lists &kpatience;'s authors in the terminal window"
msgstr "Apresenta os autores do &kpatience; na janela do terminal"

#. Tag: option
#: man-kpat.6.docbook:123
#, no-c-format
msgid "--license"
msgstr "--license"

#. Tag: para
#: man-kpat.6.docbook:124
#, no-c-format
msgid "Shows license information"
