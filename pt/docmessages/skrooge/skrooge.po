#. Tag: para
#: index.docbook:2760
#, no-c-format
msgid "dateformat is the format of the date extracted."
msgstr "O 'dateformat' é o formato da data extraída."

#. Tag: para
#: index.docbook:2762
#, no-c-format
msgid ""
"Put this file into the same folder as all other <filename class=\"extension"
