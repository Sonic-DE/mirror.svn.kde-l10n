#. Tag: para
#: index.docbook:40
#, no-c-format
msgid ""
"&ktorrent; is a bittorrent application by KDE which allows you to download "
"files using the BitTorrent protocol. It enables you to run multiple torrents "
"at the same time and comes with extended features to make it a full-featured "
"client for BitTorrent."
msgstr ""
"O &ktorrent; é uma aplicação de BitTorrent do KDE, que lhe permite "
"transferir ficheiros através do protocolo BitTorrent. Permite-lhe executar "
"várias torrentes ao mesmo tempo e vem com funcionalidades extendidas que o "
"tornam um cliente completo para o BitTorrent."

#. Tag: title
#: index.docbook:43
#, no-c-format
msgid "Features"
msgstr "Características"

#. Tag: para
#: index.docbook:44
#, no-c-format
msgid "Queuing of torrents"
msgstr "Fila de espera de torrentes"

#. Tag: para
#: index.docbook:45
#, no-c-format
msgid "Global and per torrent speed limits"
msgstr "Limites de velocidades globais e por torrentes"

#. Tag: para
#: index.docbook:46
#, no-c-format
msgid "Previewing of certain file types, build in (video and audio)"
msgstr "Antevisão incorporada de alguns tipos de ficheiros (vídeo e áudio)"

#. Tag: para
#: index.docbook:47
#, no-c-format
msgid "Importing of partially or fully downloaded files"
msgstr "Importação de ficheiros transferidos parcialmente ou por completo"

#. Tag: para
#: index.docbook:48
#, no-c-format
msgid "File prioritization for multi-file torrents"
msgstr "Prioritização de torrentes multi-ficheiros"

#. Tag: para
#: index.docbook:49
#, no-c-format
msgid "Selective downloading for multi-file torrents"
msgstr "Transferência selectiva para torrentes multi-ficheiros"

#. Tag: para
#: index.docbook:50
#, no-c-format
msgid ""
"Kick/ban peers with an additional IP Filter dialog for list/edit purposes"
msgstr ""
"Banir/expulsar as máquinas com uma janela adicional de filtros de IP's para "
"fins de listagem/edição"

#. Tag: para
#: index.docbook:51
#, no-c-format
msgid "UDP tracker support"
msgstr "Suporte a localizadores por UDP"

#. Tag: para
#: index.docbook:52
#, no-c-format
msgid "Support for private trackers and torrents"
msgstr "Suporte para localizadores e torrentes privadas"

#. Tag: para
#: index.docbook:53
#, no-c-format
msgid "Support for µTorrent's peer exchange"
msgstr "Suporte para a troca de máquinas do µTorrent"

#. Tag: para
#: index.docbook:54
#, no-c-format
msgid "Support for protocol encryption (compatible with Azureus)"
msgstr "Suporte para a encriptação do protocolo (compatível com o Azureus)"

#. Tag: para
#: index.docbook:55
#, no-c-format
msgid "Support for creating trackerless torrents"
msgstr "Suporte para a criação de torrentes sem localizador"

#. Tag: para
#: index.docbook:56
#, no-c-format
msgid "Support for distributed hash tables (DHT, the Mainline version)"
msgstr "Suporte para tabelas de dispersão distribuídas (DHT)"

#. Tag: para
#: index.docbook:57
#, no-c-format
msgid ""
"Support for UPnP to automatically forward ports on a LAN with dynamic "
"assigned hosts"
msgstr ""
"Suporte de UPnP para encaminhar automaticamente os portos numa LAN para as "
"máquinas atribuídas de forma dinâmica"

#. Tag: para
#: index.docbook:58
#, no-c-format
msgid "Support for webseeds"
msgstr "Suporte para fontes Web"

#. Tag: para
#: index.docbook:59
#, no-c-format
msgid "System tray integration"
msgstr "Integração na bandeja do sistema"

#. Tag: para
#: index.docbook:60
#, no-c-format
msgid "Tracker authentication support"
msgstr "Suporte para localizadores autenticados"

#. Tag: para
#: index.docbook:61
#, no-c-format
msgid "Connection though a proxy"
msgstr "Ligação através de 'proxies'"

#. Tag: para
#: index.docbook:62
#, no-c-format
msgid "Interprocess control via DBus interface"
msgstr "Controlo entre processos com a interface de D-Bus"

