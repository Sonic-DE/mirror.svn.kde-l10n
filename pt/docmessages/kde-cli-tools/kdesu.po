#: index.docbook:31
#, no-c-format
msgid ""
"&kdesu; is a graphical front end for the &UNIX; <command>su</command> "
"command."
msgstr ""
"O &kdesu; é um interface gráfico para o comando &UNIX; <command>su</command>."

#. Tag: keyword
#: index.docbook:35
#, no-c-format
msgid "<keyword>KDE</keyword>"
msgstr "<keyword>KDE</keyword>"

