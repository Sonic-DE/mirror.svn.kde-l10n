#. Tag: para
#: index.docbook:17
#, no-c-format
msgid ""
"<acronym>ldap</acronym> is the lightweight directory access protocol. It "
"provides access to an X.500 directory, or to a stand-alone <acronym>LDAP</"
"acronym> server."
msgstr ""
"O <acronym>LDAP</acronym> é o protocolo simples de acesso a directórios. "
"Providencia o acesso a um directório de X.500 ou a um servidor de "
"<acronym>LDAP</acronym> autónomo."

#. Tag: para
#: index.docbook:21
#, no-c-format
msgid "You can use the ldap KIO worker as follows:"
msgstr "Poderá usar o módulo do KIO de LDAP da seguinte maneira:"

#. Tag: para
#: index.docbook:23
#, no-c-format
msgid ""
"<userinput>ldap://host:port/ou=People,o=where,c=de??sub</userinput> for a "
"subtree-query"
msgstr ""
"<userinput>ldap://maquina:porto/ou=Pessoas,o=onde,c=de??sub</userinput> para "
"uma pesquisa na sub-árvore."

#. Tag: para
#: index.docbook:26
#, no-c-format
msgid ""
"or <userinput>ldap://host:port/cn=MM,ou=People,o=where,c=de??base</"
"userinput> for a complete branch."
msgstr ""
"ou <userinput>ldap://maquina:porto/cn=MM,ou=Pessoas,o=onde,c=de??base</"
"userinput> para um ramo completo."
