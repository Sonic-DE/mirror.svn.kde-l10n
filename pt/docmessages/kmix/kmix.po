#. Tag: para
#: index.docbook:173
#, no-c-format
msgid ""
"<action>Open <ulink url=\"help:/kcontrol/phonon\">&phonon; &systemsettings; "
"module</ulink></action> to configure the sound and video device preference "
"and the backends used by &kde; multimedia API, &phonon;."
msgstr ""
"<action>Abre o <ulink url=\"help:/kcontrol/phonon\">módulo do "
"&systemsettings; para o &phonon;</ulink></action> para configurar as "
"definições dos dispositivos de áudio e vídeo, assim como as infra-estruturas "
"usadas pela API de multimédia do &kde;, o &phonon;."

