"type=\"1\" name=\"edition\" />\n"
"   <field flags=\"3\" title=\"Copyright Year\" category=\"Publishing\" "
"format=\"4\" type=\"6\" name=\"cr_year\" />\n"
"   <field flags=\"2\" title=\"Publication Year\" category=\"Publishing\" "
