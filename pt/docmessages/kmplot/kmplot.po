msgstr "<phrase>Imagem da janela de Tipos de Letra</phrase>"

#. Tag: guilabel
#: index.docbook:649
#, no-c-format
msgid "Axes labels:"
msgstr "Legendas dos eixos:"

#. Tag: para
#: index.docbook:651
#, no-c-format
msgid "The font used for drawing the axis numbers and x/y labels."
msgstr ""
"O tipo de letra usado para desenhar os números dos eixos e as legendas em X/"
"Y."

#. Tag: guilabel
#: index.docbook:656
#, no-c-format
msgid "Diagram labels:"
msgstr "Legendas do diagrama:"

#. Tag: para
#: index.docbook:658
