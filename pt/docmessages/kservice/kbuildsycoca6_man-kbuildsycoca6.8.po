#. Tag: refpurpose
#: man-kbuildsycoca6.8.docbook:40
#, no-c-format
msgid "Rebuilds the KService desktop file system configuration cache"
msgstr ""
"Reconstrói a 'cache' de configurações do sistema dos ficheiros 'desktop' do "
"KService"

#. Tag: title
#: man-kbuildsycoca6.8.docbook:44
#, no-c-format
msgid "Synopsis"
msgstr "Sintaxe"

#. Tag: cmdsynopsis
#: man-kbuildsycoca6.8.docbook:46
