#, no-c-format
msgid "expand"
msgstr "expand"

#. Tag: para
#: man-akonadiclient.1.docbook:263
#, no-c-format
msgid "akonadiclient expand [OPTIONS] ITEM"
msgstr "akonadiclient expand [OPÇÕES] ITEM"

#. Tag: para
#: man-akonadiclient.1.docbook:264
#, no-c-format
msgid "Expands a contact group item"
msgstr "Expande um item de grupo de contactos"

#. Tag: option
#: man-akonadiclient.1.docbook:269 man-akonadiclient.1.docbook:328
#: man-akonadiclient.1.docbook:398
#, no-c-format
msgid "-b, --brief"
msgstr "-b, --brief"

#. Tag: para
#: man-akonadiclient.1.docbook:270
#, no-c-format
msgid "Brief output (email addresses only)"
msgstr "Resultado curto (apenas os endereços de e-mail)"

#. Tag: option
#: man-akonadiclient.1.docbook:278
#, no-c-format
msgid "export"
msgstr "export"

#. Tag: para
#: man-akonadiclient.1.docbook:280
#, no-c-format
msgid "akonadiclient export [OPTIONS] COLLECTION FILE"
msgstr "akonadiclient export [OPÇÕES] COLECÇÃO FICHEIRO"

#. Tag: para
#: man-akonadiclient.1.docbook:281
#, no-c-format
msgid ""
"Export the collection specified by COLLECTION to an XML file specified by "
"FILE."
msgstr ""
"Exporta a colecção indicada por COLECÇÃO para um ficheiro XML indicado em "
"FICHEIRO."

#. Tag: option
#: man-akonadiclient.1.docbook:295
#, no-c-format
msgid "group"
msgstr "group"

#. Tag: para
#: man-akonadiclient.1.docbook:297
#, no-c-format
msgid "akonadiclient group [OPTIONS] GROUP ARGS"
msgstr "akonadiclient group [OPÇÕES] GRUPO ARGS"

#. Tag: para
#: man-akonadiclient.1.docbook:298
#, no-c-format
msgid "Expand or modify a contact GROUP"
msgstr "Expande ou modifica um GRUPO de contactos"

#. Tag: option
#: man-akonadiclient.1.docbook:303
#, no-c-format
msgid "-e, --expand"
msgstr "-e, --expand"

#. Tag: para
#: man-akonadiclient.1.docbook:304
#, no-c-format
msgid "Show the expanded contact group (the default operation)"
msgstr "Mostra o grupo de contactos expandido (a operação por omissão)"

#. Tag: option
#: man-akonadiclient.1.docbook:308
#, no-c-format
msgid "-a, --add"
msgstr "-a, --add"

#. Tag: para
#: man-akonadiclient.1.docbook:309
#, no-c-format
msgid "Add a contact to the group"
msgstr "Adiciona um contacto ao grupo"

#. Tag: option
#: man-akonadiclient.1.docbook:313
#, no-c-format
msgid "-d, --delete"
msgstr "-d, --delete"

#. Tag: para
#: man-akonadiclient.1.docbook:314
