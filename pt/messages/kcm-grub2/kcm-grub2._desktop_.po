#: src/helper/kcmgrub2.actions:2
msgctxt "Name"
msgid "GRUB2 Bootloader Control Module"
msgstr "Módulo de Controlo do Gestor de Arranque GRUB2"

#: src/helper/kcmgrub2.actions:50
msgctxt "Name"
msgid "Restore the default GRUB2 Bootloader settings"
msgstr "Repor a configuração por omissão do gestor de arranque GRUB2"

#: src/helper/kcmgrub2.actions:94
msgctxt "Description"
msgid ""
"Administrator authorization is required to restore the default GRUB2 "
"Bootloader settings"
msgstr ""
"É necessária a autorização do administrador para repor a configuração "
"predefinida do gestor de arranque GRUB2"

#: src/helper/kcmgrub2.actions:141
msgctxt "Name"
msgid "Install the GRUB2 Bootloader"
msgstr "Instalar o Gestor de Arranque GRUB2"

#: src/helper/kcmgrub2.actions:187
msgctxt "Description"
msgid "Administrator authorization is required to install the GRUB2 Bootloader"
msgstr ""
"É necessária a autorização do administrador para instalar o gestor de "
"arranque GRUB2"

#: src/helper/kcmgrub2.actions:235
msgctxt "Name"
msgid "Load the GRUB2 Bootloader settings"
msgstr "Carregar a configuração do gestor de arranque GRUB2"

#: src/helper/kcmgrub2.actions:281
msgctxt "Description"
msgid ""
"Administrator authorization is required to load the GRUB2 Bootloader settings"
msgstr ""
"É necessária a autorização do administrador para carregar a configuração do "
"Gestor de Arranque GRUB2"

#: src/helper/kcmgrub2.actions:329
msgctxt "Name"
msgid "Save the GRUB2 Bootloader settings"
msgstr "Gravar a configuração do gestor de arranque do GRUB2"

#: src/helper/kcmgrub2.actions:374
msgctxt "Description"
msgid ""
"Administrator authorization is required to save the GRUB2 Bootloader settings"
msgstr ""
"É necessária a autorização do administrador para gravar a configuração do "
"gestor de arranque GRUB2"

