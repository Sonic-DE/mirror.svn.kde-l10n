#. (itstool) path: component/name
#: org.kde.knights.appdata.xml:9
msgid "KNights"
msgstr "KNights"

#. (itstool) path: component/summary
#: org.kde.knights.appdata.xml:10
msgid "Chess game"
msgstr "Jogo de xadrez"

#. (itstool) path: description/p
#: org.kde.knights.appdata.xml:12
msgid ""
"KNights is a chess game. As a player, your goal is to defeat your opponent "
"by checkmating their king."
msgstr ""
"O KNights é um jogo de xadrez. Como jogador, o seu objectivo é derrotar o "
"seu adversário através de um xeque-mate ao seu rei."

#. (itstool) path: description/p
#: org.kde.knights.appdata.xml:15
msgid "Features:"
msgstr "Funcionalidades:"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:17
msgid "Local play between two players on the same computer"
msgstr "Jogo local entre dois jogadores no mesmo computador"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:18
msgid "Play against any computer program that supports the XBoard protocol"
msgstr ""
"Jogo contra qualquer programa de computador que suporte o protocolo do XBoard"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:19
msgid "Play on the Free Internet Chess Server (FICS)"
msgstr ""
"Jogo no FICS (Free Internet Chess Server - Servidor Livre de Xadrez na "
"Internet)"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:20
msgid "Watching two computer engines play against each other"
msgstr "Observação de dois motores por computador a jogarem entre si"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:21
msgid "Support for legal move checking"
msgstr "Suporte para a verificação de jogadas legais"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:22
msgid "Markers for possible moves, opponent’s last move and sources of check"
msgstr ""
"Marcações para as jogadas possíveis, última jogada do adversário e origens "
"do xeque"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:23
msgid "Board borders and site notations"
msgstr "Contornos do tabuleiro e notações locais"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:24
msgid "Complete time control, with Plasma-styled clocks"
msgstr "Controlo total do tempo, com relógios baseados no estilo do Plasma"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:25
msgid ""
"Several themes, with the possibility of downloading new ones from within the "
"program"
msgstr ""
"Diversos temas, com a possibilidade de transferir novos dentro do programa"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:26
msgid "Animated moves (configurable)"
msgstr "Jogadas animadas (configurável)"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:27
msgid ""
"Views for playing on a chess server, including a seek graph, text console, "
"and chat widget"
msgstr ""
"Vistas para os jogos num servidor de xadrez, incluindo um grafo de pesquisa, "
"consola de texto e área de conversação"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:28
msgid "Option to undo and redo moves"
msgstr "Opção para desfazer e refazer jogadas"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:29
msgid "Graphic interface for making and receiving offers from remote players"
msgstr "Interface gráfica para fazer e receber ofertas de jogadores remotos"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:30
msgid ""
"Support for the UCI protocol (used by Stockfish, Chessbase, and many others)"
msgstr ""
"Suporte para o protocolo UCI (usado pelo Stockfish, Chessbase, entre muitos "
"outros)"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:31
msgid "Support for saving and loading Portable game notation (PGN) files"
msgstr ""
"Suporte para a gravação e carregamento de ficheiros no formato PGN (Portable "
"Game Notation - Notação Portável de Jogo)"

#. (itstool) path: ul/li
