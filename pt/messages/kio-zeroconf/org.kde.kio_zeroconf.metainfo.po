#: org.kde.kio_zeroconf.metainfo.xml:9
msgid "Zeroconf Support"
msgstr "Suporte para Zeroconf"

#. (itstool) path: component/summary
#: org.kde.kio_zeroconf.metainfo.xml:10
msgid "Browse local network services in Dolphin's Network page"
msgstr "Navegue nos serviços da rede local com a página de Rede do Dolphin"

#. (itstool) path: description/p
#: org.kde.kio_zeroconf.metainfo.xml:12
msgid ""
"Adds an entry to Dolphin's Network page to show local services such as "
"printers which advertise themselves with DNSSD (called Avahi or Bonjour by "
"other projects)."
msgstr ""
"Adiciona um elemento à página de Rede do Dolphin que mostra os serviços "
"locais, como as impressoras que se anunciam a elas próprias com o DNSSD "
"(chamado de Avahi ou Bonjour noutros projectos)."
