msgid "File Manager"
msgstr "Gestor de Ficheiros"

#. (itstool) path: description/p
#: org.kde.krusader.appdata.xml:13
msgid ""
"Krusader is an advanced twin panel (commander style) file manager for KDE "
"Plasma and other desktops in the *nix world"
msgstr ""
"O Krusader é um gestor de ficheiros avançado de painéis duplos (do estilo do "
"Commander) para o Plasma do KDE e outros ambientes de trabalho no mundo do "
"*nix"

