msgid "Advanced search module"
msgstr "Módulo de pesquisa avançado"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:20
msgid "Internal viewer/editor"
msgstr "Visualizador/editor interno"

#. (itstool) path: ul/li
