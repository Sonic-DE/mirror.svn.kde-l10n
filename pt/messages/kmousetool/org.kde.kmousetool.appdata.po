#. (itstool) path: component/name
#: org.kde.kmousetool.appdata.xml:9
msgid "KMouseTool"
msgstr "KMouseTool"

#. (itstool) path: component/summary
#: org.kde.kmousetool.appdata.xml:10
msgid "Automatic clicks to reduce the effects of repetitive strain injury"
msgstr ""
"'Clicks' automáticos para reduzir os efeitos de lesões por movimentos "
"repetitivos"

#. (itstool) path: description/p
#: org.kde.kmousetool.appdata.xml:12
msgid ""
"KMouseTool clicks the mouse for you, so you don't have to. KMouseTool works "
"with any mouse or pointing device."
msgstr ""
"O KMouseTool carrega o botão do rato, para que não tenha de o fazer. O "
"KMouseTool funciona com qualquer rato ou dispositivo de ponteiro."
