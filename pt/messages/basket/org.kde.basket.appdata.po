#. (itstool) path: component/name
#: org.kde.basket.appdata.xml:10
msgid "Basket"
msgstr "Basket"

#. (itstool) path: component/summary
#: org.kde.basket.appdata.xml:11
msgid "Notes and to-dos organizer"
msgstr "Organizador de notas e tarefas"

#. (itstool) path: description/p
#: org.kde.basket.appdata.xml:13
msgid ""
"This application provides as many baskets as you wish, and you can drag and "
"drop."
msgstr ""
"Esta aplicação oferece tantos cestos quantos desejar, podendo depois "
"arrastar e largar conteúdos neles."

#. (itstool) path: description/p
#: org.kde.basket.appdata.xml:14
msgid ""
"Objects can be edited, copied, dragged... So, you can arrange them as you "
"want !"
msgstr ""
"Os objectos poderão ser editados, copiados, arrastados... Por isso, pode "
"organizá-los como desejar !"

#. (itstool) path: description/p
#: org.kde.basket.appdata.xml:15
msgid "It allows to arrange notes, track to-dos and much more."
msgstr "Permite organizar as notas, acompanhar as tarefas e muito mais."

#~ msgid "KDE Community"
