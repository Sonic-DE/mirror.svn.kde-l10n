msgid "Error message"
msgstr "Mensagem de erro"

#: skrooge/skrooge.notifyrc:82
msgctxt "Comment"
msgid "This event is triggered when an error occurred"
msgstr "Este evento é despoletado quando ocorreu um erro"

#: skrooge/skrooge.notifyrc:109
msgctxt "Name"
msgid "Negative message"
msgstr "Mensagem negativa"

#: skrooge/skrooge.notifyrc:142
msgctxt "Comment"
msgid "This event is triggered when a negative message (warning) is displayed"
msgstr ""
"Este evento é despoletado quando for apresentada uma mensagem negativa "
"(aviso)"

#: skrooge/skrooge.notifyrc:169
msgctxt "Name"
msgid "Neutral message"
msgstr "Mensagem neutra"

#: skrooge/skrooge.notifyrc:202
