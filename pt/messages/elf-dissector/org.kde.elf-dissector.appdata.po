#. (itstool) path: component/name
#: org.kde.elf-dissector.appdata.xml:6
msgid "ELF Dissector"
msgstr "Análise do ELF"

#. (itstool) path: component/summary
#: org.kde.elf-dissector.appdata.xml:11
msgid "Static analysis tool for ELF files"
msgstr "Ferramenta de análise estática de ficheiros ELF"

#. (itstool) path: description/p
#: org.kde.elf-dissector.appdata.xml:13
msgid ""
"ELF Dissector is useful if you need to do one or more of the following tasks:"
msgstr ""
"A Análise do ELF é útil se precisar de fazer uma ou mais das seguintes "
"tarefas:"

#. (itstool) path: ul/li
#: org.kde.elf-dissector.appdata.xml:15
msgid ""
"Inspecting forward and backward dependencies, on library and symbol level."
msgstr ""
"Inspecção das dependências anteriores e posteriores, ao nível da biblioteca "
"e do símbolo."

#. (itstool) path: ul/li
#: org.kde.elf-dissector.appdata.xml:16
msgid ""
"Identifying load-time performance bottlenecks such as expensive static "
"constructors or excessive relocations."
msgstr ""
"Identificação de constrangimentos de performance no carregamento, como "
"construtores estáticos dispendiosos ou realocações excessivas."

#. (itstool) path: ul/li
#: org.kde.elf-dissector.appdata.xml:17
msgid "Size profiling of ELF files."
msgstr "Análise do tamanho dos ficheiros ELF."

#. (itstool) path: description/p
#: org.kde.elf-dissector.appdata.xml:19
msgid "Main features:"
msgstr "Funcionalidades principais:"

#. (itstool) path: ul/li
#: org.kde.elf-dissector.appdata.xml:21
msgid "ELF structure browser."
msgstr "Navegação pela estrutura ELF."

#. (itstool) path: ul/li
#: org.kde.elf-dissector.appdata.xml:22
msgid "Tree map visualization of the size of the various parts of an ELF file."
msgstr ""
"Visualização em árvore do tamanho das diversas componentes de um ficheiro "
"ELF."

#. (itstool) path: ul/li
#: org.kde.elf-dissector.appdata.xml:23
msgid "Relocation heatmap."
msgstr "'Mapa de calor' das realocações."

#. (itstool) path: ul/li
#: org.kde.elf-dissector.appdata.xml:24
msgid "Built-in disassembler for x86 and AArch64."
msgstr "Descodificação para Assembly incorporada para o x86 e o AArch64."

#. (itstool) path: ul/li
#: org.kde.elf-dissector.appdata.xml:25
msgid ""
"Browser for data type memory layouts extracted from DWARF debug information."
msgstr ""
"Navegação pelos diferentes formatos de memória para dados extraídos a partir "
"da informação de depuração DWARF."

#. (itstool) path: ul/li
#: org.kde.elf-dissector.appdata.xml:26
msgid "Forward and backward dependency viewer."
msgstr "Visualização das dependências anteriores e posteriores."

