#. (itstool) path: component/name
#: org.kde.ghostwriter.metainfo.xml:7
msgid "ghostwriter"
msgstr "ghostwriter"

#. (itstool) path: component/summary
#: org.kde.ghostwriter.metainfo.xml:8
msgid "Distraction-free text editor for Markdown"
msgstr "Editor de texto em Markdown sem distracções"

#. (itstool) path: description/p
#: org.kde.ghostwriter.metainfo.xml:10
msgid ""
"ghostwriter is a distraction-free text editor for Markdown featuring a live "
"HTML preview as you type, theme creation, focus mode, fullscreen mode, live "
"word count, and document navigation in an aesthetic writing environment. It "
"comes with the cmark-gfm Markdown processor built in, and can integrate with "
"Pandoc, MultiMarkdown, Discount, and cmark processors if they are installed."
msgstr ""
"O Ghostwriter é um editor de texto sem distracções para Markdown, fornecendo "
"uma antevisão de HTML em directo à medida que escreve, o modo de foco, o "
"modo em ecrã completo, um contador de palavras em tempo-real e a navegação "
"do documento num ambiente de escrita estético. Vem com o processador de "
"Markdown 'cmark-gfm' incorporado, podendo integrar-se com o Pandoc, "
"MultiMarkdown, Discount e o 'cmark', caso estejam instalados."

#. (itstool) path: screenshot/caption
#: org.kde.ghostwriter.metainfo.xml:20
msgid ""
"Enjoy a distraction-free writing experience, including a full screen mode "
"and a clean interface"
msgstr ""
"Desfrute de uma experiência de escrita sem distracções, incluindo um modo de "
"ecrã completo e uma interface limpa"

#. (itstool) path: component/developer_name
#: org.kde.ghostwriter.metainfo.xml:26
msgid "Megan Conkle"
msgstr "Megan Conkle"
