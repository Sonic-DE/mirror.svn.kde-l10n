msgctxt "Name"
msgid "A modifier key has become active"
msgstr "Uma tecla modificadora foi ativada"

#: kaccess/kaccess.notifyrc:180
msgctxt "Comment"
msgid ""
"A modifier key (e.g. Shift or Ctrl) has changed its state and is now active"
msgstr ""
"Uma tecla modificadora (p. ex., Shift ou Ctrl) alterou o seu estado e está "
"agora ativa"

