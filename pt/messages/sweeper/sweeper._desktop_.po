msgid "Sweeper"
msgstr "Sweeper"

#: org.kde.sweeper.desktop:75
msgctxt "GenericName"
msgid "System Cleaner"
msgstr "Limpeza do Sistema"

#: org.kde.sweeper.desktop:142
msgctxt "Comment"
msgid ""
"Helps to clean unwanted traces the user leaves on the system and to regain "
"disk space removing unused temporary files"
msgstr ""
"Ajuda a limpar os vestígios indesejados que o utilizador deixa no sistema "
"para voltar a ganhar espaço em disco, removendo os ficheiros temporários não "
"usados"
