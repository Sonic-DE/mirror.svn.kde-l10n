#: src/plugins/csoundsoundcontroller/csoundsoundcontroller.json
msgctxt "Name"
msgid "CSound-based Audio Controller"
msgstr "Controlador de Áudio Baseado no CSound"

#: src/plugins/fluidsynthsoundcontroller/fluidsynthsoundcontroller.json
msgctxt "Name"
msgid "FluidSynth-based Audio Controller"
msgstr "Controlador de Áudio Baseado no FluidSynth"

#: src/plugins/csoundsoundcontroller/csoundsoundcontroller.json
msgctxt "Description"
msgid ""
"This plugin provides Minuet with a CSound-based implementation of sound "
"controller."
msgstr ""
"Este 'plugin' oferece ao Minuet uma infra-estrutura de som implementada com "
"base no CSound."

#: src/plugins/fluidsynthsoundcontroller/fluidsynthsoundcontroller.json
msgctxt "Description"
msgid ""
"This plugin provides Minuet with a FluidSynth-based implementation of sound "
"controller."
msgstr ""
"Este 'plugin' oferece ao Minuet um controlador de som implementada com base "
"no FluidSynth."
