#. (itstool) path: component/name
#: org.kde.kio.admin.metainfo.xml:11
msgid "KIO Admin"
msgstr "KIO Admin"

#. (itstool) path: component/summary
#: org.kde.kio.admin.metainfo.xml:12
msgid "Enables administrative access for KIO-enabled applications"
msgstr ""
"Activa o acesso como administrador às aplicações com suporte para o KIO"

#. (itstool) path: description/p
#: org.kde.kio.admin.metainfo.xml:14
msgid ""
"KIO Admin is a KIO worker plugin that enables KIO-aware applications (such "
"as Dolphin, Kate or Gwenview) to access files as administrator/root."
msgstr ""
"O KIO Admin é um módulo do KIO que permite às aplicações com suporte para o "
"KI (como o Dolphin, o Kate ou o Gwenview) acederem aos ficheiros como "
"administrador ('root')."

