#. (itstool) path: component/name
#: org.kde.kdiff3.appdata.xml:13
msgid "KDiff3"
msgstr "KDiff3"

#. (itstool) path: component/summary
#: org.kde.kdiff3.appdata.xml:14
msgid "A file and folder comparison and merge tool"
msgstr "Uma ferramenta de comparação e junção de pastas e ficheiros"

#. (itstool) path: description/p
#: org.kde.kdiff3.appdata.xml:17
msgid "KDiff3 is a file and folder diff and merge tool which"
msgstr ""
"O KDiff3 é uma ferramenta de detecção e junção das diferenças entre "
"ficheiros e pastas que"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:19
msgid "compares and merges two or three text input files or folders,"
msgstr "compara e junta dois ou três ficheiros de texto ou pastas de entrada,"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:20
msgid "shows the differences line by line and character by character(!),"
msgstr "mostra as diferenças linha-a-linha e carácter-a-carácter(!),"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:21
msgid "provides an automatic merge-facility,"
msgstr "oferece uma funcionalidade de junção automática,"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:22
msgid "has an editor for comfortable solving of merge-conflicts,"
msgstr "tem um editor para resolver confortavelmente os conflitos de junção,"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:23
msgid "provides network transparency via KIO,"
msgstr "oferece a transparência na rede com o KIO,"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:24
msgid "has options to highlight or hide changes in white-space or comments,"
msgstr ""
"tem opções para realçar ou esconder as alterações nos espaços em branco ou "
"comentários,"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:25
msgid "supports Unicode, UTF-8 and other file encodings,"
msgstr "suporta o Unicode, o UTF-8 e outras codificações de ficheiros,"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:26
msgid "prints differences,"
msgstr "imprime as diferenças,"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:27
msgid "supports version control keyword and history merging."
msgstr ""
"suporta as palavras-chave de controlo de versões e de junção do histórico."
