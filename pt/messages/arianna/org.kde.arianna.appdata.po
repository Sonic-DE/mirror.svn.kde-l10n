#: org.kde.arianna.appdata.xml:14
msgid ""
"An ebook reader and library management app supporting \".epub\" files. "
"Arianna discovers your books automatically, and sorts them by categories, "
"genres and authors."
msgstr ""
"Um leitor de e-books e de gestão de bibliotecas de ficheiros \".epub\". O "
"Arianna descobre automaticamente os seus livros, ordenando-os por "
"categorias, géneros e autores."

