#: ktorrent/ktorrent.notifyrc:4
msgctxt "Comment"
msgid "KTorrent"
msgstr "KTorrent"

#: ktorrent/ktorrent.notifyrc:67
msgctxt "Name"
msgid "Torrent silently opened"
msgstr "A torrente foi aberta silenciosamente"

#: ktorrent/ktorrent.notifyrc:117
msgctxt "Name"
msgid "Torrent stopped by error"
msgstr "Torrente parada por erros"

#: ktorrent/ktorrent.notifyrc:174
msgctxt "Name"
msgid "Torrent has finished downloading"
msgstr "A torrente terminou a sua transferência"

#: ktorrent/ktorrent.notifyrc:231
msgctxt "Name"
msgid "Maximum share ratio reached"
msgstr "Foi atingida a quota máxima de partilha"

#: ktorrent/ktorrent.notifyrc:288
msgctxt "Name"
msgid "Maximum seed time reached"
msgstr "Foi atingida a quota máxima de publicação"

#: ktorrent/ktorrent.notifyrc:345
msgctxt "Name"
msgid "Disk space is running low"
msgstr "Está a faltar espaço em disco"

#: ktorrent/ktorrent.notifyrc:402
msgctxt "Name"
msgid "Corrupted data has been found"
msgstr "Foram encontrados dados corrompidos"

#: ktorrent/ktorrent.notifyrc:460
msgctxt "Name"
msgid "Torrent cannot be enqueued"
msgstr "A torrente não pode ser colocada em espera"

#: ktorrent/ktorrent.notifyrc:517
msgctxt "Name"
msgid "Torrent cannot be started"
msgstr "A torrente não pode ser iniciada"

#: ktorrent/ktorrent.notifyrc:574
msgctxt "Name"
msgid "Torrent cannot be loaded silently"
msgstr "A torrente não pode ser carregada silenciosamente"

#: ktorrent/ktorrent.notifyrc:631
msgctxt "Name"
msgid "DHT is not enabled"
msgstr "O DHT não está activo"

#: ktorrent/ktorrent.notifyrc:686
msgctxt "Name"
msgid "Event generated by plugin"
msgstr "Evento gerado pelo 'plugin'"

#: ktorrent/ktorrent.notifyrc:738
msgctxt "Name"
msgid "Magnet link download started"
msgstr "Transferência de ligação Magnet iniciada"

#: ktorrent/ktorrent.notifyrc:789
msgctxt "Name"
msgid "Magnet link copied to clipboard"
msgstr "Ligação Magnet copiada para a área de transferência"

#: ktorrent/org.kde.ktorrent.desktop:2
msgctxt "Name"
msgid "KTorrent"
msgstr "KTorrent"

#: ktorrent/org.kde.ktorrent.desktop:66
msgctxt "GenericName"
msgid "BitTorrent Client"
msgstr "Cliente de BitTorrent"

#: ktorrent/org.kde.ktorrent.desktop:137
msgctxt "Comment"
msgid "A BitTorrent program by KDE"
msgstr "Um programa de BitTorrent do KDE"

#~ msgctxt "Name"
#~ msgid "Scheduler"
#~ msgstr "Escalonador"

#~ msgctxt "Comment"
#~ msgid "Schedule upload and download limits over a period of a week"
#~ msgstr ""
#~ "Um 'plugin' para agendar os limites de envio e recepção durante o período "
#~ "de uma semana"

#~ msgctxt "Name"
#~ msgid "Download Order"
#~ msgstr "Ordem de Transferência"

#~ msgctxt "Comment"
#~ msgid "Specify the download order of a multi-file torrent"
#~ msgstr ""
#~ "Um 'plugin' para indicar a ordem de transferência de uma torrente multi-"
#~ "ficheiros para o KTorrent"

#~ msgctxt "Name"
#~ msgid "Information Widget"
#~ msgstr "Item de Informação"

#~ msgctxt "Comment"
#~ msgid "Displays general information about a torrent in several tabs"
#~ msgstr ""
#~ "Um 'plugin' que mostra informações gerais sobre uma torrente em várias "
#~ "páginas"

#~ msgctxt "Name"
#~ msgid "IP Filter"
#~ msgstr "Filtro de IPs"

#~ msgctxt "Comment"
#~ msgid "Filter IP addresses through a blocklist"
#~ msgstr "Filtra os endereços IP através de uma lista de bloqueios"

#~ msgctxt "Name"
#~ msgid "Log Viewer"
#~ msgstr "Visualizador do Registo"

#~ msgctxt "Comment"
#~ msgid "Displays the logging output"
#~ msgstr "Mostra o resultado de registo"

#~ msgctxt "Name"
#~ msgid "Magnet Generator"
#~ msgstr "Gerador de Magnet"

#~ msgctxt "Comment"
#~ msgid "Generates magnet links"
#~ msgstr "Gera hiperligações Magnet"

#~ msgctxt "Name"
#~ msgid "Media Player"
#~ msgstr "Reprodutor Multimédia"

#~ msgctxt "Comment"
#~ msgid "Phonon-based media player"
#~ msgstr "Leitor multimédia baseado no Phonon"

#~ msgctxt "Name"
#~ msgid "Scan Folder"
#~ msgstr "Sondagem de Pastas"

#~ msgctxt "Comment"
#~ msgid "Scan folders for torrent files and load them"
#~ msgstr "Pesquisar as pastas por ficheiros de torrentes e carregá-los"

#~ msgctxt "Name"
#~ msgid "Scan for lost files"
#~ msgstr "Sondar por ficheiros perdidos"

#~ msgctxt "Comment"
#~ msgid ""
#~ "Display files in the selected folder that don't belong to any torrent"
#~ msgstr ""
#~ "Mostrar os ficheiros na pasta seleccionada que não pertencem a nenhuma "
#~ "torrente"

#~ msgctxt "Name"
#~ msgid "Search"
#~ msgstr "Pesquisa"

#~ msgctxt "Comment"
#~ msgid "Search for torrents"
#~ msgstr "Procurar por torrentes"

#~ msgctxt "Name"
#~ msgid "Shutdown"
#~ msgstr "Encerramento"

#~ msgctxt "Comment"
#~ msgid "Allows you to shutdown your computer when torrents finish"
#~ msgstr ""
#~ "Permite-lhe encerrar o seu computador quando terminarem as torrentes"

#~ msgctxt "Name"
#~ msgid "Statistics"
#~ msgstr "Estatísticas"

#~ msgctxt "Comment"
#~ msgid "Shows statistics about torrents in several graphs"
#~ msgstr "Mostra as estatísticas das torrentes em vários gráficos"

#~ msgctxt "Name"
#~ msgid "Syndication"
#~ msgstr "Sindicância"

#~ msgctxt "Comment"
#~ msgid "Syndication plugin for KTorrent, supporting RSS and Atom feeds"
#~ msgstr "'Plugin' de sindicância do KTorrent, que suporta fontes RSS e Atom"

#~ msgctxt "Name"
#~ msgid "UPnP"
#~ msgstr "UPnP"

#~ msgctxt "Comment"
#~ msgid "Forward ports using UPnP"
#~ msgstr "Um 'plugin' de encaminhamento de portos com o UPnP"

#~ msgctxt "Name"
#~ msgid "Zeroconf"
#~ msgstr "ZeroConf"

#~ msgctxt "Comment"
#~ msgid "Discover peers on the local network using the Zeroconf protocol"
#~ msgstr "Descobrir pontos na rede local com o protocolo Zeroconf"

#~ msgctxt "Name"
#~ msgid "Scripting"
#~ msgstr "Programação"

#~ msgctxt "Comment"
#~ msgid "Enables Kross scripting support"
#~ msgstr "Activa o suporte de programação com o Kross"

#~ msgctxt "Name"
#~ msgid "Automatic Remove"
#~ msgstr "Remoção Automática"

#~ msgctxt "Comment"
#~ msgid ""
#~ "Script to automatically remove torrents when they finish downloading or "
#~ "seeding"
#~ msgstr ""
#~ "Um programa para remover automaticamente as torrentes quando terminar a "
#~ "sua transferência ou publicação"

#~ msgctxt "Name"
#~ msgid "Automatic Resume"
#~ msgstr "Continuação Automática"

#~ msgctxt "Comment"
#~ msgid ""
#~ "Script to automatically resume after some time, when the suspended state "
#~ "is enabled"
#~ msgstr ""
#~ "Um programa para prosseguir automaticamente, ao fim de algum tempo, "
#~ "quando for activado o estado suspenso"

#~ msgctxt "Name"
#~ msgid "E-Mail Notifications"
#~ msgstr "Notificações por E-Mail"

#~ msgctxt "Comment"
#~ msgid "Script to notify you of events via e-mail"
#~ msgstr "Um programa para o notificar sobre eventos por e-mail"

#~ msgctxt "Name"
#~ msgid "Tracker Grouping"
#~ msgstr "Agrupamento de Localizadores"

#~ msgctxt "Comment"
#~ msgid "Script to create automatic groups based upon tracker URLs"
#~ msgstr ""
#~ "Um programa para criar grupos automáticos com base nos URL's do "
#~ "localizador"

#~ msgctxt "Comment"
#~ msgid "Plasma widget to keep track of a single torrent"
#~ msgstr ""
#~ "Um elemento do Plasma para acompanhar o estado de uma única torrente"

#~ msgctxt "Comment"
#~ msgid "KTorrent data engine, for getting information from KTorrent"
#~ msgstr "Motor de dados do KTorrent, para obter informações do KTorrent"

#~ msgctxt "Name"
#~ msgid "Web Interface"
#~ msgstr "Interface Web"

#~ msgctxt "Comment"
#~ msgid "Allows control of KTorrent via a web interface"
#~ msgstr "Permite o controlo do KTorrent com uma interface Web"
