msgid "Download manager"
msgstr "Gestor de Transferências"

#. (itstool) path: description/p
#: org.kde.kget.appdata.xml:12
msgid "KGet is a versatile and user-friendly download manager."
msgstr "O KGet é um gestor de transferências versátil e amigável."

#. (itstool) path: description/p
#: org.kde.kget.appdata.xml:15
msgid "Features:"
msgstr "Funcionalidades:"

#. (itstool) path: ul/li
#: org.kde.kget.appdata.xml:17
msgid "Downloading files from FTP and HTTP(S) sources."
msgstr "Transferência de ficheiros de fontes em FTP ou HTTP(S)."

#. (itstool) path: ul/li
#: org.kde.kget.appdata.xml:18
msgid ""
"Pausing and resuming of downloading files, as well as the ability to restart "
"a download."
msgstr ""
"Pausa e continuação dos ficheiros transferidos, assim como a capacidade de "
"reiniciar uma transferência."

#. (itstool) path: ul/li
#: org.kde.kget.appdata.xml:19
msgid "Tells lots of information about current and pending downloads."
msgstr ""
"Devolve bastantes informações sobre as transferências actuais e pendentes."

#. (itstool) path: ul/li
#: org.kde.kget.appdata.xml:20
msgid "Embedding into system tray."
msgstr "Incorporação na bandeja do sistema."

#. (itstool) path: ul/li
#: org.kde.kget.appdata.xml:21
msgid "Integration with the Konqueror web browser."
msgstr "Integração com o navegador Web Konqueror."

#. (itstool) path: ul/li
#: org.kde.kget.appdata.xml:22
msgid ""
"Metalink support which contain multiple URLs for downloads, along with "
"checksums and other information."
msgstr ""
"Suporte para 'metalink', o qual contém vários URL's para as transferências, "
"em conjunto com os códigos de validação e outras informações."

#. (itstool) path: screenshot/caption
#: org.kde.kget.appdata.xml:31
msgid "Downloading files with KGet"
msgstr "Transferência de ficheiros com o KGet"
