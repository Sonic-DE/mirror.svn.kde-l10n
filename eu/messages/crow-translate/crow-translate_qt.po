#: src/cli.cpp:37
msgctxt "Cli|"
msgid "Display all language codes."
msgstr "Erakutsi hizkuntza-kode guztiak."

#: src/cli.cpp:39
msgctxt "Cli|"
msgid ""
"Specify the source language (by default, engine will try to determine the "
"language on its own)."
msgstr ""
"Zehaztu iturburu-hizkuntza (berez, motorrak hizkuntza bere kabuz zehazten "
"saiatuko da)."

#: src/cli.cpp:43
msgctxt "Cli|"
msgid ""
"Specify the translation language(s), split by '+' (by default, the system "
"language is used)."
msgstr ""
"Zehaztu itzulpen hizkuntza(k), '+' bidez banatuta (era lehenetsian, "
"sistemaren hizkuntza erabiltzen da)."

#: src/cli.cpp:47
msgctxt "Cli|"
msgid ""
"Specify the translator engine ('google', 'yandex', 'bing', 'libretranslate' "
"or 'lingva'), Google is used by default."
msgstr ""
"Zehaztu itzultzaile-motorra ('google', 'yandex', 'bing', 'libretranslate' "
"edo 'lingva'), berez Google erabiltzen du."

#: src/cli.cpp:51
msgctxt "Cli|"
msgid ""
"Specify Mozhi instance URL. Instance URL from the app settings will be used "
"by default."
msgstr ""
"Zehaztu Mozhi instantziaren URLa. Aplikazioaren ezarpenetako instantzia URLa "
"lehenespenez erabiliko da."

#: src/cli.cpp:55
msgctxt "Cli|"
msgid ""
"Specify translation provider ('copy' or 'mozhi'). Provider from app settings "
"will be used by default."
msgstr ""
"Zehaztu itzulpen hornitzailea ('copy' edo 'mozhi'). Era lehenetsian, "
"aplikazio ezarpenetako hornitzailea erabiliko da."

#: src/cli.cpp:58
msgctxt "Cli|"
msgid ""
"Specify TTS provider ('none', 'mozhi', 'qt', or 'piper'). Provider from app "
"settings will be used by default."
msgstr ""
"Zehaztu TTS hornitzailea ('none', 'mozhi', 'qt', edo 'piper'). Aplikazioaren "
"ezarpenetako instantzia URLa lehenespenez erabiliko da."

#: src/cli.cpp:60
msgctxt "Cli|"
msgid "Speak the translation."
msgstr "Ahoskatu itzulpena."

#: src/cli.cpp:61
msgctxt "Cli|"
msgid "Speak the source."
msgstr "Ahoskatu iturburua."

#: src/cli.cpp:62
msgctxt "Cli|"
msgid ""
"Read source text from files. Arguments will be interpreted as file paths."
msgstr ""
"Irakurri iturburu-testua fitxategietatik. Argumentuak fitxategi-bide gisa "
"interpretatuko dira."

#: src/cli.cpp:63
msgctxt "Cli|"
msgid "Add stdin data to source text."
msgstr "Gehitu sarrera estandar (STDIN) datuak iturburu-testuan."

#: src/cli.cpp:65
#, qt-format
msgctxt "Cli|"
msgid "Do not print any text when using --%1 or --%2."
msgstr "Ez inprimatu testurik --%1 or --%2 erabiltzean."

#: src/cli.cpp:66
msgctxt "Cli|"
msgid "Print only translations."
msgstr "Inprimatu itzulpenak soilik."

#: src/cli.cpp:67
msgctxt "Cli|"
msgid "Print output formatted as JSON."
msgstr "Inprimatu irteera JSON formatuan."

#: src/cli.cpp:70
msgctxt "Cli|"
msgid ""
"Application that allows to translate and speak text using various providers"
msgstr ""
"Testua hainbat hornitzaile erabiliz itzultzeko eta ahoskatzeko aukera ematen "
"duen aplikazioa"

#: src/cli.cpp:71
msgctxt "Cli|"
msgid ""
"Text to translate. By default, the translation will be done to the system "
"language."
msgstr "Itzultzeko testua. Berez, itzulpena sistemaren hizkuntzara egingo da."

