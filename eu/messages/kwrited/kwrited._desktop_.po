msgctxt "Name"
msgid "KDE Write Daemon"
msgstr "KDEren Write daimona"

#: kwrited-autostart.desktop:91
msgctxt "Comment"
msgid "Watch for messages from local users sent with write(1) or wall(1)"
msgstr ""
"Gainbegiratu write(1) edo wall(1) bidez erabiltzaile lokalek bidalitako "
"mezuak"

