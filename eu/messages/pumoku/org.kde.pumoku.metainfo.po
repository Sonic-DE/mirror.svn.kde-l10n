#. (itstool) path: description/p
#: org.kde.pumoku.metainfo.xml:28
msgid ""
"PuMoKu is a classic, 9 × 9 Sudoku solving game aimed for Plasma Mobile. It "
"comes with flexible highlighting options and (touch) input methods, full "
"undo stack and more."
msgstr ""
"PuMoKu Plama Mugikorrerako pentsatuta dagoen 9 × 9ko Sudokuak ebazteko joko "
"klasiko bat da. Nabarmentzeko aukera eta (ukimen) sarrera metodo malguak, "
"pila osoa desegin eta gehiago dakar."

#. (itstool) path: ul/li
#: org.kde.pumoku.metainfo.xml:30
msgid "Input methods: Cell first, Number first or Hybrid"
msgstr "Sarrerako metodoak: Gelaxka aurrena, Zenbakia aurrena edo Hibridoa"

#. (itstool) path: ul/li
#: org.kde.pumoku.metainfo.xml:31
msgid "Built in sudoku generator"
msgstr "Sudoku sortzailean barnean eraikia"

#. (itstool) path: ul/li
#: org.kde.pumoku.metainfo.xml:32
msgid "Automatic undo when the same action is repeated"
msgstr "Automatikoki desegin ekintza bera errepikatzen denean"

