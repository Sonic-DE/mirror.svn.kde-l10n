#. (itstool) path: component/name
#: org.kde.heaptrack.appdata.xml:6
msgid "Heaptrack"
msgstr "Heaptrack"

#. (itstool) path: component/summary
#: org.kde.heaptrack.appdata.xml:7
msgid "A heap memory profiler for Linux"
msgstr "Linuxerako memoria dinamikoaren profilatzaile bat"

#. (itstool) path: description/p
#: org.kde.heaptrack.appdata.xml:9
msgid ""
"Heaptrack traces all memory allocations and annotates these events with "
"stack traces. Dedicated analysis tools then allow you to interpret the heap "
"memory profile to:"
msgstr ""
"Heaptrack-ek memoria-esleipen guztien aztarna jarraitzen du eta gertaera "
"horiek pila-aztarnekin anotatzen ditu. Analisi tresna espezializatuek, "
"ondoren, memoria-dinamikoaren profila interpretatzen laguntzen dute, honako "
"helburuetarako:"

#. (itstool) path: ul/li
#: org.kde.heaptrack.appdata.xml:13
msgid ""
"find hotspots that need to be optimized to reduce the memory footprint of "
"your application"
msgstr ""
"zure aplikazioaren memoria-aztarna murrizteko optimizatu beharreko puntu-"
"beroak aurkitzea"

#. (itstool) path: ul/li
#: org.kde.heaptrack.appdata.xml:14
msgid ""
"find memory leaks, i.e. locations that allocate memory which is never "
"deallocated"
msgstr ""
"memoria-ihesak aurkitzea, hau da, inoiz askatzen ez den memoria esleitzen "
"duten kokalekuak"

#. (itstool) path: ul/li
#: org.kde.heaptrack.appdata.xml:15
msgid ""
"find allocation hotspots, i.e. code locations that trigger a lot of memory "
"allocation calls"
msgstr ""
"esleipen puntu-beroak aurkitzea, hau da, memoria esleipen handia eragiten "
"duten kode-zatiak"

#. (itstool) path: ul/li
#: org.kde.heaptrack.appdata.xml:16
msgid ""
"find temporary allocations, which are allocations that are directly followed "
"by their deallocation"
msgstr ""
"aldi baterako esleipenak aurkitzea, esleipena egin eta jarraian askatzen "
"duten kasuak"

#. (itstool) path: screenshot/caption
#: org.kde.heaptrack.appdata.xml:25
msgid "Summary of tracked heap memory allocation data"
msgstr "Aztarna jarraitutako memoria-dinamikoaren esleipen datuen laburpena"

#. (itstool) path: screenshot/caption
#: org.kde.heaptrack.appdata.xml:29
msgid "Flamegraph visualization of number of heap memory allocations"
msgstr "memoria-dinamikoaren esleipen kopuruaren sugar-grafiko irudikapena"

#. (itstool) path: screenshot/caption
#: org.kde.heaptrack.appdata.xml:33
msgid "Chart of heap memory allocations over time"
msgstr "Denboran zehar memoria dinamikoaren esleipenaren diagrama"
