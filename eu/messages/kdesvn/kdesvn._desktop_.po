#~ msgctxt "Comment"
#~ msgid "Remove any changes made locally. Warning - this cannot be undone."
#~ msgstr ""
#~ "Kendu lokalki eginiko aldaketa guztiak. Abisua - ez du atzera bueltarik."

#~ msgctxt "Name"
#~ msgid "Rename..."
#~ msgstr "Berrizendatu..."

#~ msgctxt "Comment"
#~ msgid ""
#~ "Rename a file locally and in the repository.  Use this rather than adding "
#~ "and deleting to rename a file."
#~ msgstr ""
#~ "Berrizendatu fitxategi bat lokalki eta gordetegian. Erabili hau fitxategi "
#~ "bat berrizendatzeko gehitzen eta ezabatzen ibili ordez."

#~ msgctxt "Name"
#~ msgid "Import Repository"
#~ msgstr "Inportatu gordetegia"

#~ msgctxt "Comment"
#~ msgid ""
#~ "Put folder into an existing repository to put it under revision control."
#~ msgstr ""
#~ "Ipini karpeta aurrez dagoen gordetegi batean berau bertsio kontrolpean "
#~ "ipintzeko."

#~ msgctxt "Name"
#~ msgid "Checkout From Repository..."
#~ msgstr "Atera gordetegitik..."

#~ msgctxt "Comment"
#~ msgid "Checkout out files from an existing repository into this folder."
#~ msgstr ""
#~ "Atera fitxategiak existitzen den gordetegi batetik karpeta honetara."

#~ msgctxt "Name"
#~ msgid "Switch..."
#~ msgstr "Aldatu..."

#~ msgctxt "Comment"
#~ msgid "Switch given working copy to another branch"
#~ msgstr "Aldatu adierazitako laneko kopia beste adar batera"

#~ msgctxt "Name"
#~ msgid "Merge..."
#~ msgstr "Bateratu..."

#~ msgctxt "Comment"
#~ msgid "Merge changes between this and another branch"
#~ msgstr "Bateratu adar honen eta beste baten arteko aldaketak"

#~ msgctxt "Name"
#~ msgid "Blame..."
#~ msgstr "Ardura..."

#~ msgctxt "Comment"
#~ msgid "See who wrote each line of the file and in what revision"
#~ msgstr ""
#~ "Ikusi fitxategiko lerro bakoitza nork idatzi zuen eta zein "
#~ "berrikuspenetan egin zuen"

#~ msgctxt "Name"
#~ msgid "Create Patch..."
#~ msgstr "Sortu adabakia..."

#~ msgctxt "Name"
#~ msgid "Export..."
