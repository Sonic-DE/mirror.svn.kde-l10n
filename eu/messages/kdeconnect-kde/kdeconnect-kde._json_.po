msgid "Virtual Monitor"
msgstr "Alegiazko monitorea"

#: fileitemactionplugin/kdeconnectsendfile.json
msgctxt "Description"
msgid "Send file to other device using KDE Connect"
msgstr "Fitxategia bidali KDE Connect erabiltzen duen beste gailu batera"

#: plasmoid/package/metadata.json
msgctxt "Description"
msgid "Manage connected devices"
msgstr "Konektatutako gailuak kudeatu"

#: plugins/battery/kdeconnect_battery.json
msgctxt "Description"
msgid "Share the battery status between devices"
msgstr "Bateriaren egoera gailuen artean partekatu"

#: plugins/clipboard/kdeconnect_clipboard.json
msgctxt "Description"
msgid "Share the clipboard between devices"
msgstr "Arbela gailuen artea partekatu"

#: plugins/connectivity-report/kdeconnect_connectivity_report.json
msgctxt "Description"
msgid "Show your phone's network signal strength"
msgstr "Zure telefonoaren sare-seinalearen sendotasuna erakutsi"

#: plugins/contacts/kdeconnect_contacts.json
msgctxt "Description"
msgid "Synchronize contacts from the connected device"
msgstr "Konektatutako gailuaren kontaktuak sinkronizatu"

#: plugins/digitizer/kdeconnect_digitizer.json
msgctxt "Description"
msgid "Use your device as a pressure sensitive drawing tablet"
msgstr ""
"Zure gailua presioarekiko sentikorra den marrazteko tableta gisa erabili"

#: plugins/findmyphone/kdeconnect_findmyphone.json
msgctxt "Description"
msgid "Find your lost phone by making it play an alarm sound"
msgstr "Galdutako zure gailua aurkitu alarma-soinu bat joaraziz"

#: plugins/findthisdevice/kdeconnect_findthisdevice.json
msgctxt "Description"
msgid "Find this device by making it play an alarm sound"
msgstr "Gailu hau aurkitu alarma-soinu bat joaraziz"

#: plugins/lockdevice/kdeconnect_lockdevice.json
msgctxt "Description"
msgid "Remotely lock and unlock your screen"
msgstr "Urrunetik zure pantaila giltzatu eta giltzapetik askatu"

#: plugins/mmtelephony/kdeconnect_mmtelephony.json
#: plugins/telephony/kdeconnect_telephony.json
msgctxt "Description"
msgid "Show notifications for incoming calls"
msgstr "Sarrerako deien jakinarazpenak erakutsi"

#: plugins/mousepad/kdeconnect_mousepad.json
msgctxt "Description"
msgid "Use your phone as a touchpad and keyboard"
msgstr "Zure telefonoa ukimen-sagu eta teklatu gisa erabili"

#: plugins/mpriscontrol/kdeconnect_mpriscontrol.json
msgctxt "Description"
msgid "Remote control your music and videos"
msgstr "Zure musika eta bideoak urrutitik kontrolatu"

#: plugins/mprisremote/kdeconnect_mprisremote.json
msgctxt "Description"
msgid "Control multimedia players from this device"
msgstr "Gailu honetatik hedabide jotzaileak kontrolatu"

#: plugins/notifications/kdeconnect_notifications.json
msgctxt "Description"
msgid "Show device's notifications on this computer and keep them in sync"
msgstr ""
"Gailuaren jakinarazpenak ordenagailu honetan erakutsi eta sinkronizatuta "
"mantendu"

#: plugins/pausemusic/kdeconnect_pausemusic.json
msgctxt "Description"
msgid "Pause music/videos during a phone call"
msgstr "Telefono deietan musika/bideoak etenarazi"

#: plugins/ping/kdeconnect_ping.json
msgctxt "Description"
msgid "Send and receive pings"
msgstr "Ping-ak bidali eta jaso"

#: plugins/presenter/kdeconnect_presenter.json
msgctxt "Description"
msgid "Use your mobile device as a presentation pointer"
msgstr "Erabili zure gailu mugikorra aurkezpen erakusle gisa"

#: plugins/remotecommands/kdeconnect_remotecommands.json
msgctxt "Description"
msgid "Trigger commands predefined on the remote device"
msgstr "Urruneko gailuan aurretiaz definitutako komandoak eragin"

#: plugins/remotecontrol/kdeconnect_remotecontrol.json
msgctxt "Description"
msgid "Use your mouse to send input to another device"
msgstr "Erabili zure sagua beste gailu batera sarrera bidaltzeko"

#: plugins/remotekeyboard/kdeconnect_remotekeyboard.json
msgctxt "Description"
msgid "Use your keyboard to send input to another device"
msgstr "Erabili zure teklatua beste gailu batera sarrera bidaltzeko"

#: plugins/remotesystemvolume/kdeconnect_remotesystemvolume.json
msgctxt "Description"
msgid "Control the volume of the connected device"
msgstr "Konektatutako gailuaren bolumena kontrolatu"

#: plugins/runcommand/kdeconnect_runcommand.json
msgctxt "Description"
msgid "Execute predefined commands remotely"
msgstr "Aurrez definitutako komandoak urrunetik exekutatu"

#: plugins/screensaver-inhibit/kdeconnect_screensaver_inhibit.json
msgctxt "Description"
msgid "Inhibit the screensaver when the device is connected"
msgstr "Pantaila-babeslea eragotzi gailua konektatuta dagoenean"

#: plugins/sendnotifications/kdeconnect_sendnotifications.json
msgctxt "Description"
msgid ""
"Broadcast this computer's notifications, so they can be shown on other "
"devices."
msgstr ""
"Ordenagailu honetako jakinarazpenak igorri, beste gailu batzuetan erakutsi "
"daitezen."

#: plugins/sftp/kdeconnect_sftp.json
msgctxt "Description"
msgid "Browse the remote device filesystem using SFTP"
msgstr "Urruneko gailuaren fitxategi-sistema arakatu SFTP erabiliz"

#: plugins/shareinputdevices/kdeconnect_shareinputdevices.json
msgctxt "Description"
msgid "Share mouse and keyboard with the remote device"
msgstr "Urruneko gailuarekin sagua eta teklatua partekatu"

#: plugins/share/kdeconnect_share.json
msgctxt "Description"
msgid "Receive and send files, URLs, or plain text"
msgstr "Fitxategiak, URLak, edo testu soila jaso eta bidali"

#: plugins/sms/kdeconnect_sms.json
msgctxt "Description"
msgid "Send and receive SMS"
msgstr "SMSak bidali eta jaso"

#: plugins/systemvolume/kdeconnect_systemvolume.json
msgctxt "Description"
msgid "Enable volume to be controlled from the connected device"
msgstr "Konektatutako gailutik bolumena kontrolatzea gaitu"

#: plugins/virtualmonitor/kdeconnect_virtualmonitor.json
msgctxt "Description"
msgid "Use your devices as virtual monitors"
msgstr "Zure gailuak alegiazko monitore gisa erabili"

