#. (itstool) path: component/name
#: org.kde.krusader.appdata.xml:7
msgid "Krusader"
msgstr "Krusader"

#. (itstool) path: component/summary
#: org.kde.krusader.appdata.xml:8
msgid "File Manager"
msgstr "Fitxategi-kudeatzailea"

#. (itstool) path: description/p
#: org.kde.krusader.appdata.xml:13
msgid ""
"Krusader is an advanced twin panel (commander style) file manager for KDE "
"Plasma and other desktops in the *nix world"
msgstr ""
"Krusader panel bikiko fitxategi kudeatzaile aurreratu bat da, KDE Plasma eta "
"*nix munduko beste mahaigainetan erabil daitekeena."

#. (itstool) path: description/p
#: org.kde.krusader.appdata.xml:14
msgid "Features:"
msgstr "Eginbideak:"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:16
msgid "Extensive archive handling"
msgstr "Artxiboen kudeaketa zabala"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:17
msgid "Mounted filesystem support"
msgstr "Muntatutako fitxategi-sistemen euskarria"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:18
msgid "FTP support"
msgstr "FTP euskarria"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:19
msgid "Advanced search module"
msgstr "Bilaketa aurreraturako modulua"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:20
msgid "Internal viewer/editor"
msgstr "Barneko erakuslea/editorea"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:21
msgid "Folder synchronisation"
msgstr "Karpetak sinkronizatzea"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:22
msgid "File content comparisons"
msgstr "Fitxategi edukia parekatzea"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:23
msgid "Powerful batch renaming"
msgstr "Izenak sortaka aldatzeko tresna ahaltsua"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:24
msgid ""
"Support for a wide variety of archive formats and can handle other KIO "
"slaves such as smb or fish."
msgstr ""
"Artxibo formatuen aniztasun zabalerako euskarria du eta beste KIO morroi "
"batzuk maneiatu ditzake smb eta fish esaterako."

#. (itstool) path: ul/li
