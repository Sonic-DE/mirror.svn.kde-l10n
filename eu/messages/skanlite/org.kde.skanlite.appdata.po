#. (itstool) path: component/name
#: org.kde.skanlite.appdata.xml:10
msgid "Skanlite"
msgstr "Skanlite"

#. (itstool) path: component/summary
#: org.kde.skanlite.appdata.xml:11
msgid "Image Scanning Application"
msgstr "Irudiak eskaneatzeko aplikazioa"

#. (itstool) path: description/p
#: org.kde.skanlite.appdata.xml:13
msgid ""
"Skanlite is a simple image scanning application to scan and save images. It "
"is optimized for scanning with flatbed scanners. Skanlite can capture not "
"only photos and documents, but also transparent slides and filmstrips, with "
"supported scanners."
msgstr ""
"Skanlite irudiak eskaneatzeko eta gordetzeko aplikazio xume bat da. Gainazal "
"lauko eskanerrekin eskaneatzeko optimizatua dago. Skanlitek argazkiak eta "
"dokumentuak ez ezik, diapositiba gardenak eta film-zerrendak ere eskaneatu "
"ditzake halakorik egitea onartzen duten eskanerrekin."

#. (itstool) path: description/p
#: org.kde.skanlite.appdata.xml:17
msgid "Features:"
msgstr "Eginbideak:"

#. (itstool) path: ul/li
#: org.kde.skanlite.appdata.xml:19
msgid ""
"Save dialog for every image scanned or saving the images immediately in a "
"specified folder with auto-generated names and format"
msgstr ""
"Gorde elkarrizketa-koadroa eskaneatutako irudi bakoitzeko edo gorde berehala "
"adierazitako formatu eta karpetan auto-sortutako izenekin."

#. (itstool) path: ul/li
#: org.kde.skanlite.appdata.xml:20
msgid "Support for networks scanners"
msgstr "Sareko Eskanerren euskarria"

#. (itstool) path: ul/li
#: org.kde.skanlite.appdata.xml:21
msgid "Preview with selection feature for the final scan"
msgstr "Aurrebista hautatzeko gaitasunaz azken eskaneatzerako"

#. (itstool) path: ul/li
#: org.kde.skanlite.appdata.xml:22
msgid "Scanning multiple selections of an image"
msgstr "Irudi baten hautatze anitzen eskaneatzea"

#. (itstool) path: screenshot/caption
#: org.kde.skanlite.appdata.xml:27
msgid "Skanlite's basic options screen with a scanned image visible"
msgstr ""
"Skanlite-ren oinarrizko aukeren pantaila, eskaneatutako irudi bat ikusgai "
"duena"
