#. (itstool) path: component/summary
#: org.kde.kmousetool.appdata.xml:10
msgid "Automatic clicks to reduce the effects of repetitive strain injury"
msgstr ""
"Esfortzu errepikakorraren ondoriozko lesioaren efektuak murrizteko klik "
"automatikoak"

#. (itstool) path: description/p
#: org.kde.kmousetool.appdata.xml:12
msgid ""
"KMouseTool clicks the mouse for you, so you don't have to. KMouseTool works "
"with any mouse or pointing device."
msgstr ""
"KMouseTool tresnak saguari klik egiten dio zure ordez, zuk egin behar ez "
"dezazun. KMouseTool edozein sagu edo gailu erakuslerekin dabil."

#~ msgid "Automatic Mouse Click"
#~ msgstr "Saguaren klik automatikoa"
