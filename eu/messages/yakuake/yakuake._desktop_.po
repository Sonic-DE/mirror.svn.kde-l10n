#: data/org.kde.yakuake.desktop:2
msgctxt "Name"
msgid "Yakuake"
msgstr "Yakuake"

#: data/org.kde.yakuake.desktop:65
msgctxt "GenericName"
msgid "Drop-down Terminal"
msgstr "Goitik-behera zabaltzen den terminala"

#: data/org.kde.yakuake.desktop:128
msgctxt "Comment"
msgid "A drop-down terminal emulator based on KDE Konsole technology."
msgstr ""
"KDE Konsole teknologian oinarritzen den goitik-behera zabaltzen den terminal "
"emulatzaile bat."

#: data/yakuake.notifyrc:4
msgctxt "Comment"
msgid "Yakuake"
msgstr "Yakuake"

