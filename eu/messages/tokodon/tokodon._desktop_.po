#: org.kde.tokodon.desktop:4 src/tokodon.notifyrc:5
msgctxt "Name"
msgid "Tokodon"
msgstr "Tokodon"

#: org.kde.tokodon.desktop:44
msgctxt "GenericName"
msgid "Browse the Fediverse"
msgstr "Arakatu Fedibertsoa"

#: org.kde.tokodon.desktop:76
msgctxt "Comment"
msgid "Client for the Mastodon"
msgstr "«Mastodon»erako bezero bat"

#: src/tokodon.notifyrc:46
msgctxt "Comment"
msgid "A client for Mastodon, the decentralized social media"
msgstr "«Mastodon»erako bezero bat, gizarte komunikabide deszentralizatua"

#: src/tokodon.notifyrc:82
msgctxt "Name"
msgid "Favorite"
msgstr "Gogokoa"

#: src/tokodon.notifyrc:118
msgctxt "Comment"
msgid "Someone favorited your post"
msgstr "Norbaitek zure posta gogoko gisa markatu du"

#: src/tokodon.notifyrc:154
msgctxt "Name"
msgid "Boost"
msgstr "Bultzada"

#: src/tokodon.notifyrc:188
msgctxt "Comment"
msgid "Someone boosted your post"
msgstr "Norbaitek zure postari bultzada eman dio"

#: src/tokodon.notifyrc:225 src/tokodon.notifyrc:364
msgctxt "Name"
msgid "Follow"
msgstr "Jarraitu"

#: src/tokodon.notifyrc:261
msgctxt "Comment"
msgid "Someone followed you"
msgstr "Norbaitek jarraitu zaitu"

#: src/tokodon.notifyrc:298
msgctxt "Name"
msgid "Follow Request"
msgstr "Jarraipen eskaera"

#: src/tokodon.notifyrc:330
msgctxt "Comment"
msgid "Someone requested to followed you"
msgstr "Norbaitek zuri jarraitzeko eskaera egin du"

#: src/tokodon.notifyrc:400
msgctxt "Comment"
msgid "Someone mentioned you"
msgstr "Norbaitek aipatu zaitu"

#: src/tokodon.notifyrc:437
msgctxt "Name"
msgid "Update"
msgstr "Eguneratzea"

#: src/tokodon.notifyrc:472
msgctxt "Comment"
msgid "Someone edited a post"
msgstr "Norbaitek posta bat editatu du"

#: src/tokodon.notifyrc:508
msgctxt "Name"
msgid "Poll"
msgstr "Galdeketa"

#: src/tokodon.notifyrc:540
msgctxt "Comment"
msgid "Someone's poll ended"
msgstr "Norbaiten galdeketa bukatu da"

#: src/tokodon.notifyrc:574
msgctxt "Name"
msgid "Status"
msgstr "Egoera"

#: src/tokodon.notifyrc:606
msgctxt "Comment"
msgid "Someone posted a new status"
msgstr "Norbaitek postaz egoera berri bat bidali du"

#: src/tokodon.notifyrc:641
msgctxt "Name"
msgid "Quote"
msgstr ""

#: src/tokodon.notifyrc:662
#, fuzzy
