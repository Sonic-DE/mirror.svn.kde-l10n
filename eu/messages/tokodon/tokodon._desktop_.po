msgctxt "Comment"
msgid "Someone quoted you"
msgstr "Norbaitek jarraitu zaitu"

#: src/tokodon.notifyrc:687
msgctxt "Name"
msgid "Annual Report"
msgstr "Urteko txostena"

#: src/tokodon.notifyrc:715
msgctxt "Comment"
msgid "Unveil your year's highlights and memorable moments on the Fediverse!"
msgstr ""
"Urteko zure aipagarrienak eta momentu gogoangarriak Fedibertsoan aurkeztu!"

#: src/tokodon.notifyrc:746
msgctxt "Name"
msgid "Other"
msgstr "Bestelakoak"

#: src/tokodon.notifyrc:775
