#. (itstool) path: component/name
#: org.kde.calligraplan.appdata.xml:7
msgid "Plan"
msgstr "Plan"

#. (itstool) path: component/summary
#: org.kde.calligraplan.appdata.xml:8
msgid "Project Management"
msgstr "Proiektu-kudeaketa"

#. (itstool) path: description/p
#: org.kde.calligraplan.appdata.xml:10
msgid ""
"Plan is a project management application. It is intended for managing "
"moderately large projects with multiple resources."
msgstr ""
"Plan, proiektuak kudeatzeko aplikazio bat da. Baliabide anizkoitzeko "
"proiektu handi samarrak kudeatzeko prestatuta dago."

#. (itstool) path: description/p
#: org.kde.calligraplan.appdata.xml:13
msgid "Features:"
msgstr "Ezaugarriak:"

#. (itstool) path: ul/li
#: org.kde.calligraplan.appdata.xml:15
msgid "Multiple views: Gant Charts, Resource View, Accounts View"
msgstr ""
"Ikuspegi anizkoitzak: Gantt diagramak, Baliabideen ikuspegia, Kontuen "
"ikuspegia"

#. (itstool) path: ul/li
#: org.kde.calligraplan.appdata.xml:16
msgid ""
"Uses standard structures: Work breakdown structure (WBS), Resource breakdown "
"structure (RBS), Cost breakdown structure (CBS)"
msgstr ""
"Egitura estandarrak erabiltzen ditu: Lana deskonponsatzeko egitura (WBS) "
"Baliabideak deskonposatzeko egitura (RBS), Kostua deskonposatzeko egitura "
"(CBS)"

#. (itstool) path: ul/li
#: org.kde.calligraplan.appdata.xml:17
msgid "Configurable level of detail on Gantt Chart"
msgstr "Zehaztasun maila konfiguragarria Gantt diagrametan"

#. (itstool) path: ul/li
#: org.kde.calligraplan.appdata.xml:18
msgid "Supports Summarytasks, Tasks, and milestones"
msgstr "Zereginen laburpenak, zereginak eta mugarriak onartzen ditu"

#. (itstool) path: ul/li
#: org.kde.calligraplan.appdata.xml:19
msgid "Configurable Scheduling Constraints"
msgstr "Antolaketa murrizketa konfiguragarriak"

