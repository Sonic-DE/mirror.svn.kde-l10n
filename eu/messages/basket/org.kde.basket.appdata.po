#. (itstool) path: component/name
#: org.kde.basket.appdata.xml:10
msgid "Basket"
msgstr "Basket"

#. (itstool) path: component/summary
#: org.kde.basket.appdata.xml:11
msgid "Notes and to-dos organizer"
msgstr "Oharren eta zereginen antolatzailea"

#. (itstool) path: description/p
#: org.kde.basket.appdata.xml:13
msgid ""
"This application provides as many baskets as you wish, and you can drag and "
"drop."
msgstr ""
"Aplikazio honek nahi adina saski hornitzen ditu, eta arrastatu eta jaregin "
"daiteke."

#. (itstool) path: description/p
#: org.kde.basket.appdata.xml:14
msgid ""
"Objects can be edited, copied, dragged... So, you can arrange them as you "
"want !"
msgstr ""
"Objektuak editatu, kopiatu, arrastatu... daitezke, nahi duzun bezala "
"antolatu ditzakezu!"

#. (itstool) path: description/p
#: org.kde.basket.appdata.xml:15
msgid "It allows to arrange notes, track to-dos and much more."
msgstr ""
"Oharrak antolatzeko, zereginen jarraipena egiteko eta askoz gehiagorako "
"aukera eskaintzen du."

#~ msgid "KDE Community"
