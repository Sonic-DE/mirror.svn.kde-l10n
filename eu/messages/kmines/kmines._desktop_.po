#~ msgctxt "Comment"
#~ msgid ""
#~ "<h3>Puddles (Water)</h3>Hitting into a puddle (blue) adds a penalty "
#~ "stroke to your score, and your ball is placed outside the puddle."
#~ msgstr ""
#~ "<h3>Putzuak (ura)</h3>Putzu (urdina) batera botatzeak kolpe baten zigorra "
