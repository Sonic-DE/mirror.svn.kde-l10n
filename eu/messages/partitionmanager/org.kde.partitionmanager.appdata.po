#. (itstool) path: component/name
#: org.kde.partitionmanager.appdata.xml:11
msgid "KDE Partition Manager"
msgstr "KDE Partizio Kudeatzailea"

#. (itstool) path: component/summary
#: org.kde.partitionmanager.appdata.xml:12
msgid "Manage disks, partitions, and file systems"
msgstr "Kudeatu diskoak, partizioak, eta fitxategi-sistemak"

#. (itstool) path: description/p
#: org.kde.partitionmanager.appdata.xml:14
msgid ""
"KDE Partition Manager is a utility to help you manage the disks, partitions, "
"and file systems on your computer. It allows you to easily create, copy, "
"move, delete, back up, restore, and resize them without losing data. It "
"supports a large number of file systems, including ext2/3/4, btrfs, "
"reiserfs, NTFS, FAT16/32, JFS, XFS and more."
msgstr ""
"KDE Partizio Kudeatzailea zure ordenagailuko diskoak, partizioak eta "
"fitxategi-sistemak kudeatzen laguntzeko baliagarritasun bat da. Era errazean "
"eta daturik galdu gabe, partizioak sortu, kopiatu, mugitu, ezabatu, babes-"
"kopia egin, lehengoratu, eta neurria aldatzeko aukera eskaintzen dizu. "
"Fitxategi-sistema kopuru handiaren euskarria du, tartean ext2/3/4, btrfs, "
"reiserfs, NTFS, FAT16/32, JFS, XFS eta gehiago."

#~ msgid "Features:"
#~ msgstr "Ezaugarriak:"

