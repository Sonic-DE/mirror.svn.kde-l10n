#: plugins/astyle/kdevastyle.json
msgctxt "Description"
msgid ""
"A plugin for formatting of sourcecode according to a specified set of rules"
msgstr ""
"Zehatutako arau multzo baten arabera sorburu-kodearen formatua ezartzen duen "
"plugin bat"

#: plugins/bazaar/kdevbazaar.json
msgctxt "Description"
msgid "This plugin integrates Bazaar to KDevelop"
msgstr "Plugin honek Bazaar KDevelopen bateratzen du"

#: plugins/clang/kdevclangsupport.json
msgctxt "Description"
msgid "C/C++ Language Support (Clang-based)"
msgstr "C/C++ lengoaien euskarria («Clang»en oinarritua)"

#: plugins/clangtidy/kdevclangtidy.json
msgctxt "Description"
msgid ""
"clang-tidy provides an extensible framework for diagnosing and fixing "
"typical programming errors, like style violations, interface misuse, or bugs "
"that can be deduced via static analysis. https://clang.llvm.org/extra/clang-"
"tidy/"
msgstr ""
"«clang-tidy»k ohiko programazio erroreak diagnostikatzeko eta konpontzeko "
"lanerako-marko hedagarri bat hornitzen du, hala nola estilo-urraketak, "
"interfazeen erabilera okerrak, edo analisi estatikoaren bidez ondoriozta "
"daitezkeen akatsak. https://clang.llvm.org/extra/clang-tidy/"

#: plugins/classbrowser/kdevclassbrowser.json
msgctxt "Description"
msgid ""
"This plugin provides a browsable model of the currently parsed classes and "
"other items."
msgstr ""
"Plugin honek dagoeneko analizatu diren klaseen eta beste elementu batzuen "
"modelo arakagarri bat hornitzen du."

#: plugins/clazy/kdevclazy.json
msgctxt "Description"
msgid "This plugin integrates Clazy to KDevelop"
msgstr "Plugin honek «Clazy» KDevelopen bateratzen du"

#: plugins/cmakebuilder/kdevcmakebuilder.json
msgctxt "Description"
msgid "Builds CMake Projects"
msgstr "«CMake» proiektuak eraikitzen ditu"

#: plugins/cmake/kdevcmakedocumentation.json
msgctxt "Description"
msgid "Allows KDevelop to provide CMake documentation"
msgstr "KDevelop-i «CMake»ren dokumentazioa hornitzeko gaitasuna ematen dio"

#: plugins/cmake/kdevcmakemanager.json
msgctxt "Description"
msgid "Allows KDevelop to manage CMake-based projects"
msgstr ""
"KDevelop-i «CMake»n oinarritutako proiektuak kudeatzeko gaitasuna ematen dio"

#: plugins/codeutils/kdevcodeutils.json
msgctxt "Description"
msgid ""
"Collection of various utilities that increase productivity while programming."
msgstr ""
"Programatzean produktibitatea handiagotzen duten hainbat utilitateren "
"bilduma."

#: plugins/contextbrowser/kdevcontextbrowser.json
msgctxt "Description"
msgid ""
"This plugin shows information about the current language context in a side "
"view, and highlights relevant declarations and uses."
msgstr ""
"Plugin honek aldeko ikuspegi batean uneko lengoaiaren testuinguruaren "
"informazioa erakusten du, eta deklarazio eta erabilera garrantzitsuak "
"nabarmentzen ditu."

#: plugins/cppcheck/kdevcppcheck.json
msgctxt "Description"
msgid "This plugin integrates Cppcheck (static analysis tool) to KDevelop"
msgstr ""
"Plugin honek Cppcheck (analisi estatikoko tresna) KDevelopen integratzen du"

#: plugins/craft/kdevcraft.json
msgctxt "Description"
msgid "Exposes KDE Craft environment as a runtime"
msgstr "KDE «Craft» exekuzio-aldiko ingurunea gisa agertzen du"

#: plugins/custom-buildsystem/kdevcustombuildsystem.json
msgctxt "Description"
msgid "Allows to use custom buildsystems for KDevelop projects"
msgstr ""
"KDevelop proiektuentzako eraiketa-sistema pertsonalizatuak erabiltzen uzten "
"du."

#: plugins/custom-definesandincludes/kdevdefinesandincludesmanager.json
msgctxt "Description"
msgid ""
"Configure which macros and include directories/files will be added to the "
"parser during project parsing."
msgstr ""
"Konfiguratu ze makro eta gehitze karpeta/fitxategi gehituko diren "
"analizatzailera proiektuaren analisian."

#: plugins/custommake/kdevcustommakemanager.json
msgctxt "Description"
msgid "Imports and edits custom make projects"
msgstr "Make proiektu pertsonalizatuak inportatu eta editatzen ditu"

#: plugins/customscript/kdevcustomscript.json
msgctxt "Description"
msgid "A plugin for formatting C files using custom scripts"
msgstr ""
"Neurrira egindako gidoiak erabiliz C fitxategiei formatua emateko plugin bat"

#: plugins/docker/kdevdocker.json
msgctxt "Description"
msgid "Exposes Docker runtimes"
msgstr "Dockerren exekuzio-denborak erakusten ditu"

#: plugins/documentswitcher/kdevdocumentswitcher.json
msgctxt "Description"
msgid "A most-recently-used document switcher for KDevPlatform."
msgstr "Azken aldian erabilitako dokumentuen aldatzailea KDevPlatformentzako."

#: plugins/documentview/kdevdocumentview.json
msgctxt "Description"
msgid ""
"This plugin displays a graphical view of all documents currently loaded and "
"separates them by mimetype."
msgstr ""
"Plugin honek unean kargatutako dokumentu guztien ikuspen grafikoa erakusten "
"du eta mimetype-z banatzen ditu."

#: plugins/execute/kdevexecute.json
msgctxt "Description"
msgid ""
"This plugin allows running of programs with no instrumentor, ie. natively by "
"the current host."
msgstr ""
"Plugin honek programak instrumentor bat gabe exekutatzen uzten du, hau da, "
"ostalariarengatik naitboki."

#: plugins/executeplasmoid/kdevexecuteplasmoid.json
msgctxt "Description"
msgid "Lets you view a plasmoid"
msgstr "Plasmoid bat ikusten uzten dizu"

#: plugins/executescript/kdevexecutescript.json
msgctxt "Description"
msgid "This plugin allows running of scripts."
msgstr "Plugin honek scripten exekuzioa ahalbidetzen du."

#: plugins/externalscript/kdevexternalscript.json
msgctxt "Description"
msgid ""
"Run external scripts or applications to manipulate the editor contents or do "
"other arbitrary actions."
msgstr ""
"Exekutatu kanpoko scriptak eta aplikazioak editorearen edukia aldatzeko edo "
"beste ausazko ekitzak egiteko."

#: plugins/filemanager/kdevfilemanager.json
msgctxt "Description"
msgid "This plugin brings a filemanager to KDevelop."
msgstr "Plugin honek fitxategi kudeatzaile bat ekartzen du KDevelopera."

#: plugins/filetemplates/kdevfiletemplates.json
msgctxt "Description"
msgid "Manages templates for source files"
msgstr "Iturri-fitxategien txantiloiak kudeatzen ditu"

#: plugins/flatpak/kdevflatpak.json
msgctxt "Description"
msgid "Exposes Flatpak runtimes"
msgstr "Flatpaken exekuzio-denborak erakusten ditu"

#: plugins/gdb/kdevgdb.json
msgctxt "Description"
msgid ""
"This plugin provides a frontend for GDB, a source-level debugger for C, C++ "
"and more."
msgstr ""
"Plugin honek aurrealde bat ematen tu GDBntzako, C, C++ etab. lengoaientzako "
"iturri-mailako araztaile bat."

#: plugins/genericprojectmanager/kdevgenericmanager.json
msgctxt "Description"
msgid "Allow KDevelop to manage generic projects"
msgstr "KDevelop proiektu generikoak kudeatzen ahalbidetzen du"

#: plugins/ghprovider/kdevghprovider.json
msgctxt "Description"
msgid "This plugin helps to obtain projects from GitHub"
msgstr "Plugin honek proiektuak GitHub-etik eskuratzen laguntzen dizu."

#: plugins/git/kdevgit.json
msgctxt "Description"
msgid "This plugin integrates Git to KDevelop"
msgstr "Plugin honek Git KDevelopen integratzen du"

#: plugins/grepview/kdevgrepview.json
msgctxt "Description"
msgid ""
"Allows fast searching of multiple files using patterns or regular "
"expressions. And allow to replace it too."
msgstr ""
"Ereduak edo adierazpen erregularrak erabiliz hainbat fitxategien bilaketa "
"azkarra ahalbidetzen du. Ordezketa ere baimentzen du."

#: plugins/heaptrack/kdevheaptrack.json
msgctxt "Description"
msgid "This plugin integrates Heaptrack to KDevelop"
msgstr "Plugin honek Heaptrack KDevelopen integratzen du"

#: plugins/konsole/kdevkonsoleview.json
msgctxt "Description"
msgid ""
"This plugin provides KDevelop with an embedded konsole for quick and easy "
"command line access."
msgstr ""
"Plugin honek konsole kapsulatu bat txertatzen du KDevelopen komando-lerrora "
"sarbide erraz eta arina emateko."

#: plugins/lldb/kdevlldb.json
msgctxt "Description"
msgid ""
"This plugin provides a frontend for LLDB, a next generation, high-"
"performance C/Obj-C/C++ debugger."
msgstr ""
"Plugin honek aurrealde bat ematen tu LLDBntzako, C/Obj-C/C++lengoaientzako "
"errendimendu altuko araztaile bat."

#: plugins/makebuilder/kdevmakebuilder.json
msgctxt "Description"
msgid "KDevelop Make Builder"
msgstr "KDevelop «Make» eraikitzailea"

#: plugins/manpage/kdevmanpage.json
msgctxt "Description"
msgid "This plugin provides Manual Pages integration"
msgstr "Plugin honek eskuliburuko orrien bateratzea hornitzen du"

#: plugins/meson/kdevmesonmanager.json
msgctxt "Description"
msgid "Imports and edits Meson projects"
msgstr "«Meson» proiektuak inportatu eta editatzen ditu"

#: plugins/ninjabuilder/kdevninja.json
msgctxt "Description"
msgid "KDevelop Ninja Builder"
msgstr "KDevelop Ninja eraikitzailea"

#: plugins/okteta/kdevokteta.json
msgctxt "Description"
msgid "Enables viewing and editing of the raw data of files (Okteta-based)"
msgstr ""
"Fitxategien datu gordinak (oinarri zortzitarrean) ikustea eta editatzea "
"gaitzen du"

#: plugins/openwith/kdevopenwith.json
msgctxt "Description"
msgid ""
"This plugin allows one to open files with associated external applications."
msgstr ""
"Plugin honek fitxategiak elkartutako kanpoko aplikazioekin irekitzen uzten "
"du."

#: plugins/outlineview/kdevoutlineview.json
msgctxt "Description"
msgid ""
"This plugin provides a view to show the outline of the currently open "
"document."
msgstr ""
"Plugin honek unean irekitako dokumentuaren eskema erakusten duen ikuspegi "
"bat ematen du."

#: plugins/patchreview/kdevpatchreview.json
msgctxt "Description"
msgid "This plugin allows reviewing patches directly in the editor."
msgstr "Plugin honek, editorean bertan adabakiak berrikusten uzten du."

#: plugins/perforce/kdevperforce.json
msgctxt "Description"
msgid "Provides Integration with Perforce Version Control System"
msgstr "«Perforce» bertsio kontrol sistemarekin bateratzea hornitzen du"

#: plugins/problemreporter/kdevproblemreporter.json
msgctxt "Description"
msgid "This plugin shows errors in source code."
msgstr "Plugin honek sorburu-kodeko erroreak erakusten ditu."

#: plugins/projectfilter/kdevprojectfilter.json
msgctxt "Description"
msgid ""
"Configure which files and folders inside the project folder should be "
"included or excluded."
msgstr ""
"Konfiguratu proiektu-karpetaren barneko zein fitxategi eta karpeta barneratu "
"edo kanporatu beharko liratekeen."

#: plugins/projectmanagerview/kdevprojectmanagerview.json
msgctxt "Description"
msgid "Lets you manage the project contents."
msgstr "Proiektuaren edukia kudeatzen uzten dizu."

#: plugins/qmakebuilder/kdevqmakebuilder.json
msgctxt "Description"
msgid "Builds QMake Projects"
msgstr "«QMake» proiektuak eraikitzen ditu"

#: plugins/qmakemanager/kdevqmakemanager.json
msgctxt "Description"
msgid "Imports and edits QMake projects"
msgstr "«QMake» proiektuak inportatu eta editatzen ditu"

#: plugins/qmljs/kdevqmljs.json
msgctxt "Description"
msgid "QML/JS language support (based on qmljs from QtCreator)"
msgstr "QML/JS lengoaiaren euskarria («QtCreator»en «qmljs»en oinarrituta)"

#: plugins/qthelp/kdevqthelp.json
msgctxt "Description"
msgid "This plugin provides QtHelp integration"
msgstr "Plugin honek «QtHelp»en bateratzea hornitzen du"

#: plugins/quickopen/kdevquickopen.json
msgctxt "Description"
msgid ""
"This plugin allows quick access to project files and language-items like "
"classes/functions."
msgstr ""
"Plugin honek proiektuetako fitxategietara eta lengoaiaren elementuetara, "
"hala nola klaseak/funtzioak, sarbide azkarra ematen du."

#: plugins/scratchpad/scratchpad.json
msgctxt "Description"
msgid ""
"Scratchpad lets you quickly run and experiment with code without a full "
"project, and even store todos."
msgstr ""
"«Scratchpad»ek, proiektu oso bat izan gabe, kodea azkar exekutatu eta "
"harekin esperimentatzen, baita zereginak gordetzen ere, uzten dizu."

#: plugins/sourceformatter/kdevsourceformatter.json
msgctxt "Description"
msgid ""
"Configure which style should be used for formatting of the sourcecode in a "
"project."
msgstr ""
"Konfiguratu, proiektu batean, sorburu-kodeari formatua emateko erabili "
"beharreko estiloa."

#: plugins/standardoutputview/kdevstandardoutputview.json
msgctxt "Description"
msgid ""
"Provides a text output tool view for other plugins to use, to show things "
"like compiler messages."
msgstr ""
"Beste pluginek erabiltzeko testu-irteerako tresna ikuspegi bat hornitzen du, "
"konpilatzailearen mezuen gisako gauzak erakusteko."

#: plugins/subversion/kdevsubversion.json
msgctxt "Description"
msgid "This plugin integrates Subversion to KDevelop."
msgstr "Plugin honek Subversion KDevelopen bateratzen du."

#: plugins/switchtobuddy/kdevswitchtobuddy.json
msgctxt "Description"
msgid ""
"Allows switching between buddy documents like implementation and header file."
msgstr ""
"Inplementazioa eta goiburu-fitxategia moduko dokumentu-lagunen artean "
"trukatzen uzten du."

#: plugins/testview/kdevtestview.json
msgctxt "Description"
msgid "Lets you see and run unit tests."
msgstr "Proba unitarioak ikusi eta exekutatzen uzten du."

