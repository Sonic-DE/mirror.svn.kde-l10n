#. (itstool) path: component/name
#: org.kde.okular.kirigami.appdata.xml:6
msgid "Okular Mobile"
msgstr "Okular Mugikorra"

#. (itstool) path: component/summary
#: org.kde.okular.kirigami.appdata.xml:7
msgid "Document Viewer"
msgstr "Dokumentu erakuslea"

#. (itstool) path: description/p
#: org.kde.okular.kirigami.appdata.xml:13
msgid ""
"Okular is a universal document viewer developed by KDE. Okular works on "
"multiple platforms, including but not limited to Linux, Windows, Mac OS X, "
"*BSD, etc."
msgstr ""
"Okular KDEk garatutako dokumentu erakusle unibertsal bat da. Okular hainbat  "
"plataformatan dabil, haien artean baino ez soilik haietara mugatua, Linux,  "
"windows, Mac OS X, *BSD, etab."

#. (itstool) path: description/p
#: org.kde.okular.kirigami.appdata.xml:16
msgid "Features:"
msgstr "Eginbideak:"

#. (itstool) path: ul/li
#: org.kde.okular.kirigami.appdata.xml:18
msgid ""
"Supported Formats: PDF, PS, Tiff, DjVu, Images, DVI, XPS, Fiction Book, "
"Comic Book, Plucker, EPub, Fax"
msgstr ""
"Onartutako formatuak: PDF, PS, Tiff, CHM, DjVu, irudiak, DVI, XPS, "
"FictionBook, Komiki liburua, Plucker, EPub, Fax"

#. (itstool) path: ul/li
#: org.kde.okular.kirigami.appdata.xml:19
msgid "Sidebar with contents, thumbnails, reviews and bookmarks"
msgstr ""
"Alboko-barra edukiekin, koadro-txikiekin, iritziekin eta laster-markekin"

#. (itstool) path: ul/li
