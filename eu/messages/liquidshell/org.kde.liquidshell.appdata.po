#. (itstool) path: component/name
#: org.kde.liquidshell.appdata.xml:4
msgid "liquidshell"
msgstr "liquidshell"

#. (itstool) path: component/summary
#. (itstool) path: description/p
#: org.kde.liquidshell.appdata.xml:5 org.kde.liquidshell.appdata.xml:10
msgid "liquidshell is an alternative to plasmashell"
msgstr "liquidshell plasmashell-en ordezko aukera bat da"

#. (itstool) path: description/p
#: org.kde.liquidshell.appdata.xml:11
msgid ""
"It does not use QtQuick but instead relies on QtWidgets, therefore no "
"hardware graphics acceleration is needed."
msgstr ""
"Ez du QtQuick erabiltzen horren ordez QtWidgets-en mende dago, ondorioz ez "
"da hardware grafikoen azeleraziorik behar."

#. (itstool) path: description/p
#: org.kde.liquidshell.appdata.xml:13
msgid "Main Features:"
msgstr "Ezaugarri nagusiak:"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:15
msgid "Wallpaper per virtual desktop"
msgstr "Horma-paper bat alegiazko mahaigaineko"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:16
msgid "No animations, no CPU hogging, low Memory footprint"
msgstr "Animaziorik ez, ez du PUZa bereganatzen, memoria-aztarna txikia"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:17
msgid "Instant startup"
msgstr "Bat-bateko abioa"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:18
msgid "No use of activities"
msgstr "Jardueren erabilerarik ez"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:19
msgid "QtWidgets based, therefore follows widget style from systemsettings"
msgstr ""
"QtWidgets oinarri du, beraz sistema-ezarpenetako trepeten estiloa jarraitzen "
"du"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:20
msgid ""
"Icons are used from your globally defined icon theme from systemsettings"
msgstr ""
"Sistema-ezarpenetan definitu duzun ikono gai orokorreko ikonoak erabiltzen "
"dira"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:21
msgid ""
"Colors are used from your globally defined color theme from systemsettings"
msgstr ""
"Sistema-ezarpenetan definitu duzun kolore gai orokorreko koloreak erabiltzen "
"dira"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:22
msgid ""
"Can additionally be styled with css by passing the commandline option -"
"stylesheet filename.css (see included example stylesheet.css)"
msgstr ""
"Gainera css-ak erabiliz apaindu daiteke komando-lerroko  «-stylesheet "
"fitxategia.css»  aukera pasatuz (ikusi  stylesheet.css  adibidea)"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:23
msgid ""
"uses existing KDE dialogs for most configurations, e.g. StartMenu, Virtual "
"Desktops, Bluetooth, Network"
msgstr ""
"Konfigurazio gehienetarako existitzen diren KDE elkarrizketa-koadroak "
"erabiltzen ditu, adib. hasiera-menua, alegiazko mahaigainak, Bluetooth, sarea"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:24
msgid "One bottom DesktopPanel"
msgstr "Mahaigaineko panel bat behean"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:25
msgid "Desktop Applets"
msgstr "Mahaigaineko aplikaziotxoak"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:43
msgid "Added install options (sleep/shutdown after install)"
msgstr "Instalazio-aukerak gehitu dira (instalatu ondoren lokartu/itzali)"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:44
msgid "Improved EULA handling on package installation"
msgstr "Paketeak instalatzerakoan EULA kudeaketa hobetu da"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:45
msgid "Added long format of time and date display to calendar popup"
msgstr "Egutegiaren laster-leihoan data eta orduaren formatu luzea gehitu da"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:46
msgid "Create default folder for storing quicklaunch apps"
msgstr "Laster-abiarazteko aplikazioak gordetzeko karpeta lehenetsia sortu"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:47
msgid "SysLoad widget width depends on CPU count"
msgstr "SysLoad trepetaren zabalera PUZ kopuruaren araberakoa da"

#. (itstool) path: ul/li
#. (itstool) path: description/p
#: org.kde.liquidshell.appdata.xml:48 org.kde.liquidshell.appdata.xml:54
msgid "Bugfixes and adjustments to newer KDE components"
msgstr "Akatsen konponketak eta KDE osagai berrietarako egokitzapenak"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:60
msgid "Notifications show how long they remain open (small animation)"
msgstr ""
"Jakinarazpenek zenbat denboraz irekita egongo diren erakusten dute (animazio "
"txikia)"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:61
msgid "Weather Applet shows moon phase"
msgstr "Eguraldi-aplikaziotxoak ilargiaren fasea erakusten du"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:62
msgid "Disk Usage Applet watches for mount/unmount to react quicker for update"
msgstr ""
"Eguneraketen aurrean azkarrago erreakzionatzeko, disko-erabileraren "
"aplikaziotxoak muntatze/desmuntatze gertaerak gainbegiratzen ditu"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:63
msgid "Display improvements in software updates component"
msgstr "Software-eguneraketen osagaian bistaratze-hobekuntzak"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:64
msgid ""
"Added DBUS-Menu support (some apps don't provide own menu but only via DBUS, "
"e.g. MS teams)"
msgstr ""
"DBUS-Menu euskarria gehitu da (aplikazio batzuek ez dute beren menurik "
"ematen eta DBUS bidez bakarrik eskaintzen dute; adib. MS Teams)"
