#: org.kde.skanpage.appdata.xml:14
msgid "Skanpage"
msgstr "Skanpage"

#. (itstool) path: component/summary
#: org.kde.skanpage.appdata.xml:15
msgid "Scan multi-page documents and images"
msgstr "Eskaneatu orri-anizkoitzeko dokumentuak eta irudiak"

#. (itstool) path: description/p
#: org.kde.skanpage.appdata.xml:17
msgid ""
"Skanpage is a simple scanning application optimized for multi-page document "
"scanning. It can also scan and save single-page documents and images."
msgstr ""
"«Skanpage» orri anitzeko dokumentuak eskaneatzeko optimizatuta dagoen "
"aplikazio bat da. Orri bakarreko dokumentuak eta irudiak ere eskaneatu eta "
"gorde ditzake."

#. (itstool) path: description/p
#: org.kde.skanpage.appdata.xml:18
msgid "Features:"
msgstr "Ezaugarriak:"

#. (itstool) path: ul/li
#: org.kde.skanpage.appdata.xml:20
msgid "Scanning from flatbed and ADF scanners"
msgstr "Gainazal lauko eta ADF eskanerretatik eskaneatzea"

#. (itstool) path: ul/li
#: org.kde.skanpage.appdata.xml:21
msgid "Configurable options for scanning device"
msgstr "Eskaneatzeko gailuen aukera konfiguragarriak"

#. (itstool) path: ul/li
#: org.kde.skanpage.appdata.xml:22
msgid "Reordering, rotation, and deletion of scanned pages"
msgstr "Eskaneatutako orrialdeak berrantolatzea, biratzea eta kentzea"

#. (itstool) path: ul/li
#: org.kde.skanpage.appdata.xml:23
msgid "Saving to multi-page PDF documents and image files"
msgstr "Orri-anizkoitzeko PDF dokumentuetan eta irudi fitxategietan gordetzea"

