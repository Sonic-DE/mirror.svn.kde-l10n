#: desktop/org.kde.spectacle.desktop.cmake:2
msgctxt "GenericName"
msgid "Screenshot Capture Utility"
msgstr "Pantaila-argazkiak atzemateko baliagarritasuna"

#: desktop/org.kde.spectacle.desktop.cmake:56 desktop/spectacle.notifyrc:4
msgctxt "Name"
msgid "Spectacle"
msgstr "Spectacle"

#: desktop/org.kde.spectacle.desktop.cmake:109
msgctxt "Comment"
msgid "Take screenshots and screen recordings"
msgstr "Atera pantaila-argazkiak eta pantailaren grabazioak"

#: desktop/org.kde.spectacle.desktop.cmake:147
msgctxt "Keywords"
msgid "snapshot;capture;print;screenshot;snipping;snipping tool;snip;"
msgstr ""
"argazkia;atzematea;inprimatzea;pantaila-argazkia;moztea;mozteko tresna;moztu;"

#: desktop/org.kde.spectacle.desktop.cmake:206
msgctxt "Name"
msgid "Capture Entire Desktop"
msgstr "Atzeman mahaigain osoa"

#: desktop/org.kde.spectacle.desktop.cmake:264
msgctxt "Name"
msgid "Capture Current Monitor"
msgstr "Atzeman uneko monitorea"

#: desktop/org.kde.spectacle.desktop.cmake:322
msgctxt "Name"
msgid "Capture Active Window"
msgstr "Atzeman leiho aktiboa"

#: desktop/org.kde.spectacle.desktop.cmake:380
msgctxt "Name"
msgid "Capture Rectangular Region"
msgstr "Atzeman eskualde laukizuzena"

#: desktop/org.kde.spectacle.desktop.cmake:438
msgctxt "Name"
msgid "Capture Window Under Cursor"
msgstr "Atzeman kurtsorearen azpiko leihoa"

#: desktop/org.kde.spectacle.desktop.cmake:491
msgctxt "Name"
msgid "Start/Stop Region Recording"
msgstr "Eskualdearen grabazioa Hasi/Gelditu"

#: desktop/org.kde.spectacle.desktop.cmake:531
msgctxt "Name"
msgid "Start/Stop Screen Recording"
msgstr "Pantailaren grabazioa Hasi/Gelditu"

#: desktop/org.kde.spectacle.desktop.cmake:571
msgctxt "Name"
msgid "Start/Stop Window Recording"
msgstr "Leihoaren grabazioa Hasi/Gelditu"

#: desktop/org.kde.spectacle.desktop.cmake:611
msgctxt "Name"
msgid "Launch without taking a screenshot"
msgstr "Abiatu pantaila-argazki bat hartu gabe"

#: desktop/spectacle.notifyrc:57
msgctxt "Comment"
msgid "Screenshot Capture Utility"
msgstr "Pantaila-argazkiak atzemateko baliagarritasuna"

#: desktop/spectacle.notifyrc:113
msgctxt "Name"
msgid "New Screenshot Saved"
msgstr "Pantaila-argazki berri bat gorde da"

#: desktop/spectacle.notifyrc:167
msgctxt "Comment"
msgid "A new screenshot was captured and saved"
msgstr "Pantaila-argazki berri bat atzeman eta gorde da"

#: desktop/spectacle.notifyrc:224
msgctxt "Name"
msgid "Recording Saved"
msgstr "Grabaketa gorde da"

#: desktop/spectacle.notifyrc:270
msgctxt "Comment"
msgid "A recording was captured and saved"
msgstr "Grabaketa bat atzeman eta gorde da"

#: desktop/spectacle.notifyrc:319
msgctxt "Name"
msgid "Text Extracted"
msgstr "Testua erauzi da"

#: desktop/spectacle.notifyrc:351
msgctxt "Comment"
msgid "Text has been extracted from image using OCR"
msgstr "Testua OCR erabiliz iruditik erauzi da"

