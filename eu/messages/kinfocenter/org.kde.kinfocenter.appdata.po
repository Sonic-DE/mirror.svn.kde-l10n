#. (itstool) path: component/name
#: org.kde.kinfocenter.appdata.xml:10
msgid "Info Center"
msgstr "Info-gunea"

#. (itstool) path: component/summary
#: org.kde.kinfocenter.appdata.xml:11
msgid "Learn about the system's hardware and status"
msgstr "Ezagutu sistemaren hardwarea eta egoera"

#. (itstool) path: description/p
#: org.kde.kinfocenter.appdata.xml:13
msgid ""
"The Info Center provides you with a centralized and convenient overview of "
"your system and desktop environment."
msgstr ""
"Info-guneak zure sistemaren eta mahaigain ingurunearen ikuspegi-orokor "
"zentralizatu eta praktiko bat ematen dizu."

#. (itstool) path: description/p
#: org.kde.kinfocenter.appdata.xml:15
msgid ""
"The information center is made up of multiple modules. Each module is a "
"separate application, but the information center organizes all of these "
"programs into a convenient location."
msgstr ""
"Informazio gunea modulu anitzez osatua dago. Modulu bakoitza aplikazio "
"bereizi bat da, baino informazio guneak programa guzti hauek kokaleku "
"praktiko batean kokatzen ditu."

#~ msgid "Centralized and convenient overview of system information"
#~ msgstr "Sistema-informazioaren ikuspegi-orokor zentralizatu eta praktikoa"
