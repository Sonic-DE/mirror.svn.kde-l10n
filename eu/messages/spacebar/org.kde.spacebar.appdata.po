#. (itstool) path: description/p
#: org.kde.spacebar.appdata.xml:12
msgid ""
"Spacebar is a SMS/MMS messaging client. It allows you to send text messages, "
"pictures and other files over a cellular network."
msgstr ""
"Spacebar SMS/MMS mezularitza bezero bat da. Mugikorreko sare baten bidez "
"testu-mezuak, argazkiak eta beste fitxategi batzuk bidaltzen uzten dizu."

#~ msgid "KDE Community"
#~ msgstr "KDE komunitatea"

#~ msgid ""
#~ "Spacebar is a telepathy client for Plasma Mobile, that is primarily "
#~ "written for sending and receiving SMS/MMS."
#~ msgstr ""
#~ "Spacebar Plasma Mobile-rako Telepathy-ren bezero bat da, nagusiki SMS/"
#~ "MMSak bidaltzeko eta jasotzeko idatzia."
