#. (itstool) path: component/name
#: org.kde.kgraphviewer.appdata.xml:9
msgid "KGraphViewer"
msgstr "KGraphViewer"

#. (itstool) path: component/summary
#: org.kde.kgraphviewer.appdata.xml:10
msgid "A Graphviz DOT graph viewer"
msgstr "Graphviz DOT grafo erakusle bat"

#. (itstool) path: description/p
#: org.kde.kgraphviewer.appdata.xml:12
msgid ""
"KGraphViewer is a Graphviz DOT graph file viewer, aimed to replace the other "
"outdated Graphviz tools. Graphs are commonly used in scientific domains and "
"particularly in computer science."
msgstr ""
"KGraphViewer Graphviz DOT grafo fitxategi erakusle bat da, zaharkitutako "
"beste Graphviz tresnak ordezkatzea xede duena. Grafoak zientzia eremuan "
"erabili ohi dira, eta bereziki informatikan."

#. (itstool) path: description/p
#: org.kde.kgraphviewer.appdata.xml:16
msgid "Features:"
msgstr "Ezaugarriak:"

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:18
msgid "Zooming"
msgstr "Zoom egitea"

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:19
msgid "Threaded loading of several graphs in tabs"
msgstr "Zenbait grafiko, hari ezberdinak erabiliz, fitxatan zamatzea"

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:20
msgid "Saving of the recent files list"
msgstr "Azken aldiko fitxategien zerrenda gordetzea"

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:21
msgid "Manual reload of files"
msgstr "Fitxategiak eskuz birzamatzea"

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:22
msgid "Display of a bird-eye view of the graph"
msgstr "Grafoa txoriaren ikuspegitik azaltzea"

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:23
msgid "Moving of the graph by dragging"
msgstr "Arrastatuz grafoa mugitzea"

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:24
msgid "Full featured printing"
msgstr "Inprimaketa ezaugarri guztiekin"

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:25
msgid "Perfect drawing of all graphviz example graphs"
msgstr "graphviz adibide grafo guztien marrazki perfektua"

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:26
msgid "Automatically choose dot for directed graphs and neato for undirected"
msgstr ""
"Aukeratu «dot» automatikoki gidatutako grafoetarako eta «neato» gidatu "
"gabekoetarako"

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:27
msgid ""
"Possibility to use an arbitrary layout algorithm as soon as it produces xdot "
"format"
msgstr ""
"Antolaera arbitrario bat erabiltzeko aukera «xdot» formatua sortzen duen "
"bezain laster"

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:28
msgid ""
"Automatic reloading with user confirmation of (externally) modified files "
"(configurable)"
msgstr ""
"Erabiltzailearen baieztapenarekin (kanpotik) aldatutako fitxategien "
"birzamatze automatikoa (konfiguragarria)"

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:29
msgid "Open new instances as new tabs in the old one (configurable)"
msgstr ""
"Ireki instantzia berriak fitxa berri gisa leiho zaharrean (konfiguragarria)"
