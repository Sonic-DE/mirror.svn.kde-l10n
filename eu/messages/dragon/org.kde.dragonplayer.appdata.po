#. (itstool) path: component/name
#: org.kde.dragonplayer.appdata.xml:9
msgid "Dragon Player"
msgstr "Dragon Player"

#. (itstool) path: component/summary
#: org.kde.dragonplayer.appdata.xml:10
msgid "Play video files and streams"
msgstr "Bideo fitxategiak eta korronteak jo"

#. (itstool) path: description/p
#: org.kde.dragonplayer.appdata.xml:12
msgid ""
"Dragon Player is a video player focusing on simplicity instead of features. "
"Its easy-to-use interface is designed to get out of your way and simply play "
"your video files and streams."
msgstr ""
"Dragon Player bideo jotzaile bat da, ezaugarrietan baino sinpletasunean "
"arreta jartzen duena. Bere interfaze erabilerraza zuri trabarik ez egiteko, "
"eta besterik gabe zure fitxategiak eta korronteak jotzeko diseinatuta dago."

#. (itstool) path: description/p
#: org.kde.dragonplayer.appdata.xml:15
msgid "Features:"
msgstr "Ezaugarriak:"

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:17
msgid ""
"Click to play or pause, and double-click to enter or exit full screen mode."
msgstr ""
"Egin klik jotzeko edo etenaldirako, eta egin klik bikoitza pantaila-osoko "
"moduan sartzeko edo irteteko."

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:18
msgid ""
"Choose the subtitle language, and automatically load the right one for your "
"language, if possible."
msgstr ""
"Aukeratu azpidatzien hizkuntza, eta zure hizkuntzarako egokia dena "
"automatikoki zamatu, ahal bada."

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:19
msgid "Choose the audio track."
msgstr "Aukeratu audio-pista."

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:20
msgid "Choose the video track."
msgstr "Aukeratu bideo-pista."

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:21
msgid "Adjust the volume by scrolling."
msgstr "Kiribilduz bolumena doitu."

#~ msgid "Video player with focus on simplicity"
#~ msgstr "Erraztasuna helburu duen bideo-jotzailea"

#~ msgid "Simple Interface"
#~ msgstr "Interfaze erraza"

#~ msgid ""
#~ "Resuming videos: Starts playing a video where you were watching it last "
#~ "time"
#~ msgstr ""
#~ "Bideoak berrekitea: Bideo bat, azken aldian utzi zenuen lekutik, jotzen "
#~ "hasten da"

#~ msgid ""
#~ "Support for subtitles: Automatically loads subtitles with the matching "
#~ "name"
#~ msgstr ""
#~ "Azpidatziak onartzen ditu: Automatikoki zamatzen ditu bat-datozen izeneko "
#~ "azpidatziak"

#~ msgid "Video display settings (brightness, contrast)"
#~ msgstr "Bideoa azaltzeko ezarpenak (distira, kontrastea)"

#~ msgid ""
#~ "Due to using Solid and Phonon DragonPlayer is independent of any "
#~ "multimedia framework or hardware abstraction layer"
#~ msgstr ""
#~ "Solid eta Phonon erabiltzen dituelako, DragonPlayer multimedia "
#~ "azpiegituretatik eta hardware abstrakzio geruzetatik independentea da"

#~ msgid "Supports playing CDs and DVDs"
#~ msgstr "CDak eta DVDak jotzeko gaitasuna du"
