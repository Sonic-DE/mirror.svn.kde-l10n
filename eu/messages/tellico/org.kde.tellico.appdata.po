msgstr "Leiho nagusia liburu bilduma bateko elementu soil bat erakutsiz"

#. (itstool) path: screenshot/caption
#: org.kde.tellico.appdata.xml:49
msgid "The main window showing side-by-side views of a game collection"
msgstr "Leiho nagusia alboz-albo joko bilduma baten ikuspegiak erakutsiz"
