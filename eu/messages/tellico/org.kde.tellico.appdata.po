#. (itstool) path: component/name
#: org.kde.tellico.appdata.xml:9
msgid "Tellico"
msgstr "Tellico"

#. (itstool) path: component/summary
#: org.kde.tellico.appdata.xml:10
msgid "Collection Manager"
msgstr "Bilduma kudeatzailea"

#. (itstool) path: description/p
#: org.kde.tellico.appdata.xml:12
msgid ""
"Tellico is an application for organizing your collections. It provides "
"default templates for books, bibliographies, videos, music, video games, "
"coins, stamps, trading cards, comic books, and wines. It allows you to enter "
"your collection in a catalogue database, saving many different properties "
"like title, author, etc."
msgstr ""
"Tellico zure bildumak antolatzeko aplikazio bat da. Lehenetsitako "
"txantiloiak hornitzen ditu liburu, bibliografia, bideo, musika, bideo-joko, "
"txanpon, zigilu, karta (kromo), komiki-liburu, eta ardoentzako. Zure bilduma "
"katalogo datu-base batean sartzen uzten dizu, propietate ezberdin ugari "
"gordez, izenburua,  egilea, eta abar."

#. (itstool) path: description/p
#: org.kde.tellico.appdata.xml:17
msgid "Features:"
msgstr "Ezaugarriak:"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:19
msgid ""
"Supports default collections of books, bibliographic entries, videos, music, "
"video games, comic books, coins, stamps, trading cards, wines, board games, "
"and file catalogs"
msgstr ""
"Liburu, bibliografia-sarrera, bideo, musika, bideo-joko, komiki-liburu, "
"txanpon, karta (kromo), ardo, taula-joko eta fitxategi-katalogoen bilduma "
"lehenetsiak onartzen ditu"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:20
msgid "Supports user-defined custom collections"
msgstr ""
"Erabiltzaileek definitutako beren erara moldatutako bildumak onartzen ditu"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:21
msgid ""
"Supports any number of user-defined fields, of several different types: "
"text, paragraph, list, checkbox, number, URL, date, images, and combinations"
msgstr ""
"Erabiltzaileek definitutako eremu kopuru mugagabea onartzen du, mota "
"ezberdinetakoak: testua, paragrafoa, zerrenda, egiaztapen-lauki, zenbaki, "
"URL, data, irudi, eta konbinazioak"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:22
msgid "Handles entries with multiple authors, genres, keywords, etc"
msgstr ""
"Egile, genero, gako-hitz, eta abar anizkoitzak dituzten sarrerak maneiatzen "
"ditu"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:23
msgid "Automatically formats titles and names"
msgstr "Automatikoki formateatzen ditu izenburuak eta izenak"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:24
msgid "Supports collection searching and view filtering"
msgstr "Bildumetan bilatzea eta ikuspegietan iragaztea onartzen du"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:25
msgid "Sorts and groups collection by various properties"
msgstr "Bildumak hainbat propietateren arabera sailkatu eta taldekatzen ditu"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:26
msgid "Allows customizable entry templates through XSLT"
msgstr ""
"XSLT erabliz norbere erara molda daitezkeen sarrera-txantiloiak onartzen ditu"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:27
msgid "Imports MODS, Bibtex, RIS, CSV, PDF metadata, and many other formats"
msgstr ""
"MODS, Bibtex, RIS, CSV, PDF meta-datuak, eta beste formatu ugari inportatzen "
"ditu"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:28
msgid "Exports to Bibtex, ONIX, CSV, HTML, and other formats"
msgstr "Bibtex, ONIX, CSV, HTML, eta beste formatuetara esportatzen du"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:29
msgid ""
"Imports information directly from Amazon.com, IMDb, z39.50 servers, PubMed, "
"SRU servers, CrossRef.org, various other websites, and from external scripts"
msgstr ""
"Informazioa inportatzen du zuzenean Amazon.com, IMDb, z39.50 zerbitzari, "
"PubMed, SRU zerbitzari, CrossRef.org, beste webgune batzuetatik, eta kanpoko "
"scriptetatik."

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:30
msgid "Imports CDDB data for cataloging audio CDs"
msgstr "Audio CDak katalogatzeko CDDB datuak inportatzen ditu"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:31
msgid "Scans and imports audio file collections, such as mp3 or ogg"
msgstr "Miatu eta audio bildumak inportatzen ditu, hala nola mp3 edo ogg"

