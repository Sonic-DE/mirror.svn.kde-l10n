#: modules/account/contents/ui/main.qml:69
#, kde-format
msgid "We need a few details to complete the setup."
msgstr "Ezarpena osatzeko xehetasun batzuk behar ditugu."

#: modules/account/contents/ui/main.qml:80
#, kde-format
msgctxt "@info"
msgid "This user will be an administrator."
msgstr "Erabiltzaile hau administratzailea izango da."

#: modules/account/contents/ui/main.qml:84
#, kde-kuit-format
msgctxt "@info"
msgid ""
"This user will have administrative privileges on the system.<nl/><nl/>This "
"means that they can change system settings, install software, and access all "
"files on the system.<nl/><nl/>Choose a strong password for this user."
msgstr ""
"Erabiltzaile honek sisteman administratzaile pribilegioak izango ditu.<nl/"
"><nl/>Horrek esan nahi du sistemaren ezarpenak aldatu, softwarea instalatu, "
"eta sistemako fitxategi guztiak atzi ditzakeela.<nl/><nl/>Erabiltzaile "
"honentzako pasahitz sendo bat aukeratu."

