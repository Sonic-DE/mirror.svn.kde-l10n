#: modules/account/metadata.json
msgctxt "Description"
msgid "Allow the user to set the account name."
msgstr "Eman erabiltzaileari kontuaren izena ezartzeko aukera."

#: modules/cellular/metadata.json
msgctxt "Description"
msgid "Allow the user to configure the cellular network."
msgstr "Eman erabiltzaileari mugikor-sarea ezartzeko aukera."

#: modules/finished/metadata.json
msgctxt "Description"
msgid ""
"Shown when the initial system setup is completed, and the user can commit "
"the changes."
msgstr ""
"Sistemaren hasierako ezarpena osatuta dagoenean erakusten da, eta "
"erabiltzailek aldaketak baliozkotu ditzakeenean."

#: modules/hostname/metadata.json
msgctxt "Description"
msgid "Allow the user to set the system hostname."
msgstr "Eman erabiltzaileari sistemaren ostalari-izena ezartzeko aukera."

#: modules/keyboard/metadata.json
msgctxt "Description"
msgid "Allow the user to choose the keyboard layout."
msgstr "Eman erabiltzaileari teklatuaren antolaera ezartzeko aukera."

#: modules/language/metadata.json
msgctxt "Description"
msgid "Allow the user to set the system language."
msgstr "Eman erabiltzaileari sistemaren hizkuntza ezartzeko aukera."

#: modules/prepare/metadata.json
msgctxt "Description"
msgid "Allows the user to configure the environment before using it."
msgstr "Eman erabiltzaileari erabili aurretik ingurunea konfiguratzeko aukera."

#: modules/time/metadata.json
msgctxt "Description"
msgid "Allow the user to set the timezone."
msgstr "Eman erabiltzaileari denbora-eremua ezartzeko aukera."

#: modules/wifi/metadata.json
msgctxt "Description"
msgid "Allow the user to connect to a Wi-Fi network."
msgstr "Eman erabiltzaileari Wi-Fi sare batera konektatzeko aukera."

