msgid "Legacy support for the zip archive format"
msgstr "zip artxibo formatuarentzako heredatutako euskarria"

#: plugins/libarchive/kerfuffle_libarchive.json.cmake
msgctxt "Description"
msgid "Full support for compressed TAR archives"
msgstr "Konprimatutako TAR artxiboentzako euskarri osoa"

#: plugins/libarchive/kerfuffle_libarchive_readonly.json.cmake
msgctxt "Description"
msgid "Open and extract DEB, RPM, ISO, AppImage, XAR, CAB, and EXE files"
msgstr ""
"Ireki eta erauzi DEB, RPM, ISO, AppImage, XAR, CAB, eta EXE fitxategiak"

