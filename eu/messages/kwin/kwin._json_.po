msgctxt "Description"
msgid "Slide Plasma popups in and out"
msgstr "Plasma gainerakorrak barrura eta kanpora irristatu"

#: src/plugins/squash/package/metadata.json
msgctxt "Description"
msgid "Squash windows when they are minimized"
msgstr "Zanpatu leihoak haiek ikonotzen direnean"

