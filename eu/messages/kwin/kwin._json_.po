msgctxt "Description"
msgid "Slide back windows when another window is raised"
msgstr "Irristatu atzerantz beste leiho bat altxatzen denean"

#: src/plugins/slide/metadata.json
msgctxt "Description"
msgid "Slide between virtual desktops when switching"
msgstr "Aldatzean, alegiazko mahaigainen artean irristatu"

