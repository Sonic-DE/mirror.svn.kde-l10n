msgctxt "Description"
msgid "Helper effect for startup feedback"
msgstr "Abiatze berrelikaduraren efektu laguntzailea"

#: src/plugins/synchronizeskipswitcher/package/metadata.json
msgctxt "Description"
msgid ""
"Hides all windows marked as Skip Taskbar to be also excluded from window "
"switchers (e.g. Alt+Tab)"
msgstr ""
"'Saltatu ataza-barra' gisa markatuta dauden leiho guztiak ezkutatzen ditu "
"leiho-kommutadoretik kanpo ere uzteko (adib., Alt+Tab)"

#: src/plugins/systembell/metadata.json
msgctxt "Description"
msgid "Provides the bell"
msgstr "Txirrina hornitzen du"

#: src/plugins/thumbnailaside/metadata.json
msgctxt "Description"
msgid ""
"Display window thumbnails on the edge of the screen; activated with a "
"keyboard shortcut"
msgstr ""
"Bistaratu leihoen koadro txikiak pantailaren ertzean; teklatuko lasterbide "
"batekin aktibatua"

#: src/plugins/tileseditor/metadata.json
msgctxt "Description"
msgid "Editor for the tiling areas"
msgstr "Eremu lauzatuen editorea"

#: src/plugins/touchpoints/metadata.json
msgctxt "Description"
msgid "Visualize touch points"
msgstr "Bistaratu ukimen puntuak"

#: src/plugins/trackmouse/metadata.json
msgctxt "Description"
msgid ""
"Display a mouse cursor locating effect; activated with a keyboard shortcut"
msgstr ""
"Bistaratu saguaren kurtsorea kokatzeko efektu bat; teklatuko lasterbide "
"batekin aktibatua"

#: src/plugins/translucency/package/metadata.json
msgctxt "Description"
msgid "Make windows translucent under different conditions"
msgstr "Leihoak zeharrargitsu bihurtzen ditu baldintzen arabera"

#: src/plugins/videowall/package/metadata.json
msgctxt "Description"
msgid ""
"Spans fullscreen video player over all attached screens to create a Video "
"Wall"
msgstr ""
"Bideo-horma bat sortzeko, leiho-osoko bideo jotzailea atxikitako pantaila "
"guzietara hedatzen du"

