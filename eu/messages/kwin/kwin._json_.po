msgstr "Luzatu, pantaila-osoko modutik/modura aldatzen diren leihoak"

#: src/plugins/glide/metadata.json
msgctxt "Description"
msgid "Glide windows as they appear or disappear"
msgstr "Irristatu leihoak haiek agertzean edo desagertzean"

#: src/plugins/hidecursor/metadata.json
msgctxt "Description"
msgid "Hide mouse cursor on inactivity or keyboard input"
msgstr ""
"Ezkutatu saguaren kurtsorea jarduerarik ez dagoenean edo teklatuaren sarrera "
"dagoenean"

#: src/plugins/highlightwindow/metadata.json
msgctxt "Description"
msgid "Highlight the appropriate window when hovering over taskbar entries"
msgstr ""
"Nabarmendu dagokion leihoa sagua ataza-barraren sarreren gainetik igarotzean"

#: src/plugins/invert/metadata.json
msgctxt "Description"
msgid ""
"Inverts the color of the desktop and windows; activated with a keyboard "
"shortcut"
msgstr ""
"Mahaigaineko eta leihoetako koloreak alderantzikatzen ditu; teklatuko "
"lasterbide batekin aktibatua"

#: src/plugins/kscreen/metadata.json
msgctxt "Description"
msgid "Helper Effect for KScreen"
msgstr "KScreen-en efektu laguntzailea"

#: src/plugins/login/package/metadata.json
msgctxt "Description"
msgid "Fade to the desktop when logging in"
msgstr "Moteldu mahaigainerantz saioa hastean"

#: src/plugins/logout/package/metadata.json
msgctxt "Description"
msgid "Fade to the logout screen"
msgstr "Moteldu saioa ixteko pantailarantz"

#: src/plugins/magiclamp/metadata.json
msgctxt "Description"
msgid "Simulate a magic lamp when minimizing windows"
msgstr "Lanpara magikoarena egin leihoak ikonotzean"

#: src/plugins/magnifier/metadata.json
msgctxt "Description"
msgid ""
"Magnify the section of the screen that is near the mouse cursor; activated "
"with a keyboard shortcut"
msgstr ""
"Handiagotu sagu-kurtsorearen ondoko pantailaren zatia; teklatuko lasterbide "
"batekin aktibatua"

#: src/plugins/maximize/package/metadata.json
msgctxt "Description"
msgid "Stretch windows when they are maximized or restored"
msgstr "Luzatu leihoak maximizatzen edo lehengoratzen direnean"

#: src/plugins/minimizeall/package/metadata.json
msgctxt "Description"
msgid "Adds a shortcut to minimize and restore all windows"
msgstr ""
"Lasterbide bat eransten du leiho guztiak minimizatzeko eta lehengoratzeko"

#: src/plugins/mouseclick/metadata.json
msgctxt "Description"
msgid ""
"Creates an animation whenever a mouse button is clicked. This is useful for "
"screenrecordings/presentations. Activated with a keyboard shortcut"
msgstr ""
"Animazio bat sortzen du saguaren botoi bati klik egiterakoan. Erabilgarria "
"da pantaila-grabaketarako/aurkezpenetarako. Teklatuko lasterbide batekin "
"aktibatua"

#: src/plugins/mousemark/metadata.json
msgctxt "Description"
msgid ""
"Allows you to draw lines on the desktop; activated with a keyboard shortcut"
msgstr ""
"Mahaigainean marrak marrazteko aukera ematen dizu; ; teklatuko lasterbide "
"batekin aktibatua"

#: src/plugins/outputlocator/metadata.json
msgctxt "Description"
msgid "Show screen names"
msgstr "Erakutsi pantailen izenak"

#: src/plugins/overview/metadata.json
msgctxt "Description"
msgid ""
"Allows you to overview virtual desktops and windows; activated with a "
"keyboard shortcut"
msgstr ""
"Alegiazko mahaigain eta leihoen ikuspegi orokor bat izaten uzten dizu; "
"teklatuko lasterbide batekin aktibatua"

#: src/plugins/scale/package/metadata.json
msgctxt "Description"
msgid "Make windows scale in and out when they are shown or hidden"
msgstr "Leihoak handitu eta txikitu haiek erakutsi edo ezkutatzean"

#: src/plugins/screenedge/metadata.json
msgctxt "Description"
msgid ""
"Highlights screen edges and corners that trigger actions when touched as the "
"cursor approaches them"
msgstr ""
"Pantailaren ertzak eta kurtsorea hurbiltzean ukitzen dituenean ekitzak "
"eragiten dituzten izkinak nabarmentzen ditu"

#: src/plugins/screentransform/metadata.json
msgctxt "Description"
msgid "Animates display transformations"
msgstr "Pantaila aldaketak animatzen ditu"

#: src/plugins/sessionquit/package/metadata.json
msgctxt "Description"
msgid "Keep the desktop background alive during logout until the end"
msgstr "Eutsi mahaigaineko atzeko-planoa bizirik saio-ixten bukaera arte"

#: src/plugins/shakecursor/metadata.json
msgctxt "Description"
msgid ""
"Makes the cursor larger when the pointer is quickly moved back and forth"
msgstr ""
"Kurtsorea handitzen du erakuslea aurrera eta atzera azkar mugitzen denean"

#: src/plugins/sheet/metadata.json
msgctxt "Description"
msgid ""
"Make modal dialogs smoothly fly in and out when they are shown or hidden"
msgstr ""
"Egin elkarrizketa-koadro modalak leunki hegan sartu edo irteten daitezen "
"haiek erakutsi edo ezkutatzean"

