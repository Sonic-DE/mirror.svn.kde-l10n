#. (itstool) path: component/name
#: org.kde.kdiff3.appdata.xml:13
msgid "KDiff3"
msgstr "KDiff3"

#. (itstool) path: component/summary
#: org.kde.kdiff3.appdata.xml:14
msgid "A file and folder comparison and merge tool"
msgstr "Fitxategiak eta karpetak alderatu eta bateratzeko tresna bat"

#. (itstool) path: description/p
#: org.kde.kdiff3.appdata.xml:17
msgid "KDiff3 is a file and folder diff and merge tool which"
msgstr "KDiff3 fitxategiak eta karpetak «diff» eta bateratzeko tresna bat da,"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:19
msgid "compares and merges two or three text input files or folders,"
msgstr ""
"sarrerako bi edo hiru testu fitxategi edo karpeta alderatu eta bateratzen "
"dituena,"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:20
msgid "shows the differences line by line and character by character(!),"
msgstr ""
"ezberdintasunak lerroz-lerro eta karakterez-karaktere erakusten ditu(!),"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:21
msgid "provides an automatic merge-facility,"
msgstr "automatikoki bateratzeko erraztasuna ematen du,"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:22
msgid "has an editor for comfortable solving of merge-conflicts,"
msgstr "bateratze-gatazkak erosotasunez ebazteko editore bat dauka,"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:23
msgid "provides network transparency via KIO,"
msgstr "KIO bidez sarearekiko gardentasuna hornitzen du,"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:24
msgid "has options to highlight or hide changes in white-space or comments,"
msgstr ""
"zuriune edo iruzkinetako aldaketak nabarmentzeko edo ezkutatzeko aukerak "
"ditu,"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:25
msgid "supports Unicode, UTF-8 and other file encodings,"
msgstr "Unicode, UTF-8 eta beste fitxategi kodeketa batzuk onartzen ditu,"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:26
msgid "prints differences,"
msgstr "ezberdintasunak inprimatzen ditu,"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:27
msgid "supports version control keyword and history merging."
msgstr "bertsio-kontrolerako gako-hitzak eta historia bateratzea onartzen du."
