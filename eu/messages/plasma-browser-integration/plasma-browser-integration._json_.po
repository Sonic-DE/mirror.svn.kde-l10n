#: flatpak-integrator/browserintegrationflatpakintegrator.json
msgctxt "Name"
msgid "Plasma Browser Integration Flatpak Integration"
msgstr "Plasman arakatzaileak bateratzea Flatpak bateratzea"

#: reminder/browserintegrationreminder.json
msgctxt "Name"
msgid "Plasma Browser Integration Installation Reminder"
msgstr "Plasman arakatzaileak bateratzea instalazioaren ohartarazpena"

#: flatpak-integrator/browserintegrationflatpakintegrator.json
msgctxt "Description"
msgid "Automatically enables support for Firefox Flatpak"
msgstr "Firefox-en Flatpak-erako euskarria automatikoki gaitzen du"

#: reminder/browserintegrationreminder.json
msgctxt "Description"
msgid ""
"Provides a link to the browser extension if the Plasma Browser Integration "
"host is installed"
msgstr ""
"Arakatzaile hedapenerako esteka bat hornitzen du, Plasman arakatzaileak "
"bateratzeko ostalaria instalatua badago"

#~ msgctxt "Name"
#~ msgid "Plasma Browser Integration Host"
#~ msgstr "Plasman arakatzaileak bateratzeko ostalaria"

#~ msgctxt "Name|plasma runner"
#~ msgid "Browser History"
#~ msgstr "Arakatzailearen historia"

#~ msgctxt "Comment"
#~ msgid "Search the browser history for visited websites"
#~ msgstr "Bilatu arakatzailearen historian bisitatutako webguneen bila"

#~ msgctxt "X-Plasma-Runner-Syntax-Descriptions"
#~ msgid "Finds websites in the browser history whose title or URL match :q:"
#~ msgstr ""
#~ "Arakatzailearen historian haien titulua edo URLa :q:(e)kin bat datozen "
#~ "webguneak aurkitzen ditu"

#~ msgctxt "Name|plasma runner"
#~ msgid "Browser Tabs"
#~ msgstr "Arakatzailearen fitxak"

#~ msgctxt "Comment"
#~ msgid "Find and activate browser tabs"
#~ msgstr "Aurkitu eta aktibatu arakatzailearen fitxak"

#~ msgctxt "X-Plasma-Runner-Syntax-Descriptions"
#~ msgid "Finds open browser tabs whose title or URL match :q:"
#~ msgstr ""
#~ "Irekita dauden arakatzaileko fitxen artean haien titulua edo URLa :q:"
#~ "(e)kin bat datozenak aurkitzen ditu"
