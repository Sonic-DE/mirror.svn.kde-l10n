#: core/smb4k.notifyrc:3 smb4k/org.kde.smb4k.desktop:3
msgctxt "Name"
msgid "Smb4K"
msgstr "Smb4K"

#: core/smb4k.notifyrc:44 smb4k/org.kde.smb4k.desktop:80
msgctxt "Comment"
msgid "Advanced Network Neighborhood Browser"
msgstr "Sareko auzo-arakatzaile aurreratua"

#: core/smb4k.notifyrc:87
msgctxt "Name"
msgid "Notification"
msgstr "jakinarazpena"

#: core/smb4k.notifyrc:128
msgctxt "Comment"
msgid "The user is notified about an action"
msgstr "Erabiltzaileari ekintza baten berri ematen zaio"

#: core/smb4k.notifyrc:169
msgctxt "Name"
msgid "Warning"
msgstr "Abisua"

#: core/smb4k.notifyrc:210
msgctxt "Comment"
msgid "A warning is shown to the user"
msgstr "Erabiltzaileari abisu bat erakusten zaio"

#: core/smb4k.notifyrc:252
msgctxt "Name"
msgid "Error"
msgstr "Errorea"

#: core/smb4k.notifyrc:293
msgctxt "Comment"
msgid "An error message is shown to the user"
msgstr "Erabiltzaileari errore-mezu bat erakusten zaio"

#: core/smb4k.notifyrc:333
msgctxt "Name"
msgid "Share mounted"
msgstr "Partekatzea muntatuta dago"

#: core/smb4k.notifyrc:371
msgctxt "Comment"
msgid "A share has been mounted"
msgstr "Partekatze bat muntatu da"

#: core/smb4k.notifyrc:413
msgctxt "Name"
msgid "Share unmounted"
msgstr "Partekatzea desmuntatu da"

#: core/smb4k.notifyrc:451
msgctxt "Comment"
msgid "A share has been unmounted"
msgstr "Partekatze bat desmuntatu da"

#: core/smb4k.notifyrc:493
msgctxt "Name"
msgid "Shares mounted"
msgstr "Partekatzeak muntatu dira"

#: core/smb4k.notifyrc:531
msgctxt "Comment"
msgid "Multiple shares have been mounted"
msgstr "Hainbat partekatze muntatu dira"

#: core/smb4k.notifyrc:573
msgctxt "Name"
msgid "Shares unmounted"
msgstr "Partekatzeak desmuntatu dira"

#: core/smb4k.notifyrc:611
msgctxt "Comment"
msgid "Multiple shares have been unmounted"
msgstr "Hainbat partekatze muntatu dira"

#: core/smb4k.notifyrc:653
msgctxt "Name"
msgid "Migrating login credentials"
msgstr "Saio-hasteko egiaztagiriak migratzen"

#: core/smb4k.notifyrc:682
msgctxt "Comment"
msgid ""
"The login credentials are migrated to the new format and the active password "
"manager"
msgstr ""
"Saio-hasteko egiaztagiriak formatu berrira eta aktibo dagoen pasahitz "
"kudeatzailera migratzen dira"

#: core/smb4k.notifyrc:714
msgctxt "Name"
msgid "Mimetype not supported"
msgstr "MIME-mota ez da onartzen"

#: core/smb4k.notifyrc:752
msgctxt "Comment"
msgid "The mimetype of the file that is to be printed is not supported"
msgstr "Inprimatu beharreko fitxategiko MIME-mota ez da onartzen"

#: core/smb4k.notifyrc:794
msgctxt "Name"
msgid "Bookmark exists"
msgstr "Liburu-marka badago"

#: core/smb4k.notifyrc:832
msgctxt "Comment"
msgid "The bookmark exists"
msgstr "Liburu-marka lehendik dago"

#: core/smb4k.notifyrc:875
msgctxt "Name"
msgid "Bookmark label in use"
msgstr "Liburu-markako etiketa erabilita dago"

#: core/smb4k.notifyrc:913
msgctxt "Comment"
msgid "The label for the bookmark already exists"
msgstr "Liburu-markarako etiketa lehendik badago"

#: core/smb4k.notifyrc:956
msgctxt "Name"
msgid "Mounting failed"
msgstr "Muntatzea huts egin du"

#: core/smb4k.notifyrc:995
msgctxt "Comment"
msgid "Mounting a share failed"
msgstr "Partekatze bat muntatzea huts egin du"

#: core/smb4k.notifyrc:1038
msgctxt "Name"
msgid "Unmounting failed"
msgstr "Desmuntatzea huts egin du"

#: core/smb4k.notifyrc:1077
msgctxt "Comment"
msgid "Unmounting a share failed"
msgstr "Partekatze bat desmuntatzea huts egin du"

#: core/smb4k.notifyrc:1120
msgctxt "Name"
msgid "Unmounting not allowed"
msgstr "Desmuntatzea ez da baimentzen"

#: core/smb4k.notifyrc:1158
msgctxt "Comment"
msgid "The unmounting of a certain share is not allowed"
msgstr "Partekatze jakin bat desmuntatzea ez da onartzen"

#: core/smb4k.notifyrc:1201
msgctxt "Name"
msgid "Synchronization failed"
msgstr "Sinkronizatzea huts egin du"

#: core/smb4k.notifyrc:1240
msgctxt "Comment"
msgid "The synchronization of a share and a local copy failed"
msgstr "Partekatze bat eta kopia lokal bat sinkronizatzea huts egin du"

#: core/smb4k.notifyrc:1282
msgctxt "Name"
msgid "Command not found"
msgstr "Komandoa ez da aurkitu"

#: core/smb4k.notifyrc:1322
msgctxt "Comment"
msgid "A required command could not be found"
msgstr "Beharrezko komando bat ez da aurkitu"

#: core/smb4k.notifyrc:1365
msgctxt "Name"
msgid "Cannot bookmark printer"
msgstr "Ezin da inprimagailuaren laster-marka egin"

#: core/smb4k.notifyrc:1403
msgctxt "Comment"
msgid "A printer cannot be bookmarked"
msgstr "Inprimagailu baten liburu-marka ezin da egin"

#: core/smb4k.notifyrc:1446
msgctxt "Name"
msgid "File not found"
msgstr "Fitxategia ez da aurkitu"

#: core/smb4k.notifyrc:1487
msgctxt "Comment"
msgid "A file could not be found"
msgstr "Ezin izan da fitxategi bat aurkitu"

#: core/smb4k.notifyrc:1530
msgctxt "Name"
msgid "Opening file failed"
msgstr "Fitxategia irekitzea huts egin du"

#: core/smb4k.notifyrc:1568
msgctxt "Comment"
msgid "A file could not be opened"
msgstr "Fitxategi bat ezin izan da ireki"

#: core/smb4k.notifyrc:1611
msgctxt "Name"
msgid "Reading file failed"
msgstr "Fitxategi bat irakurtzea huts egin du"

#: core/smb4k.notifyrc:1649
msgctxt "Comment"
msgid "A file could not be read"
msgstr "Fitxategi bat ezin izan da irakurri"

#: core/smb4k.notifyrc:1692
msgctxt "Name"
msgid "mkdir failed"
msgstr "«mkdir» huts egin du"

#: core/smb4k.notifyrc:1731
msgctxt "Comment"
msgid "A directory could not be created"
msgstr "Direktorio bat ezin izan da sortu"

#: core/smb4k.notifyrc:1774
msgctxt "Name"
msgid "Process error"
msgstr "Prozesu-errorea"

#: core/smb4k.notifyrc:1814
msgctxt "Comment"
msgid "A process error occurred"
msgstr "Prozesu-errore bat gertatu da"

#: core/smb4k.notifyrc:1857
msgctxt "Name"
msgid "Action failed"
msgstr "Ekintzak huts egin du"

#: core/smb4k.notifyrc:1897
msgctxt "Comment"
msgid "A KAuth action failed"
msgstr "«KAuth» ekintza batek huts egin du"

#: core/smb4k.notifyrc:1939
msgctxt "Name"
msgid "Invalid URL"
msgstr "URL baliogabea"

#: core/smb4k.notifyrc:1980
msgctxt "Comment"
msgid "An invalid URL was passed"
msgstr "URL baliogabe bat pasatu da"

#: core/smb4k.notifyrc:2022
msgctxt "Name"
msgid "Network communication failed"
msgstr "Sare-komunikazioak huts egin du"

#: core/smb4k.notifyrc:2057
msgctxt "Comment"
msgid "A network related action could not be performed or failed"
msgstr ""
"Sarearekin zerikusia duen ekintza bat ezin izan da gauzatu edo huts egin du"

#: core/smb4k.notifyrc:2097
msgctxt "Name"
msgid "Zeroconf error"
msgstr "«Zeroconf» errorea"

#: core/smb4k.notifyrc:2130
msgctxt "Comment"
msgid "An error with the Zeroconf daemon occurred"
msgstr "Errore bat gertatu da «Zeroconf» daimonarekin"

#: core/smb4k.notifyrc:2167
msgctxt "Name"
msgid "Keychain error"
msgstr "Gako-katearen errorea"

#: core/smb4k.notifyrc:2196
msgctxt "Comment"
msgid ""
"An error occurred while reading the login credentials from the secure storage"
msgstr ""
"Errore bat gertatu da saio-hasteko egiaztagiriak biltegi segurutik "
"irakurtzean"

#: helpers/smb4kmounthelper.actions:2
msgctxt "Name"
msgid "Mount action"
msgstr "Muntatzeko ekintza"

#: helpers/smb4kmounthelper.actions:39
msgctxt "Description"
msgid "Mounts a share"
msgstr "Partekatze bat muntatzen du"

#: helpers/smb4kmounthelper.actions:80
msgctxt "Name"
msgid "Unmount action"
msgstr "Desmuntatzeko ekintza"

#: helpers/smb4kmounthelper.actions:117
msgctxt "Description"
msgid "Unmounts a share"
msgstr "Partekatze bat desmuntatzen du"

#: smb4k/org.kde.smb4k.desktop:44
msgctxt "GenericName"
msgid "Advanced Network Browser for SAMBA"
msgstr "SAMBA arakatzeko sareko arakatzaile aurreratua"

