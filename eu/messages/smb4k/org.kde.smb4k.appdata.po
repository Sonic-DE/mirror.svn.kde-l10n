#. (itstool) path: component/name
#: org.kde.smb4k.appdata.xml:10
msgid "Smb4K"
msgstr "Smb4K"

#. (itstool) path: component/summary
#: org.kde.smb4k.appdata.xml:11
msgid "Discover and mount SAMBA and Windows shares over the network"
msgstr "Sarean aurkitu eta muntatu SAMBA eta Windows partekatzeak"

#. (itstool) path: description/p
#: org.kde.smb4k.appdata.xml:13
msgid ""
"Smb4K is an advanced network neighborhood browser and Samba share mounting "
"utility. It is based on the KDE Frameworks, QtKeychain, Samba's client "
"library (libsmbclient) and, optionally, the KDSoap WS-Discovery client. It "
"scans your network neighborhood for all available workgroups, servers and "
"shares and can mount all desired shares to your local file system."
msgstr ""
"Smb4K auzo-sare arakatzaile aurreratu bat da eta Samba partekatzeak "
"muntatzeko erabilgarritasuna. KDE Frameworks, QtKeychain, Samba-ren bezero-"
"liburutegian (libsmbclient) eta, aukeran , KDSoap WS-Discovery bezeroan "
"oinarritzen da. Zure sareko auzoa miatzen du erabilgarri dauden lantalde, "
"zerbitzari eta partekatzeen bila eta nahi diren partekatzeak muntatu ditzake "
"zure fitxategi-sistema lokalean."

#. (itstool) path: description/p
#: org.kde.smb4k.appdata.xml:16
msgid "Features:"
msgstr "Ezaugarriak:"

#. (itstool) path: ul/li
#: org.kde.smb4k.appdata.xml:20
msgid ""
"Scanning for (active) workgroups, hosts, and shares using Samba's client "
"library, DNS Service Discovery (DNS-SD) and, optionally, Web Services "
"Dynamic Discovery (WS-Discovery)"
msgstr ""
"Lantalde (aktiboak), ostalariak eta Samba partekatzeak bila aztertzea, "
"Sambaren bezero liburutegia, DNS zerbitzu aurkikuntza (DNS-SD) eta, aukeran, "
"Web zerbitzuen aurkikuntza dinamikoa (WS-Discovery) erabiliz"

#. (itstool) path: ul/li
#: org.kde.smb4k.appdata.xml:21
msgid ""
"Support of the CIFS and SMB3 file system under Linux as well as the SMBFS "
"file system under BSD"
msgstr ""
"CIFS eta SMB3 fitxategi-sistemaren euskarria Linux-en, eta SMBFS fitxategi-"
"sistemarena BSDn"

#. (itstool) path: ul/li
#: org.kde.smb4k.appdata.xml:22
msgid "Mounting and unmounting of shares"
msgstr "Partekatzeak muntatzea eta desmuntatzea"

#. (itstool) path: ul/li
#: org.kde.smb4k.appdata.xml:23
msgid "Access to the files of a mounted share using a file manager or terminal"
msgstr ""
"Atzitu muntatutako partekatze baten fitxategiak fitxategi-kudeatzaile bat "
"edo terminal bat erabiliz"

#. (itstool) path: ul/li
#: org.kde.smb4k.appdata.xml:24
msgid "Auto-detection of external mounts and unmounts"
msgstr "Kanpoko muntatzeak eta desmuntatzeak automatikoki antzematea"

#. (itstool) path: ul/li
#: org.kde.smb4k.appdata.xml:25
msgid "Remounting of previously used shares on program start"
msgstr "Aurrez erabilitako partekatzeak birmuntatzea programa abiatzean"

#. (itstool) path: ul/li
#: org.kde.smb4k.appdata.xml:26
msgid "Miscellaneous information about remote network items and mounted shares"
msgstr ""
"Urruneko sare-elementuei buruzko eta muntatutako partekatzeei buruzko "
"askotariko informazioa"

#. (itstool) path: ul/li
#: org.kde.smb4k.appdata.xml:27
msgid "Network search"
msgstr "Sareko bilaketa"

#. (itstool) path: ul/li
#: org.kde.smb4k.appdata.xml:28
msgid "Preview of the contents of a remote share"
msgstr "Urruneko partekatze baten edukiak aurreikustea"

#. (itstool) path: ul/li
#: org.kde.smb4k.appdata.xml:29
msgid "Default login"
msgstr "Saio-hasiera lehenetsia"

#. (itstool) path: ul/li
#: org.kde.smb4k.appdata.xml:30
msgid "Special handling of home shares"
msgstr "«Etxeko» partekatzeen trataera berezia"

#. (itstool) path: ul/li
#: org.kde.smb4k.appdata.xml:31
msgid "Ability to bookmark favorite shares"
msgstr "Partekatze gogokoen laster-markak egiteko gaitasuna"

#. (itstool) path: ul/li
#: org.kde.smb4k.appdata.xml:32
msgid "System tray widget"
msgstr "Sistema-erretiluko trepeta"

#. (itstool) path: ul/li
#: org.kde.smb4k.appdata.xml:33
msgid "Support of advanced mount options"
msgstr "Muntatzeko aukera aurreratuak onartzen ditu"

#. (itstool) path: ul/li
#: org.kde.smb4k.appdata.xml:34
msgid "Support of printer shares"
msgstr "Inprimagailu-partekatzeak onartzen ditu"

#. (itstool) path: ul/li
#: org.kde.smb4k.appdata.xml:35
msgid ""
"Support of several secure storage solutions for the login credentials via "
"QtKeychain"
msgstr ""
"QtKeyChain bidez saio-hasteko egiaztagirien biltegiratze segururako hainbat "
"soluzioren euskarria"

#. (itstool) path: ul/li
#: org.kde.smb4k.appdata.xml:36
msgid "Synchronization of a remote share with a local copy and vice versa"
msgstr "Partekatze bat kopia lokal batekin sinkronizatzea eta alderantziz"

#. (itstool) path: ul/li
#: org.kde.smb4k.appdata.xml:37
msgid "Ability to define custom settings for individual servers and shares"
msgstr ""
"Banakako zerbitzarietarako eta partekatzeetarako neurrira ipinitako "
"ezarpenak definitzeko gaitasuna"

#. (itstool) path: ul/li
#: org.kde.smb4k.appdata.xml:38
msgid ""
"Hardware support through the Solid device integration framework, the "
"KDBusAddons convenience classes and the Qt Network module"
msgstr ""
"Hardwarearen euskarria gailuak bateratzeko Solid «framework»aren, "
"KDBusAddons egokitasun klaseen eta Qt sare moduluen bidez"

#. (itstool) path: ul/li
#: org.kde.smb4k.appdata.xml:39
msgid "Wake-On-LAN capabilities"
msgstr "Esnatu sare bidez gaitasunak (Wake-On-LAN)"

#. (itstool) path: ul/li
#: org.kde.smb4k.appdata.xml:40
msgid "Plasmoid for desktop integration"
msgstr "Mahaigainean bateratzeko plasmoidea"

#. (itstool) path: ul/li
#: org.kde.smb4k.appdata.xml:41
msgid "Profiles for different network neighborhood setups"
msgstr "Profilak, sareko-auzo ezarpen ezberdinetarako"

#. (itstool) path: description/p
#: org.kde.smb4k.appdata.xml:43
msgid ""
"If you are working in a Windows dominated network environment, you may want "
"to install this application to be able to easily access the provided Windows "
"shares."
msgstr ""
"Windows nagusi den sare-ingurune batean lan egiten baduzu, aplikazio hau "
"instalatu nahi izan dezakezu hornitutako Windows partekatzeak erraz "
"atzitzeko."

#. (itstool) path: screenshot/caption
#: org.kde.smb4k.appdata.xml:49
msgid "The main window"
msgstr "Leiho nagusia"

