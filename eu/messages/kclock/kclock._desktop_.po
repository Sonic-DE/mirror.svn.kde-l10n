#: kclock-runner.desktop:5
msgctxt "Name|plasma runner"
msgid "Clock"
msgstr "Erlojua"

#: kclock-runner.desktop:39
msgctxt "Comment"
msgid "Find timers and start/stop them"
msgstr "Aurkitu aurkitu eta haiek abiarazi/geldiarazi"

#: kclock-runner.desktop:84
msgctxt "X-Plasma-Runner-Syntax-Descriptions"
msgid ""
"Finds timers whose name match :q:,Lists all timers and allows to start/stop "
"them.,Lists all alarms and allows to enable/disable them."
msgstr ""
"Izena :q:-rekin bat datozen tenporizadoreak aurkitzen ditu,Tenporizadore "
"denak zerrendatu eta haiek abiarazteko/geldiarazteko aukera ematen dizu.,"
"Alarma denak zerrendatu eta haiek gaitzeko/ezgaitzek aukera ematen dizu."

#: org.kde.kclockd-autostart.desktop:53
msgctxt "Comment"
msgid "A simple clock application in Kirigami."
msgstr "Kirigami-rekin egindako erloju erraz bat."

#: org.kde.kclock.desktop.in:54
msgctxt "Comment"
msgid "Set alarms and timers, use a stopwatch, and manage world clocks"
msgstr ""
"Ezarri alarmak eta tenporizadoreak, erabili kronometroa, eta kudeatu munduko "
"ordulariak"

#: org.kde.kclock.desktop.in:101
msgctxt "Keywords"
msgid "kclock;timer;stopwatch;alarm;timezone;time zone;world clock;"
msgstr ""
"kclock;tenporizadorea;kronometroa;alarma;ordu-eremua;ordu eremua;munduko "
"ordularia;"

