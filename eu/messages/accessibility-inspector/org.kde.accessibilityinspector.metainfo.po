#. (itstool) path: component/name
#: org.kde.accessibilityinspector.metainfo.xml:11
msgid "Accessibility Inspector"
msgstr "Irisgarritasun ikuskatzailea"

#. (itstool) path: component/summary
#: org.kde.accessibilityinspector.metainfo.xml:12
msgid "Inspect your application accessibility tree"
msgstr "Ikuskatu zure aplikazioaren irisgarritasun zuhaitza"

#. (itstool) path: description/p
#: org.kde.accessibilityinspector.metainfo.xml:14
msgid ""
"Accessibility Inspector is as the name suggests an inspector for your "
"application accessibility tree. It lets you check all the items exposed via "
"At-SPI, too."
msgstr ""
"Irisgarritasun ikuskatzailea, izenak iradoki bezala, zure aplikazioaren "
"irisgarritasun zuhaitzerako ikuskatzaile bat da. At-SPI bidez agerian "
"ipinitako elementu guztiak egiaztatzeko aukera ere ematen dizu."

#. (itstool) path: screenshot/caption
#: org.kde.accessibilityinspector.metainfo.xml:35
msgid "The properties of a node of the accessibility tree."
msgstr "Irisgarritasun zuhaitzeko nodo baten propietateak."

#. (itstool) path: screenshot/caption
#: org.kde.accessibilityinspector.metainfo.xml:39
msgid "The list of all the recent events."
msgstr "Azkenaldiko gertaera guztien zerrenda."

#. (itstool) path: description/p
#: org.kde.accessibilityinspector.metainfo.xml:70
msgid "Update to Qt6"
msgstr "Qt6ra eguneratzea"

#. (itstool) path: description/p
#: org.kde.accessibilityinspector.metainfo.xml:76
msgid "Initial version as a standalone component."
msgstr "Hasierako bertsioa osagai autonomo gisa."
