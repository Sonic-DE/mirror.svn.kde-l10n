#. (itstool) path: component/name
#: org.kde.plasma.disks.metainfo.xml:11
msgid "Plasma Disks"
msgstr "Plasmako diskoak"

#. (itstool) path: component/summary
#: org.kde.plasma.disks.metainfo.xml:12
msgid "Hard disk health monitoring for KDE Plasma"
msgstr "Disko zurrunen osasuna gainbegiratzea KDE Plasma-rako"

#. (itstool) path: description/p
#: org.kde.plasma.disks.metainfo.xml:14
msgid ""
"Plasma Disks monitors S.M.A.R.T. data of disks and alerts the user when "
"signs of imminent failure appear."
msgstr ""
"«Plasmako diskoak» diskoetako S.M.A.R.T. datuak gainbegiratzen ditu eta "
"erabiltzailea ohartarazten du hurbileko hutsegiteen zantzuak agertzen "
"direnean."

#. (itstool) path: screenshot/caption
#: org.kde.plasma.disks.metainfo.xml:19
msgid "The Plasma Disks Info Center module showing the state of devices."
msgstr "«Plasmako diskoen informazio gunea» modulua gailuen egoera erakusten."

