#: plugins/bwscheduler/ktorrent_bwscheduler.json
msgctxt "Name"
msgid "Scheduler"
msgstr "Antolatzailea"

#: plugins/downloadorder/ktorrent_downloadorder.json
msgctxt "Name"
msgid "Download Order"
msgstr "Zama-jaiste hurrenkera"

#: plugins/infowidget/ktorrent_infowidget.json
msgctxt "Name"
msgid "Information Widget"
msgstr "Informazio trepeta"

#: plugins/ipfilter/ktorrent_ipfilter.json
msgctxt "Name"
msgid "IP Filter"
msgstr "IP iragazkia"

#: plugins/logviewer/ktorrent_logviewer.json
msgctxt "Name"
msgid "Log Viewer"
msgstr "Egunkari erakuslea"

#: plugins/magnetgenerator/ktorrent_magnetgenerator.json
msgctxt "Name"
msgid "Magnet Generator"
msgstr "Iman sortzailea"

#: plugins/mediaplayer/ktorrent_mediaplayer.json
msgctxt "Name"
msgid "Media Player"
msgstr "Euskarri jotzailea"

#: plugins/scanfolder/ktorrent_scanfolder.json
msgctxt "Name"
msgid "Scan Folder"
msgstr "Aztertu karpeta"

#: plugins/scanforlostfiles/ktorrent_scanforlostfiles.json
msgctxt "Name"
msgid "Scan for lost files"
msgstr "Aztertu galdutako fitxategi bila"

#: plugins/search/ktorrent_search.json
msgctxt "Name"
msgid "Search"
msgstr "Bilatu"

#: plugins/shutdown/ktorrent_shutdown.json
msgctxt "Name"
msgid "Shutdown"
msgstr "Itzali"

#: plugins/stats/ktorrent_stats.json
msgctxt "Name"
msgid "Statistics"
msgstr "Estatistikak"

#: plugins/syndication/ktorrent_syndication.json
msgctxt "Name"
msgid "Syndication"
msgstr "Sindikazioa"

#: plugins/upnp/ktorrent_upnp.json
msgctxt "Name"
msgid "UPnP"
msgstr "UPnP"

#: plugins/zeroconf/ktorrent_zeroconf.json
msgctxt "Name"
msgid "Zeroconf"
msgstr "Zeroconf"

#: plugins/bwscheduler/ktorrent_bwscheduler.json
msgctxt "Description"
msgid "Schedule upload and download limits over a period of a week"
msgstr "Antolatu zama-igotzeko eta -jaisteko mugak astebeteko tartean"

#: plugins/downloadorder/ktorrent_downloadorder.json
msgctxt "Description"
msgid "Specify the download order of a multi-file torrent"
msgstr "Zehaztu zama-jaisteko hurrenkera, fitxategi anitzeko torrent batean"

#: plugins/infowidget/ktorrent_infowidget.json
msgctxt "Description"
msgid "Displays general information about a torrent in several tabs"
msgstr "Torrent bati buruzko informazioa hainbat fitxatan azaltzen du"

#: plugins/ipfilter/ktorrent_ipfilter.json
msgctxt "Description"
msgid "Filter IP addresses through a blocklist"
msgstr "Iragazi IP helbideak blokeatzeko-zerrenda baten bidez"

#: plugins/logviewer/ktorrent_logviewer.json
msgctxt "Description"
msgid "Displays the logging output"
msgstr "Egunkariko irteerakoa azaltzen du"

#: plugins/magnetgenerator/ktorrent_magnetgenerator.json
msgctxt "Description"
msgid "Generates magnet links"
msgstr "Iman-estekak sortzen ditu"

#: plugins/mediaplayer/ktorrent_mediaplayer.json
msgctxt "Description"
msgid "Phonon-based media player"
msgstr "Phonon-en oinarritutako euskarri jotzailea"

#: plugins/scanfolder/ktorrent_scanfolder.json
msgctxt "Description"
msgid "Scan folders for torrent files and load them"
msgstr "Aztertu karpetak torrent-fitxategien bila eta haiek zamatu"

#: plugins/scanforlostfiles/ktorrent_scanforlostfiles.json
msgctxt "Description"
msgid "Display files in the selected folder that don't belong to any torrent"
msgstr ""
"Hautatutako karpetan inongo torrenti ez dagozkion fitxategiak azaltzen ditu"

#: plugins/search/ktorrent_search.json
msgctxt "Description"
msgid "Search for torrents"
msgstr "Bilatu torrentak"

#: plugins/shutdown/ktorrent_shutdown.json
msgctxt "Description"
msgid "Allows you to shutdown your computer when torrents finish"
msgstr ""
"Torrentak amaitzen direnean zure ordenagailua itzaltzeko aukera ematen du"

#: plugins/stats/ktorrent_stats.json
msgctxt "Description"
msgid "Shows statistics about torrents in several graphs"
msgstr "Torrentei buruzko estatistikak erakusten ditu hainbat grafikotan"

#: plugins/syndication/ktorrent_syndication.json
msgctxt "Description"
msgid "Syndication plugin for KTorrent, supporting RSS and Atom feeds"
msgstr ""
"KTorrent-erako sindikazio plugina, RSS eta Atom jarioen euskarria duena"

#: plugins/upnp/ktorrent_upnp.json
msgctxt "Description"
msgid "Forward ports using UPnP"
msgstr "Birbidali atakak UPnP erabiliz"

#: plugins/zeroconf/ktorrent_zeroconf.json
msgctxt "Description"
msgid "Discover peers on the local network using the Zeroconf protocol"
msgstr "Aurkitu parekoak sare lokalean Zeroconf protokoloa erabiliz"

