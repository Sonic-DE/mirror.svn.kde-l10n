#: gui/org.kde.pimdataexporter.desktop:2
msgctxt "Name"
msgid "PIM Data Exporter"
msgstr "PIM-Datumeksportilo"

#: gui/org.kde.pimdataexporter.desktop:45
msgctxt "GenericName"
msgid "Saves and restores all data from PIM apps"
msgstr "Konservas kaj restarigas ĉiujn datumojn de PIM-aplikoj"

#: gui/org.kde.pimdataexporter.desktop:85
msgctxt "Comment"
msgid ""
"PIM Setting Exporter allows to save all data from PIM apps and restore them "
"in other systems."
msgstr ""
"PIM-Agordeksportilo permesas konservi ĉiujn datumojn de PIM-aplikoj kaj "
"restarigi ilin en aliaj sistemoj."
