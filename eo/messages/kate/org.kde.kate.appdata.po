#: org.kde.kate.appdata.xml:7
msgid "Kate"
msgstr "Kate"

#. (itstool) path: component/summary
#: org.kde.kate.appdata.xml:8
msgid "Advanced text editor"
msgstr "Altnivela tekstredaktilo"

#. (itstool) path: description/p
#: org.kde.kate.appdata.xml:10
msgid ""
"Kate is a fast multi-document, multi-view text editor for programmers by "
"KDE. It features stuff like LSP (Language Server Protocol) support, "
"projects, multiple cursors and selections, git integration, folder wide "
"search, horizontal and vertical splits, vi mode, syntax highlighting for "
"300+ languages, built-in terminal, dynamic word wrap and much more. It is "
"available on Linux, BSD, Windows and MacOS."
msgstr ""
"Kate estas rapida multdokumenta, plurvida tekstredaktilo por programistoj de "
"KDE. Ĝi havas aferojn kiel subteno por LSP (Lingva Servila Protokolo), "
"projektoj, multoblaj kursoroj kaj elektoj, git-integriĝo, dosieruj-ampleksa "
"serĉo, horizontalaj kaj vertikalaj dividoj, vi-reĝimo, sintaksa reliefigo "
"por 300+ lingvoj, enkonstruita terminalo, dinamika vortvolvado kaj multe "
"pli. Ĝi disponeblas en Linukso, BSD, Vindozo kaj MacOS."

