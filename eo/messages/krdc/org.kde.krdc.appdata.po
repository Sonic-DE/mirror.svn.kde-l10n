#. (itstool) path: component/summary
#: org.kde.krdc.appdata.xml:5
msgid "Connect with RDP or VNC to another computer"
msgstr "Konekti per RDP aŭ VNC al alia komputilo"

#. (itstool) path: description/p
#: org.kde.krdc.appdata.xml:11
msgid ""
"KRDC is a client application that allows you to view or even control the "
"desktop session on another machine that is running a compatible server. VNC "
"and RDP is supported."
msgstr ""
"KRDC estas klienta aplikaĵo, kiu ebligas al vi vidi aŭ eĉ kontroli la "
"labortablan seancon en alia maŝino, kiu funkcias kongruan servilon. VNC kaj "
"RDP estas subtenataj."
