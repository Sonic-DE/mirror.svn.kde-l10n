msgstr "Krei kaj ludi puzlojn en gamo de 4 ĝis 10000 pecoj"

#. (itstool) path: ul/li
#: org.kde.palapeli.appdata.xml:21
msgid "Piece-holders for helping solve large puzzles"
msgstr "Pecingoj por helpi solvi grandajn puzlojn"
