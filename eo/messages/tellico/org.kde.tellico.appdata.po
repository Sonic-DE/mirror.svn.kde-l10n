#. (itstool) path: component/name
#: org.kde.tellico.appdata.xml:9
msgid "Tellico"
msgstr "Tellico"

#. (itstool) path: component/summary
#: org.kde.tellico.appdata.xml:10
msgid "Collection Manager"
msgstr "Kolekta Administranto"

#. (itstool) path: description/p
#: org.kde.tellico.appdata.xml:12
msgid ""
"Tellico is an application for organizing your collections. It provides "
"default templates for books, bibliographies, videos, music, video games, "
"coins, stamps, trading cards, comic books, and wines. It allows you to enter "
"your collection in a catalogue database, saving many different properties "
"like title, author, etc."
msgstr ""
"Tellico estas aplikaĵo por organizi viajn kolektojn. Ĝi provizas defaŭltajn "
"ŝablonojn por libroj, bibliografioj, filmetoj, muziko, videoludoj, moneroj, "
"poŝtmarkoj, komerckartoj, komiksoj kaj vinoj. Ĝi permesas vin enigi vian "
"kolekton en kataloga datumbazo, konservante multajn malsamajn ecojn kiel "
"titolon, aŭtoron, ktp."

#. (itstool) path: description/p
#: org.kde.tellico.appdata.xml:17
msgid "Features:"
msgstr "Trajtoj:"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:19
msgid ""
"Supports default collections of books, bibliographic entries, videos, music, "
"video games, comic books, coins, stamps, trading cards, wines, board games, "
"and file catalogs"
msgstr ""
"Subtenas defaŭltajn kolektojn de libroj, bibliografiaj enskriboj, filmetoj, "
"muziko, videoludoj, komiksoj, moneroj, poŝtmarkoj, komerckartoj, vinoj, "
"tabulludoj kaj dosierkatalogoj"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:20
msgid "Supports user-defined custom collections"
msgstr "Subtenas uzant-difinitajn proprajn kolektojn"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:21
msgid ""
"Supports any number of user-defined fields, of several different types: "
"text, paragraph, list, checkbox, number, URL, date, images, and combinations"
msgstr ""
"Subtenas ajnan nombron da uzant-difinitaj kampoj, de pluraj malsamaj tipoj: "
"teksto, alineo, listo, markobutono, nombro, URL, dato, bildoj kaj kombinaĵoj"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:22
msgid "Handles entries with multiple authors, genres, keywords, etc"
msgstr "Pritraktas enskribojn kun pluraj aŭtoroj, ĝenroj, ŝlosilvortoj ktp"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:23
msgid "Automatically formats titles and names"
msgstr "Aŭtomate formatas titolojn kaj nomojn"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:24
msgid "Supports collection searching and view filtering"
msgstr "Elportas kolekton serĉadon kaj rigardan filtradon"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:25
msgid "Sorts and groups collection by various properties"
msgstr "Ordigi kaj grupigas kolekton laŭ diversaj propraĵoj"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:26
msgid "Allows customizable entry templates through XSLT"
msgstr "Permesas agordeblajn enirajn ŝablonojn per XSLT"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:27
msgid "Imports MODS, Bibtex, RIS, CSV, PDF metadata, and many other formats"
msgstr ""
"Importas metadatumojn MODS, Bibtex, RIS, CSV, PDF kaj multajn aliajn "
"formatojn"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:28
msgid "Exports to Bibtex, ONIX, CSV, HTML, and other formats"
msgstr "Eksportaĵoj al Bibtex, ONIX, CSV, HTML kaj aliaj formatoj"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:29
msgid ""
"Imports information directly from Amazon.com, IMDb, z39.50 servers, PubMed, "
"SRU servers, CrossRef.org, various other websites, and from external scripts"
msgstr ""
"Importas informojn rekte de Amazon.com, IMDb, z39.50-serviloj, PubMed, SRU-"
"serviloj, CrossRef.org, diversaj aliaj retejoj, kaj de eksteraj skriptoj"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:30
msgid "Imports CDDB data for cataloging audio CDs"
msgstr "Importas CDDB-datumojn por katalogado de son-KD-oj"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:31
msgid "Scans and imports audio file collections, such as mp3 or ogg"
msgstr "Skanas kaj importas sondosierkolektojn, kiel mp3 aŭ ogg"

