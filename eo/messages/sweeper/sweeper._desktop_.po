#: org.kde.sweeper.desktop:75
msgctxt "GenericName"
msgid "System Cleaner"
msgstr "Sistema purigilo"

#: org.kde.sweeper.desktop:142
msgctxt "Comment"
msgid ""
"Helps to clean unwanted traces the user leaves on the system and to regain "
"disk space removing unused temporary files"
msgstr ""
"Helpas purigi nedeziratajn spurojn, kiujn la uzanto lasas en la sistemo kaj "
"reakiri diskospacon forigante neuzatajn provizorajn dosierojn."
