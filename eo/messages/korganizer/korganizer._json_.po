#: plugins/datenums/datenums.json
msgctxt "Description"
msgid ""
"For each day this plugin shows its daynumber of the year at the top of the "
"agenda view. For example, February 1 is day 32 of the year."
msgstr ""
"Por ĉiu tago ĉi tiu kromaĵo montras sian tagnombron de la jaro ĉe la supro "
"de la tagorda vido. Ekzemple, la 1-a de februaro estas la 32-a tago de la "
"jaro."

#: plugins/hebrew/hebrew.json
msgctxt "Description"
msgid "Shows all dates in KOrganizer also in the Jewish calendar system."
msgstr "Montri ĉiujn datojn en KOrganizer ankaŭ en la Juda kalendarsistemo."

#: plugins/lunarphases/lunarphases.json
msgctxt "Description"
msgid "This plugin shows the day's lunar phase (New, First, Last, Full)"
msgstr "Ĉi tiu kromprogramo montras la lunfazon (Nova, Unua, Lasta, Plena)"

#: plugins/picoftheday/picoftheday.json
msgctxt "Description"
msgid "This plugin provides the Wikipedia Picture of the Day"
msgstr "Ĉi tiu kromprogramo provizas la Vikipedian Bildon de la Tago"

#: plugins/thisdayinhistory/thisdayinhistory.json
msgctxt "Description"
msgid "This plugin provides links to Wikipedia's 'This Day in History' pages"
msgstr ""
"Ĉi tiu kromprogramo provizas ligilojn al la paĝoj 'This Day in History' de "
"Vikipedio"

