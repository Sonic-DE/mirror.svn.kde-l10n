#. (itstool) path: component/name
#: org.kde.kio_zeroconf.metainfo.xml:9
msgid "Zeroconf Support"
msgstr "Subteno por Zeroconf"

#. (itstool) path: component/summary
#: org.kde.kio_zeroconf.metainfo.xml:10
msgid "Browse local network services in Dolphin's Network page"
msgstr "Trafoliumi lokretajn servojn en la Reto-paĝo de Dolphin"

#. (itstool) path: description/p
#: org.kde.kio_zeroconf.metainfo.xml:12
msgid ""
"Adds an entry to Dolphin's Network page to show local services such as "
"printers which advertise themselves with DNSSD (called Avahi or Bonjour by "
"other projects)."
msgstr ""
"Aldonas eniron al la retpaĝo de Dolphin por montri lokajn servojn kiel "
"presiloj kiuj reklamas sin per DNSSD (nomitaj Avahi aŭ Bonjour de aliaj "
"projektoj)."
