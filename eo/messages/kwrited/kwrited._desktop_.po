#: kwrited.notifyrc:48
msgctxt "Comment"
msgid "Local system message service"
msgstr "Loka sistemmesaĝa servo"

#: kwrited.notifyrc:117
msgctxt "Name"
msgid "New message received"
msgstr "Novan mesaĝon ricevis"

#: kwrited.notifyrc:192
msgctxt "Comment"
msgid "The daemon received a new message sent with wall(1) or write(1)"
msgstr "La demono ricevis novan mesaĝon senditan per wall(1) aŭ write(1)"
