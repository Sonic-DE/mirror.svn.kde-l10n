msgid "Scan & OCR Program"
msgstr "Skanad- kaj OCR-Programo"

#: app/desktop/org.kde.kooka.desktop:51
msgctxt "Name"
msgid "Kooka"
msgstr "Kooka"

#~ msgctxt "Name"
#~ msgid "Application"
#~ msgstr "Aplikaĵo"

#~ msgctxt "Comment"
#~ msgid "Open the scanned image in an application"
#~ msgstr "Malfermi la skanitan bildon en aplikaĵo"

#~ msgctxt "Name"
#~ msgid "Copy Image"
#~ msgstr "Kopii Bildon"

#~ msgctxt "Comment"
#~ msgid "Copy the scanned image to the clipboard"
#~ msgstr "Kopii la skanitan bildon al la tondujo"

#~ msgctxt "Name"
#~ msgid "Scan Gallery"
#~ msgstr "Skanaĵ-Galerio"

#~ msgctxt "Comment"
#~ msgid "Save the scanned image to the scan gallery"
#~ msgstr "Konservi la skanitan bildon en la skanan galerion"

#~ msgctxt "Name"
#~ msgid "Print Image"
#~ msgstr "Presi Bildon"

#~ msgctxt "Comment"
