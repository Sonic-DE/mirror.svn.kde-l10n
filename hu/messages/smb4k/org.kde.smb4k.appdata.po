#. (itstool) path: component/name
#: org.kde.smb4k.appdata.xml:10
msgid "Smb4K"
msgstr "Smb4K"

#. (itstool) path: component/summary
#: org.kde.smb4k.appdata.xml:11
msgid "Discover and mount SAMBA and Windows shares over the network"
msgstr ""
"SAMBA és Windows megosztások felfedezése és csatolása a hálózaton keresztül"

#. (itstool) path: description/p
#: org.kde.smb4k.appdata.xml:13
#, fuzzy
#| msgid ""
#| "Smb4K is an advanced network neighborhood browser and Samba share "
#| "mounting utility. It is based on the KDE Frameworks 5 and Samba's client "
#| "library (libsmbclient). It scans your network neighborhood for all "
#| "available workgroups, servers and shares and can mount all desired shares "
#| "to your local file system."
msgid ""
"Smb4K is an advanced network neighborhood browser and Samba share mounting "
"utility. It is based on the KDE Frameworks, QtKeychain, Samba's client "
"library (libsmbclient) and, optionally, the KDSoap WS-Discovery client. It "
"scans your network neighborhood for all available workgroups, servers and "
"shares and can mount all desired shares to your local file system."
msgstr ""
"Az Smb4K egy fejlett hálózati böngésző és Samba megosztási segédprogram. A "
"KDE Frameworks 5 és a Samba klienskönyvtárán (libsmbclient) alapul. "
"Átvizsgálja a hálózati szomszédságot az összes elérhető munkacsoport, "
"kiszolgáló és megosztás után, és képes az összes kívánt megosztást a helyi "
"fájlrendszerre csatolni."

