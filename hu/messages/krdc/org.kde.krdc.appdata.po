#: org.kde.krdc.appdata.xml:4
msgid "KRDC"
msgstr "KRDC"

#. (itstool) path: component/summary
#: org.kde.krdc.appdata.xml:5
msgid "Connect with RDP or VNC to another computer"
msgstr "Csatlakozás másik számítógéphez RDP-vel vagy VNC-vel"

#. (itstool) path: description/p
#: org.kde.krdc.appdata.xml:11
msgid ""
"KRDC is a client application that allows you to view or even control the "
"desktop session on another machine that is running a compatible server. VNC "
"and RDP is supported."
msgstr ""
"A KRDC egy kliensalkalmazás, amely lehetővé teszi egy kompatibilis "
"kiszolgálót futtató másik számítógép munkamenetének megtekintését, vagy akár "
"irányítását. A VNC és az RDP protokollok támogatottak."
