msgid "Krfb"
msgstr "Krfb"

#. (itstool) path: component/summary
#: org.kde.krfb.appdata.xml:7
msgid "Share your desktop to another computer via VNC"
msgstr "Ossza meg asztalát egy másik számítógéppel VNC-n keresztül"

#. (itstool) path: description/p
#: org.kde.krfb.appdata.xml:9
msgid ""
"Krfb Desktop Sharing is a server application that allows you to share your "
"current session with a user on another machine, who can use a VNC client to "
"view or even control the desktop."
msgstr ""
"A Krfb asztalmegosztás egy kiszolgáló alkalmazás, amely lehetővé teszi, hogy "
"megossza az aktuális munkamenetet egy másik gépen lévő felhasználóval, aki "
"egy VNC kliens segítségével megtekintheti vagy akár irányíthatja az asztalt."

#. (itstool) path: screenshot/caption
#: org.kde.krfb.appdata.xml:17
msgid "Sharing desktop with Krfb"
msgstr "Asztalmegosztás a Krfb-vel"
