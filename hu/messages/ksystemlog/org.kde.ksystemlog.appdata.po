msgid "KSystemLog"
msgstr "KSystemLog"

#. (itstool) path: component/summary
#: org.kde.ksystemlog.appdata.xml:7
msgid "system log viewer"
msgstr "Rendszernapló-megjelenítő"

#. (itstool) path: description/p
#: org.kde.ksystemlog.appdata.xml:9
msgid ""
"KSystemLog show all logs of your system, grouped by General (Default system "
"log, Authentication, Kernel, X.org...), and optional Services (Apache, Cups, "
"etc, ...). It includes many features to read nicely your log files:"
msgstr ""
"A KSystemLog megjeleníti a rendszer összes naplófájlját, általános "
"(alapértelmezett rendszernapló, hitelesítés, kernel, X.org…) és opcionális "
"szolgáltatások (Apache, Cups, stb, …) szerint csoportosítva. Számos "
"funkcióval segíti a naplófájlok olvasását:"

#. (itstool) path: ul/li
#: org.kde.ksystemlog.appdata.xml:13
msgid "Colorize log lines depending on their severities"
msgstr "Sorok színezése a fontosságuk szerint"

#. (itstool) path: ul/li
#: org.kde.ksystemlog.appdata.xml:14
msgid "Tabbed view to allow displaying several logs at the same time"
msgstr ""
"Lapokra osztott nézet több naplófájl egyszerre történő megjelenítéséhez"

#. (itstool) path: ul/li
#: org.kde.ksystemlog.appdata.xml:15
msgid "Auto display new lines logged"
msgstr "Új bejegyzések automatikus megjelenítése"

#. (itstool) path: ul/li
