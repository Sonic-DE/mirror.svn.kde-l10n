#. (itstool) path: component/name
#: org.kde.kio_zeroconf.metainfo.xml:9
msgid "Zeroconf Support"
msgstr "Zeroconf-támogatás"

#. (itstool) path: component/summary
#: org.kde.kio_zeroconf.metainfo.xml:10
msgid "Browse local network services in Dolphin's Network page"
msgstr "Helyi hálózati szolgáltatások böngészése a Dolphin Hálózat lapján"

#. (itstool) path: description/p
#: org.kde.kio_zeroconf.metainfo.xml:12
msgid ""
"Adds an entry to Dolphin's Network page to show local services such as "
"printers which advertise themselves with DNSSD (called Avahi or Bonjour by "
"other projects)."
msgstr ""
"Felveszi a Dolphinban a Hálózat alá azokat a helyi szolgáltatásokat, például "
"nyomtatókat, amik DNSSD-n keresztül hirdetik magukat (máshol Avahi vagy "
"Bonjour néven ismert)."
