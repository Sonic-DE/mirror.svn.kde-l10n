#. (itstool) path: component/name
#: org.kde.accountwizard.appdata.xml:9
msgid "Account Wizard"
msgstr "Fiókvarázsló"

#. (itstool) path: component/summary
#: org.kde.accountwizard.appdata.xml:10
msgid "Configure accounts"
msgstr "Fiókok beállítása"

#. (itstool) path: description/p
#: org.kde.accountwizard.appdata.xml:12
msgid ""
"Accountwizard allows to edit, create, delete accounts. Accountwizard "
"supports IMAP/POP3/Kolab account type. Account information can be found by "
"using ispd service."
msgstr ""
"A Fiókvarázsló lehetővé teszi fiókok szerkesztését, létrehozását és "
"törlését. A Fiókvarázsló az IMAP/POP3/Kolab fióktípusokat támogatja. A "
"fiókinformációkat az ispd szolgáltatás használatával lehet megtalálni."
