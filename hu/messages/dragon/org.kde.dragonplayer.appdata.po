#. (itstool) path: component/name
#: org.kde.dragonplayer.appdata.xml:9
msgid "Dragon Player"
msgstr "Dragon Player"

#. (itstool) path: component/summary
#: org.kde.dragonplayer.appdata.xml:10
msgid "Play video files and streams"
msgstr "Videofájlok és közvetítések lejátszása"

#. (itstool) path: description/p
#: org.kde.dragonplayer.appdata.xml:12
msgid ""
"Dragon Player is a video player focusing on simplicity instead of features. "
"Its easy-to-use interface is designed to get out of your way and simply play "
"your video files and streams."
msgstr ""
"A Dragon Player egy olyan videolejátszó, amely a funkciók helyett az "
"egyszerűségre összpontosít. Könnyen használható felületét úgy tervezték, "
"hogy ne legyen útban, és egyszerűen lejátssza a videofájlokat és "
"közvetítéseket."

#. (itstool) path: description/p
#: org.kde.dragonplayer.appdata.xml:15
msgid "Features:"
msgstr "Funkciók:"

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:17
msgid ""
"Click to play or pause, and double-click to enter or exit full screen mode."
msgstr ""
"Kattintással lejátszás vagy szüneteltetés, dupla kattintással belépés teljes "
"képernyős módba, vagy kilépés onnan."

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:18
msgid ""
"Choose the subtitle language, and automatically load the right one for your "
"language, if possible."
msgstr ""
"Felirat nyelvének kiválasztása és lehetőség szerint a nyelvének megfelelő "
"betöltése."

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:19
msgid "Choose the audio track."
msgstr "Hangsáv kiválasztása."

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:20
msgid "Choose the video track."
msgstr "Videosáv kiválasztása."

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:21
msgid "Adjust the volume by scrolling."
msgstr "Hangerő beállítása görgetéssel."

#~ msgid "Video player with focus on simplicity"
#~ msgstr "Egyszerűségre fókuszáló videólejátszó"

#~ msgid "Simple Interface"
#~ msgstr "Egyszerű felület"

#~ msgid ""
#~ "Resuming videos: Starts playing a video where you were watching it last "
#~ "time"
#~ msgstr ""
#~ "Videók folytatása: folytassa ott a lejátszást, ahol legutóbb abbahagyta"

#~ msgid ""
#~ "Support for subtitles: Automatically loads subtitles with the matching "
#~ "name"
#~ msgstr ""
#~ "Feliratok támogatása: automatikusan betölti az azonos fájlnevű feliratokat"

#~ msgid "Video display settings (brightness, contrast)"
#~ msgstr "Videómegjelenítés beállítása (fényerő, kontraszt)"

#~ msgid ""
#~ "Due to using Solid and Phonon DragonPlayer is independent of any "
#~ "multimedia framework or hardware abstraction layer"
#~ msgstr ""
#~ "A Solidnak és a Phononnak köszönhetően a Dragon Player független bármely "
#~ "multimédia keretrendszertől és hardverabsztrakciós rétegtől"

#~ msgid "Supports playing CDs and DVDs"
#~ msgstr "CD-k és DVD-k lejátszásának támogatása"
