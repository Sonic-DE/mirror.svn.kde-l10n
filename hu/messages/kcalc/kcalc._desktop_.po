#: org.kde.kcalc.desktop:2
msgctxt "Name"
msgid "KCalc"
msgstr "KCalc"

#: org.kde.kcalc.desktop:80
msgctxt "Comment"
msgid ""
"Calculator which offers many mathematical functions, such as trigonometric "
"functions, logic operations, and statistical calculations"
msgstr ""
"Számos matematikai műveletet, mint például trigonometriai függvényeket, "
"logikai műveleteket és statisztikai számításokat biztosító számológép."

#: org.kde.kcalc.desktop:125
msgctxt "GenericName"
msgid "Scientific Calculator"
msgstr "Tudományos számológép"

