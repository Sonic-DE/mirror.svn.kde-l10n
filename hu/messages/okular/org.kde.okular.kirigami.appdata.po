msgid "Okular Mobile"
msgstr "Okular Mobile"

#. (itstool) path: component/summary
#: org.kde.okular.kirigami.appdata.xml:7
msgid "Document Viewer"
msgstr "Dokumentummegjelenítő"

#. (itstool) path: description/p
#: org.kde.okular.kirigami.appdata.xml:13
msgid ""
"Okular is a universal document viewer developed by KDE. Okular works on "
"multiple platforms, including but not limited to Linux, Windows, Mac OS X, "
"*BSD, etc."
msgstr ""
"Az Okulat a KDE által fejlesztett univerzális dokumentummegjelenítő. Számos "
"platformon elérhető, többek között Linuxon, Windowson, Mac OS X-en, BSD "
"rendszereken, stb."

#. (itstool) path: description/p
#: org.kde.okular.kirigami.appdata.xml:16
msgid "Features:"
msgstr "Szolgáltatások:"

#. (itstool) path: ul/li
#: org.kde.okular.kirigami.appdata.xml:18
msgid ""
"Supported Formats: PDF, PS, Tiff, DjVu, Images, DVI, XPS, Fiction Book, "
"Comic Book, Plucker, EPub, Fax"
msgstr ""
"Támogatott formátumok: PDF, PS, Tiff, DjVu, képek, DVI, XPS, FictionBook, "
"képregények, Plucker, EPub, Fax"

#. (itstool) path: ul/li
#: org.kde.okular.kirigami.appdata.xml:19
msgid "Sidebar with contents, thumbnails, reviews and bookmarks"
msgstr ""
"Oldalsáv tartalomjegyzékkel, előnézettel, értékelésekkel és könyvjelzőkkel"

#. (itstool) path: ul/li
#: org.kde.okular.kirigami.appdata.xml:20
