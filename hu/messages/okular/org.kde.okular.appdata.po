#. (itstool) path: component/name
#: org.kde.okular.appdata.xml:7
msgid "Okular"
msgstr "Okular"

#. (itstool) path: component/summary
#: org.kde.okular.appdata.xml:8
msgid "View and annotate documents"
msgstr "Dokumentumok megjelenítése és jegyzetelése"

#. (itstool) path: description/p
#: org.kde.okular.appdata.xml:10
msgid ""
"Okular is a universal document viewer developed by KDE. Okular works on "
"multiple platforms, including but not limited to Linux, Windows, Mac OS X, "
"*BSD, etc."
msgstr ""
"Az Okulat a KDE által fejlesztett univerzális dokumentummegjelenítő. Számos "
"platformon elérhető, többek között Linuxon, Windowson, Mac OS X-en, BSD "
"rendszereken, stb."

#. (itstool) path: description/p
#: org.kde.okular.appdata.xml:13
msgid "Features:"
msgstr "Szolgáltatások:"

#. (itstool) path: ul/li
#: org.kde.okular.appdata.xml:15
msgid ""
"Supported Formats: PDF, PS, Tiff, DjVu, Images, DVI, XPS, Fiction Book, "
"Comic Book, Plucker, EPub, Fax"
msgstr ""
"Támogatott formátumok: PDF, PS, Tiff, DjVu, képek, DVI, XPS, illusztrált "
"könyvek, képregények, Plucker, EPub, Fax"

#. (itstool) path: ul/li
#: org.kde.okular.appdata.xml:16
msgid "Sidebar with contents, thumbnails, reviews and bookmarks"
msgstr ""
"Oldalsáv tartalomjegyzékkel, előnézettel, értékelésekkel és könyvjelzőkkel"

#. (itstool) path: ul/li
#: org.kde.okular.appdata.xml:17
msgid "Annotations support"
msgstr "Jegyzetek támogatása"

#. (itstool) path: screenshot/caption
#: org.kde.okular.appdata.xml:22
msgid "Reading manual in Okular"
msgstr "Kézikönyv olvasása Okularban"

