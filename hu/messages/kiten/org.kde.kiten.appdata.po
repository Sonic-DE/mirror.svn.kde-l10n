#. (itstool) path: component/summary
#: org.kde.kiten.appdata.xml:11
msgid "Japanese Reference and Study Tool"
msgstr "Segédprogram a japán nyelv tanulásához"

#. (itstool) path: description/p
#: org.kde.kiten.appdata.xml:13
msgid ""
"Kiten is a Japanese reference and study tool. It features an English to "
"Japanese and Japanese to English dictionary, as well as a Kanji dictionary. "
"For the Kanji dictionary there are multiple ways supported to look up "
"characters."
msgstr ""
"A Kiten egy japán referencia- és tanulmányi eszköz. Tartalmaz egy angol-"
"japán és japán-angol szótárat, valamint egy kandzsi szótárat. A "
"kandzsiszótárban többféleképpen lehet keresni a karakterek."

#. (itstool) path: screenshot/caption
