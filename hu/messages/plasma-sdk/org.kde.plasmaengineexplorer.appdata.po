#. (itstool) path: component/name
#: org.kde.plasmaengineexplorer.appdata.xml:8
msgid "Plasma Engine Explorer"
msgstr "Plasma adatmodul-böngésző"

#. (itstool) path: component/summary
#: org.kde.plasmaengineexplorer.appdata.xml:9
msgid "Explorer for the data published by Plasma Data Engines"
msgstr "Adatkezelő a Plasma adatmodulok által szolgáltatott adatokhoz"

#. (itstool) path: description/p
#: org.kde.plasmaengineexplorer.appdata.xml:11
msgid ""
"Plasma Engine Explorer is a graphical tool allowing developers to test "
"Plasma DataEngines without writing a Plasma applet."
msgstr ""
"A Plasma adatmodul-böngésző egy grafikus segédprogram, amely lehetővé teszi "
"a fejlesztőknek a Plasma DataEngines tesztelését anélkül, hogy meg kellene "
"írni hozzá egy Plasma kisalkalmazást."
