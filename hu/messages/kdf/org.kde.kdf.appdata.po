msgid "KDiskFree"
msgstr "KDiskFree"

#. (itstool) path: component/summary
#: org.kde.kdf.appdata.xml:10
msgid "View Disk Usage"
msgstr "Lemezhasználat megjelenítése"

#. (itstool) path: description/p
#: org.kde.kdf.appdata.xml:12
msgid ""
"KDiskFree displays the available file devices (hard drive partitions, floppy "
"and CD drives, etc.) along with information on their capacity, free space, "
"type and mount point. It also allows you to mount and unmount drives and "
"view them in a file manager."
msgstr ""
"A KDiskFree megjeleníti a rendelkezésre álló fájleszközöket (merevlemez-"
"partíciók, floppy- és CD-meghajtók stb.), valamint a kapacitásukra, szabad "
"helyükre, típusukra és csatlakoztatási pontjaikra vonatkozó információkat. "
"Lehetővé teszi továbbá a meghajtók csatlakoztatását és leválasztását, "
"valamint a fájlkezelőben való megtekintésüket."

