#. Tag: para
#: index.docbook:17
#, no-c-format
msgid ""
"<acronym>ldap</acronym> is the lightweight directory access protocol. It "
"provides access to an X.500 directory, or to a stand-alone <acronym>LDAP</"
"acronym> server."
msgstr ""
"Az <acronym>LDAP</acronym> az angol Lightweight Directory Access Protocol "
"kifejezés rövidítése. Hozzáférést biztosít X.500-alapú címtárakban vagy "
"önálló <acronym>LDAP</acronym>-kiszolgálókon tárolt adatokhoz."

#. Tag: para
#: index.docbook:21
#, no-c-format
msgid "You can use the ldap KIO worker as follows:"
msgstr "Az ldap KDE-protokoll szintaktikája a következő:"

#. Tag: para
#: index.docbook:23
#, no-c-format
msgid ""
"<userinput>ldap://host:port/ou=People,o=where,c=de??sub</userinput> for a "
"subtree-query"
msgstr ""
"<userinput>ldap://gépnév:port/ou=emberek,o=hely,c=hu??sub</userinput> részfa "
"lekérdezése esetén"

#. Tag: para
#: index.docbook:26
#, no-c-format
msgid ""
"or <userinput>ldap://host:port/cn=MM,ou=People,o=where,c=de??base</"
"userinput> for a complete branch."
msgstr ""
"vagy <userinput>ldap://gépnév:port/cn=MM,ou=emberek,o=hely,c=hu??base</"
"userinput> teljes ág lekérdezése esetén."
