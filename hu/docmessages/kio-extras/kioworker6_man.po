#. Tag: para
#: index.docbook:22
#, fuzzy, no-c-format
#| msgid ""
#| "Using the man ioslave you are able to read the man pages installed on "
#| "your system. It is easy to use:"
msgid ""
"Using the man KIO worker you are able to read the man pages installed on "
"your system. It is easy to use:"
msgstr ""
"A man protokoll segítségével el lehet olvasni a rendszerben telepített man "
"formátumú dokumentumokat. Használata nagyon egyszerű:"

#. Tag: para
#: index.docbook:31
#, no-c-format
msgid "See the sections of the manual, click to find the rest."
msgstr ""
"A man-dokumentum szakaszainak áttekintése, kattintással lehet továbblépni."

#. Tag: userinput
#: index.docbook:36
#, no-c-format
msgid "<command>man:/</command><replaceable>fopen</replaceable>"
msgstr "<command>man:/</command><replaceable>fopen</replaceable>"

#. Tag: para
#: index.docbook:38
#, no-c-format
msgid "See the man page of <command>fopen</command>."
msgstr "Az <command>fopen</command> parancs man-oldalának megnyitása."

#. Tag: userinput
#: index.docbook:43
#, no-c-format
msgid "<command>man:/</command><replaceable>fopen(3)</replaceable>"
msgstr "<command>man:/</command><replaceable>fopen(3)</replaceable>"

#. Tag: para
#: index.docbook:45
#, fuzzy, no-c-format
msgid "See the man page of <command>fopen</command> in section 3."
msgstr "Az <command>fopen</command> parancs man-oldalának megnyitása."

#. Tag: userinput
#: index.docbook:50
#, no-c-format
msgid "<command>man:/</command><replaceable>(3)</replaceable>"
msgstr "<command>man:/</command><replaceable>(3)</replaceable>"

#. Tag: para
#: index.docbook:52
#, no-c-format
msgid "See the index of section 3."
msgstr ""

#. Tag: userinput
#: index.docbook:57
#, no-c-format
