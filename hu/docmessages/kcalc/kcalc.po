#. Tag: para
#: index.docbook:723
#, no-c-format
msgid ""
"<userinput>10 Lsh 3 =</userinput> gives <emphasis>80</emphasis> (10 "
"multiplied by 2 three times)."
msgstr ""
"<userinput>10 Lsh 3 =</userinput> a következő eredményt adja: <emphasis>80</"
