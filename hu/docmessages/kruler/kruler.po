msgid "Introduction"
msgstr "Bevezetés"

#. Tag: para
#: index.docbook:53
#, fuzzy, no-c-format
#| msgid ""
#| "&kruler; is a very simple application, with only one aim in life. To "
#| "measure distances on your screen."
msgid ""
"&kruler; is a very simple application, with only one aim in life. To measure "
"pixel distances on your screen. It is useful for working on layout of "
"dialogs, web pages &etc;"
msgstr ""
"A &kruler; egy egyszerű segédprogram, egyetlen rendeltetése az, hogy "
"távolságokat lehessen vele mérni a képernyőn."

#. Tag: para
#: index.docbook:57
#, fuzzy, no-c-format
msgid ""
"To start &kruler;, choose <menuchoice><guimenu>Applications</"
"guimenu><guisubmenu>Utilities</guisubmenu> <guisubmenu>More Applications</"
"guisubmenu> <guimenuitem>Screen Ruler</guimenuitem></menuchoice> from your "
"application menu."
msgstr ""
"A &kruler; indításához válassza a <menuchoice><guimenu>Grafikus programok</"
"guimenu> <guimenuitem>Képernyővonalzó</guimenuitem></menuchoice> menüpontot "
"a <guimenu>K</guimenu> menüben."

