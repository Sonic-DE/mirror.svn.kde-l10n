#| "BEF (Belgium), DEM (Germany), ESP (Spain), FIM (Finland), FRF (France), "
#| "GRD (Greece), IEP (Ireland), ITL (Italy), LUF (Luxembourg), NLG "
#| "(Netherlands), or PTE (Portugal)."
msgid ""
