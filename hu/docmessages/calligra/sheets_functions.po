#, no-c-format
msgid "RECEIVED(\"2/28/2001\"; \"8/31/2001\"; 1000; 0.05; 0) returns 1,025.787"
msgstr "RECEIVED(\"2/28/2001\"; \"8/31/2001\"; 1000; 0,05; 0) értéke 1 025,787"

