#, no-c-format
msgid "N(value)"
msgstr "N(érték)"

#. Tag: para
#: functions.docbook:4902
#, no-c-format
msgid "N(3.14) returns 3.14"
msgstr "N(3,14) értéke 3,14"

#. Tag: para
#: functions.docbook:4905
#, no-c-format
msgid "N(\"7\") returns 0 (because \"7\" is text)"
msgstr "N(\"7\") rtéke 0 (mert a \"7\" egy szöveg)"

