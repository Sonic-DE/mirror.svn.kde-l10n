#. Tag: guilabel
#: using-kmail.docbook:2212
#, no-c-format
msgid ""
"When encrypting emails, always also encrypt to the certificate of my own "
"identity"
msgstr ""

#. Tag: para
#: using-kmail.docbook:2214
#, fuzzy, no-c-format
#| msgid ""
#| "If this option is off and you want to send an encrypted message to "
