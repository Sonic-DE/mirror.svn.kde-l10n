#. Tag: userinput
#: index.docbook:693
#, no-c-format
msgid "K=10^-3"
msgstr ""

#. Tag: userinput
#: index.docbook:696
#, no-c-format
msgid "C=OH"
msgstr ""

#. Tag: userinput
#: index.docbook:699
#, no-c-format
msgid "OH=(10^-14)/H"
msgstr ""

#. Tag: userinput
#: index.docbook:702
#, no-c-format
msgid "H=10^-4"
msgstr ""

#. Tag: userinput
#: index.docbook:705
#, no-c-format
msgid "B=6*(10^-2)"
msgstr ""

#. Tag: para
#: index.docbook:707
#, no-c-format
msgid ""
"Then you have to write <userinput>D</userinput> as <guilabel>X axis:</"
"guilabel> and <userinput>A</userinput> as <guilabel>Y axis:</guilabel>: so "
"you will find out how the concentration of A changes as a function of D "
"concentration."
msgstr ""

#. Tag: para
#: index.docbook:711
#, no-c-format
msgid ""
"Please don't use parenthesis for exponents: <userinput>10^-3</userinput> is "
"correct, while <userinput>10^(-3)</userinput> is wrong."
msgstr ""

#. Tag: para
#: index.docbook:718
