msgstr "&pgr;"

#. Tag: para
#: index.docbook:894
#, no-c-format
msgid "Constants representing &pgr; (3.14159...)."
msgstr "Konstant som repræsenterer &pgr; (3,14159...)."

#. Tag: term
#: index.docbook:899
#, no-c-format
