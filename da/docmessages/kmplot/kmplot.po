"x<subscript>2</subscript>,...,x<subscript>n</subscript>}."
msgstr ""
"Giver den største værdi i talmængden {x<subscript>1</subscript>,"
"x<subscript>2</subscript>,...,x<subscript>n</subscript>}."

#. Tag: term
#: index.docbook:877
#, no-c-format
msgid ""
"mod(x<subscript>1</subscript>,x<subscript>2</subscript>,...,x<subscript>n</"
"subscript>)"
msgstr ""
"mod(x<subscript>1</subscript>,x<subscript>2</subscript>,...,x<subscript>n</"
"subscript>)"

#. Tag: para
#: index.docbook:878
