#: index.docbook:108
#, no-c-format
msgid "How to Play"
msgstr ""

#. Tag: para
#: index.docbook:110
#, fuzzy, no-c-format
#| msgid ""
#| "When you start a &konquest; game, a settings window pops up. From here "
#| "you need to enter player names, decide the number of planets, and how "
