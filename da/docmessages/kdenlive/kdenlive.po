msgid "<phrase>Kdenlive window with the tutorial files</phrase>"
msgstr "<phrase>Kdenlive 0.8 med vejledningsfilerne i vinduet</phrase>"

#. Tag: para
#: index.docbook:108
#, fuzzy, no-c-format
