msgstr "<guilabel>Arkiv</guilabel>"

#. Tag: guilabel
#: index.docbook:692
#, no-c-format
msgid "Archive backend:"
msgstr "Arkiveringsgrænseflade:"

#. Tag: para
#: index.docbook:693
#, fuzzy, no-c-format
#| msgid ""
#| "&akregator; currently only uses the Metakit database but for &kde; 4, "
