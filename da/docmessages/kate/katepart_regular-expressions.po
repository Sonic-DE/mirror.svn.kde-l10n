msgstr "Dette matcher <acronym>ASCII</acronym>-lodret-tab-tegnet (VT, 0x0B)."

#. Tag: userinput
#: regular-expressions.docbook:202
#, no-c-format
msgid "\\xhhhh"
msgstr "\\xhhhh"

#. Tag: para
#: regular-expressions.docbook:204
#, fuzzy, no-c-format
#| msgid ""
#| "This matches the Unicode character corresponding to the hexadecimal "
