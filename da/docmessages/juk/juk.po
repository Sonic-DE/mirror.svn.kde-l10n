msgstr "<guimenu>Afspiller</guimenu><guimenuitem>Pause</guimenuitem>"

#. Tag: para
#: index.docbook:1328
#, no-c-format
msgid ""
"This command pauses the currently playing song. Use the Play command to "
"restart playback."
msgstr ""
