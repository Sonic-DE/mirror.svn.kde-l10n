#. Tag: refpurpose
#: man-cvslastlog.1.docbook:20
#, no-c-format
msgid "Prints the log entry for the last commit for a file."
msgstr "Skriver logindgangen ud for den sidste arkivering af en fil."

#. Tag: cmdsynopsis
#: man-cvslastlog.1.docbook:24
#, no-c-format
msgid ""
"<command>cvslastlog</command> <group><option><replaceable>filename</"
"replaceable></option></group>"
msgstr ""
"<command>cvslastlog</command> <group><option><replaceable>filnavn</"
"replaceable></option></group>"

#. Tag: title
#: man-cvslastlog.1.docbook:32
#, no-c-format
msgid "Description"
msgstr "Beskrivelse"

#. Tag: para
#: man-cvslastlog.1.docbook:34
#, no-c-format
msgid ""
"<command>cvslastlog</command> shows the log associated with the last CVS "
"commit for the given file. It depends on the version of the local file, not "
"the one on the server."
msgstr ""
"<command>cvslastlog</command> viser loggen som hører sammen med den seneste "
"arkivering i CVS for den givne fil. Den afhænger af versionen af den lokale "
"fil, ikke den på serveren."

