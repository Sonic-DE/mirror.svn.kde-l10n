#. Tag: para
#: index.docbook:402
#, fuzzy, no-c-format
#| msgid ""
#| "To install a vocabulary from the Internet, click on the vocabulary item "
#| "in the list, then press the <quote><guibutton>Install</guibutton></quote> "
