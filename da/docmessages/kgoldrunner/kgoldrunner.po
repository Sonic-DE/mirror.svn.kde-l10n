msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>Q</keycap></keycombo></"
"shortcut> <guimenu>Spil</guimenu><guimenuitem>Afslut</guimenuitem>"

#. Tag: para
#: index.docbook:901
