#~ msgid "Enable tooltips"
#~ msgstr "Aktivér værktøjsvink"

#~ msgid "This will toggle tooltips off and on."
#~ msgstr "Dette slår værktøjsvink til og fra"

#~ msgid ""
#~ "If you click on the <guilabel>Effects</guilabel> tab, you will see the "
#~ "panel is divided into two sections."
#~ msgstr ""
#~ "Hvis du klikker på <guilabel>Effekter</guilabel>-fanebladet, vil du se "
