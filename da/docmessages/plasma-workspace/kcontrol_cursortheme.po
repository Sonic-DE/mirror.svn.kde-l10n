#~ msgid "Double click interval"
#~ msgstr "Dobbeltklik-interval"

#~ msgid ""
#~ "This is the maximum amount of time between clicks for &kde; to register a "
#~ "double click. If you click twice, and the time between those two clicks "
#~ "is less than this number, &kde; recognizes that as a double click. If the "
#~ "time between these two clicks is greater than this number, &kde; "
