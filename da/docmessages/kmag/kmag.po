#. Tag: title
#: index.docbook:442
#, no-c-format
msgid "Command Reference"
msgstr "Kommandoreference"

#. Tag: para
#: index.docbook:444
#, no-c-format
msgid ""
"&kmagnifier; automatically uses all your default shortcuts for saving file, "
"opening new window, printing, starting/stopping refresh (reload button in "
"&konqueror;), zoom-in, zoom-out &etc;"
msgstr ""
"&kmagnifier; bruger automatisk alle dine standardgenveje til at gemme fil, "
"åbne et nyt vindue, udskrive, starte/stoppe genopfriske (genindlæs-knappen i "
"&konqueror;), forstørre, formindske &etc;"

#. Tag: title
#: index.docbook:449
#, no-c-format
msgid "Default Keyboard Shortcuts"
msgstr "Standardtastaturgenveje"

#. Tag: keycombo
#: index.docbook:453
#, no-c-format
msgid "&Ctrl;<keycap>S</keycap>"
msgstr "&Ctrl;<keycap>S</keycap>"

#. Tag: para
#: index.docbook:454
#, no-c-format
msgid "This will save the contents of the zoom window to a file."
msgstr "Dette vil gemme indholdet af det forstørrede vindue til en fil."

#. Tag: keycap
#: index.docbook:459
#, no-c-format
msgid "<keycap>F2</keycap>"
msgstr "<keycap>F2</keycap>"

#. Tag: para
#: index.docbook:460
#, no-c-format
msgid "Switch to \"Follow Mouse Mode\"."
msgstr "Skift til \"Følg mus tilstand\"."

#. Tag: keycap
#: index.docbook:464
#, no-c-format
msgid "<keycap>F3</keycap>"
msgstr "<keycap>F3</keycap>"

#. Tag: para
#: index.docbook:465
#, no-c-format
msgid "Switch to \"Selection Window Mode\"."
msgstr "Skift til \"Markeringsvindue-tilstand\"."

