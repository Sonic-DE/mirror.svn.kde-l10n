#: index.docbook:506
#, no-c-format
msgid "&Ctrl;<keycap>M</keycap>"
msgstr "&Ctrl;<keycap>M</keycap>"

#. Tag: para
#: index.docbook:507
#, no-c-format
msgid "Show/Hide the menubar."
msgstr "Vis/Skjul menulinjen."

#. Tag: keycombo
#: index.docbook:511
#, no-c-format
msgid "&Ctrl;<keycap>-</keycap>"
msgstr "&Ctrl;<keycap>-</keycap>"

#. Tag: para
