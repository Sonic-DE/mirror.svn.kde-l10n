msgstr "<keycap>F7</keycap>"

#. Tag: keycombo
#: index.docbook:491
#, no-c-format
msgid "&Ctrl;<keycap>N</keycap>"
msgstr "&Ctrl;<keycap>N</keycap>"

#. Tag: para
#: index.docbook:492
#, no-c-format
msgid "This will open a new &kmagnifier; window."
msgstr "Dette åbner åbne et nyt &kmagnifier;-vindue."

#. Tag: keycombo
#: index.docbook:495
#, no-c-format
msgid "&Ctrl;<keycap>P</keycap>"
msgstr "&Ctrl;<keycap>P</keycap>"

#. Tag: para
#: index.docbook:496
#, no-c-format
msgid ""
"This will open the print dialog for printing the contents of the zoom window."
msgstr ""
"Dette vil åbne udskriftsdialogen til at udskrive indholdet af "
"forstørrelsesvinduet."

#. Tag: keycombo
#: index.docbook:500
#, no-c-format
msgid "&Ctrl;<keycap>C</keycap>"
msgstr "&Ctrl;<keycap>C</keycap>"

#. Tag: para
#: index.docbook:501
#, no-c-format
msgid "This will copy the zoom window contents to the clipboard."
msgstr "Dette vil kopiere forstørrelsesvinduets indhold til udklipsholderen."

