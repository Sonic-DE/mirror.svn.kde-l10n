#: index.docbook:469
#, no-c-format
msgid "<keycap>F4</keycap>"
msgstr "<keycap>F4</keycap>"

#. Tag: para
#: index.docbook:470
#, no-c-format
msgid "Switch to \"Whole Screen Mode\"."
msgstr "Skift til \"Helskærmstilstand\"."

#. Tag: keycap
#: index.docbook:474
#, no-c-format
msgid "<keycap>F5</keycap>"
msgstr "<keycap>F5</keycap>"

#. Tag: para
#: index.docbook:475
#, no-c-format
msgid ""
"This will start the refresh of the zoom window if it is stopped, or stops "
"the refresh of the zoom window if the refresh is currently on."
msgstr ""
"Dette vil starte genopfriskningen af forstørrelsesvinduet hvis det er "
"stoppet, eller stoppe genopfriskningen af forstørrelsesvinduet hvis "
"genopfriskning er slået til."

