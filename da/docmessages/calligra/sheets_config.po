#~ msgstr "Så vises dialogen <guilabel>Indstil genveje</guilabel>."

#~ msgid "Simple shortcut configuration"
#~ msgstr "Enkel indstilling af genveje"

#~ msgid "Advanced shortcut configuration"
#~ msgstr "Avanceret indstilling af genveje"

#~ msgid ""
