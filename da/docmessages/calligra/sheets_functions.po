#, no-c-format
msgid "New text which will be replacement"
msgstr "Ny tekst som vil være erstatning"

#. Tag: seg
#: functions.docbook:10197
#, no-c-format
msgid "Which occurrence to replace"
msgstr "Hvilken forekomst der skal erstattes"

