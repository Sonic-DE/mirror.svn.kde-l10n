msgstr ""
"Funktionen FISHER() giver Fisher-transformationen for x og laver en funktion "
"tæt på en normalfordeling."

#. Tag: para
#: functions.docbook:7933
#, no-c-format
msgid "FISHER(number)"
msgstr "FISHER(tal)"

#. Tag: para
#: functions.docbook:7940
#, no-c-format
