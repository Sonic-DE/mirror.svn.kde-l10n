#. Tag: title
#: index.docbook:64
#, no-c-format
msgid "Introduction"
msgstr "Indledning"

#. Tag: para
#: index.docbook:66
#, fuzzy, no-c-format
#| msgid ""
#| "&kbruch; is a small program to practice calculating with fractions. "
#| "Therefore 4 different exercises are offered."
msgid ""
"&kbruch; is a small program to practice calculating with fractions and "
"percentages. Six different exercises are offered as well as a learning mode."
msgstr ""
"&kbruch; er et lille program til at øve sig i at regne med brøker. Dertil "
"tilbydes 4 forskellige øvelser."

#. Tag: para
#: index.docbook:72
#, fuzzy, no-c-format
#| msgid ""
#| "Fraction Task - in this exercise you have to solve a given fraction task. "
#| "You have to enter numerator and denominator. This is the main exercise."
msgid ""
"<guilabel>Arithmetic</guilabel> - in this exercise you have to solve a given "
"fraction task. You have to enter the numerator and the denominator. This is "
"the main exercise."
msgstr ""
"Brøkopgave - i denneøvelse skal du løse en given brøkopgave. Du skal skrive "
"tæller og nævner. Dette er hovedøvelsen."

#. Tag: para
#: index.docbook:76
#, fuzzy, no-c-format
#| msgid ""
#| "Comparison - in this exercise you have to compare the size of 2 given "
#| "fractions."
msgid ""
"<guilabel>Comparison</guilabel> - in this exercise you have to compare the "
"size of 2 given fractions, using the symbols <guibutton>&gt;</guibutton>, "
"<guibutton>&lt;</guibutton> or <guibutton>=</guibutton>."
msgstr ""
"Sammenligning - i denne øvelse skal du sammenligne størrelserne af 2 givne "
"brøker."

#. Tag: para
#: index.docbook:81
#, fuzzy, no-c-format
#| msgid ""
#| "Conversion - in this exercise you have to convert a given number into a "
#| "fraction."
msgid ""
"<guilabel>Conversion</guilabel> - in this exercise you have to convert a "
"given number into a fraction."
msgstr ""
"Konvertering - i denne øvelse skal du konvertere et givet tal til en brøk."

#. Tag: para
#: index.docbook:85
#, fuzzy, no-c-format
#| msgid ""
#| "Conversion - in this exercise you have to convert a given number into a "
#| "fraction."
msgid ""
"<guilabel>Mixed Numbers</guilabel> - in this exercise you have to convert a "
"mixed number into an improper fraction (ratio) and vice versa."
msgstr ""
"Konvertering - i denne øvelse skal du konvertere et givet tal til en brøk."

#. Tag: para
#: index.docbook:89
#, fuzzy, no-c-format
#| msgid ""
#| "Factorization - in this exercise you have to factorize a given number "
#| "into its prime factors."
msgid ""
"<guilabel>Factorization</guilabel> - in this exercise you have to factorize "
"a given number into its prime factors."
msgstr ""
"Faktorisering - i denne øvelse skal du faktorisere et givet tal i dets "
"primfaktorer."

#. Tag: para
#: index.docbook:93
#, fuzzy, no-c-format
#| msgid ""
#| "Comparison - in this exercise you have to compare the size of 2 given "
#| "fractions."
msgid ""
"<guilabel>Percentage</guilabel> - in this exercise you have to calculate "
"percentages."
msgstr ""
"Sammenligning - i denne øvelse skal du sammenligne størrelserne af 2 givne "
"brøker."

#. Tag: para
#: index.docbook:98
#, fuzzy, no-c-format
#| msgid ""
#| "In all different exercises &kbruch; will generate a task and the user has "
#| "to solve it. The program checks the input and gives a feedback about it."
msgid ""
"In each different exercise &kbruch; will generate a task and the user has to "
"solve it. The program checks the input and gives a feedback about it."
msgstr ""
"I alle de forskellige øvelser vil &kbruch; generere en opgave og brugeren "
"skal løse den. Programmet tjekker det der skrives og giver tilbagemelding om "
"det."

#. Tag: para
#: index.docbook:103
#, fuzzy, no-c-format
#| msgid ""
#| "&kbruch; counts how many tasks were solved at all and how many tasks were "
#| "solved correctly. The statistics are shown to the user, but this part of "
#| "the main window can be hidden. The user can reset the statistics at any "
#| "point."
msgid ""
"&kbruch; counts how many tasks were solved at all and how many tasks were "
"solved correctly. The statistics are shown to the user."
msgstr ""
"&kbruch; tæller hvor mange opgaver der blev løst i det hele taget og hvor "
"mange af dem der var rigtige. Statistikken vises til brugeren, men denne del "
"af hovedvinduet kan skjules. Brugeren kan nulstille statistikken når "
"somhelst."

#. Tag: para
#: index.docbook:109
#, no-c-format
msgid ""
"&kbruch; is very compact and focuses on the core idea of a task generator. "
"An online help system provides context-sensitive help for the different "
"situations."
msgstr ""
"&kbruch; er meget kompakt og fokuserer på kerneideen at være "
"opgavegenerator. Et online hjælpsystem giver sammenhængsfølsom hjælp for de "
"forskellige situationer."

