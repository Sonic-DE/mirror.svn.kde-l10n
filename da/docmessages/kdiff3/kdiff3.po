#. Tag: guilabel
#: index.docbook:1530
#, fuzzy, no-c-format
#| msgid "Recursive Directories:"
msgid "Recursive folders"
msgstr "Rekursive mapper:"

#. Tag: para
#: index.docbook:1530
#, fuzzy, no-c-format
#| msgid "Select whether to search directories recursively."
msgid "Select whether to search folders recursively."
msgstr "Vælg om mapper skal gennemsøges rekursivt."

#. Tag: guilabel
#: index.docbook:1532
#, fuzzy, no-c-format
#| msgid "File Pattern(s):"
