#. Tag: para
#: commands.docbook:8
#, no-c-format
msgid "A brief overview of some special menu items in &kcalc;:"
msgstr ""

#. Tag: menuchoice
#: commands.docbook:12
#, no-c-format
msgid "<guimenu>Constants</guimenu> <guimenuitem>Mathematics</guimenuitem>"
msgstr "<guimenu>Konstanter</guimenu> <guimenuitem>Matematik</guimenuitem>"

#. Tag: action
#: commands.docbook:16
#, no-c-format
msgid "Display Pi, Euler Number or Golden Ratio."
msgstr "Vis pi, Eulers tal eller det gyldne snit."

#. Tag: menuchoice
#: commands.docbook:21
#, no-c-format
msgid ""
"<guimenu>Constants</guimenu> <guimenuitem>Electromagnetism</guimenuitem>"
msgstr ""
"<guimenu>Konstanter</guimenu> <guimenuitem>Elektromagnetisme</guimenuitem>"

#. Tag: action
#: commands.docbook:25
#, no-c-format
msgid ""
"Display Light Speed, Elementary Charge, Impedance of Vacuum, Permeability of "
"Vacuum or Permittivity of Vacuum."
msgstr ""
"Vis lyshastigheden, elementarladningen, impedansen i vakuum, permeabiliteten "
"i vakuum eller kapacitiviteten i vakuum."

#. Tag: menuchoice
#: commands.docbook:31
#, no-c-format
msgid ""
"<guimenu>Constants</guimenu> <guimenuitem>Atomic &amp; Nuclear</guimenuitem>"
msgstr ""
"<guimenu>Konstanter</guimenu> <guimenuitem>Atomer og kernefysik</guimenuitem>"

#. Tag: action
#: commands.docbook:35
#, no-c-format
msgid ""
"Display Planck's Constant, Elementary Charge or Fine-Structure Constant."
msgstr "Vis Plancks konstant, elementarladningen eller finstrukturkonstanten."

#. Tag: menuchoice
#: commands.docbook:41
#, no-c-format
msgid "<guimenu>Constants</guimenu> <guimenuitem>Thermodynamics</guimenuitem>"
msgstr "<guimenu>Konstanter</guimenu> <guimenuitem>Termodynamik</guimenuitem>"

#. Tag: action
#: commands.docbook:45
#, no-c-format
msgid ""
"Display Boltzmann Constant, Atomic Mass Unit, Molar Gas Constant, Stefan-"
"Boltzmann Constant or Avogadro's Number."
msgstr ""
"Vis Boltzmanns konstant, atommassenheden, den molære gaskonstant, Stefan-"
"Boltzmanns konstant eller Avogadros tal."

#. Tag: menuchoice
#: commands.docbook:51
#, no-c-format
msgid "<guimenu>Constants</guimenu> <guimenuitem>Gravitation</guimenuitem>"
msgstr "<guimenu>Konstanter</guimenu> <guimenuitem>Tyngdekraft</guimenuitem>"

#. Tag: para
#: commands.docbook:55
#, no-c-format
msgid "Display Constant of Gravitation or Earth Acceleration."
msgstr "Vis gravitationskonstanten eller jordaccelerationen."

