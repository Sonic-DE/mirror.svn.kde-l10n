msgid ""
"The comprehensive and indispensable <ulink url=\"https://invisible-island."
"net/xterm/ctlseqs/ctlseqs.html\">XTerm Control Sequences</ulink> "
"documentation"
msgstr ""

#. Tag: title
#: index.docbook:1850
#, no-c-format
msgid "Using Style Sheet for the Tab Bar"
msgstr ""

#. Tag: para
#: index.docbook:1851
#, no-c-format
msgid ""
"The default style sheet for the tab bar sets the minimum and maximum tab "
"widths. The user can create a <filename role=\"extension\">.css</filename> "
"file and have &konsole; use that as the style sheet for the tab bar. In the "
"<filename role=\"extension\">.css</filename> file, the widget to use is "
"<userinput>QTabBar::tab</userinput>."
msgstr ""

#. Tag: para
#: index.docbook:1857
#, no-c-format
msgid ""
"For more information, consider reading <ulink url=\"https://doc.qt.io/qt-5/"
"stylesheet.html\">&Qt; Style Sheets</ulink>"
msgstr ""

#. Tag: para
#: index.docbook:1870
#, no-c-format
msgid "Change the selected tab's background to a light gray"
msgstr ""

#. Tag: programlisting
#: index.docbook:1872
#, no-c-format
msgid ""
"QTabBar::tab:selected {\n"
"    background: #999999\n"
"}"
msgstr ""

#. Tag: para
#: index.docbook:1876
#, fuzzy, no-c-format
#| msgid "<action>Copy the selected text to the clipboard</action>."
msgid "Change the selected tab's text to red"
msgstr "<action>Kopiér den valgte tekst til klippebordet.</action>"

#. Tag: programlisting
#: index.docbook:1878
#, no-c-format
msgid ""
"QTabBar::tab:selected {\n"
"    color: red\n"
"}"
msgstr ""

#. Tag: para
#: index.docbook:1881
#, no-c-format
msgid "All tabs will be at least 200 pixels in width"
msgstr ""

#. Tag: programlisting
#: index.docbook:1883
#, no-c-format
msgid ""
"QTabBar::tab {\n"
"    min-width: 200px\n"
"}"
msgstr ""

#. Tag: para
#: index.docbook:1886
#, no-c-format
msgid "Only the selected tab will be at least 200 pixels in width"
msgstr ""

#. Tag: programlisting
#: index.docbook:1888
#, no-c-format
msgid ""
"QTabBar::tab::selected {\n"
"    min-width: 200px\n"
"}"
msgstr ""

#. Tag: para
#: index.docbook:1891
#, no-c-format
msgid "Any of these can be combined in one file"
msgstr ""

#. Tag: programlisting
#: index.docbook:1893
#, no-c-format
msgid ""
"QTabBar::tab::selected {\n"
"    background: #999999;\n"
"    color: red;\n"
"    min-width: 200px;\n"
"}\n"
"QTabBar::tab {\n"
"    min-width: 100px\n"
"}"
msgstr ""

#. Tag: title
#: index.docbook:1903
#, no-c-format
msgid "Did You Know?, Common Issues and More"
msgstr ""

#. Tag: title
#: index.docbook:1906
#, no-c-format
msgid "Did You Know?"
msgstr ""

#. Tag: para
#: index.docbook:1910
#, fuzzy, no-c-format
#| msgid ""
#| "Pressing the &Ctrl; and &Alt; keys along with the &LMB; will select a "
#| "column of text."
msgid ""
"Pressing &Ctrl; while selecting text will cause lines breaks to be converted "
"to spaces when pasted."
msgstr ""
"Tryk på &Ctrl;- og &Alt;-tasterne sammen med venstre museknap vælger en "
"søjle med tekst."

#. Tag: para
#: index.docbook:1914
#, fuzzy, no-c-format
#| msgid ""
#| "Pressing the &Ctrl; and &Alt; keys along with the &LMB; will select a "
#| "column of text."
msgid ""
"Pressing the <keycombo action=\"simul\">&Ctrl;&Alt;</keycombo> keys while "
"selecting text will select columns."
msgstr ""
"Tryk på &Ctrl;- og &Alt;-tasterne sammen med venstre museknap vælger en "
"søjle med tekst."

#. Tag: para
#: index.docbook:1918
#, no-c-format
msgid ""
"The <keycombo action=\"simul\">&Ctrl;<mousebutton>Wheel</mousebutton></"
"keycombo> combination will zoom text size, like in konqueror and firefox."
msgstr ""

#. Tag: para
#: index.docbook:1922
#, no-c-format
msgid ""
"When a program evaluates either mouse button, pressing the &Shift; key will "
"allow the popup menu to appear."
msgstr ""

#. Tag: para
#: index.docbook:1926
#, fuzzy, no-c-format
#| msgid ""
#| "<shortcut><keycombo action=\"simul\">&Shift;<keycap>Insert</keycap></"
#| "keycombo></shortcut> <guimenu>Edit</guimenu><guimenuitem>Paste </"
