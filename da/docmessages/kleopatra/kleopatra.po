msgstr "Ændr standardskrifttype som bruges for alle listevisninger i &kde;."

#. Tag: para
#: index.docbook:1846
#, no-c-format
msgid "Use a custom font."
msgstr "Brug en egen skrifttype."

#. Tag: para
#: index.docbook:1851
#, no-c-format
