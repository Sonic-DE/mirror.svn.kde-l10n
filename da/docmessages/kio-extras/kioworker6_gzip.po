msgid "gzip"
msgstr "gzip"

#. Tag: author
#: index.docbook:12
#, no-c-format
msgid "&Lauri.Watts; &Lauri.Watts.mail;"
msgstr "&Lauri.Watts; &Lauri.Watts.mail;"

#. Tag: trans_comment
