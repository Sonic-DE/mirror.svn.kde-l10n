msgid "KDiskFree"
msgstr "KDiskFree"

#. (itstool) path: component/summary
#: org.kde.kdf.appdata.xml:10
msgid "View Disk Usage"
msgstr "Se diskforbrug"

#. (itstool) path: description/p
#: org.kde.kdf.appdata.xml:12
msgid ""
"KDiskFree displays the available file devices (hard drive partitions, floppy "
"and CD drives, etc.) along with information on their capacity, free space, "
"type and mount point. It also allows you to mount and unmount drives and "
"view them in a file manager."
msgstr ""
"KDiskFree viser de tilgængelige filenheder (harddiskpartitioner, diskette- "
"og cd-drev, osv.) med information om deres kapacitet, ledig plads, type og "
"monteringspunkt. Det lader dig også montere og afmontere drev og se dem i "
"filhåndteringen."

