#: host/org.kde.plasma.browser_integration.host.desktop.in:3
msgctxt "Name"
msgid "Plasma Browser Integration Host"
msgstr "Vært for Plasma browser-integration"

#: host/plasma-runner-browserhistory.desktop:3
msgctxt "Name|plasma runner"
msgid "Browser History"
msgstr "Browserhistorik"

#: host/plasma-runner-browserhistory.desktop:48
msgctxt "Comment"
msgid "Search the browser history for visited websites"
msgstr "Søg i browserhistorikken for besøgte hjemmesider"

#: host/plasma-runner-browserhistory.desktop:108
msgctxt "X-Plasma-Runner-Syntax-Descriptions"
msgid "Finds websites in the browser history whose title or URL match :q:"
msgstr ""
"Finder hjemmesider i browserhistorikken hvis titler eller URL matcher :q:"

#: host/plasma-runner-browsertabs.desktop:3
msgctxt "Name|plasma runner"
msgid "Browser Tabs"
msgstr "Browser-faneblade"

#: host/plasma-runner-browsertabs.desktop:49
msgctxt "Comment"
msgid "Find and activate browser tabs"
msgstr "Find og aktivér browser-faneblade"

#: host/plasma-runner-browsertabs.desktop:115
msgctxt "X-Plasma-Runner-Syntax-Descriptions"
msgid "Finds open browser tabs whose title or URL match :q:"
msgstr "Finder åbne browserfaneblade hvis titel eller URL matcher :q:"

