#~ msgstr ""
#~ "Filelight opretter et interaktivt kort med koncentriske segmenterede "
#~ "ringe som hjælper med at visualisere diskforbruget på din computer"

#~ msgid ""
#~ "Filelight is an application to visualize the disk usage on your computer"
#~ msgstr ""
#~ "Filelight er et program til at visualisere diskforbruget på din computer"

#~ msgid "File system navigation by mouse clicks"
#~ msgstr "Navigation af filsystemet med museklik"

