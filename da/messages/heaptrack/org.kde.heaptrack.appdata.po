#. (itstool) path: component/name
#: org.kde.heaptrack.appdata.xml:6
msgid "Heaptrack"
msgstr "Heaptrack"

#. (itstool) path: component/summary
#: org.kde.heaptrack.appdata.xml:7
msgid "A heap memory profiler for Linux"
msgstr "En heap-hukommelsesprofilering til Linux"

#. (itstool) path: description/p
#: org.kde.heaptrack.appdata.xml:9
msgid ""
"Heaptrack traces all memory allocations and annotates these events with "
"stack traces. Dedicated analysis tools then allow you to interpret the heap "
"memory profile to:"
msgstr ""
"Heaptrack sporer alle hukommelsesallokeringer og anmærker begivenhederne med "
"stakspor. Dedikerede analyseværktøjer som giver dig mulighed for at fortolke "
"heapens hukommelsesprofil til:"

#. (itstool) path: ul/li
#: org.kde.heaptrack.appdata.xml:13
msgid ""
"find hotspots that need to be optimized to reduce the memory footprint of "
"your application"
msgstr ""
"find hotspots som behøver optimering for at reducere dit programs "
"hukommelsesfodaftryk"

#. (itstool) path: ul/li
#: org.kde.heaptrack.appdata.xml:14
msgid ""
"find memory leaks, i.e. locations that allocate memory which is never "
"deallocated"
msgstr ""
"find hukommelseslæk, dvs. positioner som allokerer hukommelse som aldrig "
"deallokeres"

#. (itstool) path: ul/li
#: org.kde.heaptrack.appdata.xml:15
msgid ""
"find allocation hotspots, i.e. code locations that trigger a lot of memory "
"allocation calls"
msgstr ""
"find allokerede hotspots, dvs. kodepositioner som udløser en masse kald for "
"hukommelsesallokering"

#. (itstool) path: ul/li
#: org.kde.heaptrack.appdata.xml:16
msgid ""
"find temporary allocations, which are allocations that are directly followed "
"by their deallocation"
msgstr ""
"find midlertidige allokeringer, som er allokeringer der direkte følges af "
"deres deallokering"

