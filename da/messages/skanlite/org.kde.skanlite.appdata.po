#. (itstool) path: component/name
#: org.kde.skanlite.appdata.xml:10
msgid "Skanlite"
msgstr "Skanlite"

#. (itstool) path: component/summary
#: org.kde.skanlite.appdata.xml:11
msgid "Image Scanning Application"
msgstr "Scannerprogram"

#. (itstool) path: description/p
#: org.kde.skanlite.appdata.xml:13
msgid ""
"Skanlite is a simple image scanning application to scan and save images. It "
"is optimized for scanning with flatbed scanners. Skanlite can capture not "
"only photos and documents, but also transparent slides and filmstrips, with "
"supported scanners."
msgstr ""
"Skanlite er et simpelt scannerprogram til at scanne og gemme billeder. "
"Skanlite er optimeret til at scanne med flatbed-scannere. Skanlite kan ikke "
"kun scanne billeder og dokumenter, men også transparenter og filmruller med "
"scannere der understøtter det."

#. (itstool) path: description/p
#: org.kde.skanlite.appdata.xml:17
msgid "Features:"
msgstr "Funktioner:"

#. (itstool) path: ul/li
#: org.kde.skanlite.appdata.xml:19
msgid ""
"Save dialog for every image scanned or saving the images immediately in a "
"specified folder with auto-generated names and format"
msgstr ""
"Gemmedialog for hvert billede der scannes eller gemning af billeder direkte "
"i en angiven mappe med autogenererede navne og format"

#. (itstool) path: ul/li
#: org.kde.skanlite.appdata.xml:20
msgid "Support for networks scanners"
msgstr "Understøttelse af netværksscannere"

#. (itstool) path: ul/li
