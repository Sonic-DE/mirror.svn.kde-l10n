#. Tag: title
#: functions.docbook:9629
#, no-c-format
msgid "FIXED"
msgstr ""

#. Tag: para
#: functions.docbook:9630
#, no-c-format
msgid ""
"The FIXED() function rounds a number to the specified number of decimals, "
"formats the number in decimal format string, and returns the result as text. "
"If decimals is negative, number is rounded to the left of the decimal point. "
"If you omit decimals, it is assumed to be 2. If optional parameter no_commas "
"is True, thousand separators will not show up."
msgstr ""
"FIXED() umsebenzi ujikelezisa kwinani leshumi elithile elikhankanyiweyo, "
"ifomata inani leshumi lomtya, ibuyisela iziphumo zokubhaliweyo. "
"ezingenasiphumo, inani lijikelezisiwe ekohlo lenani elilishumi kwincopho. "
"Ukuba ushiya amanan eshumi, itahtwa njenge 2. Ukuba ukhetho lwe parameter "
"akukho_ziphumlisi Yinyaniso, Abohluli abiyinkulungwane abazukubonakala."

#. Tag: para
#: functions.docbook:9635
#, no-c-format
msgid "FIXED(number;decimals;no_commas)"
msgstr "FIXED(inani;amanani alishumi;akukho_commas)"

#. Tag: seg
#: functions.docbook:9641
#, fuzzy, no-c-format
msgid "No_commas"
msgstr "No_commas"

#. Tag: para
#: functions.docbook:9644
#, no-c-format
msgid "FIXED(1234.567;1) returns \"1,234.6\""
msgstr "FIXED(1234.567;1) ibuyisela \"1,234.6\""

#. Tag: para
#: functions.docbook:9647
#, no-c-format
msgid "FIXED(1234.567;1;FALSE) returns \"1234.6\""
msgstr "FIXED(1234.567;1;FALSE) ibuyisela \"1234.6\""

#. Tag: para
#: functions.docbook:9650
#, no-c-format
msgid "FIXED(44.332) returns \"44.33\""
msgstr "FIXED(44.332) ibuyisela u \"44.33\""

