#. Tag: title
#: configuring.docbook:8
#, no-c-format
msgid "Configuring &kate;"
msgstr "Iqwalasela i &kate;"

#. Tag: title
#: configuring.docbook:11
#, no-c-format
msgid "Overview"
msgstr "Imboniselo engaphaya"

