#. Tag: title
#: man-kpackagetool6.1.docbook:52
#, no-c-format
msgid "Options"
msgstr "Võtmed"

#. Tag: option
#: man-kpackagetool6.1.docbook:56
#, no-c-format
msgid "-v, --version"
msgstr "-v, --version"

#. Tag: para
#: man-kpackagetool6.1.docbook:57
#, no-c-format
msgid "Displays version information."
msgstr "Versiooniteabe näitamine."

#. Tag: option
#: man-kpackagetool6.1.docbook:60
#, no-c-format
msgid "-h, --help"
msgstr "-h, --help"

#. Tag: para
#: man-kpackagetool6.1.docbook:61
#, no-c-format
msgid "Displays this help."
msgstr "Abi näitamine."

#. Tag: term
#: man-kpackagetool6.1.docbook:64
#, no-c-format
msgid "<option>--hash</option> <replaceable> path</replaceable>"
msgstr "<option>--hash</option> <replaceable> asukoht</replaceable>"

#. Tag: para
#: man-kpackagetool6.1.docbook:65
#, no-c-format
msgid "Generate a SHA1 hash for the package at <quote>path</quote>."
msgstr "SHA1 räsi genereerimine paketile asukohas <quote>asukoht</quote>."

#. Tag: option
#: man-kpackagetool6.1.docbook:68
#, no-c-format
msgid "-g, --global"
msgstr "-g, --global"

#. Tag: para
#: man-kpackagetool6.1.docbook:69
#, no-c-format
msgid "For install or remove, operates on packages installed for all users."
msgstr ""
"Paigaldamise või eemaldamise korral käsitleb pakette, mis on paigaldatud "
"kõigi kasutajate jaoks."

#. Tag: term
#: man-kpackagetool6.1.docbook:72
#, no-c-format
msgid "<option>-t, --type</option> <replaceable> type</replaceable>"
msgstr "<option>-t, --type</option> <replaceable> tüüp</replaceable>"

#. Tag: para
#: man-kpackagetool6.1.docbook:73
#, no-c-format
msgid ""
"The type of package, corresponding to the service type of the package "
"plugin, &eg; KPackage/Generic, Plasma/Theme, Plasma/Wallpaper, Plasma/"
"Applet, &etc;"
msgstr ""

#. Tag: term
#: man-kpackagetool6.1.docbook:77
#, no-c-format
msgid "<option>-i, --install</option> <replaceable> path</replaceable>"
msgstr "<option>-i, --install</option> <replaceable> asukoht</replaceable>"

#. Tag: para
#: man-kpackagetool6.1.docbook:78
#, no-c-format
msgid "Install the package at <quote>path</quote>."
msgstr "Paketi paigaldamine <quote>asukohta</quote>."

#. Tag: term
#: man-kpackagetool6.1.docbook:81
#, no-c-format
msgid "<option>-s, --show</option> <replaceable> name</replaceable>"
msgstr "<option>-s, --show</option> <replaceable> nimi</replaceable>"

#. Tag: para
#: man-kpackagetool6.1.docbook:82
#, no-c-format
msgid "Show information of package <quote>name</quote>."
msgstr "Paketi nimega <quote>nimi</quote> teabe näitamine."

#. Tag: term
#: man-kpackagetool6.1.docbook:85
#, no-c-format
msgid "<option>-u, --upgrade</option> <replaceable> path</replaceable>"
msgstr "<option>-u, --upgrade</option> <replaceable> asukoht</replaceable>"

#. Tag: para
#: man-kpackagetool6.1.docbook:86
#, no-c-format
msgid "Upgrade the package at <quote>path</quote>."
msgstr "Paketi uuendamine <quote>asukohas</quote>."

#. Tag: option
#: man-kpackagetool6.1.docbook:89
#, no-c-format
msgid "-l, --list"
msgstr "-l, --list"

#. Tag: para
#: man-kpackagetool6.1.docbook:90
#, no-c-format
msgid "List installed packages."
msgstr "Paigaldatud pakettide loetlemine."

#. Tag: option
#: man-kpackagetool6.1.docbook:93
#, no-c-format
msgid "--list-types"
msgstr "--list-types"

#. Tag: para
#: man-kpackagetool6.1.docbook:94
#, no-c-format
msgid "Lists all known Package types that can be installed."
msgstr "Kõigi teadaolevate paigaldatavate paketitüüpide näitamine."

#. Tag: term
#: man-kpackagetool6.1.docbook:97
#, no-c-format
msgid "<option>-r, --remove</option> <replaceable> name</replaceable>"
msgstr "<option>-r, --remove</option> <replaceable> nimi</replaceable>"

#. Tag: para
#: man-kpackagetool6.1.docbook:98
#, no-c-format
msgid "Remove the package named <quote>name</quote>."
msgstr "Paketi nimega <quote>nimi</quote> eemaldamine."

#. Tag: term
#: man-kpackagetool6.1.docbook:101
#, no-c-format
msgid "<option>-p, --packageroot</option> <replaceable> path</replaceable>"
msgstr "<option>-p, --packageroot</option> <replaceable> asukoht</replaceable>"

#. Tag: para
#: man-kpackagetool6.1.docbook:102
#, no-c-format
msgid ""
"Absolute path to the package root. If not supplied, then the standard data "
"directories for this &plasma; session will be searched instead."
msgstr ""
"Pakettide juurasukoha absoluutne asukoht. Kui seda ei anta, otsitakse antud "
"&plasma; seansi standardsetest andmekataloogidest."

#. Tag: term
#: man-kpackagetool6.1.docbook:106
#, no-c-format
msgid "<option>--generate-index</option> <replaceable> path</replaceable>"
msgstr "<option>--generate-index</option> <replaceable> asukoht</replaceable>"

#. Tag: para
#: man-kpackagetool6.1.docbook:107
#, fuzzy, no-c-format
#| msgid ""
#| "Recreate the plugin index. To be used in conjunction with either the "
#| "option <option>-t</option> or <option>-g</option>. Recreates the index "
#| "for the given type or package root. Operates in the user directory, "
#| "unless <option>-g</option> is used"
msgid ""
"Recreate the plugin index. To be used in conjunction with either the option "
"<option>-t</option> or <option>-g</option>. Recreates the index for the "
"given type or package root. Operates in the user directory, unless <option>-"
"g</option> is used."
msgstr ""
"Pluginate indeksi taasloomine. Kasutamiseks koos võtmega <option>-t</option> "
"või <option>-g</option>. Taasluuakse määratud tüübi või paketi juurasukoha "
"indeks. Töötab kasutaja kataloogis, kui ei kasutata võtit <option>-g</"
"option>."

