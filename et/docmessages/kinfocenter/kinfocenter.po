#~ msgid "IEEE 1394 Device Information Module"
#~ msgstr "IEEE 1394 seadmete infomoodul"

#~ msgid ""
#~ "The IEEE 1394 interface, also known as <trademark>FireWire</trademark>, "
#~ "is a serial bus interface standard for high-speed communications and "
#~ "isochronous real-time data transfer."
#~ msgstr ""
#~ "IEEE 1394 liides, tuntud ka kui <trademark>FireWire</trademark>, on kiire "
#~ "side ja isokroonse reaalajas andmete edastamise järjestiksiini liidese "
#~ "standard."

#~ msgid ""
#~ "The list in this module displays all devices attached to IEEE 1394 bus "
#~ "and allows you to reset the bus by clicking the <guibutton>Generate 1394 "
#~ "Bus Reset</guibutton> button."
#~ msgstr ""
#~ "Moodulis esitatud loend toob ära kõik IEEE 1394 siiniga ühendatud seadmed "
#~ "ning võimaldab siini lähtestada klõpsuga nupule <guibutton>Lähtesta 1394 "
#~ "siin</guibutton>"

#~ msgid "The meaning of the columns in this list:"
#~ msgstr "Loendi veergude tähendus on järgmine:"

#~ msgid ""
#~ "<guilabel>Name</guilabel>: port or node name, the number can change with "
#~ "each bus reset"
#~ msgstr ""
#~ "<guilabel>Nimi</guilabel>: pordi või sõlme nimi, arv võib muutuda iga "
#~ "siini lähtestamisega"

#~ msgid "<guilabel>GUID</guilabel>: the 64 bit GUID of the node"
#~ msgstr "<guilabel>GUID</guilabel>: 64-bitine sõlme GUID"

#~ msgid ""
#~ "<guilabel>Local</guilabel>: checked if the node is an IEEE 1394 port of "
#~ "your computer"
#~ msgstr ""
#~ "<guilabel>Kohalik</guilabel>: märgitud, kui sõlm on sinu arvuti IEEE 1394 "
#~ "port"

#~ msgid ""
#~ "<guilabel>IRM</guilabel>: checked if the node is isochronous resource "
#~ "manager capable"
#~ msgstr ""
#~ "<guilabel>IRM</guilabel>: märgitud, kui sõlm suudab toimida isokroonse "
#~ "ressurssihaldurina"

#~ msgid ""
#~ "<guilabel>CRM</guilabel>: checked if the node is cycle master capable"
#~ msgstr ""
#~ "<guilabel>CRM</guilabel>: märgitud, kui sõlm suudab toimida tsüklijuhina"

#~ msgid ""
#~ "<guilabel>ISO</guilabel>: checked if the node supports isochronous "
#~ "transfers"
#~ msgstr ""
#~ "<guilabel>ISO</guilabel>: märgitud, kui sõlm toetab isokroonset edastust"

#~ msgid "<guilabel>BM</guilabel>: checked if the node is bus manager capable"
#~ msgstr ""
#~ "<guilabel>BM</guilabel>: märgitud, kui sõlm võib toimida siinihaldurina"

#~ msgid ""
#~ "<guilabel>PM</guilabel>: checked if the node is power management capable"
#~ msgstr ""
#~ "<guilabel>PM</guilabel>: märgitud, kui sõlm võib toimida energiahaldurina"

#~ msgid ""
#~ "<guilabel>Acc</guilabel>: the cycle clock accuracy of the node, valid "
#~ "from 0 to 100"
#~ msgstr ""
#~ "<guilabel>Acc</guilabel>: sõlme tsüklikella täpsus vahemikus 0 kuni 100"

#~ msgid "<guilabel>Speed</guilabel>: the speed of the node"
#~ msgstr "<guilabel>Kiirus</guilabel>: sõlme kiirus"

#~ msgid "<guilabel>Vendor</guilabel>: the vendor of the device"
#~ msgstr "<guilabel>Tootja</guilabel>: seadme tootja"

