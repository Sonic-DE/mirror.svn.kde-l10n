#. Tag: para
#: index.docbook:135
#, fuzzy, no-c-format
#| msgid ""
#| "Scripts set on to be ran on <guilabel>Shutdown</guilabel> are copied or "
#| "symlinked in the <filename class=\"directory\">$HOME/.config/plasma-"
#| "workspace/shutdown</filename> directory and will be automatically run "
#| "during &plasma; shutdown after the user has logged out."
