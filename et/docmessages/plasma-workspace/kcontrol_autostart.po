#. Tag: para
#: index.docbook:128
#, fuzzy, no-c-format
#| msgid ""
#| "Scripts and desktop files set to run on <guilabel>Startup</guilabel> are "
#| "copied or symlinked in <filename class=\"directory\">$HOME/.config/"
