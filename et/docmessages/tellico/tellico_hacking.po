#. Tag: title
#: hacking.docbook:338
#, no-c-format
msgid "Bibtex Character Translation"
msgstr "Bibtexi märgiteisendus"

#. Tag: para
#: hacking.docbook:340
#, no-c-format
msgid ""
"When bibtex files are imported or exported, certain characters are "
"translated between their TeX equivalents and the Unicode characters. Those "
"character mappings are contained in the <filename>bibtex-translation.xml</"
"filename> file, located in the installation data directory. The mappings can "
"be modified, as desired. The key element contains the Unicode character, and "
"the string elements within contain the TeX equivalents, which may be a one-"
"to-many mapping. The first one is the one used when exporting to bibtex."
msgstr ""
"Bibtex-failide importimisel või eksportimisel teisendatakse teatavad TeXi ja "
"Unicode'i märgid. Vastavad seosed on kirjas failis <filename>bibtex-"
"translation.xml</filename>, mis asub paigalduse andmekataloogis (data). Neid "
"seoseid võib vastavalt vajadusele või soovile muuta. Element key sisaldab "
"Unicode'i märki ning element string selle TeXi vasteid; tegemist võib olla "
"ka üks-mitmele-seosega. Bibtexi eksportimisel kasutatakse esimest seost."

#. Tag: programlisting
#: hacking.docbook:344
#, no-c-format
msgid ""
"<![CDATA[\n"
"  <key char=\"À\">\n"
"    <string>{\\`A}</string>\n"
"    <string>\\`{A}</string>\n"
"  </key>\n"
"]]>"
msgstr ""
"<![CDATA[\n"
"  <key char=\"À\">\n"
"    <string>{\\`A}</string>\n"
"    <string>\\`{A}</string>\n"
"  </key>\n"
"]]>"

