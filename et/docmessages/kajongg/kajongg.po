#. Tag: screeninfo
#: index.docbook:548
#, no-c-format
msgid "<screeninfo>Configure Dialog</screeninfo>"
msgstr "<screeninfo>Seadistustedialoog</screeninfo>"

#. Tag: phrase
#: index.docbook:554
#, no-c-format
