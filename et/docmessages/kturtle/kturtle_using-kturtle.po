#~ msgid ""
#~ "This action <quote>indents</quote> (adds white space at the beginning of) "
#~ "the lines that are selected. When <quote>indentation</quote> is used "
#~ "properly this can make code much easier to read. All examples use "
#~ "indentation, please check them out."
