#. Tag: para
#: index.docbook:18
#, fuzzy, no-c-format
#| msgid ""
#| "The smb ioslave enables you to browse the shares of a &Windows; (or "
#| "Samba) network."
msgid ""
"The smb worker enables you to browse the shares of a &Windows; (or Samba) "
"network."
msgstr ""
"Smb IO-moodul võimaldab sirvida &Windows; (või Samba) võrgu jagatud "
"ressursse."

#. Tag: para
#: index.docbook:23
#, no-c-format
msgid ""
"To see the workgroups, enter <userinput><command>smb:/</command></userinput>."
msgstr ""
"Töögruppide nägemiseks sisesta <userinput><command>smb:/</command></"
"userinput>."

#. Tag: para
#: index.docbook:27
#, no-c-format
msgid ""
"<userinput><command>smb://</command><replaceable>a_workgroup</replaceable></"
"userinput> will list the hosts in this workgroup."
msgstr ""
"<userinput><command>smb://</command><replaceable>töögrupp</replaceable></"
"userinput> näitab selle töögrupi masinaid."

#. Tag: para
#: index.docbook:31
#, no-c-format
msgid ""
"To see the shares of a host, enter <userinput><command>smb://</"
"command><replaceable>the_host</replaceable></userinput> or "
"<userinput><command>smb:/</command><replaceable>a_workgroup</replaceable>/"
"<replaceable>the_host</replaceable></userinput>."
msgstr ""
"Masina jagatud ressursside nägemiseks sisesta <userinput><command>smb://</"
"command><replaceable>masin</replaceable></userinput> või "
"<userinput><command>smb:/</command><replaceable>töögrupp</"
"replaceable><replaceable>masin</replaceable></userinput>."

#. Tag: para
#: index.docbook:37
#, no-c-format
msgid ""
"To access a share directly enter <userinput><command>smb://</"
"command><replaceable>the_host/the_share</replaceable></userinput> or "
"<userinput><command>smb:/</command><replaceable>a_workgroup</replaceable>/"
"<replaceable>the_host</replaceable>/<replaceable>the_share</replaceable></"
"userinput>"
msgstr ""
"Jagatud ressursside vahetuks kasutamiseks sisesta <userinput><command>smb://"
"</command><replaceable>masin/ressurss</replaceable></userinput> või "
"<userinput><command>smb:/</command><replaceable>töögrupp</"
"replaceable><replaceable>masin</replaceable>/<replaceable>ressurss</"
"replaceable></userinput>"

#. Tag: para
#: index.docbook:44
#, fuzzy, no-c-format
#| msgid ""
#| "The smb ioslave requires that you have libsmbclient to use this ioslave."
msgid "The smb worker requires that you have libsmbclient to use this worker."
msgstr "Smb IO-mooduli kasutamiseks on nõutav libsmbclient."

#. Tag: para
#: index.docbook:48
#, fuzzy, no-c-format
#| msgid ""
#| "You can set your default user name and password in the &systemsettings; "
#| "category <guilabel>Network and Connectivity</guilabel> in "
#| "<menuchoice><guisubmenu>Sharing</guisubmenu><guimenuitem> Windows Shares</"
#| "guimenuitem></menuchoice>. This is especially useful if you are a member "
#| "of a &Windows; <acronym>NT</acronym> domain. There you can also set your "
#| "workgroup name, but in most cases this is not required. The kioslave will "
#| "ask for your username and password if a default is not set."
msgid ""
"You can set your default user name and password in the &systemsettings; "
"category <guilabel>Network</guilabel> in "
"<menuchoice><guisubmenu>Connectivity</guisubmenu><guimenuitem> Windows "
"Shares</guimenuitem></menuchoice>. This is especially useful if you are a "
"member of a &Windows; <acronym>NT</acronym> domain. There you can also set "
"your workgroup name, but in most cases this is not required. The worker will "
"ask for your username and password if a default is not set."
msgstr ""
"Oma vaikimisi pruugitava kasutajanime ja parooli saad määrata Süsteemi "
"seadistustes kategoorias <guilabel>Võrk ja ühendus</guilabel> "
"(<menuchoice><guisubmenu>Jagamine</guisubmenu><guimenuitem>Windowsi "
"ressursid</guimenuitem></menuchoice>). See tuleb eriti kasuks siis, kui "
"kuulud &Windows; <acronym>NT</acronym> domeeni. Seal saab määrata ka "
"töögrupi nime, kuid see ei ole enamasti nõutav. KIO-moodul pärib sinu "
"kasutajanime ja parooli, kui nende vaikeväärtusi ei ole määratud."

#~ msgid ""
#~ "This ioslave is tested and developed using mainly Samba 2.0.7, but other "
#~ "versions of Samba should work too."
#~ msgstr ""
#~ "IO moodul on testitud ja arendatud peamiselt Samba 2.0.7 peal, kuid see "
#~ "peaks toimima ka Samba muude versioonidega."

