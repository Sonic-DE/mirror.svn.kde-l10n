#| msgid ""
#| "The KService cache generated by <command>kbuildsycoca5</command>. On Unix "
#| "systems, <varname>cachedir</varname> is typically <filename class="
#| "\"directory\"><envar>XDG_CONFIG_HOME</envar></filename>"
