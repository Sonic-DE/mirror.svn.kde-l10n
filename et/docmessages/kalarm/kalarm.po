msgstr ""
"Vali menüükäsk <menuchoice><guimenu>Redigeerimine</guimenu> "
"<guimenuitem>Kustuta</guimenuitem></menuchoice>."

#. Tag: para
#: index.docbook:496
#, no-c-format
msgid ""
"<mousebutton>Right</mousebutton> click on the selected entries and choose "
