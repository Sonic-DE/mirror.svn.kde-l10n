msgstr "--edit-new-command"

#. Tag: entry
#: index.docbook:3685
#, no-c-format
msgid "Display the Alarm Edit dialog, in order to edit a new command alarm."
msgstr "Avab häire redigeerimise dialoogi uue käsuhäire redigeerimiseks."

#. Tag: option
#: index.docbook:3689
#, no-c-format
msgid "--edit-new-display"
msgstr "--edit-new-display"

#. Tag: entry
#: index.docbook:3690
#, no-c-format
msgid "Display the Alarm Edit dialog, in order to edit a new display alarm."
msgstr "Avab häire redigeerimise dialoogi uue nähtava häire redigeerimiseks."

#. Tag: option
#: index.docbook:3694
#, no-c-format
msgid "--edit-new-email"
msgstr "--edit-new-email"

#. Tag: entry
#: index.docbook:3695
#, no-c-format
msgid "Display the Alarm Edit dialog, in order to edit a new email alarm."
msgstr "Avab häire redigeerimise dialoogi uue kirjahäire redigeerimiseks."

#. Tag: option
#: index.docbook:3699
#, no-c-format
msgid "--edit-new-preset <replaceable>templateName</replaceable>"
msgstr "--edit-new-preset <replaceable>mallinimi</replaceable>"

#. Tag: entry
#: index.docbook:3700
#, no-c-format
msgid ""
"Display the Alarm Edit dialog, preset with the alarm template of the "
"specified name, in order to edit a new alarm."
