#. Tag: guimenuitem
#: index.docbook:2355
#, no-c-format
msgid "Quit"
msgstr "Välju"

#. Tag: action
#: index.docbook:2356
#, no-c-format
msgid "Closes the &kalarm; system tray icon and main windows."
msgstr "Sulgeb &kalarm;i süsteemisalve ikooni ja peaakna."

#. Tag: para
#: index.docbook:2358
#, no-c-format
