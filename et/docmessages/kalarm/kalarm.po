msgstr "Lõpetab &kalarm;i töö, kui ei kuvata ühtegi häireteate akent."

#. Tag: title
#: index.docbook:2364
#, no-c-format
msgid "Displaying &kalarm; in the System Tray"
msgstr "&kalarm;i näitamine süsteemisalves"

#. Tag: para
#: index.docbook:2366
#, fuzzy, no-c-format
#| msgid ""
