msgid ""
"<shortcut><keycap>T</keycap></shortcut> <guimenu>Move</guimenu> "
"<guimenuitem>Teleport Safely</guimenuitem>"
msgstr ""
"<shortcut><keycap>T</keycap></shortcut> <guimenu>Käik</guimenu> "
"<guimenuitem>Turvaline teleport</guimenuitem>"

#. Tag: para
#: index.docbook:262
#, no-c-format
msgid ""
"<action>Teleports the hero to a random, empty cell that is guaranteed to be "
"safe from attack on that turn.</action> See <link linkend=\"teleport-safely"
"\" endterm=\"special-actions-title\"></link>."
msgstr ""
"<action>Telepordib kangelase juhuslikult valitud tühja lahtrisse, kus ta on "
"kindlasti antud käigul kaitstud rünnaku eest.</action> Vaata ka <link "
"linkend=\"teleport-safely\" endterm=\"special-actions-title\"></link>."

#. Tag: menuchoice
