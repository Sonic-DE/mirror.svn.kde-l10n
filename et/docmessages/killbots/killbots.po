"<shortcut><keycap>Tühikuklahv</keycap></shortcut> <guimenu>Käik</guimenu> "
"<guimenuitem>Teleport (võimaluse korral turvaline)</guimenuitem>"

#. Tag: para
#: index.docbook:270
#, no-c-format
msgid ""
"A convenience action. <action>Teleports the hero safely if there is enough "
"energy available, otherwise just teleports randomly.</action>"
msgstr ""
"Puhtalt mugavuse pärast: <action>telepordib kangelase turvaliselt, kui on "
"piisavalt energiat, vastasel juhul lihtsalt telepordib.</action>"

#. Tag: menuchoice
#: index.docbook:273
#, no-c-format
msgid ""
"<shortcut><keycap>F</keycap></shortcut> <guimenu>Move</guimenu> "
"<guimenuitem>Vaporizer</guimenuitem>"
msgstr ""
"<shortcut><keycap>F</keycap></shortcut> <guimenu>Käik</guimenu> "
"<guimenuitem>Aurustaja</guimenuitem>"

#. Tag: para
#: index.docbook:278
#, no-c-format
msgid ""
"<action>Destroys all robots in cells adjacent to the hero</action>. See "
"<link linkend=\"vaporizer\" endterm=\"special-actions-title\"></link>."
msgstr ""
"<action>Hävitab kõik kangelase naaberlahtrites olevad robotid.</action> "
