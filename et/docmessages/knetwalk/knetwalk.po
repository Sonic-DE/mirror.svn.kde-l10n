"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>N</keycap></keycombo> </"
"shortcut> <guimenu>Mäng</guimenu> <guimenuitem>Uus</guimenuitem>"

#. Tag: para
#: index.docbook:128
#, no-c-format
msgid ""
"Starts a new game. It creates a random board using the current difficulty "
"level."
msgstr ""
"Alustab uut mängu. Selleks luuakse senise raskusastmega juhusliku sisuga "
"mängulaud."

#. Tag: menuchoice
#: index.docbook:135
#, no-c-format
msgid ""
"<shortcut><keycap>P</keycap></shortcut> <guimenu>Game</guimenu> "
"<guimenuitem>Pause</guimenuitem>"
msgstr ""
"<shortcut><keycap>P</keycap></shortcut> <guimenu>Mäng</guimenu> "
