#, no-c-format
msgid "LaTeX+PS (&okular;)"
msgstr "LaTeX+PS (&okular;)"

#. Tag: application
#: index.docbook:2901
#, no-c-format
msgid "PDFLaTeX+PDF (embedded viewer)"
msgstr "PDFLaTeX+PDF (põimitud näitaja)"

#. Tag: application
