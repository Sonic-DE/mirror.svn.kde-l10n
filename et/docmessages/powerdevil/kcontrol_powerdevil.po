#. Tag: term
#: index.docbook:240
#, no-c-format
msgid "Peripheral devices"
msgstr "Välisseadmed"

#. Tag: para
#: index.docbook:242
#, fuzzy, no-c-format
#| msgid "Defines the low level for peripheral devices &eg; a wireless mouse."
msgid ""
