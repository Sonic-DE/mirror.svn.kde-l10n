msgstr "Skriptide ülevaade"

#. Tag: para
#: index.docbook:2612
#, no-c-format
msgid ""
"&konversation; comes with several scripts installed by default, please refer "
"to this guide to learn how to use them."
msgstr ""
"Koos &konversation;iga paigaldatakse vaikimisi mõned skriptd, mille "
"kasutamisest tuleb alljärgnevalt juttu."

#. Tag: userinput
#: index.docbook:2616
#, no-c-format
msgid ""
"<command>/exec </command> <replaceable>bug</replaceable> [<replaceable>Bug "
"Number|Search String</replaceable>]"
msgstr ""
"<command>/exec </command> <replaceable>bug</replaceable> "
"[<replaceable>veateate number|Otsingustring</replaceable>]"

#. Tag: para
