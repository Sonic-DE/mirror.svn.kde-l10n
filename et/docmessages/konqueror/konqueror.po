#~ msgid ""
#~ "The default User Agent header for &konqueror; is Mozilla/5.0(compatible;"
#~ "Konqueror/4.7)(KHTML/4.7, like Gecko). If you come across a site that "
#~ "refuses this browser access, change your User Agent to one of the options "
#~ "below."
#~ msgstr ""
