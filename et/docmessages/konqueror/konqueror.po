#. Tag: title
#: index.docbook:2510
#, no-c-format
msgid "Special Shortcuts"
msgstr "Spetsiaalsed kiirklahvid"

#. Tag: para
#: index.docbook:2511
#, no-c-format
msgid "There are some useful shortcuts that are not shown in any of the menus:"
msgstr "Need on mõned kasulikud kiirklahvid, mida ei ole näha üheski menüüs:"

#. Tag: keycap
#: index.docbook:2515
#, no-c-format
