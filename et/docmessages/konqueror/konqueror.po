#~ msgid "Shortcuts"
#~ msgstr "Kiirklahvid"

#~ msgid ""
#~ "To change the shortcut key arrangements used by &konqueror; select "
#~ "<menuchoice><guimenu>Settings</guimenu><guimenuitem>Configure "
#~ "Shortcuts... </guimenuitem></menuchoice>. This will launch a dialog box "
