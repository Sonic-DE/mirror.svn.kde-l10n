#. Tag: para
#: index.docbook:55
#, no-c-format
msgid ""
"&i18n-kapplication; is an editor for &kaddressbook; themes based on <ulink "
"url=\"https://github.com/steveire/grantlee\">Grantlee</ulink>."
msgstr ""
"&i18n-kapplication; on KDE aadressiraamatu kontakti teema redaktor, mille "
"aluseks on <ulink url=\"https://github.com/steveire/grantlee\">Grantlee</"
"ulink>."

#. Tag: title
#: index.docbook:59
#, no-c-format
msgid "Using &i18n-kapplication;"
msgstr "&i18n-kapplication;i kasutamine"

#. Tag: para
#: index.docbook:60
#, no-c-format
msgid ""
"This editor is used to create themes for your contacts in &kaddressbook;. "
"More Information you find in the <ulink url=\"http://www.grantlee.org/apidox/"
"\">Grantlee</ulink> documentation."
msgstr ""
"See redaktor on mõeldud KDE aadressiraamatus leiduvatele kontaktidele "
"teemade loomiseks. Rohkem teavet leiab <ulink url=\"http://www.grantlee.org/"
"apidox/\">Grantlee</ulink> dokumentatsioonist."

