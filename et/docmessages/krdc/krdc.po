msgstr "&krdc; seadistused - <guilabel>RDP vaikeväärtuste</guilabel> kaart"

#. Tag: phrase
#: index.docbook:490
#, no-c-format
msgid "&krdc; preferences - <guilabel>RDP Defaults</guilabel> profiles tab"
msgstr "&krdc; seadistused - <guilabel>RDP vaikeväärtuste</guilabel> kaart"

#. Tag: title
#: index.docbook:503
#, no-c-format
msgid "Questions and Answers"
msgstr "Küsimused ja vastused"

#. Tag: para
#: index.docbook:518
#, no-c-format
msgid "Why does <acronym>RDP</acronym> support not work?"
msgstr "Miks <acronym>RDP</acronym> toetus ei toimi?"

#. Tag: para
#: index.docbook:521
#, no-c-format
msgid ""
"<acronym>RDP</acronym> support in &krdc; depends on xfreerdp (FreeRDP). Make "
"sure that you have installed this runtime dependency."
msgstr ""
"<acronym>RDP</acronym> toetus &krdc;-s sõltub programmist xfreerdp "
"(FreeRDP). Kontrolli, kas see on ikka paigaldatud."

