#: index.docbook:475
#, no-c-format
msgid "&krdc; preferences - <guilabel>VNC Defaults</guilabel> profiles tab"
msgstr "&krdc; seadistused - <guilabel>VNC vaikeväärtuste</guilabel> kaart"

