#. Tag: para
#: index.docbook:207
#, no-c-format
msgid ""
"The <guimenu>Game</guimenu> menu lets you control the status of the current "
"game:"
msgstr ""
"Menüü <guimenu>Mäng</guimenu> võimaldab valida mänguga seotud valikuid:"

#. Tag: menuchoice
#: index.docbook:214
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>N</keycap></keycombo></"
"shortcut> <guimenu>Game</guimenu><guimenuitem>New</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>N</keycap></keycombo></"
"shortcut> <guimenu>Mäng</guimenu> <guimenuitem>Uus</guimenuitem>"

#. Tag: para
#: index.docbook:219
#, no-c-format
msgid ""
"<action>Finishes the current game</action> and starts a new session with new "
"tiles."
msgstr ""
"<action>Lõpetab aktiivse mängu</action> ja käivitab uue seansi uue "
"kivivalikuga."

#. Tag: menuchoice
#: index.docbook:224
#, no-c-format
msgid ""
"<shortcut><keycombo><keycap>F5</keycap></keycombo></shortcut> <guimenu>Game</"
"guimenu><guimenuitem>Restart Game</guimenuitem>"
msgstr ""
"<shortcut><keycombo><keycap>F5</keycap></keycombo></shortcut> <guimenu>Mäng</"
"guimenu><guimenuitem>Käivita mäng uuesti</guimenuitem>"

#. Tag: action
#: index.docbook:229
#, no-c-format
msgid "Restarts the current game with the same tiles."
msgstr "Taaskäivitab mängu sama kivivalikuga."

#. Tag: menuchoice
#: index.docbook:234
#, no-c-format
msgid ""
"<shortcut><keycombo><keycap>P</keycap></keycombo></shortcut> <guimenu>Game</"
"guimenu><guimenuitem>Pause</guimenuitem>"
msgstr ""
"<shortcut><keycombo><keycap>P</keycap></keycombo></shortcut> <guimenu>Mäng</"
"guimenu><guimenuitem>Paus</guimenuitem>"

#. Tag: para
