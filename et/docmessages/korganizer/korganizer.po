msgstr "<link linkend=\"agenda-view\">Päevakavavaate</link> valikud:"

#. Tag: guilabel
#: index.docbook:2217
#, no-c-format
msgid "Hour size:"
msgstr "Tunni suurus"

#. Tag: para
#: index.docbook:2218
#, no-c-format
msgid ""
"By using this you can control the height of the rows in the Agenda view."
msgstr "Selle abil saab määrata ridade kõrguse päevakavavaates."

#. Tag: guilabel
#: index.docbook:2223
#, no-c-format
msgid "Show icons in agenda view items"
