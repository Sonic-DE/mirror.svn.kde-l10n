#. Tag: title
#: index.docbook:3546
#, no-c-format
msgid "Command Line"
msgstr "Käsurida"

#. Tag: para
#: index.docbook:3548
#, fuzzy, no-c-format
#| msgid ""
#| "A nice program to access a &kde; calendar from the command line is "
#| "konsolekalendar, which is included in the kdepim package together with "
#| "&korganizer;."
