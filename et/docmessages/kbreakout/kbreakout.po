#: index.docbook:117
#, no-c-format
msgid "Brick Types"
msgstr "Tellisetüübid"

#. Tag: para
#: index.docbook:119
#, no-c-format
msgid "Pictures for the bricks below are for the default theme of &kbreakout;."
msgstr ""
