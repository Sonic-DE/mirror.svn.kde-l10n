#. Tag: title
#: index.docbook:142
#, no-c-format
msgid "Using &kalzium;"
msgstr "&kalzium;i kasutamine"

#. Tag: title
#: index.docbook:144
#, no-c-format
msgid "Overview of &kalzium; usage"
msgstr "&kalzium;i kasutamise ülevaade"

#. Tag: para
#: index.docbook:145
#, no-c-format
msgid ""
"&kalzium; is very easy to use. It is specially designed for students of all "
"ages to use as a small and quick database."
msgstr ""
"&kalzium;i on väga lihtne kasutada. See on spetsiaalselt loodud igas vanuses "
"õppuritele väikeseks hõlpsasti ja kiiresti kasutatavaks andmebaasiks."

#. Tag: para
#: index.docbook:146
#, no-c-format
