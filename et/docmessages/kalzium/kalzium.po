#: index.docbook:509
#, no-c-format
msgid "Isotope Table"
msgstr "Isotoobitabel"

#. Tag: para
#: index.docbook:510
#, fuzzy, no-c-format
#| msgid ""
#| "The <guimenuitem>Isotope Table...</guimenuitem> shows you the isotopes of "
#| "the elements."
msgid ""
"The <guilabel>Isotope Table</guilabel> shows you the isotopes of the "
"elements."
msgstr ""
"<guimenuitem>Isotoobitabel...</guimenuitem> näitab elementide isotoope."

#. Tag: para
#: index.docbook:513
#, no-c-format
