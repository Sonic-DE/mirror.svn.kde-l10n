#. Tag: para
#: index.docbook:17
#, no-c-format
msgid ""
"The <emphasis>file</emphasis> protocol is used by all &kde; applications to "
"display locally available files."
msgstr ""
"Protokolli <emphasis>file</emphasis> kasutavad kõik &kde; rakendused "
"kättesaadavate kohalike failide näitamiseks."

#. Tag: para
#: index.docbook:21
#, no-c-format
msgid ""
"Entering <userinput><command>file:/directoryname</command></userinput> in "
"&konqueror; lists the files of this folder."
msgstr ""
"Kui anda &konqueror;is käsk <userinput><command>file:/katalooginimi</"
"command></userinput>, näidatakse kõiki antud kataloogi faile."
