#~ msgid "Member Groups"
#~ msgstr "Liikmete grupid"

#~ msgid ""
#~ "In the context menu for the image property editor there is an item for "
#~ "member groups, here you specify that the given item is a member of a "
#~ "given group. See <xref linkend=\"fig-membergroup-config\"/>."
#~ msgstr ""
#~ "Piltide omaduste redaktori kontekstimenüüs on kirje liikmete gruppide "
