#~ "This page shows a tree view of your browsing History. <mousebutton>Left</"
#~ "mousebutton> clicking on an item will open it in the main view, or you "
#~ "can open it in a new &konqueror; window by <mousebutton>right </"
#~ "mousebutton> clicking and selecting <guimenuitem>Open in New Window</"
#~ "guimenuitem> from the pop up menu."
#~ msgstr ""
