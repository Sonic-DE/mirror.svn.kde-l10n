#~ msgid "With the Sidebar"
#~ msgstr "Külgriba kasutamine"

#~ msgid ""
#~ "It contains a number of tabbed pages; <mousebutton>left</mousebutton> "
#~ "click on a tab's icon to view that page. <mousebutton>Left</mousebutton> "
#~ "clicking on the icon for the visible page will collapse the Sidebar so "
#~ "that only the tab icons are visible."
#~ msgstr ""
#~ "See sisaldab mitu eraldi kaarti, mille vaatamiseks klõpsa vastava "
