#~ msgid "Root Folder"
#~ msgstr "Juurkataloog"

#~ msgid ""
#~ "The <guilabel>Root Folder</guilabel> tree has the path <filename class="
#~ "\"directory\">/</filename>, and is the base folder of your system's local "
#~ "files. If you expand the <quote>Root</quote> folder you will find another "
#~ "folder called <filename class=\"directory\">root</filename>. This belongs "
