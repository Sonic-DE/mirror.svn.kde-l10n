#~ msgstr ""
#~ "Kui kopeerid mitut elementi, võib aktiivse elemendi <guibutton>vahele "
#~ "jätta</guibutton>."

#~ msgid ""
#~ "The <guibutton>Apply to All</guibutton> button can be used if you have "
