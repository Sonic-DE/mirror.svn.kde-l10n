#. Tag: guilabel
#: configure.docbook:4136
#, no-c-format
msgid "OutOfOfficeDomain"
msgstr "OutOfOfficeDomain"

#. Tag: para
#: configure.docbook:4138
#, fuzzy, no-c-format
#| msgid ""
#| "When editing vacation (out-of-office) scripts, the user can specify a "
#| "domain to limit the sending of such replies to. Applying defaults to the "
#| "out-of-office configuration dialog via the corresponding button will "
#| "restore this domain, in case the user has changed it. To pre-load this "
#| "setting with a default value, add to the <quote>[OutOfOffice]</quote> "
#| "section:"
msgid ""
"When editing vacation (out-of-office) scripts, the user may specify a domain "
"to limit the sending of such replies to. Applying defaults to the out-of-"
"office configuration dialog via the corresponding button will restore this "
"domain, in case the user has changed it. To pre-load this setting with a "
"default value, add to the <quote>[OutOfOffice]</quote> section:"
msgstr ""
"Puhkuseteadete skripte redigeerides võib kasutaja määrata domeeni, ainult "
"kuhu vastused saadetakse. Vaikeväärtuste rakendamine puhkuseteadete "
"seadistusdialoogis vastava nupu abil taastab selle domeeni, kui kasutaja on "
"seda muutnud. Selle laadimiseks eelnevalt määratud vaikeväärtusega lisa "
"sektsiooni <quote>[OutOfOffice]</quote> rida:"

#. Tag: programlisting
#: configure.docbook:4145
#, no-c-format
msgid "OutOfOfficeDomain=myMailDomain.test"
msgstr "OutOfOfficeDomain=minuKirjadeDomeen.test"

#. Tag: para
#: configure.docbook:4147
#, no-c-format
msgid ""
"<prompt>&percnt;</prompt> <userinput><command>kwriteconfig</command> "
"<option>--file <replaceable>/path/to/kmail2rc</replaceable> --group "
"OutOfOffice --key OutOfOfficeDomain myMailDomain.test</option></userinput>"
msgstr ""
"<prompt>&percnt;</prompt> <userinput><command>kwriteconfig</command> "
"<option>--file <replaceable>/kmail2rc/asukoht</replaceable> --group "
"OutOfOffice --key OutOfOfficeDomain minuKirjadeDomeen.test</option></"
"userinput>"

#. Tag: guilabel
#: configure.docbook:4155
#, no-c-format
msgid "OutOfOfficeReactToSpam"
msgstr "OutOfOfficeReactToSpam"

#. Tag: para
#: configure.docbook:4157
#, no-c-format
msgid ""
"By default, out-of-office replies are not sent to messages marked as SPAM. "
"To override this behavior, add to the [OutOfOffice] section:"
msgstr ""
"Vaikimisi ei saadeta puhkuseteateid kirjadele, mis on märgitud rämpspostiks. "
"Selle tühistamiseks lisa sektsiooni [OutOfOffice] rida:"

#. Tag: programlisting
#: configure.docbook:4162
#, no-c-format
msgid "OutOfOfficeReactToSpam=true"
msgstr "OutOfOfficeReactToSpam=true"

#. Tag: para
#: configure.docbook:4164
#, no-c-format
msgid ""
"<prompt>&percnt;</prompt> <userinput><command>kwriteconfig</command> "
"<option>--file <replaceable>/path/to/kmail2rc</replaceable> --group "
"OutOfOffice --key OutOfOfficeReactToSpam true</option></userinput>"
msgstr ""
"<prompt>&percnt;</prompt> <userinput><command>kwriteconfig</command> "
"<option>--file <replaceable>/kmail2rc/asukoht</replaceable> --group "
"OutOfOffice --key OutOfOfficeReactToSpam true</option></userinput>"

