"kirjad</guimenuitem></menuchoice>."

#. Tag: guilabel
#: configure.docbook:831
#, no-c-format
msgid "On Manual Mail Checks"
msgstr "Kirjade käsitsikontrollimisel"

#. Tag: para
#: configure.docbook:832
#, fuzzy, no-c-format
#| msgid ""
#| "Queued messages will be sent after you have manually checked for new "
#| "mail, &eg; with <menuchoice><guimenu>File</guimenu><guimenuitem>Check "
