#~ msgid ""
#~ "The most problematic part is the <emphasis>Outbox</emphasis>. First, "
#~ "locate <filename>specialmailcollectionsrc</filename> in your &kde; "
#~ "configuration directory (<filename>$HOME/.kde4/share/config</filename> or "
#~ "similar). It contains something like this:"
#~ msgstr ""
