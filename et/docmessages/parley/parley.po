#. Tag: title
#: index.docbook:891
#, no-c-format
msgid "Editing Words"
msgstr "Sõnade muutmine"

#. Tag: para
#: index.docbook:893
#, no-c-format
msgid ""
"If you want to replace a word, select its entry and start typing. To change "
