msgstr "Uue sõnavara lisamine"

#. Tag: para
#: index.docbook:887
#, fuzzy, no-c-format
#| msgid ""
#| "Use <guilabel>Add New Entry</guilabel> in the toolbar to add new words. "
#| "You can start typing the word in the first language right away. After "
