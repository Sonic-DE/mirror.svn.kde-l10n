#. Tag: para
#: index.docbook:40
#, no-c-format
msgid ""
"&ktorrent; is a bittorrent application by KDE which allows you to download "
"files using the BitTorrent protocol. It enables you to run multiple torrents "
"at the same time and comes with extended features to make it a full-featured "
"client for BitTorrent."
msgstr ""
"&ktorrent; on KDE BitTorrenti rakendus, mis võimaldab faili alla laadida "
"BitTorrenti protokolli kasutades. See lubab käivitada mitmeid torrente "
"korraga ning pakub ohtralt võimalusi, et olla täiemahuline BitTorrenti "
"klient."

#. Tag: title
#: index.docbook:43
#, no-c-format
msgid "Features"
msgstr "Võimalused"

#. Tag: para
#: index.docbook:44
#, no-c-format
msgid "Queuing of torrents"
msgstr "Torrentide seadmine järjekorda"

#. Tag: para
#: index.docbook:45
#, no-c-format
msgid "Global and per torrent speed limits"
msgstr "Üldised ja torrentipõhised kiirusepiirangud"

#. Tag: para
#: index.docbook:46
#, no-c-format
msgid "Previewing of certain file types, build in (video and audio)"
msgstr "Teatud failitüüpide sisseehitatud eelvaatlus (video ja heli)"

#. Tag: para
#: index.docbook:47
#, no-c-format
msgid "Importing of partially or fully downloaded files"
msgstr "Osaliselt või täielikult allalaaditud failide import"

#. Tag: para
#: index.docbook:48
#, no-c-format
msgid "File prioritization for multi-file torrents"
msgstr "Failide prioriteedi määramine mitmefaililiste torrentide korral"

#. Tag: para
#: index.docbook:49
#, no-c-format
msgid "Selective downloading for multi-file torrents"
msgstr "Valikuline allalaadimine mitmefaililiste torrentide korral"

#. Tag: para
#: index.docbook:50
#, no-c-format
msgid ""
"Kick/ban peers with an additional IP Filter dialog for list/edit purposes"
msgstr "Masinate keelamine ja pagendamine täiendava IP-filtri dialoogiga"

#. Tag: para
#: index.docbook:51
#, no-c-format
msgid "UDP tracker support"
msgstr "UDP tracker'i toetus"

#. Tag: para
#: index.docbook:52
#, no-c-format
msgid "Support for private trackers and torrents"
msgstr "Era-tracker'ite ja -torrentide toetus"

#. Tag: para
#: index.docbook:53
#, no-c-format
msgid "Support for µTorrent's peer exchange"
msgstr "µTorrent'i masinate suhtlemise toetus"

#. Tag: para
#: index.docbook:54
#, no-c-format
msgid "Support for protocol encryption (compatible with Azureus)"
msgstr "Protokolli krüptimise toetus (ühildub Azureusega)"

#. Tag: para
#: index.docbook:55
#, no-c-format
msgid "Support for creating trackerless torrents"
msgstr "Tracker'ivabade torrentide loomise toetus"

#. Tag: para
#: index.docbook:56
#, no-c-format
msgid "Support for distributed hash tables (DHT, the Mainline version)"
msgstr "Distributiivse räsitabeli (DHT, põhiversioon) toetus"

#. Tag: para
#: index.docbook:57
#, no-c-format
msgid ""
"Support for UPnP to automatically forward ports on a LAN with dynamic "
"assigned hosts"
msgstr ""
"UPnP toetus portide automaatseks edasisuunamiseks dünaamiliselt omistatavate "
"masinatega kohtvõrgus"

#. Tag: para
#: index.docbook:58
#, no-c-format
msgid "Support for webseeds"
msgstr "Veebilevituse toetus"

#. Tag: para
#: index.docbook:59
#, no-c-format
msgid "System tray integration"
msgstr "Lõimimine süsteemisalvega"

#. Tag: para
#: index.docbook:60
#, no-c-format
msgid "Tracker authentication support"
msgstr "Tracker'i autentimise toetus"

#. Tag: para
#: index.docbook:61
#, no-c-format
msgid "Connection though a proxy"
msgstr "Ühendus läbi puhverserveri"

#. Tag: para
#: index.docbook:62
#, fuzzy, no-c-format
