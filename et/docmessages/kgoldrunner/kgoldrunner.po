#: index.docbook:574
#, fuzzy, no-c-format
#| msgid "<screeninfo>The Level Selection dialog</screeninfo>"
msgid "<screeninfo>The Select Game dialog</screeninfo>"
msgstr "<screeninfo>Taseme valimise dialoog</screeninfo>"

