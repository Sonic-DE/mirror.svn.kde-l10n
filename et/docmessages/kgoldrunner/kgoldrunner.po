#. Tag: menuchoice
#: index.docbook:1027
#, no-c-format
msgid "<guimenu>Editor</guimenu><guimenuitem>Create Level</guimenuitem>"
msgstr "<guimenu>Redaktor</guimenu><guimenuitem>Loo tase</guimenuitem>"

#. Tag: para
#: index.docbook:1032
#, fuzzy, no-c-format
#| msgid ""
#| "Shows the Editor toolbar and a blank playing area on which you can draw a "
