#, fuzzy, no-c-format
#| msgid "<phrase>The Level Selection dialog</phrase>"
msgid "<phrase>The Select Game dialog</phrase>"
msgstr "<phrase>Taseme valimise dialoog</phrase>"

#. Tag: para
#: index.docbook:585
#, fuzzy, no-c-format
#| msgid ""
#| "This box appears when you select the <guimenuitem>New Game</guimenuitem> "
#| "action and also when you select items from the <guimenu>Editor</guimenu> "
#| "menu or replays from the <guimenu>Move</guimenu> menu. You use it to "
