"  - - - - - - - -       H * * * * O - - -          - - - * - - - -\n"
"  - - - - - - - -         - - - - O - - -          - - - O - - - -\n"
"H * * * O - - - -         - - - - - - - -          - - - - - - - -\n"
"  - - - - - - - -         - - - - - - - -          - - - - - - - -\n"
"  - - - - - - - -         - - - - - - - -          - - - - - - - -"
msgstr ""
"- - - - - - - -         - - - - - - - -          - - - - - - - -\n"
"  - - - - - - - -         - - - - - - - -          - - - - O - - -\n"
"  - - - - - - - -         - - - - O - - -        H * * * * - - - -\n"
"  - - - - - - - -       H * * * * O - - -          - - - * - - - -\n"
