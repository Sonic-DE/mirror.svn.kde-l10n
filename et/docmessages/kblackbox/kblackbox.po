#, no-c-format
msgid ""
"1\n"
"  - * - - - - - -         - - - - - - - -         - - - - - - - -       \n"
"  - * - - - - - -         - - - - - - - -         - - - - - - - -       \n"
"1 * * - - - - - -         - - - - - - - -         - O - - - - O -       \n"
"  - - O - - - - -         - - O - - - - -         - - * * * * - -\n"
