#. Tag: para
#: index.docbook:34
#, no-c-format
msgid ""
"&ktimer; is an application that lets you start an application after a "
"certain amount of time has passed."
msgstr ""
"&ktimer; on rakendus, mis võimaldab käivitada rakendusi pärast määratud aja "
"möödumist."

#. Tag: keyword
#: index.docbook:41
#, no-c-format
msgid "<keyword>KDE</keyword>"
msgstr "<keyword>KDE</keyword>"

#. Tag: keyword
