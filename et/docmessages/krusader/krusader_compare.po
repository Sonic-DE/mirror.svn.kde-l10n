#. Tag: title
#: compare.docbook:8
#, fuzzy, no-c-format
msgid "<title>Compare</title>"
msgstr "<title> Võrdle</title>"

#. Tag: para
#: compare.docbook:9
#, fuzzy, no-c-format
msgid ""
"&krusader; contains several compare functions: <guimenuitem>Compare by "
"Content</guimenuitem>, <guimenuitem>Compare Folders</guimenuitem> and the "
"<link linkend=\"synchronizer\">Synchronizer</link> compare function."
msgstr ""
"&krusader; sisaldab võrdlemine<guimenuitem> Võrdle x</"
"guimenuitem><guimenuitem> Võrdle</guimenuitem> ja<link linkend=\"synchronizer"
"\"></link> võrdlemine function."

#. Tag: title
#: compare.docbook:15
#, fuzzy, no-c-format
msgid "Compare by Content"
msgstr "Võrdle x Sisu"

#. Tag: primary
#: compare.docbook:17 compare.docbook:34
#, fuzzy, no-c-format
msgid "<primary>Compare</primary>"
msgstr "<primary> Võrdle</primary>"

#. Tag: secondary
#: compare.docbook:18
#, fuzzy, no-c-format
msgid "Content"
msgstr "Sisu"

#. Tag: para
#: compare.docbook:20
#, fuzzy, no-c-format
msgid ""
"Select one file in each panel and use <menuchoice> <guimenu>File</guimenu> "
"<guimenuitem>Compare by content...</guimenuitem> </menuchoice>. &krusader; "
"will open an external graphical difference tool that is <link linkend="
"\"konfig-dependencies\">configured</link>. &kompare;, <ulink url=\"https://"
"www.kde.org/applications/development/kdiff3/\"><application>KDiff3</"
"application></ulink> and <ulink url=\"http://furius.ca/xxdiff/"
"\"><application>xxdiff</application></ulink> are supported."
msgstr ""
"Vali üks fail asukohas paneel ja<emphasis role=\"bold"
"\"><menuchoice><guimenu> Fail</guimenu><guimenuitem> Võrdle x</guimenuitem></"
"menuchoice></emphasis>&krusader; open väline eristuv osa on<link linkend="
"\"konfig-dependencies\"></link>&kompare;<ulink url=\"http://kdiff3."
"sourceforge.net\"><application></application></ulink> ja<ulink url=\"http://"
"furius.ca/xxdiff/\"><application></application></ulink>."

#. Tag: title
#: compare.docbook:32
#, fuzzy, no-c-format
msgid "Compare Folders"
msgstr "Võrdle"

#. Tag: secondary
#: compare.docbook:35
#, no-c-format
msgid "Folders"
msgstr ""

#. Tag: para
#: compare.docbook:37
#, fuzzy, no-c-format
msgid ""
"Compare the files of each panel by using <menuchoice> <guimenu>Edit</"
"guimenu> <guimenuitem>Compare Folders</guimenuitem> </menuchoice>. By "
"default newer and single files will be selected in each panel, this "
"behaviour can be changed in the <guimenuitem>Compare Setup</guimenuitem> "
"menu."
msgstr ""
"Võrdle failid  /  paneel x kasutamine<emphasis role=\"bold"
"\"><menuchoice><guimenu> Muuda</guimenu><guimenuitem> Võrdle</guimenuitem></"
"menuchoice></emphasis> vaikimisi ja single failid asukohas paneel muudetud "
"asukohas<guimenuitem> Võrdle Setup</guimenuitem> menüü."

#. Tag: para
#: compare.docbook:46
#, fuzzy, no-c-format
msgid ""
"The files are not compared by content but by their names and dates only."
msgstr "failid mitte x x ja."

