#, no-c-format
msgid "Game Rules, Strategies and Tips"
msgstr "Mängureeglid, strateegia ja nõuanded"

#. Tag: title
#: index.docbook:79
#, no-c-format
msgid "Rules"
msgstr "Reeglid"

#. Tag: para
#: index.docbook:81
#, no-c-format
msgid "The rules are simple: just keep space for the blocks to fall!"
msgstr "Reeglid on imelihtsad: taga klotsidele piisav ruum langemiseks!"

#. Tag: para
#: index.docbook:82
#, no-c-format
msgid "When a new block cannot fall, the game is over."
msgstr "Kui klotsil pole kuhugi langeda, on mäng läbi."

#. Tag: title
#: index.docbook:87
#, no-c-format
msgid "Strategies and Tips"
msgstr "Strateegia ja nõuanded"

#. Tag: para
#: index.docbook:89
#, no-c-format
msgid ""
"Do not forget to check the preview area: it shows the next piece that will "
"be released."
msgstr "Jälgi alati eelvaatluse ala, kus näeb, milline klots järgmisena ilmub."

#. Tag: para
#: index.docbook:90
#, no-c-format
msgid "For additional points, try to remove several lines at once."
msgstr "Lisapunktide hankimiseks püüa eemaldada korraga mitu rida."

