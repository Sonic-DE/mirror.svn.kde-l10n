#~ msgid ""
#~ "Language locale setting to use. This option makes it possible to set "
#~ "another language environment for a program than what is the default. The "
#~ "correct language pack for this language has to be installed for this "
#~ "option to work. The default language when there is none set is en_US. "
#~ "When deciding upon a language, the following resources are looked up, in "
#~ "order: <envar>KDE_LANG</envar>, configuration file, <envar>LC_CTYPE</"
#~ "envar>, <envar>LC_MESSAGES</envar>, <envar>LC_ALL</envar>, <envar>LANG</"
#~ "envar>."
#~ msgstr ""
#~ "Kasutatava lokaadi määratlemine. Selle abil saab rakendusele määrata mõne "
#~ "muu kui vaikimisi keelekeskkonna. Selleks peab olema paigaldatud muidugi "
#~ "vastava keele tarkvarapakett. Kui midagi pole määratud, on vaikimisi "
#~ "keeleks en_US. Keele üle otsustades uuritakse järgmisi ressursse (just "
#~ "selles järjekorras): <envar>KDE_LANG</envar>, seadistusfail, "
#~ "<envar>LC_CTYPE</envar>, <envar>LC_MESSAGES</envar>, <envar>LC_ALL</"
#~ "envar>, <envar>LANG</envar>."

#~ msgid "$<envar>KDE_UTF8_FILENAMES</envar>"
#~ msgstr "$<envar>KDE_UTF8_FILENAMES</envar>"

#~ msgid ""
