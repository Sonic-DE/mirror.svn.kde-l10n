msgstr ""
"Ajaplaani muutmiseks vali see lihtsalt nimekirjast, tee sellele paremklõps "
"ja vali kontekstimenüüst <guimenuitem>Muuda</guimenuitem>. Ilmub uue "
"ajaplaani dialoogile sarnane dialoog, kus saad kõiki vajalikke andmeid muuta."

#. Tag: title
#: details-schedules.docbook:244
#, no-c-format
msgid "Deleting schedules"
msgstr "Ajaplaanide kustutamine"

#. Tag: para
#: details-schedules.docbook:245
#, fuzzy, no-c-format
#| msgid ""
#| "To delete a schedule simply select the entry in the list and right click "
#| "to bring up the context menu and select <guimenuitem>Delete</guimenuitem>."
