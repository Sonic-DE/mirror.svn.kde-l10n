#. Tag: title
#: index.docbook:317
#, no-c-format
msgid "Getting a new language"
msgstr "Uue keele hankimine"

#. Tag: para
#: index.docbook:318
#, fuzzy, no-c-format
#| msgid ""
#| "You might want to use &klettres; to help you learn a new language. By "
