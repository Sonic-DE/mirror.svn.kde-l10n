#. Tag: guilabel
#: index.docbook:228
#, no-c-format
msgid "<guilabel>Window type</guilabel>"
msgstr "<guilabel>Akna tüüp</guilabel>"

#. Tag: guilabel
#: index.docbook:229
#, no-c-format
msgid "Window title"
msgstr "Akna tiitel"

#. Tag: para
#: index.docbook:233
#, no-c-format
msgid ""
"Click the <guilabel>OK</guilabel> button to back-fill the <guilabel>Window "
