#. Tag: title
#: index.docbook:48
#, no-c-format
msgid "Wacom Tablet Settings"
msgstr "Wacomi graafikalaua seadistused"

#. Tag: para
#: index.docbook:49
#, fuzzy, no-c-format
#| msgid ""
#| "The tablet &systemsettings; module handles all setting for your graphic "
#| "tablet. All tablets supported by the <ulink url=\"http://linuxwacom."
#| "sourceforge.net\">&Linux; Wacom driver</ulink> project are handled by "
#| "this settings interface. Make sure your tablet is detected either via "
#| "xorg.conf or HAL and works in general. Refer to the <link linkend="
#| "\"detection\">tablet detection</link> section for more information."
msgid ""
"The tablet &systemsettings; module handles all setting for your graphic "
"tablet. All tablets supported by the <ulink url=\"https://linuxwacom.github."
"io\">&Linux; Wacom driver</ulink> project are handled by this settings "
"interface. Make sure your tablet is detected either via xorg.conf or udev "
"and works in general. Refer to the <link linkend=\"detection\">tablet "
"detection</link> section for more information."
msgstr ""
"Süsteemi seadistuste graafikalaua moodul puudutab kõiki graafikalaua "
"seadistusi. Selle abil saab seadistada kõiki graafikalaudu, mida toetab "
"<ulink url=\"http://linuxwacom.sourceforge.net\">&Linux; Wacomi draiveri</"
"ulink> projekt. Kontrolli, et sinu graafikalaud oleks tuvastatud kas failis "
"xorg.conf või HAL-i poolt ja üldiselt ikka töötaks. Täpsemalt kõneleb "
"sellest <link linkend=\"detection\">graafikalaua tuvastamist</link> käsitlev "
"osa."

#. Tag: para
#: index.docbook:55
#, fuzzy, no-c-format
#| msgid ""
#| "The <application>wacom-tools</application> or the <application>xf86-input-"
#| "wacom</application> driver must be installed on your computer and "
#| "<command>xsetwacom</command> must be available in order to make this "
#| "module work correctly."
msgid ""
"The <application>xf86-input-wacom</application> driver must be installed on "
"your computer and <command>xsetwacom</command> must be available in order to "
"make this module work correctly."
msgstr ""
"Arvutisse peab olema paigaldatud draiver <application>wacom-tools</"
"application> või <application>xf86-input-wacom</application> ning lisaks on "
"mooduli korrektseks tööks vajalik, et saadaval oleks ka <command>xsetwacom</"
"command>."

#. Tag: para
#: index.docbook:59
#, fuzzy, no-c-format
#| msgid ""
#| "The module is split into various tab pages that handle all aspects of "
#| "your tablet and the pen: <link linkend=\"tablet-profiles\">Profiles</"
#| "link>, <link linkend=\"tablet-general\">General Information</link>, <link "
#| "linkend=\"pad-buttons\">Pad Buttons</link>, <link linkend=\"pad-mapping"
