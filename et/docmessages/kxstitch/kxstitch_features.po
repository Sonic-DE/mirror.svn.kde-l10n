#. Tag: title
#: features.docbook:2
#, no-c-format
msgid "Features"
msgstr "Omadused"

#. Tag: para
#: features.docbook:3
#, no-c-format
msgid "The current feature list and other planned features is shown here."
msgstr ""
"Siin näeb rakenduse praeguste ja mõningate plaanitavate omaduste loetelu."

#. Tag: para
#: features.docbook:5
#, no-c-format
msgid "Creation of new patterns"
msgstr "Uute mustrite loomine"

#. Tag: para
#: features.docbook:7
#, no-c-format
msgid "User defined size"
msgstr "Kasutaja määratud suurus"

#. Tag: para
#: features.docbook:8
#, no-c-format
msgid "Selection of material color"
msgstr "Materjali värvi valik"

#. Tag: para
#: features.docbook:9
#, no-c-format
msgid "Insertion of a background images for tracing"
msgstr "Taustapildi lisamine viiteks"

#. Tag: para
#: features.docbook:10
#, no-c-format
msgid "Importing of various image formats"
msgstr "Mitmesuguste pildivormingute import"

#. Tag: para
#: features.docbook:11
#, no-c-format
msgid "Importing options allow"
msgstr "Importimisvalikud võimaldavad"

#. Tag: para
#: features.docbook:13
#, no-c-format
msgid "Limiting the number of colors"
msgstr "piirata värvide arvu"

#. Tag: para
#: features.docbook:14
#, no-c-format
msgid "Limiting colors to a specific palette"
msgstr "piirata värve konkreetse paletiga"

#. Tag: para
#: features.docbook:15
#, no-c-format
msgid "Scaling to a finished size"
msgstr "skaleerida lõplikule suurusele"

#. Tag: para
#: features.docbook:16
#, no-c-format
msgid "Support for transparency in images"
msgstr "läbipaistvuse kasutamist piltides"

#. Tag: para
#: features.docbook:17
#, no-c-format
msgid "Allow the use of fractional stitches"
msgstr "osaliste ristpistete kasutamist"

#. Tag: para
#: features.docbook:22
#, no-c-format
msgid "Editing of existing patterns, Editing tools will include"
msgstr ""
"Olemasolevate mustrite muutmine. Muutmistööriistade seas leiab järgmisi:"

#. Tag: para
#: features.docbook:24
#, no-c-format
msgid "Open and filled rectangles"
msgstr "Täitmata ja täidetud ristkülikud"

#. Tag: para
#: features.docbook:25
#, no-c-format
msgid "Open and filled ellipses"
msgstr "Täitmata ja täidetud ellipsid"

#. Tag: para
#: features.docbook:26
#, no-c-format
msgid "Filled polygons"
msgstr "Täidetud hulknurgad"

#. Tag: para
#: features.docbook:27
#, no-c-format
msgid "Painting"
msgstr "Joonistamine"

#. Tag: para
#: features.docbook:28
#, no-c-format
msgid "Lines"
msgstr "Jooned"

#. Tag: para
#: features.docbook:29
#, no-c-format
msgid "Erasing stitches, knots and backstitches"
msgstr "Rist-, sõlm- ja tikkpistete kustutamine"

#. Tag: para
#: features.docbook:30
#, no-c-format
msgid "Color selection from existing stitches"
msgstr "Värvi valimine olemasolevalt pistelt"

#. Tag: para
#: features.docbook:31
#, no-c-format
msgid "Swapping two colors"
msgstr "Kahe värvi vahetamine"

#. Tag: para
#: features.docbook:32
#, no-c-format
msgid "Replace one color with another"
msgstr "Ühe värvi asendamine teisega"

#. Tag: para
#: features.docbook:33
#, no-c-format
msgid "Text with user defined fonts and sizes"
msgstr "Tekst kasutaja määratud fondi ja suurusega"

#. Tag: para
#: features.docbook:34
#, no-c-format
msgid "Cut, copy and paste of rectangular areas."
msgstr "Ristkülikukujuliste alade lõikamine, kopeerimine ja asetamine"

#. Tag: para
#: features.docbook:35
#, no-c-format
msgid "Unlimited undo and redo"
msgstr "Piiramata tagasivõtmine ja uuestitegemine"

#. Tag: para
#: features.docbook:36
#, no-c-format
msgid "Mirroring, horizontally and vertically."
msgstr "Peegeldamine rõht- ja püstsuunas"

#. Tag: para
#: features.docbook:37
#, no-c-format
msgid "Rotation, 90, 180 and 270 degrees anti clockwise."
msgstr "Pööramine 90, 180 ja 270 kraadi vastupäeva"

#. Tag: para
#: features.docbook:38
#, no-c-format
msgid "Resizing of the canvas"
msgstr "Kanvaa suuruse muutmine"

#. Tag: para
#: features.docbook:40
#, no-c-format
msgid "Extend canvas left, top, right, bottom"
msgstr "kanvaa laiendamine vasakule, üles, paremale, alla"

#. Tag: para
#: features.docbook:41
#, no-c-format
msgid "Cropping canvas to pattern"
msgstr "kanvaa kärpimine mustri suurusele"

#. Tag: para
#: features.docbook:42
#, no-c-format
msgid "Cropping canvas to selection"
msgstr "kanvaa kärpimine valiku suurusele"

#. Tag: para
#: features.docbook:43
#, no-c-format
msgid "Inserting rows and columns"
msgstr "ridade ja veergude lisamine"

#. Tag: para
#: features.docbook:44
#, no-c-format
msgid "Center the pattern on the canvas"
msgstr "mustri tsentreerimine kanvaal"

#. Tag: para
#: features.docbook:47
#, no-c-format
msgid "Conversion between floss schemes"
msgstr "Lõngatüüpide teisendamine"

#. Tag: para
#: features.docbook:50
#, no-c-format
msgid "Use of standard floss pallets, DMC, Anchor, etc."
msgstr "Standardsete lõngapalettide (DMC, Anchor jt.) kasutamine"

#. Tag: para
#: features.docbook:51
#, no-c-format
msgid "Create customized floss pallets"
msgstr "Kohandatud lõngapalettide loomine"

#. Tag: para
#: features.docbook:52
#, no-c-format
msgid "Create new colors for any floss pallet"
msgstr "Uute värvide loomine kõigis lõngapalettides"

#. Tag: para
#: features.docbook:53
#, no-c-format
msgid "Save / Load current palette"
msgstr "Aktiivse paleti salvestamine ja laadimine"

#. Tag: para
#: features.docbook:54
#, no-c-format
msgid "Use of standard stitches"
msgstr "Standardsete pistete kasutamine"

#. Tag: para
#: features.docbook:55
#, no-c-format
msgid "Pattern library manager"
msgstr "Mustrikogu haldur"

#. Tag: para
#: features.docbook:57
#, no-c-format
msgid "Create new library patterns"
msgstr "Kogudes uute mustrite loomine"

#. Tag: para
#: features.docbook:58
#, no-c-format
msgid "Insert library patterns into a design"
msgstr "Kogu mustrite lisamine aktiivsesse mustrisse"

#. Tag: para
#: features.docbook:59
#, no-c-format
msgid "Drag and drop from the library to the pattern"
msgstr "Lohistamine kogust mustrisse"

#. Tag: para
#: features.docbook:60
#, no-c-format
msgid "Drag and drop from one library to another"
msgstr "Lohistamine ühest kogust teise"

#. Tag: para
#: features.docbook:61
#, no-c-format
msgid "Assign key press to patterns for use with the Alphabet tool"
msgstr "Klahvivajutuste seostamine mustriga alfabeeditööriista tarbeks"

#. Tag: para
#: features.docbook:64
#, no-c-format
msgid "Free use of backstitching"
msgstr "Tikkpistete vaba kasutamine"

#. Tag: para
#: features.docbook:65
#, no-c-format
msgid "Printing of completed patterns and floss keys"
msgstr "Valmis mustrite ja legendide trükkimine"

#. Tag: para
#: features.docbook:67
#, no-c-format
msgid "Pattern image"
msgstr "Mustri pilt"

#. Tag: para
#: features.docbook:68
#, no-c-format
msgid "Instructions"
msgstr "Juhised"

#. Tag: para
#: features.docbook:69
#, no-c-format
msgid "Floss key and stitch summary"
msgstr "Legend (teave lõnga ja kõige muu kohta)"

#. Tag: para
#: features.docbook:70
#, no-c-format
msgid "Pattern chart with page map"
msgstr "Mustrileht"

#. Tag: para
#: features.docbook:71
#, no-c-format
msgid "Text boxes"
msgstr "Tekstikastid"

#. Tag: para
#: features.docbook:74
#, no-c-format
msgid "Mapping of symbols to flosses"
msgstr "Lõngade seostamine sümbolitega"

#. Tag: para
#: features.docbook:75
#, no-c-format
msgid "Specify the number of threads for stitches and backstitches"
msgstr "Rist- ja tikkpistete lõnga niitide arvu määramine"

#. Tag: para
#: features.docbook:76
#, no-c-format
msgid "Calibration of floss colors"
msgstr "Lõnga värvide kalibreerimine"

#. Tag: para
#: features.docbook:78
#, no-c-format
msgid ""
"Requests for new features can be made to the <ulink url=\"http://bugs.kde.org"
"\">KDE Bugtracking System</ulink>"
msgstr ""
"Uusi omadusi saab taotleda <ulink url=\"http://bugs.kde.org\">KDE veateadete "
"jälgimise süsteemis</ulink>."

