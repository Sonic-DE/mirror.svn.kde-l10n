msgstr "Liigub aktiivse dokumentatsiooni eelmisele leheküljele."

#. Tag: menuchoice
#: index.docbook:738
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>PgDown</keycap></"
"keycombo></shortcut> <guimenu>Go</guimenu> <guimenuitem>Next Page</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>PgDown</keycap></"
"keycombo></shortcut> <guimenu>Liikumine</guimenu> <guimenuitem>Järgmine "
"lehekülg</guimenuitem>"

#. Tag: para
#: index.docbook:743
#, no-c-format
msgid "Go to the next page of the current documentation."
msgstr "Liigub aktiivse dokumentatsiooni järgmisele leheküljele."

#. Tag: menuchoice
#: index.docbook:750
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt;<keysym>Left</keysym></keycombo></"
"shortcut> <guimenu>Go</guimenu> <guimenuitem>Back</guimenuitem>"
