#~ msgid ""
#~ "Boolean syntax lets you use the operators <literal>AND</literal>, "
#~ "<literal>OR</literal> and <literal>NOT</literal> to create complex "
#~ "searches. Some examples:"
#~ msgstr ""
#~ "Boolean ehk tõeväärtustehteid kasutav süntaks võimaldab keerulisemateks "
#~ "otsinguteks kasutada tõeväärtusi <literal>AND</literal>, <literal>OR</"
#~ "literal> ja <literal>NOT</literal>. Mõned näited:"

#~ msgid "cat and dog"
#~ msgstr "kass AND koer"

#~ msgid ""
#~ "Searches for pages which have both the words <userinput>cat</userinput> "
#~ "and <userinput>dog</userinput> in them. Pages with only one or the other "
#~ "will not be returned."
#~ msgstr ""
#~ "Otsitakse lehekülgi, kus esineb nii sõna <userinput>kass</userinput> kui "
#~ "ka <userinput>koer</userinput>. Lehekülgi, kus esineb ainult üks neist, "
#~ "ei näidata."

#~ msgid "cat not dog"
#~ msgstr "kass NOT koer"

#~ msgid ""
#~ "Searches for pages with <userinput>cat</userinput> in them, but only "
#~ "returns the ones that don't have the word <userinput>dog</userinput> in "
#~ "them."
#~ msgstr ""
#~ "Otsitakse lehekülgi, kus esineb <userinput>kass</userinput>, aga "
#~ "näidatakse ainult neid, kus ei esine sõna <userinput>koer</userinput>."

#~ msgid "cat or (dog not nose)"
#~ msgstr "kass OR (koer NOT nina)"

#~ msgid ""
#~ "Searches for pages which contain <userinput>cat</userinput>, and for "
#~ "pages which contain <userinput>dog</userinput> but don't contain "
#~ "<userinput>nose</userinput>. Pages which contain both <userinput>cat</"
#~ "userinput> and <userinput>nose</userinput> would be returned, pages "
#~ "containing all three words would not."
#~ msgstr ""
#~ "Otsitakse lehekülgi, mis sisaldavad sõna <userinput>kass</userinput>, ja "
#~ "lehekülgi, mis sisaldavad sõna <userinput>koer</userinput>, aga ei "
#~ "sisalda sõna <userinput>nina</userinput>. Näidatakse lehekülgi, kus "
#~ "esineb nii <userinput>kass</userinput> kui ka <userinput>nina</"
#~ "userinput>, aga mitte lehekülgi, kus esinevad kõik kolm sõna."

