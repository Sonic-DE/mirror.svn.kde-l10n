#~ "trükkimine</glossseealso> <glossseealso otherterm=\"gloss-cups\">&CUPS;</"
#~ "glossseealso> <glossseealso otherterm=\"gloss-kprinter\">kprinter</"
#~ "glossseealso> <glossseealso otherterm=\"gloss-kdeprinthandbook"
