#| "the local environment. This includes &eg; the currency used for monetary "
#| "values or the time format and translating text.&newpara; More info:"
#| "&newpara; &linkstart;\"http://l10n.kde.org\"&linkmid;l10n.kde.org&linkend;"
msgid ""
