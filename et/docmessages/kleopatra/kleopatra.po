#: index.docbook:2451
#, no-c-format
msgid "ldap server"
msgstr "ldap server"

#. Tag: literal
#: index.docbook:2456
#, no-c-format
msgid "key fingerprint"
msgstr "key fingerprint"

#. Tag: literal
#: index.docbook:2460
#, no-c-format
msgid "pub key"
msgstr "pub key"

#. Tag: literal
#: index.docbook:2463
#, no-c-format
msgid "sec key"
msgstr "sec key"

#. Tag: literal
