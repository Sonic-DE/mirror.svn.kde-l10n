#. Tag: para
#: index.docbook:767
#, no-c-format
msgid "Then, to start &kontact; with a module active, type:"
msgstr "&kontact;i käivitamiseks aktiivse mooduliga tuleb anda käsk:"

#. Tag: para
#: index.docbook:769
#, no-c-format
msgid ""
"<prompt>&percnt;</prompt> <command>kontact --module <replaceable>moduleName</"
