#. Tag: title
#: index.docbook:87
#, no-c-format
msgid "Starting &minuet;"
msgstr "&minuet;i käivitamine"

#. Tag: para
#: index.docbook:89
#, fuzzy, no-c-format
#| msgid ""
#| "You can start &minuet; from the application launcher. Open the &kde; "
#| "program menu by clicking on the application launcher icon on the toolbar "
#| "at the bottom left of your screen. This will raise a menu. Move your "
#| "cursor up the menu to the <menuchoice><guimenu>Applications</"
#| "guimenu><guisubmenu>Education</guisubmenu><guisubmenu>Miscellaneous</"
