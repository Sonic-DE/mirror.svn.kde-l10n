#: index.docbook:1250
#, no-c-format
msgid "Step into (gdb's <quote>step</quote>)"
msgstr ""

#. Tag: keycap
#: index.docbook:1253
#, no-c-format
msgid "<keycap>F12</keycap>"
msgstr ""

