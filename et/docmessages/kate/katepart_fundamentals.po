#~ "(&kde; 3 mode)</guilabel> in the next section is checked."
#~ msgstr ""
#~ "Neid valikuid näeb ainult siis, kui järgmises sektsioonis on märgitud "
#~ "valik <guilabel>Kogenud kasutaja režiimi (&kde; 3 režiimi) lubamine</"
#~ "guilabel>."

#~ msgid "By creation"
#~ msgstr "Loomisaja järgi"

