msgid ""
"<userinput>dsVariable</userinput>, if applicable: variable names (&eg; "
"$someVar in PHP/Perl)."
msgstr ""
"<userinput>dsVariable</userinput>, kui võimalik: muutuja nimed (nt. $someVar "
