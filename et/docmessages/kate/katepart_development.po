"&lt;DetectChar char=&quot;(character)&quot; (common attributes) (dynamic) /"
"&gt;"
msgstr "&lt;DetectChar char=&quot;(märk)&quot; (üldatribuudid) (dynamic) /&gt;"

#. Tag: para
#: development.docbook:844
#, no-c-format
msgid ""
"The <userinput>char</userinput> attribute defines the character to match."
msgstr "Atribuut <userinput>char</userinput> määrab otsitava märgi."

#. Tag: term
#: development.docbook:850
#, no-c-format
msgid "Detect2Chars"
msgstr "Detect2Chars"

#. Tag: para
#: development.docbook:852
#, no-c-format
