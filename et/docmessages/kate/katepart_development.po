msgstr ""
"<userinput>dsExtension</userinput>, üldised laiendused, näiteks Qt klassid "
"ning C++ ja Pythoni funktsioonid/makrod."

#. Tag: para
#: development.docbook:588
#, no-c-format
msgid ""
"<userinput>dsPreprocessor</userinput>, preprocessor statements or macro "
"definitions."
msgstr ""
"<userinput>dsPreprocessor</userinput>, preprotsessori laused või makro "
"definitsioonid."

#. Tag: para
#: development.docbook:589
#, no-c-format
msgid ""
"<userinput>dsAttribute</userinput>, annotations such as @override and "
"__declspec(...)."
msgstr ""
"<userinput>dsAttribute</userinput>, annotatsioonid, näiteks @override ja "
