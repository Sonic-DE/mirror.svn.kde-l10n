msgstr ""
"Vali aktiivse dokumendi kodeering. See tühistab aktiivse dokumendi jaoks "
"vaikekodeeringu, mis on kindlaks määratud dialoogi <menuchoice> "
"<guimenu>Seadistused</guimenu> <guimenuitem>Redaktori seadistamine...</"
"guimenuitem></menuchoice> kaardil <guilabel>Avamine/Salvestamine</guilabel>."

#. Tag: menuchoice
#: menus.docbook:1505
#, no-c-format
msgid "<guimenu>Tools</guimenu> <guisubmenu>End of Line</guisubmenu>"
msgstr "<guimenu>Tööriistad</guimenu> <guisubmenu>Rea lõpp</guisubmenu>"

#. Tag: para
#: menus.docbook:1510
#, no-c-format
msgid ""
"Choose your preferred end of line mode for your active document. This "
"overwrites the global end of line mode set in <menuchoice> "
"<guimenu>Settings</guimenu><guimenuitem>Configure Editor...</guimenuitem> </"
"menuchoice> for your current document only."
msgstr ""
