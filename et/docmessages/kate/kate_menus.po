"seadistamine...</guimenuitem></menuchoice>"

#. Tag: menuchoice
#: menus.docbook:1477
#, no-c-format
msgid "<guimenu>Tools</guimenu> <guisubmenu>Indentation</guisubmenu>"
msgstr "<guimenu>Tööriistad</guimenu> <guisubmenu>Treppimine</guisubmenu>"

#. Tag: para
#: menus.docbook:1482
#, no-c-format
msgid ""
"Choose the <ulink url=\"help:/katepart/kate-part-autoindent.html\">style of "
