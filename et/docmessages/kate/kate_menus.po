msgstr "<guimenu>Seansid</guimenu> <guimenuitem>Uus</guimenuitem>"

#. Tag: para
#: menus.docbook:1376
#, no-c-format
msgid "Creates a new empty session. All currently open files will be closed."
msgstr "Loob uue tühja seansi. Kõik parajasti avatud failid suletakse."

#. Tag: menuchoice
#: menus.docbook:1382
#, no-c-format
msgid "<guimenu>Sessions</guimenu> <guimenuitem>Open Session...</guimenuitem>"
msgstr "<guimenu>Seansid</guimenu> <guimenuitem>Ava seanss...</guimenuitem>"

#. Tag: para
#: menus.docbook:1386
#, no-c-format
msgid ""
"Open an existing session. The Session Chooser dialog is displayed to let you "
"choose one."
msgstr "Avab olemasoleva seansi. Seda aitab teha seansivalija."

#. Tag: menuchoice
#: menus.docbook:1391
#, no-c-format
msgid "<guimenu>Sessions</guimenu> <guisubmenu>Quick Open Session</guisubmenu>"
msgstr "<guimenu>Seansid</guimenu><guisubmenu>Ava kiirseanss</guisubmenu>"

#. Tag: para
#: menus.docbook:1395
#, no-c-format
msgid "This submenu lets you open an existing session."
msgstr "Sellest alammenüüst saab avada olemasoleva seansi."

#. Tag: menuchoice
#: menus.docbook:1400
#, no-c-format
msgid "<guimenu>Sessions</guimenu> <guimenuitem>Save Session</guimenuitem>"
msgstr "<guimenu>Seansid</guimenu> <guimenuitem>Salvesta seanss</guimenuitem>"

#. Tag: para
#: menus.docbook:1404
#, no-c-format
msgid ""
"Save the current session. If the session is anonymous, you will be prompted "
"for a session name."
msgstr ""
"Salvestab aktiivse seansi. Kui see on anonüümne, palutakse sul sellele nimi "
"anda."

#. Tag: menuchoice
#: menus.docbook:1409
#, no-c-format
msgid ""
"<guimenu>Sessions</guimenu> <guimenuitem>Save Session As...</guimenuitem>"
