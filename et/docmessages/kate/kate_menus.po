"treppimise, mis on kindlaks määratud dialoogis <menuchoice> "
"<guimenu>Seadistused</guimenu> <guimenuitem>Redaktori seadistamine...</"
"guimenuitem></menuchoice>"

#. Tag: menuchoice
#: menus.docbook:1491
#, no-c-format
msgid "<guimenu>Tools</guimenu> <guisubmenu>Encoding</guisubmenu>"
msgstr "<guimenu>Tööriistad</guimenu> <guisubmenu>Kodeering</guisubmenu>"

