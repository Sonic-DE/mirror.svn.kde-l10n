#~ "document.canComment( <parameter>uint algus_atribuut</parameter>, "
#~ "<parameter>uint lõpp_atribuut</parameter> ); [function]"

#~ msgid ""
#~ "<parameter>start_attribute</parameter> The attribute at the start of the "
