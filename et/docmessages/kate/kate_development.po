#~ msgid "The Document API"
#~ msgstr "Dokumendi API"

#~ msgid ""
#~ "Whenever a script is being executed, there is a global variable "
#~ "<quote><literal>document</literal></quote> representing the current "
#~ "active document. The following is a list of all available Document "
#~ "functions."
#~ msgstr ""
#~ "Skripti käivitamisel on alati olemas globaalne muutuja "
#~ "<quote><literal>document</literal></quote>, mis tähistab aktiivset "
#~ "dokumenti. Järgnevalt on loetletud saadaolevad dokumendifunktsioonid."

#~ msgid "String document.fileName();"
#~ msgstr "String document.fileName();"

#~ msgid ""
#~ "Returns the document's filename or an empty string for unsaved text "
#~ "buffers."
#~ msgstr ""
#~ "Tagastab dokumendi failinime või tühja stringi salvestamata tekstipuhvri "
#~ "korral."

#~ msgid "String document.url();"
#~ msgstr "String document.url();"

#~ msgid ""
#~ "Returns the document's full url or an empty string for unsaved text "
#~ "buffers."
#~ msgstr ""
#~ "Tagastab dokumendi täieliku URL-i või tühja stringi salvestamata "
#~ "tekstipuhvri korral."

#~ msgid "String document.mimeType();"
#~ msgstr "String document.mimeType();"

#~ msgid ""
#~ "Returns the document's mime type or the mime type <literal>application/"
#~ "octet-stream</literal> if no appropriate mime type could be found."
#~ msgstr ""
#~ "Tagastab dokumendi MIME tüübi või MIME tüübi <literal>application/octet-"
#~ "stream</literal>, kui sobivat MIME tüüpi ei leita."

#~ msgid "String document.encoding();"
#~ msgstr "String document.encoding();"

#~ msgid "Returns the currently used encoding to save the file."
#~ msgstr "Tagastab faili salvestamisel kasutatava kodeeringu."

#~ msgid "String document.highlightingMode();"
#~ msgstr "String document.highlightingMode();"

#~ msgid "Returns the global highlighting mode used for the whole document."
#~ msgstr ""
#~ "Tagastab kogu dokumendis kasutatava globaalse esiletõstmise režiimi."

#~ msgid ""
#~ "String document.highlightingModeAt(<parameter>Cursor <replaceable>pos</"
#~ "replaceable></parameter>);"
#~ msgstr ""
#~ "String document.highlightingModeAt(<parameter>Cursor "
#~ "<replaceable>asukoht</replaceable></parameter>);"

#~ msgid ""
#~ "Returns the highlighting mode used at the given position in the document."
#~ msgstr ""
#~ "Tagastab dokumendi määratud asukohas kasutatava esiletõstmise režiimi."

#~ msgid "Array document.embeddedHighlightingModes();"
#~ msgstr "Array document.embeddedHighlightingModes();"

#~ msgid "Returns an array of highlighting modes embedded in this document."
#~ msgstr "Tagastab dokumenti põimitud esiletõstmise režiimide massiivi."

#~ msgid "bool document.isModified();"
#~ msgstr "bool document.isModified();"

#~ msgid ""
#~ "Returns <literal>true</literal>, if the document has unsaved changes "
#~ "(modified), otherwise <literal>false</literal>."
#~ msgstr ""
#~ "Tagastab <literal>true</literal>, kui dokument sisaldab salvestamata "
#~ "muudatusi, vastasel juhul <literal>false</literal>."

