#~ "<quote><filename>myutils</filename></quote>. Arvude abil kontrollib "
#~ "&kappname; API täitmise järjekorda. Nii kutsutakse fail "
#~ "<filename>05_cursor.js</filename> välja enne faili <filename>10_range.js</"
#~ "filename>. (Samasugune käivitamise järjekord kehtib näiteks Linuxis "
#~ "käitustasemete puhul.)"

