#~ "arg>"
#~ msgstr ""
#~ "<command>set-line-numbers</command><arg choice=\"req\">TÕEVÄÄRTUS enable</"
#~ "arg>"

#~ msgid "Sets the visibility of the line numbers pane."
#~ msgstr "Reanumbrite paneeli näitamine."

#~ msgid ""
#~ "<command>set-replace-tabs</command><arg choice=\"req\">BOOLEAN enable</"
#~ "arg>"
#~ msgstr ""
#~ "<command>set-replace-tabs</command><arg choice=\"req\">TÕEVÄÄRTUS enable</"
