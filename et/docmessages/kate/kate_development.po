#~ "String document.charAt(<parameter>Cursor <replaceable>cursor</"
#~ "replaceable></parameter>);"
#~ msgstr ""
#~ "String document.charAt(<parameter>int <replaceable>rida</replaceable></"
#~ "parameter>, <parameter>int <replaceable>veerg</replaceable></"
