#~ msgstr "Tavaline tekst"

#~ msgid ""
#~ "This is the default background for the editor area, it will be the "
#~ "dominant color on the editor area."
#~ msgstr ""
#~ "See on redaktoriala vaikimisi taust ja ühtlasi redaktoriala domineeriv "
#~ "värv."

#~ msgid "Selected text"
