#: advanced.docbook:349
#, no-c-format
msgid "<userinput>p</userinput>"
msgstr "<userinput>p</userinput>"

#. Tag: para
#: advanced.docbook:350
#, no-c-format
msgid "Prompt for permission to replace the next occurrence."
msgstr "Loa küsimine järgmise asenduse korral."

