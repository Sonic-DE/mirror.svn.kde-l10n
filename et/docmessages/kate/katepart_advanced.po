#, no-c-format
msgid "<userinput>e</userinput>"
msgstr "<userinput>e</userinput>"

#. Tag: para
#: advanced.docbook:333 advanced.docbook:726
#, no-c-format
msgid "Search in the selection only."
msgstr "Otsing ainult valikus."

