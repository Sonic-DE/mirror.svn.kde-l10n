#, no-c-format
msgid ""
"<userinput>Current Project</userinput> - Show files from current project only"
msgstr ""

#. Tag: para
#: fundamentals.docbook:567
#, no-c-format
msgid "<userinput>All Projects</userinput> - Show files from all open projects"
msgstr ""

#. Tag: para
#: fundamentals.docbook:568
#, no-c-format
msgid ""
"<userinput>Fuzzy Filtering</userinput> - Use fuzzy matching algorithm to "
"filter files"
