msgstr "Kaks arvu, mida seob loogiline VÕI"

#. Tag: guibutton
#: index.docbook:384
#, no-c-format
msgid "<guibutton>XOR</guibutton>"
msgstr "<guibutton>XOR</guibutton>"

#. Tag: entry
#: index.docbook:385
#, no-c-format
msgid "Two numbers are logically exclusive ored"
msgstr "Kaks arvu, mida seob loogiline välistav VÕI"

#. Tag: guibutton
#: index.docbook:387 index.docbook:566
#, no-c-format
msgid "<guibutton>Lsh</guibutton>"
msgstr "<guibutton>Lsh</guibutton>"

#. Tag: entry
#: index.docbook:388
#, no-c-format
