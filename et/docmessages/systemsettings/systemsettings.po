#~ msgid "Advanced User Settings"
#~ msgstr "Muud kasutaja seadistused"

#~ msgid ""
#~ "This section covers the settings related to the more advanced system "
#~ "settings for the user. Settings include digital cameras, file "
#~ "associations, input actions, resources, services, sessions, and hardware "
#~ "management."
#~ msgstr ""
#~ "See hõlmab kasutajaga seotud põhjalikumaid süsteemi seadistusi: "
#~ "digikaamerad, failiseosed, sisestustoimingud, ressursid, teenused, "
#~ "seansid, riistvara."

#~ msgid ""
