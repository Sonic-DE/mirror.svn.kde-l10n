msgstr "Valik: <option>-b</option>/<option>--backups</option>"

#. Tag: para
#: index.docbook:3544
#, fuzzy, no-c-format
#| msgid ""
#| "This option causes <ulink url=\"man:/rsync"
#| "\"><citerefentry><refentrytitle>rsync</refentrytitle><manvolnum>1</"
#| "manvolnum></citerefentry></ulink> to set the group of the destination "
#| "file to be the same as the on of the source file. If the receiving "
