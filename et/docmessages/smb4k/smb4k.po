msgstr ""

#. Tag: guibutton
#: index.docbook:3530
#, no-c-format
msgid "Preserve permissions"
msgstr "Õiguste säilitamine"

#. Tag: para
#: index.docbook:3533
#, no-c-format
msgid "Option: <option>-p</option>/<option>--perms</option>"
msgstr "Valik: <option>-p</option>/<option>--perms</option>"

#. Tag: para
#: index.docbook:3534
#, no-c-format
msgid ""
"This option causes the receiving side to set the destination permissions to "
"be the same as the source permissions."
msgstr ""
"See sunnib vastuvõtvat poolt määrama sihtkohale samasugused õigused, nagu on "
"lähtekohas."

