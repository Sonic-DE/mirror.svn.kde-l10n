#. (itstool) path: component/name
#: org.kde.kio_zeroconf.metainfo.xml:9
msgid "Zeroconf Support"
msgstr "Zeroconfi toetus"

#. (itstool) path: component/summary
#: org.kde.kio_zeroconf.metainfo.xml:10
msgid "Browse local network services in Dolphin's Network page"
msgstr "Kohalike võrguteenuste sirvimine Dolphini võrgulehel"

#. (itstool) path: description/p
#: org.kde.kio_zeroconf.metainfo.xml:12
msgid ""
"Adds an entry to Dolphin's Network page to show local services such as "
"printers which advertise themselves with DNSSD (called Avahi or Bonjour by "
"other projects)."
msgstr ""
"Dolphini võrgulehele kirje lisamine, mis näitab kohalikke teenusi, näiteks "
"printereid, mis teavitavad enda olemasolust DNSSD kaudu (mis teistes "
"projektides kannab Avahi või Bonjouri nime)."
