msgid "Skanlite"
msgstr "Skanlite"

#. (itstool) path: component/summary
#: org.kde.skanlite.appdata.xml:11
msgid "Image Scanning Application"
msgstr "Piltide skannimise rakendus"

#. (itstool) path: description/p
#: org.kde.skanlite.appdata.xml:13
#, fuzzy
#| msgid ""
#| "Skanlite is a simple image scanning application to scan and save images. "
#| "Skanlite is based on libksane, an interface for SANE library to control "
#| "image scanners."
msgid ""
"Skanlite is a simple image scanning application to scan and save images. It "
"is optimized for scanning with flatbed scanners. Skanlite can capture not "
"only photos and documents, but also transparent slides and filmstrips, with "
"supported scanners."
msgstr ""
"Skanlite on lihtne piltide skannimise rakendus piltide skannimiseks ja "
"salvestamiseks. Skanlite'i aluseks on libksane - SANE teegi liides "
"pildiskannerite juhtimiseks."

