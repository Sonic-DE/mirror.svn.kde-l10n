msgid "Create and play puzzles ranging from 4 to 10,000 pieces"
msgstr "Puslede loomine ja läbimängimine, milles on 4 kuni 10 000 tükki"

#. (itstool) path: ul/li
#: org.kde.palapeli.appdata.xml:21
msgid "Piece-holders for helping solve large puzzles"
msgstr "Tükihoidikud suuremate puslede lahendamise hõlbustamiseks"
