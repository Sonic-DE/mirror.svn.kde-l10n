#. (itstool) path: component/name
#: org.kde.tellico.appdata.xml:9
msgid "Tellico"
msgstr "Tellico"

#. (itstool) path: component/summary
#: org.kde.tellico.appdata.xml:10
msgid "Collection Manager"
msgstr "Kogude haldur"

#. (itstool) path: description/p
#: org.kde.tellico.appdata.xml:12
msgid ""
"Tellico is an application for organizing your collections. It provides "
"default templates for books, bibliographies, videos, music, video games, "
"coins, stamps, trading cards, comic books, and wines. It allows you to enter "
"your collection in a catalogue database, saving many different properties "
"like title, author, etc."
msgstr ""
"Tellico on kõikvõimalike kogude haldamiseks mõeldud rakendus. See pakub "
"vaikimisi malle raamatute, bibliograafiate, videode, muusika, videomängude, "
"müntide, markide, mängukaartide, koomiksite ja veinide tarbeks. Rakenduses "
"saab oma kogu sisestada kataloogi andmebaasi, kuhu salvestatakse hulk "
"omadusi, näiteks nimi, autor jne."

#. (itstool) path: description/p
#: org.kde.tellico.appdata.xml:17
msgid "Features:"
msgstr "Omadused:"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:19
msgid ""
"Supports default collections of books, bibliographic entries, videos, music, "
"video games, comic books, coins, stamps, trading cards, wines, board games, "
"and file catalogs"
msgstr ""
"Vaikimisi on toetatud, raamatute, bibliograafiliste kirjete, videode, "
"muusika, videomängude, koomiksite, müntide, markide, mängukaartide, veinide, "
"lauamängude ja failikataloogide kogud"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:20
msgid "Supports user-defined custom collections"
msgstr "Toetatud on ka kasutaja loodud kohandatud kogud"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:21
msgid ""
"Supports any number of user-defined fields, of several different types: "
"text, paragraph, list, checkbox, number, URL, date, images, and combinations"
msgstr ""
"Toetatud on mis tahes hulk kasutaja määratud välju, mis võivad olla väga eri "
"tüüpi: tekst, lõik, loend, märkekast, arv, URL, kuupäev, pilt või nende "
"kombinatsioon"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:22
msgid "Handles entries with multiple authors, genres, keywords, etc"
msgstr ""
"Raskusi ei valmista ka kirjed, mis sisaldavad mitut autorit, žanri, "
"võtmesõna jne."

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:23
msgid "Automatically formats titles and names"
msgstr "Pealkirjasid ja nimesid saab lasta automaatselt vormindada"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:24
msgid "Supports collection searching and view filtering"
msgstr "Toetatud on kogudes otsimine ja vaate filtreerimine"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:25
msgid "Sorts and groups collection by various properties"
msgstr "Kogusid saab sortida ja rühmitada eri omaduste järgi"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:26
msgid "Allows customizable entry templates through XSLT"
msgstr "XSLT abil on võimalik luua kohandatud kirjemalle"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:27
msgid "Imports MODS, Bibtex, RIS, CSV, PDF metadata, and many other formats"
msgstr ""
"MODS-i, Bibtexi, RIS-i, CSV, PDF-i metaandmete ja veel paljude vormingute "
"import"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:28
msgid "Exports to Bibtex, ONIX, CSV, HTML, and other formats"
msgstr "Eksport Bibtexi, ONIX-i, CSV, HTML-i ja veel paljudesse vormingutesse"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:29
msgid ""
"Imports information directly from Amazon.com, IMDb, z39.50 servers, PubMed, "
"SRU servers, CrossRef.org, various other websites, and from external scripts"
msgstr ""
"Teabe importimine otse Amazon.com-ist, IMDb-st, z39.50 serveritest, PubMed-"
"ist, SRU serveritest, CrossRef.org-ist, veel paljudelt veebilehekülgedelt ja "
"väliste skriptide kaudu"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:30
msgid "Imports CDDB data for cataloging audio CDs"
msgstr "CDDB andmete import audio-CD-de kataloogimiseks"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:31
msgid "Scans and imports audio file collections, such as mp3 or ogg"
msgstr "Helifailide (näiteks mp3 või ogg) kogude läbiuurimine ja import"

