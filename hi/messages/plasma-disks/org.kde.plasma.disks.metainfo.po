#. (itstool) path: component/name
#: org.kde.plasma.disks.metainfo.xml:11
msgid "Plasma Disks"
msgstr "प्लाज्मा डिस्क"

#. (itstool) path: component/summary
#: org.kde.plasma.disks.metainfo.xml:12
msgid "Hard disk health monitoring for KDE Plasma"
msgstr "केडीई प्लाज़्मा के लिए हार्ड डिस्क स्वास्थ्य निगरानी"

#. (itstool) path: description/p
#: org.kde.plasma.disks.metainfo.xml:14
msgid ""
"Plasma Disks monitors S.M.A.R.T. data of disks and alerts the user when "
"signs of imminent failure appear."
msgstr ""
"प्लाज्मा डिस्क, डिस्क के S.M.A.R.T. डेटा पर नज़र रखता है और आसन्न विफलता के संकेत दिखाई "
"देने पर उपयोगकर्ता को सचेत करता है।"

#. (itstool) path: screenshot/caption
#: org.kde.plasma.disks.metainfo.xml:19
msgid "The Plasma Disks Info Center module showing the state of devices."
msgstr "प्लाज्मा डिस्क सूचना केंद्र मॉड्यूल, उपकरणों की स्थिति दर्शाता है।"

#. (itstool) path: component/developer_name
