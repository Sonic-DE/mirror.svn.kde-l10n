#: kwrited-autostart.desktop:2
msgctxt "Name"
msgid "KDE Write Daemon"
msgstr "केडीई राइट डेमन"

#: kwrited-autostart.desktop:91
msgctxt "Comment"
msgid "Watch for messages from local users sent with write(1) or wall(1)"
msgstr "स्थानीय उपयोक्ताओं द्वारा राइट(1) या वाल(1) के जरिए भेजे गए संदेशों के लिए देखें"

#: kwrited.notifyrc:3
msgctxt "Name"
msgid "Local System Message Service"
msgstr "स्थानिक तंत्र संदेश सेवा"

#: kwrited.notifyrc:48
msgctxt "Comment"
msgid "Local system message service"
msgstr "स्थानिक तंत्र संदेश सेवा"

#: kwrited.notifyrc:117
msgctxt "Name"
msgid "New message received"
msgstr "नया संदेश मिला"

#: kwrited.notifyrc:192
msgctxt "Comment"
msgid "The daemon received a new message sent with wall(1) or write(1)"
msgstr "डेमन द्वारा राइट(1) या वाल(1) के जरिए भेजे गए संदेश प्राप्त किया गया"

#~ msgctxt "Name"
#~ msgid "Write Daemon"
#~ msgstr "राइट डेमन"
