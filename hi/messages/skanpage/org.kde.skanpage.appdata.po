#. (itstool) path: component/name
#: org.kde.skanpage.appdata.xml:14
msgid "Skanpage"
msgstr "पेज स्कैन करें"

#. (itstool) path: component/summary
#: org.kde.skanpage.appdata.xml:15
msgid "Scan multi-page documents and images"
msgstr "बहु-पृष्ठ दस्तावेज़ों और छवियों को स्कैन करें"

#. (itstool) path: description/p
#: org.kde.skanpage.appdata.xml:17
msgid ""
"Skanpage is a simple scanning application optimized for multi-page document "
"scanning. It can also scan and save single-page documents and images."
msgstr ""
"स्कैनपेज एक सरल स्कैनिंग एप्लीकेशन है जो मल्टी-पेज डॉक्यूमेंट स्कैनिंग के लिए अनुकूलित है। यह सिंगल-"
"पेज डॉक्यूमेंट और इमेज को भी स्कैन और सेव कर सकता है।"

#. (itstool) path: description/p
#: org.kde.skanpage.appdata.xml:18
msgid "Features:"
msgstr "विशेषताएँ:"

#. (itstool) path: ul/li
#: org.kde.skanpage.appdata.xml:20
msgid "Scanning from flatbed and ADF scanners"
msgstr "फ्लैटबेड और एडीएफ स्कैनर से स्कैनिंग"

#. (itstool) path: ul/li
#: org.kde.skanpage.appdata.xml:21
msgid "Configurable options for scanning device"
msgstr "स्कैनिंग डिवाइस के लिए कॉन्फ़िगर करने योग्य विकल्प"

#. (itstool) path: ul/li
#: org.kde.skanpage.appdata.xml:22
msgid "Reordering, rotation, and deletion of scanned pages"
msgstr "स्कैन किए गए पृष्ठों का पुनः क्रम निर्धारण, घूर्णन और विलोपन"

#. (itstool) path: ul/li
#: org.kde.skanpage.appdata.xml:23
msgid "Saving to multi-page PDF documents and image files"
msgstr "बहु-पृष्ठ पीडीएफ दस्तावेज़ों और छवि फ़ाइलों को सहेजना"

