#. (itstool) path: component/name
#: org.kde.accountwizard.appdata.xml:9
msgid "Account Wizard"
msgstr "खाता विज़ार्ड"

#. (itstool) path: component/summary
#: org.kde.accountwizard.appdata.xml:10
msgid "Configure accounts"
msgstr "खाते कॉन्फ़िगर करें"

#. (itstool) path: description/p
#: org.kde.accountwizard.appdata.xml:12
msgid ""
"Accountwizard allows to edit, create, delete accounts. Accountwizard "
"supports IMAP/POP3/Kolab account type. Account information can be found by "
"using ispd service."
msgstr ""
"अकाउंटविज़ार्ड अकाउंट को संपादित करने, बनाने, हटाने की अनुमति देता है। अकाउंटविज़ार्ड IMAP/"
"POP3/कोलैब अकाउंट प्रकार का समर्थन करता है। ispd सेवा का उपयोग करके खाता जानकारी "
"प्राप्त की जा सकती है।"
