#: gui/org.kde.pimdataexporter.desktop:2
msgctxt "Name"
msgid "PIM Data Exporter"
msgstr "पीआईएम डेटा निर्यातक"

#: gui/org.kde.pimdataexporter.desktop:45
msgctxt "GenericName"
msgid "Saves and restores all data from PIM apps"
msgstr "PIM ऐप्स से सभी डेटा को सहेजता है और पुनर्स्थापित करता है"

#: gui/org.kde.pimdataexporter.desktop:85
msgctxt "Comment"
msgid ""
"PIM Setting Exporter allows to save all data from PIM apps and restore them "
"in other systems."
msgstr ""
"पीआईएम सेटिंग एक्सपोर्टर पीआईएम ऐप्स से सभी डेटा को सहेजने और उन्हें अन्य सिस्टम में "
"पुनर्स्थापित करने की अनुमति देता है।"
