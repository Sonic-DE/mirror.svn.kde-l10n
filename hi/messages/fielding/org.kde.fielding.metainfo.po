#: org.kde.fielding.metainfo.xml:8
msgid "Fielding"
msgstr "फील्डिंग"

#. (itstool) path: component/summary
#: org.kde.fielding.metainfo.xml:13
msgid "Test your REST APIs"
msgstr "अपने REST API का परीक्षण करें"

#. (itstool) path: description/p
#: org.kde.fielding.metainfo.xml:17
msgid ""
"Fielding makes it easy to test your REST API, it allows you to make requests "
"for the most used HTTP methods."
msgstr ""
"फील्डिंग आपके REST API का परीक्षण करना आसान बनाता है, यह आपको सबसे अधिक उपयोग किए "
"जाने वाले HTTP तरीकों के लिए अनुरोध करने की अनुमति देता है।"

#. (itstool) path: screenshot/caption
#: org.kde.fielding.metainfo.xml:22
msgid "Main view making a GET request"
msgstr "GET अनुरोध करने वाला मुख्य दृश्य"

