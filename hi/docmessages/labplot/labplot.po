msgstr ""
"3-आयामी हाइपरबोलिक स्पेस पर लाप्लासियन का शून्यवाँ रेडियल आइगेनफ़ंक्शन, "
"L<superscript>H3d</superscript><subscript>0</subscript>(&lambda;,,&eta;) := "
"sin(&lambda; &eta;)/(&lambda; sinh(&eta;)) for &eta; &gt;= 0"

