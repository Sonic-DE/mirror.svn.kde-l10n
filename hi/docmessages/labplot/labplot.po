"for &eta; &gt;= 0"
msgstr ""
"3-आयामी हाइपरबोलिक स्पेस पर लाप्लासियन का शून्यवाँ रेडियल आइगेनफ़ंक्शन, "
"L<superscript>H3d</superscript><subscript>1</subscript>(&lambda;,&eta;) := 1/"
"&radic;{&lambda;<superscript>2</superscript> + 1} sin(&lambda; &eta;)/"
"(&lambda; sinh(&eta;)) (coth(&eta;) - &lambda; cot(&lambda; &eta;)) for "
"&eta; &gt;= 0"

