#. Tag: author
#: index.docbook:13
#, no-c-format
msgid "&Mike.McBride; &Mike.McBride.mail;"
msgstr "&माइक.मैकब्राइड; &माइक.मैकब्राइड.मेल;"

#. Tag: trans_comment
#: index.docbook:14
#, no-c-format
