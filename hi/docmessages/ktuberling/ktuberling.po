msgstr "मेनू आइटम"

#. Tag: title
#: index.docbook:298
#, no-c-format
msgid "The Game Menu"
msgstr "खेल मेनू"

#. Tag: menuchoice
#: index.docbook:303
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>N</keycap></keycombo> </"
"shortcut> <guimenu>Game</guimenu> <guimenuitem>New</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>N</keycap></keycombo> </"
"shortcut> <guimenu>गेम</guimenu> <guimenuitem>नया</guimenuitem>"

#. Tag: para
#: index.docbook:306
#, no-c-format
msgid "<action>Clears</action> the <quote>playground</quote> area."
msgstr "<action>खेल का मैदान</quote> क्षेत्र साफ़ करता है।"

#. Tag: menuchoice
#: index.docbook:310
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>O</keycap></keycombo> </"
"shortcut> <guimenu>Game</guimenu> <guimenuitem>Load…</guimenuitem>"
msgstr ""
"<shortcut><keycombo Action='simul'>&Ctrl;<keycap>O</keycap></keycombo> </"
"shortcut> <guimenu>गेम</guimenu> <guimenuitem>लोड करें...</guimenuitem>"

#. Tag: para
#: index.docbook:313
#, no-c-format
msgid ""
"<action>Opens an existing <literal role=\"extension\">.tuberling</literal> "
"file</action> from your disk."
msgstr ""
"<action>आपकी डिस्क से एक मौजूदा <literal role=\"extension\">.tuberling</"
"literal> फ़ाइल</action> खोलता है."

#. Tag: menuchoice
#: index.docbook:318
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>S</keycap></keycombo> </"
"shortcut> <guimenu>Game</guimenu> <guimenuitem>Save</guimenuitem>"
msgstr ""
"<shortcut><keycombo Action='simul'>&Ctrl;<keycap>S</keycap></keycombo> </"
"shortcut> <guimenu>गेम</guimenu> <guimenuitem>सहेजें</guimenuitem>"

#. Tag: para
#: index.docbook:321
#, no-c-format
msgid ""
"<action>Saves</action> your creation. The tuberling is saved to a small file "
"where only the position of objects are saved."
msgstr ""
"<action>आपकी रचना को सहेजता है</action>। ट्यूबरलिंग को एक छोटी फ़ाइल में सहेजा जाता है "
"जहाँ केवल वस्तुओं की स्थिति ही सहेजी जाती है।"

#. Tag: menuchoice
#: index.docbook:326
#, no-c-format
msgid "<guimenu>Game</guimenu> <guimenuitem>Save as Picture…</guimenuitem>"
msgstr "<guimenu>गेम</guimenu> <guimenuitem>चित्र के रूप में सहेजें...</guimenuitem>"

#. Tag: para
#: index.docbook:328
#, no-c-format
msgid ""
"<action>Creates a graphics file</action> containing a picture of your "
"tuberling."
msgstr ""
"<action>एक ग्राफ़िक्स फ़ाइल बनाता है</action> जिसमें आपके ट्यूबरलिंग का चित्र होता है।"

#. Tag: menuchoice
#: index.docbook:333
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>P</keycap></keycombo> </"
"shortcut> <guimenu>Game</guimenu> <guimenuitem>Print…</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>P</keycap></keycombo> </"
"shortcut> <guimenu>गेम</guimenu> <guimenuitem>प्रिंट…</guimenuitem>"

#. Tag: para
#: index.docbook:336
#, no-c-format
msgid "<action>Prints</action> your tuberling picture."
msgstr "<action>आपके ट्यूबरलिंग चित्र को प्रिंट करता है</action>."

#. Tag: menuchoice
#: index.docbook:340
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>Q</keycap></keycombo> </"
"shortcut> <guimenu>Game</guimenu> <guimenuitem>Quit</guimenuitem>"
msgstr ""
"<shortcut><keycombo Action='simul'>&Ctrl;<keycap>Q</keycap></keycombo> </"
"shortcut> <guimenu>गेम</guimenu> <guimenuitem>छोड़ें</guimenuitem>"

#. Tag: para
#: index.docbook:343
#, no-c-format
msgid "<action>Quit</action> &i18n-ktuberling;."
msgstr "<action>छोड़ो</action> &i18n-ktuberling;."

#. Tag: title
#: index.docbook:350
#, no-c-format
msgid "The Edit Menu"
msgstr "संपादन मेनू"

#. Tag: menuchoice
#: index.docbook:355
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>Z</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Undo</guimenuitem>"
msgstr ""
"<shortcut><keycombo Action='simul'>&Ctrl;<keycap>Z</keycap></keycombo> </"
"shortcut> <guimenu>संपादित करें</guimenu> <guimenuitem>पूर्ववत करें</guimenuitem>"

#. Tag: para
#: index.docbook:358
#, no-c-format
msgid "<action>Undo</action> the last <quote>object</quote> placement."
msgstr "<action>पूर्ववत करें</action> अंतिम <quote>ऑब्जेक्ट</quote> प्लेसमेंट."

#. Tag: menuchoice
#: index.docbook:363
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;&Shift;<keycap>Z</keycap></"
"keycombo> </shortcut> <guimenu>Edit</guimenu> <guimenuitem>Redo</guimenuitem>"
msgstr ""
"<shortcut><keycombo Action='simul'>&Ctrl;&Shift;<keycap>Z</keycap></"
"keycombo> </shortcut> <guimenu>संपादित करें</guimenu> <guimenuitem>फिर से करें</"
"guimenuitem>"

#. Tag: para
#: index.docbook:366
#, no-c-format
msgid ""
"<action>Re-does</action> the last <quote>object</quote> placement. This menu "
"option is active only if you have previously used <guilabel>Undo</guilabel>."
msgstr ""
"<action>पिछले <quote>ऑब्जेक्ट</quote> प्लेसमेंट को फिर से करता है। यह मेनू विकल्प केवल तभी "
"सक्रिय होता है जब आपने पहले <guilabel>पूर्ववत करें</guilabel> का उपयोग किया हो।"

#. Tag: menuchoice
#: index.docbook:372
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>C</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Copy</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>C</keycap></keycombo> </"
"shortcut> <guimenu>संपादित करें</guimenu> <guimenuitem>कॉपी करें</guimenuitem>"

#. Tag: para
#: index.docbook:375
#, no-c-format
msgid ""
"<action>Copy</action> the <quote>playground</quote> area to the clipboard."
msgstr "<action>खेल का मैदान</quote> क्षेत्र को क्लिपबोर्ड पर कॉपी करें।"

#. Tag: title
#: index.docbook:383
#, no-c-format
msgid "The View Menu"
msgstr "दृश्य मेनू"

#. Tag: menuchoice
#: index.docbook:388
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;&Shift;<keycap>F</keycap></"
"keycombo> </shortcut> <guimenu>View</guimenu> <guimenuitem>Full Screen Mode</"
"guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;&Shift;<keycap>F</keycap></"
"keycombo> </shortcut> <guimenu>देखें</guimenu> <guimenuitem>पूर्ण स्क्रीन मोड</"
"guimenuitem>"

#. Tag: para
#: index.docbook:391
#, no-c-format
msgid "Toggles the graphic interface to full screen mode."
msgstr "ग्राफ़िक इंटरफ़ेस को पूर्ण स्क्रीन मोड पर टॉगल करता है."

#. Tag: title
#: index.docbook:398
#, no-c-format
msgid "The Playground Menu"
msgstr "खेल का मैदान मेनू"

#. Tag: menuchoice
#: index.docbook:403
#, no-c-format
msgid ""
"<guimenu>Playground</guimenu> <guimenuitem>Lock Aspect Ratio</guimenuitem>"
msgstr "<guimenu>खेल का मैदान</guimenu> <guimenuitem>लॉक पहलू अनुपात</guimenuitem>"

#. Tag: para
#: index.docbook:405
#, no-c-format
msgid ""
"This option preserves the playground aspect ratio when resizing the &i18n-"
"ktuberling; window. When the playground aspect ratio does not match the one "
"of the window the background is filled with the one specified in the theme."
msgstr ""
"यह विकल्प &i18n-ktuberling; विंडो का आकार बदलते समय प्लेग्राउंड पहलू अनुपात को सुरक्षित "
"रखता है। जब प्लेग्राउंड पहलू अनुपात विंडो के पहलू अनुपात से मेल नहीं खाता है, तो पृष्ठभूमि थीम "
"में निर्दिष्ट पहलू अनुपात से भर जाती है।"

#. Tag: menuchoice
#: index.docbook:411
#, no-c-format
msgid ""
"<guimenu>Playground</guimenu> <guimenuitem><replaceable>Playground Name</"
"replaceable></guimenuitem>"
msgstr ""
"<guimenu>खेल का मैदान</guimenu> <guimenuitem><replaceable>खेल के मैदान का नाम</"
"replaceable></guimenuitem>"

#. Tag: para
#: index.docbook:414
#, no-c-format
msgid "<action>Switches to the playground</action>."
msgstr "<action>खेल के मैदान पर स्विच करता है</action>."

#. Tag: para
#: index.docbook:419
#, no-c-format
msgid "It will contain the playgrounds installed in your system."
msgstr "इसमें आपके सिस्टम में स्थापित खेल के मैदान शामिल होंगे।"

#. Tag: para
#: index.docbook:422
#, no-c-format
msgid ""
"&i18n-ktuberling; remembers the last chosen playground the next time it "
"starts up."
msgstr ""
"&i18n-ktuberling; अगली बार शुरू होने पर अंतिम बार चुने गए खेल के मैदान को याद रखता है।"

#. Tag: title
#: index.docbook:428
#, no-c-format
msgid "The Speech Menu"
msgstr "भाषण मेनू"

#. Tag: menuchoice
#: index.docbook:433
#, no-c-format
msgid "<guimenu>Speech</guimenu> <guimenuitem>No Sound</guimenuitem>"
msgstr "<guimenu>भाषण</guimenu> <guimenuitem>कोई ध्वनि नहीं</guimenuitem>"

#. Tag: para
#: index.docbook:435
#, no-c-format
msgid "<action>Toggles sound off</action>."
msgstr "<action>ध्वनि बंद कर देता है</action>."

#. Tag: menuchoice
#: index.docbook:439
#, no-c-format
msgid ""
"<guimenu>Speech</guimenu> <guimenuitem><replaceable>Language Name</"
"replaceable></guimenuitem>"
msgstr ""
"<guimenu>भाषण</guimenu> <guimenuitem><replaceable>भाषा का नाम</replaceable></"
"guimenuitem>"

#. Tag: para
#: index.docbook:441
#, no-c-format
msgid "<action>Toggles sound on and speaks the selected language</action>."
msgstr "<action>ध्वनि चालू करता है और चयनित भाषा बोलता है</action>."

#. Tag: para
#: index.docbook:446
#, no-c-format
msgid "&i18n-ktuberling; remembers of this option the next time it starts up."
msgstr "&i18n-ktuberling; अगली बार प्रारंभ होने पर इस विकल्प को याद रखता है।"

#. Tag: title
#: index.docbook:452
#, no-c-format
msgid "The Settings and Help Menus"
msgstr "सेटिंग्स और सहायता मेनू"

#. Tag: para
#: index.docbook:454
#, no-c-format
msgid ""
"Additionally &i18n-ktuberling; has the common &kde; <guimenu>Settings</"
"guimenu> and <guimenu>Help</guimenu> menu items, for more information read "
"the sections about the <ulink url=\"help:/fundamentals/menus.html#menus-"
"settings\">Settings Menu</ulink> and <ulink url=\"help:/fundamentals/menus."
"html#menus-help\">Help Menu</ulink> of the &kde; Fundamentals."
msgstr ""
"इसके अतिरिक्त &i18n-ktuberling; में सामान्य &kde; <guimenu>सेटिंग्स</guimenu> और "
"<guimenu>सहायता</guimenu> मेनू आइटम हैं, अधिक जानकारी के लिए &kde; फंडामेंटल्स के "
"<ulink url=\"help:/fundamentals/menus.html#menus-settings\">सेटिंग्स मेनू</ulink> "
"और <ulink url=\"help:/fundamentals/menus.html#menus-help\">सहायता मेनू</ulink> "
"के बारे में अनुभाग पढ़ें।"

#. Tag: title
#: index.docbook:467
#, no-c-format
msgid "Frequently Asked Questions"
msgstr "अक्सर पूछे जाने वाले प्रश्नों"

#. Tag: para
#: index.docbook:471
#, no-c-format
msgid "I want to change the way this game looks. Can I?"
msgstr "मैं इस खेल का स्वरूप बदलना चाहता हूँ। क्या मैं ऐसा कर सकता हूँ?"

#. Tag: para
#: index.docbook:472
#, no-c-format
msgid ""
"Yes you can. Refer to <link linkend=\"theme_change\">this</link> section of "
"'Interface Overview' for details."
msgstr ""
"हाँ, आप कर सकते हैं। देखें<link linkend=\"theme_change\"> यह</link> विवरण के लिए "
"&#39;इंटरफ़ेस अवलोकन&#39; अनुभाग देखें।"

#. Tag: para
#: index.docbook:475
#, no-c-format
msgid "Can I use the keyboard to play this game?"
msgstr "क्या मैं इस गेम को खेलने के लिए कीबोर्ड का उपयोग कर सकता हूँ?"

#. Tag: para
#: index.docbook:476
#, no-c-format
msgid "No. This game cannot be played using keyboard."
msgstr "नहीं. यह गेम कीबोर्ड का उपयोग करके नहीं खेला जा सकता."

#. Tag: para
#: index.docbook:479
#, no-c-format
msgid ""
"I have made a great picture and I want to share it with my friends. Can I "
"save it as an image?"
msgstr ""
"मैंने एक बेहतरीन तस्वीर बनाई है और मैं इसे अपने दोस्तों के साथ साझा करना चाहता हूँ। क्या मैं "
"इसे इमेज के रूप में सहेज सकता हूँ?"

#. Tag: para
#: index.docbook:480
#, no-c-format
msgid ""
"Yes. To save the current session as an image refer to <link linkend=\"game-"
"save-as-picture\">this</link> section of 'Interface Overview' for details."
msgstr ""
"हाँ। वर्तमान सत्र को छवि के रूप में सहेजने के लिए देखें<link linkend=\"game-save-as-"
"picture\"> यह</link> विवरण के लिए &#39;इंटरफ़ेस अवलोकन&#39; अनुभाग देखें।"

