#, no-c-format
msgid "&s1; .. &s9;"
msgstr "&s1; .. &s9;"

#. Tag: entry
#: index.docbook:700
#, no-c-format
msgid "Stone 1 to Stone 9"
msgstr "पत्थर 1 से पत्थर 9 तक"

#. Tag: entry
#: index.docbook:703
#, no-c-format
msgid "&b1; .. &b9;"
msgstr "&b1; .. &b9;"

#. Tag: entry
