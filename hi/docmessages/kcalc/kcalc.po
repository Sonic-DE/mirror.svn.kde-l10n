msgstr "कोसाइन की गणना करें"

#. Tag: entry
#: index.docbook:229
#, no-c-format
msgid "&Shift; <guibutton>Cos</guibutton> or <guibutton>Acos</guibutton>"
msgstr "&Shift; <guibutton>Cos</guibutton> या <guibutton>Acos</guibutton>"

#. Tag: entry
#: index.docbook:230
#, no-c-format
msgid "Compute the inverse cosine"
msgstr "व्युत्क्रम कोसाइन की गणना करें"

#. Tag: guibutton
