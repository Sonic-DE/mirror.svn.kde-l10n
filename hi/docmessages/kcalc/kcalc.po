msgstr "<guibutton>1/x</guibutton>"

#. Tag: entry
#: index.docbook:267
#, no-c-format
msgid "Compute the reciprocal for a number"
msgstr "किसी संख्या के व्युत्क्रम की गणना करें"

#. Tag: entry
#: index.docbook:269
#, no-c-format
msgid ""
"<guibutton>&Shift;</guibutton> <guibutton>1/x</guibutton> or <guibutton>nCm</"
"guibutton>"
msgstr ""
"<guibutton>&Shift;</guibutton> <guibutton>1/x</guibutton> या <guibutton>nCm</"
"guibutton>"

#. Tag: entry
#: index.docbook:270
#, no-c-format
msgid ""
"Compute the number of distinct second-operand-element subsets of it that can "
"be formed for any set containing first operand elements (binomial "
"coefficient)"
msgstr ""
"प्रथम ऑपरेंड तत्वों (द्विपद गुणांक) वाले किसी भी सेट के लिए बनाए जा सकने वाले इसके विशिष्ट "
"द्वितीय-ऑपरेंड-तत्व उपसमुच्चयों की संख्या की गणना करें"

#. Tag: guibutton
#: index.docbook:272 index.docbook:558
#, no-c-format
msgid "<guibutton>x!</guibutton>"
msgstr "<guibutton>x!</guibutton>"

#. Tag: entry
#: index.docbook:273
#, no-c-format
msgid ""
"Compute the product of all positive integers less than or equal to the "
"current integer operand (factorial)"
msgstr ""
"वर्तमान पूर्णांक ऑपरेंड (फैक्टरियल) से कम या बराबर सभी धनात्मक पूर्णांकों के गुणनफल की गणना "
"करें"

#. Tag: guibutton
#: index.docbook:275
#, no-c-format
msgid "<guibutton>x²</guibutton>"
msgstr "<guibutton>x²</guibutton>"

#. Tag: entry
#: index.docbook:276
#, no-c-format
msgid "Compute the square of x"
msgstr "x का वर्ग ज्ञात करें"

#. Tag: entry
#: index.docbook:278
#, no-c-format
msgid ""
"<guibutton>&Shift;</guibutton> <guibutton>x²</guibutton> or <guibutton>√x</"
"guibutton>"
msgstr ""
"<guibutton>&Shift;</guibutton> <guibutton>x²</guibutton> या <guibutton>√x</"
"guibutton>"

#. Tag: entry
#: index.docbook:279
#, no-c-format
msgid "Compute the square root of x"
msgstr "x का वर्गमूल निकालें"

#. Tag: guibutton
