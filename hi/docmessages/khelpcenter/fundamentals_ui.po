#. Tag: title
#: ui.docbook:18
#, no-c-format
msgid "A Visual Dictionary"
msgstr "एक दृश्य शब्दकोश"

#. Tag: para
#: ui.docbook:20
#, no-c-format
msgid ""
"The &plasma-workspaces; feature many different graphical user interface "
"elements, commonly known as <quote>widgets</quote>. This guide will "
"introduce you to their names and functions."
msgstr ""
"&plasma-workspaces; में कई अलग-अलग ग्राफ़िकल यूज़र इंटरफ़ेस तत्व होते हैं, जिन्हें आम तौर पर "
"<quote>विजेट्स</quote> के नाम से जाना जाता है। यह गाइड आपको उनके नाम और फ़ंक्शन से "
"परिचित कराएगा।"

#. Tag: title
#: ui.docbook:25
#, no-c-format
msgid "The Big Picture"
msgstr "बड़ा चित्र"

#. Tag: title
#: ui.docbook:28
#, no-c-format
msgid "Windows"
msgstr "विंडोज़"

#. Tag: screeninfo
#: ui.docbook:31
#, no-c-format
msgid "A Window"
msgstr "एक खिड़की"

#. Tag: para
#: ui.docbook:55
#, no-c-format
msgid ""
"This is the window of the &kwrite;, a text editor. Click on part of the "
"window to learn more about it."
msgstr ""
"यह &kwrite; नामक टेक्स्ट एडिटर की विंडो है। इसके बारे में अधिक जानने के लिए विंडो के भाग "
"पर क्लिक करें।"

#. Tag: para
#: ui.docbook:60
#, no-c-format
msgid "The <emphasis role=\"bold\">Window Menu</emphasis>"
msgstr "<emphasis role=\"bold\">विंडो मेनू</emphasis>"

#. Tag: para
#: ui.docbook:64
#, no-c-format
msgid ""
"The <emphasis role=\"bold\"><link linkend=\"visualdict-titlebar\">Titlebar</"
"link></emphasis>"
msgstr ""
"<emphasis role=\"bold\"><link linkend=\"visualdict-titlebar\">शीर्षक टाईटल</"
"link></emphasis>"

#. Tag: para
#: ui.docbook:68
#, no-c-format
msgid ""
"Buttons to <emphasis>minimize</emphasis>, <emphasis>maximize</emphasis>, or "
"<emphasis>close</emphasis> the window"
msgstr ""
"विंडो को <emphasis>न्यूनतम</emphasis>, <emphasis>अधिकतम</emphasis>, या "
"<emphasis>बंद</emphasis> करने के लिए बटन"

#. Tag: para
#: ui.docbook:73
#, no-c-format
msgid ""
"The <emphasis role=\"bold\"><link linkend=\"visualdict-menubar\">Menubar</"
"link></emphasis>"
msgstr ""
"<emphasis role=\"bold\"><link linkend=\"visualdict-menubar\">मेनू पट्टी</link></"
"emphasis>"

#. Tag: para
#: ui.docbook:77
#, no-c-format
msgid ""
"The <emphasis role=\"bold\"><link linkend=\"visualdict-toolbar\">Toolbar</"
"link></emphasis>"
msgstr ""
"<emphasis role=\"bold\"><link linkend=\"visualdict-toolbar\">उपकरण पट्टी</"
"link></emphasis>"

#. Tag: para
#: ui.docbook:81
#, no-c-format
msgid ""
"A very large <emphasis role=\"bold\"><link linkend=\"visualdict-text-area"
"\">Text Area</link></emphasis> that acts as this program's <emphasis role="
"\"bold\"><link linkend=\"visualdict-central-widget\">Central Widget</link></"
"emphasis>"
msgstr ""
"एक बहुत बड़ा<emphasis role=\"bold\"><link linkend=\"visualdict-text-area\"> "
"पाठ क्षेत्र</link></emphasis> जो इस कार्यक्रम के रूप में कार्य करता है<emphasis role="
"\"bold\"><link linkend=\"visualdict-central-widget\"> केंद्रीय विजेट</link></"
"emphasis>"

#. Tag: para
#: ui.docbook:88
#, no-c-format
msgid ""
"A vertical <emphasis role=\"bold\"><link linkend=\"visualdict-scrollbar"
"\">Scrollbar</link></emphasis> (there is also a horizontal scrollbar below "
"the text box)"
msgstr ""
"एक ऊर्ध्वाधर<emphasis role=\"bold\"><link linkend=\"visualdict-scrollbar\"> "
"स्क्रॉल बार</link></emphasis> (टेक्स्ट बॉक्स के नीचे एक क्षैतिज स्क्रॉलबार भी है)"

#. Tag: para
#: ui.docbook:93
#, no-c-format
msgid ""
"The <emphasis role=\"bold\"><link linkend=\"visualdict-statusbar"
"\">Statusbar</link></emphasis>"
msgstr ""
"<emphasis role=\"bold\"><link linkend=\"visualdict-statusbar\">स्टेटस बार</"
"link></emphasis>"

#. Tag: screeninfo
#: ui.docbook:100
#, no-c-format
msgid "Another Window"
msgstr "एक और विंडो"

#. Tag: para
#: ui.docbook:119
#, no-c-format
msgid ""
"This is the another window, that of the &dolphin; file manager. Click on "
"part of the window to learn more about it."
msgstr ""
"यह दूसरी विंडो है, जो &dolphin; फ़ाइल मैनेजर की है। इसके बारे में अधिक जानने के लिए विंडो "
"के भाग पर क्लिक करें।"

#. Tag: para
#: ui.docbook:124
#, no-c-format
msgid ""
"A <emphasis role=\"bold\"><link linkend=\"visualdict-panel\">panel</link></"
"emphasis> that contains a list of Places on the computer system"
msgstr ""
"ए<emphasis role=\"bold\"><link linkend=\"visualdict-panel\"> पैनल</link></"
"emphasis> जिसमें कंप्यूटर सिस्टम पर स्थानों की सूची शामिल है"

#. Tag: para
#: ui.docbook:129
#, no-c-format
msgid ""
"A <emphasis role=\"bold\"><link linkend=\"visualdict-breadcrumb"
"\">Breadcrumb</link></emphasis> of the path of the displayed folder"
msgstr ""
"ए<emphasis role=\"bold\"><link linkend=\"visualdict-breadcrumb\"> ब्रेडक्रम्ब</"
"link></emphasis> प्रदर्शित फ़ोल्डर के पथ का"

#. Tag: para
#: ui.docbook:134
#, no-c-format
msgid ""
"A folder <emphasis role=\"bold\"><link linkend=\"visualdict-icon\">Icon</"
"link></emphasis>"
msgstr ""
"एक फ़ोल्डर<emphasis role=\"bold\"><link linkend=\"visualdict-icon\"> आइकन</"
"link></emphasis>"

#. Tag: para
#: ui.docbook:138
#, no-c-format
msgid ""
"A file <emphasis role=\"bold\"><link linkend=\"visualdict-icon\">Icon</"
"link></emphasis>"
msgstr ""
"एक फ़ाइल<emphasis role=\"bold\"><link linkend=\"visualdict-icon\"> आइकन</"
"link></emphasis>"

#. Tag: para
#: ui.docbook:142
#, no-c-format
msgid ""
"A highlighted <emphasis role=\"bold\"><link linkend=\"visualdict-icon"
"\">Icon</link></emphasis>"
msgstr ""
"एक हाइलाइट किया गया<emphasis role=\"bold\"><link linkend=\"visualdict-icon"
"\"> आइकन</link></emphasis>"

#. Tag: para
#: ui.docbook:146
#, no-c-format
msgid ""
"A <emphasis role=\"bold\"><link linkend=\"visualdict-context-menu\">Context "
"Menu</link></emphasis> listing actions that can be performed on a file"
msgstr ""
"ए<emphasis role=\"bold\"><link linkend=\"visualdict-context-menu\"> संदर्भ मेनू</"
"link></emphasis> किसी फ़ाइल पर निष्पादित की जा सकने वाली क्रियाओं की सूची बनाना"

#. Tag: para
#: ui.docbook:151
#, no-c-format
msgid ""
"A <emphasis role=\"bold\"><link linkend=\"visualdict-slider\">Slider</link></"
"emphasis> that changes the size of the <link linkend=\"visualdict-icon"
"\">Icons</link> displayed"
msgstr ""
"ए<emphasis role=\"bold\"><link linkend=\"visualdict-slider\"> स्लाइडर</link></"
"emphasis> जो आकार बदलता है<link linkend=\"visualdict-icon\"> माउस</link> "
"दिखाया"

#. Tag: para
#: ui.docbook:157
#, no-c-format
msgid ""
"More <emphasis role=\"bold\"><link linkend=\"visualdict-panel\">Panels</"
"link></emphasis>"
msgstr ""
"अधिक<emphasis role=\"bold\"><link linkend=\"visualdict-panel\"> पैनलों</link></"
"emphasis>"

