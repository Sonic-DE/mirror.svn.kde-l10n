#. Tag: para
#: ui.docbook:235
#, no-c-format
msgid ""
"A <emphasis role=\"bold\"><link linkend=\"visualdict-tree-view\">Tree View</"
"link></emphasis>"
msgstr ""
"ए<emphasis role=\"bold\"><link linkend=\"visualdict-tree-view\"> वृक्ष दृश्य</"
"link></emphasis>"

#. Tag: para
#: ui.docbook:239
#, no-c-format
msgid ""
"A <emphasis role=\"bold\"><link linkend=\"visualdict-check-box\">Check Box</"
"link></emphasis> that has been selected"
msgstr ""
