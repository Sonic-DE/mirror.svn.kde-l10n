#. Tag: glossterm
#: index.docbook:113
#, no-c-format
msgid "GHNS"
msgstr "जीएचएनएस"

#. Tag: para
#: index.docbook:114
#, no-c-format
msgid "<acronym>GHNS</acronym> is the acronym of Get Hot New Stuff."
msgstr "<acronym>GHNS</acronym> गेट हॉट न्यू स्टफ का संक्षिप्त रूप है।"

#. Tag: glossseealso
#: index.docbook:115
#, no-c-format
