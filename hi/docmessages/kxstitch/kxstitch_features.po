#. Tag: title
#: features.docbook:2
#, no-c-format
msgid "Features"
msgstr "विशेषताएँ"

#. Tag: para
#: features.docbook:3
#, no-c-format
msgid "The current feature list and other planned features is shown here."
msgstr "वर्तमान फीचर सूची और अन्य नियोजित फीचर यहां दर्शाए गए हैं।"

#. Tag: para
#: features.docbook:5
#, no-c-format
msgid "Creation of new patterns"
msgstr "नये पैटर्न का निर्माण"

#. Tag: para
#: features.docbook:7
#, no-c-format
msgid "User defined size"
msgstr "उपयोगकर्ता परिभाषित आकार"

#. Tag: para
#: features.docbook:8
#, no-c-format
msgid "Selection of material color"
msgstr "सामग्री के रंग का चयन"

#. Tag: para
#: features.docbook:9
#, no-c-format
msgid "Insertion of a background images for tracing"
msgstr "ट्रेसिंग के लिए पृष्ठभूमि छवियाँ सम्मिलित करना"

#. Tag: para
#: features.docbook:10
#, no-c-format
msgid "Importing of various image formats"
msgstr "विभिन्न छवि प्रारूपों का आयात"

#. Tag: para
#: features.docbook:11
#, no-c-format
msgid "Importing options allow"
msgstr "आयात विकल्प की अनुमति दें"

#. Tag: para
#: features.docbook:13
#, no-c-format
msgid "Limiting the number of colors"
msgstr "रंगों की संख्या सीमित करना"

#. Tag: para
#: features.docbook:14
#, no-c-format
msgid "Limiting colors to a specific palette"
msgstr "रंगों को एक विशिष्ट पैलेट तक सीमित करना"

#. Tag: para
#: features.docbook:15
#, no-c-format
msgid "Scaling to a finished size"
msgstr "पूर्ण आकार तक स्केलिंग"

#. Tag: para
#: features.docbook:16
#, no-c-format
msgid "Support for transparency in images"
msgstr "छवियों में पारदर्शिता के लिए समर्थन"

#. Tag: para
#: features.docbook:17
#, no-c-format
msgid "Allow the use of fractional stitches"
msgstr "आंशिक टांकों के उपयोग की अनुमति दें"

#. Tag: para
#: features.docbook:22
#, no-c-format
msgid "Editing of existing patterns, Editing tools will include"
msgstr "मौजूदा पैटर्न का संपादन, संपादन उपकरण शामिल होंगे"

#. Tag: para
#: features.docbook:24
#, no-c-format
msgid "Open and filled rectangles"
msgstr "खुले और भरे हुए आयत"

#. Tag: para
#: features.docbook:25
#, no-c-format
msgid "Open and filled ellipses"
msgstr "खुले और भरे हुए दीर्घवृत्त"

#. Tag: para
#: features.docbook:26
#, no-c-format
msgid "Filled polygons"
msgstr "भरे हुए बहुभुज"

#. Tag: para
#: features.docbook:27
#, no-c-format
msgid "Painting"
msgstr "चित्रकारी"

#. Tag: para
#: features.docbook:28
#, no-c-format
msgid "Lines"
msgstr "पंक्तियां"

#. Tag: para
#: features.docbook:29
#, no-c-format
msgid "Erasing stitches, knots and backstitches"
msgstr "टाँके, गांठें और पिछली टाँके मिटाना"

#. Tag: para
#: features.docbook:30
#, no-c-format
msgid "Color selection from existing stitches"
msgstr "मौजूदा टांकों से रंग का चयन"

#. Tag: para
#: features.docbook:31
#, no-c-format
msgid "Swapping two colors"
msgstr "दो रंगों की अदला-बदली"

#. Tag: para
#: features.docbook:32
#, no-c-format
msgid "Replace one color with another"
msgstr "एक रंग को दूसरे से बदलें"

#. Tag: para
#: features.docbook:33
#, no-c-format
msgid "Text with user defined fonts and sizes"
msgstr "उपयोगकर्ता द्वारा निर्धारित फ़ॉन्ट और आकार वाला पाठ"

#. Tag: para
#: features.docbook:34
#, no-c-format
msgid "Cut, copy and paste of rectangular areas."
msgstr "आयताकार क्षेत्रों को काटें, कॉपी करें और पेस्ट करें।"

#. Tag: para
#: features.docbook:35
#, no-c-format
msgid "Unlimited undo and redo"
msgstr "असीमित पूर्ववत और पुनः करें"

#. Tag: para
#: features.docbook:36
#, no-c-format
msgid "Mirroring, horizontally and vertically."
msgstr "क्षैतिज और ऊर्ध्वाधर रूप से मिररिंग।"

#. Tag: para
#: features.docbook:37
#, no-c-format
msgid "Rotation, 90, 180 and 270 degrees anti clockwise."
msgstr "घूर्णन, 90, 180 और 270 डिग्री वामावर्त।"

#. Tag: para
#: features.docbook:38
#, no-c-format
msgid "Resizing of the canvas"
msgstr "कैनवास का आकार बदलना"

#. Tag: para
#: features.docbook:40
#, no-c-format
msgid "Extend canvas left, top, right, bottom"
msgstr "कैनवास को बाएँ, ऊपर, दाएँ, नीचे बढ़ाएँ"

#. Tag: para
#: features.docbook:41
#, no-c-format
msgid "Cropping canvas to pattern"
msgstr "पैटर्न के अनुसार कैनवास को काटना"

#. Tag: para
#: features.docbook:42
#, no-c-format
msgid "Cropping canvas to selection"
msgstr "चयन के लिए कैनवास को क्रॉप करना"

#. Tag: para
#: features.docbook:43
#, no-c-format
msgid "Inserting rows and columns"
msgstr "पंक्तियाँ और कॉलम सम्मिलित करना"

#. Tag: para
#: features.docbook:44
#, no-c-format
msgid "Center the pattern on the canvas"
msgstr "पैटर्न को कैनवास पर केन्द्रित करें"

#. Tag: para
#: features.docbook:47
#, no-c-format
msgid "Conversion between floss schemes"
msgstr "फ़्लॉस योजनाओं के बीच रूपांतरण"

#. Tag: para
#: features.docbook:50
#, no-c-format
msgid "Use of standard floss pallets, DMC, Anchor, etc."
msgstr "मानक फ्लॉस पैलेट, डीएमसी, एंकर आदि का उपयोग।"

#. Tag: para
#: features.docbook:51
#, no-c-format
msgid "Create customized floss pallets"
msgstr "अनुकूलित फ़्लॉस पैलेट बनाएं"

#. Tag: para
#: features.docbook:52
#, no-c-format
msgid "Create new colors for any floss pallet"
msgstr "किसी भी फ़्लॉस पैलेट के लिए नए रंग बनाएं"

#. Tag: para
#: features.docbook:53
#, no-c-format
msgid "Save / Load current palette"
msgstr "वर्तमान पैलेट सहेजें / लोड करें"

#. Tag: para
#: features.docbook:54
#, no-c-format
msgid "Use of standard stitches"
msgstr "मानक टांकों का उपयोग"

#. Tag: para
#: features.docbook:55
#, no-c-format
msgid "Pattern library manager"
msgstr "पैटर्न लाइब्रेरी प्रबंधक"

#. Tag: para
#: features.docbook:57
#, no-c-format
msgid "Create new library patterns"
msgstr "नए लाइब्रेरी पैटर्न बनाएं"

#. Tag: para
#: features.docbook:58
#, no-c-format
msgid "Insert library patterns into a design"
msgstr "डिज़ाइन में लाइब्रेरी पैटर्न डालें"

#. Tag: para
#: features.docbook:59
#, no-c-format
msgid "Drag and drop from the library to the pattern"
msgstr "लाइब्रेरी से पैटर्न तक खींचें और छोड़ें"

#. Tag: para
#: features.docbook:60
#, no-c-format
msgid "Drag and drop from one library to another"
msgstr "एक लाइब्रेरी से दूसरी लाइब्रेरी में खींचें और छोड़ें"

#. Tag: para
#: features.docbook:61
#, no-c-format
msgid "Assign key press to patterns for use with the Alphabet tool"
msgstr "वर्णमाला टूल के साथ उपयोग के लिए पैटर्न को कुंजी प्रेस असाइन करें"

#. Tag: para
#: features.docbook:64
#, no-c-format
msgid "Free use of backstitching"
msgstr "बैकस्टिचिंग का निःशुल्क उपयोग"

#. Tag: para
#: features.docbook:65
#, no-c-format
msgid "Printing of completed patterns and floss keys"
msgstr "पूर्ण पैटर्न और फ़्लॉस कुंजियों का मुद्रण"

#. Tag: para
#: features.docbook:67
#, no-c-format
msgid "Pattern image"
msgstr "पैटर्न छवि"

#. Tag: para
#: features.docbook:68
#, no-c-format
msgid "Instructions"
msgstr "निर्देश"

#. Tag: para
#: features.docbook:69
#, no-c-format
msgid "Floss key and stitch summary"
msgstr "फ्लॉस कुंजी और सिलाई सारांश"

#. Tag: para
#: features.docbook:70
#, no-c-format
msgid "Pattern chart with page map"
msgstr "पृष्ठ मानचित्र के साथ पैटर्न चार्ट"

#. Tag: para
#: features.docbook:71
#, no-c-format
msgid "Text boxes"
msgstr "पाठ बॉक्स"

#. Tag: para
#: features.docbook:74
#, no-c-format
msgid "Mapping of symbols to flosses"
msgstr "प्रतीकों का फ्लॉस से मानचित्रण"

#. Tag: para
#: features.docbook:75
#, no-c-format
msgid "Specify the number of threads for stitches and backstitches"
msgstr "टांकों और बैकस्टिच के लिए धागों की संख्या निर्दिष्ट करें"

#. Tag: para
#: features.docbook:76
#, no-c-format
msgid "Calibration of floss colors"
msgstr "फ़्लॉस रंगों का अंशांकन"

#. Tag: para
#: features.docbook:78
#, no-c-format
msgid ""
"Requests for new features can be made to the <ulink url=\"http://bugs.kde.org"
"\">KDE Bugtracking System</ulink>"
msgstr ""
"नई सुविधाओं के लिए अनुरोध <ulink url=\"http://bugs.kde.org\">केडीई बगट्रैकिंग सिस्टम</"
"ulink> से किया जा सकता है"
