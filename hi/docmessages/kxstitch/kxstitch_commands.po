#. Tag: title
#: commands.docbook:2
#, no-c-format
msgid "Command Reference"
msgstr "कमांड संदर्भ"

#. Tag: title
#: commands.docbook:5
#, no-c-format
msgid "&kxstitch; Menus"
msgstr "&kxstitch; मेनू"

#. Tag: title
#: commands.docbook:7
#, no-c-format
msgid "The File Menu"
msgstr "फ़ाइल मेनू"

#. Tag: menuchoice
#: commands.docbook:11
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>N</keycap></keycombo></"
"shortcut><guimenuitem>New</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>N</keycap></keycombo></"
"shortcut><guimenuitem>नया</guimenuitem>"

#. Tag: action
#: commands.docbook:12
#, no-c-format
msgid ""
"Creates a new pattern, using the default values set in the pattern "
"properties dialog."
msgstr "पैटर्न गुण संवाद में निर्धारित डिफ़ॉल्ट मानों का उपयोग करके एक नया पैटर्न बनाता है।"

#. Tag: menuchoice
#: commands.docbook:15
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>O</keycap></keycombo></"
"shortcut><guimenuitem>Open</guimenuitem>"
msgstr ""
"<शॉर्टकट><कीकॉम्बो एक्शन='सिमुल'>&Ctrl;<कीकैप>ओ</कीकैप></कीकॉम्बो></"
"शॉर्टकट><गुइमेनुइटम>ओपन</गुइमेनुइटम>"

#. Tag: action
#: commands.docbook:16
#, no-c-format
msgid "Opens an existing pattern"
msgstr "मौजूदा पैटर्न खोलता है"

#. Tag: guimenuitem
#: commands.docbook:19
#, no-c-format
msgid "Open Recent"
msgstr "हाल ही वाला खोलें"

#. Tag: action
#: commands.docbook:20
#, no-c-format
msgid "Open a recently used pattern"
msgstr "हाल ही में उपयोग किया गया पैटर्न खोलें"

#. Tag: menuchoice
#: commands.docbook:23
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>S</keycap></keycombo></"
"shortcut><guimenuitem>Save</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>S</keycap></keycombo></"
"shortcut><guimenuitem>सहेजें</guimenuitem>"

#. Tag: action
#: commands.docbook:24
#, no-c-format
msgid "Saves the pattern"
msgstr "पैटर्न सहेजता है"

#. Tag: menuchoice
#: commands.docbook:27
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;&Shift;<keycap>S</keycap></"
"keycombo></shortcut><guimenuitem>Save As</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;&Shift;<keycap>S</keycap></"
"keycombo></shortcut><guimenuitem>इस रूप में सहेजें</guimenuitem>"

#. Tag: action
#: commands.docbook:28
#, no-c-format
msgid "Saves the pattern under a new name"
msgstr "पैटर्न को नए नाम से सहेजता है"

#. Tag: guimenuitem
#: commands.docbook:31
#, no-c-format
msgid "Revert"
msgstr "फिर लौट आना"

#. Tag: action
#: commands.docbook:32
#, no-c-format
msgid "Revert the pattern to the last saved state"
msgstr "पैटर्न को अंतिम सहेजी गई स्थिति पर वापस लाएं"

#. Tag: menuchoice
#: commands.docbook:35
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>P</keycap></keycombo></"
"shortcut><guimenuitem>Print</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>P</keycap></keycombo></"
"shortcut><guimenuitem>प्रिंट</guimenuitem>"

#. Tag: action
#: commands.docbook:36
#, no-c-format
msgid "Print the pattern"
msgstr "पैटर्न प्रिंट करें"

#. Tag: guimenuitem
#: commands.docbook:39
#, no-c-format
msgid "Print Setup"
msgstr "प्रिंट सेटअप"

#. Tag: action
#: commands.docbook:40
#, no-c-format
msgid "Set up the printing layout"
msgstr "प्रिंटिंग लेआउट सेट करें"

#. Tag: guimenuitem
#: commands.docbook:43
#, no-c-format
msgid "Import Image"
msgstr "छवि आयात करें"

#. Tag: action
#: commands.docbook:44
#, no-c-format
msgid "Import an image file converting it to stitches"
msgstr "छवि फ़ाइल को स्टिच में परिवर्तित करके आयात करें"

#. Tag: guimenuitem
#: commands.docbook:47
#, no-c-format
msgid "File Properties"
msgstr "फ़ाइल गुण"

#. Tag: action
#: commands.docbook:48
#, no-c-format
msgid "Display / Edit the document properties"
msgstr "दस्तावेज़ गुण प्रदर्शित करें / संपादित करें"

#. Tag: guimenuitem
#: commands.docbook:51
#, no-c-format
msgid "Add Background Image"
msgstr "पृष्ठभूमि छवि जोड़ें"

#. Tag: action
#: commands.docbook:52
#, no-c-format
msgid "Insert an image as a background for tracing."
msgstr "ट्रेसिंग के लिए पृष्ठभूमि के रूप में एक छवि डालें।"

#. Tag: guimenuitem
#: commands.docbook:55
#, no-c-format
msgid "Remove Background Image"
msgstr "पृष्ठभूमि छवि हटाएँ"

#. Tag: action
#: commands.docbook:56
#, no-c-format
msgid ""
"Select a background image to remove. The sub menu for this is populated from "
"the background images previously inserted."
msgstr ""
"हटाने के लिए एक पृष्ठभूमि छवि चुनें। इसके लिए उप मेनू पहले डाली गई पृष्ठभूमि छवियों से भरा हुआ "
"है।"

#. Tag: menuchoice
#: commands.docbook:59
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>W</keycap></keycombo></"
"shortcut><guimenuitem>Close</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>W</keycap></keycombo></"
"shortcut><guimenuitem>बंद करें</guimenuitem>"

#. Tag: action
#: commands.docbook:60
#, no-c-format
msgid "Close the pattern"
msgstr "पैटर्न बंद करें"

#. Tag: menuchoice
#: commands.docbook:63
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>Q</keycap></keycombo></"
"shortcut><guimenuitem>Quit</guimenuitem>"
msgstr ""
"<shortcut><keycombo Action='simul'>&Ctrl;<keycap>Q</keycap></keycombo></"
"shortcut><guimenuitem>छोड़ें</guimenuitem>"

#. Tag: simpara
#: commands.docbook:64
#, no-c-format
msgid "<action>Quits</action> &kxstitch;"
msgstr "<action>छोड़ता है</action> &kxstitch;"

#. Tag: title
#: commands.docbook:71
#, no-c-format
msgid "The Edit Menu"
msgstr "संपादन मेनू"

#. Tag: menuchoice
#: commands.docbook:75
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>Z</keycap></keycombo></"
"shortcut><guimenuitem>Undo</guimenuitem>"
msgstr ""
"<shortcut><keycombo Action='simul'>&Ctrl;<keycap>Z</keycap></keycombo></"
"shortcut><guimenuitem>पूर्ववत करें</guimenuitem>"

#. Tag: action
#: commands.docbook:76
#, no-c-format
msgid ""
"Undo the last change. The list of changes are shown in the History window."
msgstr "अंतिम परिवर्तन पूर्ववत करें: परिवर्तनों की सूची इतिहास विंडो में दिखाई जाती है।"

#. Tag: menuchoice
#: commands.docbook:79
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;&Shift;<keycap>Z</keycap></"
"keycombo></shortcut><guimenuitem>Redo</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;&Shift;<keycap>Z</keycap></"
"keycombo></shortcut><guimenuitem>फिर से करें</guimenuitem>"

#. Tag: action
#: commands.docbook:80
#, no-c-format
msgid ""
"Redo the last change undone. The list of changes are shown in the History "
"window."
msgstr "पिछले परिवर्तन को पूर्ववत करें। परिवर्तनों की सूची इतिहास विंडो में दिखाई जाती है।"

#. Tag: menuchoice
#: commands.docbook:83
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>X</keycap></keycombo></"
"shortcut><guimenuitem>Cut</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>X</keycap></keycombo></"
"shortcut><guimenuitem>कट</guimenuitem>"

#. Tag: action
#: commands.docbook:84
#, no-c-format
msgid "Cut the selected area to the clipboard"
msgstr "चयनित क्षेत्र को क्लिपबोर्ड पर काटें"

#. Tag: menuchoice
#: commands.docbook:87
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>C</keycap></keycombo></"
"shortcut><guimenuitem>Copy</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>C</keycap></keycombo></"
"shortcut><guimenuitem>कॉपी करें</guimenuitem>"

#. Tag: action
#: commands.docbook:88
#, no-c-format
msgid "Copy the selected area to the clipboard"
msgstr "चयनित क्षेत्र को क्लिपबोर्ड पर कॉपी करें"

#. Tag: menuchoice
#: commands.docbook:91
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>V</keycap></keycombo></"
"shortcut><guimenuitem>Paste</guimenuitem>"
msgstr ""
"<shortcut><keycombo Action='simul'>&Ctrl;<keycap>V</keycap></keycombo></"
"shortcut><guimenuitem>पेस्ट</guimenuitem>"

#. Tag: action
#: commands.docbook:92
#, no-c-format
msgid "Paste the selected area"
msgstr "चयनित क्षेत्र चिपकाएँ"

#. Tag: menuchoice
#: commands.docbook:95
#, no-c-format
msgid ""
"<guisubmenu>Selection Masks</guisubmenu><guimenuitem>Stitch Mask</"
"guimenuitem>"
msgstr "<guisubmenu>चयन मास्क</guisubmenu><guimenuitem>सिलाई मास्क</guimenuitem>"

#. Tag: action
#: commands.docbook:96
#, no-c-format
msgid "Limit selections to the currently selected stitch type"
msgstr "चयन को वर्तमान में चयनित सिलाई प्रकार तक सीमित करें"

#. Tag: menuchoice
#: commands.docbook:99
#, no-c-format
msgid ""
"<guisubmenu>Selection Masks</guisubmenu><guimenuitem>Color Mask</guimenuitem>"
msgstr "<guisubmenu>चयन मास्क</guisubmenu><guimenuitem>रंग मास्क</guimenuitem>"

#. Tag: action
#: commands.docbook:100
#, no-c-format
msgid "Limit selections to the currently selected color"
msgstr "चयन को वर्तमान में चयनित रंग तक सीमित करें"

#. Tag: menuchoice
#: commands.docbook:102
#, no-c-format
msgid ""
"<guisubmenu>Selection Masks</guisubmenu><guimenuitem>Exclude Backstitches</"
"guimenuitem>"
msgstr ""
"<guisubmenu>चयन मास्क</guisubmenu><guimenuitem>बैकस्टिच को बाहर करें</guimenuitem>"

#. Tag: action
#: commands.docbook:103
#, no-c-format
msgid "Exclude backstitches from the selection"
msgstr "चयन से बैकस्टिच को बाहर रखें"

#. Tag: menuchoice
#: commands.docbook:106
#, no-c-format
msgid ""
"<guisubmenu>Selection Masks</guisubmenu><guimenuitem>Exclude Knots</"
"guimenuitem>"
msgstr "<guisubmenu>चयन मास्क</guisubmenu><guimenuitem>गांठें निकालें</guimenuitem>"

#. Tag: action
#: commands.docbook:107
#, no-c-format
msgid "Exclude Knots from the selection"
msgstr "नॉट्स को चयन से बाहर रखें"

#. Tag: guimenuitem
#: commands.docbook:110
#, no-c-format
msgid "Mirror / Rotate makes copies"
msgstr "मिरर / रोटेट प्रतिलिपियाँ बनाता है"

#. Tag: action
#: commands.docbook:111
#, no-c-format
msgid ""
"If set, the mirror and rotate functions will make a copy of the selection, "
"otherwise the selected area is moved"
msgstr ""
"यदि सेट किया गया है, तो मिरर और रोटेट फ़ंक्शन चयन की प्रतिलिपि बना देंगे, अन्यथा चयनित "
"क्षेत्र को स्थानांतरित कर दिया जाएगा"

#. Tag: menuchoice
#: commands.docbook:114
#, no-c-format
msgid ""
"<guisubmenu>Mirror Selection</guisubmenu><guimenuitem>Horizontally</"
"guimenuitem>"
msgstr "<guisubmenu>मिरर चयन</guisubmenu><guimenuitem>क्षैतिज रूप से</guimenuitem>"

#. Tag: action
#: commands.docbook:115
#, no-c-format
msgid "Mirror the selected area horizontally, &ie; flipped from left to right"
msgstr "चयनित क्षेत्र को क्षैतिज रूप से प्रतिबिम्बित करें, अर्थात बाएं से दाएं पलटें"

#. Tag: menuchoice
#: commands.docbook:118
#, no-c-format
msgid ""
"<guisubmenu>Mirror Selection</guisubmenu><guimenuitem>Vertically</"
"guimenuitem>"
msgstr "<guisubmenu>मिरर चयन</guisubmenu><guimenuitem>वर्टिकल</guimenuitem>"

#. Tag: action
#: commands.docbook:119
#, no-c-format
msgid "Mirrors the selected area vertically, &ie; flipped from top to bottom"
msgstr ""
"चयनित क्षेत्र को लंबवत रूप से प्रतिबिंबित करता है, अर्थात ऊपर से नीचे की ओर फ़्लिप करता है"

#. Tag: menuchoice
#: commands.docbook:122
#, no-c-format
msgid ""
"<guisubmenu>Rotate Selection</guisubmenu><guimenuitem>90 degrees</"
"guimenuitem>"
msgstr "<guisubmenu>चयन घुमाएँ</guisubmenu><guimenuitem>90 डिग्री</guimenuitem>"

#. Tag: action
#: commands.docbook:123
#, no-c-format
msgid "Rotate the selected area anti clockwise 90 degrees"
msgstr "चयनित क्षेत्र को वामावर्त 90 डिग्री घुमाएँ"

#. Tag: menuchoice
#: commands.docbook:126
#, no-c-format
msgid ""
"<guisubmenu>Rotate Selection</guisubmenu><guimenuitem>180 degrees</"
"guimenuitem>"
msgstr "<guisubmenu>चयन घुमाएँ</guisubmenu><guimenuitem>180 डिग्री</guimenuitem>"

#. Tag: action
#: commands.docbook:127
#, no-c-format
msgid "Rotate the selected area anti clockwise 180 degrees"
msgstr "चयनित क्षेत्र को वामावर्त 180 डिग्री घुमाएँ"

#. Tag: menuchoice
#: commands.docbook:130
#, no-c-format
msgid ""
"<guisubmenu>Rotate Selection</guisubmenu><guimenuitem>270 degrees</"
"guimenuitem>"
msgstr "<guisubmenu>चयन घुमाएँ</guisubmenu><guimenuitem>270 डिग्री</guimenuitem>"

#. Tag: action
#: commands.docbook:131
#, no-c-format
msgid "Rotate the selected area anti clockwise 270 degrees"
msgstr "चयनित क्षेत्र को वामावर्त 270 डिग्री घुमाएँ"

#. Tag: title
#: commands.docbook:136
#, no-c-format
msgid "Cut, Copy and Paste"
msgstr "कट, कॉपी और पेस्ट"

#. Tag: para
#: commands.docbook:137
#, no-c-format
msgid ""
"Cutting and copying areas of the pattern can make use of stitch and color "
"masks and the exclusion of backstitches and knots to limit the selection."
msgstr ""
"पैटर्न के क्षेत्रों को काटने और कॉपी करने में सिलाई और रंग मास्क का उपयोग किया जा सकता है "
"और चयन को सीमित करने के लिए बैकस्टिच और गांठों को हटाया जा सकता है।"

#. Tag: para
#: commands.docbook:141
#, no-c-format
msgid ""
"The paste operation in &kxstitch; allows you to press and hold the &LMB; "
"down roughly in the position that the paste data is to go which will provide "
"an image of the paste data to allow accurate positioning before releasing "
"the mouse button to finalize the position. This technique is also used for "
"the mirroring and rotate functions. The cursor keys can also be used to move "
"the pasted pattern around and the &Enter; key used to fix the position."
msgstr ""
"&kxstitch; में पेस्ट ऑपरेशन आपको &LMB; को लगभग उस स्थिति में दबाकर रखने की अनुमति देता "
"है जहाँ पेस्ट डेटा जाना है जो पेस्ट डेटा की एक छवि प्रदान करेगा ताकि स्थिति को अंतिम रूप "
"देने के लिए माउस बटन को छोड़ने से पहले सटीक स्थिति की अनुमति मिल सके। इस तकनीक का "
"उपयोग मिररिंग और रोटेट फ़ंक्शन के लिए भी किया जाता है। कर्सर कुंजियों का उपयोग पेस्ट किए "
"गए पैटर्न को इधर-उधर ले जाने के लिए भी किया जा सकता है और &Enter; कुंजी का उपयोग "
"स्थिति को ठीक करने के लिए किया जाता है।"

#. Tag: title
#: commands.docbook:152
#, no-c-format
msgid "The View Menu"
msgstr "दृश्य मेनू"

#. Tag: guimenuitem
#: commands.docbook:156
#, no-c-format
msgid "Actual Size"
msgstr "वास्तविक आकार"

#. Tag: action
#: commands.docbook:157
#, no-c-format
msgid "Zoom the view so that the screen size approximates the physical size"
msgstr "दृश्य को ज़ूम करें ताकि स्क्रीन का आकार भौतिक आकार के लगभग बराबर हो जाए"

#. Tag: guimenuitem
#: commands.docbook:160
#, no-c-format
msgid "Fit To Page"
msgstr "पेज के लिए फिट"

#. Tag: action
#: commands.docbook:161
#, no-c-format
msgid "Zoom the view so that the whole pattern fits within the visible area"
msgstr "दृश्य को ज़ूम करें ताकि पूरा पैटर्न दृश्य क्षेत्र में फ़िट हो जाए"

#. Tag: guimenuitem
#: commands.docbook:164
#, no-c-format
msgid "Fit To Page Width"
msgstr "पेज की चौड़ाई के अनुसार फ़िट करें"

#. Tag: action
#: commands.docbook:165
#, no-c-format
msgid "Zoom the view so that the patterns width fits within the visible area"
msgstr "दृश्य को ज़ूम करें ताकि पैटर्न की चौड़ाई दृश्य क्षेत्र में फिट हो जाए"

#. Tag: guimenuitem
#: commands.docbook:168
#, no-c-format
msgid "Fit To Page Height"
msgstr "पेज की ऊंचाई पर फिट करें"

#. Tag: action
#: commands.docbook:169
#, no-c-format
msgid "Zoom the view so that the patterns height fits within the visible area"
msgstr "दृश्य को ज़ूम करें ताकि पैटर्न की ऊंचाई दृश्य क्षेत्र में फिट हो जाए"

#. Tag: menuchoice
#: commands.docbook:172
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>+</keycap></keycombo></"
"shortcut><guimenuitem>Zoom In</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>+</keycap></keycombo></"
"shortcut><guimenuitem>ज़ूम इन</guimenuitem>"

#. Tag: action
#: commands.docbook:173
#, no-c-format
msgid "Zoom in on the editor view"
msgstr "संपादक दृश्य पर ज़ूम इन करें"

#. Tag: menuchoice
#: commands.docbook:176
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>-</keycap></keycombo></"
"shortcut><guimenuitem>Zoom Out</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>-</keycap></keycombo></"
"shortcut><guimenuitem>ज़ूम आउट</guimenuitem>"

#. Tag: action
#: commands.docbook:177
#, no-c-format
msgid "Zoom out on the editor view"
msgstr "संपादक दृश्य पर ज़ूम आउट करें"

#. Tag: guimenuitem
#: commands.docbook:179
#, no-c-format
msgid "Preview"
msgstr "पूर्व दर्शन"

#. Tag: action
#: commands.docbook:180
#, no-c-format
msgid "Show or hide the preview window"
msgstr "पूर्वावलोकन विंडो दिखाएँ या छिपाएँ"

#. Tag: guimenuitem
#: commands.docbook:183
#, no-c-format
msgid "Palette"
msgstr "पैलेट"

#. Tag: action
#: commands.docbook:184
#, no-c-format
msgid "Show or hide the palette window"
msgstr "पैलेट विंडो दिखाएँ या छिपाएँ"

#. Tag: guimenuitem
#: commands.docbook:187
#, no-c-format
msgid "History"
msgstr "इतिहास"

#. Tag: action
#: commands.docbook:188
#, no-c-format
msgid "Show or hide the history window"
msgstr "इतिहास विंडो दिखाएँ या छिपाएँ"

#. Tag: guimenuitem
#: commands.docbook:191
#, no-c-format
msgid "Imported Image"
msgstr "आयातित छवि"

#. Tag: action
#: commands.docbook:192
#, no-c-format
msgid "Show or hide the imported image preview window"
msgstr "आयातित छवि पूर्वावलोकन विंडो दिखाएँ या छिपाएँ"

#. Tag: guimenuitem
#: commands.docbook:195
#, no-c-format
msgid "Show Background Image"
msgstr "पृष्ठभूमि छवि दिखाएं"

#. Tag: action
#: commands.docbook:196
#, no-c-format
msgid ""
"Show or hide a background image. The list is generated dynamically based on "
"the inserted background images"
msgstr ""
"पृष्ठभूमि छवि दिखाएँ या छिपाएँ। सूची डाली गई पृष्ठभूमि छवियों के आधार पर गतिशील रूप से "
"बनाई जाती है"

#. Tag: guimenuitem
#: commands.docbook:199
#, no-c-format
msgid "Fit Background Image to Selection"
msgstr "पृष्ठभूमि छवि को चयन में फ़िट करें"

#. Tag: action
#: commands.docbook:200
#, no-c-format
msgid "Fit the selected background image to the current selection area"
msgstr "चयनित पृष्ठभूमि छवि को वर्तमान चयन क्षेत्र में फ़िट करें"

#. Tag: title
#: commands.docbook:207
#, no-c-format
msgid "The Stitches Menu"
msgstr "टाँके मेनू"

#. Tag: guimenuitem
#: commands.docbook:211
#, no-c-format
msgid "Quarter Stitch"
msgstr "क्वार्टर सिलाई"

#. Tag: action
#: commands.docbook:212
#, no-c-format
msgid ""
"Quarter Stitch, the position is determined by the quadrant of the cell "
"selected"
msgstr "क्वार्टर स्टिच, स्थिति चयनित सेल के चतुर्थांश द्वारा निर्धारित की जाती है"

#. Tag: guimenuitem
#: commands.docbook:215
#, no-c-format
msgid "Half Stitch"
msgstr "आधा सिलाई"

#. Tag: action
#: commands.docbook:216
#, no-c-format
msgid ""
"Half Stitch, the direction is determined by the quadrant of the cell selected"
msgstr "हाफ स्टिच, दिशा चयनित सेल के चतुर्थांश द्वारा निर्धारित की जाती है"

#. Tag: guimenuitem
#: commands.docbook:219
#, no-c-format
msgid "3 Quarter Stitch"
msgstr "3 क्वार्टर सिलाई"

#. Tag: action
#: commands.docbook:221
#, no-c-format
msgid ""
"Three Quarter Stitch, the orientation is determined by the quadrant of the "
"cell selected"
msgstr ""
"तीन चौथाई सिलाई, अभिविन्यास चयनित सेल के चतुर्थांश द्वारा निर्धारित किया जाता है"

#. Tag: guimenuitem
#: commands.docbook:224
#, no-c-format
msgid "<guimenuitem>Full Stitch</guimenuitem>"
msgstr "<guimenuitem>पूर्ण सिलाई</guimenuitem>"

#. Tag: action
#: commands.docbook:225
#, no-c-format
msgid "<action>Full Stitch</action>"
msgstr "<action>पूर्ण सिलाई</action>"

#. Tag: guimenuitem
#: commands.docbook:228
#, no-c-format
msgid "Small Half Stitch"
msgstr "छोटी आधी सिलाई"

#. Tag: action
#: commands.docbook:229
#, no-c-format
msgid ""
"A small half stitch, the position is determined by the quadrant of the cell "
"selected"
msgstr "एक छोटी सी आधी सिलाई, स्थिति चयनित सेल के चतुर्थांश द्वारा निर्धारित की जाती है"

#. Tag: guimenuitem
#: commands.docbook:232
#, no-c-format
msgid "Small Full Stitch"
msgstr "छोटी पूरी सिलाई"

#. Tag: action
#: commands.docbook:233
#, no-c-format
msgid ""
"A small full stitch, the position is determined by the quadrant of the cell "
"selected"
msgstr "एक छोटी सी पूरी सिलाई, स्थिति चयनित सेल के चतुर्थांश द्वारा निर्धारित की जाती है"

#. Tag: guimenuitem
#: commands.docbook:236
#, no-c-format
msgid "French Knot"
msgstr "फ्रेंच नॉट"

#. Tag: action
#: commands.docbook:237
#, no-c-format
msgid "French Knot Stitch"
msgstr "फ्रेंच नॉट सिलाई"

#. Tag: title
#: commands.docbook:244
#, no-c-format
msgid "The Tools Menu"
msgstr "उपकरण मेनू"

#. Tag: guimenuitem
#: commands.docbook:248
#, no-c-format
msgid "Paint"
msgstr "रँगना"

#. Tag: action
#: commands.docbook:249
#, no-c-format
msgid ""
"Paint stitches onto the canvas - Press down the &LMB; and drag around the "
"window. Stitches will be added to each cell passed over. Release the mouse "
"button to stop painting."
msgstr ""
"कैनवास पर टाँके पेंट करें - &LMB; को दबाएँ और विंडो के चारों ओर खींचें। प्रत्येक सेल पर टाँके "
"जोड़े जाएँगे। पेंटिंग रोकने के लिए माउस बटन छोड़ें।"

#. Tag: guimenuitem
#: commands.docbook:255
#, no-c-format
msgid "Draw"
msgstr "खींचना"

#. Tag: action
#: commands.docbook:256
#, no-c-format
msgid ""
"Draw a line of stitches onto the canvas - Press down the &LMB; at the start "
"of the line, drag to the required end point of the line and release the "
"mouse button. Stitches will be added to each cell that the line passes "
"through."
msgstr ""
"कैनवास पर टांकों की एक रेखा खींचें - रेखा की शुरुआत में &LMB; दबाएं, रेखा के वांछित अंतिम बिंदु "
"तक खींचें और माउस बटन छोड़ दें। रेखा जिस भी सेल से होकर गुज़रेगी, उसमें टांके जुड़ जाएँगे।"

#. Tag: guimenuitem
#: commands.docbook:263
#, no-c-format
msgid "Erase"
msgstr "मिटाएं"

#. Tag: action
#: commands.docbook:264
#, no-c-format
msgid ""
"Erase stitches - Press down the &LMB; and drag over the stitches to be "
"deleted. All stitches within the cells passed over will be removed. Release "
"the mouse button to stop erasing. To erase backstitches hold down the &Ctrl; "
"key and left click in the start or end point of the backstitch, if there is "
"more than one backstitch at the digitized point this method will erase the "
"first one found. To delete a specific backstitch, click and drag from one "
"end to the other. To erase french knots hold down the &Shift; key and left "
"click on the knot to delete it."
msgstr ""
"टांके मिटाएँ - &LMB; को दबाएँ और हटाए जाने वाले टांकों पर खींचें। कोशिकाओं के अंदर के सभी "
"टांके हटा दिए जाएँगे। मिटाना बंद करने के लिए माउस बटन को छोड़ दें। बैकस्टिच मिटाने के लिए "
"&Ctrl; कुंजी को दबाए रखें और बैकस्टिच के आरंभ या अंत बिंदु पर बायाँ क्लिक करें, यदि "
"डिजिटाइज़ किए गए बिंदु पर एक से अधिक बैकस्टिच हैं, तो यह विधि पहले पाए गए बैकस्टिच को "
"मिटा देगी। किसी विशिष्ट बैकस्टिच को मिटाने के लिए, क्लिक करें और एक छोर से दूसरे छोर तक "
"खींचें। फ्रेंच नॉट्स मिटाने के लिए &Shift; कुंजी को दबाए रखें और इसे हटाने के लिए नॉट पर "
"बायाँ क्लिक करें।"

#. Tag: guimenuitem
#: commands.docbook:273
#, no-c-format
msgid "Draw Rectangle"
msgstr "आयत बनाएं"

#. Tag: action
#: commands.docbook:274
#, no-c-format
msgid ""
"Draw a rectangle - Press down the &LMB; at one corner of the rectangle and "
"drag to the opposite corner. Release the mouse button and an unfilled "
"rectangle of stitches will be added to the canvas."
msgstr ""
"एक आयत बनाएँ - आयत के एक कोने पर &LMB; दबाएँ और विपरीत कोने पर खींचें। माउस बटन छोड़ें "
"और टाँकों का एक खाली आयत कैनवास पर जुड़ जाएगा।"

#. Tag: guimenuitem
#: commands.docbook:281
#, no-c-format
msgid "Fill Rectangle"
msgstr "आयत भरें"

#. Tag: action
#: commands.docbook:282
#, no-c-format
msgid ""
"Draw a filled rectangle - Press down the &LMB; at one corner of the "
"rectangle and drag to the opposite corner. Release the mouse button and a "
"filled rectangle of stitches will be added to the canvas."
msgstr ""
"भरा हुआ आयत बनाएँ - आयत के एक कोने पर &LMB; दबाएँ और विपरीत कोने पर खींचें। माउस बटन "
"छोड़ें और टाँकों से भरा हुआ आयत कैनवास पर जुड़ जाएगा।"

#. Tag: guimenuitem
#: commands.docbook:288
#, no-c-format
msgid "Draw Ellipse"
msgstr "दीर्घवृत्त बनाएं"

#. Tag: action
#: commands.docbook:289
#, no-c-format
msgid ""
"Draw an ellipse - Press down the &LMB; at one corner of the ellipse and drag "
"to the opposite corner. Release the mouse button and an unfilled ellipse of "
"stitches will be added to the canvas."
msgstr ""
"एक दीर्घवृत्त बनाएं - दीर्घवृत्त के एक कोने पर &LMB; दबाएं और विपरीत कोने पर खींचें। माउस "
"बटन छोड़ें और टांकों का एक खाली दीर्घवृत्त कैनवास पर जुड़ जाएगा।"

#. Tag: guimenuitem
#: commands.docbook:296
#, no-c-format
msgid "Fill Ellipse"
msgstr "दीर्घवृत्त भरें"

#. Tag: action
#: commands.docbook:297
#, no-c-format
msgid ""
"Draw a filled ellipse - Press down the &LMB; at one corner of the ellipse "
"and drag to the opposite corner. Release the mouse button and a filled "
"ellipse of stitches will be added to the canvas."
msgstr ""
"भरा हुआ दीर्घवृत्त बनाएं - दीर्घवृत्त के एक कोने पर &LMB; दबाएं और विपरीत कोने पर खींचें। "
"माउस बटन छोड़ें और टांकों का भरा हुआ दीर्घवृत्त कैनवास में जुड़ जाएगा।"

#. Tag: guimenuitem
#: commands.docbook:303
#, no-c-format
msgid "Fill Polygon"
msgstr "बहुभुज भरें"

#. Tag: action
#: commands.docbook:304
#, no-c-format
msgid ""
"Draw a filled polygon - Click on each cell marking the vertexes of the "
"polygon, click and drag to create more complex curves. Each of the vertexes "
"are marked by a circle with a black line joining them. To close the polygon "
"click on the starting cell again. You can use the &Backspace; key to remove "
"the last point, or the &Esc; key to remove all vertexes and cancel the "
"operation."
msgstr ""
"एक भरा हुआ बहुभुज बनाएं - बहुभुज के शीर्षों को चिह्नित करने वाले प्रत्येक सेल पर क्लिक करें, "
"अधिक जटिल वक्र बनाने के लिए क्लिक करें और खींचें। प्रत्येक शीर्ष को एक वृत्त द्वारा चिह्नित "
"किया जाता है जिसमें उन्हें जोड़ने वाली एक काली रेखा होती है। बहुभुज को बंद करने के लिए फिर "
"से आरंभिक सेल पर क्लिक करें। आप अंतिम बिंदु को हटाने के लिए &Backspace; कुंजी का उपयोग कर "
"सकते हैं, या सभी शीर्षों को हटाने और ऑपरेशन को रद्द करने के लिए &Esc; कुंजी का उपयोग कर "
"सकते हैं।"

#. Tag: guimenuitem
#: commands.docbook:312
#, no-c-format
msgid "Text"
msgstr "मूलपाठ"

#. Tag: action
#: commands.docbook:313
#, no-c-format
msgid ""
"Insert text in stitches. This invokes the text dialog. Select the font "
"required and the size, enter the text and click <guibutton>OK</guibutton>. "
"Press the &LMB; roughly where you would like the text, move the mouse to "
"position the text accurately and then release the mouse button. This is the "
"same as the paste function."
msgstr ""
"टांकों में टेक्स्ट डालें। यह टेक्स्ट डायलॉग को आमंत्रित करता है। आवश्यक फ़ॉन्ट और आकार का चयन "
"करें, टेक्स्ट दर्ज करें और <guibutton>OK</guibutton> पर क्लिक करें। &LMB; को लगभग उस "
"जगह दबाएँ जहाँ आप टेक्स्ट चाहते हैं, टेक्स्ट को सही स्थिति में रखने के लिए माउस को घुमाएँ और "
"फिर माउस बटन को छोड़ दें। यह पेस्ट फ़ंक्शन के समान ही है।"

#. Tag: guimenuitem
#: commands.docbook:320
#, no-c-format
msgid "Alphabet"
msgstr "वर्णमाला"

#. Tag: action
#: commands.docbook:321
#, no-c-format
msgid ""
"Insert patterns from the currently selected library that match the keys "
"pressed. This allows the creation of pattern alphabets that can have a key "
"assignment. After selecting this tool and clicking a position on the pattern "
"for the insertion point, each key pressed will be searched for in the "
"current library for a matching pattern. If found this will be inserted at "
"the position on the pattern and the insertion position then advanced by the "
"width of the inserted character pattern. The pattern space will be extended "
"right to allow further characters to be entered. Pressing &Enter; will start "
"a new line under the position of the original insertion point, the pattern "
"space will be extended downwards to accommodate the new line if insufficient "
"space is available. &Backspace; will delete the last character entered and "
"the <keycap>Space</keycap> key will advance the insertion point by either "
"the width of a space character in the library or a predetermined amount if "
"no space character exists. The text will wrap onto the next line if the edge "
"of the pattern is reached and the end of a word is detected."
msgstr ""
"वर्तमान में चयनित लाइब्रेरी से पैटर्न डालें जो दबाए गए कुंजियों से मेल खाते हों। यह पैटर्न "
"वर्णमाला के निर्माण की अनुमति देता है जिसमें कुंजी असाइनमेंट हो सकता है। इस उपकरण का चयन "
"करने और सम्मिलन बिंदु के लिए पैटर्न पर एक स्थिति पर क्लिक करने के बाद, दबाए गए प्रत्येक "
"कुंजी को वर्तमान लाइब्रेरी में एक मिलान पैटर्न के लिए खोजा जाएगा। यदि यह पाया जाता है "
"तो इसे पैटर्न पर स्थिति में डाला जाएगा और फिर सम्मिलित वर्ण पैटर्न की चौड़ाई से सम्मिलन "
"स्थिति को आगे बढ़ाया जाएगा। आगे के वर्णों को दर्ज करने की अनुमति देने के लिए पैटर्न स्थान को "
"दाईं ओर बढ़ाया जाएगा। &Enter; दबाने पर मूल सम्मिलन बिंदु की स्थिति के नीचे एक नई पंक्ति "
"शुरू होगी, यदि अपर्याप्त स्थान उपलब्ध है तो नई पंक्ति को समायोजित करने के लिए पैटर्न स्थान "
"को नीचे की ओर बढ़ाया जाएगा। &Backspace; दर्ज किए गए अंतिम वर्ण को हटा देगा और "
"<keycap>Space</keycap> कुंजी लाइब्रेरी में स्पेस वर्ण की चौड़ाई या यदि कोई स्पेस वर्ण "
"मौजूद नहीं है तो पूर्व निर्धारित राशि द्वारा सम्मिलन बिंदु को आगे बढ़ाएगी। यदि पैटर्न के "
"किनारे पर पहुँच जाता है और किसी शब्द का अंत पता चल जाता है तो पाठ अगली पंक्ति पर लपेट "
"जाएगा।"

#. Tag: guimenuitem
#: commands.docbook:336
#, no-c-format
msgid "Select"
msgstr "चुनना"

#. Tag: action
#: commands.docbook:337
#, no-c-format
msgid ""
"Select a rectangular region - Press down the &LMB; at one corner of the "
"rectangle, drag to the opposite corner and release the button. A selection "
"rectangle is shown to indicate the area."
msgstr ""
"आयताकार क्षेत्र चुनें - आयत के एक कोने पर &LMB; दबाएं, विपरीत कोने पर खींचें और बटन छोड़ "
"दें। क्षेत्र को इंगित करने के लिए एक चयन आयत दिखाया गया है।"

#. Tag: guimenuitem
#: commands.docbook:343
#, no-c-format
msgid "Color picker"
msgstr "रंग चुनने वाली मशीन"

#. Tag: action
#: commands.docbook:344
#, no-c-format
msgid ""
"Allows the selection of a color from the existing stitches. Hovering over "
"stitches will show a tool tip indicating the color under the cursor. "
"Clicking with the &LMB; will select it."
msgstr ""
"मौजूदा टांकों में से किसी रंग का चयन करने की अनुमति देता है। टांकों पर मँडराते समय कर्सर के "
"नीचे रंग को इंगित करने वाला एक टूल टिप दिखाई देगा। &LMB; के साथ क्लिक करने पर उसका "
"चयन हो जाएगा।"

#. Tag: guimenuitem
#: commands.docbook:350
#, no-c-format
msgid "Backstitch"
msgstr "टांका"

#. Tag: action
#: commands.docbook:351
#, no-c-format
msgid ""
"Add backstitching to the canvas - Press down the &LMB; at the start of the "
"backstitch, it will snap to the closest of 9 points in the cell, drag to the "
"end point of the backstitch and release the mouse button, again this will "
"snap to the nearest of 9 points in the cell."
msgstr ""
"कैनवास में बैकस्टिचिंग जोड़ें - बैकस्टिच के प्रारंभ में &LMB; दबाएं, यह सेल में 9 बिंदुओं में से "
"निकटतम पर स्नैप करेगा, बैकस्टिच के अंतिम बिंदु तक खींचें और माउस बटन छोड़ दें, यह फिर से सेल "
"में 9 बिंदुओं में से निकटतम पर स्नैप करेगा।"

#. Tag: title
#: commands.docbook:362
#, no-c-format
msgid "The Palette Menu"
msgstr "पैलेट मेनू"

#. Tag: guimenuitem
#: commands.docbook:366
#, no-c-format
msgid "Palette Manager"
msgstr "पैलेट प्रबंधक"

#. Tag: action
#: commands.docbook:367
#, no-c-format
msgid ""
"Add and remove colors to the current palette. Assign symbols and the number "
"of strands for the stitching and backstitching."
msgstr ""
"वर्तमान पैलेट में रंग जोड़ें और हटाएँ। सिलाई और बैकस्टिचिंग के लिए प्रतीक और धागों की संख्या "
"निर्दिष्ट करें।"

#. Tag: guimenuitem
#: commands.docbook:373
#, no-c-format
msgid "Show Symbols"
msgstr "प्रतीक दिखाएं"

#. Tag: action
#: commands.docbook:374
#, no-c-format
msgid "Show the symbols associated with each color"
msgstr "प्रत्येक रंग से जुड़े प्रतीक दिखाएँ"

#. Tag: guimenuitem
#: commands.docbook:376
#, no-c-format
msgid "Clear Unused"
msgstr "अप्रयुक्त साफ़ करें"

#. Tag: action
#: commands.docbook:377
#, no-c-format
msgid "Removes the unused colors from the palette."
msgstr "पैलेट से अप्रयुक्त रंगों को हटाता है।"

#. Tag: guimenuitem
#: commands.docbook:380
#, no-c-format
msgid "Swap Colors"
msgstr "रंग बदलें"

#. Tag: action
#: commands.docbook:381
#, no-c-format
msgid ""
"The next color selected will be swapped with the currently selected color. "
"If you select the eye dropper tool, you can choose the color to be swapped "
"with directly from the pattern."
msgstr ""
"अगला चयनित रंग वर्तमान में चयनित रंग के साथ बदल दिया जाएगा। यदि आप आई ड्रॉपर टूल चुनते "
"हैं, तो आप पैटर्न से सीधे स्वैप किए जाने वाले रंग को चुन सकते हैं।"

#. Tag: guimenuitem
#: commands.docbook:387
#, no-c-format
msgid "Replace Colors"
msgstr "रंग बदलें"

#. Tag: action
#: commands.docbook:388
#, no-c-format
msgid ""
"The next color selected will replace the currently selected color. As with "
"swap colors, you can use the eye dropper tool to select the color from the "
"pattern."
msgstr ""
"अगला चयनित रंग वर्तमान में चयनित रंग को प्रतिस्थापित कर देगा। स्वैप रंगों की तरह, आप "
"पैटर्न से रंग चुनने के लिए आई ड्रॉपर टूल का उपयोग कर सकते हैं।"

#. Tag: title
#: commands.docbook:398
#, no-c-format
msgid "The Library Menu"
msgstr "लाइब्रेरी मेनू"

#. Tag: guimenuitem
#: commands.docbook:402
#, no-c-format
msgid "Library Manager"
msgstr "पुस्तकालय प्रबंधक"

#. Tag: action
#: commands.docbook:403
#, no-c-format
msgid ""
"Open the pattern library manager which is a non modal dialog allowing the "
"creation and use of libraries of patterns or alphabets. Drag and drop is "
"available to allow the dragging and dropping of patterns from the library to "
"the pattern. Automatic conversion of flosses to suit the current pattern and "
"scaling of the image to the current pattern scale for accurate positioning."
msgstr ""
"पैटर्न लाइब्रेरी मैनेजर खोलें जो एक नॉन मोडल डायलॉग है जो पैटर्न या अल्फाबेट की लाइब्रेरी "
"बनाने और इस्तेमाल करने की अनुमति देता है। लाइब्रेरी से पैटर्न को पैटर्न में खींचने और छोड़ने की "
"अनुमति देने के लिए ड्रैग और ड्रॉप उपलब्ध है। वर्तमान पैटर्न के अनुरूप फ़्लॉस का स्वचालित "
"रूपांतरण और सटीक स्थिति के लिए वर्तमान पैटर्न स्केल पर छवि का स्केलिंग।"

#. Tag: title
#: commands.docbook:415
#, no-c-format
msgid "The Pattern Menu"
msgstr "पैटर्न मेनू"

#. Tag: guimenuitem
#: commands.docbook:419
#, no-c-format
msgid "Extend Pattern"
msgstr "पैटर्न का विस्तार करें"

#. Tag: action
#: commands.docbook:420
#, no-c-format
msgid "Extend the pattern top, left, right and bottom"
msgstr "पैटर्न को ऊपर, बाएं, दाएं और नीचे बढ़ाएं"

#. Tag: guimenuitem
#: commands.docbook:423
#, no-c-format
msgid "Center Pattern"
msgstr "केंद्र पैटर्न"

#. Tag: action
#: commands.docbook:424
#, no-c-format
msgid "Center the pattern in the canvas"
msgstr "पैटर्न को कैनवास के केंद्र में रखें"

#. Tag: guimenuitem
#: commands.docbook:427
#, no-c-format
msgid "Crop Canvas To Pattern"
msgstr "पैटर्न के लिए कैनवास क्रॉप करें"

#. Tag: action
#: commands.docbook:428
#, no-c-format
msgid "Crop the canvas to the extents of the pattern"
msgstr "पैटर्न की सीमा तक कैनवास को क्रॉप करें"

#. Tag: guimenuitem
#: commands.docbook:431
#, no-c-format
msgid "Crop Canvas To Selection"
msgstr "चयन के लिए कैनवास क्रॉप करें"

#. Tag: action
#: commands.docbook:432
#, no-c-format
msgid "Crop the canvas to the extents of the current selection"
msgstr "वर्तमान चयन की सीमा तक कैनवास को क्रॉप करें"

#. Tag: guimenuitem
#: commands.docbook:435
#, no-c-format
msgid "Insert Rows"
msgstr "पंक्तियाँ सम्मिलित करें"

#. Tag: action
#: commands.docbook:436
#, no-c-format
msgid "Insert a number of rows represented by a selection area"
msgstr "चयन क्षेत्र द्वारा दर्शाई गई कई पंक्तियाँ सम्मिलित करें"

#. Tag: guimenuitem
#: commands.docbook:439
#, no-c-format
msgid "Insert Columns"
msgstr "कॉलम डालें"

#. Tag: action
#: commands.docbook:440
#, no-c-format
msgid "Insert a number of columns represented by a selection area"
msgstr "चयन क्षेत्र द्वारा दर्शाए गए कई स्तंभ सम्मिलित करें"

#. Tag: title
#: commands.docbook:447
#, no-c-format
msgid "The Settings Menu"
msgstr "सेटिंग्स मेनू"

#. Tag: para
#: commands.docbook:448
#, no-c-format
msgid ""
"Apart from the common &kde; Settings menu entries described in the <ulink "
"url=\"help:/fundamentals/menus.html#menus-settings\"> Settings Menu</ulink> "
"chapter of the &kde; Fundamentals &kxstitch; has these application specific "
"menu entries:"
msgstr ""
"&kde; फंडामेंटल्स &kxstitch; के <ulink url=\"help:/fundamentals/menus.html#menus-"
"settings\"> सेटिंग्स मेनू</ulink> अध्याय में वर्णित सामान्य &kde; सेटिंग्स मेनू प्रविष्टियों के "
"अलावा, इसमें ये अनुप्रयोग विशिष्ट मेनू प्रविष्टियां भी हैं:"

#. Tag: guimenuitem
#: commands.docbook:454
#, no-c-format
msgid "Format Scales As"
msgstr "प्रारूप स्केल इस प्रकार"

#. Tag: action
#: commands.docbook:455
#, no-c-format
msgid "Change the scale display format to Stitches, CM or Inches."
msgstr "स्केल प्रदर्शन प्रारूप को टाँके, सेमी या इंच में बदलें।"

#. Tag: guimenuitem
#: commands.docbook:458
#, no-c-format
msgid "Render Stitches As"
msgstr "टांके को इस प्रकार प्रस्तुत करें"

#. Tag: action
#: commands.docbook:459
#, no-c-format
msgid "Change the way stitches are displayed."
msgstr "टांकों को प्रदर्शित करने का तरीका बदलें."

#. Tag: guimenuitem
#: commands.docbook:462
#, no-c-format
msgid "Render Backstitches As"
msgstr "बैकस्टिच को इस प्रकार प्रस्तुत करें"

#. Tag: action
#: commands.docbook:463
#, no-c-format
msgid "Change the way backstitches are displayed."
msgstr "बैकस्टिच को प्रदर्शित करने का तरीका बदलें."

#. Tag: guimenuitem
#: commands.docbook:466
#, no-c-format
msgid "Render Knots As"
msgstr "नॉट्स को इस प्रकार प्रस्तुत करें"

#. Tag: action
#: commands.docbook:467
#, no-c-format
msgid "Change the way knots are displayed."
msgstr "गांठों को प्रदर्शित करने का तरीका बदलें."

#. Tag: guimenuitem
#: commands.docbook:470
#, no-c-format
msgid "Color Highlight"
msgstr "रंग हाइलाइट"

#. Tag: action
#: commands.docbook:471
#, no-c-format
msgid "Enable or disable color highlight mode"
msgstr "रंग हाइलाइट मोड सक्षम या अक्षम करें"

#. Tag: guimenuitem
#: commands.docbook:474
#, no-c-format
msgid "Show Stitches"
msgstr "टाँके दिखाएँ"

#. Tag: action
#: commands.docbook:475
#, no-c-format
msgid "Show or hide the stitches"
msgstr "टाँके दिखाएँ या छिपाएँ"

#. Tag: guimenuitem
#: commands.docbook:478
#, no-c-format
msgid "Show Backstitches"
msgstr "बैकस्टिच दिखाएँ"

#. Tag: action
#: commands.docbook:479
#, no-c-format
msgid "Show or hide the backstitches"
msgstr "बैकस्टिच दिखाएँ या छिपाएँ"

#. Tag: guimenuitem
#: commands.docbook:482
#, no-c-format
msgid "Show French Knots"
msgstr "फ्रेंच नॉट्स दिखाएँ"

#. Tag: action
#: commands.docbook:483
#, no-c-format
msgid "Show or hide the french knots"
msgstr "फ्रेंच नॉट्स दिखाएं या छिपाएं"

#. Tag: guimenuitem
#: commands.docbook:486
#, no-c-format
msgid "Show Grid"
msgstr "ग्रिड दिखाएं"

#. Tag: action
#: commands.docbook:487
#, no-c-format
msgid "Show or hide the grid"
msgstr "ग्रिड दिखाएँ या छिपाएँ"

#. Tag: guimenuitem
#: commands.docbook:490
#, no-c-format
msgid "Show Background Images"
msgstr "पृष्ठभूमि छवियाँ दिखाएँ"

#. Tag: action
#: commands.docbook:491
#, no-c-format
msgid "Show or hide all the background images"
msgstr "सभी पृष्ठभूमि छवियाँ दिखाएँ या छिपाएँ"

#. Tag: guimenuitem
#: commands.docbook:494
#, no-c-format
msgid "Configure &kxstitch;"
msgstr "कॉन्फ़िगर करें &kxstitch;"

#. Tag: action
#: commands.docbook:495
#, no-c-format
msgid ""
"Open &kxstitch; <link linkend=\"ConfigurationDialog\">configuration dialog</"
"link>."
msgstr ""
"खोलें &amp;kxstitch;<link linkend=\"ConfigurationDialog\"> कॉन्फ़िगरेशन संवाद</"
"link> ."

#. Tag: title
#: commands.docbook:503
#, no-c-format
msgid "The Help Menu"
msgstr "सहायता मेनू"

#. Tag: para
#: commands.docbook:504
#, no-c-format
msgid ""
"Additionally &kxstitch; has the common &kde; Help menu items, for more "
"information read the section about the <ulink url=\"help:/fundamentals/menus."
"html#menus-help\">Help Menu</ulink> of the &kde; Fundamentals."
msgstr ""
"इसके अतिरिक्त &kxstitch; में सामान्य &kde; सहायता मेनू आइटम हैं, अधिक जानकारी के लिए "
"&kde; Fundamentals के <ulink url=\"help:/fundamentals/menus.html#menus-help"
"\">सहायता मेनू</ulink> के बारे में अनुभाग पढ़ें।"
