#. Tag: title
#: index.docbook:52
#, no-c-format
msgid "Introduction"
msgstr "परिचय"

#. Tag: para
#: index.docbook:56
#, no-c-format
msgid "Start &kget; (you should see a Drop Target)"
msgstr "आरंभ करें &kget; (आपको एक ड्रॉप टारगेट दिखना चाहिए)"

#. Tag: para
#: index.docbook:57
#, no-c-format
msgid "Drag and drop the required &URL; in the &kget; window/Drop Target."
msgstr "आवश्यक &URL; को &kget; विंडो/ड्रॉप टारगेट में खींचें और छोड़ें।"

#. Tag: screeninfo
#: index.docbook:60 index.docbook:535
#, no-c-format
msgid "<screeninfo>Screenshot of &kget;</screeninfo>"
msgstr "<screeninfo>&kget; का स्क्रीनशॉट</screeninfo>"

#. Tag: phrase
#: index.docbook:66 index.docbook:541
#, no-c-format
msgid "<phrase>Screenshot of &kget;</phrase>"
msgstr "<phrase>&kget; का स्क्रीनशॉट</phrase>"

#. Tag: title
#: index.docbook:74
#, no-c-format
msgid "&kget; Drop Target"
msgstr "&kget; लक्ष्य गिराओ"

#. Tag: para
#: index.docbook:76
#, no-c-format
msgid "The &kget; Drop Target has four options."
msgstr "ड्रॉप टारगेट में चार विकल्प हैं।"

#. Tag: screeninfo
#: index.docbook:81
#, no-c-format
msgid "<screeninfo>Screenshot of &kget; drop target</screeninfo>"
msgstr "<screeninfo>&kget; ड्रॉप टारगेट का स्क्रीनशॉट</screeninfo>"

#. Tag: phrase
#: index.docbook:87
#, no-c-format
msgid "<phrase>Screenshot of &kget; drop target</phrase>"
msgstr "<phrase>&kget; ड्रॉप टारगेट का स्क्रीनशॉट</phrase>"

#. Tag: title
#: index.docbook:93
#, no-c-format
msgid "&kget; Drop Target options"
msgstr "&kget; लक्ष्य विकल्प छोड़ें"

#. Tag: para
#: index.docbook:94
#, no-c-format
msgid "Right click on the drop target to see the options."
msgstr "विकल्प देखने के लिए ड्रॉप लक्ष्य पर राइट क्लिक करें।"

#. Tag: menuchoice
#: index.docbook:101
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>R</keycap></keycombo> </"
"shortcut> <guimenuitem>Start / Resume All</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>R</keycap></keycombo> </"
"shortcut> <guimenuitem>सभी आरंभ करें / फिर से शुरू करें</guimenuitem>"

#. Tag: action
#: index.docbook:110
#, no-c-format
msgid ""
"To start a download or resume all the pending downloads. The shortcut for "
"doing this is <keycombo action=\"simul\">&Ctrl;<keycap>R</keycap></keycombo>"
msgstr ""
"डाउनलोड शुरू करने या सभी लंबित डाउनलोड को फिर से शुरू करने के लिए। ऐसा करने का शॉर्टकट "
"है <keycombo action=\"simul\">&Ctrl;<keycap>R</keycap></keycombo>"

#. Tag: guimenuitem
#: index.docbook:118
#, no-c-format
msgid "Show/Hide Main Window"
msgstr "मुख्य विंडो दिखाएँ/छिपाएँ"

#. Tag: action
#: index.docbook:123
#, no-c-format
msgid "This option shows or minimizes the main window to the system tray."
msgstr "यह विकल्प मुख्य विंडो को सिस्टम ट्रे में दिखाता है या छोटा करता है।"

#. Tag: guimenuitem
#: index.docbook:130
#, no-c-format
msgid "Sticky"
msgstr "चिपचिपा"

#. Tag: action
#: index.docbook:135
#, no-c-format
msgid "Makes the &kget; drop target undraggable."
msgstr "&kget; ड्रॉप लक्ष्य को अ-खींचने योग्य बनाता है."

#. Tag: guimenuitem
#: index.docbook:143
#, no-c-format
msgid "Quit &kget;"
msgstr "छोड़ो &kget;"

#. Tag: action
#: index.docbook:148 index.docbook:698
#, no-c-format
msgid "Quits &kget;"
msgstr "छोड़ता है &kget;"

#. Tag: title
#: index.docbook:157
#, no-c-format
msgid "&kget;'s Configuration window"
msgstr "&kget; की कॉन्फ़िगरेशन विंडो"

#. Tag: menuchoice
#: index.docbook:160
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Configure &kget;</guimenuitem>"
msgstr "<guimenu>सेटिंग्स</guimenu> <guimenuitem>कॉन्फ़िगर &kget;</guimenuitem>"

#. Tag: action
#: index.docbook:164
#, no-c-format
msgid "Opens the &kget; configuration window"
msgstr "&kget; कॉन्फ़िगरेशन विंडो खोलता है"

#. Tag: title
#: index.docbook:169
#, no-c-format
msgid "<title>Appearance</title>"
msgstr "<title>उपस्थिति</title>"

#. Tag: screeninfo
#: index.docbook:172
#, no-c-format
msgid "<screeninfo>Appearance</screeninfo>"
msgstr "<screeninfo>उपस्थिति</screeninfo>"

#. Tag: phrase
#: index.docbook:178
#, no-c-format
msgid "<phrase>Appearance</phrase>"
msgstr "<वाक्यांश>उपस्थिति</वाक्यांश>"

#. Tag: guimenuitem
#: index.docbook:188
#, no-c-format
msgid "<guimenuitem>Appearance</guimenuitem>"
msgstr "<guimenuitem>उपस्थिति</guimenuitem>"

#. Tag: action
#: index.docbook:193
#, no-c-format
msgid "You can modify the various appearance related stuff here."
msgstr "आप यहां उपस्थिति से संबंधित विभिन्न चीजों को संशोधित कर सकते हैं।"

#. Tag: guimenuitem
#: index.docbook:200
#, no-c-format
msgid "Use Drop Target"
msgstr "ड्रॉप टारगेट का उपयोग करें"

#. Tag: action
#: index.docbook:205
#, no-c-format
msgid "Uncheck this if you do not want the &kget; Drop Target."
msgstr "यदि आप &kget; ड्रॉप टारगेट नहीं चाहते हैं तो इसे अनचेक करें।"

#. Tag: guimenuitem
#: index.docbook:212
#, no-c-format
msgid "Enable animations"
msgstr "एनिमेशन सक्षम करें"

#. Tag: action
#: index.docbook:217
#, no-c-format
msgid "Enables few fancy animations."
msgstr "कुछ फैंसी एनिमेशन सक्षम करता है."

#. Tag: title
#: index.docbook:226
#, no-c-format
msgid "Groups"
msgstr "समूह"

#. Tag: para
#: index.docbook:227
#, no-c-format
msgid "You can group downloads."
msgstr "आप डाउनलोड को समूहीकृत कर सकते हैं."

#. Tag: screeninfo
#: index.docbook:229
#, no-c-format
msgid "<screeninfo>&kget; Groups</screeninfo>"
msgstr "<screeninfo>&kget; समूह</screeninfo>"

#. Tag: phrase
#: index.docbook:235
#, no-c-format
msgid "<phrase>&kget; Groups</phrase>"
msgstr "<वाक्यांश>&kget; समूह</वाक्यांश>"

#. Tag: guimenuitem
#: index.docbook:244
#, no-c-format
msgid "Use default folders for groups as suggestion"
msgstr "सुझाव के तौर पर समूहों के लिए डिफ़ॉल्ट फ़ोल्डर का उपयोग करें"

#. Tag: action
#: index.docbook:249
#, no-c-format
msgid ""
"Tick this box if you want &kget; to use default folders for your downloads."
msgstr ""
"यदि आप अपने डाउनलोड के लिए डिफ़ॉल्ट फ़ोल्डर्स का उपयोग करना चाहते हैं तो इस बॉक्स को "
"टिक करें।"

#. Tag: title
#: index.docbook:258
#, no-c-format
msgid "Network"
msgstr "नेटवर्क"

#. Tag: para
#: index.docbook:259
#, no-c-format
msgid "You can modify your network related settings here."
msgstr "आप यहां अपनी नेटवर्क संबंधी सेटिंग्स संशोधित कर सकते हैं।"

#. Tag: screeninfo
#: index.docbook:261
#, no-c-format
msgid "<screeninfo>&kget; Network</screeninfo>"
msgstr "<screeninfo>&kget; नेटवर्क</screeninfo>"

#. Tag: phrase
#: index.docbook:267
#, no-c-format
msgid "<phrase>&kget; Network</phrase>"
msgstr "<वाक्यांश>&kget; नेटवर्क</वाक्यांश>"

#. Tag: guimenuitem
#: index.docbook:276
#, no-c-format
msgid "Limit Maximum Downloads Per Group"
msgstr "प्रति समूह अधिकतम डाउनलोड सीमा"

#. Tag: action
#: index.docbook:281
#, no-c-format
msgid "Check this box if you want Download limits to be implemented."
msgstr "यदि आप डाउनलोड सीमा लागू करना चाहते हैं तो इस बॉक्स को चेक करें।"

#. Tag: guimenuitem
#: index.docbook:288
#, no-c-format
msgid "Speed Limit"
msgstr "गति सीमा"

#. Tag: action
#: index.docbook:293
#, no-c-format
msgid "Check this box if you want the Global speed limits to be used."
msgstr "यदि आप चाहते हैं कि वैश्विक गति सीमा का उपयोग किया जाए तो इस बॉक्स को चेक करें।"

#. Tag: guimenuitem
#: index.docbook:301
#, no-c-format
msgid "Global download limit"
msgstr "वैश्विक डाउनलोड सीमा"

#. Tag: action
#: index.docbook:306
#, no-c-format
msgid "Set the maximum global download limit."
msgstr "अधिकतम वैश्विक डाउनलोड सीमा निर्धारित करें."

#. Tag: guimenuitem
#: index.docbook:314
#, no-c-format
msgid "Global upload limit"
msgstr "वैश्विक अपलोड सीमा"

#. Tag: action
#: index.docbook:319
#, no-c-format
msgid "Set the maximum upload limit."
msgstr "अधिकतम अपलोड सीमा निर्धारित करें."

#. Tag: guimenuitem
#: index.docbook:327
#, no-c-format
msgid "Reconnect on Broken Connection"
msgstr "टूटे हुए कनेक्शन पर पुनः कनेक्ट करें"

#. Tag: action
#: index.docbook:332
#, no-c-format
msgid ""
"Check this box if you want &kget; to reconnect after an error or a broken "
"connection."
msgstr ""
"यदि आप किसी त्रुटि या टूटे हुए कनेक्शन के बाद पुनः कनेक्ट करना चाहते हैं तो इस बॉक्स को चेक "
"करें।"

#. Tag: guimenuitem
#: index.docbook:340
#, no-c-format
msgid "Number of retries"
msgstr "पुनःप्रयासों की संख्या"

#. Tag: action
#: index.docbook:345
#, no-c-format
msgid "Set the maximum number of time &kget; will try to reconnect."
msgstr "&kget; द्वारा पुनः कनेक्ट करने के प्रयास की अधिकतम संख्या निर्धारित करें."

#. Tag: guimenuitem
#: index.docbook:353
#, no-c-format
msgid "Retry after"
msgstr "इसके बाद पुनः प्रयास करें"

#. Tag: action
#: index.docbook:358
#, no-c-format
msgid "Set the retrying interval here (in seconds)"
msgstr "पुनः प्रयास अंतराल यहाँ सेट करें (सेकंड में)"

#. Tag: title
#: index.docbook:368
#, no-c-format
msgid "Web Interface"
msgstr "वेब इंटरफ़ेस"

#. Tag: para
#: index.docbook:369
#, no-c-format
msgid ""
"To enable the web interface, check <guilabel>Enable Web Interface</"
"guilabel>; default port is 8080, and you configure any port higher than "
"1024. Then set <guilabel>User</guilabel> and <guilabel>Password</guilabel>. "
"You can access your web interface at http://127.0.0.1:&lt;port&gt;. You will "
"need to enter the username and password to get access."
msgstr ""
"वेब इंटरफ़ेस को सक्षम करने के लिए, <guilabel>वेब इंटरफ़ेस सक्षम करें</guilabel> को चेक करें; "
"डिफ़ॉल्ट पोर्ट 8080 है, और आप 1024 से अधिक किसी भी पोर्ट को कॉन्फ़िगर कर सकते हैं। फिर "
"<guilabel>उपयोगकर्ता</guilabel> और <guilabel>पासवर्ड</guilabel> सेट करें। आप अपने "
"वेब इंटरफ़ेस को http://127.0.0.1:&lt;port&gt; पर एक्सेस कर सकते हैं। एक्सेस पाने के लिए "
"आपको उपयोगकर्ता नाम और पासवर्ड दर्ज करना होगा।"

#. Tag: screeninfo
#: index.docbook:377
#, no-c-format
msgid "<screeninfo>&kget; Web Interface</screeninfo>"
msgstr "<screeninfo>&kget; वेब इंटरफ़ेस</screeninfo>"

#. Tag: phrase
#: index.docbook:383
#, no-c-format
msgid "<phrase>&kget; Web Interface</phrase>"
msgstr "<वाक्यांश>&kget; वेब इंटरफ़ेस</वाक्यांश>"

#. Tag: title
#: index.docbook:391
#, no-c-format
msgid "Verification"
msgstr "सत्यापन"

#. Tag: para
#: index.docbook:392
#, no-c-format
msgid "Verify your downloads."
msgstr "अपने डाउनलोड सत्यापित करें."

#. Tag: screeninfo
#: index.docbook:394
#, no-c-format
msgid "<screeninfo>&kget; Verification</screeninfo>"
msgstr "<screeninfo>&kget; सत्यापन</screeninfo>"

#. Tag: phrase
#: index.docbook:400
#, no-c-format
msgid "<phrase>&kget; Verification</phrase>"
msgstr "<वाक्यांश>&kget; सत्यापन</वाक्यांश>"

#. Tag: para
#: index.docbook:405
#, no-c-format
msgid ""
"Using the two methods <guilabel>Automatic checksums verification</guilabel> "
"and <guilabel>Signature</guilabel> you can verify your downloads. You just "
"have to tick the <guilabel>Automatic verification</guilabel> check box."
msgstr ""
"दो तरीकों <guilabel>स्वचालित चेकसम सत्यापन</guilabel> और <guilabel>हस्ताक्षर</"
"guilabel> का उपयोग करके आप अपने डाउनलोड को सत्यापित कर सकते हैं। आपको बस "
"<guilabel>स्वचालित सत्यापन</guilabel> चेक बॉक्स पर टिक करना होगा।"

#. Tag: title
#: index.docbook:410
#, no-c-format
msgid "Integration"
msgstr "एकीकरण"

#. Tag: guimenuitem
#: index.docbook:415
#, no-c-format
msgid "Use as download manager for Konqueror"
msgstr "कोनक्वेरर के लिए डाउनलोड प्रबंधक के रूप में उपयोग करें"

#. Tag: action
#: index.docbook:420
#, no-c-format
msgid "You can set &kget; as your download manager for &konqueror;."
msgstr "आप &kget; को &konqueror; के लिए डाउनलोड प्रबंधक के रूप में सेट कर सकते हैं।"

#. Tag: guimenuitem
#: index.docbook:428
#, no-c-format
msgid "Monitor clipboard for files to download"
msgstr "डाउनलोड की जाने वाली फ़ाइलों के लिए क्लिपबोर्ड पर नज़र रखें"

#. Tag: para
#: index.docbook:432
#, no-c-format
msgid ""
"You can turn on this feature that asks if you want to download &URL;s copied "
"into the clipboard."
msgstr ""
"आप इस सुविधा को चालू कर सकते हैं जो पूछती है कि क्या आप क्लिपबोर्ड में कॉपी किए गए &URL; "
"को डाउनलोड करना चाहते हैं।"

#. Tag: title
#: index.docbook:441
#, no-c-format
msgid "Advanced"
msgstr "विकसित"

#. Tag: para
#: index.docbook:442
#, no-c-format
msgid "Modify Advanced Options."
msgstr "उन्नत विकल्प संशोधित करें."

#. Tag: screeninfo
#: index.docbook:444
#, no-c-format
msgid "<screeninfo>&kget; Advanced Options</screeninfo>"
msgstr "<screeninfo>&kget; उन्नत विकल्प</screeninfo>"

#. Tag: phrase
#: index.docbook:450
#, no-c-format
msgid "<phrase>&kget; Advanced Options</phrase>"
msgstr "<phrase>&kget; उन्नत विकल्प</phrase>"

#. Tag: guimenuitem
#: index.docbook:459
#, no-c-format
msgid "Enable system tray icon"
msgstr "सिस्टम ट्रे आइकन सक्षम करें"

#. Tag: action
#: index.docbook:464
#, no-c-format
msgid "This check box enables the &kget; system tray icon."
msgstr "यह चेक बॉक्स &kget; सिस्टम ट्रे आइकन को सक्षम करता है।"

#. Tag: guimenuitem
#: index.docbook:472
#, no-c-format
msgid "Execute action after all downloads have been finished"
msgstr "सभी डाउनलोड समाप्त हो जाने के बाद कार्रवाई निष्पादित करें"

#. Tag: action
#: index.docbook:477
#, no-c-format
msgid ""
"Check this box to enable Quitting &kget; after all downloads have finished. "
"At startup you can choose to Restore Download state. Such as Stop All "
"downloads/ Start All downloads."
msgstr ""
"सभी डाउनलोड समाप्त होने के बाद क्विटिंग &kget; को सक्षम करने के लिए इस बॉक्स को चेक "
"करें। स्टार्टअप पर आप डाउनलोड स्थिति को पुनर्स्थापित करना चुन सकते हैं। जैसे कि सभी "
"डाउनलोड रोकें/सभी डाउनलोड शुरू करें।"

#. Tag: guimenuitem
#: index.docbook:486
#, no-c-format
msgid "History backend"
msgstr "इतिहास बैकएंड"

#. Tag: action
#: index.docbook:491
#, no-c-format
msgid "You can choose your history backend as Sqlite or Xml."
msgstr "आप अपना इतिहास बैकएंड SQLite या XML के रूप में चुन सकते हैं।"

#. Tag: guimenuitem
#: index.docbook:499
#, no-c-format
msgid "Enable &kde; global progress tracking"
msgstr "वैश्विक प्रगति ट्रैकिंग सक्षम करें"

#. Tag: action
#: index.docbook:504
#, no-c-format
msgid ""
"You can set &kget; to show every single download or show overall progress."
msgstr "आप प्रत्येक डाउनलोड या समग्र प्रगति दिखाने के लिए &kget; सेट कर सकते हैं।"

#. Tag: title
#: index.docbook:512
#, no-c-format
msgid "Plugins"
msgstr "प्लग-इन"

#. Tag: screeninfo
#: index.docbook:514
#, no-c-format
msgid "<screeninfo>&kget; Plugins Options</screeninfo>"
msgstr "<screeninfo>&kget; प्लगइन्स विकल्प</screeninfo>"

#. Tag: phrase
#: index.docbook:520
#, no-c-format
msgid "<phrase>&kget; Plugins Options</phrase>"
msgstr "<phrase>&kget; प्लगइन्स विकल्प</phrase>"

#. Tag: para
#: index.docbook:524
#, no-c-format
msgid ""
"On this page you can select the transfer plugins to be used. Use the "
"<inlinemediaobject><imageobject><imagedata fileref=\"pluginsettings.png\" "
"format=\"PNG\"/> </imageobject></inlinemediaobject> button to change the "
"default settings for a plugin."
msgstr ""
"इस पृष्ठ पर आप उपयोग किए जाने वाले स्थानांतरण प्लगइन्स का चयन कर सकते हैं। किसी प्लगइन के "
"लिए डिफ़ॉल्ट सेटिंग बदलने के लिए <inlinemediaobject><imageobject><imagedata "
"fileref=\"pluginsettings.png\" format=\"PNG\"/> </imageobject></"
"inlinemediaobject> बटन का उपयोग करें।"

#. Tag: title
#: index.docbook:532
#, no-c-format
msgid "Main Window"
msgstr "मुख्य विंडो"

#. Tag: para
#: index.docbook:533
#, no-c-format
msgid "Overview of &kget;'s Main Window"
msgstr "&kget; की मुख्य विंडो का अवलोकन"

#. Tag: title
#: index.docbook:547
#, no-c-format
msgid "The File Menu"
msgstr "फ़ाइल मेनू"

#. Tag: menuchoice
#: index.docbook:550
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>N</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>New Download...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>N</keycap></keycombo> </"
"shortcut> <guimenu>फ़ाइल</guimenu> <guimenuitem>नया डाउनलोड...</guimenuitem>"

#. Tag: action
#: index.docbook:557
#, no-c-format
msgid "Add a new file to download"
msgstr "डाउनलोड करने के लिए एक नई फ़ाइल जोड़ें"

#. Tag: menuchoice
#: index.docbook:561
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>L</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Import Links...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo Action='simul'>&Ctrl;<keycap>L</keycap></keycombo> </"
"shortcut> <guimenu>फ़ाइल</guimenu> <guimenuitem>लिंक आयात करें...</guimenuitem>"

#. Tag: screeninfo
#: index.docbook:570
#, no-c-format
msgid "<screeninfo>Import Links</screeninfo>"
msgstr "<screeninfo>लिंक आयात करें</screeninfo>"

#. Tag: phrase
#: index.docbook:576
#, no-c-format
msgid "<phrase>Import Links</phrase>"
msgstr "<phrase>लिंक आयात करें</phrase>"

#. Tag: action
#: index.docbook:580
#, no-c-format
msgid ""
"This action brings up another window, where you can see and manipulate which "
"file to download. Also you can make a selection based on <guilabel>Videos</"
"guilabel>, <guilabel>Images</guilabel>, <guilabel>Audio</guilabel> and "
"<guilabel>Archives</guilabel>. There is also a text box to filter out "
"results."
msgstr ""
"यह क्रिया एक और विंडो लाती है, जहाँ आप देख सकते हैं और हेरफेर कर सकते हैं कि कौन सी फ़ाइल "
"डाउनलोड करनी है। इसके अलावा आप <guilabel>वीडियो</guilabel>, <guilabel>इमेज</"
"guilabel>, <guilabel>ऑडियो</guilabel> और <guilabel>आर्काइव्स</guilabel> के आधार "
"पर चयन कर सकते हैं। परिणामों को फ़िल्टर करने के लिए एक टेक्स्ट बॉक्स भी है।"

#. Tag: menuchoice
#: index.docbook:585
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>I</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Import Transfers...</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>I</keycap></keycombo> </"
"shortcut> <guimenu>फ़ाइल</guimenu> <guimenuitem>स्थानान्तरण आयात करें...</"
"guimenuitem>"

#. Tag: action
#: index.docbook:592
#, no-c-format
msgid ""
"Loads a <filename class=\"extension\">*.kgt</filename>, <filename class="
"\"extension\">*.metalink</filename>, <filename class=\"extension\">*.meta4</"
"filename> or <filename class=\"extension\">*.torrent</filename> file."
msgstr ""
"<filename class=\"extension\">*.kgt</filename>, <filename class=\"extension"
"\">*.metalink</filename>, <filename class=\"extension\">*.meta4</filename> "
"या <filename class=\"extension\">*.torrent</filename> फ़ाइल लोड करता है।"

#. Tag: menuchoice
#: index.docbook:596
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>E</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Export Transfers List...</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>E</keycap></keycombo> </"
"shortcut> <guimenu>फ़ाइल</guimenu> <guimenuitem>स्थानान्तरण सूची निर्यात करें...</"
"guimenuitem>"

#. Tag: action
#: index.docbook:603
#, no-c-format
msgid ""
"Export the highlighted links to a <filename class=\"extension\">.kgt</"
"filename> file, to be loaded later."
msgstr ""
"हाइलाइट किए गए लिंक को <filename class=\"extension\">.kgt</filename> फ़ाइल में "
"निर्यात करें, जिसे बाद में लोड किया जाएगा।"

#. Tag: menuchoice
#: index.docbook:607
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Create a Metalink</guimenuitem>"
msgstr "<guimenu>फ़ाइल</guimenu> <guimenuitem>मेटालिंक बनाएं</guimenuitem>"

#. Tag: screeninfo
#: index.docbook:613
#, no-c-format
msgid "Creating a metalink0"
msgstr "मेटलिंक0 बनाना"

#. Tag: phrase
#: index.docbook:619
#, no-c-format
msgid "Creating a Metalink0"
msgstr "मेटलिंक बनाना0"

#. Tag: para
#: index.docbook:623
#, no-c-format
msgid ""
"Select between creating a new Metalink and loading an existing Metalink. "
"Click the <guilabel>Next</guilabel> button to proceed."
msgstr ""
"नया मेटालिंक बनाने और मौजूदा मेटालिंक लोड करने के बीच चयन करें। आगे बढ़ने के लिए "
"<guilabel>अगला</guilabel> बटन पर क्लिक करें।"

#. Tag: screeninfo
#: index.docbook:626
#, no-c-format
msgid "Creating a metalink1"
msgstr "मेटलिंक1 बनाना"

#. Tag: phrase
#: index.docbook:632
#, no-c-format
msgid "Creating a Metalink1"
msgstr "मेटलिंक1 बनाना"

#. Tag: para
#: index.docbook:636
#, no-c-format
msgid ""
"Here you can choose to enter some general optional information. Such as "
"where can this metalink be obtained from (Enter the &URL; in the text box "
"next to <guilabel>Origin</guilabel>)."
msgstr ""
"यहाँ आप कुछ सामान्य वैकल्पिक जानकारी दर्ज करना चुन सकते हैं। जैसे कि यह मेटालिंक कहाँ से "
"प्राप्त किया जा सकता है (<guilabel>Origin</guilabel> के बगल में स्थित टेक्स्ट बॉक्स में "
"&URL; दर्ज करें)।"

#. Tag: screeninfo
#: index.docbook:639
#, no-c-format
msgid "Creating a metalink2"
msgstr "मेटलिंक2 बनाना"

#. Tag: phrase
#: index.docbook:645
#, no-c-format
msgid "Creating a Metalink2"
msgstr "मेटलिंक2 बनाना"

#. Tag: para
#: index.docbook:649
#, no-c-format
msgid ""
"Here you have to enter the &URL; from where you are trying to download the "
"file. Also you can enter some optional information such as Preference "
"(Priority) for a particular mirror if you are adding more then one mirrors, "
"for the file you want to download."
msgstr ""
"यहाँ आपको वह &URL; दर्ज करना होगा जहाँ से आप फ़ाइल डाउनलोड करने का प्रयास कर रहे हैं। "
"साथ ही आप कुछ वैकल्पिक जानकारी भी दर्ज कर सकते हैं जैसे कि किसी विशेष मिरर के लिए "
"वरीयता (प्राथमिकता) यदि आप उस फ़ाइल के लिए एक से अधिक मिरर जोड़ रहे हैं जिसे आप "
"डाउनलोड करना चाहते हैं।"

#. Tag: screeninfo
#: index.docbook:652
#, no-c-format
msgid "Creating a metalink 3"
msgstr "मेटलिंक 3 बनाना"

#. Tag: phrase
#: index.docbook:658
#, no-c-format
msgid "Creating a Metalink 3"
msgstr "मेटालिंक 3 बनाना"

#. Tag: para
#: index.docbook:662
#, no-c-format
msgid ""
"You should be able to see a new window where all your files which will be "
"imported will be shown."
msgstr "आपको एक नई विंडो दिखाई देगी, जिसमें आपकी सभी आयातित फ़ाइलें दिखाई जाएंगी।"

#. Tag: menuchoice
#: index.docbook:667
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>H</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Transfer History</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>H</keycap></keycombo> </"
"shortcut> <guimenu>फ़ाइल</guimenu> <guimenuitem>स्थानांतरण इतिहास</guimenuitem>"

#. Tag: screeninfo
#: index.docbook:676
#, no-c-format
msgid "<screeninfo>Transfer History</screeninfo>"
msgstr "<screeninfo>स्थानांतरण इतिहास</screeninfo>"

#. Tag: phrase
#: index.docbook:682
#, no-c-format
msgid "<phrase>Transfer History</phrase>"
msgstr "<phrase>स्थानांतरण इतिहास</phrase>"

#. Tag: action
#: index.docbook:686
#, no-c-format
msgid ""
"Opens a new window where you can see all the files downloaded using &kget;. "
"You can manage your history here, including filter and clear the history."
msgstr ""
"एक नई विंडो खुलेगी, जहाँ आप &kget; का उपयोग करके डाउनलोड की गई सभी फ़ाइलें देख सकते हैं। "
"आप यहाँ अपना इतिहास प्रबंधित कर सकते हैं, जिसमें फ़िल्टर करना और इतिहास साफ़ करना शामिल "
"है।"

#. Tag: menuchoice
#: index.docbook:691
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>Q</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Quit</guimenuitem>"
msgstr ""
"<shortcut> <keycombo Action='simul'>&Ctrl;<keycap>Q</keycap></keycombo> </"
"shortcut> <guimenu>फ़ाइल</guimenu> <guimenuitem>छोड़ें</guimenuitem>"

