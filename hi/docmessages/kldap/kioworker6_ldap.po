#. Tag: title
#: index.docbook:9
#, no-c-format
msgid "ldap"
msgstr "एलडीएपी"

#. Tag: author
#: index.docbook:12
#, no-c-format
msgid "&Lauri.Watts; &Lauri.Watts.mail;"
msgstr "&Lauri.Watts; &Lauri.Watts.मेल;"

#. Tag: trans_comment
#: index.docbook:13
#, no-c-format
msgid "ROLES_OF_TRANSLATORS"
msgstr "अनुवादकों की भूमिकाएँ"

#. Tag: para
#: index.docbook:17
#, no-c-format
msgid ""
"<acronym>ldap</acronym> is the lightweight directory access protocol. It "
"provides access to an X.500 directory, or to a stand-alone <acronym>LDAP</"
"acronym> server."
msgstr ""
"<acronym>ldap</acronym> एक हल्का निर्देशिका एक्सेस प्रोटोकॉल है। यह X.500 निर्देशिका "
"या स्टैंड-अलोन <acronym>LDAP</acronym> सर्वर तक पहुँच प्रदान करता है।"

#. Tag: para
#: index.docbook:21
#, no-c-format
msgid "You can use the ldap KIO worker as follows:"
msgstr "आप ldap KIO वर्कर का उपयोग निम्न प्रकार कर सकते हैं:"

#. Tag: para
#: index.docbook:23
#, no-c-format
msgid ""
"<userinput>ldap://host:port/ou=People,o=where,c=de??sub</userinput> for a "
"subtree-query"
msgstr ""
"<userinput>ldap://host:port/ou=People,o=where,c=de??sub</userinput> सबट्री-"
"क्वेरी के लिए"

#. Tag: para
#: index.docbook:26
#, no-c-format
msgid ""
"or <userinput>ldap://host:port/cn=MM,ou=People,o=where,c=de??base</"
"userinput> for a complete branch."
msgstr ""
"या पूर्ण शाखा के लिए <userinput>ldap://host:port/cn=MM,ou=People,o=where,c=de??"
"base</userinput>."
