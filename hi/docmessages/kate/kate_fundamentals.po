#: fundamentals.docbook:337
#, no-c-format
msgid "Show Sidebars"
msgstr "साइडबार दिखाएं"

#. Tag: keycombo
#: fundamentals.docbook:340 fundamentals.docbook:369
#, no-c-format
msgid "&Ctrl;&Shift;<keycap>T</keycap>"
msgstr "&Ctrl;&Shift;<keycap>T</keycap>"

