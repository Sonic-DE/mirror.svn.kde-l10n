msgstr "सब को सुरक्षित करें"

#. Tag: keycombo
#: fundamentals.docbook:310
#, no-c-format
msgid "&Ctrl;<keycap>O</keycap>"
msgstr "&Ctrl;<keycap>ओ</keycap>"

#. Tag: link
