msgstr "&Ctrl;<keycap>क्यू</keycap>"

#. Tag: para
#: fundamentals.docbook:333
#, no-c-format
msgid "Quit - close active copy of editor"
msgstr "बाहर निकलें - संपादक की सक्रिय प्रतिलिपि बंद करें"

#. Tag: keycombo
#: fundamentals.docbook:336
#, no-c-format
msgid "&Ctrl;&Alt;&Shift;<keycap>F</keycap>"
msgstr "&Ctrl;&Alt;&Shift;<keycap>एफ</keycap>"

