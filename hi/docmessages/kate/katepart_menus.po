#. Tag: para
#: menus.docbook:1077
#, no-c-format
msgid "Move the cursor to the associated opening or closing bracket."
msgstr "कर्सर को संबंधित आरंभिक या समापन कोष्ठक पर ले जाएं।"

#. Tag: menuchoice
#: menus.docbook:1082
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>6</keycap></"
"keycombo> </shortcut> <guimenu>Go</guimenu> <guimenuitem>Select to Matching "
"Bracket</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>6</keycap></"
"keycombo> </shortcut> <guimenu>जाएँ</guimenu> <guimenuitem>मिलान ब्रैकेट का चयन "
"करें</guimenuitem>"

#. Tag: para
#: menus.docbook:1090
#, no-c-format
msgid "Selects the text between associated opening and closing brackets."
msgstr "संबद्ध आरंभिक और समापन कोष्ठकों के बीच पाठ का चयन करता है।"

#. Tag: menuchoice
#: menus.docbook:1095
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>6</keycap></"
"keycombo> </shortcut> <guimenu>Go</guimenu> <guisubmenu>Bookmarks</"
"guisubmenu>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>6</keycap></"
"keycombo> </shortcut> <guimenu>जाएँ</guimenu> <guisubmenu>बुकमार्क</guisubmenu>"

#. Tag: para
#: menus.docbook:1103
#, no-c-format
msgid ""
"Below the entries described here, one entry for each bookmark in the active "
"document will be available. The text will be the first few words of the "
"marked line. Choose an item to move the cursor to the start of that line. "
"The editor will scroll as necessary to make that line visible."
msgstr ""
"यहाँ वर्णित प्रविष्टियों के नीचे, सक्रिय दस्तावेज़ में प्रत्येक बुकमार्क के लिए एक प्रविष्टि "
"उपलब्ध होगी। पाठ चिह्नित पंक्ति के पहले कुछ शब्द होंगे। कर्सर को उस पंक्ति की शुरुआत में ले "
"जाने के लिए कोई आइटम चुनें। संपादक उस पंक्ति को दृश्यमान बनाने के लिए आवश्यकतानुसार स्क्रॉल "
"करेगा।"

#. Tag: menuchoice
#: menus.docbook:1112
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>B</keycap></keycombo> </"
"shortcut> <guimenu>Go</guimenu> <guisubmenu>Bookmarks</guisubmenu> "
"<guimenuitem>Set Bookmark</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>B</keycap></keycombo> </"
"shortcut> <guimenu>जाएँ</guimenu> <guisubmenu>बुकमार्क</guisubmenu> "
"<guimenuitem>बुकमार्क सेट करें</guimenuitem>"

#. Tag: para
#: menus.docbook:1121
#, no-c-format
msgid ""
"Sets or removes a bookmark in the current line of the active document. (If "
"it's there, it is removed, otherwise one is set.)"
msgstr ""
"सक्रिय दस्तावेज़ की वर्तमान पंक्ति में बुकमार्क सेट करता है या हटाता है। (यदि यह वहां है, तो "
"इसे हटा दिया जाता है, अन्यथा एक सेट किया जाता है।)"

#. Tag: menuchoice
#: menus.docbook:1127
#, no-c-format
msgid ""
"<guimenu>Go</guimenu> <guisubmenu>Bookmarks</guisubmenu> <guimenuitem>Clear "
"All Bookmarks</guimenuitem>"
msgstr ""
"<guimenu>जाएँ</guimenu> <guisubmenu>बुकमार्क</guisubmenu> <guimenuitem>सभी "
"बुकमार्क साफ़ करें</guimenuitem>"

#. Tag: para
#: menus.docbook:1133
#, no-c-format
msgid ""
"This command will remove all the markers from the document as well as the "
"list of markers which is appended at the bottom of this menu item."
msgstr ""
"यह कमांड दस्तावेज़ से सभी मार्करों को हटा देगा, साथ ही इस मेनू आइटम के नीचे संलग्न मार्करों "
"की सूची को भी हटा देगा।"

#. Tag: menuchoice
#: menus.docbook:1141
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt;&PgUp;</keycombo> </shortcut> "
"<guimenu>Go</guimenu> <guisubmenu>Bookmarks</guisubmenu> "
"<guimenuitem>Previous</guimenuitem>"
msgstr ""
"<शॉर्टकट> <कीकॉम्बो एक्शन = \"सिमुल\">&Alt;&PgUp;</कीकॉम्बो> </शॉर्टकट> <गुइमेनू>गो</"
"गुइमेनू> <गुइमेनु>बुकमार्क्स</गुइमेनुइटम> <गुइमेनुइटम>पिछला</गुइमेनुइटम>"

#. Tag: para
#: menus.docbook:1149
#, no-c-format
msgid ""
"This will move the cursor to beginning of the first above line with a "
"bookmark. The menuitem text will include the line number and the first piece "
"of text on the line. This item is only available when there is a bookmark in "
"a line above the cursor."
msgstr ""
"यह कर्सर को बुकमार्क के साथ ऊपर की पहली लाइन की शुरुआत में ले जाएगा। मेन्यूआइटम टेक्स्ट में "
"लाइन नंबर और लाइन पर टेक्स्ट का पहला भाग शामिल होगा। यह आइटम केवल तभी उपलब्ध होता "
"है जब कर्सर के ऊपर की लाइन में बुकमार्क हो।"

#. Tag: menuchoice
#: menus.docbook:1156
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt;&PgDn;</keycombo> </shortcut> "
"<guimenu>Go</guimenu> <guisubmenu>Bookmarks</guisubmenu> <guimenuitem>Next</"
"guimenuitem>"
msgstr ""
"<शॉर्टकट> <कीकॉम्बो एक्शन = \"सिमुल\">&Alt;&PgDn;</कीकॉम्बो> </शॉर्टकट> <गुइमेनू>गो</"
"गुइमेनू> <गुइमेनु>बुकमार्क्स</गुइमेनुइटम> <गुइमेनुइटम>अगला</गुइमेनुइटम>"

#. Tag: para
#: menus.docbook:1164
#, no-c-format
msgid ""
"This will move the cursor to beginning of the next line with a bookmark. The "
"menuitem text will include the line number and the first piece of text on "
"the line. This item is only available when there is a bookmark in a line "
"below the cursor."
msgstr ""
"यह कर्सर को बुकमार्क के साथ अगली पंक्ति की शुरुआत में ले जाएगा। मेनूआइटम टेक्स्ट में लाइन नंबर "
"और लाइन पर टेक्स्ट का पहला भाग शामिल होगा। यह आइटम केवल तभी उपलब्ध होता है जब कर्सर "
"के नीचे एक पंक्ति में बुकमार्क होता है।"

#. Tag: title
#: menus.docbook:1176
#, no-c-format
msgid "The Tools Menu"
msgstr "उपकरण मेनू"

#. Tag: menuchoice
#: menus.docbook:1181
#, no-c-format
msgid "<guimenu>Tools</guimenu> <guisubmenu>Mode</guisubmenu>"
msgstr "<guimenu>उपकरण</guimenu> <highsubmenu>मोड</highlysubmenu>"

#. Tag: para
#: menus.docbook:1186
#, no-c-format
msgid ""
"Choose the filetype scheme you prefer for the active document. This "
"overwrites the global filetype mode set in <menuchoice> <guimenu>Settings</"
"guimenu><guimenuitem>Configure Editor...</guimenuitem></menuchoice> in the "
"Filetypes tab for your current document only."
msgstr ""
"सक्रिय दस्तावेज़ के लिए अपनी पसंदीदा फ़ाइल प्रकार योजना चुनें। यह केवल आपके वर्तमान दस्तावेज़ "
"के लिए फ़ाइल प्रकार टैब में <menuchoice> <guimenu>सेटिंग्स</"
"guimenu><guimenuitem>संपादक कॉन्फ़िगर करें...</guimenuitem></menuchoice> में सेट "
"वैश्विक फ़ाइल प्रकार मोड को अधिलेखित करता है।"

#. Tag: menuchoice
#: menus.docbook:1194
#, no-c-format
msgid "<guimenu>Tools</guimenu> <guisubmenu>Highlighting</guisubmenu>"
msgstr "<guimenu>टूल्स</guimenu> <guisubmenu>हाइलाइटिंग</guisubmenu>"

#. Tag: para
#: menus.docbook:1199
#, no-c-format
msgid ""
"Choose the Highlighting scheme you prefer for the active document. This "
"overwrites the global highlighting mode set in <menuchoice> "
"<guimenu>Settings</guimenu><guimenuitem>Configure Editor...</guimenuitem> </"
"menuchoice> for your current document only."
msgstr ""
"सक्रिय दस्तावेज़ के लिए अपनी पसंदीदा हाइलाइटिंग योजना चुनें। यह केवल आपके वर्तमान दस्तावेज़ "
"के लिए <menuchoice> <guimenu>सेटिंग्स</guimenu><guimenuitem>संपादक कॉन्फ़िगर करें...</"
"guimenuitem> </menuchoice> में सेट किए गए वैश्विक हाइलाइटिंग मोड को अधिलेखित करता है।"

#. Tag: menuchoice
#: menus.docbook:1207
#, no-c-format
msgid "<guimenu>Tools</guimenu> <guisubmenu>Indentation</guisubmenu>"
msgstr "<guimenu>उपकरण</guimenu> <guisubmenu>इंडेंटेशन</guisubmenu>"

#. Tag: para
#: menus.docbook:1212
#, no-c-format
msgid ""
"Choose the style of indentation you want for your active document. This "
"overwrites the global indentation mode set in <menuchoice> "
"<guimenu>Settings</guimenu><guimenuitem>Configure Editor...</guimenuitem> </"
"menuchoice> for your current document only."
msgstr ""
"अपने सक्रिय दस्तावेज़ के लिए इच्छित इंडेंटेशन की शैली चुनें। यह केवल आपके वर्तमान दस्तावेज़ के लिए "
"<menuchoice> <guimenu>सेटिंग्स</guimenu><guimenuitem>संपादक कॉन्फ़िगर करें...</"
"guimenuitem> </menuchoice> में सेट किए गए वैश्विक इंडेंटेशन मोड को अधिलेखित करता है।"

#. Tag: menuchoice
#: menus.docbook:1220
#, no-c-format
msgid "<guimenu>Tools</guimenu> <guisubmenu>Encoding</guisubmenu>"
msgstr "<guimenu>उपकरण</guimenu> <guisubmenu>एन्कोडिंग</guimenu>"

#. Tag: para
#: menus.docbook:1225
#, no-c-format
msgid ""
"You can overwrite the default encoding set in <menuchoice> "
"<guimenu>Settings</guimenu><guimenuitem>Configure Editor...</guimenuitem> </"
"menuchoice> in the <guilabel>Open/Save</guilabel> page to set a different "
"encoding for your current document. The encoding you set here will be only "
"valid for your current document."
msgstr ""
"आप अपने वर्तमान दस्तावेज़ के लिए एक अलग एन्कोडिंग सेट करने के लिए <guilabel>खोलें/सहेजें</"
"guilabel> पृष्ठ में <menuchoice> <guimenu>सेटिंग्स</guimenu><guimenuitem>संपादक "
"कॉन्फ़िगर करें...</guimenuitem> </menuchoice> में सेट डिफ़ॉल्ट एन्कोडिंग को अधिलेखित कर "
"सकते हैं। आपके द्वारा यहाँ सेट की गई एन्कोडिंग केवल आपके वर्तमान दस्तावेज़ के लिए मान्य होगी।"

#. Tag: menuchoice
#: menus.docbook:1234
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu> <guisubmenu>Add Byte Mark Order (BOM)</guisubmenu>"
msgstr ""
"<guimenu>टूल्स</guimenu> <guisubmenu>बाइट मार्क ऑर्डर (BOM) जोड़ें</guisubmenu>"

#. Tag: para
#: menus.docbook:1239
#, no-c-format
msgid ""
"Checking this action you can explicitly add a byte order mark for unicode "
"encoded documents. The byte order mark (BOM) is a Unicode character used to "
"signal the endianness (byte order) of a text file or stream, for more "
"information see <ulink url=\"https://en.wikipedia.org/wiki/Byte_order_mark"
"\">Byte Order Mark</ulink>."
msgstr ""
"इस क्रिया को जाँचने पर आप यूनिकोड एनकोडेड दस्तावेज़ों के लिए स्पष्ट रूप से बाइट ऑर्डर मार्क "
"जोड़ सकते हैं। बाइट ऑर्डर मार्क (BOM) एक यूनिकोड वर्ण है जिसका उपयोग किसी टेक्स्ट फ़ाइल "
"या स्ट्रीम के एंडियननेस (बाइट ऑर्डर) को संकेत देने के लिए किया जाता है, अधिक जानकारी के "
"लिए <ulink url=\"https://en.wikipedia.org/wiki/Byte_order_mark\">बाइट ऑर्डर "
"मार्क</ulink> देखें।"

#. Tag: menuchoice
#: menus.docbook:1247
#, no-c-format
msgid "<guimenu>Tools</guimenu> <guisubmenu>End of Line</guisubmenu>"
msgstr "<guimenu>टूल्स</guimenu> <guisubmenu>पंक्ति का अंत</guisubmenu>"

#. Tag: para
#: menus.docbook:1252
#, no-c-format
msgid ""
"Choose your preferred end of line mode for your active document. This "
"overwrites the global end of line mode set in <menuchoice> "
"<guimenu>Settings</guimenu><guimenuitem>Configure Editor...</guimenuitem> </"
"menuchoice> for your current document only."
msgstr ""
"अपने सक्रिय दस्तावेज़ के लिए अपनी पसंदीदा पंक्ति समाप्ति मोड चुनें। यह केवल आपके वर्तमान "
"दस्तावेज़ के लिए <menuchoice> <guimenu>सेटिंग्स</guimenu><guimenuitem>संपादक कॉन्फ़िगर "
"करें...</guimenuitem> </menuchoice> में सेट की गई वैश्विक पंक्ति समाप्ति मोड को "
"अधिलेखित करता है।"

#. Tag: menuchoice
#: menus.docbook:1260
#, no-c-format
msgid "<guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu>"
msgstr "<guimenu>उपकरण</guimenu> <guisubmenu>स्क्रिप्ट</guimenu>"

#. Tag: para
#: menus.docbook:1265
#, no-c-format
msgid ""
"This submenu contains a list of all scripted actions. The list can easily be "
"modified by <link linkend=\"dev-scripting-command-line\">writing your own "
"scripts</link>. This way, &katepart; can be extended with user-defined tools."
msgstr ""
"इस सबमेनू में सभी स्क्रिप्टेड क्रियाओं की सूची है। सूची को आसानी से संशोधित किया जा सकता "
"है<link linkend=\"dev-scripting-command-line\"> अपनी स्वयं की स्क्रिप्ट लिखना</"
"link> इस तरह, &amp;katepart; को उपयोगकर्ता-परिभाषित उपकरणों के साथ बढ़ाया जा "
"सकता है।"

#. Tag: menuchoice
#: menus.docbook:1273
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu> "
"<guisubmenu>Navigation</guisubmenu>"
msgstr ""
"<guimenu>उपकरण</guimenu> <guisubmenu>स्क्रिप्ट</guisubmenu> <guisubmenu>नेविगेशन</"
"guisubmenu>"

#. Tag: menuchoice
#: menus.docbook:1281
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift;&Up;</keycombo> </"
"shortcut> <guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu> "
"<guisubmenu>Navigation</guisubmenu> <guimenuitem>Move cursor to previous "
"matching indent</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift;&Up;</keycombo> </"
"shortcut> <guimenu>टूल्स</guimenu> <guisubmenu>स्क्रिप्ट</guisubmenu> "
"<guisubmenu>नेविगेशन</guisubmenu> <guimenuitem>कर्सर को पिछले मिलान वाले इंडेंट पर ले "
"जाएं</guimenuitem>"

#. Tag: para
#: menus.docbook:1290
#, no-c-format
msgid ""
"Moves the cursor to the first line above the current line that is indented "
"at the same level as the current line."
msgstr ""
"कर्सर को वर्तमान पंक्ति के ऊपर पहली पंक्ति पर ले जाता है जो वर्तमान पंक्ति के समान स्तर पर "
"इंडेंट की गई है।"

#. Tag: menuchoice
#: menus.docbook:1297
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift;&Down;</keycombo> </"
"shortcut> <guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu> "
"<guisubmenu>Navigation</guisubmenu> <guimenuitem>Move cursor to next "
"matching indent</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift;&Down;</keycombo> </"
"shortcut> <guimenu>टूल्स</guimenu> <guisubmenu>स्क्रिप्ट</guisubmenu> "
"<guisubmenu>नेविगेशन</guisubmenu> <guimenuitem>कर्सर को अगले मिलान वाले इंडेंट पर ले "
"जाएं</guimenuitem>"

#. Tag: para
#: menus.docbook:1306
#, no-c-format
msgid ""
"Moves the cursor to the first line below the current line that is indented "
"at the same level as the current line."
msgstr ""
"कर्सर को वर्तमान पंक्ति के नीचे पहली पंक्ति पर ले जाता है जो वर्तमान पंक्ति के समान स्तर पर "
"इंडेंट की गई है।"

#. Tag: menuchoice
#: menus.docbook:1322
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu> "
"<guisubmenu>Editing</guisubmenu>"
msgstr ""
"<guimenu>उपकरण</guimenu> <guisubmenu>स्क्रिप्ट</guisubmenu> <guisubmenu>संपादन</"
"guisubmenu>"

#. Tag: menuchoice
#: menus.docbook:1330
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu> "
"<guisubmenu>Editing</guisubmenu> <guimenuitem>Sort Selected Text</"
"guimenuitem>"
msgstr ""
"<guimenu>टूल्स</guimenu> <guisubmenu>स्क्रिप्ट</guisubmenu> <guisubmenu>संपादन</"
"guisubmenu> <guimenuitem>चयनित टेक्स्ट को क्रमबद्ध करें</guimenuitem>"

#. Tag: para
#: menus.docbook:1336
#, no-c-format
msgid "Sorts the selected text or whole document in ascending order."
msgstr "चयनित पाठ या संपूर्ण दस्तावेज़ को आरोही क्रम में सॉर्ट करता है।"

#. Tag: menuchoice
#: menus.docbook:1342
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;&Down;</keycombo> </"
"shortcut> <guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu> "
"<guisubmenu>Editing</guisubmenu> <guimenuitem>Move Lines Down</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;&Down;</keycombo> </"
"shortcut> <guimenu>टूल्स</guimenu> <guisubmenu>स्क्रिप्ट</guisubmenu> "
"<guisubmenu>संपादन</guisubmenu> <guimenuitem>लाइनों को नीचे ले जाएँ</guimenuitem>"

#. Tag: para
#: menus.docbook:1351
#, no-c-format
msgid "Move selected lines down."
msgstr "चयनित पंक्तियों को नीचे ले जाएँ."

#. Tag: menuchoice
#: menus.docbook:1357
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;&Up;</keycombo> </"
"shortcut> <guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu> "
"<guisubmenu>Editing</guisubmenu> <guimenuitem>Move Lines Up</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;&Up;</keycombo> </"
"shortcut> <guimenu>टूल्स</guimenu> <guisubmenu>स्क्रिप्ट</guisubmenu> "
"<guisubmenu>संपादन</guisubmenu> <guimenuitem>लाइनों को ऊपर ले जाएँ</guimenuitem>"

#. Tag: para
#: menus.docbook:1366
#, no-c-format
msgid "Move selected lines up."
msgstr "चयनित पंक्तियों को ऊपर ले जाएँ."

#. Tag: menuchoice
#: menus.docbook:1372
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Alt;&Down;</keycombo> </"
"shortcut> <guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu> "
"<guisubmenu>Editing</guisubmenu> <guimenuitem>Duplicate Selected Lines Down</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Alt;&Down;</keycombo> </"
"shortcut> <guimenu>टूल्स</guimenu> <guisubmenu>स्क्रिप्ट</guisubmenu> "
"<guisubmenu>संपादन</guisubmenu> <guimenuitem>चयनित पंक्तियों को नीचे डुप्लिकेट करें</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:1381
#, no-c-format
msgid "Duplicates the selected lines down."
msgstr "चयनित पंक्तियों को नीचे डुप्लिकेट करता है."

#. Tag: menuchoice
#: menus.docbook:1387
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Alt;&Up;</keycombo> </shortcut> "
"<guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu> "
"<guisubmenu>Editing</guisubmenu> <guimenuitem>Duplicate Selected Lines Up</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Alt;&Up;</keycombo> </shortcut> "
"<guimenu>टूल्स</guimenu> <guisubmenu>स्क्रिप्ट</guisubmenu> <guisubmenu>संपादन</"
"guisubmenu> <guimenuitem>चयनित पंक्तियों की प्रतिलिपि बनाएँ</guimenuitem>"

#. Tag: para
#: menus.docbook:1396
#, no-c-format
msgid "Duplicates the selected lines up."
msgstr "चयनित पंक्तियों की प्रतिलिपि बनाता है."

#. Tag: menuchoice
#: menus.docbook:1402
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu> "
"<guisubmenu>Editing</guisubmenu> <guimenuitem>URI-encode selected text</"
"guimenuitem>"
msgstr ""
"<guimenu>उपकरण</guimenu> <guisubmenu>स्क्रिप्ट</guimenu> <guimenu>संपादन</"
"guimenuitem> चयनित पाठ को यूआरआई-एनकोड करें</guimenuitem>"

#. Tag: para
#: menus.docbook:1408
#, no-c-format
msgid ""
"Encodes the selected text so that it can be used as part of a query string "
"in a &URL;, replacing the selection with the encoded text."
msgstr ""
"चयनित पाठ को एनकोड करता है ताकि इसे &URL; में क्वेरी स्ट्रिंग के भाग के रूप में उपयोग किया "
"जा सके, तथा चयनित पाठ को एनकोडेड पाठ से प्रतिस्थापित किया जा सके।"

#. Tag: menuchoice
#: menus.docbook:1415
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu> "
"<guisubmenu>Editing</guisubmenu> <guimenuitem>URI-decode selected text</"
"guimenuitem>"
msgstr ""
"<guimenu>टूल्स</guimenu> <guisubmenu>स्क्रिप्ट</guisubmenu> <guisubmenu>संपादन</"
"guisubmenu> <guimenuitem>चयनित पाठ को URI-डिकोड करें</guimenuitem>"

#. Tag: para
#: menus.docbook:1421
#, no-c-format
msgid ""
"If part of the query string of a &URL; is selected, this will decode it and "
"replace the selection with the original raw text."
msgstr ""
"यदि &URL; की क्वेरी स्ट्रिंग का भाग चयनित है, तो यह उसे डिकोड कर देगा और चयन को मूल "
"कच्चे पाठ से प्रतिस्थापित कर देगा।"

#. Tag: menuchoice
#: menus.docbook:1431
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu> <guisubmenu>Emmet</"
"guisubmenu>"
msgstr ""
"<guimenu>उपकरण</guimenu> <guisubmenu>स्क्रिप्ट</guisubmenu> <guisubmenu>एम्मेट</"
"guisubmenu>"

#. Tag: menuchoice
#: menus.docbook:1439
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu> <guisubmenu>Emmet</"
"guisubmenu> <guimenuitem>Expand abbreviation</guimenuitem>"
msgstr ""
"<guimenu>उपकरण</guimenu> <guisubmenu>स्क्रिप्ट</guimenuitem> <guimenu>एम्मेट</"
"guimenuitem>संक्षेप का विस्तार करें</guimenuitem>"

#. Tag: para
#: menus.docbook:1445
#, no-c-format
msgid ""
"Converts the selected text to a pair of opening and closing &HTML; or &XML; "
"tags. For example, if <userinput>div</userinput> is selected, this item will "
"replace that with <computeroutput>&lt;div&gt;&lt;/div&gt;</computeroutput>."
msgstr ""
"चयनित टेक्स्ट को आरंभिक और समापन &HTML; या &XML; टैग की जोड़ी में परिवर्तित करता है। "
"उदाहरण के लिए, यदि <userinput>div</userinput> चयनित है, तो यह आइटम उसे "
"<computeroutput>&lt;div&gt;&lt;/div&gt;</computeroutput> से प्रतिस्थापित कर देगा।"

#. Tag: menuchoice
#: menus.docbook:1453
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu> <guisubmenu>Emmet</"
"guisubmenu> <guimenuitem>Wrap with tag</guimenuitem>"
msgstr ""
"<guimenu>टूल्स</guimenu> <guisubmenu>स्क्रिप्ट</guisubmenu> <guisubmenu>एम्मेट</"
"guisubmenu> <guimenuitem>टैग के साथ लपेटें</guimenuitem>"

#. Tag: para
#: menus.docbook:1459
#, no-c-format
msgid ""
"Wraps the selected text with the tag provided on the <link linkend=\"dev-"
"scripting-command-line\">command line</link>."
msgstr ""
"चयनित पाठ को दिए गए टैग के साथ लपेटता है<link linkend=\"dev-scripting-command-"
"line\"> कमांड लाइन</link> ."

#. Tag: menuchoice
#: menus.docbook:1466
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu> <guisubmenu>Emmet</"
"guisubmenu> <guimenuitem>Move cursor to matching tag</guimenuitem>"
msgstr ""
"<guimenu>टूल्स</guimenu> <guimenu>स्क्रिप्ट</guimenuitem> <guimenu>एम्मेट</"
"guimenuitem> <guimenuitem>कर्सर को मेल खाने वाले टैग पर ले जाएं</guimenuitem>"

#. Tag: para
#: menus.docbook:1472
#, no-c-format
msgid ""
"If the cursor is inside an opening &HTML;/&XML; tag, this item will move it "
"to the closing tag. If the cursor is inside the closing tag, it will instead "
"move it to the opening tag."
msgstr ""
"यदि कर्सर किसी आरंभिक &HTML;/&XML; टैग के अंदर है, तो यह आइटम उसे समापन टैग पर ले "
"जाएगा। यदि कर्सर समापन टैग के अंदर है, तो यह उसे आरंभिक टैग पर ले जाएगा।"

#. Tag: menuchoice
#: menus.docbook:1480
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu> <guisubmenu>Emmet</"
"guisubmenu> <guimenuitem>Select &HTML;/&XML; tag contents inwards</"
"guimenuitem>"
msgstr ""
"<guimenu>टूल्स</guimenu> <guisubmenu>स्क्रिप्ट</guisubmenu> <guisubmenu>Emmet</"
"guisubmenu> <guimenuitem>अंदर की ओर &HTML;/&XML; टैग सामग्री का चयन करें</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:1486
#, no-c-format
msgid ""
"When the cursor is inside a pair of &HTML;/&XML; tags, this option will "
"change the selection to include the contents of those &HTML;/&XML; tags, "
"without selecting the tags themselves."
msgstr ""
"जब कर्सर &HTML;/&XML; टैग्स के एक जोड़े के अंदर होता है, तो यह विकल्प उन &HTML;/&XML; "
"टैग्स की सामग्री को शामिल करने के लिए चयन को बदल देगा, बिना टैग्स का चयन किए।"

#. Tag: menuchoice
#: menus.docbook:1494
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu> <guisubmenu>Emmet</"
"guisubmenu> <guimenuitem>Select &HTML;/&XML; tag contents outwards</"
"guimenuitem>"
msgstr ""
"<guimenu>टूल्स</guimenu> <guisubmenu>स्क्रिप्ट</guisubmenu> <guimenu>एम्मेट</"
"guimenuitem>&HTML;/&XML चुनें; सामग्री को बाहर की ओर टैग करें</guimenuitem>"

#. Tag: para
#: menus.docbook:1500
#, no-c-format
msgid ""
"When the cursor is inside a pair of &HTML;/&XML; tags, this item will change "
"the selection to include the contents of those &HTML;/&XML; tags, including "
"the tags themselves."
msgstr ""
"जब कर्सर &HTML;/&XML; टैग्स की एक जोड़ी के अंदर होता है, तो यह आइटम उन &HTML;/&XML; "
"टैग्स की सामग्री को शामिल करने के लिए चयन को बदल देगा, जिसमें स्वयं टैग्स भी शामिल हैं।"

#. Tag: menuchoice
#: menus.docbook:1508
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu> <guisubmenu>Emmet</"
"guisubmenu> <guimenuitem>Toggle Comment</guimenuitem>"
msgstr ""
"<guimenu>उपकरण</guimenu> <guimenu>स्क्रिप्ट</guimenuitem> <guimenu>एम्मेट</"
"guimenuitem> <guimenuitem>टिप्पणी टॉगल करें</guimenuitem>"

#. Tag: para
#: menus.docbook:1514
#, no-c-format
msgid ""
"If the selected portion is not a comment, this item will enclose that "
"portion in &HTML;/&XML; comments (&eg; <computeroutput>&lt;!-- selected text "
"--&gt;</computeroutput>). If the selected portion is a comment, the comment "
"tags will be removed instead."
msgstr ""
"यदि चयनित भाग कोई टिप्पणी नहीं है, तो यह आइटम उस भाग को &HTML;/&XML; टिप्पणियों में "
"संलग्न कर देगा (&eg; <computeroutput>&lt;!-- selected text --&gt;</"
"computeroutput>)। यदि चयनित भाग कोई टिप्पणी है, तो इसके स्थान पर टिप्पणी टैग हटा "
"दिए जाएंगे।"

#. Tag: menuchoice
#: menus.docbook:1525
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu><guisubmenu>Scripts</guisubmenu><guisubmenu>Emmet</"
"guisubmenu> <guimenuitem>Delete tag under cursor</guimenuitem>"
msgstr ""
"<guimenu>टूल्स</guimenu><guisubmenu>स्क्रिप्ट</guimenu><guisubmenu>एम्मेट</"
"guimenutem> <guimenuitem>कर्सर के नीचे टैग हटाएं</guimenuitem>"

#. Tag: para
#: menus.docbook:1529
#, no-c-format
msgid ""
"If the cursor is presently inside a &HTML;/&XML; tag, this item will delete "
"the entire tag."
msgstr ""
"यदि कर्सर वर्तमान में &HTML;/&XML; टैग के अंदर है, तो यह आइटम संपूर्ण टैग को हटा देगा।"

#. Tag: menuchoice
#: menus.docbook:1536
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu> <guisubmenu>Emmet</"
"guisubmenu> <guimenuitem>Decrement number by 1</guimenuitem>"
msgstr ""
"<guimenu>टूल्स</guimenu> <guisubmenu>स्क्रिप्ट</guisubmenu> <guisubmenu>एम्मेट</"
"guisubmenu> <guimenuitem>संख्या में 1 की कमी करें</guimenuitem>"

#. Tag: para
#: menus.docbook:1542
#, no-c-format
msgid ""
"This item will subtract one from the currently selected text, if it is a "
"number. For example, if <userinput>5</userinput> is selected, it will become "
"<computeroutput>4</computeroutput>."
msgstr ""
"यह आइटम वर्तमान में चयनित टेक्स्ट से एक घटा देगा, यदि यह एक संख्या है। उदाहरण के लिए, "
"यदि <userinput>5</userinput> चुना जाता है, तो यह <computeroutput>4</"
"computeroutput> बन जाएगा।"

#. Tag: menuchoice
#: menus.docbook:1550
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu> <guisubmenu>Emmet</"
"guisubmenu> <guimenuitem>Decrement number by 10</guimenuitem>"
msgstr ""
"<guimenu>टूल्स</guimenu> <guisubmenu>स्क्रिप्ट</guisubmenu> <guisubmenu>एम्मेट</"
"guisubmenu> <guimenuitem>संख्या में 10 की कमी करें</guimenuitem>"

#. Tag: para
#: menus.docbook:1556
#, no-c-format
msgid ""
"This item will subtract 10 from the currently selected text, if it is a "
"number. For example, if <userinput>15</userinput> is selected, it will "
"become <computeroutput>5</computeroutput>."
msgstr ""
"यह आइटम वर्तमान में चयनित टेक्स्ट से 10 घटा देगा, यदि यह एक संख्या है। उदाहरण के लिए, "
"यदि <userinput>15</userinput> चुना जाता है, तो यह <computeroutput>5</"
"computeroutput> बन जाएगा।"

#. Tag: menuchoice
#: menus.docbook:1564
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu> <guisubmenu>Emmet</"
"guisubmenu> <guimenuitem>Decrement number by 0.1</guimenuitem>"
msgstr ""
"<guimenu>टूल्स</guimenu> <guisubmenu>स्क्रिप्ट</guisubmenu> <guisubmenu>एम्मेट</"
"guisubmenu> <guimenuitem>संख्या में 0.1 की कमी करें</guimenuitem>"

#. Tag: para
#: menus.docbook:1570
#, no-c-format
msgid ""
"This item will subtract 0.1 from the currently selected text, if it is a "
"number. For example, if <userinput>4.5</userinput> is selected, it will "
"become <computeroutput>4.4</computeroutput>."
msgstr ""
"यह आइटम वर्तमान में चयनित टेक्स्ट से 0.1 घटा देगा, यदि यह एक संख्या है। उदाहरण के लिए, "
"यदि <userinput>4.5</userinput> चुना जाता है, तो यह <computeroutput>4.4</"
"computeroutput> बन जाएगा।"

#. Tag: menuchoice
#: menus.docbook:1578
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu> <guisubmenu>Emmet</"
"guisubmenu> <guimenuitem>Increment number by 1</guimenuitem>"
msgstr ""
"<guimenu>टूल्स</guimenu> <guisubmenu>स्क्रिप्ट</guisubmenu> <guisubmenu>एम्मेट</"
"guisubmenu> <guimenuitem>संख्या में 1 की वृद्धि करें</guimenuitem>"

#. Tag: para
#: menus.docbook:1584
#, no-c-format
msgid ""
"This item will add one to the currently selected text, if it is a number. "
"For example, if <userinput>5</userinput> is selected, it will become "
"<computeroutput>6</computeroutput>."
msgstr ""
"यह आइटम वर्तमान में चयनित टेक्स्ट में एक जोड़ देगा, यदि यह एक संख्या है। उदाहरण के लिए, "
"यदि <userinput>5</userinput> चुना जाता है, तो यह <computeroutput>6</"
"computeroutput> बन जाएगा।"

#. Tag: menuchoice
#: menus.docbook:1592
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu> <guisubmenu>Emmet</"
"guisubmenu> <guimenuitem>Increment number by 10</guimenuitem>"
msgstr ""
"<guimenu>टूल्स</guimenu> <guisubmenu>स्क्रिप्ट</guisubmenu> <guisubmenu>एम्मेट</"
"guisubmenu> <guimenuitem>संख्या में 10 की वृद्धि करें</guimenuitem>"

#. Tag: para
#: menus.docbook:1598
#, no-c-format
msgid ""
"This item will add 10 to the currently selected text, if it is a number. For "
"example, if <userinput>5</userinput> is selected, it will become "
"<computeroutput>15</computeroutput>."
msgstr ""
"यह आइटम वर्तमान में चयनित टेक्स्ट में 10 जोड़ देगा, यदि यह एक संख्या है। उदाहरण के लिए, "
"यदि <userinput>5</userinput> चुना जाता है, तो यह <computeroutput>15</"
"computeroutput> बन जाएगा।"

#. Tag: menuchoice
#: menus.docbook:1606
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu> <guisubmenu>Emmet</"
"guisubmenu> <guimenuitem>Increment number by 0.1</guimenuitem>"
msgstr ""
"<guimenu>टूल्स</guimenu> <guisubmenu>स्क्रिप्ट</guisubmenu> <guisubmenu>एम्मेट</"
"guisubmenu> <guimenuitem>संख्या में 0.1 की वृद्धि करें</guimenuitem>"

#. Tag: para
#: menus.docbook:1612
#, no-c-format
msgid ""
"This item will add 0.1 to the currently selected text, if it is a number. "
"For example, if <userinput>4.5</userinput> is selected, it will become "
"<computeroutput>4.6</computeroutput>."
msgstr ""
"यह आइटम वर्तमान में चयनित टेक्स्ट में 0.1 जोड़ देगा, यदि यह एक संख्या है। उदाहरण के लिए, "
"यदि <userinput>4.5</userinput> चुना जाता है, तो यह <computeroutput>4.6</"
"computeroutput> बन जाएगा।"

#. Tag: menuchoice
#: menus.docbook:1628
#, no-c-format
msgid ""
"<shortcut> <keycap>F7</keycap> </shortcut> <guimenu>Tools</guimenu> "
"<guimenuitem>Switch to Command Line</guimenuitem>"
msgstr ""
"<shortcut> <keycap>F7</keycap> </shortcut> <guimenu>टूल्स</guimenu> "
"<guimenuitem>कमांड लाइन पर स्विच करें</guimenuitem>"

#. Tag: para
#: menus.docbook:1636
#, no-c-format
msgid ""
"Displays the &katepart; command line at the bottom of the window. In the "
"command line, type <userinput>help</userinput> to get help and "
"<userinput>help list</userinput> to get a list of commands. For more "
"information on the command line, see <link linkend=\"advanced-editing-tools-"
"commandline\">The Editor Component Command Line</link>."
msgstr ""
"विंडो के निचले भाग में &amp;katepart; कमांड लाइन प्रदर्शित करता है। कमांड लाइन में, टाइप "
"करें<userinput> मदद</userinput> सहायता पाने के लिए और<userinput> सहायता सूची</"
"userinput> कमांड की सूची प्राप्त करने के लिए। कमांड लाइन पर अधिक जानकारी के लिए, "
"देखें<link linkend=\"advanced-editing-tools-commandline\"> संपादक घटक कमांड लाइन</"
"link> ."

#. Tag: menuchoice
#: menus.docbook:1645
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Space;</keycombo> </shortcut> "
"<guimenu>Tools</guimenu> <guimenuitem>Invoke Code Completion</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Space;</keycombo> </shortcut> "
"<guimenu>टूल्स</guimenu> <guimenuitem>कोड पूर्णता लागू करें</guimenuitem>"

#. Tag: para
#: menus.docbook:1653
#, no-c-format
msgid ""
"Manually invoke command completion, usually by using a shortcut bound to "
"this action."
msgstr ""
"कमांड पूर्णता को मैन्युअल रूप से लागू करें, आमतौर पर इस क्रिया से जुड़े शॉर्टकट का उपयोग करके।"

#. Tag: menuchoice
#: menus.docbook:1658
#, no-c-format
msgid "<guimenu>Tools</guimenu> <guimenuitem>Word Completion</guimenuitem>"
msgstr "<guimenu>टूल्स</guimenu> <guimenuitem>शब्द पूर्णता</guimenuitem>"

#. Tag: para
#: menus.docbook:1663
#, no-c-format
msgid ""
"<guimenuitem>Reuse Word Below</guimenuitem> (<keycombo action=\"simul"
"\">&Ctrl; <keycap>9</keycap></keycombo>) and <guimenuitem>Reuse Word Above</"
"guimenuitem> (<keycombo action=\"simul\">&Ctrl; <keycap>8</keycap></"
"keycombo>) complete the currently typed text by searching for similar words "
"backward or forward from the current cursor position. <guimenuitem>Shell "
"Completion</guimenuitem> pops up a completion box with matching entries."
msgstr ""
"<guimenuitem>नीचे शब्द का पुनः उपयोग करें</guimenuitem> (<keycombo action=\"simul"
"\">&Ctrl; <keycap>9</keycap></keycombo>) और <guimenuitem>ऊपर शब्द का पुनः "
"उपयोग करें</guimenuitem> (<keycombo action=\"simul\">&Ctrl; <keycap>8</"
"keycap></keycombo>) वर्तमान कर्सर स्थिति से पीछे या आगे समान शब्दों की खोज करके "
"वर्तमान में टाइप किए गए पाठ को पूरा करते हैं। <guimenuitem>शेल पूर्णता</guimenuitem> "
"मेल खाने वाली प्रविष्टियों के साथ एक पूर्णता बॉक्स पॉप अप करता है।"

#. Tag: menuchoice
#: menus.docbook:1673
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>O</keycap></"
"keycombo> </shortcut> <guimenu>Tools</guimenu> <guisubmenu>Spelling</"
"guisubmenu> <guimenuitem>Automatic Spell Checking</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>O</keycap></"
"keycombo> </shortcut> <guimenu>टूल्स</guimenu> <guisubmenu>वर्तनी</guisubmenu> "
"<guimenuitem>स्वचालित वर्तनी जाँच</guimenuitem>"

#. Tag: para
#: menus.docbook:1682
#, no-c-format
msgid ""
"When <guimenuitem>Automatic Spell Checking</guimenuitem> is enabled, wrongly "
"spelled text is underlined in the document on-the-fly."
msgstr ""
"जब <guimenuitem>स्वचालित वर्तनी जाँच</guimenuitem> सक्षम होती है, तो दस्तावेज़ में गलत "
"वर्तनी वाला पाठ तुरंत रेखांकित हो जाता है।"

#. Tag: menuchoice
#: menus.docbook:1688
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu> <guisubmenu>Spelling</guisubmenu> "
"<guimenuitem>Spelling...</guimenuitem>"
msgstr ""
"<guimenu>टूल्स</guimenu> <guisubmenu>वर्तनी</guisubmenu> <guimenuitem>वर्तनी...</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:1699
#, no-c-format
msgid ""
"<action>This initiates the spellchecking program - a program designed to "
"help the user catch and correct any spelling errors.</action> Clicking on "
"this entry will start the checker and bring up the speller dialog box "
"through which the user can control the process. There are four settings "
"lined up vertically in the center of the dialog with their corresponding "
"labels just to the left. Starting at the top they are:"
msgstr ""
"<action>यह वर्तनी जाँच कार्यक्रम आरंभ करता है - एक ऐसा कार्यक्रम जो उपयोगकर्ता को "
"किसी भी वर्तनी त्रुटि को पकड़ने और उसे सही करने में मदद करने के लिए डिज़ाइन किया गया है।</"
"action> इस प्रविष्टि पर क्लिक करने से जाँचकर्ता शुरू हो जाएगा और स्पेलर संवाद बॉक्स सामने "
"आएगा जिसके माध्यम से उपयोगकर्ता प्रक्रिया को नियंत्रित कर सकता है। संवाद के केंद्र में चार "
"सेटिंग्स लंबवत पंक्तिबद्ध हैं जिनके संगत लेबल बाईं ओर हैं। शीर्ष से शुरू करते हुए वे हैं:"

#. Tag: guilabel
#: menus.docbook:1709
#, no-c-format
msgid "Unknown word:"
msgstr "अज्ञात शब्द:"

#. Tag: para
#: menus.docbook:1710
#, no-c-format
msgid ""
"Here, the spellchecker indicates the word currently under consideration. "
"This happens when the checker encounters a word not in its dictionary - a "
"file containing a list of correctly spelled words against which it compares "
"each word in the editor."
msgstr ""
"यहाँ, वर्तनी जाँचक वर्तमान में विचाराधीन शब्द को इंगित करता है। ऐसा तब होता है जब जाँचक "
"को कोई ऐसा शब्द मिलता है जो उसके शब्दकोश में नहीं है - एक फ़ाइल जिसमें सही वर्तनी वाले "
"शब्दों की सूची होती है जिसके साथ वह संपादक में प्रत्येक शब्द की तुलना करता है।"

#. Tag: guilabel
#: menus.docbook:1717
#, no-c-format
msgid "Replace with:"
msgstr "के साथ बदलें:"

#. Tag: para
#: menus.docbook:1718
#, no-c-format
msgid ""
"If the checker has any similar words in its dictionary the first one will be "
"listed here. The user can accept the suggestion, type in his or her own "
"correction, or choose a different suggestion from the next box."
msgstr ""
"अगर चेकर के शब्दकोश में कोई समान शब्द है तो पहला शब्द यहाँ सूचीबद्ध किया जाएगा। "
"उपयोगकर्ता सुझाव स्वीकार कर सकता है, अपना स्वयं का सुधार टाइप कर सकता है, या अगले "
"बॉक्स से कोई अलग सुझाव चुन सकता है।"

#. Tag: guilabel
#: menus.docbook:1724
#, no-c-format
msgid "Language:"
msgstr "भाषा:"

#. Tag: para
#: menus.docbook:1725
#, no-c-format
msgid ""
"If you have installed multiple dictionaries, here you can select which "
"dictionary/language should be used."
msgstr ""
"यदि आपने एक से अधिक शब्दकोश स्थापित किए हैं, तो यहां आप चुन सकते हैं कि किस शब्दकोश/भाषा "
"का उपयोग किया जाना चाहिए।"

#. Tag: para
#: menus.docbook:1730
#, no-c-format
msgid ""
"On the right side of the dialog box are 6 buttons that allow the user to "
"control the spellcheck process. They are:"
msgstr ""
"डायलॉग बॉक्स के दाईं ओर 6 बटन हैं जो उपयोगकर्ता को वर्तनी जाँच प्रक्रिया को नियंत्रित "
"करने की अनुमति देते हैं। वे हैं:"

#. Tag: guibutton
#: menus.docbook:1736
#, no-c-format
msgid "Add to Dictionary"
msgstr "शब्दकोश में जोड़ें"

#. Tag: para
#: menus.docbook:1737
#, no-c-format
msgid ""
"Pressing this button adds the <guilabel>Unknown word </guilabel> to the "
"checker's dictionary. This means that in the future the checker will always "
"consider this word to be correctly spelled."
msgstr ""
"इस बटन को दबाने से <guilabel>अज्ञात शब्द </guilabel> चेकर की डिक्शनरी में जुड़ जाता है। "
"इसका मतलब यह है कि भविष्य में चेकर हमेशा इस शब्द को सही वर्तनी वाला मानेगा।"

#. Tag: guilabel
#: menus.docbook:1744
#, no-c-format
msgid "Suggest"
msgstr "सुझाव देना"

#. Tag: para
#: menus.docbook:1745
#, no-c-format
msgid ""
"The checker may list here a number of possible replacements for the word "
"under consideration. Clicking on any one of the suggestions will cause that "
"word to be entered in the <guilabel>Replace with</guilabel> box, above."
msgstr ""
"जाँचकर्ता यहाँ विचाराधीन शब्द के लिए कई संभावित प्रतिस्थापनों को सूचीबद्ध कर सकता है। "
"सुझावों में से किसी एक पर क्लिक करने से वह शब्द ऊपर दिए गए <guilabel>इसके साथ बदलें</"
"guilabel> बॉक्स में दर्ज हो जाएगा।"

#. Tag: guibutton
#: menus.docbook:1752
#, no-c-format
msgid "Replace"
msgstr "प्रतिस्थापित करें"

#. Tag: para
#: menus.docbook:1753
#, no-c-format
msgid ""
"This button has the checker replace the word under consideration in the "
"document with the word in the <guilabel>Replace with</guilabel> box."
msgstr ""
"इस बटन से परीक्षक दस्तावेज़ में विचाराधीन शब्द को <guilabel>इससे प्रतिस्थापित करें</"
"guilabel> बॉक्स में दिए गए शब्द से प्रतिस्थापित कर सकता है।"

#. Tag: guibutton
#: menus.docbook:1759
#, no-c-format
msgid "Replace All"
msgstr "सभी को प्रतिस्थापित करें"

#. Tag: para
#: menus.docbook:1760
#, no-c-format
msgid ""
"This button causes the checker to replace not only the current "
"<guilabel>Unknown word:</guilabel> but to automatically make the same "
"substitution for any other occurrences of this <guilabel>Unknown word</"
"guilabel> in the document."
msgstr ""
"यह बटन परीक्षक को न केवल वर्तमान <guilabel>अज्ञात शब्द:</guilabel> को प्रतिस्थापित "
"करने का कारण बनता है, बल्कि दस्तावेज़ में इस <guilabel>अज्ञात शब्द</guilabel> की किसी "
"भी अन्य घटना के लिए स्वचालित रूप से समान प्रतिस्थापन करता है।"

#. Tag: guibutton
#: menus.docbook:1767
#, no-c-format
msgid "Ignore"
msgstr "अनदेखा करना"

#. Tag: para
#: menus.docbook:1768
#, no-c-format
msgid ""
"Activating this button will have the checker move on without making any "
"changes."
msgstr "इस बटन को सक्रिय करने से चेकर बिना कोई परिवर्तन किए आगे बढ़ जाएगा।"

#. Tag: guibutton
#: menus.docbook:1773
#, no-c-format
msgid "Ignore All"
msgstr "सभी को अनदेखा करें"

#. Tag: para
#: menus.docbook:1774
#, no-c-format
msgid ""
"This button tells the checker to do nothing with the current "
"<guilabel>Unknown word:</guilabel> and to pass over any other instances of "
"the same word."
msgstr ""
"यह बटन परीक्षक को वर्तमान <guilabel>अज्ञात शब्द:</guilabel> के साथ कुछ भी न करने "
"तथा उसी शब्द के किसी अन्य उदाहरण को छोड़ देने के लिए कहता है।"

#. Tag: para
#: menus.docbook:1776
#, no-c-format
msgid ""
"This only applies to the current spellcheck run. If the checker is run again "
"later it will stop on this same word."
msgstr ""
"यह केवल वर्तमान वर्तनी जाँच रन पर लागू होता है। यदि बाद में जाँचकर्ता को फिर से चलाया "
"जाता है तो यह इसी शब्द पर रुक जाएगा।"

#. Tag: para
#: menus.docbook:1783
#, no-c-format
msgid ""
"Three more buttons are located horizontally along the bottom of the "
"spellcheck dialog. They are:"
msgstr "वर्तनी जाँच संवाद के निचले भाग में क्षैतिज रूप से तीन और बटन स्थित हैं। वे हैं:"

#. Tag: guibutton
#: menus.docbook:1789
#, no-c-format
msgid "Help"
msgstr "मदद"

#. Tag: para
#: menus.docbook:1790
#, no-c-format
msgid "This invokes the &kde; help system with the help page for this dialog."
msgstr ""
"यह इस संवाद के लिए सहायता पृष्ठ के साथ &kde; सहायता प्रणाली को आमंत्रित करता है।"

#. Tag: guibutton
#: menus.docbook:1795
#, no-c-format
msgid "Finished"
msgstr "खत्म"

#. Tag: para
#: menus.docbook:1796
#, no-c-format
msgid "This button ends the spellcheck process, and returns to the document."
msgstr "यह बटन वर्तनी जांच प्रक्रिया को समाप्त करता है, और दस्तावेज़ पर वापस लौटता है।"

#. Tag: guibutton
#: menus.docbook:1801
#, no-c-format
msgid "Cancel"
msgstr "रद्द करना"

#. Tag: para
#: menus.docbook:1802
#, no-c-format
msgid ""
"This button cancels the spellcheck process, all modifications are reverted, "
"and you will return to your document."
msgstr ""
"यह बटन वर्तनी जांच प्रक्रिया को रद्द कर देता है, सभी संशोधन पूर्ववत हो जाते हैं, और आप "
"अपने दस्तावेज़ पर वापस आ जाएंगे।"

#. Tag: menuchoice
#: menus.docbook:1813
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu> <guisubmenu>Spelling</guisubmenu> "
"<guimenuitem>Spelling (from cursor)...</guimenuitem>"
msgstr ""
"<guimenu>टूल्स</guimenu> <guisubmenu>वर्तनी</guisubmenu> <guimenuitem>वर्तनी "
"(कर्सर से)...</guimenuitem>"

#. Tag: para
#: menus.docbook:1819
#, no-c-format
msgid ""
"This initiates the spellchecking program but it starts where your cursor is "
"instead of at the beginning of the document."
msgstr ""
"इससे वर्तनी जांच कार्यक्रम आरंभ हो जाता है, लेकिन यह दस्तावेज़ के आरंभ में नहीं, बल्कि वहां से "
"आरंभ होता है जहां आपका कर्सर होता है।"

#. Tag: menuchoice
#: menus.docbook:1825
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu> <guisubmenu>Spelling</guisubmenu> "
"<guimenuitem>Spellcheck Selection...</guimenuitem>"
msgstr ""
"<guimenu>टूल्स</guimenu> <guisubmenu>वर्तनी</guisubmenu> <guimenuitem>वर्तनी जांच "
"चयन...</guimenuitem>"

#. Tag: para
#: menus.docbook:1831
#, no-c-format
msgid "Spellchecks the current selection."
msgstr "वर्तमान चयन की वर्तनी जाँचता है."

#. Tag: menuchoice
#: menus.docbook:1836
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu> <guisubmenu>Spelling</guisubmenu> "
"<guimenuitem>Change Dictionary</guimenuitem>"
msgstr ""
"<guimenu>टूल्स</guimenu> <guisubmenu>वर्तनी</guisubmenu> <guimenuitem>शब्दकोश "
"बदलें</guimenuitem>"

#. Tag: para
#: menus.docbook:1842
#, no-c-format
msgid ""
"Displays a drop down box with all available dictionaries for spellchecking "
"at the bottom of the editor window. This allows easy switching of the "
"spellcheck dictionary &eg; for automatic spellcheck of text in different "
"languages."
msgstr ""
"संपादक विंडो के निचले भाग में वर्तनी जाँच के लिए सभी उपलब्ध शब्दकोशों के साथ एक ड्रॉप डाउन "
"बॉक्स प्रदर्शित करता है। यह वर्तनी जाँच शब्दकोश को आसानी से बदलने की अनुमति देता है &eg; "
"विभिन्न भाषाओं में पाठ की स्वचालित वर्तनी जाँच के लिए।"

#. Tag: title
#: menus.docbook:1852
#, no-c-format
msgid "The Settings and Help Menu"
msgstr "सेटिंग्स और सहायता मेनू"

#. Tag: menuchoice
#: menus.docbook:1856
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guisubmenu>Editor Color Theme</guisubmenu>"
msgstr "<guimenu>सेटिंग्स</guimenu> <submenu>रंग थीम संपादक</guimenu>"

#. Tag: para
#: menus.docbook:1860
#, no-c-format
msgid ""
"This menu lists the available color schemes. You can change the schema for "
"the current view here, to change the default schema you need to use the "
"<ulink url=\"help:/katepart/config-dialog-editor.html#prefcolors\">Fonts "
"&amp; Colors</ulink> page of the config dialog."
msgstr ""
"यह मेनू उपलब्ध रंग योजनाओं को सूचीबद्ध करता है। आप वर्तमान दृश्य के लिए स्कीमा को यहाँ बदल "
"सकते हैं, डिफ़ॉल्ट स्कीमा को बदलने के लिए आपको कॉन्फ़िगरेशन संवाद के <ulink url=\"help:/"
"katepart/config-dialog-editor.html#prefcolors\">फ़ॉन्ट और रंग</ulink> पृष्ठ का "
"उपयोग करना होगा।"

#. Tag: para
#: menus.docbook:1868
#, no-c-format
msgid ""
"&katepart; has the common &kde; <guimenu>Settings</guimenu> and "
"<guimenu>Help</guimenu> menu items, for more information read the sections "
"about the <ulink url=\"help:/fundamentals/menus.html#menus-settings"
"\">Settings Menu</ulink> and <ulink url=\"help:/fundamentals/menus."
"html#menus-help\">Help Menu</ulink> of the &kde; Fundamentals."
msgstr ""
"&katepart; में सामान्य &kde; <guimenu>सेटिंग्स</guimenu> और <guimenu>सहायता</"
"guimenu> मेनू आइटम हैं, अधिक जानकारी के लिए &kde; फंडामेंटल्स के <ulink url=\"help:/"
"fundamentals/menus.html#menus-settings\">सेटिंग्स मेनू</ulink> और <ulink url="
"\"help:/fundamentals/menus.html#menus-help\">सहायता मेनू</ulink> के बारे में अनुभाग "
"पढ़ें।"
