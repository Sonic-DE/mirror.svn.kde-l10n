#. Tag: title
#: menus.docbook:2
#, no-c-format
msgid "The Menu Entries"
msgstr "मेनू प्रविष्टियाँ"

#. Tag: title
#: menus.docbook:5
#, no-c-format
msgid "The File Menu"
msgstr "फ़ाइल मेनू"

#. Tag: menuchoice
#: menus.docbook:10
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>N</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>New</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>N</keycap></keycombo> </"
"shortcut> <guimenu>फ़ाइल</guimenu> <guimenuitem>नया</guimenuitem>"

#. Tag: para
#: menus.docbook:18
#, no-c-format
msgid "This starts a new document in a new and independent editor window."
msgstr "इससे एक नया दस्तावेज़ एक नई और स्वतंत्र संपादक विंडो में शुरू हो जाता है।"

#. Tag: menuchoice
#: menus.docbook:25
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>New Window</guimenuitem>"
msgstr "<guimenu>फ़ाइल</guimenu> <guimenuitem>नई विंडो</guimenuitem>"

#. Tag: para
#: menus.docbook:30
#, no-c-format
msgid ""
"Create another window containing the current document. All changes to the "
"document in one window are reflected in the other window and vice versa."
msgstr ""
"वर्तमान दस्तावेज़ वाली एक और विंडो बनाएँ। एक विंडो में दस्तावेज़ में किए गए सभी परिवर्तन "
"दूसरी विंडो में दिखाई देंगे और इसके विपरीत।"

#. Tag: menuchoice
#: menus.docbook:36
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>O</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Open...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo Action='simul'>&Ctrl;<keycap>O</keycap></keycombo> </"
"shortcut> <guimenu>फ़ाइल</guimenu> <guimenuitem>खोलें...</guimenuitem>"

#. Tag: para
#: menus.docbook:44
#, no-c-format
msgid ""
"Displays a standard &kde; <guilabel>Open File</guilabel> dialog. Use the "
"file view to select the file you want to open, and click on <guibutton>Open</"
"guibutton> to open it."
msgstr ""
"एक मानक &kde; <guilabel>फ़ाइल खोलें</guilabel> संवाद प्रदर्शित करता है। जिस फ़ाइल को "
"आप खोलना चाहते हैं उसे चुनने के लिए फ़ाइल दृश्य का उपयोग करें, और उसे खोलने के लिए "
"<guibutton>खोलें</guibutton> पर क्लिक करें।"

#. Tag: menuchoice
#: menus.docbook:51
#, no-c-format
msgid "<guimenu>File</guimenu> <guisubmenu>Open Recent</guisubmenu>"
msgstr "<मेनू>फ़ाइल</मेनू> <मेनू>हाल ही में खोलें</मेनू>"

#. Tag: para
#: menus.docbook:56
#, no-c-format
msgid ""
"This is a shortcut to open recently saved documents. Clicking on this item "
"opens a list to the side of the menu with several of the most recently saved "
"files. Clicking on a specific file will open it in &kappname; - if the file "
"still resides at the same location."
msgstr ""
"यह हाल ही में सहेजे गए दस्तावेज़ों को खोलने का एक शॉर्टकट है। इस आइटम पर क्लिक करने से मेनू "
"के किनारे एक सूची खुलती है जिसमें सबसे हाल ही में सहेजी गई कई फ़ाइलें होती हैं। किसी विशिष्ट "
"फ़ाइल पर क्लिक करने से वह &kappname; में खुलेगी - यदि फ़ाइल अभी भी उसी स्थान पर मौजूद है।"

#. Tag: menuchoice
#: menus.docbook:67
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>S</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Save</guimenuitem>"
msgstr ""
"<shortcut> <keycombo Action='simul'>&Ctrl;<keycap>S</keycap></keycombo> </"
"shortcut> <guimenu>फ़ाइल</guimenu> <guimenuitem>सहेजें</guimenuitem>"

#. Tag: para
#: menus.docbook:75
#, no-c-format
msgid ""
"This saves the current document. If there has already been a save of the "
"document then this will overwrite the previously saved file without asking "
"for the user's consent. If it is the first save of a new document the save "
"as dialog (described below) will be invoked."
msgstr ""
"यह वर्तमान दस्तावेज़ को सहेजता है। यदि दस्तावेज़ को पहले ही सहेजा जा चुका है, तो यह "
"उपयोगकर्ता की सहमति के बिना पहले से सहेजी गई फ़ाइल को अधिलेखित कर देगा। यदि यह किसी "
"नए दस्तावेज़ का पहला सहेजा गया है, तो सहेजें के रूप में संवाद (नीचे वर्णित) को आमंत्रित किया "
"जाएगा।"

#. Tag: menuchoice
#: menus.docbook:85
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>S</keycap></"
"keycombo> </shortcut> <guimenu>File</guimenu> <guimenuitem>Save As...</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>S</keycap></"
"keycombo> </shortcut> <guimenu>फ़ाइल</guimenu> <guimenuitem>इस रूप में सहेजें...</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:93
#, no-c-format
msgid ""
"This allows a document to be saved with a new file name. This is done by "
"means of the file dialog box described above in the <link linkend=\"file-open"
"\">Open</link> section of this help file."
msgstr ""
"इससे दस्तावेज़ को नए फ़ाइल नाम से सहेजा जा सकता है। यह ऊपर वर्णित फ़ाइल डायलॉग बॉक्स के "
"माध्यम से किया जाता है।<link linkend=\"file-open\"> खुला</link> इस सहायता फ़ाइल "
"का अनुभाग देखें."

#. Tag: menuchoice
#: menus.docbook:102
#, no-c-format
msgid ""
"<guimenu>File</guimenu> <guimenuitem>Save As with Encoding</guimenuitem>"
msgstr "<guimenu>फ़ाइल</guimenu> <guimenuitem>एन्कोडिंग के साथ सहेजें</guimenuitem>"

#. Tag: para
#: menus.docbook:107
#, no-c-format
msgid "Save a document with a new file name in a different encoding."
msgstr "किसी दस्तावेज़ को भिन्न एनकोडिंग में नए फ़ाइल नाम से सहेजें."

#. Tag: menuchoice
#: menus.docbook:113
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Save Copy As</guimenuitem>"
msgstr "<guimenu>फ़ाइल</guimenu> <guimenuitem>कॉपी इस रूप में सहेजें</guimenuitem>"

#. Tag: para
#: menus.docbook:118
#, no-c-format
msgid ""
"Save a copy of the document with a new file name and continue editing the "
"original document."
msgstr ""
"दस्तावेज़ की एक प्रतिलिपि को नए फ़ाइल नाम से सहेजें और मूल दस्तावेज़ का संपादन जारी रखें।"

#. Tag: menuchoice
#: menus.docbook:124
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"><keycap>F5</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Reload</guimenuitem>"
msgstr ""
"<शॉर्टकट> <कीकॉम्बो एक्शन = \"सिमुल\"><कीकैप>एफ5</कीकैप></कीकॉम्बो> </शॉर्टकट> "
"<गुइमेनू>फ़ाइल</गुइमेनू> <गुइमेनुइटम>पुनः लोड करें</गुइमेनुइटम>"

#. Tag: para
#: menus.docbook:132
#, no-c-format
msgid ""
"Reloads the active file from disk. This command is useful if another program "
"or process has changed the file while you have it open in &kappname;."
msgstr ""
"डिस्क से सक्रिय फ़ाइल को पुनः लोड करता है। यह कमांड तब उपयोगी होता है जब किसी अन्य "
"प्रोग्राम या प्रक्रिया ने फ़ाइल को तब बदला हो जब आपने इसे &kappname; में खोला हुआ हो।"

#. Tag: menuchoice
#: menus.docbook:140
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>P</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Print...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>P</keycap></keycombo> </"
"shortcut> <guimenu>फ़ाइल</guimenu> <guimenuitem>प्रिंट...</guimenuitem>"

#. Tag: para
#: menus.docbook:148
#, no-c-format
msgid ""
"Opens a simple print dialog allowing the user to specify what, where, and "
"how to print."
msgstr ""
"एक सरल प्रिंट संवाद खोलता है जो उपयोगकर्ता को यह निर्दिष्ट करने की अनुमति देता है कि "
"क्या, कहाँ और कैसे प्रिंट करना है।"

#. Tag: menuchoice
#: menus.docbook:158
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Export as HTML</guimenuitem>"
msgstr ""
"<guimenu>फ़ाइल</guimenu> <guimenuitem>HTML के रूप में निर्यात करें</guimenuitem>"

#. Tag: para
#: menus.docbook:163
#, no-c-format
msgid ""
"Save the currently open document as an &HTML; file, which will be formatted "
"using the current syntax highlighting and color scheme settings."
msgstr ""
"वर्तमान में खुले दस्तावेज़ को &HTML; फ़ाइल के रूप में सहेजें, जिसे वर्तमान सिंटैक्स हाइलाइटिंग और "
"रंग योजना सेटिंग्स का उपयोग करके स्वरूपित किया जाएगा।"

#. Tag: menuchoice
#: menus.docbook:169
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>W</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Close</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>W</keycap></keycombo> </"
"shortcut> <guimenu>फ़ाइल</guimenu> <guimenuitem>बंद करें</guimenuitem>"

#. Tag: para
#: menus.docbook:177
#, no-c-format
msgid ""
"Close the active file with this command. If you have made unsaved changes, "
"you will be prompted to save the file before &kappname; closes it."
msgstr ""
"इस कमांड से सक्रिय फ़ाइल को बंद करें। यदि आपने बिना सहेजे गए परिवर्तन किए हैं, तो "
"&kappname; द्वारा फ़ाइल को बंद करने से पहले आपको फ़ाइल को सहेजने के लिए कहा जाएगा।"

#. Tag: menuchoice
#: menus.docbook:185
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>Q</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Quit</guimenuitem>"
msgstr ""
"<shortcut> <keycombo Action='simul'>&Ctrl;<keycap>Q</keycap></keycombo> </"
"shortcut> <guimenu>फ़ाइल</guimenu> <guimenuitem>छोड़ें</guimenuitem>"

#. Tag: para
#: menus.docbook:193
#, no-c-format
msgid ""
"This will close the editor window, if you have more than one instance of "
"&kappname; running, through the <guimenuitem>New</guimenuitem> or "
"<guimenuitem>New Window</guimenuitem> menu items, those instances will not "
"be closed."
msgstr ""
"इससे संपादक विंडो बंद हो जाएगी, यदि आपके पास &kappname; के एक से अधिक इंस्टेंस चल रहे हैं, "
"तो <guimenuitem>नया</guimenuitem> या <guimenuitem>नई विंडो</guimenuitem> मेनू "
"आइटम के माध्यम से, वे इंस्टेंस बंद नहीं होंगे।"

#. Tag: title
#: menus.docbook:207
#, no-c-format
msgid "The Edit Menu"
msgstr "संपादन मेनू"

#. Tag: menuchoice
#: menus.docbook:212
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>Z</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Undo</guimenuitem>"
msgstr ""
"<shortcut><keycombo Action='simul'>&Ctrl;<keycap>Z</keycap></keycombo> </"
"shortcut> <guimenu>संपादित करें</guimenu> <guimenuitem>पूर्ववत करें</guimenuitem>"

#. Tag: para
#: menus.docbook:220
#, no-c-format
msgid "Undo the last editing command (typing, copying, cutting &etc;)"
msgstr "अंतिम संपादन आदेश को पूर्ववत करें (टाइपिंग, कॉपी करना, काटना आदि)"

#. Tag: para
#: menus.docbook:221
#, no-c-format
msgid ""
"This may undo several editing commands of the same type, like typing in "
"characters."
msgstr "इससे एक ही प्रकार के कई संपादन आदेश रद्द हो सकते हैं, जैसे अक्षर टाइप करना।"

#. Tag: menuchoice
#: menus.docbook:227
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>Z</keycap></"
"keycombo> </shortcut> <guimenu>Edit</guimenu> <guimenuitem>Redo</guimenuitem>"
msgstr ""
"<शॉर्टकट> <कीकॉम्बो एक्शन = \"सिमुल\">&Ctrl;&Shift;<कीकैप>जेड</कीकैप></कीकॉम्बो> </"
"शॉर्टकट> <गुइमेनू>संपादित करें</गुइमेनु> <गुइमेनुइटम>फिर से करें</गुइमेनुइटम>"

#. Tag: para
#: menus.docbook:235
#, no-c-format
msgid "This will reverse the most recent change (if any) made using Undo."
msgstr ""
"इससे पूर्ववत का उपयोग करके किया गया सबसे हालिया परिवर्तन (यदि कोई हो) उलट जाएगा।"

#. Tag: menuchoice
#: menus.docbook:240
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>X</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Cut</guimenuitem>"
msgstr ""
"<शॉर्टकट> <keycombo action=\"simul\">&Ctrl;<keycap>X</keycap></keycombo> </"
"shortcut> <guimenu>संपादित करें</guimenu> <guimenuitem>काटें</guimenuitem>"

#. Tag: para
#: menus.docbook:248
#, no-c-format
msgid ""
"This command deletes the current selection and places it on the clipboard. "
"The clipboard works invisibly and provides a way to transfer data between "
"applications."
msgstr ""
"यह कमांड मौजूदा चयन को हटा देता है और उसे क्लिपबोर्ड पर रख देता है। क्लिपबोर्ड अदृश्य रूप "
"से काम करता है और अनुप्रयोगों के बीच डेटा स्थानांतरित करने का एक तरीका प्रदान करता है।"

#. Tag: menuchoice
#: menus.docbook:255
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>C</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Copy</guimenuitem>"
msgstr ""
"<शॉर्टकट> <keycombo action=\"simul\">&Ctrl;<keycap>C</keycap></keycombo> </"
"shortcut> <guimenu>संपादित करें</guimenu> <guimenuitem>कॉपी करें</guimenuitem>"

#. Tag: para
#: menus.docbook:263
#, no-c-format
msgid ""
"This copies the currently selected text to the clipboard so that it may be "
"pasted elsewhere. The clipboard works invisibly and provides a way to "
"transfer data between applications."
msgstr ""
"यह वर्तमान में चयनित टेक्स्ट को क्लिपबोर्ड पर कॉपी करता है ताकि इसे कहीं और चिपकाया जा "
"सके। क्लिपबोर्ड अदृश्य रूप से काम करता है और अनुप्रयोगों के बीच डेटा स्थानांतरित करने का एक "
"तरीका प्रदान करता है।"

#. Tag: menuchoice
#: menus.docbook:270
#, no-c-format
msgid "<guimenu>Edit</guimenu> <guimenuitem>Copy as HTML</guimenuitem>"
msgstr ""
"<guimenu>संपादित करें</guimenu> <guimenuitem>HTML के रूप में कॉपी करें</guimenuitem>"

#. Tag: para
#: menus.docbook:275
#, no-c-format
msgid ""
"Copy the selection as &HTML;, formatted using the current syntax "
"highlighting and color scheme settings."
msgstr ""
"चयन को &HTML; के रूप में कॉपी करें, वर्तमान सिंटैक्स हाइलाइटिंग और रंग योजना सेटिंग्स का "
"उपयोग करके स्वरूपित करें।"

#. Tag: menuchoice
#: menus.docbook:281
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>V</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Paste</guimenuitem>"
msgstr ""
"<शॉर्टकट> <कीकॉम्बो एक्शन = \"सिमुल\">&Ctrl;<कीकैप>वी</कीकैप></कीकॉम्बो> </शॉर्टकट> "
"<गुइमेनू>संपादित करें</गुइमेनु> <गुइमेनुइटम>पेस्ट करें</गुइमेनुइटम>"

#. Tag: para
#: menus.docbook:289
#, no-c-format
msgid ""
"This will insert the first item in the clipboard at the cursor position. The "
"clipboard works invisibly and provides a way to transfer data between "
"applications."
msgstr ""
"यह कर्सर की स्थिति पर क्लिपबोर्ड में पहला आइटम डाल देगा। क्लिपबोर्ड अदृश्य रूप से काम "
"करता है और अनुप्रयोगों के बीच डेटा स्थानांतरित करने का एक तरीका प्रदान करता है।"

#. Tag: para
#: menus.docbook:292
#, no-c-format
msgid ""
"If Overwrite Selection is enabled, the pasted text will overwrite the "
"selection, if any."
msgstr ""
"यदि चयन अधिलेखित करें सक्षम है, तो चिपकाया गया पाठ चयन को अधिलेखित कर देगा, यदि कोई "
"हो।"

#. Tag: menuchoice
#: menus.docbook:297
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;&Ins;</keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Paste Selection</guimenuitem>"
msgstr ""
"<शॉर्टकट> <कीकॉम्बो एक्शन = \"सिमुल\">&Ctrl;&Shift;&Ins;</keycombo> </शॉर्टकट> "
"<गइमेनू>संपादित करें</गुइमेनू> <गुइमेनुइटम>चयन पेस्ट करें</गुइमेनुइटम>"

#. Tag: para
#: menus.docbook:305
#, no-c-format
msgid ""
"This will paste the <ulink url=\"https://en.wikipedia.org/wiki/"
"Clipboard_(computing)#X_Window_System\">mouse selection</ulink> contents "
"that were chosen previously. Mark some text with the mouse pointer to paste "
"it in the currently open file using this menu item."
msgstr ""
"यह <ulink url=\"https://en.wikipedia.org/wiki/"
"Clipboard_(computing)#X_Window_System\">माउस चयन</ulink> सामग्री को चिपकाएगा "
"जो पहले चुनी गई थी। इस मेनू आइटम का उपयोग करके वर्तमान में खुली फ़ाइल में पेस्ट करने के लिए "
"माउस पॉइंटर से कुछ टेक्स्ट को चिह्नित करें।"

#. Tag: menuchoice
#: menus.docbook:310
#, no-c-format
msgid ""
"<guimenu>Edit</guimenu> <guimenuitem>Swap with clipboard contents</"
"guimenuitem>"
msgstr ""
"<guimenu>संपादित करें</guimenu> <guimenuitem>क्लिपबोर्ड सामग्री के साथ स्वैप करें</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:315
#, no-c-format
msgid ""
"This will swap the selected text with the <ulink url=\"https://en.wikipedia."
"org/wiki/Clipboard_(computing)#X_Window_System\">clipboard</ulink> contents."
msgstr ""
"इससे चयनित पाठ <ulink url=\"https://en.wikipedia.org/wiki/"
"Clipboard_(computing)#X_Window_System\">क्लिपबोर्ड</ulink> सामग्री के साथ बदल "
"जाएगा।"

#. Tag: menuchoice
#: menus.docbook:320
#, no-c-format
msgid ""
"<guimenu>Edit</guimenu> <guimenuitem>Clipboard History Paste</guimenuitem>"
msgstr ""
"<guimenu>संपादित करें</guimenu> <guimenuitem>क्लिपबोर्ड इतिहास पेस्ट करें</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:325
#, no-c-format
msgid ""
"This will open a dialog to select and paste an entry from the clipboard "
"history."
msgstr "इससे क्लिपबोर्ड इतिहास से एक प्रविष्टि चुनने और चिपकाने के लिए एक संवाद खुल जाएगा।"

#. Tag: menuchoice
#: menus.docbook:330
#, no-c-format
msgid "<guimenu>Edit</guimenu> <guimenuitem>Input Modes</guimenuitem>"
msgstr "<guimenu>संपादित करें</guimenu> <guimenuitem>इनपुट मोड</guimenuitem>"

#. Tag: para
#: menus.docbook:335
#, no-c-format
msgid ""
"Switch between a normal and a vi-like, modal editing mode. The vi input mode "
"supports the most used commands and motions from vim's normal and visual "
"mode and has an optional vi mode statusbar. This status bar shows commands "
"while they are being entered, output from commands and the current mode. The "
"behavior of this mode can be configured in the <link linkend=\"pref-edit-vi-"
"input-mode\">Vi Input Mode</link> tab of the <guilabel>Editing</guilabel> "
"page in &kappname;'s settings dialog."
msgstr ""
"सामान्य और vi-जैसे, मोडल संपादन मोड के बीच स्विच करें। vi इनपुट मोड vim के सामान्य और "
"विज़ुअल मोड से सबसे ज़्यादा इस्तेमाल किए जाने वाले कमांड और मोशन को सपोर्ट करता है और इसमें "
"एक वैकल्पिक vi मोड स्टेटसबार होता है। यह स्टेटस बार कमांड को दर्ज किए जाने के दौरान, "
"कमांड से आउटपुट और वर्तमान मोड दिखाता है। इस मोड के व्यवहार को कॉन्फ़िगर किया जा सकता "
"है<link linkend=\"pref-edit-vi-input-mode\"> Vi इनपुट मोड</link> टैब "
"का<guilabel> संपादन</guilabel> &amp;kappname; के सेटिंग संवाद में पृष्ठ पर जाएँ."

#. Tag: menuchoice
#: menus.docbook:345
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ins;</keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Overwrite Mode</guimenuitem>"
msgstr ""
"<शॉर्टकट> <कीकॉम्बो एक्शन = \"सिमुल\">&इन्स;</कीकॉम्बो> </शॉर्टकट> <गुइमेनू>संपादित करें</"
"गुइमेनू> <गुइमेनुइटम>ओवरराइट मोड</गुइमेनुइटम>"

#. Tag: para
#: menus.docbook:353
#, no-c-format
msgid ""
"Toggles the Insert/Overwrite modes. When the mode is <guilabel>INS</"
"guilabel>, you insert characters where the cursor is. When the mode is "
"<guilabel>OVR</guilabel>, writing characters will replace the current "
"characters if your cursor is positioned before any character. The status bar "
"shows the current state of the Overwrite Mode, either <guilabel>INS</"
"guilabel> or <guilabel>OVR</guilabel>."
msgstr ""
"इन्सर्ट/ओवरराइट मोड को टॉगल करता है। जब मोड <guilabel>INS</guilabel> होता है, तो "
"आप कर्सर के स्थान पर अक्षर डालते हैं। जब मोड <guilabel>OVR</guilabel> होता है, तो "
"यदि आपका कर्सर किसी भी अक्षर से पहले स्थित है, तो लिखने वाले अक्षर वर्तमान अक्षरों को "
"बदल देंगे। स्टेटस बार ओवरराइट मोड की वर्तमान स्थिति दिखाता है, या तो <guilabel>INS</"
"guilabel> या <guilabel>OVR</guilabel>।"

#. Tag: menuchoice
#: menus.docbook:362
#, no-c-format
msgid "<guimenu>Edit</guimenu> <guimenuitem>Read Only Mode</guimenuitem>"
msgstr ""
"<guimenu>संपादित करें</guimenu> <guimenuitem>केवल पढ़ने के लिए मोड</guimenuitem>"

#. Tag: para
#: menus.docbook:367
#, no-c-format
msgid ""
"Set the current document to Read Only mode. This prevents any text addition "
"and any changes in the document formatting."
msgstr ""
"वर्तमान दस्तावेज़ को केवल पढ़ने के लिए मोड पर सेट करें। यह किसी भी पाठ को जोड़ने और "
"दस्तावेज़ स्वरूपण में किसी भी परिवर्तन को रोकता है।"

#. Tag: menuchoice
#: menus.docbook:373
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>F</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Find...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>F</keycap></keycombo> </"
"shortcut> <guimenu>संपादित करें</guimenu> <guimenuitem>ढूंढें...</guimenuitem>"

#. Tag: para
#: menus.docbook:381
#, no-c-format
msgid ""
"This opens the incremental search bar at the bottom of the editor window. On "
"the left side of the bar is a button with an icon to close the bar, followed "
"by a small text box for entering the search pattern."
msgstr ""
"इससे एडिटर विंडो के निचले हिस्से में इंक्रीमेंटल सर्च बार खुल जाता है। बार के बाईं ओर एक बटन "
"है जिस पर बार को बंद करने के लिए एक आइकन है, उसके बाद सर्च पैटर्न दर्ज करने के लिए एक "
"छोटा टेक्स्ट बॉक्स है।"

#. Tag: para
#: menus.docbook:384
#, no-c-format
msgid ""
"When you start entering characters of your search pattern, the search starts "
"immediately. If there is a match in the text this is highlighted and the "
"background color of the entry field changes to light green. If the search "
"pattern does not match any string in the text, this is indicated by a light "
"red background color of the entry field."
msgstr ""
"जब आप अपने खोज पैटर्न के अक्षर दर्ज करना शुरू करते हैं, तो खोज तुरंत शुरू हो जाती है। यदि "
"पाठ में कोई मिलान होता है तो इसे हाइलाइट किया जाता है और प्रविष्टि फ़ील्ड का पृष्ठभूमि "
"रंग हल्के हरे रंग में बदल जाता है। यदि खोज पैटर्न पाठ में किसी भी स्ट्रिंग से मेल नहीं खाता है, "
"तो यह प्रविष्टि फ़ील्ड के हल्के लाल पृष्ठभूमि रंग द्वारा इंगित किया जाता है।"

#. Tag: para
#: menus.docbook:388 menus.docbook:488
#, no-c-format
msgid ""
"Use the <inlinemediaobject><imageobject><imagedata fileref=\"arrow-up-"
"double-22.png\" format=\"PNG\"/></imageobject></inlinemediaobject> or "
"<inlinemediaobject><imageobject><imagedata fileref=\"arrow-down-double-22.png"
"\" format=\"PNG\"/></imageobject></inlinemediaobject> button to jump to the "
"next or previous match in the document."
msgstr ""
"दस्तावेज़ में अगले या पिछले मिलान पर जाने के लिए "
"<inlinemediaobject><imageobject><imagedata fileref=\"arrow-up-double-22.png"
"\" format=\"PNG\"/></imageobject></inlinemediaobject> या "
"<inlinemediaobject><imageobject><imagedata fileref=\"arrow-down-double-22.png"
"\" format=\"PNG\"/></imageobject></inlinemediaobject> बटन का उपयोग करें।"

#. Tag: para
#: menus.docbook:392
#, no-c-format
msgid ""
"Matches in the document are highlighted even when you close the search bar. "
"To clear this highlighting, press the &Esc; key."
msgstr ""
"जब आप खोज बार बंद करते हैं, तब भी दस्तावेज़ में मिलान हाइलाइट किए जाते हैं। इस हाइलाइटिंग "
"को साफ़ करने के लिए, &Esc; कुंजी दबाएँ।"

#. Tag: para
#: menus.docbook:394
#, no-c-format
msgid ""
"You can choose whether the search should be case sensitive. Selecting "
"<inlinemediaobject><imageobject><imagedata fileref=\"format-text-"
"superscript-22.png\" format=\"PNG\"/></imageobject></inlinemediaobject> will "
"limit finds to entries that match the case (upper or lower) of each of the "
"characters in the search pattern."
msgstr ""
"आप चुन सकते हैं कि खोज केस सेंसिटिव होनी चाहिए या नहीं। "
"<inlinemediaobject><imageobject><imagedata fileref=\"format-text-"
"superscript-22.png\" format=\"PNG\"/></imageobject></inlinemediaobject> का "
"चयन करने से खोज पैटर्न में प्रत्येक वर्ण के केस (ऊपरी या निचले) से मेल खाने वाली प्रविष्टियों "
"तक खोज सीमित हो जाएगी।"

#. Tag: para
#: menus.docbook:399
#, no-c-format
msgid ""
"Click on the <inlinemediaobject><imageobject><imagedata fileref=\"configure-"
"shortcuts-22.png\" format=\"PNG\"/></imageobject></inlinemediaobject> button "
"at the right side of the incremental search bar to switch to the power "
"search and replace bar."
msgstr ""
"पावर सर्च और रिप्लेस बार पर स्विच करने के लिए वृद्धिशील सर्च बार के दाईं ओर स्थित "
"<inlinemediaobject><imageobject><imagedata fileref=\"configure-shortcuts-22."
"png\" format=\"PNG\"/></imageobject></inlinemediaobject> बटन पर क्लिक करें।"

#. Tag: menuchoice
#: menus.docbook:407
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"><keycap>F3</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guisubmenu>Find Variants</guisubmenu> "
"<guimenuitem>Find Next</guimenuitem>"
msgstr ""
"<शॉर्टकट> <कीकॉम्बो एक्शन = \"सिमुल\"><कीकैप>एफ3</कीकैप></कीकॉम्बो> </शॉर्टकट> "
"<गुइमेनू>संपादित करें</गुइमेनू> <गुइमेनू>वेरिएंट ढूंढें</गुइमेनुइटम>अगला खोजें< /guimenuitem>"

#. Tag: para
#: menus.docbook:416
#, no-c-format
msgid ""
"This repeats the last find operation, if any, without calling the "
"incremental search bar, and searching forwards through the document starting "
"from the cursor position."
msgstr ""
"यह वृद्धिशील खोज बार को बुलाए बिना, यदि कोई हो तो, अंतिम खोज ऑपरेशन को दोहराता है, "
"तथा कर्सर की स्थिति से प्रारंभ करके दस्तावेज़ में आगे की ओर खोज करता है।"

#. Tag: menuchoice
#: menus.docbook:423
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Shift;<keycap>F3</keycap></keycombo> "
"</shortcut> <guimenu>Edit</guimenu> <guisubmenu>Find Variants</guisubmenu> "
"<guimenuitem>Find Previous</guimenuitem>"
msgstr ""
"<शॉर्टकट> <कीकॉम्बो एक्शन = \"सिमुल\">&शिफ्ट;<कीकैप>एफ3</कीकैप></कीकॉम्बो> </शॉर्टकट> "
"<गइमेनू>संपादित करें</गुइमेनू> <गुइमेनु>वेरिएंट ढूंढें</गुइमेनुइटम>ढूंढें पिछला</guimenuitem>"

#. Tag: para
#: menus.docbook:432
#, no-c-format
msgid ""
"This repeats the last find operation, if any, without calling the "
"incremental search bar, and searching backwards instead of forwards through "
"the document."
msgstr ""
"यह वृद्धिशील खोज बार को बुलाए बिना, यदि कोई हो तो, अंतिम खोज ऑपरेशन को दोहराता है, "
"तथा दस्तावेज़ में आगे की ओर खोजने के बजाय पीछे की ओर खोज करता है।"

#. Tag: menuchoice
#: menus.docbook:441
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>H</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guisubmenu>Find Variants</guisubmenu> "
"<guimenuitem>Find Selected</guimenuitem>"
msgstr ""
"<शॉर्टकट> <कीकॉम्बो एक्शन = \"सिमुल\">&Ctrl;<कीकैप>एच</कीकैप></कीकॉम्बो> </शॉर्टकट> "
"<गुइमेनू>संपादित करें</गुइमेनू> <गुइमेनु>वेरिएंट ढूंढें</गुइमेनुइटम>ढूंढें चयनित</guimenuitem>"

#. Tag: para
#: menus.docbook:450
#, no-c-format
msgid "Finds next occurrence of selected text."
msgstr "चयनित पाठ की अगली घटना ढूँढता है."

#. Tag: menuchoice
#: menus.docbook:455
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>H</keycap></"
"keycombo> </shortcut> <guimenu>Edit</guimenu> <guisubmenu>Find Variants</"
"guisubmenu> <guimenuitem>Find Selected Backwards</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>H</keycap></"
"keycombo> </shortcut> <guimenu>संपादित करें</guimenu> <guisubmenu>वेरिएंट खोजें</"
"guisubmenu> <guimenuitem>चयनित को पीछे की ओर खोजें</guimenuitem>"

#. Tag: para
#: menus.docbook:464
#, no-c-format
msgid "Finds previous occurrence of selected text."
msgstr "चयनित पाठ की पिछली उपस्थिति ढूँढता है."

#. Tag: menuchoice
#: menus.docbook:469
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>R</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Replace...</guimenuitem>"
msgstr ""
"<शॉर्टकट> <कीकॉम्बो एक्शन = \"सिमुल\">&Ctrl;<कीकैप>आर</कीकैप></कीकॉम्बो> </शॉर्टकट> "
"<गुइमेनू>संपादित करें</गुइमेनु> <गुइमेनुइटम>बदलें...</गुइमेनुइटम>"

#. Tag: para
#: menus.docbook:477
#, no-c-format
msgid ""
"This command opens the power search and replace bar. On the upper left side "
"of the bar is a button with an icon to close the bar, followed by a small "
"text box for entering the search pattern."
msgstr ""
"यह कमांड पावर सर्च और रिप्लेस बार को खोलता है। बार के ऊपरी बाएँ तरफ एक बटन है जिस पर "
"बार को बंद करने के लिए एक आइकन है, उसके बाद सर्च पैटर्न दर्ज करने के लिए एक छोटा टेक्स्ट "
"बॉक्स है।"

#. Tag: para
#: menus.docbook:480
#, no-c-format
msgid ""
"You can control the search mode by selecting <guilabel>Plain text</"
"guilabel>, <guilabel>Whole words</guilabel>, <guilabel>Escape sequences</"
"guilabel> or <guilabel>Regular expression</guilabel> from the drop down box."
msgstr ""
"आप ड्रॉप डाउन बॉक्स से <guilabel>सादा पाठ</guilabel>, <guilabel>संपूर्ण शब्द</"
"guilabel>, <guilabel>एस्केप अनुक्रम</guilabel> या <guilabel>नियमित अभिव्यक्ति</"
"guilabel> का चयन करके खोज मोड को नियंत्रित कर सकते हैं।"

#. Tag: para
#: menus.docbook:484
#, no-c-format
msgid ""
"If <guilabel>Escape sequences</guilabel> or <guilabel>Regular expression</"
"guilabel> are selected, the <guibutton>Add...</guibutton> menuitem at the "
"bottom of the context menu of the text boxes will be enabled and allows you "
"to add escape sequences or regular expression items to the search or replace "
"pattern from predefined lists."
msgstr ""
"यदि <guilabel>एस्केप अनुक्रम</guilabel> या <guilabel>नियमित अभिव्यक्ति</guilabel> "
"चयनित हैं, तो पाठ बॉक्स के संदर्भ मेनू के नीचे स्थित <guibutton>जोड़ें...</guibutton> "
"मेनूआइटम सक्षम हो जाएगा और आपको पूर्वनिर्धारित सूचियों से खोज या प्रतिस्थापन पैटर्न में "
"एस्केप अनुक्रम या नियमित अभिव्यक्ति आइटम जोड़ने की अनुमति देगा।"

#. Tag: para
#: menus.docbook:492
#, no-c-format
msgid ""
"Enter the text to replace with in the text box labeled <guilabel>Replace</"
"guilabel> and click the <guibutton>Replace</guibutton> button to replace "
"only the highlighted text or the <guibutton>Replace All</guibutton> button "
"to replace the search text in the whole document."
msgstr ""
"<guilabel>Replace</guilabel> लेबल वाले टेक्स्ट बॉक्स में प्रतिस्थापित करने के लिए टेक्स्ट "
"दर्ज करें और केवल हाइलाइट किए गए टेक्स्ट को प्रतिस्थापित करने के लिए "
"<guibutton>Replace</guibutton> बटन पर क्लिक करें या पूरे दस्तावेज़ में खोजे गए टेक्स्ट को "
"प्रतिस्थापित करने के लिए <guibutton>Replace All</guibutton> बटन पर क्लिक करें।"

#. Tag: para
#: menus.docbook:496
#, no-c-format
msgid ""
"You can modify the search and replace behavior by selecting different "
"options at the bottom of the bar. Selecting "
"<inlinemediaobject><imageobject><imagedata fileref=\"format-text-"
"superscript-22.png\" format=\"PNG\"/></imageobject></inlinemediaobject> will "
"limit finds to entries that match the case (upper or lower) of each of the "
"characters in the search pattern. <inlinemediaobject><imageobject><imagedata "
"fileref=\"edit-select-all-22.png\" format=\"PNG\"/></imageobject></"
"inlinemediaobject> will search and replace within the current selection "
"only. The <guilabel>Find All</guilabel> button highlights all matches in the "
"document and shows the number of found matches in a small popup."
msgstr ""
"आप बार के नीचे अलग-अलग विकल्प चुनकर खोज और प्रतिस्थापन व्यवहार को संशोधित कर सकते हैं। "
"<inlinemediaobject><imageobject><imagedata fileref=\"format-text-"
"superscript-22.png\" format=\"PNG\"/></imageobject></inlinemediaobject> का "
"चयन करने से खोज पैटर्न में प्रत्येक वर्ण के केस (ऊपरी या निचले) से मेल खाने वाली प्रविष्टियों "
"तक खोज सीमित हो जाएगी। <inlinemediaobject><imageobject><imagedata fileref="
"\"edit-select-all-22.png\" format=\"PNG\"/></imageobject></"
"inlinemediaobject> केवल वर्तमान चयन के भीतर खोज और प्रतिस्थापन करेगा। "
"<guilabel>सभी खोजें</guilabel> बटन दस्तावेज़ में सभी मिलानों को हाइलाइट करता है और एक "
"छोटे पॉपअप में पाए गए मिलानों की संख्या दिखाता है।"

#. Tag: para
#: menus.docbook:506
#, no-c-format
msgid ""
"Click on the <inlinemediaobject><imageobject><imagedata fileref=\"configure-"
"shortcuts-22.png\" format=\"PNG\"/></imageobject></inlinemediaobject> button "
"at the right side of the power search and replace bar to switch to the "
"incremental search bar."
msgstr ""
"वृद्धिशील खोज बार पर स्विच करने के लिए पावर खोज और प्रतिस्थापित बार के दाईं ओर स्थित "
"<inlinemediaobject><imageobject><imagedata fileref=\"configure-shortcuts-22."
"png\" format=\"PNG\"/></imageobject></inlinemediaobject> बटन पर क्लिक करें।"

#. Tag: title
#: menus.docbook:519
#, no-c-format
msgid "The Selection Menu"
msgstr "चयन मेनू"

#. Tag: menuchoice
#: menus.docbook:523
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>A</keycap></keycombo> </"
"shortcut> <guimenu>Selection</guimenu> <guimenuitem>Select All</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>A</keycap></keycombo> </"
"shortcut> <guimenu>चयन</guimenu> <guimenuitem>सभी का चयन करें</guimenuitem>"

#. Tag: para
#: menus.docbook:531
#, no-c-format
msgid ""
"This will select the entire document. This could be very useful for copying "
"the entire file to another application."
msgstr ""
"इससे पूरा दस्तावेज़ चयनित हो जाएगा। यह पूरी फ़ाइल को किसी अन्य एप्लिकेशन में कॉपी करने के "
"लिए बहुत उपयोगी हो सकता है।"

#. Tag: menuchoice
#: menus.docbook:537
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>A</keycap></"
"keycombo> </shortcut> <guimenu>Selection</guimenu> <guimenuitem>Deselect</"
"guimenuitem>"
msgstr ""
"<शॉर्टकट> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>A</keycap></"
"keycombo> </shortcut> <guimenu>चयन</guimenu> <guimenuitem>अचयनित करें</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:545
#, no-c-format
msgid "Deselects the selected text in the editor if any."
msgstr "यदि कोई हो तो संपादक में चयनित पाठ को अचयनित कर देता है।"

#. Tag: menuchoice
#: menus.docbook:550
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>B</keycap></"
"keycombo> </shortcut> <guimenu>Selection</guimenu> <guimenuitem>Block "
"Selection Mode</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>B</keycap></"
"keycombo> </shortcut> <guimenu>चयन</guimenu> <guimenuitem>ब्लॉक चयन मोड</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:558
#, no-c-format
msgid ""
"Toggles Selection Mode. When the Selection Mode is <guilabel>BLOCK</"
"guilabel>, the status bar contains the string <guilabel>[BLOCK]</guilabel> "
"and you can make vertical selections, &eg; select column 5 to 10 in lines 9 "
"to 15."
msgstr ""
"चयन मोड टॉगल करता है। जब चयन मोड <guilabel>BLOCK</guilabel> होता है, तो स्टेटस "
"बार में स्ट्रिंग <guilabel>[BLOCK]</guilabel> होती है और आप लंबवत चयन कर सकते हैं, "
"&eg; पंक्ति 9 से 15 में कॉलम 5 से 10 का चयन करें।"

#. Tag: menuchoice
#: menus.docbook:596
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>D</keycap></keycombo> </"
"shortcut> <guimenu>Selection</guimenu> <guimenuitem>Comment</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>D</keycap></keycombo> </"
"shortcut> <guimenu>चयन</guimenu> <guimenuitem>टिप्पणी</guimenuitem>"

#. Tag: para
#: menus.docbook:603
#, no-c-format
msgid ""
"This adds one space to the beginning of the line where the text cursor is "
"located or to the beginning of any selected lines."
msgstr ""
"यह उस पंक्ति के आरंभ में एक स्थान जोड़ता है जहां टेक्स्ट कर्सर स्थित है या किसी चयनित पंक्ति के "
"आरंभ में एक स्थान जोड़ता है।"

#. Tag: menuchoice
#: menus.docbook:610
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>D</keycap></"
"keycombo> </shortcut> <guimenu>Selection</guimenu> <guimenuitem>Uncomment</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>D</keycap></"
"keycombo> </shortcut> <guimenu>चयन</guimenu> <guimenuitem>टिप्पणी हटाएं</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:617
#, no-c-format
msgid ""
"This removes one space (if any exist) from the beginning of the line where "
"the text cursor is located or from the beginning of any selected lines."
msgstr ""
"यह उस पंक्ति के आरंभ से, जहां टेक्स्ट कर्सर स्थित है, या किसी चयनित पंक्ति के आरंभ से एक स्थान "
"(यदि कोई हो) हटा देता है।"

#. Tag: menuchoice
#: menus.docbook:623
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>J</keycap></keycombo> </"
"shortcut> <guimenu>Selection</guimenu> <guimenuitem>Join Lines</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>J</keycap></keycombo> </"
"shortcut> <guimenu>चयन</guimenu> <guimenuitem>लाइनें जोड़ें</guimenuitem>"

#. Tag: para
#: menus.docbook:630
#, no-c-format
msgid ""
"Joins the selected lines, or the current line and the line below with one "
"white space character as a separator. Leading/trailing white space on joined "
"lines is removed in the affected ends."
msgstr ""
"चयनित पंक्तियों, या वर्तमान पंक्ति और नीचे की पंक्ति को एक सफेद स्थान वर्ण के साथ विभाजक "
"के रूप में जोड़ता है। प्रभावित सिरों पर जुड़ी हुई पंक्तियों पर आगे/पीछे का सफेद स्थान हटा दिया "
"जाता है।"

#. Tag: menuchoice
#: menus.docbook:636
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Alt;<keycap>U</keycap></"
"keycombo> </shortcut> <guimenu>Selection</guimenu> "
"<guimenuitem>Capitalization</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Alt;<keycap>U</keycap></"
"keycombo> </shortcut> <guimenu>चयन</guimenu> <guimenuitem>कैपिटलाइज़ेशन</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:643
#, no-c-format
msgid "Capitalize the selected text or the current word."
msgstr "चयनित पाठ या वर्तमान शब्द को बड़े अक्षर में लिखें।"

#. Tag: menuchoice
#: menus.docbook:648
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>U</keycap></keycombo> </"
"shortcut> <guimenu>Selection</guimenu> <guimenuitem>Uppercase</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>U</keycap></keycombo> </"
"shortcut> <guimenu>चयन</guimenu> <guimenuitem>अपरकेस</guimenuitem>"

#. Tag: para
#: menus.docbook:655
#, no-c-format
msgid "Put the selected text or the letter after the cursor in uppercase."
msgstr "चयनित टेक्स्ट या अक्षर को कर्सर के बाद बड़े अक्षरों में रखें।"

#. Tag: menuchoice
#: menus.docbook:660
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>U</keycap></"
"keycombo> </shortcut> <guimenu>Selection</guimenu> <guimenuitem>Lowercase</"
"guimenuitem>"
msgstr ""
"<शॉर्टकट> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>U</keycap></"
"keycombo> </shortcut> <guimenu>चयन</guimenu> <guimenuitem>लोअरकेस</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:667
#, no-c-format
msgid "Put the selected text or the letter after the cursor in lowercase."
msgstr "चयनित टेक्स्ट या अक्षर को कर्सर के बाद लोअरकेस में रखें।"

#. Tag: menuchoice
#: menus.docbook:672
#, no-c-format
msgid ""
"<guimenu>Selection</guimenu> <guimenuitem>Clean Indentation</guimenuitem>"
msgstr "<guimenu>चयन</guimenu> <guimenuitem>क्लीन इंडेंटेशन</guimenuitem>"

#. Tag: para
#: menus.docbook:677
#, no-c-format
msgid ""
"This cleans the indentation for the current selection or for the line the "
"cursor is currently in. Cleaning the indentation ensures that all your "
"selected text follows the indentation mode you choose."
msgstr ""
"यह वर्तमान चयन या उस पंक्ति के लिए इंडेंटेशन को साफ करता है जिसमें वर्तमान में कर्सर मौजूद "
"है। इंडेंटेशन को साफ करने से यह सुनिश्चित होता है कि आपका चयनित सभी टेक्स्ट आपके द्वारा चुने "
"गए इंडेंटेशन मोड का अनुसरण करता है।"

#. Tag: menuchoice
#: menus.docbook:684
#, no-c-format
msgid "<guimenu>Selection</guimenu> <guimenuitem>Format Indent</guimenuitem>"
msgstr "<guimenu>चयन</guimenu> <guimenuitem>प्रारूप इंडेंट</guimenuitem>"

#. Tag: para
#: menus.docbook:689
#, no-c-format
msgid ""
"Causes a realign of the current line or selected lines using the indentation "
"mode and indentation settings in the document."
msgstr ""
"दस्तावेज़ में इंडेंटेशन मोड और इंडेंटेशन सेटिंग्स का उपयोग करके वर्तमान पंक्ति या चयनित पंक्तियों "
"को पुनः संरेखित करता है।"

#. Tag: menuchoice
#: menus.docbook:695
#, no-c-format
msgid "<guimenu>Selection</guimenu> <guimenuitem>Align On...</guimenuitem>"
msgstr "<guimenu>चयन</guimenu> <guimenuitem>संरेखित करें...</guimenuitem>"

#. Tag: para
#: menus.docbook:700
#, no-c-format
msgid ""
"This command aligns lines in the selected block or whole document on the "
"column given by a regular expression that you will be prompted for."
msgstr ""
"यह आदेश चयनित ब्लॉक या संपूर्ण दस्तावेज़ में पंक्तियों को उस नियमित अभिव्यक्ति द्वारा दिए गए "
"कॉलम पर संरेखित करता है, जिसके लिए आपको संकेत दिया जाएगा।"

#. Tag: para
#: menus.docbook:701
#, no-c-format
msgid ""
"If you give an empty pattern it will align on the first non-blank character "
"by default."
msgstr ""
"यदि आप कोई रिक्त पैटर्न देते हैं तो यह डिफ़ॉल्ट रूप से पहले गैर-रिक्त अक्षर पर संरेखित हो "
"जाएगा।"

#. Tag: para
#: menus.docbook:702
#, no-c-format
msgid "If the pattern has a capture it will indent on the captured match."
msgstr "यदि पैटर्न में कोई कैप्चर है तो वह कैप्चर किए गए मैच पर इंडेंट करेगा।"

#. Tag: emphasis
#: menus.docbook:703
#, no-c-format
msgid "Examples:"
msgstr "उदाहरण:"

#. Tag: para
#: menus.docbook:704
#, no-c-format
msgid ""
"With '<userinput>-</userinput>' it will insert spaces before the first '-' "
"of each lines to align them all on the same column."
msgstr ""
"'<userinput>-</userinput>' के साथ यह प्रत्येक पंक्ति के प्रथम '-' से पहले रिक्त स्थान "
"डालेगा ताकि वे सभी एक ही कॉलम में संरेखित हो जाएं।"

#. Tag: para
#: menus.docbook:705
#, no-c-format
msgid ""
"With '<userinput>alignon :\\\\s+(.)</userinput>' it will insert spaces "
"before the first non-blank character that occurs after a colon to align them "
"all on the same column."
msgstr ""
"'<userinput>alignon :\\\\s+(.)</userinput>' के साथ यह कोलन के बाद आने वाले पहले "
"गैर-रिक्त वर्ण से पहले रिक्त स्थान डालेगा, ताकि उन सभी को एक ही कॉलम में संरेखित किया जा "
"सके।"

#. Tag: menuchoice
#: menus.docbook:710
#, no-c-format
msgid "<guimenu>Selection</guimenu> <guimenuitem>Apply Word Wrap</guimenuitem>"
msgstr "<guimenu>चयन</guimenu> <guimenuitem>वर्ड रैप लागू करें</guimenuitem>"

#. Tag: para
#: menus.docbook:714
#, no-c-format
msgid ""
"Apply static word wrapping on all the document. That means that a new line "
"of text will automatically start when the current line exceeds the length "
"specified by the <guilabel>Wrap words at</guilabel> option in the Editing "
"tab in <menuchoice> <guimenu>Settings</guimenu><guimenuitem>Configure "
"Editor...</guimenuitem></menuchoice> menu."
msgstr ""
"सभी दस्तावेज़ों पर स्टैटिक वर्ड रैपिंग लागू करें। इसका मतलब है कि जब मौजूदा लाइन "
"<menuchoice> <guimenu>सेटिंग्स</guimenu><guimenuitem>संपादक कॉन्फ़िगर करें...</"
"guimenuitem></menuchoice> मेनू में संपादन टैब में <guilabel>शब्दों को लपेटें</guilabel> "
"विकल्प द्वारा निर्दिष्ट लंबाई से अधिक हो जाती है, तो पाठ की एक नई पंक्ति स्वचालित रूप से "
"शुरू हो जाएगी।"

#. Tag: menuchoice
#: menus.docbook:723
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Alt;&Up;</keycombo> </shortcut> "
"<guimenu>Selection</guimenu> <guimenuitem>Add Caret above Cursor</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Alt;&Up;</keycombo> </shortcut> "
"<guimenu>चयन</guimenu> <guimenuitem>कर्सर के ऊपर कैरेट जोड़ें</guimenuitem>"

#. Tag: para
#: menus.docbook:730
#, no-c-format
msgid ""
"Adds another caret above the current cursor. The caret is placed in the line "
"directly above and in the same column as the current cursor."
msgstr ""
"वर्तमान कर्सर के ऊपर एक और कैरेट जोड़ता है। कैरेट को वर्तमान कर्सर के ठीक ऊपर वाली लाइन "
"में और उसी कॉलम में रखा जाता है।"

#. Tag: menuchoice
#: menus.docbook:735
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Alt;&Down;</keycombo> </"
"shortcut> <guimenu>Selection</guimenu> <guimenuitem>Add Caret below Cursor</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Alt;&Down;</keycombo> </"
"shortcut> <guimenu>चयन</guimenu> <guimenuitem>कर्सर के नीचे कैरेट जोड़ें</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:742
#, no-c-format
msgid ""
"Adds another caret below the current cursor. The caret is placed in the line "
"directly above and in the same column as the current cursor."
msgstr ""
"वर्तमान कर्सर के नीचे एक और कैरेट जोड़ता है। कैरेट को वर्तमान कर्सर के ठीक ऊपर वाली लाइन "
"में और उसी कॉलम में रखा जाता है।"

#. Tag: menuchoice
#: menus.docbook:747
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift;<keycap>I</keycap></"
"keycombo> </shortcut> <guimenu>Selection</guimenu> <guimenuitem>Add Cursors "
"to Line Ends</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift;<keycap>I</keycap></"
"keycombo> </shortcut> <guimenu>चयन</guimenu> <guimenuitem>पंक्ति के अंत में कर्सर "
"जोड़ें</guimenuitem>"

#. Tag: para
#: menus.docbook:754
#, no-c-format
msgid "Adds a cursor to every currently selected line."
msgstr "वर्तमान में चयनित प्रत्येक पंक्ति में एक कर्सर जोड़ता है।"

#. Tag: menuchoice
#: menus.docbook:759
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt;<keycap>J</keycap></keycombo> </"
"shortcut> <guimenu>Selection</guimenu> <guimenuitem>Find and Select Next "
"Occurrence</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt;<keycap>J</keycap></keycombo> </"
"shortcut> <guimenu>चयन</guimenu> <guimenuitem>अगली घटना खोजें और चुनें</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:766
#, no-c-format
msgid ""
"Finds the next occurrence of the word currently under the cursor, selects it "
"and adds a cursor."
msgstr ""
"वर्तमान में कर्सर के नीचे मौजूद शब्द की अगली उपस्थिति ढूंढता है, उसे चुनता है और कर्सर जोड़ता "
"है।"

#. Tag: menuchoice
#: menus.docbook:771
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Alt;&Shift;<keycap>J</keycap></"
"keycombo> </shortcut> <guimenu>Selection</guimenu> <guimenuitem>Find and "
"Select All Occurrences</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Alt;&Shift;<keycap>J</keycap></"
"keycombo> </shortcut> <guimenu>चयन</guimenu> <guimenuitem>सभी घटनाओं को खोजें "
"और चुनें</guimenuitem>"

#. Tag: para
#: menus.docbook:778
#, no-c-format
msgid ""
"Finds all occurrences of the word currently under the cursor, selects them "
"and adds a cursor for each of them."
msgstr ""
"वर्तमान में कर्सर के अंतर्गत शब्द की सभी घटनाओं को ढूंढता है, उन्हें चुनता है और उनमें से प्रत्येक "
"के लिए एक कर्सर जोड़ता है।"

#. Tag: title
#: menus.docbook:788
#, no-c-format
msgid "The View Menu"
msgstr "दृश्य मेनू"

#. Tag: menuchoice
#: menus.docbook:793
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>+</keycap></keycombo> </"
"shortcut> <guimenu>View</guimenu> <guimenuitem>Enlarge Font</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>+</keycap></keycombo> </"
"shortcut> <guimenu>देखें</guimenu> <guimenuitem>फ़ॉन्ट बड़ा करें</guimenuitem>"

#. Tag: para
#: menus.docbook:800
#, no-c-format
msgid "This increases the display font size."
msgstr "इससे डिस्प्ले फ़ॉन्ट का आकार बढ़ जाता है."

#. Tag: menuchoice
#: menus.docbook:804
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>-</keycap></keycombo> </"
"shortcut> <guimenu>View</guimenu> <guimenuitem>Shrink Font</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>-</keycap></keycombo> </"
"shortcut> <guimenu>देखें</guimenu> <guimenuitem>फ़ॉन्ट छोटा करें</guimenuitem>"

#. Tag: para
#: menus.docbook:811
#, no-c-format
msgid "This decreases the display font size."
msgstr "इससे डिस्प्ले फ़ॉन्ट का आकार घट जाता है."

#. Tag: menuchoice
#: menus.docbook:815
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"><keycap>F10</keycap></keycombo> </"
"shortcut> <guimenu>View</guimenu> <guisubmenu>Word Wrap</guisubmenu> "
"<guimenuitem>Dynamic Word Wrap</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"><keycap>F10</keycap></keycombo> </"
"shortcut> <guimenu>देखें</guimenu> <guisubmenu>वर्ड व्रेप</guisubmenu> "
"<guimenuitem>डायनामिक वर्ड व्रेप</guimenuitem>"

#. Tag: para
#: menus.docbook:823
#, no-c-format
msgid ""
"Toggles dynamic word wrap in the current view. Dynamic word wrap makes all "
"the text in a view visible without the need for horizontal scrolling by "
"rendering one actual line on more visual lines as needed."
msgstr ""
"वर्तमान दृश्य में डायनेमिक वर्ड रैप को टॉगल करता है। डायनेमिक वर्ड रैप, आवश्यकतानुसार एक "
"वास्तविक पंक्ति को अधिक दृश्य पंक्तियों पर प्रस्तुत करके क्षैतिज स्क्रॉलिंग की आवश्यकता के बिना "
"दृश्य में सभी पाठ को दृश्यमान बनाता है।"

#. Tag: menuchoice
#: menus.docbook:830
#, no-c-format
msgid ""
"<guimenu>View</guimenu> <guisubmenu>Word Wrap</guisubmenu> "
"<guisubmenu>Dynamic Word Wrap Indicators</guisubmenu>"
msgstr ""
"<guimenu>देखें</guimenu> <guisubmenu>वर्ड रैप</guisubmenu> <guisubmenu>डायनेमिक "
"वर्ड रैप संकेतक</guisubmenu>"

#. Tag: para
#: menus.docbook:836
#, no-c-format
msgid ""
"Choose when and how the dynamic word wrap indicators should be displayed. "
"This is only available if the <guilabel>Dynamic Word Wrap</guilabel> option "
"is checked."
msgstr ""
"चुनें कि डायनामिक वर्ड रैप संकेतक कब और कैसे प्रदर्शित किए जाने चाहिए। यह तभी उपलब्ध है जब "
"<guilabel>Dynamic Word Wrap</guilabel> विकल्प चेक किया गया हो।"

#. Tag: menuchoice
#: menus.docbook:843
#, no-c-format
msgid ""
"<guimenu>View</guimenu> <guisubmenu>Word Wrap</guisubmenu> <guimenuitem>Show "
"Static Word Wrap Marker</guimenuitem>"
msgstr ""
"<guimenu>देखें</guimenu> <guisubmenu>वर्ड रैप</guisubmenu> <guimenuitem>स्टेटिक वर्ड "
"रैप मार्कर दिखाएं</guimenuitem>"

#. Tag: para
#: menus.docbook:849
#, no-c-format
msgid ""
"If this option is checked, a vertical line will be drawn at the word wrap "
"column as defined in the <menuchoice> <guimenu>Settings</guimenu> "
"<guimenuitem>Configure Editor...</guimenuitem></menuchoice> in the Editing "
"tab. Please note that the word wrap marker is only drawn if you use a fixed "
"pitch font."
msgstr ""
"यदि यह विकल्प चुना गया है, तो संपादन टैब में <menuchoice> <guimenu>सेटिंग्स</guimenu> "
"<guimenuitem>संपादक कॉन्फ़िगर करें...</guimenuitem></menuchoice> में परिभाषित अनुसार "
"वर्ड रैप कॉलम पर एक लंबवत रेखा खींची जाएगी। कृपया ध्यान दें कि वर्ड रैप मार्कर केवल तभी "
"खींचा जाता है जब आप एक निश्चित पिच फ़ॉन्ट का उपयोग करते हैं।"

#. Tag: menuchoice
#: menus.docbook:859
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"><keycap>F6</keycap></keycombo> </"
"shortcut> <guimenu>View</guimenu> <guisubmenu>Borders</guisubmenu> "
"<guimenuitem>Show Icon Border</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"><keycap>F6</keycap></keycombo> </"
"shortcut> <guimenu>देखें</guimenu> <guisubmenu>बॉर्डर</guisubmenu> "
"<guimenuitem>आइकन बॉर्डर दिखाएं</guimenuitem>"

#. Tag: para
#: menus.docbook:868
#, no-c-format
msgid ""
"This is a toggle item. Setting it on checked will make the Icon Border "
"visible in the left side of the active editor, and vice versa. The Icon "
"Border indicates the positions of the marked lines in the editor."
msgstr ""
"यह एक टॉगल आइटम है। इसे चेक पर सेट करने से आइकन बॉर्डर सक्रिय संपादक के बाईं ओर दिखाई "
"देगा, और इसके विपरीत। आइकन बॉर्डर संपादक में चिह्नित लाइनों की स्थिति को इंगित करता है।"

#. Tag: menuchoice
#: menus.docbook:875
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"><keycap>F11</keycap></keycombo> </"
"shortcut> <guimenu>View</guimenu> <guisubmenu>Borders</guisubmenu> "
"<guimenuitem>Show Line Numbers</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"><keycap>F11</keycap></keycombo> </"
"shortcut> <guimenu>देखें</guimenu> <guisubmenu>बॉर्डर</guisubmenu> "
"<guimenuitem>लाइन नंबर दिखाएं</guimenuitem>"

#. Tag: para
#: menus.docbook:884
#, no-c-format
msgid ""
"This is a toggle Item. Setting it on checked will make a pane displaying the "
"line numbers of the document visible in the left border of the active "
"editor, and vice versa."
msgstr ""
"यह एक टॉगल आइटम है। इसे चेक पर सेट करने से सक्रिय संपादक की बाईं सीमा में दस्तावेज़ की "
"पंक्ति संख्या प्रदर्शित करने वाला एक फलक दिखाई देगा, और इसके विपरीत।"

#. Tag: menuchoice
#: menus.docbook:891
#, no-c-format
msgid ""
"<guimenu>View</guimenu> <guisubmenu>Borders</guisubmenu> <guimenuitem>Show "
"Scrollbar Marks</guimenuitem>"
msgstr ""
"<guimenu>देखें</guimenu> <guimenu>बॉर्डर्स</guimenuitem> <guimenuitem>स्क्रॉलबार "
"चिह्न दिखाएं</guimenuitem>"

#. Tag: para
#: menus.docbook:897
#, no-c-format
msgid ""
"If this option is checked, the view will show marks on the vertical "
"scrollbar. The marks are equivalent to the marks on the <link linkend=\"view-"
"show-icon-border\">Icon Border</link>."
msgstr ""
"यदि यह विकल्प चुना गया है, तो दृश्य ऊर्ध्वाधर स्क्रॉलबार पर निशान दिखाएगा। ये निशान "
"स्क्रॉलबार पर मौजूद निशानों के बराबर हैं।<link linkend=\"view-show-icon-border\"> "
"आइकन बॉर्डर</link> ."

#. Tag: menuchoice
#: menus.docbook:904
#, no-c-format
msgid ""
"<guimenu>View</guimenu> <guisubmenu>Borders</guisubmenu> <guimenuitem>Show "
"Scrollbar Mini-Map</guimenuitem>"
msgstr ""
"<guimenu>देखें</guimenu> <guimenu>बॉर्डर्स</guimenuitem> <guimenuitem>स्क्रॉलबार "
"मिनी-मैप दिखाएं</guimenuitem>"

#. Tag: para
#: menus.docbook:909
#, no-c-format
msgid ""
"This will replace the scrollbar with a visualization of the current "
"document. For more information on the scrollbar minimap, see <xref linkend="
"\"kate-part-scrollbar-minimap\"/>."
msgstr ""
"यह स्क्रॉलबार को वर्तमान दस्तावेज़ के विज़ुअलाइज़ेशन से बदल देगा। स्क्रॉलबार मिनिमैप पर अधिक "
"जानकारी के लिए, <xref linkend=\"kate-part-scrollbar-minimap\"/> देखें।"

#. Tag: menuchoice
#: menus.docbook:915
#, no-c-format
msgid "<guimenu>View</guimenu> <guimenuitem>Code Folding</guimenuitem>"
msgstr "<guimenu>देखें</guimenu> <guimenuitem>कोड फोल्डिंग</guimenuitem>"

#. Tag: para
#: menus.docbook:919
#, no-c-format
msgid ""
"These options pertain to <ulink url=\"help:/katepart/advanced-editing-tools-"
"code-folding.html\">code folding</ulink>:"
msgstr ""
"ये विकल्प <ulink url=\"help:/katepart/advanced-editing-tools-code-folding.html"
"\">कोड फोल्डिंग</ulink> से संबंधित हैं:"

#. Tag: menuchoice
#: menus.docbook:925
#, no-c-format
msgid ""
"<guimenu>View</guimenu> <guisubmenu>Borders</guisubmenu> <guisubmenu>Code "
"Folding</guisubmenu> <guimenuitem>Show Folding Markers</guimenuitem>"
msgstr ""
"<guimenu>देखें</guimenu> <guisubmenu>बॉर्डर</guisubmenu> <guisubmenu>कोड फोल्डिंग</"
"guisubmenu> <guimenuitem>फोल्डिंग मार्कर दिखाएं</guimenuitem>"

#. Tag: para
#: menus.docbook:931
#, no-c-format
msgid ""
"Toggles the display of the folding marker pane in the left side of the view."
msgstr "दृश्य के बाईं ओर फोल्डिंग मार्कर फलक के प्रदर्शन को टॉगल करता है।"

#. Tag: menuchoice
#: menus.docbook:936
#, no-c-format
msgid ""
"<guimenu>View</guimenu> <guisubmenu>Code Folding</guisubmenu> "
"<guimenuitem>Fold Current Node</guimenuitem>"
msgstr ""
"<guimenu>देखें</guimenu> <guisubmenu>कोड फोल्डिंग</guisubmenu> "
"<guimenuitem>वर्तमान नोड को मोड़ें</guimenuitem>"

#. Tag: para
#: menus.docbook:941
#, no-c-format
msgid "Collapse the region that contains the cursor."
msgstr "कर्सर वाले क्षेत्र को संक्षिप्त करें."

#. Tag: menuchoice
#: menus.docbook:945
#, no-c-format
msgid ""
"<guimenu>View</guimenu> <guisubmenu>Code Folding</guisubmenu> "
"<guimenuitem>Unfold Current Node</guimenuitem>"
msgstr ""
"<guimenu>देखें</guimenu> <guisubmenu>कोड फोल्डिंग</guisubmenu> "
"<guimenuitem>वर्तमान नोड खोलें</guimenuitem>"

#. Tag: para
#: menus.docbook:950
#, no-c-format
msgid "Expand the region that contains the cursor."
msgstr "कर्सर वाले क्षेत्र का विस्तार करें."

#. Tag: menuchoice
#: menus.docbook:954
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>-</keycap></"
"keycombo> </shortcut> <guimenu>View</guimenu> <guisubmenu>Code Folding</"
"guisubmenu> <guimenuitem>Fold Toplevel Nodes</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>-</keycap></"
"keycombo> </shortcut> <guimenu>देखें</guimenu> <guisubmenu>कोड फोल्डिंग</"
"guisubmenu> <guimenuitem>शीर्ष स्तर नोड्स को मोड़ें</guimenuitem>"

#. Tag: para
#: menus.docbook:962
#, no-c-format
msgid ""
"Collapse all toplevel regions in the document. Click on the right pointing "
"triangle to expand all toplevel regions."
msgstr ""
"दस्तावेज़ में सभी शीर्ष-स्तरीय क्षेत्रों को संक्षिप्त करें। सभी शीर्ष-स्तरीय क्षेत्रों को विस्तृत "
"करने के लिए दाईं ओर इंगित करने वाले त्रिभुज पर क्लिक करें।"

#. Tag: menuchoice
#: menus.docbook:967
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>+</keycap></"
"keycombo> </shortcut> <guimenu>View</guimenu> <guisubmenu>Code Folding</"
"guisubmenu> <guimenuitem>Unfold Toplevel Nodes</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>+</keycap></"
"keycombo> </shortcut> <guimenu>देखें</guimenu> <guisubmenu>कोड फोल्डिंग</"
"guisubmenu> <guimenuitem>शीर्ष स्तर नोड्स खोलें</guimenuitem>"

#. Tag: para
#: menus.docbook:975
#, no-c-format
msgid "Expand all toplevel regions in the document."
msgstr "दस्तावेज़ में सभी शीर्षस्तरीय क्षेत्रों का विस्तार करें."

#. Tag: guimenuitem
#: menus.docbook:984
#, no-c-format
msgid "Show Non-Printable Spaces"
msgstr "गैर-मुद्रण योग्य स्थान दिखाएं"

#. Tag: para
#: menus.docbook:986
#, no-c-format
msgid "Show/hide bounding box around non-printable spaces."
msgstr "गैर-मुद्रण योग्य स्थानों के आसपास बाउंडिंग बॉक्स दिखाएँ/छिपाएँ।"

#. Tag: title
#: menus.docbook:995
#, no-c-format
msgid "The Go Menu"
msgstr "गो मेनू"

#. Tag: menuchoice
#: menus.docbook:999
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>G</keycap></keycombo> </"
"shortcut> <guimenu>Go</guimenu> <guimenuitem>Go to Line...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>G</keycap></keycombo> </"
"shortcut> <guimenu>जाओ</guimenu> <guimenuitem>लाइन पर जाओ...</guimenuitem>"

#. Tag: para
#: menus.docbook:1007
#, no-c-format
msgid ""
"This opens the goto line bar at the bottom of the window which is used to "
"have the cursor jump to a particular line (specified by number) in the "
"document. The line number may be entered directly into the text box or "
"graphically by clicking on the up or down arrow spin controls at the side of "
"the text box. The little up arrow will increase the line number and the down "
"arrow decrease it. Close the bar with a click on the button with an icon on "
"the left side of the bar."
msgstr ""
"यह विंडो के निचले भाग में गोटो लाइन बार खोलता है जिसका उपयोग दस्तावेज़ में कर्सर को किसी "
"विशेष लाइन (संख्या द्वारा निर्दिष्ट) पर ले जाने के लिए किया जाता है। लाइन नंबर को सीधे "
"टेक्स्ट बॉक्स में या टेक्स्ट बॉक्स के किनारे ऊपर या नीचे तीर स्पिन नियंत्रण पर क्लिक करके "
"ग्राफ़िक रूप से दर्ज किया जा सकता है। छोटा ऊपर वाला तीर लाइन नंबर बढ़ाएगा और नीचे "
"वाला तीर इसे घटाएगा। बार के बाईं ओर एक आइकन वाले बटन पर क्लिक करके बार को बंद करें।"

#. Tag: menuchoice
#: menus.docbook:1019
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>E</keycap></keycombo> </"
"shortcut> <guimenu>Go</guimenu> <guimenuitem>Go to Previous Editing Line</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>E</keycap></keycombo> </"
"shortcut> <guimenu>जाएँ</guimenu> <guimenuitem>पिछली संपादन पंक्ति पर जाएँ</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:1027
#, no-c-format
msgid ""
"This action jumps the previous editing line in the <link linkend="
"\"multicursor-modifier-configure\">multicursor configuration</link>."
msgstr ""
"यह क्रिया पिछली संपादन पंक्ति को छोड़ देती है<link linkend=\"multicursor-modifier-"
"configure\"> मल्टीकर्सर कॉन्फ़िगरेशन</link> ."

