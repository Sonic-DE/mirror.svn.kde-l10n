"Line</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>E</keycap></"
"keycombo> </shortcut> <guimenu>जाएँ</guimenu> <guimenuitem>अगली संपादन पंक्ति पर "
