msgid "<userinput>i(</userinput>"
msgstr "<userinput>i(</userinput>"

#. Tag: para
#: vi.docbook:577
#, no-c-format
msgid ""
"Previous opening parenthesis [<userinput>(</userinput>] to next closing "
"parenthesis [<userinput>)</userinput>], including the parenthesis"
msgstr ""
"पिछला आरंभिक कोष्ठक [<userinput>(</userinput>] से अगले समापन कोष्ठक "
"[<userinput>)</userinput>], जिसमें कोष्ठक भी शामिल है"

#. Tag: userinput
#: vi.docbook:580
#, no-c-format
msgid "<userinput>a(</userinput>"
msgstr "<userinput>a(</userinput>"

#. Tag: para
#: vi.docbook:581
#, no-c-format
msgid ""
"Previous opening parenthesis [<userinput>(</userinput>] to next closing "
"parenthesis [<userinput>)</userinput>], excluding the parenthesis"
msgstr ""
"पिछला आरंभिक कोष्ठक [<userinput>(</userinput>] से अगले समापन कोष्ठक "
"[<userinput>)</userinput>] तक, कोष्ठक को छोड़कर"

#. Tag: userinput
#: vi.docbook:584
#, no-c-format
msgid "<userinput>i[</userinput>"
msgstr "<userinput>i[</userinput>"

#. Tag: para
#: vi.docbook:585
#, no-c-format
msgid ""
"Previous opening square bracket (<userinput>[</userinput>) to next closing "
"square bracket (<userinput>]</userinput>), including the brackets"
msgstr ""
"पिछले आरंभिक वर्गाकार कोष्ठक (<userinput>[</userinput>) से अगले बंद वर्गाकार कोष्ठक "
"(<userinput>]</userinput>), कोष्ठकों सहित"

#. Tag: userinput
#: vi.docbook:588
#, no-c-format
msgid "<userinput>a[</userinput>"
msgstr "<userinput>a[</userinput>"

#. Tag: para
#: vi.docbook:589
#, no-c-format
msgid ""
"Previous opening square bracket (<userinput>[</userinput>) to next closing "
"square bracket (<userinput>]</userinput>), excluding the brackets"
msgstr ""
"पिछले खुलने वाले वर्गाकार कोष्ठक (<userinput>[</userinput>) से अगले बंद होने वाले "
"वर्गाकार कोष्ठक (<userinput>]</userinput>), कोष्ठकों को छोड़कर"

#. Tag: userinput
#: vi.docbook:592
#, no-c-format
msgid "<userinput>i{</userinput>"
msgstr "<userinput>i{</userinput>"

#. Tag: para
#: vi.docbook:593
#, no-c-format
msgid ""
"Previous opening curly bracket (<userinput>{</userinput>) to next closing "
"curly bracket (<userinput>}</userinput>), including the brackets"
msgstr ""
"पिछले आरंभिक कर्ली ब्रैकेट (<userinput>{</userinput>) से अगले समापन कर्ली ब्रैकेट "
"(<userinput>}</userinput>), ब्रैकेट सहित"

#. Tag: userinput
#: vi.docbook:596
#, no-c-format
msgid "<userinput>a{</userinput>"
msgstr "<userinput>a{</userinput>"

#. Tag: para
#: vi.docbook:597
#, no-c-format
msgid ""
"Previous opening curly bracket (<userinput>{</userinput>) to next closing "
"curly bracket (<userinput>}</userinput>), excluding the brackets"
msgstr ""
"पिछले खुले कर्ली ब्रैकेट (<userinput>{</userinput>) से अगले बंद कर्ली ब्रैकेट (<userinput>}"
"</userinput>), ब्रैकेट को छोड़कर"

#. Tag: userinput
#: vi.docbook:600
#, no-c-format
msgid "i&lt;"
msgstr "मैं&lt;"

#. Tag: para
#: vi.docbook:601
#, no-c-format
msgid ""
"Previous opening angle bracket (<userinput>&lt;</userinput>) to next closing "
"angle bracket (<userinput>&gt;</userinput>), including the brackets"
msgstr ""
"पिछले आरंभिक कोण कोष्ठक (<userinput>&lt;</userinput>) से अगले समापन कोण कोष्ठक "
"(<userinput>&gt;</userinput>), कोष्ठकों सहित"

#. Tag: userinput
#: vi.docbook:604
#, no-c-format
msgid "a&lt;"
msgstr "ए&lt;"

#. Tag: para
#: vi.docbook:605
#, no-c-format
msgid ""
"Previous opening angle bracket (<userinput>&lt;</userinput>) to next closing "
"square bracket (<userinput>&gt;</userinput>), excluding the brackets"
msgstr ""
"पिछले खुलने वाले कोण कोष्ठक (<userinput>&lt;</userinput>) से अगले बंद होने वाले वर्ग "
"कोष्ठक (<userinput>&gt;</userinput>), कोष्ठकों को छोड़कर"

#. Tag: userinput
#: vi.docbook:608
#, no-c-format
msgid "<userinput>i`</userinput>"
msgstr "<userinput>i`</userinput>"

#. Tag: para
#: vi.docbook:609
#, no-c-format
msgid ""
"Previous backtick (<userinput>`</userinput>) to next backtick, including the "
"backticks"
msgstr "पिछला बैकटिक (<userinput>`</userinput>) से अगला बैकटिक, बैकटिक सहित"

#. Tag: userinput
#: vi.docbook:612
#, no-c-format
msgid "<userinput>a`</userinput>"
msgstr "<userinput>a`</userinput>"

#. Tag: para
#: vi.docbook:613
#, no-c-format
msgid ""
"Previous backtick (<userinput>`</userinput>) to next backtick, excluding the "
"backticks"
msgstr "पिछला बैकटिक (<userinput>`</userinput>) से अगले बैकटिक तक, बैकटिक को छोड़कर"

