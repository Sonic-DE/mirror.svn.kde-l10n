#. Tag: title
#: compare.docbook:8
#, no-c-format
msgid "<title>Compare</title>"
msgstr "<title>तुलना करना</title>"

#. Tag: para
#: compare.docbook:9
#, no-c-format
msgid ""
"&krusader; contains several compare functions: <guimenuitem>Compare by "
"Content</guimenuitem>, <guimenuitem>Compare Folders</guimenuitem> and the "
"<link linkend=\"synchronizer\">Synchronizer</link> compare function."
msgstr ""
"&amp;krusader; में कई तुलना फ़ंक्शन शामिल हैं:<guimenuitem> सामग्री के आधार पर तुलना "
"करें</guimenuitem> ,<guimenuitem> फ़ोल्डरों की तुलना करें</guimenuitem> और यह<link "
"linkend=\"synchronizer\"> समकालीन बनानेवाला</link> तुलना समारोह."

#. Tag: title
#: compare.docbook:15
#, no-c-format
msgid "Compare by Content"
msgstr "सामग्री के आधार पर तुलना करें"

#. Tag: primary
#: compare.docbook:17 compare.docbook:34
#, no-c-format
msgid "<primary>Compare</primary>"
msgstr "<प्राथमिक>तुलना करें</प्राथमिक>"

#. Tag: secondary
#: compare.docbook:18
#, no-c-format
msgid "Content"
msgstr "सामग्री"

#. Tag: para
#: compare.docbook:20
#, no-c-format
msgid ""
"Select one file in each panel and use <menuchoice> <guimenu>File</guimenu> "
"<guimenuitem>Compare by content...</guimenuitem> </menuchoice>. &krusader; "
"will open an external graphical difference tool that is <link linkend="
"\"konfig-dependencies\">configured</link>. &kompare;, <ulink url=\"https://"
"www.kde.org/applications/development/kdiff3/\"><application>KDiff3</"
"application></ulink> and <ulink url=\"http://furius.ca/xxdiff/"
"\"><application>xxdiff</application></ulink> are supported."
msgstr ""
"प्रत्येक पैनल में एक फ़ाइल का चयन करें और उपयोग करें<menuchoice><guimenu> फ़ाइल</"
"guimenu><guimenuitem> सामग्री के आधार पर तुलना करें...</guimenuitem></"
"menuchoice> . &amp;krusader; एक बाहरी ग्राफिकल अंतर उपकरण खोलेगा जो<link "
"linkend=\"konfig-dependencies\"> कॉन्फ़िगर किया गया</link> .&amp;kompare;,"
"<ulink url=\"https://www.kde.org/applications/development/kdiff3/"
"\"><application> केडिफ3</application></ulink> और<ulink url=\"http://furius.ca/"
"xxdiff/\"><application> xxडिफ</application></ulink> समर्थित हैं."

#. Tag: title
#: compare.docbook:32
#, no-c-format
msgid "Compare Folders"
msgstr "फ़ोल्डरों की तुलना करें"

#. Tag: secondary
#: compare.docbook:35
#, no-c-format
msgid "Folders"
msgstr "फ़ोल्डर"

#. Tag: para
#: compare.docbook:37
#, no-c-format
msgid ""
"Compare the files of each panel by using <menuchoice> <guimenu>Edit</"
"guimenu> <guimenuitem>Compare Folders</guimenuitem> </menuchoice>. By "
"default newer and single files will be selected in each panel, this "
"behaviour can be changed in the <guimenuitem>Compare Setup</guimenuitem> "
"menu."
msgstr ""
"<menuchoice> <guimenu>संपादन</guimenu> <guimenuitem>फ़ोल्डर्स की तुलना करें</"
"guimenuitem> </menuchoice> का उपयोग करके प्रत्येक पैनल की फ़ाइलों की तुलना करें। "
"डिफ़ॉल्ट रूप से प्रत्येक पैनल में नई और एकल फ़ाइलें चुनी जाएँगी, इस व्यवहार को "
"<guimenuitem>सेटअप की तुलना करें</guimenuitem> मेनू में बदला जा सकता है।"

#. Tag: para
#: compare.docbook:46
#, no-c-format
msgid ""
"The files are not compared by content but by their names and dates only."
msgstr ""
"फाइलों की तुलना उनकी विषय-वस्तु के आधार पर नहीं बल्कि केवल उनके नाम और तारीख के आधार "
"पर की जाती है।"

#. Tag: menuchoice
#: compare.docbook:52
#, no-c-format
msgid "<guimenu>Edit</guimenu> <guimenuitem>Compare Setup</guimenuitem>"
msgstr ""
"<guimenu>संपादित करें</guimenu> <guimenuitem>सेटअप की तुलना करें</guimenuitem>"

#. Tag: para
#: compare.docbook:58
#, no-c-format
msgid "Configures the <guimenuitem>Compare Folders</guimenuitem> function."
msgstr "<guimenuitem>फ़ोल्डर्स की तुलना करें</guimenuitem> फ़ंक्शन को कॉन्फ़िगर करता है."

#. Tag: para
#: compare.docbook:63
#, no-c-format
msgid "<guimenuitem>Select Newer and Single</guimenuitem> (default)"
msgstr "<guimenuitem>नया और एकल चुनें</guimenuitem> (डिफ़ॉल्ट)"

#. Tag: guimenuitem
#: compare.docbook:69
#, no-c-format
msgid "Select Single"
msgstr "एकल चुनें"

#. Tag: guimenuitem
#: compare.docbook:74
#, no-c-format
msgid "Select Newer"
msgstr "नया चुनें"

#. Tag: guimenuitem
#: compare.docbook:79
#, no-c-format
msgid "Select Different and Single"
msgstr "अलग और एकल का चयन करें"

#. Tag: guimenuitem
#: compare.docbook:85
#, no-c-format
msgid "Select Different"
msgstr "अलग चुनें"
