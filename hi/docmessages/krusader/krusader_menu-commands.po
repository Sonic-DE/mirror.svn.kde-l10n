msgstr "वर्तमान उपयोगकर्ता के होम फ़ोल्डर पर नेविगेट करता है."

#. Tag: menuchoice
#: menu-commands.docbook:715
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; &Backspace;</keycombo> </"
"shortcut> <guimenu>Go</guimenu> <guimenuitem>Root</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; &Backspace;</keycombo> </"
"shortcut> <guimenu>जाओ</guimenu> <guimenuitem>रूट</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:725
#, no-c-format
msgid "Navigates to the root folder of the system."
msgstr "सिस्टम के रूट फ़ोल्डर पर नेविगेट करता है."

#. Tag: menuchoice
