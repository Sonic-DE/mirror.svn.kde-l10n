"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>F</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Find in folder...</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>F</keycap></keycombo> </"
"shortcut> <guimenu>संपादित करें</guimenu> <guimenuitem>फ़ोल्डर में खोजें...</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:555
#, no-c-format
msgid ""
"Toggles &krusader; <link linkend=\"quicksearch\">quick search</link> "
"function."
msgstr ""
"टॉगल &amp;krusader;<link linkend=\"quicksearch\"> त्वरित खोज</link> समारोह।"

#. Tag: menuchoice
#: menu-commands.docbook:561
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift; <keycap>C</keycap></"
"keycombo> </shortcut> <guimenu>Edit</guimenu> <guimenuitem>Compare Folders</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift; <keycap>C</keycap></"
"keycombo> </shortcut> <guimenu>संपादित करें</guimenu> <guimenuitem>फ़ोल्डर्स की "
"तुलना करें</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:571
#, no-c-format
msgid ""
"Toggles &krusader; <link linkend=\"compare-dir\">Compare Folders</link> "
"function."
msgstr ""
"टॉगल &amp;krusader;<link linkend=\"compare-dir\"> फ़ोल्डरों की तुलना करें</link> "
"समारोह।"

#. Tag: menuchoice
#: menu-commands.docbook:577
#, no-c-format
msgid "<guimenu>Edit</guimenu> <guimenuitem>Compare Setup</guimenuitem>"
msgstr ""
"<guimenu>संपादित करें</guimenu> <guimenuitem>सेटअप की तुलना करें</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:583
#, no-c-format
msgid "Configures the <guimenuitem>Compare Folders</guimenuitem> function."
msgstr "<guimenuitem>फ़ोल्डर्स की तुलना करें</guimenuitem> फ़ंक्शन को कॉन्फ़िगर करता है."

#. Tag: para
#: menu-commands.docbook:587
#, no-c-format
msgid "<guimenuitem>Select Newer and Single</guimenuitem> (default)"
msgstr "<guimenuitem>नया और एकल चुनें</guimenuitem> (डिफ़ॉल्ट)"

#. Tag: guimenuitem
#: menu-commands.docbook:592
#, no-c-format
msgid "Select Single"
msgstr "एकल चुनें"

#. Tag: guimenuitem
#: menu-commands.docbook:597
