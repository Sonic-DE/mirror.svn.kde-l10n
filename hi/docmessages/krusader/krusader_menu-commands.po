msgstr "दृश्य स्केल बढ़ाएँ."

#. Tag: menuchoice
#: menu-commands.docbook:800
#, no-c-format
msgid "<guimenu>View</guimenu> <guimenuitem>Zoom Out</guimenuitem>"
msgstr "<guimenu>देखें</guimenu> <guimenuitem>ज़ूम आउट करें</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:806
#, no-c-format
msgid "Decrease the view scale."
msgstr "दृश्य स्केल घटाएँ."

#. Tag: menuchoice
#: menu-commands.docbook:811
#, no-c-format
msgid "<guimenu>View</guimenu> <guimenuitem>Default Zoom</guimenuitem>"
msgstr "<guimenu>देखें</guimenu> <guimenuitem>डिफ़ॉल्ट ज़ूम</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:817
#, no-c-format
msgid "Reset the view scale."
msgstr "दृश्य स्केल रीसेट करें."

#. Tag: menuchoice
#: menu-commands.docbook:822
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> &Alt;&Shift; <keycap>D</keycap></"
"keycombo> </shortcut> <guimenu>View</guimenu> <guimenuitem>Detailed View</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> &Alt;&Shift; <keycap>D</keycap></"
"keycombo> </shortcut> <guimenu>देखें</guimenu> <guimenuitem>विस्तृत दृश्य</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:833
#, no-c-format
msgid ""
"Shows the file names, file size, creation date and time and their attributes."
msgstr "फ़ाइल नाम, फ़ाइल आकार, निर्माण दिनांक और समय और उनकी विशेषताएं दिखाता है।"

#. Tag: menuchoice
#: menu-commands.docbook:838
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> &Alt;&Shift; <keycap>B</keycap></"
"keycombo> </shortcut> <guimenu>View</guimenu> <guimenuitem>Brief View</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> &Alt;&Shift; <keycap>B</keycap></"
"keycombo> </shortcut> <guimenu>देखें</guimenu> <guimenuitem>संक्षिप्त दृश्य</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:849
#, no-c-format
msgid "Shows only the file names."
msgstr "केवल फ़ाइल नाम दिखाता है."

#. Tag: menuchoice
#: menu-commands.docbook:854
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt; <keycap>.</keycap></keycombo> </"
"shortcut> <guimenu>View</guimenu> <guimenuitem>Show Hidden Files</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt; <keycap>.</keycap></keycombo> </"
"shortcut> <guimenu>देखें</guimenu> <guimenuitem>छिपी हुई फ़ाइलें दिखाएँ</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:864
#, no-c-format
msgid ""
"Toggles the option to display the hidden files in the &krusader; panels."
msgstr "&krusader; पैनलों में छिपी हुई फ़ाइलों को प्रदर्शित करने के विकल्प को टॉगल करता है।"

#. Tag: menuchoice
#: menu-commands.docbook:870
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Shift; <keycap>F10</keycap></"
"keycombo> </shortcut> <guimenu>View</guimenu> <guimenuitem>All Files</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Shift; <keycap>F10</keycap></"
"keycombo> </shortcut> <guimenu>देखें</guimenu> <guimenuitem>सभी फ़ाइलें</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:880
#, no-c-format
msgid "Turns off all filters and display all files."
msgstr "सभी फ़िल्टर बंद कर देता है और सभी फ़ाइलें प्रदर्शित करता है."

#. Tag: menuchoice
#: menu-commands.docbook:885
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Shift; <keycap>F12</keycap></"
"keycombo> </shortcut> <guimenu>View</guimenu> <guimenuitem>Custom</"
"guimenuitem>"
msgstr ""
"<शॉर्टकट> <keycombo action=\"simul\">&Shift; <keycap>F12</keycap></keycombo> "
"</shortcut> <guimenu>देखें</guimenu> <guimenuitem>कस्टम</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:895
#, no-c-format
msgid ""
"Allows you to install a custom filter on the &krusader; panel. Only files "
"that match the filter pattern(s) and folders will be displayed. Do not "
"forget to deactivate the custom filter after use, or some files may not be "
"visible."
msgstr ""
"आपको &krusader; पैनल पर कस्टम फ़िल्टर स्थापित करने की अनुमति देता है। केवल वे फ़ाइलें "
"प्रदर्शित की जाएँगी जो फ़िल्टर पैटर्न(ओं) और फ़ोल्डरों से मेल खाती हैं। उपयोग के बाद कस्टम "
"फ़िल्टर को निष्क्रिय करना न भूलें, अन्यथा कुछ फ़ाइलें दिखाई नहीं देंगी।"

#. Tag: menuchoice
#: menu-commands.docbook:904
#, no-c-format
msgid "<guimenu>View</guimenu> <guimenuitem>Show Previews</guimenuitem>"
msgstr "<guimenu>देखें</guimenu> <guimenuitem>पूर्वावलोकन दिखाएं</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:910
#, no-c-format
msgid ""
"If checked, show the previews for all files and folders on the active panel."
msgstr ""
"यदि चेक किया गया है, तो सक्रिय पैनल पर सभी फ़ाइलों और फ़ोल्डरों का पूर्वावलोकन दिखाएं."

#. Tag: menuchoice
#: menu-commands.docbook:915
#, no-c-format
msgid ""
"<guimenu>View</guimenu> <guimenuitem>Select Remote Charset</guimenuitem>"
msgstr "<guimenu>देखें</guimenu> <guimenuitem>दूरस्थ वर्णसेट चुनें</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:921
#, no-c-format
msgid ""
"Selects the remote charset for <link linkend=\"remote-connections\">Remote "
"Connections</link>."
msgstr ""
"के लिए दूरस्थ वर्णसेट का चयन करता है<link linkend=\"remote-connections\"> दूरस्थ "
"कनेक्शन</link> ."

