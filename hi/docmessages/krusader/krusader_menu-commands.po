msgstr ""
"<link linkend=\"calculate\">अधिभोग स्थान की गणना करता है</link> फ़ाइलों और "
"फ़ोल्डरों, अभिलेखागारों और दूरस्थ फ़ाइल सिस्टमों का संग्रह।"

#. Tag: menuchoice
#: menu-commands.docbook:629
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt; <keysym>Return</keysym></"
"keycombo> </shortcut> <guimenu>Edit</guimenu> <guimenuitem>Properties...</"
"guimenuitem>"
msgstr ""
"<शॉर्टकट> <कीकॉम्बो एक्शन='एक साथ'>&Alt; <keysym>वापसी</keysym></keycombo> </"
"shortcut> <guimenu>संपादित करें</guimenu> <guimenuitem>गुण...</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:639
#, no-c-format
msgid ""
"Opens the properties dialog for the currently selected file. (KP refers to "
"Key Pad.)"
msgstr "वर्तमान में चयनित फ़ाइल के लिए गुण संवाद खोलता है। (KP का अर्थ कुंजी पैड है।)"

#. Tag: title
#: menu-commands.docbook:646
#, no-c-format
msgid "Go Menu"
msgstr "मेनू पर जाएँ"

#. Tag: menuchoice
#: menu-commands.docbook:650
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt; &Up;</keycombo> </shortcut> "
"<guimenu>Go</guimenu> <guimenuitem>Up</guimenuitem>"
msgstr ""
"<शॉर्टकट> <कीकॉम्बो एक्शन='एक साथ'>&Alt; &ऊपर;</keycombo> </शॉर्टकट> "
"<guimenu>जाएं</guimenu> <guimenuitem>ऊपर</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:660
#, no-c-format
msgid "Navigates to the parent folder of the active panel."
msgstr "सक्रिय पैनल के मूल फ़ोल्डर पर नेविगेट करता है."

#. Tag: menuchoice
#: menu-commands.docbook:666
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt; &Left;</keycombo> </shortcut> "
"<guimenu>Go</guimenu> <guimenuitem>Back</guimenuitem>"
msgstr ""
"<शॉर्टकट> <कीकॉम्बो एक्शन='एक साथ'>&Alt; &बाएँ;</keycombo> </शॉर्टकट> "
"<guimenu>जाएँ</guimenu> <guimenuitem>वापस</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:676
#, no-c-format
msgid "Navigates to the previously viewed folder in the active panel."
msgstr "सक्रिय पैनल में पहले देखे गए फ़ोल्डर पर नेविगेट करता है."

#. Tag: menuchoice
#: menu-commands.docbook:682
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt; &Right;</keycombo> </shortcut> "
"<guimenu>Go</guimenu> <guimenuitem>Forward</guimenuitem>"
msgstr ""
"<शॉर्टकट> <कीकॉम्बो एक्शन='एक साथ'>&Alt; &दाएं;</keycombo> </शॉर्टकट> "
"<guimenu>जाएं</guimenu> <guimenuitem>आगे बढ़ें</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:692
#, no-c-format
msgid ""
"Navigates to the next viewed folder in the active panel. Becomes available "
"only if <menuchoice><guimenu>Go</guimenu> <guimenuitem>Back</guimenuitem></"
"menuchoice> was used beforehand."
msgstr ""
"सक्रिय पैनल में अगले देखे गए फ़ोल्डर पर नेविगेट करता है। यह तभी उपलब्ध होता है जब "
"<menuchoice><guimenu>Go</guimenu> <guimenuitem>Back</guimenuitem></"
"menuchoice> का पहले से उपयोग किया गया हो।"

#. Tag: menuchoice
#: menu-commands.docbook:699
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt; &Home;</keycombo> </shortcut> "
"<guimenu>Go</guimenu> <guimenuitem>Home</guimenuitem>"
msgstr ""
"<शॉर्टकट> <कीकॉम्बो एक्शन='एक साथ'>&Alt; &होम;</कीकॉम्बो> </शॉर्टकट> <गुइमेनु>जाएं</"
"गुइमेनु> <गुइमेनुइटम>होम</गुइमेनुइटम>"

#. Tag: para
#: menu-commands.docbook:709
#, no-c-format
