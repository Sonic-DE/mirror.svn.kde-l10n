"संपादित करने की अनुमति देता है।"

#. Tag: menuchoice
#: menu-commands.docbook:1034
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> &Ctrl;&Alt;<keycap>M</keycap> </"
"keycombo> </shortcut> <guimenu>Useractions</guimenu><guisubmenu>Samples</"
"guisubmenu> <guimenuitem>Mount</guimenuitem>"
msgstr ""
"<शॉर्टकट> <कीकॉम्बो एक्शन = \"सिमुल\"> &Ctrl;&Alt;<keycap>M</keycap> </keycombo> "
"</शॉर्टकट> <guimenu>उपयोगकर्ता</guimenu><guisubmenu>नमूने</guisubmenu> "
"<guimenuitem> माउंट</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1045
#, no-c-format
