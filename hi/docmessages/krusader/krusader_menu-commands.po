#. Tag: title
#: menu-commands.docbook:8
#, no-c-format
msgid "Menu Commands"
msgstr "मेनू कमांड"

#. Tag: primary
#: menu-commands.docbook:10
#, no-c-format
msgid "Commands"
msgstr "आदेश"

#. Tag: secondary
#: menu-commands.docbook:11
#, no-c-format
msgid "Menu"
msgstr "मेनू"

#. Tag: title
#: menu-commands.docbook:14
#, no-c-format
msgid "File Menu"
msgstr "फ़ाइल मेनू"

#. Tag: menuchoice
#: menu-commands.docbook:18
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Shift; <keycap>F4</keycap></keycombo> "
"</shortcut> <guimenu>File</guimenu> <guimenuitem>New Text File...</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Shift; <keycap>F4</keycap></keycombo> "
"</shortcut> <guimenu>फ़ाइल</guimenu> <guimenuitem>नई टेक्स्ट फ़ाइल...</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:28
#, no-c-format
msgid ""
"Creates a new text file in the current folder, unless another folder is "
"specified. The new file is opened for editing after it is created."
msgstr ""
"मौजूदा फ़ोल्डर में एक नई टेक्स्ट फ़ाइल बनाता है, जब तक कि कोई दूसरा फ़ोल्डर निर्दिष्ट न हो। "
"नई फ़ाइल बनने के बाद संपादन के लिए खोली जाती है।"

#. Tag: menuchoice
#: menu-commands.docbook:35
#, no-c-format
msgid ""
"<shortcut> <keycap>F7</keycap> </shortcut> <guimenu>File</guimenu> "
"<guimenuitem>New Folder</guimenuitem>"
msgstr ""
"<शॉर्टकट> <keycap>F7</keycap> </शॉर्टकट> <guimenu>फ़ाइल</guimenu> "
"<guimenuitem>नया फ़ोल्डर</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:44
#, no-c-format
msgid "Creates a new folder in the current folder."
msgstr "वर्तमान फ़ोल्डर में एक नया फ़ोल्डर बनाता है."

#. Tag: menuchoice
#: menu-commands.docbook:50
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> &Alt;&Ctrl; <keycap>S</keycap></"
"keycombo> </shortcut> <guimenu>File</guimenu> <guimenuitem>New Symlink...</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> &Alt;&Ctrl; <keycap>S</keycap></"
"keycombo> </shortcut> <guimenu>फ़ाइल</guimenu> <guimenuitem>नया सिमलिंक...</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:61
#, no-c-format
msgid "Creates a symbolic link to the currently selected file."
msgstr "वर्तमान में चयनित फ़ाइल के लिए एक प्रतीकात्मक लिंक बनाता है."

#. Tag: menuchoice
#: menu-commands.docbook:67
#, no-c-format
msgid ""
"<shortcut> <keycap>F3</keycap> </shortcut> <guimenu>File</guimenu> "
"<guimenuitem>View File</guimenuitem>"
msgstr ""
"<शॉर्टकट> <keycap>F3</keycap> </शॉर्टकट> <guimenu>फ़ाइल</guimenu> "
"<guimenuitem>फ़ाइल देखें</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:76
#, no-c-format
msgid ""
"Opens the currently selected file for <link linkend=\"kredit\">viewing</"
"link>."
msgstr ""
"वर्तमान में चयनित फ़ाइल को खोलता है<link linkend=\"kredit\"> को देखने</link> ."

#. Tag: menuchoice
#: menu-commands.docbook:82
#, no-c-format
msgid ""
"<shortcut> <keycap>F4</keycap> </shortcut> <guimenu>File</guimenu> "
"<guimenuitem>Edit File</guimenuitem>"
msgstr ""
"<शॉर्टकट> <keycap>F4</keycap> </शॉर्टकट> <guimenu>फ़ाइल</guimenu> "
"<guimenuitem>फ़ाइल संपादित करें</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:91
#, no-c-format
msgid ""
"Opens the currently selected file for <link linkend=\"kredit\">editing</"
"link>."
msgstr "वर्तमान में चयनित फ़ाइल को खोलता है<link linkend=\"kredit\"> संपादन</link> ."

#. Tag: menuchoice
#: menu-commands.docbook:97
#, no-c-format
msgid ""
"<shortcut> <keycap>F5</keycap> </shortcut> <guimenu>File</guimenu> "
"<guimenuitem>Copy to other panel</guimenuitem>"
msgstr ""
"<shortcut> <keycap>F5</keycap> </shortcut> <guimenu>फ़ाइल</guimenu> "
"<guimenuitem>अन्य पैनल पर कॉपी करें</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:106
#, no-c-format
msgid "Copy the currently selected files or folders to the other panel."
msgstr "वर्तमान में चयनित फ़ाइलों या फ़ोल्डरों को दूसरे पैनल पर कॉपी करें।"

#. Tag: menuchoice
#: menu-commands.docbook:112
#, no-c-format
msgid ""
"<shortcut> <keycap>F6</keycap> </shortcut> <guimenu>File</guimenu> "
"<guimenuitem>Move</guimenuitem>"
msgstr ""
"<शॉर्टकट> <keycap>F6</keycap> </शॉर्टकट> <guimenu>फ़ाइल</guimenu> "
"<guimenuitem>स्थानांतरित करें</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:121
#, no-c-format
msgid ""
"Opens a dialog to <link linkend=\"copying\">move</link> the currently "
"selected files or folders to a specified location."
msgstr ""
"एक संवाद खोलता है<link linkend=\"copying\"> कदम</link> वर्तमान में चयनित फ़ाइलों या "
"फ़ोल्डरों को निर्दिष्ट स्थान पर ले जाएँ।"

#. Tag: menuchoice
#: menu-commands.docbook:128
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift; <keycap>P</keycap></"
"keycombo> </shortcut> <guimenu>File</guimenu> <guimenuitem>Pack...</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift; <keycap>P</keycap></"
"keycombo> </shortcut> <guimenu>फ़ाइल</guimenu> <guimenuitem>पैक...</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:138
#, no-c-format
msgid ""
"Creates a <link linkend=\"pack-archive\">new archive</link> of all the "
"selected files and folders in the active panel."
msgstr ""
"बनाता है<link linkend=\"pack-archive\"> नया संग्रह</link> सक्रिय पैनल में सभी चयनित "
"फ़ाइलों और फ़ोल्डरों की."

#. Tag: menuchoice
#: menu-commands.docbook:146
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift; <keycap>U</keycap></"
"keycombo> </shortcut> <guimenu>File</guimenu> <guimenuitem>Unpack...</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift; <keycap>U</keycap></"
"keycombo> </shortcut> <guimenu>फ़ाइल</guimenu> <guimenuitem>अनपैक करें...</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:156
#, no-c-format
msgid ""
"<link linkend=\"unpacking-archives\">Unpacks</link> all the selected files "
"in the active panel."
msgstr ""
"<link linkend=\"unpacking-archives\">अनपैक</link> सक्रिय पैनल में सभी चयनित फ़ाइलें."

#. Tag: menuchoice
#: menu-commands.docbook:163
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift; <keycap>E</keycap></"
"keycombo> </shortcut> <guimenu>File</guimenu> <guimenuitem>Test Archive</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift; <keycap>E</keycap></"
"keycombo> </shortcut> <guimenu>फ़ाइल</guimenu> <guimenuitem>परीक्षण संग्रह</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:173
#, no-c-format
msgid "<link linkend=\"test-archive\">Tests archive</link> for corruption."
msgstr "<link linkend=\"test-archive\">परीक्षण संग्रह</link> भ्रष्टाचार के लिए."

#. Tag: menuchoice
#: menu-commands.docbook:180
#, no-c-format
msgid ""
"<guimenu>File</guimenu> <guimenuitem>Compare by Content...</guimenuitem>"
msgstr ""
"<guimenu>फ़ाइल</guimenu> <guimenuitem>सामग्री के आधार पर तुलना करें...</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:186
#, fuzzy, no-c-format
#| msgid ""
#| "Compares two current files by content - one from each panel via an "
#| "external graphical diff utility. By default &kompare; is used, but you "
#| "can also use &eg; <ulink url=\"http://furius.ca/xxdiff/"
#| "\"><application>xxdiff</application></ulink> or <ulink url=\"https://www."
#| "kde.org/applications/development/kdiff3/\"><application>KDiff3</"
#| "application></ulink> , change it in the <link linkend=\"konfig-"
#| "dependencies\">Konfigurator Dependencies page</link>."
msgid ""
"Compares two current files by content - one from each panel via an external "
"graphical diff utility. By default &kompare; is used, but you can also use "
"&eg; <ulink url=\"http://furius.ca/xxdiff/\"><application>xxdiff</"
"application></ulink> or <ulink url=\"https://apps.kde.org/"
"kdiff3\"><application>KDiff3</application></ulink> , change it in the <link "
"linkend=\"konfig-dependencies\">Konfigurator Dependencies page</link>."
msgstr ""
"सामग्री के आधार पर दो मौजूदा फ़ाइलों की तुलना करता है - बाहरी ग्राफ़िकल डिफ यूटिलिटी के "
"ज़रिए प्रत्येक पैनल से एक। डिफ़ॉल्ट रूप से &amp;kompare; का उपयोग किया जाता है, लेकिन आप "
"⪚ का भी उपयोग कर सकते हैं<ulink url=\"http://furius.ca/xxdiff/\"><application> "
"xxडिफ</application></ulink> या<ulink url=\"https://www.kde.org/applications/"
"development/kdiff3/\"><application> केडिफ3</application></ulink> , इसे "
"बदलें<link linkend=\"konfig-dependencies\"> कॉन्फ़िगरेटर निर्भरता पृष्ठ</link> ."

#. Tag: menuchoice
#: menu-commands.docbook:196
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Shift; <keycap>F2</keycap></keycombo> "
"</shortcut> <guimenu>File</guimenu> <guimenuitem>Multi Rename...</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Shift; <keycap>F2</keycap></keycombo> "
"</shortcut> <guimenu>फ़ाइल</guimenu> <guimenuitem>एकाधिक नाम बदलें...</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:206
#, fuzzy, no-c-format
#| msgid ""
#| "This menu option starts <ulink url=\"https://www.kde.org/applications/"
#| "utilities/krename/\"><application>Krename</application></ulink>, a very "
#| "powerful external batch renamer."
msgid ""
"This menu option starts <ulink url=\"hhttps://apps.kde.org/krename"
"\"><application>Krename</application></ulink>, a very powerful external "
"batch renamer."
msgstr ""
"यह मेनू विकल्प <ulink url=\"https://www.kde.org/applications/utilities/krename/"
"\"><application>Krename</application></ulink> प्रारंभ करता है, जो एक बहुत "
"शक्तिशाली बाह्य बैच नामांतरक है।"

#. Tag: title
#: menu-commands.docbook:209
#, no-c-format
msgid "Krename Features"
msgstr "Krename विशेषताएं"

#. Tag: para
#: menu-commands.docbook:211
#, no-c-format
msgid "Renaming a list of files based on a set of expressions"
msgstr "अभिव्यक्तियों के एक सेट के आधार पर फ़ाइलों की सूची का नाम बदलना"

#. Tag: para
#: menu-commands.docbook:215
#, no-c-format
msgid "Copying/moving a list of files to another folder"
msgstr "फ़ाइलों की सूची को किसी अन्य फ़ोल्डर में कॉपी करना/स्थानांतरित करना"

#. Tag: para
#: menu-commands.docbook:219
#, no-c-format
msgid "Convert filenames to upper/lower case"
msgstr "फ़ाइल नामों को अपर/लोअर केस में बदलें"

#. Tag: para
#: menu-commands.docbook:222
#, no-c-format
msgid "Adding numbers to filenames"
msgstr "फ़ाइल नामों में संख्याएँ जोड़ना"

#. Tag: para
#: menu-commands.docbook:225
#, no-c-format
msgid "Finding and replacing parts of the filename"
msgstr "फ़ाइल नाम के कुछ हिस्सों को ढूँढना और बदलना"

#. Tag: para
#: menu-commands.docbook:229
#, no-c-format
msgid "Renaming MP3/OGG Vorbis files based on their ID3 tags"
msgstr "MP3/OGG Vorbis फ़ाइलों का नाम उनके ID3 टैग के आधार पर बदलना"

#. Tag: para
#: menu-commands.docbook:233
#, no-c-format
msgid "Setting access and modification dates"
msgstr "पहुँच और संशोधन तिथियाँ निर्धारित करना"

#. Tag: para
#: menu-commands.docbook:236
#, no-c-format
msgid "Changing permissions and file ownership"
msgstr "अनुमतियाँ और फ़ाइल स्वामित्व बदलना"

#. Tag: para
#: menu-commands.docbook:239
#, no-c-format
msgid "A plugin API which allows you to extend KRename's features"
msgstr "एक प्लगइन API जो आपको KRename की सुविधाओं का विस्तार करने की अनुमति देता है"

#. Tag: para
#: menu-commands.docbook:243
#, no-c-format
msgid "Renaming folders recursively"
msgstr "फ़ोल्डरों का पुनरावर्ती नाम बदलना"

#. Tag: para
#: menu-commands.docbook:246
#, no-c-format
msgid "Support for KFilePlugins"
msgstr "KFilePlugins के लिए समर्थन"

#. Tag: para
#: menu-commands.docbook:249
#, no-c-format
msgid "Undo renaming"
msgstr "नाम बदलना पूर्ववत करें"

#. Tag: para
#: menu-commands.docbook:252
#, no-c-format
msgid "And many more...."
msgstr "और भी कई...."

#. Tag: menuchoice
#: menu-commands.docbook:259
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Create Checksum...</guimenuitem>"
msgstr "<guimenu>फ़ाइल</guimenu> <guimenuitem>चेकसम बनाएं...</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:265
#, no-c-format
msgid ""
"<link linkend=\"checksum\">Checksum creation</link> on file(s) and/or "
"folder(s)."
msgstr ""
"<link linkend=\"checksum\">चेकसम निर्माण</link> फ़ाइल(फ़ाइलों) और/या "
"फ़ोल्डर(फ़ोल्डरों) पर."

#. Tag: menuchoice
#: menu-commands.docbook:272
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Verify Checksum...</guimenuitem>"
msgstr "<guimenu>फ़ाइल</guimenu> <guimenuitem>चेकसम सत्यापित करें...</guimenuitem>"

#. Tag: link
#: menu-commands.docbook:279
#, no-c-format
msgid "Verify Checksum"
msgstr "चेकसम सत्यापित करें"

#. Tag: menuchoice
#: menu-commands.docbook:286
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>P</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Split File...</guimenuitem>"
msgstr ""
"<शॉर्टकट> <कीकॉम्बो एक्शन='सिमुल'>&Ctrl; <keycap>P</keycap></keycombo> </"
"shortcut> <guimenu>फ़ाइल</guimenu> <guimenuitem>स्प्लिट फ़ाइल...</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:296
#, no-c-format
msgid ""
"The <link linkend=\"splitter\">Split file</link> function splits a file up "
"into multiple smaller files so that it can be stored on several smaller "
"media (like <hardware>diskettes, zip-drives, ...</hardware>) or sent by e-"
"mail."
msgstr ""
"<link linkend=\"splitter\">विभाजित फ़ाइल</link> फ़ंक्शन किसी फ़ाइल को कई छोटी "
"फ़ाइलों में विभाजित करता है ताकि उसे कई छोटे मीडिया (जैसे<hardware> डिस्केट, ज़िप-"
"ड्राइव, ...</hardware> ) या ई-मेल द्वारा भेजा जा सकता है।"

#. Tag: menuchoice
#: menu-commands.docbook:305
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>B</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Combine Files...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>B</keycap></keycombo> </"
"shortcut> <guimenu>फ़ाइल</guimenu> <guimenuitem>फ़ाइलें संयोजित करें...</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:315
#, no-c-format
msgid ""
"The <link linkend=\"splitter\">Combine files</link> function combines "
"multiple files into one file after the <link linkend=\"splitter\">Split "
"file</link> function was used."
msgstr ""
"<link linkend=\"splitter\">फ़ाइलें संयोजित करें</link> फ़ंक्शन एकाधिक फ़ाइलों को एक "
"फ़ाइल में संयोजित करता है<link linkend=\"splitter\"> विभाजित फ़ाइल</link> फ़ंक्शन का "
"उपयोग किया गया."

#. Tag: menuchoice
#: menu-commands.docbook:323
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>Q</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Quit</guimenuitem>"
msgstr ""
"<शॉर्टकट> <कीकॉम्बो एक्शन='एक साथ'>&Ctrl; <keycap>Q</keycap></keycombo> </"
"shortcut> <guimenu>फ़ाइल</guimenu> <guimenuitem>छोड़ें</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:333
#, no-c-format
msgid ""
"Closes &krusader; and cleans up the temporary folder, the same as pressing "
"<keycap>F10</keycap> key."
msgstr ""
"&krusader; को बंद करता है और अस्थायी फ़ोल्डर को साफ़ करता है, ठीक वैसे ही जैसे "
"<keycap>F10</keycap> कुंजी को दबाने पर होता है।"

#. Tag: title
#: menu-commands.docbook:341
#, no-c-format
msgid "Edit Menu"
msgstr "संपादन मेनू"

#. Tag: menuchoice
#: menu-commands.docbook:345
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>X</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Cut</guimenuitem>"
msgstr ""
"<शॉर्टकट> <keycombo action=\"simul\">&Ctrl; <keycap>X</keycap></keycombo> </"
"shortcut> <guimenu>संपादित करें</guimenu> <guimenuitem>काटें</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:355
#, no-c-format
msgid ""
"<link linkend=\"copying\">Cuts</link> the selected file(s) to the clipboard "
"to be moved to another location."
msgstr ""
"<link linkend=\"copying\">कटौती</link> चयनित फ़ाइल(फ़ाइलों) को क्लिपबोर्ड पर ले "
"जाएं ताकि उन्हें किसी अन्य स्थान पर ले जाया जा सके।"

#. Tag: menuchoice
#: menu-commands.docbook:362
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>C</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Copy</guimenuitem>"
msgstr ""
"<शॉर्टकट> <keycombo action=\"simul\">&Ctrl; <keycap>C</keycap></keycombo> </"
"shortcut> <guimenu>संपादित करें</guimenu> <guimenuitem>कॉपी करें</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:372
#, no-c-format
msgid ""
"<link linkend=\"copying\">Copies</link> the selected file(s) to the "
"clipboard to be moved to another location."
msgstr ""
"<link linkend=\"copying\">प्रतियां</link> चयनित फ़ाइल(फ़ाइलों) को क्लिपबोर्ड पर ले "
"जाएं ताकि उन्हें किसी अन्य स्थान पर ले जाया जा सके।"

#. Tag: menuchoice
#: menu-commands.docbook:379
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>V</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Paste</guimenuitem>"
msgstr ""
"<शॉर्टकट> <कीकॉम्बो एक्शन='सिमुल'>&Ctrl; <keycap>V</keycap></keycombo> </"
"shortcut> <guimenu>संपादित करें</guimenu> <guimenuitem>पेस्ट करें</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:389
#, no-c-format
msgid ""
"<link linkend=\"copying\">Pastes</link> previously cut or copied items from "
"the clipboard to the current folder."
msgstr ""
"<link linkend=\"copying\">चिपकाता</link> क्लिपबोर्ड से पहले से काटे गए या कॉपी किए "
"गए आइटम को वर्तमान फ़ोल्डर में रखें।"

#. Tag: menuchoice
#: menu-commands.docbook:414
#, no-c-format
msgid ""
"<shortcut> <keycap>F8</keycap> </shortcut> <guimenu>Edit</guimenu> "
"<guimenuitem>Delete</guimenuitem>"
msgstr ""
"<शॉर्टकट> <कीकैप>एफ8</कीकैप> </शॉर्टकट> <गुइमेनू>संपादित करें</गुइमेनू> <गुइमेनुइटम>हटाएं</"
"गुइमेनुइटम>"

#. Tag: para
#: menu-commands.docbook:423
#, no-c-format
msgid ""
"<link linkend=\"deleting\">Deletes</link> the currently selected file(s)."
msgstr "<link linkend=\"deleting\">हटाता</link> वर्तमान में चयनित फ़ाइल(फ़ाइलें)."

#. Tag: menuchoice
#: menu-commands.docbook:430
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>+</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Select Group...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>+</keycap></keycombo> </"
"shortcut> <guimenu>संपादित करें</guimenu> <guimenuitem>समूह का चयन करें...</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:440
#, no-c-format
msgid ""
"Opens a dialog which allows you to select files in the active panel. In the "
"<guilabel>Search for</guilabel> dialog place the main search criteria. Enter "
"a filename, a wildcard ( <literal role=\"extension\">*.o.*</literal>, "
"<literal role=\"extension\">*.c</literal> &etc;) or both - separated by a "
"space. When using <literal>'text'</literal>, the results are the same as "
"<literal>'*text*'</literal>. You can exclude files from the search with "
"'|' (&eg; <literal role=\"extension\">'*.cpp *.h | *.moc.cpp'</literal>). "
"With the <link linkend=\"profiles\">profile handler</link> you can manage "
"your selections for future usage. A double-click on a profile is the same as "
"entering the selection and pressing the <guibutton>OK</guibutton> button. "
"More options for <guilabel>Select Group</guilabel> dialog are explained in "
"the <link linkend=\"krusearcher\">Search dialog</link>, which are basically "
"almost the same dialogs."
msgstr ""
"एक संवाद खोलता है जो आपको सक्रिय पैनल में फ़ाइलों का चयन करने की अनुमति देता है।"
"<guilabel> निम्न को खोजें</guilabel> संवाद में मुख्य खोज मानदंड रखें। फ़ाइल नाम, "
"वाइल्डकार्ड (<literal role=\"extension\"> *.ओ.*</literal> ,<literal role="
"\"extension\"> *।सी</literal> &amp;etc;) या दोनों - एक स्थान से अलग। उपयोग करते "
"समय<literal> &#39;मूलपाठ&#39;</literal> , परिणाम समान हैं<literal> &#39;"
"*मूलपाठ*&#39;</literal> . आप &#39;|&#39; (⪚ .) के साथ फ़ाइलों को खोज से बाहर कर "
"सकते हैं<literal role=\"extension\"> &#39;*.cpp *.h | *.moc.cpp&#39;</"
"literal> )। साथ<link linkend=\"profiles\"> प्रोफ़ाइल हैंडलर</link> आप भविष्य में "
"उपयोग के लिए अपने चयनों का प्रबंधन कर सकते हैं। प्रोफ़ाइल पर डबल-क्लिक करना चयन दर्ज करने "
"और बटन दबाने के समान है<guibutton> ठीक है</guibutton> बटन. अधिक विकल्प<guilabel> "
"समूह का चयन करें</guilabel> संवाद को इस प्रकार समझाया गया है<link linkend="
"\"krusearcher\"> खोज संवाद</link> , जो मूलतः लगभग एक जैसे ही संवाद हैं।"

#. Tag: menuchoice
#: menu-commands.docbook:465
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>-</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Unselect Group...</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>-</keycap></keycombo> </"
"shortcut> <guimenu>संपादित करें</guimenu> <guimenuitem>समूह का चयन रद्द करें...</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:475
#, no-c-format
msgid ""
"The opposite of <guimenuitem>Select Group</guimenuitem>. The files that "
"match the pattern in the active panel will be deselected."
msgstr ""
"<guimenuitem>समूह का चयन करें</guimenuitem> के विपरीत। सक्रिय पैनल में पैटर्न से मेल खाने "
"वाली फ़ाइलों का चयन रद्द कर दिया जाएगा।"

#. Tag: menuchoice
#: menu-commands.docbook:483
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt; <keycap>+</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Select All</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt; <keycap>+</keycap></keycombo> </"
"shortcut> <guimenu>संपादित करें</guimenu> <guimenuitem>सभी का चयन करें</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:493
#, no-c-format
msgid ""
"Selects all files in the active panel. You can also select all folders by "
"activating the <guilabel>Autoselect folders</guilabel> option in the <link "
"linkend=\"konfig-panel\">Konfigurator Panel page</link>."
msgstr ""
"सक्रिय पैनल में सभी फ़ाइलों का चयन करता है। आप सक्रिय करके सभी फ़ोल्डर्स का चयन भी कर "
"सकते हैं<guilabel> फ़ोल्डरों का स्वतः चयन</guilabel> विकल्प में<link linkend=\"konfig-"
"panel\"> कोन्फ़िगरेटर पैनल पृष्ठ</link> ."

#. Tag: menuchoice
#: menu-commands.docbook:501
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt; <keycap>-</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Unselect All</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt; <keycap>-</keycap></keycombo> </"
"shortcut> <guimenu>संपादित करें</guimenu> <guimenuitem>सभी का चयन रद्द करें</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:511
#, no-c-format
msgid "Unselects all the files in the active panel."
msgstr "सक्रिय पैनल में सभी फ़ाइलों का चयन रद्द कर देता है."

#. Tag: menuchoice
#: menu-commands.docbook:516
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt; <keycap>*</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Invert Selection</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt; <keycap>*</keycap></keycombo> </"
"shortcut> <guimenu>संपादित करें</guimenu> <guimenuitem>चयन उलटें</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:526
#, no-c-format
msgid ""
"Inverts the selection status of all the files in the active panel (&ie; "
"selected files will become unselected and deselected files will become "
"selected)."
msgstr ""
"सक्रिय पैनल में सभी फ़ाइलों की चयन स्थिति को उलट देता है (&ie; चयनित फ़ाइलें अचयनित हो "
"जाएंगी और अचयनित फ़ाइलें चयनित हो जाएंगी)।"

#. Tag: menuchoice
#: menu-commands.docbook:534
#, no-c-format
msgid "<guimenu>Edit</guimenu> <guimenuitem>Restore Selection</guimenuitem>"
msgstr ""
"<guimenu>संपादित करें</guimenu> <guimenuitem>चयन पुनर्स्थापित करें</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:540
#, no-c-format
msgid "Restore the selection status of previously unselected items."
msgstr "पहले से अचयनित आइटमों की चयन स्थिति को पुनर्स्थापित करें."

#. Tag: menuchoice
#: menu-commands.docbook:545
#, no-c-format
