#. Tag: title
#: diskusage.docbook:8
#, no-c-format
msgid "<title>Disk Usage</title>"
msgstr "<title>डिस्क उपयोग</title>"

#. Tag: primary
#: diskusage.docbook:10
#, no-c-format
msgid "<primary>Disk Usage</primary>"
msgstr "<प्राथमिक>डिस्क उपयोग</प्राथमिक>"

#. Tag: para
#: diskusage.docbook:12
#, no-c-format
msgid ""
"The Disk Usage is based on the code of &filelight;. The Disk Usage shows you "
"how your disk space is being used by a graphical representation of your file "
"system. The following presentations are possible:"
msgstr ""
"डिस्क उपयोग &filelight; के कोड पर आधारित है। डिस्क उपयोग आपको दिखाता है कि आपके "
"फ़ाइल सिस्टम के ग्राफ़िकल प्रतिनिधित्व द्वारा आपके डिस्क स्थान का उपयोग कैसे किया जा रहा "
"है। निम्नलिखित प्रस्तुतियाँ संभव हैं:"

#. Tag: para
#: diskusage.docbook:18
#, no-c-format
msgid "Line view"
msgstr "लाइन दृश्य"

#. Tag: para
#: diskusage.docbook:21
#, no-c-format
msgid "Detailed view"
msgstr "विस्तृत विवरण"

#. Tag: para
#: diskusage.docbook:24
#, no-c-format
msgid ""
"<application>Filelight</application> view: as a set of concentric segmented-"
"rings"
msgstr ""
"<application>Filelight</application> दृश्य: संकेंद्रित खंडित-वलयों के एक सेट के रूप में"

#. Tag: para
#: diskusage.docbook:28
#, no-c-format
msgid ""
"Choose <menuchoice> <guimenu>Tools</guimenu> <guimenuitem>Disk Usage...</"
"guimenuitem> </menuchoice> or <keycombo action=\"simul\">&Alt;&Shift; "
"<keycap>S</keycap></keycombo> to start this feature in a separate window, or "
"open it inside the <link linkend=\"sidebar\">Sidebar</link>."
msgstr ""
"चुनना<menuchoice><guimenu> औजार</guimenu><guimenuitem> डिस्क उपयोग...</"
"guimenuitem></menuchoice> या<keycombo action=\"simul\"> &amp;Alt;&amp;शिफ्ट;"
"<keycap> एस</keycap></keycombo> इस सुविधा को एक अलग विंडो में शुरू करने के लिए, या "
"इसे अंदर खोलने के लिए<link linkend=\"sidebar\"> साइड बार</link> ."

#. Tag: para
#: diskusage.docbook:38
#, no-c-format
msgid "Disk Usage Keybindings, right click menu."
msgstr "डिस्क उपयोग कीबाइंडिंग, राइट क्लिक मेनू."

#. Tag: para
#: diskusage.docbook:41
#, no-c-format
msgid "<keycap>Del</keycap>: Delete"
msgstr "<keycap>Del</keycap>: हटाएं"

#. Tag: para
#: diskusage.docbook:45
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Ctrl; <keycap>E</keycap></keycombo>: Exclude"
msgstr ""
"<keycombo action=\"simul\">&Ctrl; <keycap>E</keycap></keycombo>: बहिष्कृत करें"

#. Tag: para
#: diskusage.docbook:50
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Shift; <keycap>Arrow Up</keycap></keycombo>: Up "
"one folder"
msgstr ""
"<keycombo action=\"simul\">&Shift; <keycap>ऊपर तीर</keycap></keycombo>: एक "
"फ़ोल्डर ऊपर"

#. Tag: para
#: diskusage.docbook:55
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Ctrl; <keycap>N</keycap></keycombo>: new search"
msgstr ""
"<keycombo action=\"simul\">&Ctrl; <keycap>N</keycap></keycombo>: नई खोज"

#. Tag: para
#: diskusage.docbook:60
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Ctrl; <keycap>R</keycap></keycombo>: refresh"
msgstr ""
"<keycombo action=\"simul\">&Ctrl; <keycap>R</keycap></keycombo>: रिफ्रेश करें"

#. Tag: para
#: diskusage.docbook:65
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Ctrl; <keycap>I</keycap></keycombo>: include all"
msgstr ""
"<keycombo action=\"simul\">&Ctrl; <keycap>I</keycap></keycombo>: सभी को "
"शामिल करें"

#. Tag: para
#: diskusage.docbook:70
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Shift; <keycap>Arrow Down</keycap></keycombo>: "
"step into"
msgstr ""
"<keycombo action=\"simul\">&Shift; <keycap>नीचे तीर</keycap></keycombo>: अंदर "
"कदम रखें"

#. Tag: para
#: diskusage.docbook:75
#, no-c-format
msgid "View menu:"
msgstr "मेनू देखें:"

#. Tag: para
#: diskusage.docbook:78
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Ctrl; <keycap>L</keycap></keycombo>: Line view"
msgstr ""
"<keycombo action=\"simul\">&Ctrl; <keycap>L</keycap></keycombo>: लाइन दृश्य"

#. Tag: para
#: diskusage.docbook:83
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Ctrl; <keycap>D</keycap></keycombo>: Detailed "
"view"
msgstr ""
"<keycombo action=\"simul\">&Ctrl; <keycap>D</keycap></keycombo>: विस्तृत दृश्य"

#. Tag: para
#: diskusage.docbook:88
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Ctrl; <keycap>F</keycap></keycombo>: Filelight "
"view"
msgstr ""
"<keycombo action=\"simul\">&Ctrl; <keycap>F</keycap></keycombo>: फ़ाइललाइट दृश्य"

#. Tag: para
#: diskusage.docbook:93
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Shift; <keycap>Arrow Right</keycap></keycombo>: "
"Next view"
msgstr ""
"<keycombo action=\"simul\">&Shift; <keycap>दायाँ तीर</keycap></keycombo>: "
"अगला दृश्य"

#. Tag: para
#: diskusage.docbook:98
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Shift; <keycap>Arrow Left</keycap></keycombo>: "
"Previous view"
msgstr ""
"<keycombo action=\"simul\">&Shift; <keycap>बायां तीर</keycap></keycombo>: "
"पिछला दृश्य"
