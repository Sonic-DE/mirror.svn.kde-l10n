#~ "mechanism."
#~ msgstr ""
#~ "&watchgnupg; वह प्रक्रिया है जो वास्तव में गतिविधि के लिए लॉगिंग सॉकेट की निगरानी "
#~ "करती है और &kwatchgnupg; टेक्स्ट दृश्य में दिखाई देने वाली पंक्तियों को प्रारूपित करती "
#~ "है। इस समूह में सेटिंग्स को &gpgconf; तंत्र का उपयोग करके बैकएंड तक भेजा जाता है।"

#~ msgid ""
#~ "<guilabel>Executable</guilabel> contains the path to the &watchgnupg; "
#~ "application. If &watchgnupg; is in your <varname>$PATH</varname>, you can "
#~ "keep the default <userinput>watchgnupg</userinput>. If &watchgnupg; is "
#~ "not in your <varname>$PATH</varname>, or if you have more than one "
#~ "version installed, enter the absolute filename of the watchgnupg "
#~ "executable here."
#~ msgstr ""
#~ "<guilabel>Executable</guilabel> में &watchgnupg; एप्लीकेशन का पथ होता है। यदि "
#~ "&watchgnupg; आपके <varname>$PATH</varname> में है, तो आप डिफ़ॉल्ट "
#~ "<userinput>watchgnupg</userinput> रख सकते हैं। यदि &watchgnupg; आपके <varname>"
#~ "$PATH</varname> में नहीं है, या यदि आपके पास एक से अधिक संस्करण इंस्टॉल हैं, तो "
#~ "watchgnupg निष्पादन योग्य का पूर्ण फ़ाइल नाम यहाँ दर्ज करें।"

#~ msgid ""
#~ "<guilabel>Socket</guilabel> contains the socket that &watchgnupg; should "
#~ "listen on. A change here is distributed to all &gnupg; backend modules "
#~ "using &gpgconf;, so you don't need to change this setting if your &gnupg; "
#~ "config files have another <varname>log-file</varname> set."
#~ msgstr ""
#~ "<guilabel>सॉकेट</guilabel> में वह सॉकेट होता है जिस पर &watchgnupg; को सुनना "
#~ "चाहिए। यहाँ किया गया परिवर्तन &gpgconf; का उपयोग करके सभी &gnupg; बैकएंड मॉड्यूल "
#~ "में वितरित किया जाता है, इसलिए यदि आपकी &gnupg; कॉन्फ़िगरेशन फ़ाइलों में कोई अन्य "
#~ "<varname>log-file</varname> सेट है, तो आपको यह सेटिंग बदलने की आवश्यकता नहीं है।"

#~ msgid ""
#~ "<guilabel>Default log level</guilabel> determines the amount of logging "
#~ "information returned by the backend modules. See the &watchgnupg; "
#~ "documentation for what level includes which information. A change here is "
#~ "distributed to all &gnupg; backend modules using &gpgconf;, so you don't "
#~ "need to change this setting if your &gnupg; config files have another "
#~ "<varname>log-level</varname> set."
#~ msgstr ""
#~ "<guilabel>डिफ़ॉल्ट लॉग लेवल</guilabel> बैकएंड मॉड्यूल द्वारा लौटाई गई लॉगिंग "
#~ "जानकारी की मात्रा निर्धारित करता है। किस लेवल में कौन सी जानकारी शामिल है, इसके "
#~ "लिए &watchgnupg; दस्तावेज़ देखें। यहाँ किया गया परिवर्तन &gpgconf; का उपयोग करके "
#~ "सभी &gnupg; बैकएंड मॉड्यूल में वितरित किया जाता है, इसलिए यदि आपकी &gnupg; "
#~ "कॉन्फ़िगरेशन फ़ाइलों में कोई अन्य <varname>log-level</varname> सेट है, तो आपको इस "
#~ "सेटिंग को बदलने की आवश्यकता नहीं है।"
