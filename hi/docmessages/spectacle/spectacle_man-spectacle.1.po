#. Tag: title
#: man-spectacle.1.docbook:35
#, no-c-format
msgid "Description"
msgstr "विवरण"

#. Tag: para
#: man-spectacle.1.docbook:36
#, no-c-format
msgid ""
"<command>spectacle</command> is a simple application for capturing desktop "
"screenshots. It can capture images of the entire desktop, a single monitor, "
"the currently active window, the window currently under the mouse, or a "
"rectangular region of the screen. The images can then be annotated, printed, "
"sent to other applications for manipulation, or quickly be saved as-is."
msgstr ""
"<command>spectacle</command> डेस्कटॉप स्क्रीनशॉट कैप्चर करने के लिए एक सरल एप्लिकेशन "
"है। यह पूरे डेस्कटॉप, एक मॉनिटर, वर्तमान में सक्रिय विंडो, माउस के नीचे वर्तमान में विंडो या "
"स्क्रीन के आयताकार क्षेत्र की छवियों को कैप्चर कर सकता है। फिर छवियों को एनोटेट किया जा "
"सकता है, प्रिंट किया जा सकता है, हेरफेर के लिए अन्य एप्लिकेशन को भेजा जा सकता है, या "
"जल्दी से सहेजा जा सकता है।"

#. Tag: title
#: man-spectacle.1.docbook:40
#, no-c-format
msgid "Spectacle options"
msgstr "तमाशा विकल्प"

#. Tag: option
#: man-spectacle.1.docbook:44
#, no-c-format
msgid "-h, --help"
msgstr "-एच, --सहायता"

#. Tag: para
#: man-spectacle.1.docbook:46
#, no-c-format
msgid "Displays help on commandline options."
msgstr "कमांडलाइन विकल्पों पर सहायता प्रदर्शित करता है."

#. Tag: option
#: man-spectacle.1.docbook:51
#, no-c-format
msgid "--help-all"
msgstr "--सभी की मदद करो"

#. Tag: para
#: man-spectacle.1.docbook:53
#, no-c-format
msgid "Displays help including Qt specific options."
msgstr "Qt विशिष्ट विकल्पों सहित सहायता प्रदर्शित करता है."

#. Tag: option
#: man-spectacle.1.docbook:58
#, no-c-format
msgid "-v, --version"
msgstr "-v, --संस्करण"

#. Tag: para
#: man-spectacle.1.docbook:60
#, no-c-format
msgid "Displays version information."
msgstr "संस्करण जानकारी प्रदर्शित करता है."

#. Tag: option
#: man-spectacle.1.docbook:65
#, no-c-format
msgid "-f, --fullscreen"
msgstr "-f, --फुलस्क्रीन"

#. Tag: para
#: man-spectacle.1.docbook:67
#, no-c-format
msgid "Capture the entire desktop (default)."
msgstr "संपूर्ण डेस्कटॉप कैप्चर करें (डिफ़ॉल्ट)."

#. Tag: option
#: man-spectacle.1.docbook:72
#, no-c-format
msgid "--scaled"
msgstr ""

#. Tag: para
#: man-spectacle.1.docbook:74
#, no-c-format
msgid ""
"When used with <option>-f</option>/<option>--fullscreen</option>, capture "
"all screens scaled to the same size. Has no effect without <option>-f</"
"option>."
msgstr ""

#. Tag: option
#: man-spectacle.1.docbook:79
#, no-c-format
msgid "-m, --current"
msgstr "-एम, --वर्तमान"

#. Tag: para
#: man-spectacle.1.docbook:81
#, no-c-format
msgid "Capture the current monitor."
msgstr "वर्तमान मॉनिटर कैप्चर करें."

#. Tag: option
#: man-spectacle.1.docbook:86
#, no-c-format
msgid "-a, --activewindow"
msgstr "-a, --सक्रियविंडो"

#. Tag: para
#: man-spectacle.1.docbook:88
#, no-c-format
msgid "Capture the active window."
msgstr "सक्रिय विंडो कैप्चर करें."

#. Tag: option
#: man-spectacle.1.docbook:93
#, no-c-format
msgid "-u, --windowundercursor"
msgstr "-u, --विंडोअंडरकर्सर"

#. Tag: para
#: man-spectacle.1.docbook:95
#, no-c-format
msgid ""
"Capture the window currently under the cursor, including parents of pop-up "
"menus."
msgstr "पॉप-अप मेनू के पैरेंट सहित वर्तमान में कर्सर के नीचे स्थित विंडो को कैप्चर करें।"

#. Tag: option
#: man-spectacle.1.docbook:100
#, no-c-format
msgid "-t, --transientonly"
msgstr "-t, --क्षणिककेवल"

#. Tag: para
#: man-spectacle.1.docbook:102
#, no-c-format
msgid ""
"Capture the window currently under the cursor, excluding parents of pop-up "
"menus."
msgstr "पॉप-अप मेनू के पैरेंट को छोड़कर, वर्तमान में कर्सर के नीचे स्थित विंडो को कैप्चर करें।"

#. Tag: option
#: man-spectacle.1.docbook:107
#, no-c-format
msgid "-r, --region"
msgstr "-आर, --क्षेत्र"

#. Tag: para
#: man-spectacle.1.docbook:109
#, no-c-format
msgid "Capture a rectangular region of the screen."
msgstr "स्क्रीन के एक आयताकार क्षेत्र को कैप्चर करें."

#. Tag: option
#: man-spectacle.1.docbook:114
#, no-c-format
msgid "-l, --launchonly"
msgstr "-l, --launchonly"

#. Tag: para
#: man-spectacle.1.docbook:116
#, no-c-format
msgid "Launch Spectacle without taking a screenshot."
msgstr "स्क्रीनशॉट लिए बिना स्पेक्टेकल लॉन्च करें।"

#. Tag: option
#: man-spectacle.1.docbook:121
#, no-c-format
msgid "-g, --gui"
msgstr "-जी, --गुई"

#. Tag: para
#: man-spectacle.1.docbook:123
#, no-c-format
msgid "Start in GUI mode (default)."
msgstr "GUI मोड में प्रारंभ करें (डिफ़ॉल्ट)."

#. Tag: option
#: man-spectacle.1.docbook:128
#, no-c-format
msgid "-b, --background"
msgstr "-बी, --पृष्ठभूमि"

#. Tag: para
#: man-spectacle.1.docbook:130
#, no-c-format
msgid "Take a screenshot and exit without showing the GUI."
msgstr "स्क्रीनशॉट लें और GUI दिखाए बिना बाहर निकलें।"

#. Tag: option
#: man-spectacle.1.docbook:135
#, no-c-format
msgid "-s, --dbus"
msgstr "-एस, --डीबस"

#. Tag: para
#: man-spectacle.1.docbook:137
#, no-c-format
msgid "Start in DBus-Activation mode."
msgstr "DBus-सक्रियण मोड में प्रारंभ करें."

#. Tag: option
#: man-spectacle.1.docbook:142
#, no-c-format
msgid "-n, --nonotify"
msgstr "-एन, --नोनोटिफाई"

#. Tag: para
#: man-spectacle.1.docbook:144
#, no-c-format
msgid ""
"In background mode, do not pop up a notification when the screenshot is "
"taken."
msgstr "बैकग्राउंड मोड में, स्क्रीनशॉट लेते समय कोई नोटिफिकेशन पॉप-अप न करें।"

#. Tag: option
#: man-spectacle.1.docbook:149
#, no-c-format
msgid "-o, --output <replaceable>fileName</replaceable>"
msgstr "-o, --output <प्रतिस्थापन योग्य>फ़ाइलनाम</प्रतिस्थापन योग्य>"

#. Tag: para
#: man-spectacle.1.docbook:151
#, no-c-format
msgid ""
"In background mode, save image to specified file <replaceable>fileName</"
"replaceable>."
msgstr ""
"पृष्ठभूमि मोड में, छवि को निर्दिष्ट फ़ाइल <replaceable>fileName</replaceable> में सहेजें।"

#. Tag: option
#: man-spectacle.1.docbook:156
#, no-c-format
msgid "-d, --delay <replaceable>delayMsec</replaceable>"
msgstr "-d, --delay <प्रतिस्थापन योग्य>delayMsec</प्रतिस्थापन योग्य>"

#. Tag: para
#: man-spectacle.1.docbook:158
#, no-c-format
msgid "In background mode, delay before taking the shot (in milliseconds)."
msgstr "पृष्ठभूमि मोड में, शॉट लेने से पहले विलंब (मिलीसेकंड में)।"

#. Tag: option
#: man-spectacle.1.docbook:163
#, no-c-format
msgid "-c, --copy-image"
msgstr "-सी, --कॉपी-छवि"

#. Tag: para
#: man-spectacle.1.docbook:165
#, no-c-format
msgid ""
"In background mode, copy screenshot only to clipboard, unless -o is also "
"used."
msgstr ""
"पृष्ठभूमि मोड में, स्क्रीनशॉट को केवल क्लिपबोर्ड पर कॉपी करें, जब तक कि -o का भी उपयोग न "
"किया जाए।"

#. Tag: option
#: man-spectacle.1.docbook:170
#, no-c-format
msgid "-C, --copy-path"
msgstr "-सी, --कॉपी-पथ"

#. Tag: para
#: man-spectacle.1.docbook:172
#, no-c-format
msgid "In background mode, copy screenshot file path to clipboard."
msgstr "पृष्ठभूमि मोड में, स्क्रीनशॉट फ़ाइल पथ को क्लिपबोर्ड पर कॉपी करें।"

#. Tag: option
#: man-spectacle.1.docbook:177
#, no-c-format
msgid "-w, --onclick"
msgstr "-w, --ऑनक्लिक"

#. Tag: para
#: man-spectacle.1.docbook:179
#, no-c-format
msgid "Wait for a click before taking screenshot. Invalidates delay.."
msgstr "स्क्रीनशॉट लेने से पहले क्लिक का इंतज़ार करें। देरी अमान्य है.."

#. Tag: option
#: man-spectacle.1.docbook:184
#, no-c-format
msgid "-i, --new-instance"
msgstr "-i, --नया-इंस्टेंस"

#. Tag: para
#: man-spectacle.1.docbook:186
#, no-c-format
msgid "Starts a new GUI instance of spectacle without registering to DBus."
msgstr "DBus में पंजीकरण किए बिना स्पेक्टेकल का एक नया GUI उदाहरण प्रारंभ करता है।"

#. Tag: option
#: man-spectacle.1.docbook:191
#, no-c-format
msgid "-p, --pointer"
msgstr "-पी, --पॉइंटर"

#. Tag: para
#: man-spectacle.1.docbook:193
#, no-c-format
msgid "In background mode, include pointer in the screenshot."
msgstr "पृष्ठभूमि मोड में, स्क्रीनशॉट में पॉइंटर शामिल करें।"

#. Tag: option
#: man-spectacle.1.docbook:198
#, no-c-format
msgid "-e, --no-decoration"
msgstr "-ई, --कोई-सजावट नहीं"

#. Tag: para
#: man-spectacle.1.docbook:200
#, no-c-format
msgid ""
"In background mode, do not include window decorations in the screenshot."
msgstr "पृष्ठभूमि मोड में, स्क्रीनशॉट में विंडो सजावट शामिल न करें।"

#. Tag: option
#: man-spectacle.1.docbook:205
#, no-c-format
msgid "-E, --edit-existing <replaceable>existingFileName</replaceable>"
msgstr "-E, --edit-मौजूदा <प्रतिस्थापन योग्य>मौजूदाफ़ाइलनाम</प्रतिस्थापन योग्य>"

#. Tag: para
#: man-spectacle.1.docbook:207
#, no-c-format
msgid "Open and edit existing screenshot file."
msgstr "मौजूदा स्क्रीनशॉट फ़ाइल खोलें और संपादित करें."

#. Tag: title
#: man-spectacle.1.docbook:213
#, no-c-format
msgid "Feedback"
msgstr "प्रतिक्रिया"

#. Tag: para
#: man-spectacle.1.docbook:214
#, no-c-format
