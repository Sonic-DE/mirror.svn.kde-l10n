#: man-kpat.6.docbook:112
#, no-c-format
msgid "--generate"
msgstr "--उत्पन्न"

#. Tag: para
#: man-kpat.6.docbook:113
#, no-c-format
msgid "Generate random test cases"
msgstr "यादृच्छिक परीक्षण मामले उत्पन्न करें"

#. Tag: option
