msgstr "एक अत्यधिक व्यसनकारी कार्ड गेम"

#. Tag: cmdsynopsis
#: man-kpat.6.docbook:25
#, no-c-format
msgid ""
"<command>kpat</command> <group choice=\"opt\"><option>--solvegame</option> "
"<replaceable> file</replaceable></group> <group choice=\"opt\"><option>--"
"solve</option> <replaceable> num</replaceable></group> <group choice=\"opt"
"\"><option>--start</option> <replaceable> num</replaceable></group> <group "
"choice=\"opt\"><option>--end</option> <replaceable> num</replaceable></"
"group> <group choice=\"opt\"><option>--gametype</option> <replaceable> game</"
"replaceable></group> <group choice=\"opt\"><option>--testdir</option> "
"<replaceable> directory</replaceable></group> <group choice=\"opt"
"\"><option>--generate</option></group> <group choice=\"opt"
"\"><option><replaceable>file</replaceable></option></group>"
msgstr ""
"<command>केपीएटी</command><group choice=\"opt\"><option value=--solvegame> --"
"सॉल्वगेम</option><replaceable> फ़ाइल</replaceable></group><group choice=\"opt"
"\"><option value=--solve> --हल करना</option><replaceable> संख्या</"
"replaceable></group><group choice=\"opt\"><option value=--start> --शुरू</"
"option><replaceable> संख्या</replaceable></group><group choice=\"opt\"><option "
"value=--end> --अंत</option><replaceable> संख्या</replaceable></group><group "
"choice=\"opt\"><option value=--gametype> --गेम का प्रकार</option><replaceable> "
"खेल</replaceable></group><group choice=\"opt\"><option value=--testdir> --"
"टेस्टडायर</option><replaceable> निर्देशिका</replaceable></group><group choice="
"\"opt\"><option value=--generate> --उत्पन्न</option></group><group choice=\"opt"
"\"><option><replaceable> फ़ाइल</replaceable></option></group>"

#. Tag: title
#: man-kpat.6.docbook:39
#, no-c-format
msgid "DESCRIPTION"
msgstr "विवरण"

#. Tag: para
#: man-kpat.6.docbook:40
#, no-c-format
msgid ""
"&kpatience; is a compendium of several well known patience card games, "
"ranging from the well known Klondike and Freecell, to lesser known games "
"such as Grandfather's Clock and Mod3. In all there are 12 variations for you "
"to while away time."
msgstr ""
"&kpatience; कई प्रसिद्ध धैर्य कार्ड गेम का एक संग्रह है, जिसमें प्रसिद्ध क्लोंडाइक और फ़्रीसेल "
"से लेकर ग्रैंडफ़ादर क्लॉक और मॉड3 जैसे कम प्रसिद्ध गेम शामिल हैं। कुल मिलाकर आपके लिए समय "
"बिताने के लिए 12 विविधताएँ हैं।"

#. Tag: title
#: man-kpat.6.docbook:48
#, no-c-format
msgid "OPTIONS"
msgstr "विकल्प"

#. Tag: para
#: man-kpat.6.docbook:49
#, no-c-format
msgid ""
"This program follows the usual GNU command line syntax, with long options "
"starting with two dashes (`--'). A summary of the options supported by "
"<command>kpat</command> is included below."
msgstr ""
"यह प्रोग्राम सामान्य GNU कमांड लाइन सिंटैक्स का अनुसरण करता है, जिसमें लंबे विकल्प दो डैश "
"(`--') से शुरू होते हैं। <command>kpat</command> द्वारा समर्थित विकल्पों का सारांश नीचे "
"दिया गया है।"

#. Tag: term
#: man-kpat.6.docbook:58
#, no-c-format
msgid "<option>-h</option> <option>--help</option>"
msgstr "<option value=-h>-एच</option><option value=--help> --मदद</option>"

#. Tag: para
#: man-kpat.6.docbook:59
#, no-c-format
msgid "This lists the options available at the command line"
msgstr "यह कमांड लाइन पर उपलब्ध विकल्पों की सूची देता है"

#. Tag: term
#: man-kpat.6.docbook:64
#, no-c-format
msgid "<option>-v</option> <option>--version</option>"
msgstr "<option value=-v>-v</option><option value=--version> --संस्करण</option>"

#. Tag: para
#: man-kpat.6.docbook:66
#, no-c-format
msgid "Lists version information for &kpatience;"
msgstr "&kpatience; के लिए संस्करण जानकारी सूचीबद्ध करता है"

#. Tag: term
#: man-kpat.6.docbook:70
#, no-c-format
msgid "<option>--solvegame</option> <replaceable> file</replaceable>"
msgstr ""
"<option value=--solvegame>--खेल को हल करें</option><replaceable> फ़ाइल</"
"replaceable>"

#. Tag: para
#: man-kpat.6.docbook:72
#, no-c-format
msgid "Try to find a solution to the given savegame"
msgstr "दिए गए सेवगेम का समाधान ढूंढने का प्रयास करें"

#. Tag: term
#: man-kpat.6.docbook:77
#, no-c-format
msgid "<option>--solve</option> <replaceable> num</replaceable>"
msgstr ""
"<option value=--solve>--हल करना</option><replaceable> चाहे</replaceable>"

#. Tag: para
#: man-kpat.6.docbook:79
#, no-c-format
msgid "Dealer to solve (debug)"
msgstr "डीलर को हल करना है (डीबग)"

#. Tag: term
#: man-kpat.6.docbook:84
#, no-c-format
msgid "<option>--start</option> <replaceable> num</replaceable>"
msgstr "<option value=--start>--शुरू</option><replaceable> संख्या</replaceable>"

#. Tag: para
#: man-kpat.6.docbook:86
#, no-c-format
msgid "Game range start (default 0:INT_MAX)"
msgstr "गेम रेंज प्रारंभ (डिफ़ॉल्ट 0:INT_MAX)"

#. Tag: term
#: man-kpat.6.docbook:91
#, no-c-format
msgid "<option>--end</option> <replaceable> num</replaceable>"
msgstr "<option value=--end>--अंत</option><replaceable> संख्या</replaceable>"

#. Tag: para
#: man-kpat.6.docbook:93
#, no-c-format
msgid "Game range end (default start:start if start given)"
msgstr "खेल सीमा समाप्त (डिफ़ॉल्ट प्रारंभ: प्रारंभ यदि प्रारंभ दिया गया है)"

#. Tag: term
#: man-kpat.6.docbook:98
#, no-c-format
msgid "<option>--gametype</option> <replaceable> game</replaceable>"
msgstr ""
"<option value=--gametype>--गेम का प्रकार</option><replaceable> खेल</replaceable>"

#. Tag: para
#: man-kpat.6.docbook:100
#, fuzzy, no-c-format
#| msgid ""
#| "Skip the selection screen and load a particular game type. Valid values "
#| "are: acesup, fortyeight, freecell, golf, grandfather, grandfathersclock, "
#| "gypsy, klondike, mod3, simplesimon, spider, yukon"
msgid ""
"Skip the selection screen and load a particular game type. Valid values are: "
"acesup, fortyeight, freecell, golf, grandfather, grandfathersclock, "
"normandy, klondike, mod3, simplesimon, spider, yukon"
msgstr ""
"चयन स्क्रीन को छोड़ें और एक विशेष गेम प्रकार लोड करें। मान्य मान हैं: acesup, fortyeight, "
"freecell, golf, grandfather, grandfathersclock, gypsy, klondike, mod3, "
"simplesimon, spider, yukon"

#. Tag: term
#: man-kpat.6.docbook:105
#, no-c-format
msgid "<option>--testdir</option> <replaceable> directory</replaceable>"
msgstr ""
"<option value=--testdir>--टेस्टडायर</option><replaceable> निर्देशिका</"
"replaceable>"

#. Tag: para
#: man-kpat.6.docbook:107
#, no-c-format
msgid "Directory with test cases"
