"Common commandline options for all applications based on the &Qt; toolkit"
msgstr "&Qt; टूलकिट पर आधारित सभी अनुप्रयोगों के लिए सामान्य कमांडलाइन विकल्प"

#. Tag: cmdsynopsis
#: man-qt6options.7.docbook:27
#, no-c-format
msgid ""
"<command><replaceable>Qt application</replaceable></command> <arg choice="
"\"opt\"><option>-style=</option> <replaceable>style</replaceable> / <option>-"
"style</option> <replaceable>style</replaceable></arg> <arg choice=\"opt"
"\"><option>-stylesheet=</option> <replaceable>stylesheet</replaceable> / "
"<option>-stylesheet</option> <replaceable>stylesheet</replaceable></arg> "
"<arg choice=\"opt\"><option>-widgetcount</option></arg> <arg choice=\"opt"
"\"><option>-reverse</option></arg> <arg choice=\"opt\"><option>-"
"qmljsdebugger=</option> <replaceable>port</replaceable></arg> <arg choice="
"\"opt\"><option>-platform</option> <replaceable>platformName[:options]</"
"replaceable></arg> <arg choice=\"opt\"><option>-platformpluginpath</option> "
"<replaceable>path</replaceable></arg> <arg choice=\"opt\"><option>-"
"platformtheme</option> <replaceable>platformTheme</replaceable></arg> <arg "
"choice=\"opt\"><option>-plugin</option> <replaceable>plugin</replaceable></"
"arg> <arg choice=\"opt\"><option>-qwindowgeometry</option> "
"<replaceable>geometry</replaceable></arg> <arg choice=\"opt\"><option>-"
"qwindowicon</option> <replaceable>icon</replaceable></arg> <arg choice=\"opt"
"\"><option>-qwindowtitle</option> <replaceable>title</replaceable></arg> "
"<arg choice=\"opt\"><option>-reverse</option></arg> <arg choice=\"opt"
"\"><option>-session</option> <replaceable>session</replaceable></arg> <arg "
"choice=\"opt\"><option>-display</option> <replaceable>hostname:"
"screen_number</replaceable></arg> <arg choice=\"opt\"><option>-geometry</"
"option> <replaceable>geometry</replaceable></arg> <arg choice=\"opt"
"\"><option>-dialogs=</option> <replaceable>[xp|none]</replaceable></arg> "
"<arg choice=\"opt\"><option>-fontengine=</option> <replaceable>freetype</"
"replaceable></arg> <arg choice=\"opt\"><option>-h, --help and -? on &Windows;"
"</option></arg> <arg choice=\"opt\"><option>-v --version</option></arg>"
msgstr ""
"<command><replaceable>क्यूटी अनुप्रयोग</replaceable></command><arg choice=\"opt"
"\"><option value=-style=> -शैली=</option><replaceable> शैली</replaceable> /"
"<option value=-style> -शैली</option><replaceable> शैली</replaceable></arg><arg "
"choice=\"opt\"><option value=-stylesheet=> -स्टाइलशीट=</option><replaceable> "
"शैली पत्रक</replaceable> /<option value=-stylesheet> -शैली पत्रक</"
"option><replaceable> शैली पत्रक</replaceable></arg><arg choice=\"opt\"><option "
"value=-widgetcount> -विजेटकाउंट</option></arg><arg choice=\"opt\"><option "
"value=-reverse> -रिवर्स</option></arg><arg choice=\"opt\"><option value=-"
"qmljsdebugger=> -qmljsडिबगर=</option><replaceable> पत्तन</replaceable></"
"arg><arg choice=\"opt\"><option value=-platform> -प्लैटफ़ॉर्म</"
"option><replaceable> प्लेटफ़ॉर्मनाम[:विकल्प]</replaceable></arg><arg choice=\"opt"
"\"><option value=-platformpluginpath> -प्लेटफॉर्मप्लगइनपथ</option><replaceable> "
"पथ</replaceable></arg><arg choice=\"opt\"><option value=-platformtheme> -"
"प्लेटफॉर्मथीम</option><replaceable> प्लेटफ़ॉर्म थीम</replaceable></arg><arg choice="
"\"opt\"><option value=-plugin> -लगाना</option><replaceable> लगाना</"
"replaceable></arg><arg choice=\"opt\"><option value=-qwindowgeometry> -"
"qwindowgeometry</option><replaceable> ज्यामिति</replaceable></arg><arg choice="
"\"opt\"><option value=-qwindowicon> -qwindowicon</option><replaceable> आइकन</"
"replaceable></arg><arg choice=\"opt\"><option value=-qwindowtitle> -"
"qwindowtitle</option><replaceable> शीर्षक</replaceable></arg><arg choice=\"opt"
"\"><option value=-reverse> -रिवर्स</option></arg><arg choice=\"opt\"><option "
"value=-session> -सत्र</option><replaceable> सत्र</replaceable></arg><arg "
"choice=\"opt\"><option value=-display> -प्रदर्शन</option><replaceable> "
"होस्टनाम: स्क्रीन_नंबर</replaceable></arg><arg choice=\"opt\"><option value=-"
"geometry> -ज्यामिति</option><replaceable> ज्यामिति</replaceable></arg><arg "
"choice=\"opt\"><option value=-dialogs=> -संवाद=</option><replaceable> [xp|कोई "
"नहीं]</replaceable></arg><arg choice=\"opt\"><option value=-fontengine=> -"
"फॉन्टइंजिन=</option><replaceable> फ्रीटाइप</replaceable></arg><arg choice=\"opt"
"\"><option value=\"-h, --help and -? on &amp;Windows;\"> &amp;Windows; पर -"
"h, --help और -?</option></arg><arg choice=\"opt\"><option value=\"-v --"
"version\"> -v --संस्करण</option></arg>"

#. Tag: title
#: man-qt6options.7.docbook:57
#, no-c-format
msgid "Options"
msgstr "विकल्प"

#. Tag: para
#: man-qt6options.7.docbook:59
#, no-c-format
msgid "The following options apply to all &Qt; applications:"
msgstr "निम्नलिखित विकल्प सभी &Qt; अनुप्रयोगों पर लागू होते हैं:"

#. Tag: term
#: man-qt6options.7.docbook:64
#, no-c-format
msgid ""
"<option>-style=</option> <replaceable>style</replaceable> / <option>-style</"
"option> <replaceable>style</replaceable>"
msgstr ""
"<option value=-style=>-शैली=</option><replaceable> शैली</replaceable> /<option "
"value=-style> -शैली</option><replaceable> शैली</replaceable>"

#. Tag: para
#: man-qt6options.7.docbook:67
#, no-c-format
msgid ""
"Set the application &GUI; style. Possible values depend on the system "
"configuration. If &Qt; is compiled with additional styles or has additional "
"styles as plugins these will be available to the <option>-style</option> "
"command line option."
msgstr ""
"एप्लिकेशन &amp;GUI; स्टाइल सेट करें। संभावित मान सिस्टम कॉन्फ़िगरेशन पर निर्भर करते हैं। "
"यदि &amp;Qt; को अतिरिक्त शैलियों के साथ संकलित किया गया है या प्लगइन के रूप में अतिरिक्त "
"शैलियाँ हैं तो ये उपलब्ध होंगी<option value=-style> -शैली</option> कमांड लाइन विकल्प."

#. Tag: term
#: man-qt6options.7.docbook:74
#, no-c-format
msgid ""
"<option>-stylesheet=</option> <replaceable>stylesheet</replaceable> / "
"<option>-stylesheet</option> <replaceable>stylesheet</replaceable>"
msgstr ""
"<option value=-stylesheet=>-स्टाइलशीट=</option><replaceable> शैली पत्रक</"
"replaceable> /<option value=-stylesheet> -शैली पत्रक</option><replaceable> शैली "
"पत्रक</replaceable>"

#. Tag: para
#: man-qt6options.7.docbook:77
#, no-c-format
msgid ""
"Set the application styleSheet. The value must be a path to a file that "
"contains the Style Sheet."
msgstr "एप्लिकेशन स्टाइलशीट सेट करें। मान स्टाइलशीट वाली फ़ाइल का पथ होना चाहिए।"

#. Tag: option
#: man-qt6options.7.docbook:84
#, no-c-format
msgid "-widgetcount"
msgstr "-विजेटकाउंट"

#. Tag: para
#: man-qt6options.7.docbook:86
#, no-c-format
msgid ""
"Print debug message at the end about number of widgets left undestroyed and "
"maximum number of widgets existed at the same time."
msgstr ""
"अंत में नष्ट न किए गए विजेट्स की संख्या तथा एक ही समय में मौजूद अधिकतम विजेट्स की संख्या के "
"बारे में डिबग संदेश प्रिंट करें।"

#. Tag: option
#: man-qt6options.7.docbook:93
#, no-c-format
msgid "-reverse"
msgstr "-रिवर्स"

#. Tag: para
#: man-qt6options.7.docbook:95
#, no-c-format
msgid ""
"Set the application's layout direction to <methodname>Qt::RightToLeft</"
"methodname>. This option is intended to aid debugging and should not be used "
"in production. The default value is automatically detected from the user's "
"locale (see also <methodname>QLocale::textDirection()</methodname>)."
msgstr ""
"एप्लिकेशन के लेआउट दिशा को <methodname>Qt::RightToLeft</methodname> पर सेट करें। यह "
"विकल्प डीबगिंग में सहायता के लिए है और इसका उपयोग उत्पादन में नहीं किया जाना चाहिए। "
"डिफ़ॉल्ट मान उपयोगकर्ता के लोकेल से स्वचालित रूप से पता लगाया जाता है "
"(<methodname>QLocale::textDirection()</methodname> भी देखें)।"

#. Tag: term
#: man-qt6options.7.docbook:104
#, no-c-format
msgid "<option>-qmljsdebugger=</option> <replaceable>port</replaceable>"
msgstr ""
"<option value=-qmljsdebugger=>-qmljsडिबगर=</option><replaceable> पत्तन</"
"replaceable>"

#. Tag: para
#: man-qt6options.7.docbook:107
#, no-c-format
msgid ""
"Activate the QML/JS debugger with a specified port. The value must be of "
"format port:1234[,block], where block is optional and will make the "
"application wait until a debugger connects to it."
msgstr ""
"QML/JS डीबगर को निर्दिष्ट पोर्ट के साथ सक्रिय करें। मान पोर्ट:1234[,ब्लॉक] प्रारूप का "
"होना चाहिए, जहां ब्लॉक वैकल्पिक है और यह तब तक एप्लिकेशन को प्रतीक्षा कराएगा जब तक कि "
"कोई डीबगर उससे कनेक्ट न हो जाए।"

#. Tag: term
#: man-qt6options.7.docbook:114
#, no-c-format
msgid ""
"<option>-platform</option> <replaceable>platformName[:options]</replaceable>"
msgstr ""
"<option value=-platform>-प्लैटफ़ॉर्म</option><replaceable> प्लेटफ़ॉर्मनाम[:विकल्प]</"
"replaceable>"

#. Tag: para
#: man-qt6options.7.docbook:117
#, no-c-format
msgid "Specify the &Qt; Platform Abstraction (QPA) plugin."
msgstr "&Qt; प्लेटफ़ॉर्म एब्स्ट्रैक्शन (QPA) प्लगइन निर्दिष्ट करें."

#. Tag: term
#: man-qt6options.7.docbook:123
#, no-c-format
msgid "<option>-platformpluginpath</option> <replaceable>path</replaceable>"
msgstr ""
"<option value=-platformpluginpath>-प्लेटफॉर्मप्लगइनपथ</option><replaceable> पथ</"
"replaceable>"

#. Tag: para
#: man-qt6options.7.docbook:126
#, no-c-format
msgid "Specify the path to platform plugins."
msgstr "प्लेटफ़ॉर्म प्लगइन्स का पथ निर्दिष्ट करें."

#. Tag: term
#: man-qt6options.7.docbook:132
#, no-c-format
msgid ""
"<option>-platformtheme</option> <replaceable>platformTheme</replaceable>"
msgstr ""
"<option value=-platformtheme>-प्लेटफॉर्मथीम</option><replaceable> प्लेटफ़ॉर्म थीम</"
"replaceable>"

#. Tag: para
#: man-qt6options.7.docbook:135
#, no-c-format
msgid "Specify the platform theme."
msgstr "प्लेटफ़ॉर्म थीम निर्दिष्ट करें."

#. Tag: term
#: man-qt6options.7.docbook:141
#, no-c-format
msgid "<option>-plugin</option> <replaceable>plugin</replaceable>"
msgstr "<option value=-plugin>-लगाना</option><replaceable> लगाना</replaceable>"

#. Tag: para
#: man-qt6options.7.docbook:144
#, no-c-format
msgid ""
"Specify additional plugins to load. The argument may appear multiple times."
msgstr "लोड करने के लिए अतिरिक्त प्लगइन्स निर्दिष्ट करें। तर्क कई बार प्रकट हो सकता है।"

#. Tag: term
#: man-qt6options.7.docbook:150
#, no-c-format
msgid "<option>-qwindowgeometry</option> <replaceable>geometry</replaceable>"
msgstr ""
"<option value=-qwindowgeometry>-qwindowgeometry</option><replaceable> "
"ज्यामिति</replaceable>"

#. Tag: para
#: man-qt6options.7.docbook:153
#, no-c-format
msgid ""
"Specify the window geometry for the main window using the &X11;-syntax. For "
"example: -qwindowgeometry 100x100+50+50"
msgstr ""
"&X11;-सिंटैक्स का उपयोग करके मुख्य विंडो के लिए विंडो ज्यामिति निर्दिष्ट करें। उदाहरण के "
"लिए: -qwindowgeometry 100x100+50+50"

#. Tag: term
#: man-qt6options.7.docbook:159
#, no-c-format
msgid "<option>-qwindowicon</option> <replaceable>icon</replaceable>"
msgstr ""
"<option value=-qwindowicon>-qwindowicon</option><replaceable> आइकन</"
"replaceable>"

#. Tag: para
#: man-qt6options.7.docbook:162
#, no-c-format
msgid "Set the default window icon."
msgstr "डिफ़ॉल्ट विंडो आइकन सेट करें."

#. Tag: term
#: man-qt6options.7.docbook:168
#, no-c-format
msgid "<option>-qwindowtitle</option> <replaceable>title</replaceable>"
msgstr ""
"<option value=-qwindowtitle>-qwindowtitle</option><replaceable> शीर्षक</"
"replaceable>"

#. Tag: para
#: man-qt6options.7.docbook:171
#, no-c-format
msgid "Set the title of the first window."
msgstr "प्रथम विंडो का शीर्षक सेट करें."

#. Tag: term
#: man-qt6options.7.docbook:177
#, no-c-format
msgid "<option>-session</option> <replaceable>session</replaceable>"
msgstr "<option value=-session>-सत्र</option><replaceable> सत्र</replaceable>"

#. Tag: para
#: man-qt6options.7.docbook:180
#, no-c-format
msgid "Restore the application from an earlier session."
msgstr "अनुप्रयोग को पहले सत्र से पुनर्स्थापित करें."

#. Tag: term
#: man-qt6options.7.docbook:186
#, no-c-format
msgid ""
"<option>-display</option> <replaceable>hostname:screen_number</replaceable>"
msgstr ""
"<option value=-display>-प्रदर्शन</option><replaceable> होस्टनाम: स्क्रीन_नंबर</"
"replaceable>"

#. Tag: para
#: man-qt6options.7.docbook:189
#, no-c-format
msgid ""
"Switch displays on &X11;. Overrides the <envar>DISPLAY</envar> environment "
"variable."
msgstr ""
"स्विच &X11; पर प्रदर्शित होता है। <envar>DISPLAY</envar> पर्यावरण चर को ओवरराइड "
"करता है।"

#. Tag: term
#: man-qt6options.7.docbook:195
#, no-c-format
msgid "<option>-geometry</option> <replaceable>geometry</replaceable>"
msgstr ""
"<option value=-geometry>-ज्यामिति</option><replaceable> ज्यामिति</replaceable>"

#. Tag: para
#: man-qt6options.7.docbook:198
#, no-c-format
msgid ""
"Specify the window geometry for the main window on &X11;. For example: -"
"geometry 100x100+50+50"
msgstr ""
"&X11; पर मुख्य विंडो के लिए विंडो ज्यामिति निर्दिष्ट करें। उदाहरण के लिए: -geometry "
"100x100+50+50"

#. Tag: term
#: man-qt6options.7.docbook:204
#, no-c-format
msgid "<option>-dialogs=</option> <replaceable>[xp|none]</replaceable>"
msgstr ""
"<option value=-dialogs=>-संवाद=</option><replaceable> [xp|कोई नहीं]</"
"replaceable>"

#. Tag: para
#: man-qt6options.7.docbook:207
#, no-c-format
msgid ""
"Only available for the &Windows; platform. XP uses native style dialogs and "
"none disables them."
msgstr ""
"केवल &Windows; प्लेटफ़ॉर्म के लिए उपलब्ध है। XP मूल शैली संवाद का उपयोग करता है और कोई "
"भी उन्हें अक्षम नहीं करता है।"

#. Tag: term
#: man-qt6options.7.docbook:213
#, no-c-format
msgid "<option>-fontengine=</option> <replaceable>freetype</replaceable>"
msgstr ""
"<option value=-fontengine=>-फॉन्टइंजिन=</option><replaceable> फ्रीटाइप</"
"replaceable>"

#. Tag: para
#: man-qt6options.7.docbook:216
#, no-c-format
msgid "Use the FreeType font engine."
msgstr "फ्रीटाइप फ़ॉन्ट इंजन का उपयोग करें."

#. Tag: option
#: man-qt6options.7.docbook:224
#, no-c-format
msgid "-h, --help and -? on &Windows;"
msgstr "&Windows; पर -h, --help और -?"

#. Tag: para
#: man-qt6options.7.docbook:226
#, no-c-format
msgid "Print all options and the application description."
msgstr "सभी विकल्प और आवेदन विवरण प्रिंट करें।"

#. Tag: option
#: man-qt6options.7.docbook:233
#, no-c-format
msgid "-v --version"
msgstr "-v --संस्करण"

#. Tag: para
#: man-qt6options.7.docbook:235
#, no-c-format
msgid "Display the version string of the application."
msgstr "अनुप्रयोग का संस्करण स्ट्रिंग प्रदर्शित करें."

#. Tag: title
#: man-qt6options.7.docbook:246
#, no-c-format
msgid "See Also"
msgstr "यह भी देखें"

#. Tag: para
#: man-qt6options.7.docbook:247
#, no-c-format
msgid "<replaceable>kf6options</replaceable>(7)"
msgstr "<प्रतिस्थापन योग्य>kf6options</प्रतिस्थापन योग्य>(7)"

#. Tag: title
#: man-qt6options.7.docbook:252
#, no-c-format
msgid "Authors"
msgstr "लेखक"

#. Tag: para
#: man-qt6options.7.docbook:253
#, no-c-format
msgid "Man page originally written by &Lauri.Watts; &Lauri.Watts.mail;"
msgstr "मैन पेज मूल रूप से &Lauri.Watts; &Lauri.Watts.mail; द्वारा लिखा गया है"

#. Tag: para
#: man-qt6options.7.docbook:254
#, no-c-format
msgid "Updated to &frameworks; 5 by &Burkhard.Lueck; &Burkhard.Lueck.mail;"
msgstr ""
"&Burkhard.Lueck; &Burkhard.Lueck.mail; द्वारा &frameworks; 5 में अद्यतन किया गया"

#. Tag: para
#: man-qt6options.7.docbook:255
#, no-c-format
msgid ""
"The infos for this man page are from <ulink url=\"https://doc.qt.io/qt-6/"
"qapplication.html#QApplication\">QApplication documentation</ulink>, <ulink "
