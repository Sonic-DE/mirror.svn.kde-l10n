msgstr "&Lauri.Watts; &Lauri.Watts.मेल;"

#. Tag: date
#: man-kf6options.7.docbook:10
#, no-c-format
msgid "2016-05-13"
msgstr "2016-05-13"

#. Tag: releaseinfo
#: man-kf6options.7.docbook:11
#, no-c-format
msgid "Frameworks 6.0"
msgstr "फ्रेमवर्क 6.0"

#. Tag: productname
#: man-kf6options.7.docbook:12
#, no-c-format
msgid "KDE Frameworks"
msgstr "केडीई फ्रेमवर्क"

#. Tag: refentrytitle
#: man-kf6options.7.docbook:16
#, no-c-format
msgid "<refentrytitle>kf6options</refentrytitle>"
msgstr "<refentrytitle>kf6options</refentrytitle>"

#. Tag: manvolnum
#: man-kf6options.7.docbook:17
#, no-c-format
msgid "<manvolnum>7</manvolnum>"
msgstr "<manvolnum>7</manvolnum>"

#. Tag: refname
#: man-kf6options.7.docbook:21
#, no-c-format
msgid "<refname>kf6options</refname>"
msgstr "<refname>kf6options</refname>"

#. Tag: refpurpose
#: man-kf6options.7.docbook:22
#, no-c-format
msgid "Common commandline options for all applications based on &kf6-full;"
msgstr "&kf6-full; पर आधारित सभी अनुप्रयोगों के लिए सामान्य कमांडलाइन विकल्प"

#. Tag: cmdsynopsis
#: man-kf6options.7.docbook:26
#, no-c-format
msgid ""
"<command><replaceable>KDE application</replaceable></command> <arg choice="
"\"opt\"><option>-h, --help</option></arg> <arg choice=\"opt\"><option>-v, --"
"version</option></arg> <arg choice=\"opt\"><option>--author</option></arg> "
"<arg choice=\"opt\"><option>--license</option></arg> <arg choice=\"opt"
"\"><option>--desktopfile</option> <replaceable>file name</replaceable></arg>"
msgstr ""
"<command><replaceable>केडीई अनुप्रयोग</replaceable></command><arg choice=\"opt"
"\"><option value=\"-h, --help\"> -एच, --सहायता</option></arg><arg choice="
"\"opt\"><option value=\"-v, --version\"> -v, --संस्करण</option></arg><arg "
"choice=\"opt\"><option value=--author> --लेखक</option></arg><arg choice=\"opt"
"\"><option value=--license> --लाइसेंस</option></arg><arg choice=\"opt"
"\"><option value=--desktopfile> --डेस्कटॉपफ़ाइल</option><replaceable> फ़ाइल का "
"नाम</replaceable></arg>"

#. Tag: title
#: man-kf6options.7.docbook:37
#, no-c-format
msgid "Options"
msgstr "विकल्प"

#. Tag: para
#: man-kf6options.7.docbook:39
#, no-c-format
msgid "The following options apply to all &kde; applications:"
msgstr "निम्नलिखित विकल्प सभी &kde; अनुप्रयोगों पर लागू होते हैं:"

#. Tag: term
#: man-kf6options.7.docbook:43
#, no-c-format
msgid "<option>-h</option> <option>--help</option>"
msgstr "<option value=-h>-एच</option><option value=--help> --मदद</option>"

#. Tag: para
#: man-kf6options.7.docbook:44
#, no-c-format
msgid "This lists the options available at the command line."
msgstr "यह कमांड लाइन पर उपलब्ध विकल्पों की सूची देता है।"

#. Tag: term
#: man-kf6options.7.docbook:49
#, no-c-format
msgid "<option>-v</option> <option>--version</option>"
msgstr "<option value=-v>-v</option><option value=--version> --संस्करण</option>"

#. Tag: para
#: man-kf6options.7.docbook:51
#, no-c-format
msgid ""
"Lists version information for <replaceable>KDE application</replaceable>."
msgstr ""
"<replaceable>KDE अनुप्रयोग</replaceable> के लिए संस्करण जानकारी सूचीबद्ध करता है."

#. Tag: option
#: man-kf6options.7.docbook:55
#, no-c-format
msgid "--author"
msgstr "--लेखक"

#. Tag: para
#: man-kf6options.7.docbook:56
#, no-c-format
msgid ""
"Lists <replaceable>KDE application</replaceable> authors in the terminal "
"window."
msgstr ""
"टर्मिनल विंडो में <replaceable>KDE अनुप्रयोग</replaceable> लेखकों को सूचीबद्ध करता है।"

#. Tag: option
#: man-kf6options.7.docbook:60
#, no-c-format
msgid "--license"
msgstr "--लाइसेंस"

#. Tag: para
#: man-kf6options.7.docbook:61
#, no-c-format
msgid "Shows license information."
msgstr "लाइसेंस जानकारी दिखाता है."

#. Tag: term
#: man-kf6options.7.docbook:65
#, no-c-format
msgid "<option>--desktopfile</option> <replaceable>file name</replaceable>"
msgstr ""
"<option value=--desktopfile>--डेस्कटॉपफ़ाइल</option><replaceable> फ़ाइल का नाम</"
"replaceable>"

#. Tag: para
#: man-kf6options.7.docbook:66
#, no-c-format
msgid "The base file name of the desktop entry for this application."
msgstr "इस अनुप्रयोग के लिए डेस्कटॉप प्रविष्टि का आधार फ़ाइल नाम."

#. Tag: para
#: man-kf6options.7.docbook:67
#, no-c-format
msgid ""
"This is in particular useful for wrapper applications and applications "
"having in general multiple desktop files. Thus each desktop file can put its "
"own name into the exec command."
msgstr ""
"यह रैपर अनुप्रयोगों और सामान्य रूप से कई डेस्कटॉप फ़ाइलों वाले अनुप्रयोगों के लिए विशेष रूप से "
"उपयोगी है। इस प्रकार प्रत्येक डेस्कटॉप फ़ाइल exec कमांड में अपना नाम डाल सकती है।"

#. Tag: title
#: man-kf6options.7.docbook:78
#, no-c-format
msgid "See Also"
msgstr "यह भी देखें"

#. Tag: para
#: man-kf6options.7.docbook:79
#, no-c-format
msgid "qt6options(7)"
msgstr "qt6विकल्प(7)"

