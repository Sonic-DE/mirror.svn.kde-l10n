msgstr "वाक्यांश पुस्तक बचाता है."

#. Tag: menuchoice
#: index.docbook:579
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Import...</guimenuitem>"
msgstr "<guimenu>फ़ाइल</guimenu> <guimenuitem>आयात करें...</guimenuitem>"

#. Tag: action
#: index.docbook:583 index.docbook:687
#, no-c-format
msgid "Imports a file and adds its contents to the phrase book"
msgstr "फ़ाइल आयात करता है और इसकी सामग्री को वाक्यांश पुस्तिका में जोड़ता है"

#. Tag: menuchoice
#: index.docbook:586
#, no-c-format
msgid ""
"<guimenu>File</guimenu> <guimenuitem>Import Standard Phrase Book</"
"guimenuitem>"
msgstr ""
"<guimenu>फ़ाइल</guimenu> <guimenuitem>मानक वाक्यांश पुस्तक आयात करें</guimenuitem>"

#. Tag: action
#: index.docbook:590 index.docbook:693
#, no-c-format
msgid "Imports a standard phrase book and adds its contents to the phrase book"
msgstr ""
"एक मानक वाक्यांश पुस्तिका आयात करता है और इसकी सामग्री को वाक्यांश पुस्तिका में जोड़ता है"

#. Tag: menuchoice
#: index.docbook:593
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Export...</guimenuitem>"
msgstr "<guimenu>फ़ाइल</guimenu> <guimenuitem>निर्यात करें...</guimenuitem>"

#. Tag: action
#: index.docbook:597 index.docbook:699
#, no-c-format
msgid "Exports the currently selected phrase(s) or phrase book(s) to a file"
msgstr ""
"वर्तमान में चयनित वाक्यांश(वाक्यों) या वाक्यांश पुस्तिका(वाक्यों) को फ़ाइल में निर्यात करता है"

#. Tag: menuchoice
#: index.docbook:600
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>W</keycap></keycombo> </shortcut> "
"<guimenu>File</guimenu> <guimenuitem>Close</guimenuitem>"
msgstr ""
"<शॉर्टकट> <कीकॉम्बो>&Ctrl;<कीकैप>W</कीकैप></कीकॉम्बो> </शॉर्टकट> <guimenu>फ़ाइल</"
"guimenu> <guimenuitem>बंद करें</guimenuitem>"

#. Tag: action
#: index.docbook:607
