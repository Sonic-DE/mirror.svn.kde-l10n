msgstr "वाक्यांश पुस्तिका संपादन विंडो के भीतर आदेश"

#. Tag: menuchoice
#: index.docbook:555
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>New Phrase</guimenuitem>"
msgstr "<guimenu>फ़ाइल</guimenu> <guimenuitem>नया वाक्यांश</guimenuitem>"

#. Tag: action
#: index.docbook:559 index.docbook:675
#, no-c-format
msgid "Adds a new phrase."
msgstr "एक नया वाक्यांश जोड़ता है."

#. Tag: menuchoice
#: index.docbook:562
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>New Phrase Book</guimenuitem>"
msgstr "<guimenu>फ़ाइल</guimenu> <guimenuitem>नई वाक्यांश पुस्तक</guimenuitem>"

#. Tag: action
#: index.docbook:566 index.docbook:681
#, no-c-format
msgid "Adds a new phrase book."
msgstr "एक नई वाक्यांश पुस्तक जोड़ता है."

#. Tag: menuchoice
#: index.docbook:569
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>S</keycap></keycombo> </shortcut> "
"<guimenu>File</guimenu> <guimenuitem>Save</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>S</keycap></keycombo> </shortcut> "
"<guimenu>फ़ाइल</guimenu> <guimenuitem>सहेजें</guimenuitem>"

#. Tag: action
#: index.docbook:576
#, no-c-format
