msgid "Credits and License"
msgstr "क्रेडिट और लाइसेंस"

#. Tag: para
#: index.docbook:1394
#, no-c-format
msgid ""
"Documentation Copyright see the UserBase <ulink url=\"https://userbase.kde."
"org/index.php?title=KDevelop4/Manual&amp;action=history\">KDevelop4/Manual "
"page history</ulink>"
msgstr ""
"दस्तावेज़ीकरण कॉपीराइट यूजरबेस देखें <ulink url=\"https://userbase.kde.org/index.php?"
"title=KDevelop4/Manual&amp;action=history\">KDevelop4/Manual पृष्ठ इतिहास</"
"ulink>"

