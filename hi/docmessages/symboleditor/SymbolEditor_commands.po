#. Tag: title
#: commands.docbook:2
#, no-c-format
msgid "Command Reference"
msgstr "कमांड संदर्भ"

#. Tag: title
#: commands.docbook:5
#, no-c-format
msgid "&symboleditor; Menus"
msgstr "&symboleditor; मेनू"

#. Tag: title
#: commands.docbook:7
#, no-c-format
msgid "The File Menu"
msgstr "फ़ाइल मेनू"

#. Tag: menuchoice
#: commands.docbook:11
#, no-c-format
msgid ""
"<shortcut><keycombo>&Ctrl;<keycap>N</keycap></keycombo></"
"shortcut><guimenuitem>New</guimenuitem>"
msgstr ""
"<शॉर्टकट><कीकॉम्बो>&Ctrl;<कीकैप>एन</कीकैप></कीकॉम्बो></शॉर्टकट><गुइमेनूइटम>नया</"
"गुइमेनूइटम>"

#. Tag: action
#: commands.docbook:12
#, no-c-format
msgid "Creates a new library"
msgstr "एक नई लाइब्रेरी बनाता है"

#. Tag: menuchoice
#: commands.docbook:15
#, no-c-format
msgid ""
"<shortcut><keycombo>&Ctrl;<keycap>O</keycap></keycombo></"
"shortcut><guimenuitem>Open</guimenuitem>"
msgstr ""
"<shortcut><keycombo>&Ctrl;<keycap>O</keycap></keycombo></"
"shortcut><guimenuitem>खोलें</guimenuitem>"

#. Tag: action
#: commands.docbook:16
#, no-c-format
msgid "Opens an existing library"
msgstr "मौजूदा लाइब्रेरी खोलता है"

#. Tag: guimenuitem
#: commands.docbook:19
#, no-c-format
msgid "Open Recent"
msgstr "हाल ही वाला खोलें"

#. Tag: action
#: commands.docbook:20
#, no-c-format
msgid "Open a recently used library"
msgstr "हाल ही में उपयोग की गई लाइब्रेरी खोलें"

#. Tag: menuchoice
#: commands.docbook:23
#, no-c-format
msgid ""
"<shortcut><keycombo>&Ctrl;<keycap>S</keycap></keycombo></"
"shortcut><guimenuitem>Save</guimenuitem>"
msgstr ""
"<शॉर्टकट><कीकॉम्बो>&Ctrl;<कीकैप>S</कीकैप></कीकॉम्बो></शॉर्टकट><guimenuitem>सहेजें</"
"guimenuitem>"

#. Tag: action
#: commands.docbook:24
#, no-c-format
msgid "Saves the library"
msgstr "पुस्तकालय बचाता है"

#. Tag: menuchoice
#: commands.docbook:27
#, no-c-format
msgid ""
"<shortcut><keycombo>&Ctrl;&Shift;<keycap>S</keycap></keycombo></"
"shortcut><guimenuitem>Save As</guimenuitem>"
msgstr ""
"<शॉर्टकट><कीकॉम्बो>&Ctrl;&Shift;<कीकैप>S</कीकैप></कीकॉम्बो></"
"शॉर्टकट><guimenuitem>इस रूप में सहेजें</guimenuitem>"

#. Tag: action
#: commands.docbook:28
#, no-c-format
msgid "Saves the library under a new name"
msgstr "लाइब्रेरी को नए नाम से सहेजता है"

#. Tag: guimenuitem
#: commands.docbook:31
#, no-c-format
msgid "Save Symbol"
msgstr "प्रतीक सहेजें"

#. Tag: listitem
#: commands.docbook:32
#, no-c-format
msgid ""
"<simpara><action>Save the symbol being edited</action></simpara> <simpara>If "
"the symbol being edited was selected from the library, saving will update "
"that symbol. If it is a new symbol, it will be appended to the library and "
"subsequent saves will append another new symbol to the library. </simpara>"
msgstr ""
"<simpara><action>संपादित किए जा रहे प्रतीक को सहेजें</action></simpara> "
"<simpara>यदि संपादित किया जा रहा प्रतीक लाइब्रेरी से चुना गया था, तो सहेजने से वह "
"प्रतीक अपडेट हो जाएगा। यदि यह एक नया प्रतीक है, तो इसे लाइब्रेरी में जोड़ दिया जाएगा "
"और बाद में सहेजने से लाइब्रेरी में एक और नया प्रतीक जुड़ जाएगा। </simpara>"

#. Tag: guimenuitem
#: commands.docbook:39
#, no-c-format
msgid "Save Symbol as New"
msgstr "प्रतीक को नए रूप में सहेजें"

#. Tag: listitem
#: commands.docbook:40
#, no-c-format
msgid ""
"<simpara><action>Save the symbol being edited as a new symbol</action></"
"simpara> <simpara>When a symbol is saved as new it will be appended to the "
"library regardless of it having originally been selected from the library "
"for editing. Subsequent saves will append another new symbol to the library. "
"</simpara>"
msgstr ""
"<simpara><action>संपादित किए जा रहे प्रतीक को नए प्रतीक के रूप में सहेजें</action></"
"simpara> <simpara>जब कोई प्रतीक नए रूप में सहेजा जाता है तो उसे लाइब्रेरी में जोड़ दिया "
"जाएगा, भले ही उसे मूल रूप से संपादन के लिए लाइब्रेरी से चुना गया हो। बाद में सहेजे जाने पर "
"लाइब्रेरी में एक और नया प्रतीक जोड़ दिया जाएगा।</simpara>"

#. Tag: guimenuitem
#: commands.docbook:47
#, no-c-format
msgid "Import Library"
msgstr "लाइब्रेरी आयात करें"

#. Tag: action
#: commands.docbook:48
#, no-c-format
msgid ""
"Import a library appending the contained symbols into the current library"
msgstr "वर्तमान लाइब्रेरी में निहित प्रतीकों को जोड़कर लाइब्रेरी आयात करें"

#. Tag: menuchoice
#: commands.docbook:51
#, no-c-format
msgid ""
"<shortcut><keycombo>&Ctrl;<keycap>W</keycap></keycombo></"
"shortcut><guimenuitem>Close</guimenuitem>"
msgstr ""
"<शॉर्टकट><कीकॉम्बो>&Ctrl;<कीकैप>डब्ल्यू</कीकैप></कीकॉम्बो></शॉर्टकट><गुइमेनूइटम>बंद करें</"
"गुइमेनूइटम>"

#. Tag: action
#: commands.docbook:52
#, no-c-format
msgid "Close the library"
msgstr "पुस्तकालय बंद करें"

#. Tag: menuchoice
#: commands.docbook:55
#, no-c-format
msgid ""
"<shortcut><keycombo>&Ctrl;<keycap>Q</keycap></keycombo></"
"shortcut><guimenuitem>Quit</guimenuitem>"
msgstr ""
"<शॉर्टकट><कीकॉम्बो>&Ctrl;<कीकैप>Q</कीकैप></कीकॉम्बो></शॉर्टकट><guimenuitem>छोड़ें</"
"guimenuitem>"

#. Tag: action
#: commands.docbook:56
#, no-c-format
msgid "Quits &symboleditor;"
msgstr "&symboleditor; छोड़ता है"

#. Tag: title
#: commands.docbook:63
#, no-c-format
msgid "The Edit Menu"
msgstr "संपादन मेनू"

#. Tag: para
#: commands.docbook:64
#, no-c-format
msgid ""
"&symboleditor; has the common &kde; <guimenu>Edit</guimenu> menu items, for "
"more information read the sections about the <ulink url=\"help:/fundamentals/"
"menus.html#menus-edit\">Edit Menu</ulink> of the &kde; Fundamentals."
msgstr ""
"&symboleditor; में सामान्य &kde; <guimenu>संपादन</guimenu> मेनू आइटम हैं, अधिक "
"जानकारी के लिए &kde; फंडामेंटल्स के <ulink url=\"help:/fundamentals/menus."
"html#menus-edit\">संपादन मेनू</ulink> के बारे में अनुभाग पढ़ें।"

#. Tag: title
#: commands.docbook:70
#, no-c-format
msgid "The Rendering Menu and Toolbar"
msgstr "रेंडरिंग मेनू और टूलबार"

#. Tag: screeninfo
#: commands.docbook:72
#, no-c-format
msgid "Here is a screen shot of the rendering toolbar"
msgstr "यहाँ रेंडरिंग टूलबार का एक स्क्रीन शॉट है"

