msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>H</keycap></keycombo> </"
"shortcut> <guimenu>गेम</guimenu> <guimenuitem>उच्च स्कोर दिखाएं</guimenuitem>"

#. Tag: para
#: index.docbook:635
#, no-c-format
msgid "Shows a dialog containing the High Scores."
msgstr "उच्च स्कोर वाला एक संवाद दिखाता है."

#. Tag: menuchoice
#: index.docbook:642
#, no-c-format
