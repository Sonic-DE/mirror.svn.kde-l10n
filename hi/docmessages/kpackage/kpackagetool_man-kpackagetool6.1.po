#. Tag: title
#: man-kpackagetool6.1.docbook:8
#, no-c-format
msgid "KPackage Manager"
msgstr "केपैकेज मैनेजर"

#. Tag: date
#: man-kpackagetool6.1.docbook:9
#, no-c-format
msgid "2017-01-03"
msgstr "2017-01-03"

#. Tag: releaseinfo
#: man-kpackagetool6.1.docbook:10
#, no-c-format
msgid "Frameworks 5.30"
msgstr "फ्रेमवर्क 5.30"

#. Tag: productname
#: man-kpackagetool6.1.docbook:11
#, no-c-format
msgid "KDE Frameworks"
msgstr "केडीई फ्रेमवर्क"

#. Tag: manvolnum
#: man-kpackagetool6.1.docbook:16
#, no-c-format
msgid "<manvolnum>1</manvolnum>"
msgstr "<मैनवोलन्यूम>1</मैनवोलन्यूम>"

#. Tag: refpurpose
#: man-kpackagetool6.1.docbook:21
#, no-c-format
msgid "Install, list, remove &plasma; packages"
msgstr "पैकेज स्थापित करें, सूचीबद्ध करें, हटाएं"

#. Tag: cmdsynopsis
#: man-kpackagetool6.1.docbook:25
#, no-c-format
msgid ""
"<command>kpackagetool6</command> <group choice=\"opt\"><option>-v, --"
"version</option></group> <group choice=\"opt\"><option>-h, --help</option></"
"group> <group choice=\"opt\"><option>--hash</option> <replaceable> path</"
"replaceable></group> <group choice=\"opt\"><option>-g, --global</option></"
"group> <group choice=\"opt\"><option>-t, --type</option> <replaceable> type</"
"replaceable></group> <group choice=\"opt\"><option>-i, --install</option> "
"<replaceable> path</replaceable></group> <group choice=\"opt\"><option>-s, --"
"show</option> <replaceable> name</replaceable></group> <group choice=\"opt"
"\"><option>-u, --upgrade</option> <replaceable> path</replaceable></group> "
"<group choice=\"opt\"><option>-l, --list</option></group> <group choice=\"opt"
"\"><option>--list-types</option></group> <group choice=\"opt\"><option>-r, --"
"remove</option> <replaceable> name</replaceable></group> <group choice=\"opt"
"\"><option>-p, --packageroot</option> <replaceable> path</replaceable></"
"group> <group choice=\"opt\"><option>--generate-index</option></group>"
msgstr ""
"<command>kpackagetool6</command><group choice=\"opt\"><option value=\"-v, --"
"version\"> -v, --संस्करण</option></group><group choice=\"opt\"><option value="
"\"-h, --help\"> -एच, --सहायता</option></group><group choice=\"opt\"><option "
"value=--hash> --हैश</option><replaceable> पथ</replaceable></group><group "
"choice=\"opt\"><option value=\"-g, --global\"> -जी, --ग्लोबल</option></"
"group><group choice=\"opt\"><option value=\"-t, --type\"> -टी, --प्रकार</"
"option><replaceable> प्रकार</replaceable></group><group choice=\"opt"
"\"><option value=\"-i, --install\"> -i, --इंस्टॉल</option><replaceable> पथ</"
"replaceable></group><group choice=\"opt\"><option value=\"-s, --show\"> -एस, "
"--शो</option><replaceable> नाम</replaceable></group><group choice=\"opt"
"\"><option value=\"-u, --upgrade\"> -u, --अपग्रेड</option><replaceable> पथ</"
"replaceable></group><group choice=\"opt\"><option value=\"-l, --list\"> -l, "
"--सूची</option></group><group choice=\"opt\"><option value=--list-types> --"
"सूची-प्रकार</option></group><group choice=\"opt\"><option value=\"-r, --remove"
"\"> -आर, --हटाएँ</option><replaceable> नाम</replaceable></group><group choice="
"\"opt\"><option value=\"-p, --packageroot\"> -p, --पैकेजरूट</"
"option><replaceable> पथ</replaceable></group><group choice=\"opt\"><option "
"value=--generate-index> --जनरेट-इंडेक्स</option></group>"

#. Tag: title
#: man-kpackagetool6.1.docbook:45
#, no-c-format
msgid "Description"
msgstr "विवरण"

#. Tag: para
#: man-kpackagetool6.1.docbook:46
#, no-c-format
msgid ""
"<command>kpackagetool6</command> is a command line tool to install, list, "
"remove &plasma; packages."
msgstr ""
"<command>kpackagetool6</command> पैकेजों को स्थापित करने, सूचीबद्ध करने, हटाने के लिए "
"एक कमांड लाइन टूल है।"

#. Tag: title
#: man-kpackagetool6.1.docbook:52
#, no-c-format
msgid "Options"
msgstr "विकल्प"

#. Tag: option
#: man-kpackagetool6.1.docbook:56
#, no-c-format
msgid "-v, --version"
msgstr "-v, --संस्करण"

#. Tag: para
#: man-kpackagetool6.1.docbook:57
#, no-c-format
msgid "Displays version information."
msgstr "संस्करण जानकारी प्रदर्शित करता है."

#. Tag: option
#: man-kpackagetool6.1.docbook:60
#, no-c-format
msgid "-h, --help"
msgstr "-एच, --सहायता"

#. Tag: para
#: man-kpackagetool6.1.docbook:61
#, no-c-format
msgid "Displays this help."
msgstr "यह सहायता प्रदर्शित करता है."

#. Tag: term
#: man-kpackagetool6.1.docbook:64
#, no-c-format
msgid "<option>--hash</option> <replaceable> path</replaceable>"
msgstr "<option value=--hash>--हैश</option><replaceable> पथ</replaceable>"

#. Tag: para
#: man-kpackagetool6.1.docbook:65
#, no-c-format
msgid "Generate a SHA1 hash for the package at <quote>path</quote>."
msgstr "<quote>path</quote> पर पैकेज के लिए SHA1 हैश उत्पन्न करें।"

#. Tag: option
#: man-kpackagetool6.1.docbook:68
#, no-c-format
msgid "-g, --global"
msgstr "-जी, --ग्लोबल"

#. Tag: para
#: man-kpackagetool6.1.docbook:69
#, no-c-format
msgid "For install or remove, operates on packages installed for all users."
msgstr ""
"इंस्टॉल या हटाने के लिए, सभी उपयोगकर्ताओं के लिए इंस्टॉल किए गए पैकेजों पर काम करता है।"

#. Tag: term
#: man-kpackagetool6.1.docbook:72
#, no-c-format
msgid "<option>-t, --type</option> <replaceable> type</replaceable>"
msgstr ""
"<option value=\"-t, --type\">-टी, --प्रकार</option><replaceable> प्रकार</"
"replaceable>"

#. Tag: para
#: man-kpackagetool6.1.docbook:73
#, no-c-format
msgid ""
"The type of package, corresponding to the service type of the package "
"plugin, &eg; KPackage/Generic, Plasma/Theme, Plasma/Wallpaper, Plasma/"
"Applet, &etc;"
msgstr ""
"पैकेज प्लगइन के सेवा प्रकार के अनुरूप पैकेज का प्रकार, &eg; KPackage/Generic, Plasma/"
"Theme, Plasma/Wallpaper, Plasma/Applet, &etc;"

#. Tag: term
#: man-kpackagetool6.1.docbook:77
#, no-c-format
msgid "<option>-i, --install</option> <replaceable> path</replaceable>"
msgstr ""
"<option value=\"-i, --install\">-i, --इंस्टॉल</option><replaceable> पथ</"
"replaceable>"

#. Tag: para
#: man-kpackagetool6.1.docbook:78
#, no-c-format
msgid "Install the package at <quote>path</quote>."
msgstr "पैकेज को <quote>path</quote> पर स्थापित करें."

#. Tag: term
#: man-kpackagetool6.1.docbook:81
#, no-c-format
msgid "<option>-s, --show</option> <replaceable> name</replaceable>"
msgstr ""
"<option value=\"-s, --show\">-एस, --शो</option><replaceable> नाम</"
"replaceable>"

#. Tag: para
#: man-kpackagetool6.1.docbook:82
#, no-c-format
msgid "Show information of package <quote>name</quote>."
msgstr "पैकेज <quote>नाम</quote> की जानकारी दिखाएँ."

#. Tag: term
#: man-kpackagetool6.1.docbook:85
#, no-c-format
msgid "<option>-u, --upgrade</option> <replaceable> path</replaceable>"
msgstr ""
"<option value=\"-u, --upgrade\">-u, --अपग्रेड</option><replaceable> पथ</"
"replaceable>"

#. Tag: para
#: man-kpackagetool6.1.docbook:86
#, no-c-format
msgid "Upgrade the package at <quote>path</quote>."
msgstr "पैकेज को <quote>path</quote> पर अपग्रेड करें."

#. Tag: option
#: man-kpackagetool6.1.docbook:89
#, no-c-format
msgid "-l, --list"
msgstr "-l, --सूची"

#. Tag: para
#: man-kpackagetool6.1.docbook:90
#, no-c-format
msgid "List installed packages."
msgstr "स्थापित पैकेजों की सूची बनाएं."

#. Tag: option
#: man-kpackagetool6.1.docbook:93
#, no-c-format
msgid "--list-types"
msgstr "--सूची-प्रकार"

#. Tag: para
#: man-kpackagetool6.1.docbook:94
#, no-c-format
msgid "Lists all known Package types that can be installed."
msgstr "सभी ज्ञात पैकेज प्रकारों को सूचीबद्ध करता है जिन्हें स्थापित किया जा सकता है।"

#. Tag: term
#: man-kpackagetool6.1.docbook:97
#, no-c-format
msgid "<option>-r, --remove</option> <replaceable> name</replaceable>"
msgstr ""
"<option value=\"-r, --remove\">-आर, --हटाएँ</option><replaceable> नाम</"
"replaceable>"

#. Tag: para
#: man-kpackagetool6.1.docbook:98
#, no-c-format
msgid "Remove the package named <quote>name</quote>."
msgstr "<quote>name</quote> नामक पैकेज को हटाएँ."

#. Tag: term
#: man-kpackagetool6.1.docbook:101
#, no-c-format
msgid "<option>-p, --packageroot</option> <replaceable> path</replaceable>"
msgstr ""
"<option value=\"-p, --packageroot\">-p, --पैकेजरूट</option><replaceable> पथ</"
"replaceable>"

#. Tag: para
#: man-kpackagetool6.1.docbook:102
#, no-c-format
msgid ""
"Absolute path to the package root. If not supplied, then the standard data "
"directories for this &plasma; session will be searched instead."
msgstr ""
"पैकेज रूट का पूर्ण पथ। यदि प्रदान नहीं किया गया है, तो इसके बजाय इस &plasma; सत्र के "
"लिए मानक डेटा निर्देशिकाएँ खोजी जाएँगी।"

#. Tag: term
#: man-kpackagetool6.1.docbook:106
#, no-c-format
msgid "<option>--generate-index</option> <replaceable> path</replaceable>"
msgstr ""
"<option value=--generate-index>--जनरेट-इंडेक्स</option><replaceable> पथ</"
"replaceable>"

#. Tag: para
#: man-kpackagetool6.1.docbook:107
#, no-c-format
msgid ""
"Recreate the plugin index. To be used in conjunction with either the option "
"<option>-t</option> or <option>-g</option>. Recreates the index for the "
"given type or package root. Operates in the user directory, unless <option>-"
"g</option> is used."
msgstr ""
"प्लगइन इंडेक्स को फिर से बनाएँ। किसी भी विकल्प के साथ संयोजन में उपयोग किया जाना "
"चाहिए<option value=-t> -टी</option> या<option value=-g> -जी</option> दिए गए "
"प्रकार या पैकेज रूट के लिए इंडेक्स को फिर से बनाता है। उपयोगकर्ता निर्देशिका में संचालित "
"होता है, जब तक कि<option value=-g> -जी</option> प्रयोग किया जाता है।"

#. Tag: title
#: man-kpackagetool6.1.docbook:118
#, no-c-format
msgid "See Also"
msgstr "यह भी देखें"

#. Tag: para
#: man-kpackagetool6.1.docbook:120
#, no-c-format
msgid ""
"More detailed user documentation is available from <ulink url=\"help:/plasma-"
"desktop\">help:/plasma-desktop</ulink> (either enter this &URL; into "
"&konqueror;, or run <userinput><command>khelpcenter</command> "
"<parameter>help:/plasma-desktop</parameter></userinput>)."
msgstr ""
"अधिक विस्तृत उपयोगकर्ता दस्तावेज़ <ulink url=\"help:/plasma-desktop\">help:/plasma-"
"desktop</ulink> से उपलब्ध है (इस &URL; को &konqueror; में प्रविष्ट करें, या "
"<userinput><command>khelpcenter</command> <parameter>help:/plasma-desktop</"
"parameter></userinput> चलाएँ)।"

#. Tag: title
#: man-kpackagetool6.1.docbook:129
#, no-c-format
msgid "Authors"
msgstr "लेखक"

#. Tag: para
#: man-kpackagetool6.1.docbook:130
#, no-c-format
msgid ""
"<command>kpackagetool6</command> was written by "
"<personname><firstname>Aaron</firstname><surname>Seigo</surname></"
"personname> <email>aseigo@kde.org</email>."
msgstr ""
"<command>kpackagetool6</command> को <personname><firstname>Aaron</"
"firstname><surname>Seigo</surname></personname> <email>aseigo@kde.org</"
"email> द्वारा लिखा गया था।"
