msgstr "पिछले छेद पर जाएँ."

#. Tag: menuchoice
#: index.docbook:465
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Home;</keycombo> </shortcut> "
"<guimenu>Go</guimenu> <guimenuitem>First Hole</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Home;</keycombo> </shortcut> "
"<guimenu>जाओ</guimenu> <guimenuitem>पहला छेद</guimenuitem>"

#. Tag: action
#: index.docbook:473
#, no-c-format
