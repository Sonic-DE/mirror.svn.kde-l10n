msgstr "पाठ्यक्रम के पहले छेद पर जाएँ।"

#. Tag: menuchoice
#: index.docbook:478
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;&End;</keycombo> </"
"shortcut> <guimenu>Go</guimenu> <guimenuitem>Last Hole</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;&End;</keycombo> </"
"shortcut> <guimenu>जाओ</guimenu> <guimenuitem>अंतिम छेद</guimenuitem>"

#. Tag: action
#: index.docbook:487
#, no-c-format
msgid "Go to the last hole in the course."
msgstr "पाठ्यक्रम के अंतिम छेद तक जाएँ।"

#. Tag: menuchoice
#: index.docbook:492
#, no-c-format
