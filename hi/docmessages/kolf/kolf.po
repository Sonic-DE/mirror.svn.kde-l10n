msgstr "आपके द्वारा किया गया अंतिम शॉट पूर्ववत करें।"

#. Tag: title
#: index.docbook:423
#, no-c-format
msgid "The Go Menu"
msgstr "गो मेनू"

#. Tag: menuchoice
#: index.docbook:427
#, no-c-format
msgid "<guimenu>Go</guimenu> <guisubmenu>Switch to Hole</guisubmenu>"
msgstr "<guimenu>जाएँ</guimenu> <guisubmenu>होल पर जाएँ</guisubmenu>"

#. Tag: para
#: index.docbook:432
