msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>Z</keycap></keycombo> </"
"shortcut> <guimenu>छेद</guimenu> <guimenuitem>शॉट पूर्ववत करें</guimenuitem>"

