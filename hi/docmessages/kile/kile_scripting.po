#, no-c-format
msgid "void document.refreshStructure();"
msgstr "शून्य दस्तावेज़.रिफ्रेशस्ट्रक्चर();"

#. Tag: para
#: scripting.docbook:1285
#, no-c-format
msgid ""
"Refresh the structure view (see <xref linkend=\"navigating\" role=\"select: "
"title pageabbrv\"/>)."
msgstr ""
"संरचना दृश्य को ताज़ा करें (देखें <xref linkend=\"navigating\" role=\"select: title "
"pageabbrv\"/>)."

#. Tag: title
#: scripting.docbook:1294
#, no-c-format
msgid "The &kile; API"
msgstr "&kile; एपीआई"

#. Tag: para
#: scripting.docbook:1296
#, no-c-format
msgid ""
"The global object (variable) <userinput>kile</userinput> is used to handle "
"top level interactions with the outside world, input message and dialog "
"interfaces. These API calls are divided into subobjects to structure this "
"part of the scripting API. Conceptually <userinput>kile</userinput> is a bit "
"like <userinput>window</userinput> in a browser API."
msgstr ""
"वैश्विक ऑब्जेक्ट (चर) <userinput>kile</userinput> का उपयोग बाहरी दुनिया, इनपुट संदेश "
"और संवाद इंटरफेस के साथ शीर्ष स्तर की बातचीत को संभालने के लिए किया जाता है। स्क्रिप्टिंग "
"API के इस भाग को संरचित करने के लिए इन API कॉल को उप-ऑब्जेक्ट में विभाजित किया जाता "
"है। वैचारिक रूप से <userinput>kile</userinput> ब्राउज़र API में <userinput>window</"
"userinput> जैसा है।"

#. Tag: para
#: scripting.docbook:1298
#, no-c-format
msgid "<literal>kile.alert</literal>: &nbsp; message boxes"
msgstr "<literal>kile.alert</literal>: &nbsp; संदेश बॉक्स"

#. Tag: para
#: scripting.docbook:1299
#, no-c-format
msgid "<literal>kile.input</literal>: &nbsp; get user input"
msgstr "<literal>kile.input</literal>: &nbsp; उपयोगकर्ता इनपुट प्राप्त करें"

#. Tag: para
#: scripting.docbook:1300
#, no-c-format
msgid "<literal>kile.wizard</literal>: &nbsp; call one of &kile;'s wizards"
msgstr "<literal>kile.wizard</literal>: &nbsp; &kile के किसी एक जादूगर को बुलाएँ"

#. Tag: para
#: scripting.docbook:1301
#, no-c-format
msgid "<literal>kile.script</literal>: &nbsp; get info about a running script"
msgstr ""
"<literal>kile.script</literal>: &nbsp; चल रही स्क्रिप्ट के बारे में जानकारी प्राप्त करें"

#. Tag: para
#: scripting.docbook:1302
#, no-c-format
msgid ""
"<literal>kile.file</literal>: &nbsp; file operations like read and write."
msgstr "<literal>kile.file</literal>: &nbsp; फ़ाइल संचालन जैसे पढ़ना और लिखना."

#. Tag: title
#: scripting.docbook:1308
#, no-c-format
msgid "Alert"
msgstr "चेतावनी"

#. Tag: synopsis
#: scripting.docbook:1311
#, no-c-format
msgid ""
"void kile.alert.information(<parameter>String <replaceable>text</"
"replaceable></parameter>, <parameter>String <replaceable>caption</"
"replaceable></parameter>);"
msgstr ""
"void kile.alert.information(<पैरामीटर>स्ट्रिंग <प्रतिस्थापन योग्य>टेक्स्ट</प्रतिस्थापन "
"योग्य></पैरामीटर>, <पैरामीटर>स्ट्रिंग <प्रतिस्थापन योग्य>कैप्शन</प्रतिस्थापन योग्य></"
"पैरामीटर>);"

#. Tag: para
#: scripting.docbook:1312
#, no-c-format
msgid ""
"Display an <emphasis>Information</emphasis> dialog. <parameter>text</"
"parameter> is the message string and <parameter>caption</parameter> the "
"title of the message box. The default title is the script name."
msgstr ""
"<emphasis>सूचना</emphasis> संवाद प्रदर्शित करें। <parameter>text</parameter> संदेश "
"स्ट्रिंग है और <parameter>caption</parameter> संदेश बॉक्स का शीर्षक है। डिफ़ॉल्ट शीर्षक "
"स्क्रिप्ट नाम है।"

#. Tag: synopsis
#: scripting.docbook:1318
#, no-c-format
msgid ""
"void kile.alert.sorry(<parameter>String <replaceable>text</replaceable></"
"parameter>, <parameter>String <replaceable>caption</replaceable></"
"parameter>);"
msgstr ""
"void kile.alert.sorry(<पैरामीटर>स्ट्रिंग <प्रतिस्थापन योग्य>टेक्स्ट</प्रतिस्थापन योग्य></"
"पैरामीटर>, <पैरामीटर>स्ट्रिंग <प्रतिस्थापन योग्य>कैप्शन</प्रतिस्थापन योग्य></पैरामीटर>);"

#. Tag: para
#: scripting.docbook:1319
#, no-c-format
msgid ""
"Display a <emphasis>Sorry</emphasis> dialog. <parameter>text</parameter> is "
"the message string and <parameter>caption</parameter> the title of the "
"message box. The default title is the script name."
msgstr ""
"<emphasis>Sorry</emphasis> संवाद प्रदर्शित करें। <parameter>text</parameter> संदेश "
"स्ट्रिंग है और <parameter>caption</parameter> संदेश बॉक्स का शीर्षक है। डिफ़ॉल्ट शीर्षक "
"स्क्रिप्ट नाम है।"

#. Tag: synopsis
#: scripting.docbook:1325
#, no-c-format
msgid ""
"void kile.alert.error(<parameter>String <replaceable>text</replaceable></"
"parameter>, <parameter>String <replaceable>caption</replaceable></"
"parameter>);"
msgstr ""
"void kile.alert.error(<पैरामीटर>स्ट्रिंग <प्रतिस्थापन योग्य>टेक्स्ट</प्रतिस्थापन योग्य></"
"पैरामीटर>, <पैरामीटर>स्ट्रिंग <प्रतिस्थापन योग्य>कैप्शन</प्रतिस्थापन योग्य></पैरामीटर>);"

#. Tag: para
#: scripting.docbook:1326
#, no-c-format
msgid ""
"Display an <emphasis>Error</emphasis> dialog. <parameter>text</parameter> is "
"the message string and <parameter>caption</parameter> the title of the "
"message box. The default title is the script name."
msgstr ""
"<emphasis>Error</emphasis> संवाद प्रदर्शित करें। <parameter>text</parameter> संदेश "
"स्ट्रिंग है और <parameter>caption</parameter> संदेश बॉक्स का शीर्षक है। डिफ़ॉल्ट शीर्षक "
"स्क्रिप्ट नाम है।"

#. Tag: synopsis
#: scripting.docbook:1332
#, no-c-format
msgid ""
"String kile.alert.question(<parameter>String <replaceable>text</"
"replaceable></parameter>, <parameter>String <replaceable>caption</"
"replaceable></parameter>);"
msgstr ""
"स्ट्रिंग kile.alert.question(<पैरामीटर>स्ट्रिंग <प्रतिस्थापन योग्य>टेक्स्ट</प्रतिस्थापन "
"योग्य></पैरामीटर>, <पैरामीटर>स्ट्रिंग <प्रतिस्थापन योग्य>कैप्शन</प्रतिस्थापन योग्य></"
"पैरामीटर>);"

#. Tag: para
#: scripting.docbook:1333
#, no-c-format
msgid ""
"Display a simple <emphasis>question</emphasis> dialog. <parameter>text</"
"parameter> is the message string and <parameter>caption</parameter> the "
"title of the message box. The default title is the script name. The returned "
"string is either <literal>yes</literal> or <literal>no</literal>."
msgstr ""
"एक सरल <emphasis>प्रश्न</emphasis> संवाद प्रदर्शित करें। <parameter>text</"
"parameter> संदेश स्ट्रिंग है और <parameter>caption</parameter> संदेश बॉक्स का शीर्षक "
"है। डिफ़ॉल्ट शीर्षक स्क्रिप्ट का नाम है। लौटाई गई स्ट्रिंग या तो <literal>yes</literal> "
"या <literal>no</literal> है।"

#. Tag: synopsis
#: scripting.docbook:1339
#, no-c-format
msgid ""
"String kile.alert.warning(<parameter>String <replaceable>text</replaceable></"
"parameter>, <parameter>String <replaceable>caption</replaceable></"
"parameter>);"
msgstr ""
"स्ट्रिंग kile.alert.warning(<पैरामीटर>स्ट्रिंग <प्रतिस्थापन योग्य>टेक्स्ट</प्रतिस्थापन "
"योग्य></पैरामीटर>, <पैरामीटर>स्ट्रिंग <प्रतिस्थापन योग्य>कैप्शन</प्रतिस्थापन योग्य></"
"पैरामीटर>);"

#. Tag: para
#: scripting.docbook:1340
#, no-c-format
msgid ""
"Display a simple <emphasis>warning</emphasis> dialog. <parameter>text</"
"parameter> is the message string and <parameter>caption</parameter> the "
"title of the message box. The default title is the script name. The returned "
"string is either <literal>continue</literal> or <literal>cancel</literal>."
msgstr ""
"एक सरल <emphasis>चेतावनी</emphasis> संवाद प्रदर्शित करें। <parameter>text</"
"parameter> संदेश स्ट्रिंग है और <parameter>caption</parameter> संदेश बॉक्स का शीर्षक "
"है। डिफ़ॉल्ट शीर्षक स्क्रिप्ट का नाम है। लौटाई गई स्ट्रिंग या तो <literal>continue</"
"literal> या <literal>cancel</literal> है।"

#. Tag: title
#: scripting.docbook:1348
#, no-c-format
msgid "Input"
msgstr "इनपुट"

#. Tag: synopsis
#: scripting.docbook:1351
#, no-c-format
msgid ""
"String kile.input.getListboxItem(<parameter>String <replaceable>caption</"
"replaceable></parameter>, <parameter>String <replaceable>label</"
"replaceable></parameter>, <parameter>StringList <replaceable>list</"
"replaceable></parameter>);"
msgstr ""
"स्ट्रिंग kile.input.getListboxItem(<पैरामीटर>स्ट्रिंग <प्रतिस्थापन योग्य>कैप्शन</"
"प्रतिस्थापन योग्य></पैरामीटर>, <पैरामीटर>स्ट्रिंग <प्रतिस्थापन योग्य>लेबल</प्रतिस्थापन "
"योग्य></पैरामीटर>, <पैरामीटर>स्ट्रिंगसूची <प्रतिस्थापन योग्य>सूची</प्रतिस्थापन योग्य></"
"पैरामीटर>);"

#. Tag: para
#: scripting.docbook:1352
#, no-c-format
msgid ""
"Function to let the user select an item from a list, which is shown as a "
"listbox. <parameter>caption</parameter> is the text that is displayed in the "
"title bar, <parameter>label</parameter> is the text that appears as the "
"label for the list and <parameter>list</parameter> is the string list which "
"is inserted into the list."
msgstr ""
"उपयोगकर्ता को सूची से कोई आइटम चुनने देने वाला फ़ंक्शन, जिसे लिस्टबॉक्स के रूप में दिखाया "
"जाता है। <parameter>caption</parameter> वह पाठ है जो शीर्षक बार में प्रदर्शित होता "
"है, <parameter>label</parameter> वह पाठ है जो सूची के लिए लेबल के रूप में दिखाई देता है "
"और <parameter>list</parameter> वह स्ट्रिंग सूची है जिसे सूची में डाला जाता है।"

#. Tag: synopsis
#: scripting.docbook:1358
#, no-c-format
msgid ""
"String kile.input.getComboboxItem(<parameter>String <replaceable>caption</"
"replaceable></parameter>, <parameter>String <replaceable>label</"
"replaceable></parameter>, <parameter>StringList <replaceable>list</"
"replaceable></parameter>);"
msgstr ""
"स्ट्रिंग kile.input.getComboboxItem(<पैरामीटर>स्ट्रिंग <प्रतिस्थापन योग्य>कैप्शन</"
"प्रतिस्थापन योग्य></पैरामीटर>, <पैरामीटर>स्ट्रिंग <प्रतिस्थापन योग्य>लेबल</प्रतिस्थापन "
"योग्य></पैरामीटर>, <पैरामीटर>स्ट्रिंगसूची <प्रतिस्थापन योग्य>सूची</प्रतिस्थापन योग्य></"
"पैरामीटर>);"

#. Tag: para
#: scripting.docbook:1359
#, no-c-format
msgid ""
"Function to let the user select an item from a list, which is shown as a "
"combobox. <parameter>caption</parameter> is the text that is displayed in "
"the title bar, <parameter>label</parameter> is the text that appears as the "
"label for the list and <parameter>list</parameter> is the string list which "
"is inserted into the list."
msgstr ""
"उपयोगकर्ता को सूची से कोई आइटम चुनने देने वाला फ़ंक्शन, जिसे कॉम्बोबॉक्स के रूप में दिखाया "
"जाता है। <parameter>caption</parameter> वह पाठ है जो शीर्षक बार में प्रदर्शित होता "
"है, <parameter>label</parameter> वह पाठ है जो सूची के लिए लेबल के रूप में दिखाई देता है "
"और <parameter>list</parameter> वह स्ट्रिंग सूची है जिसे सूची में डाला जाता है।"

#. Tag: synopsis
#: scripting.docbook:1365
#, no-c-format
msgid ""
"String kile.input.getText(<parameter>String <replaceable>caption</"
"replaceable></parameter>, <parameter>String <replaceable>label</"
"replaceable></parameter>);"
msgstr ""
"स्ट्रिंग kile.input.getText(<पैरामीटर>स्ट्रिंग <प्रतिस्थापन योग्य>कैप्शन</प्रतिस्थापन "
"योग्य></पैरामीटर>, <पैरामीटर>स्ट्रिंग <प्रतिस्थापन योग्य>लेबल</प्रतिस्थापन योग्य></"
"पैरामीटर>);"

#. Tag: para
#: scripting.docbook:1366
#, no-c-format
msgid ""
"Function to get a string from the user. <parameter>caption</parameter> is "
"the text that is displayed in the title bar and <parameter>label</parameter> "
"the text that appears as a label for the line edit."
msgstr ""
"उपयोगकर्ता से स्ट्रिंग प्राप्त करने का फ़ंक्शन। <parameter>caption</parameter> वह पाठ है "
"जो शीर्षक पट्टी में प्रदर्शित होता है और <parameter>label</parameter> वह पाठ है जो "
"पंक्ति संपादन के लिए लेबल के रूप में प्रकट होता है।"

#. Tag: synopsis
#: scripting.docbook:1372
#, no-c-format
msgid ""
"String kile.input.getLatexCommand(<parameter>String <replaceable>caption</"
"replaceable></parameter>, <parameter>String <replaceable>label</"
"replaceable></parameter>);"
msgstr ""
"स्ट्रिंग kile.input.getLatexCommand(<पैरामीटर>स्ट्रिंग <प्रतिस्थापन योग्य>कैप्शन</"
"प्रतिस्थापन योग्य></पैरामीटर>, <पैरामीटर>स्ट्रिंग <प्रतिस्थापन योग्य>लेबल</प्रतिस्थापन "
"योग्य></पैरामीटर>);"

#. Tag: para
#: scripting.docbook:1373
#, no-c-format
msgid ""
"Function to get a &latex; command from the user. This means that only lower- "
"and uppercase letters are allowed. <parameter>caption</parameter> is the "
"text that is displayed in the title bar and <parameter>label</parameter> the "
"text that appears as a label for the line edit."
msgstr ""
"उपयोगकर्ता से &latex; कमांड प्राप्त करने के लिए फ़ंक्शन। इसका मतलब है कि केवल छोटे और बड़े "
"अक्षरों की अनुमति है। <parameter>caption</parameter> वह पाठ है जो शीर्षक बार में "
"प्रदर्शित होता है और <parameter>label</parameter> वह पाठ है जो पंक्ति संपादन के लिए "
"लेबल के रूप में दिखाई देता है।"

#. Tag: synopsis
#: scripting.docbook:1379
#, no-c-format
msgid ""
"int kile.input.getInteger(<parameter>String <replaceable>caption</"
"replaceable></parameter>, <parameter>String <replaceable>label</"
"replaceable></parameter>, <parameter>int <replaceable>min = INT_MIN</"
"replaceable></parameter>, <parameter>int <replaceable>max = INT_MAX</"
"replaceable></parameter>);"
msgstr ""
"int kile.input.getInteger(<पैरामीटर>स्ट्रिंग <प्रतिस्थापन>कैप्शन</प्रतिस्थापन></"
"पैरामीटर>, <पैरामीटर>स्ट्रिंग <प्रतिस्थापन>लेबल</प्रतिस्थापन></पैरामीटर>, <पैरामीटर>int "
"<प्रतिस्थापन>न्यूनतम = INT_MIN</प्रतिस्थापन></पैरामीटर>, <पैरामीटर>int "
"<प्रतिस्थापन>अधिकतम = INT_MAX</प्रतिस्थापन></पैरामीटर>);"

#. Tag: para
#: scripting.docbook:1380
#, no-c-format
msgid ""
"Function to get an integer from the user. <parameter>caption</parameter> is "
"the text that is displayed in the title bar. <parameter>label</parameter> is "
"the text that appears as the label for the spin box. <parameter>min</"
"parameter> and <parameter>max</parameter> are the minimum and maximum "
"allowable values the user may choose. Default values are <literal>INT_MIN</"
"literal> and <literal>INT_MAX</literal>."
msgstr ""
"उपयोगकर्ता से पूर्णांक प्राप्त करने का फ़ंक्शन। <पैरामीटर>कैप्शन</पैरामीटर> वह टेक्स्ट है जो "
"टाइटल बार में प्रदर्शित होता है। <पैरामीटर>लेबल</पैरामीटर> वह टेक्स्ट है जो स्पिन बॉक्स के "
"लिए लेबल के रूप में दिखाई देता है। <पैरामीटर>न्यूनतम</पैरामीटर> और <पैरामीटर>अधिकतम</"
"पैरामीटर> न्यूनतम और अधिकतम स्वीकार्य मान हैं जिन्हें उपयोगकर्ता चुन सकता है। डिफ़ॉल्ट मान "
"<शाब्दिक>INT_MIN</शाब्दिक> और <शाब्दिक>INT_MAX</शाब्दिक> हैं।"

#. Tag: synopsis
#: scripting.docbook:1386
#, no-c-format
msgid ""
"int kile.input.getPosInteger(<parameter>String <replaceable>caption</"
"replaceable></parameter>, <parameter>String <replaceable>label</"
"replaceable></parameter>, <parameter>int <replaceable>min = 1</replaceable></"
"parameter>, <parameter>int <replaceable>max = INT_MAX</replaceable></"
"parameter>);"
msgstr ""
"int kile.input.getPosInteger(<पैरामीटर>स्ट्रिंग <प्रतिस्थापन>कैप्शन</प्रतिस्थापन></"
"पैरामीटर>, <पैरामीटर>स्ट्रिंग <प्रतिस्थापन>लेबल</प्रतिस्थापन></पैरामीटर>, <पैरामीटर>int "
"<प्रतिस्थापन>न्यूनतम = 1</प्रतिस्थापन></पैरामीटर>, <पैरामीटर>int <प्रतिस्थापन>अधिकतम = "
"INT_MAX</प्रतिस्थापन></पैरामीटर>);"

#. Tag: para
#: scripting.docbook:1387
#, no-c-format
msgid ""
"Function to get a positive integer from the user. <parameter>caption</"
"parameter> is the text that is displayed in the title bar. <parameter>label</"
"parameter> is the text that appears as the label for the spin box. "
"<parameter>min</parameter> and <parameter>max</parameter> are the minimum "
"and maximum allowable values the user may choose. Default values are "
"<literal>1</literal> and <literal>INT_MAX</literal>."
msgstr ""
"उपयोगकर्ता से एक सकारात्मक पूर्णांक प्राप्त करने के लिए फ़ंक्शन। <parameter>caption</"
"parameter> वह टेक्स्ट है जो शीर्षक बार में प्रदर्शित होता है। <parameter>label</"
"parameter> वह टेक्स्ट है जो स्पिन बॉक्स के लिए लेबल के रूप में दिखाई देता है। "
"<parameter>min</parameter> और <parameter>max</parameter> न्यूनतम और अधिकतम "
"स्वीकार्य मान हैं जिन्हें उपयोगकर्ता चुन सकता है। डिफ़ॉल्ट मान <literal>1</literal> और "
"<literal>INT_MAX</literal> हैं।"

#. Tag: title
#: scripting.docbook:1395
#, no-c-format
msgid "Wizard"
msgstr "जादूगर"

#. Tag: synopsis
#: scripting.docbook:1398
#, no-c-format
msgid "void kile.wizard.tabular();"
msgstr "शून्य kile.wizard.tabular();"

#. Tag: para
#: scripting.docbook:1399
#, no-c-format
msgid ""
"Calls the <emphasis>Tabular wizard</emphasis>, which helps to write a "
"tabular environment (see <xref linkend=\"wizard_array\" role=\"select: title "
"pageabbrv\"/>)."
msgstr ""
"<emphasis>सारणीबद्ध विज़ार्ड</emphasis> को कॉल करता है, जो सारणीबद्ध वातावरण लिखने "
"में मदद करता है (देखें <xref linkend=\"wizard_array\" role=\"select: title "
"pageabbrv\"/>)."

#. Tag: synopsis
#: scripting.docbook:1405
#, no-c-format
msgid "void kile.wizard.array();"
msgstr "शून्य kile.wizard.array();"

#. Tag: para
#: scripting.docbook:1406
#, no-c-format
msgid ""
"Calls the <emphasis>Array wizard</emphasis>, which helps to write an array "
"environment (see <xref linkend=\"wizard_array\" role=\"select: title "
"pageabbrv\"/>)."
msgstr ""
"<emphasis>ऐरे विज़ार्ड</emphasis> को कॉल करता है, जो ऐरे वातावरण लिखने में मदद करता "
"है (देखें <xref linkend=\"wizard_array\" role=\"select: title pageabbrv\"/>)."

#. Tag: synopsis
#: scripting.docbook:1412
#, no-c-format
msgid "void kile.wizard.tabbing();"
msgstr "शून्य kile.wizard.tabbing();"

#. Tag: para
#: scripting.docbook:1413
#, no-c-format
msgid ""
"Calls the <emphasis>Tabbing wizard</emphasis>, which helps to write a "
"tabbing environment (see <xref linkend=\"wizard_array\" role=\"select: title "
"pageabbrv\"/>)."
msgstr ""
"<emphasis>टैबिंग विज़ार्ड</emphasis> को कॉल करता है, जो टैबिंग वातावरण लिखने में मदद "
"करता है (देखें <xref linkend=\"wizard_array\" role=\"select: title pageabbrv\"/"
">)."

#. Tag: synopsis
#: scripting.docbook:1419
#, no-c-format
msgid "void kile.wizard.floatEnvironment();"
msgstr "शून्य kile.wizard.floatEnvironment();"

#. Tag: para
#: scripting.docbook:1420
#, no-c-format
msgid ""
"Calls the <emphasis>Floats wizard</emphasis>, which helps to insert floating "
"elements (see <xref linkend=\"wizard_float\" role=\"select: title pageabbrv"
"\"/>)."
msgstr ""
"<emphasis>फ्लोट्स विज़ार्ड</emphasis> को कॉल करता है, जो फ्लोटिंग तत्वों को सम्मिलित "
"करने में मदद करता है (देखें <xref linkend=\"wizard_float\" role=\"select: title "
"pageabbrv\"/>)."

#. Tag: synopsis
#: scripting.docbook:1426
#, no-c-format
msgid "void kile.wizard.mathEnvironment();"
msgstr "शून्य kile.wizard.mathEnvironment();"

#. Tag: para
#: scripting.docbook:1427
#, no-c-format
msgid ""
"Calls the <emphasis>Math wizard</emphasis>, which helps to insert math "
"environments (see <xref linkend=\"wizard_math\" role=\"select: title "
"pageabbrv\"/>)."
msgstr ""
"<emphasis>गणित विज़ार्ड</emphasis> को कॉल करता है, जो गणितीय वातावरण सम्मिलित "
"करने में सहायता करता है (देखें <xref linkend=\"wizard_math\" role=\"select: title "
"pageabbrv\"/>)."

#. Tag: synopsis
#: scripting.docbook:1433
#, no-c-format
msgid "void kile.wizard.postscript();"
msgstr "शून्य kile.wizard.postscript();"

#. Tag: para
#: scripting.docbook:1434
#, no-c-format
msgid ""
"Calls the <emphasis>Postscript Tools wizard</emphasis>, which may help to "
"manipulate or rearrange Postscript documents (see <xref linkend="
"\"wizard_postscript\" role=\"select: title pageabbrv\"/>)."
msgstr ""
"<emphasis>पोस्टस्क्रिप्ट उपकरण विज़ार्ड</emphasis> को कॉल करता है, जो पोस्टस्क्रिप्ट "
"दस्तावेज़ों में हेरफेर या पुनर्व्यवस्थित करने में मदद कर सकता है (देखें <xref linkend="
"\"wizard_postscript\" role=\"select: title pageabbrv\"/>)."

#. Tag: title
#: scripting.docbook:1442
#, no-c-format
msgid "Script"
msgstr "लिखी हुई कहानी"

#. Tag: synopsis
#: scripting.docbook:1445
#, no-c-format
msgid "String kile.script.name();"
msgstr "स्ट्रिंग kile.script.name();"

#. Tag: para
#: scripting.docbook:1446
#, no-c-format
msgid "Returns the basename of a running script (without path and extension)."
msgstr "चल रही स्क्रिप्ट का आधार नाम लौटाता है (पथ और एक्सटेंशन के बिना)."

#. Tag: synopsis
#: scripting.docbook:1452
#, no-c-format
msgid "String kile.script.caption();"
msgstr "स्ट्रिंग kile.script.caption();"

#. Tag: para
#: scripting.docbook:1453
#, no-c-format
msgid ""
"Returns a string, which can be used as a caption of alert boxes. It looks "
"like <userinput>Script: scriptname.js</userinput>."
msgstr ""
"एक स्ट्रिंग लौटाता है, जिसका उपयोग अलर्ट बॉक्स के कैप्शन के रूप में किया जा सकता है। यह "
"<userinput>Script: scriptname.js</userinput> जैसा दिखता है।"

#. Tag: title
#: scripting.docbook:1461
#, no-c-format
msgid "File"
msgstr "फ़ाइल"

#. Tag: synopsis
#: scripting.docbook:1464
#, no-c-format
msgid ""
"Object kile.file.read(<parameter>String <replaceable>filename</replaceable></"
"parameter>);"
msgstr ""
"ऑब्जेक्ट kile.file.read(<पैरामीटर>स्ट्रिंग <प्रतिस्थापन योग्य>फ़ाइलनाम</प्रतिस्थापन "
"योग्य></पैरामीटर>);"

#. Tag: para
#: scripting.docbook:1465
#, no-c-format
msgid "Read the contents of a text file. It is used like"
msgstr "किसी टेक्स्ट फ़ाइल की सामग्री पढ़ें। इसका उपयोग इस प्रकार किया जाता है"

#. Tag: para
#: scripting.docbook:1467
#, no-c-format
msgid ""
"Example: <function>var res = kile.file.read(\"path/to/file.txt\");</function>"
msgstr ""
"उदाहरण: <function>var res = kile.file.read(\"path/to/file.txt\");</function>"

#. Tag: para
#: scripting.docbook:1469
#, no-c-format
msgid ""
"The return value <userinput>res</userinput> is an object (better: a map) "
"with three properties:"
msgstr ""
"वापसी मान <userinput>res</userinput> एक ऑब्जेक्ट (बेहतर: एक मानचित्र) है जिसमें तीन "
"गुण हैं:"

#. Tag: para
#: scripting.docbook:1473
#, no-c-format
msgid ""
"<guilabel>status:</guilabel>&nbsp; Gives the status code of the operation, "
"which can be 0 (no error), 1 (access failed) or 2 (access denied). So, if no "
"error occurred, the value of <userinput>res.status</userinput> or "
"<userinput>res[\"status\"]</userinput> will be 0."
msgstr ""
"<guilabel>स्थिति:</guilabel>&nbsp; ऑपरेशन का स्टेटस कोड देता है, जो 0 (कोई त्रुटि "
"नहीं), 1 (पहुँच विफल) या 2 (पहुँच अस्वीकृत) हो सकता है। इसलिए, यदि कोई त्रुटि नहीं हुई, "
"तो <userinput>res.status</userinput> या <userinput>res[\"status\"]</"
"userinput> का मान 0 होगा।"

#. Tag: para
#: scripting.docbook:1474
#, no-c-format
msgid "<guilabel>result:</guilabel>&nbsp; Contains the text of the given file."
msgstr "<guilabel>परिणाम:</guilabel>&nbsp; दी गई फ़ाइल का पाठ शामिल है।"

#. Tag: para
#: scripting.docbook:1475
#, no-c-format
msgid ""
"<guilabel>message:</guilabel>&nbsp; Contains an error message, if an error "
"occurred."
msgstr ""
"<guilabel>संदेश:</guilabel>&nbsp; यदि कोई त्रुटि हुई है, तो इसमें एक त्रुटि संदेश शामिल "
"है।"

#. Tag: synopsis
#: scripting.docbook:1481
#, no-c-format
msgid "Object kile.file.read();"
msgstr "ऑब्जेक्ट kile.file.read();"

#. Tag: para
#: scripting.docbook:1482
#, no-c-format
msgid ""
"The same as <literal>read(filename)</literal>, but no filename is given. A "
"dialog will appear to select the file to read."
msgstr ""
"<literal>read(filename)</literal> जैसा ही, लेकिन कोई फ़ाइल नाम नहीं दिया गया है। "
"पढ़ने के लिए फ़ाइल चुनने के लिए एक डायलॉग दिखाई देगा।"

#. Tag: synopsis
#: scripting.docbook:1488
#, no-c-format
msgid ""
"Object kile.file.write(<parameter>String <replaceable>filename</"
"replaceable></parameter>, <parameter>String <replaceable>text</replaceable></"
"parameter>);"
msgstr ""
"ऑब्जेक्ट kile.file.write(<पैरामीटर>स्ट्रिंग <प्रतिस्थापन योग्य>फ़ाइल नाम</प्रतिस्थापन "
"योग्य></पैरामीटर>, <पैरामीटर>स्ट्रिंग <प्रतिस्थापन योग्य>पाठ</प्रतिस्थापन योग्य></"
"पैरामीटर>);"

#. Tag: para
#: scripting.docbook:1489
#, no-c-format
msgid "Write the given text into a file. It is used like"
msgstr "दिए गए टेक्स्ट को एक फ़ाइल में लिखें। इसका उपयोग इस प्रकार किया जाता है"

#. Tag: para
#: scripting.docbook:1491
#, no-c-format
msgid ""
"Example: <function>var res = kile.file.write(\"path/to/file.txt\",\"Some "
"text...\");</function>"
msgstr ""
"उदाहरण: <function>var res = kile.file.write(\"path/to/file.txt\",\"कुछ पाठ..."
"\");</function>"

#. Tag: para
#: scripting.docbook:1493
#, no-c-format
msgid ""
"The return value <userinput>res</userinput> is an object (better: a map) "
"with two properties: <literal>status</literal> and <literal>message</"
"literal> (see <literal>read()</literal> for more information)."
msgstr ""
"वापसी मान <userinput>res</userinput> एक ऑब्जेक्ट (बेहतर: एक मानचित्र) है जिसमें दो "
"गुण हैं: <literal>status</literal> और <literal>message</literal> (अधिक जानकारी "
"के लिए <literal>read()</literal> देखें)।"

#. Tag: synopsis
#: scripting.docbook:1499
#, no-c-format
msgid ""
"Object kile.file.write(<parameter>String <replaceable>text</replaceable></"
"parameter>);"
msgstr ""
"ऑब्जेक्ट kile.file.write(<पैरामीटर>स्ट्रिंग <प्रतिस्थापन योग्य>टेक्स्ट</प्रतिस्थापन योग्य></"
"पैरामीटर>);"

#. Tag: para
#: scripting.docbook:1500
#, no-c-format
msgid ""
"The same as <literal>write(filename,text)</literal>, but no filename is "
"given. A dialog will appear to choose a filename."
msgstr ""
"<literal>write(filename,text)</literal> जैसा ही, लेकिन कोई फ़ाइल नाम नहीं दिया "
"गया है। फ़ाइल नाम चुनने के लिए एक डायलॉग दिखाई देगा।"

#. Tag: synopsis
#: scripting.docbook:1506
#, no-c-format
msgid ""
"String kile.file.getOpenFileName(<parameter>String <replaceable>startDir</"
"replaceable></parameter>, <parameter>String <replaceable>filter</"
"replaceable></parameter>);"
msgstr ""
"स्ट्रिंग kile.file.getOpenFileName(<पैरामीटर>स्ट्रिंग <प्रतिस्थापन योग्य>startDir</"
"प्रतिस्थापन योग्य></पैरामीटर>, <पैरामीटर>स्ट्रिंग <प्रतिस्थापन योग्य>फ़िल्टर</प्रतिस्थापन "
"योग्य></पैरामीटर>);"

#. Tag: para
#: scripting.docbook:1507
#, no-c-format
msgid ""
"Creates a modal file dialog and return the selected filename or an empty "
"string if none is chosen. Note that with this method the user must select an "
"existing filename."
msgstr ""
"एक मोडल फ़ाइल डायलॉग बनाता है और चयनित फ़ाइल नाम या कोई भी नहीं चुने जाने पर एक "
"खाली स्ट्रिंग लौटाता है। ध्यान दें कि इस विधि के साथ उपयोगकर्ता को एक मौजूदा फ़ाइल नाम "
"चुनना होगा।"

#. Tag: para
#: scripting.docbook:1509
#, no-c-format
msgid "Parameters:"
msgstr "पैरामीटर:"

#. Tag: para
#: scripting.docbook:1513
#, no-c-format
msgid ""
"<guilabel>startDir:</guilabel>&nbsp; Starting directory of the open dialog."
msgstr "<guilabel>startDir:</guilabel>&nbsp; खुले संवाद की प्रारंभिक निर्देशिका."

#. Tag: para
#: scripting.docbook:1514
#, no-c-format
msgid ""
"<guilabel>filter:</guilabel>&nbsp; A shell glob or a mime-type-filter that "
"specifies which files to display. Refer to the KFileDialog documentation for "
"more information on this parameter."
msgstr ""
"<guilabel>फ़िल्टर:</guilabel>&nbsp; एक शेल ग्लोब या एक माइम-टाइप-फ़िल्टर जो "
"निर्दिष्ट करता है कि कौन सी फ़ाइलें प्रदर्शित की जाएँगी। इस पैरामीटर पर अधिक जानकारी के "
"लिए KFileDialog दस्तावेज़ देखें।"

#. Tag: para
#: scripting.docbook:1516
#, no-c-format
msgid ""
"Both parameters are optional. If you omit <literal>filter</literal>, all "
"files will be displayed. If additionally <literal>startDir</literal> is "
"omitted, the dialog will take the current document directory as starting "
"point."
msgstr ""
"दोनों पैरामीटर वैकल्पिक हैं। यदि आप <literal>filter</literal> को छोड़ देते हैं, तो सभी "
"फ़ाइलें प्रदर्शित होंगी। यदि इसके अतिरिक्त <literal>startDir</literal> को छोड़ दिया "
"जाता है, तो संवाद वर्तमान दस्तावेज़ निर्देशिका को आरंभिक बिंदु के रूप में लेगा।"

#. Tag: synopsis
#: scripting.docbook:1522
#, no-c-format
msgid ""
"String kile.file.getSaveFileName(<parameter>String <replaceable>startDir</"
"replaceable></parameter>, <parameter>String <replaceable>filter</"
"replaceable></parameter>);"
msgstr ""
"स्ट्रिंग kile.file.getSaveFileName(<पैरामीटर>स्ट्रिंग <प्रतिस्थापन योग्य>startDir</"
"प्रतिस्थापन योग्य></पैरामीटर>, <पैरामीटर>स्ट्रिंग <प्रतिस्थापन योग्य>फ़िल्टर</प्रतिस्थापन "
"योग्य></पैरामीटर>);"

#. Tag: para
#: scripting.docbook:1523
#, no-c-format
msgid ""
"Creates a modal file dialog and returns the selected filename or an empty "
"string if none is chosen. Note that with this method the user need not "
"select an existing filename. See <literal>getOpenFileName()</literal> for an "
"explanation of the parameters."
msgstr ""
"एक मोडल फ़ाइल डायलॉग बनाता है और चयनित फ़ाइल नाम या कोई भी नहीं चुने जाने पर एक "
"खाली स्ट्रिंग लौटाता है। ध्यान दें कि इस विधि के साथ उपयोगकर्ता को मौजूदा फ़ाइल नाम चुनने "
"की आवश्यकता नहीं है। मापदंडों के स्पष्टीकरण के लिए <literal>getOpenFileName()</"
"literal> देखें।"

#. Tag: title
#: scripting.docbook:1537
#, no-c-format
msgid "Examples"
msgstr "उदाहरण"

#. Tag: para
#: scripting.docbook:1539
#, no-c-format
msgid ""
"Some examples may help you to understand how to use the scripting API. These "
"examples and some more are found in the scripting directory of &kile;: "
"<filename>KILE_APP_DIR/scripts/</filename>. Each script contains a short "
"description."
msgstr ""
"कुछ उदाहरण आपको यह समझने में मदद कर सकते हैं कि स्क्रिप्टिंग API का उपयोग कैसे करें। ये "
"उदाहरण और कुछ और उदाहरण &kile;: <filename>KILE_APP_DIR/scripts/</filename> की "
"स्क्रिप्टिंग निर्देशिका में पाए जाते हैं। प्रत्येक स्क्रिप्ट में एक संक्षिप्त विवरण होता है।"

#. Tag: title
#: scripting.docbook:1542
#, no-c-format
msgid "Example 1: replace environment name"
msgstr "उदाहरण 1: पर्यावरण नाम बदलें"

#. Tag: para
#: scripting.docbook:1544
#, no-c-format
msgid ""
"Replace a surrounding &latex; environment with another, where the relative "
"cursor position will not be changed. <userinput>\\begin{abc}...\\end{abc}</"
"userinput> for example can be changed to <userinput>\\begin{xyz}...\\end{xyz}"
"</userinput>."
msgstr ""
"आसपास के &latex; वातावरण को दूसरे से बदलें, जहां सापेक्ष कर्सर स्थिति नहीं बदली जाएगी। "
"उदाहरण के लिए <userinput>\\begin{abc}...\\end{abc}</userinput> को <userinput>"
"\\begin{xyz}...\\end{xyz}</userinput> में बदला जा सकता है।"

#. Tag: programlisting
#: scripting.docbook:1546
#, no-c-format
msgid ""
"var range = document.environmentRange(false);\n"
"if ( range.isValid() ) {\n"
"        var envname = kile.input.getLatexCommand(\"Enter Environment\",\"New "
"environment name:\");\n"
"        if ( envname != '' ) {\n"
"                replaceEnvCommand(envname,range);\n"
"        }\n"
"}\n"
"else {\n"
"        kile.alert.sorry(\"No surrounding LaTeX environment found.\");\n"
"}\n"
"\n"
"function replaceEnvCommand(newEnv,r)\n"
"{\n"
"        var c = view.cursorPosition();\n"
"\n"
"        var envname = document.environmentName();\n"
"\n"
"        if ( envname != \"\" ) {\n"
"                var beginRange = new Range(r.start,new Cursor(r.start.line,r."
"start.column+8+envname.length));\n"
"                var endRange = new Range(new Cursor(r.end.line,r.end."
"column-6-envname.length),r.end);\n"
"\n"
"                document.editBegin();\n"
"                document.replaceText(endRange,\"\\\\end{\"+newEnv+\"}\");\n"
"                document.replaceText(beginRange,\"\\\\begin{\"+newEnv+"
"\"}\");\n"
"                document.editEnd();\n"
"        }\n"
"}"
msgstr ""
"var range = document.environmentRange(false);\n"
"if ( range.isValid() ) {\n"
"var envname = kile.input.getLatexCommand(\"Enter Environment\",\"New "
"environment name:\");\n"
"if ( envname != '' ) {\n"
"replaceEnvCommand(envname,range);\n"
"}\n"
"}\n"
"else {\n"
"kile.alert.sorry(\"कोई आसपास का LaTeX वातावरण नहीं मिला।\");\n"
"}\n"
"\n"
"function replaceEnvCommand(newEnv,r)\n"
"{\n"
"var c = view.cursorPosition();\n"
"\n"
"var envname = document.environmentName();\n"
"\n"
"if ( envname != \"\" ) {\n"
"var beginRange = new Range(r.start,new Cursor(r.start.line,r.start.column"
"+8+envname.length));\n"
"var endRange = new Range(new Cursor(r.end.line,r.end.column-6-envname."
"length),r.end);\n"
"\n"
"document.editBegin();\n"
"document.replaceText(endRange,\"\\\\end{\"+newEnv+\"}\");\n"
"document.replaceText(beginRange,\"\\\\begin{\"+newEnv+\"}\");\n"
"document.editEnd();\n"
"}\n"
"}"

#. Tag: title
#: scripting.docbook:1550
#, no-c-format
msgid "Example 2: replace a &latex; font command"
msgstr "उदाहरण 2: &latex; फ़ॉन्ट कमांड को प्रतिस्थापित करें"

#. Tag: para
#: scripting.docbook:1552
#, no-c-format
msgid ""
"Replace a surrounding &latex; font command with another font command, when "
"the cursor is placed inside the texgroup. The relative cursor position will "
"not be changed. <userinput>\\textbf{abc}</userinput> for example can be "
"changed to <userinput>\\textit{abc}</userinput>."
msgstr ""
"जब कर्सर को टेक्सग्रुप के अंदर रखा जाता है, तो आसपास के &latex; फ़ॉन्ट कमांड को दूसरे फ़ॉन्ट "
"कमांड से बदलें। सापेक्ष कर्सर की स्थिति नहीं बदली जाएगी। उदाहरण के लिए <userinput>"
"\\textbf{abc}</userinput> को <userinput>\\textit{abc}</userinput> में बदला जा "
"सकता है।"

#. Tag: programlisting
#: scripting.docbook:1554
#, no-c-format
msgid ""
"var fontCommands = new Array(\"\\\\textbf\",\"\\\\textit\",\"\\\\textsl\","
"\"\\\\texttt\",\n"
"                             \"\\\\textsc\",\"\\\\textrm\",\"\\\\textsf\","
"\"\\\\emph\");\n"
"\n"
"var range = document.texgroupRange(false);\n"
"if ( range.isValid() ) {\n"
"        replaceFontCommand(range);\n"
"}\n"
"else {\n"
"        kile.alert.sorry(\"No surrounding TeX group found.\");\n"
"}\n"
"\n"
"function replaceFontCommand(r)\n"
"{\n"
"        var c = view.cursorPosition();\n"
"\n"
"        document.editBegin();\n"
"        view.setCursorPosition(r.start);\n"
"        var cmd = document.latexCommand();\n"
"        var index = fontCommands.indexOf(cmd);\n"
"        if ( index >= 0 ) {\n"
"                var cmdRange = document.latexCommandRange();\n"
"                if ( cmdRange.isValid() ) {\n"
"                        var newcommand = kile.input.getListboxItem(\"Choose"
"\",\n"
"                                                    \"Choose font command:\","
"buildCmdList(cmd));\n"
"                        if ( newcommand != \"\" ) {\n"
"                                document.replaceText(cmdRange,newcommand);\n"
"                                c.column = c.column - (cmd.length - "
"newcommand.length);\n"
"                        }\n"
"                }\n"
"/                view.setCursorPosition(c);\n"
"        }\n"
"        else {\n"
"                kile.alert.sorry(\"No surrounding font command found.\");\n"
"        }\n"
"        document.editEnd();\n"
"}\n"
"\n"
"function buildCmdList(current)\n"
"{\n"
"        var result = new Array();\n"
"        for ( i=0; i&lt;fontCommands.length; ++i ) {\n"
"                if ( fontCommands[i] != current ) {\n"
"                        result.push(fontCommands[i]);\n"
"                }\n"
"        }\n"
"        return result;\n"
"}"
msgstr ""
"var fontCommands = new Array(\"\\\\textbf\",\"\\\\textit\",\"\\\\textsl\","
"\"\\\\texttt\",\n"
"\"\\\\textsc\",\"\\\\textrm\",\"\\\\textsf\",\"\\\\emph\");\n"
"\n"
"var range = document.texgroupRange(false);\n"
"if ( range.isValid() ) {\n"
"replaceFontCommand(range);\n"
"}\n"
"else {\n"
"kile.alert.sorry(\"कोई आसपास का TeX समूह नहीं मिला।\");\n"
"}\n"
"\n"
"function replaceFontCommand(r)\n"
"{\n"
"var c = view.cursorPosition();\n"
"\n"
"document.editBegin();\n"
"view.setCursorPosition(r.start);\n"
"var cmd = document.latexCommand();\n"
"var index = fontCommands.indexOf(cmd);\n"
"यदि (सूचकांक >= 0) {\n"
"var cmdRange = document.latexCommandRange();\n"
"यदि (cmdRange.isValid()) {\n"
"var newcommand = kile.input.getListboxItem(\"Choose\",\n"
"\"फ़ॉन्ट कमांड चुनें:\",buildCmdList(cmd));\n"
"यदि (newcommand != \"\") {\n"
"document.replaceText(cmdRange,newcommand);\n"
"c.column = c.column - (cmd.length - newcommand.length);\n"
"}\n"
"}\n"
"/ view.setCursorPosition(c);\n"
"}\n"
"अन्यथा {\n"
"kile.alert.sorry(\"कोई आस-पास का फ़ॉन्ट कमांड नहीं मिला.\");\n"
"}\n"
"document.editEnd();\n"
"}\n"
"फ़ंक्शन buildCmdList(current)\n"
"{\n"
"var result = new Array();\n"
"for (i=0; i&lt;fontCommands.length; ++i) {\n"
"if (fontCommands[i] != current) {\n"
"result.push(fontCommands[i]);\n"
"}\n"
"}\n"
"return result;\n"
"}"

#. Tag: title
#: scripting.docbook:1559
#, no-c-format
msgid "Example 3: surround selected text"
msgstr "उदाहरण 3: चयनित पाठ को घेरें"

#. Tag: para
#: scripting.docbook:1561
#, no-c-format
msgid ""
"Surround selected text with a TeX command, where the relative cursor "
"position will not be changed. <userinput>abc</userinput> for example can be "
"changed to <userinput>\\texcommand{abc}</userinput>."
msgstr ""
"चयनित पाठ को TeX कमांड से घेरें, जहां सापेक्ष कर्सर स्थिति नहीं बदली जाएगी। उदाहरण के "
"लिए <userinput>abc</userinput> को <userinput>\\texcommand{abc}</userinput> में "
"बदला जा सकता है।"

#. Tag: programlisting
#: scripting.docbook:1563
#, no-c-format
msgid ""
"var range = view.selectionRange();\n"
"\n"
"if ( range.isValid() ) {\n"
"        var cmd = kile.input.getLatexCommand(\"Choose\",\"Choose surrounding "
"LaTeX command:\");\n"
"        if ( cmd != \"\" ) {\n"
"                surroundTexCommand(\"\\\\\"+cmd,range);\n"
"        }\n"
"}\n"
"else {\n"
"        kile.alert.sorry(\"No selection found.\");\n"
"}\n"
"\n"
"function surroundTexCommand(cmd,r)\n"
"{\n"
"        var c = view.cursorPosition();\n"
"\n"
"        document.editBegin();\n"
"        view.clearSelection();\n"
"        document.insertText(r.end,\"}\");\n"
"        document.insertText(r.start,cmd+\"{\");\n"
"\n"
"        c.column = c.column + cmd.length + 2;\n"
"        view.setCursorPosition(c);\n"
"        document.editEnd();\n"
"}"
msgstr ""
"var range = view.selectionRange();\n"
"\n"
"if ( range.isValid() ) {\n"
"var cmd = kile.input.getLatexCommand(\"Choose\",\"Choose around LaTeX "
"command:\");\n"
"\n"
"if ( cmd != \"\" ) {\n"
"aroundTexCommand(\"\\\\\"+cmd,range);\n"
"}\n"
"}\n"
"else {\n"
"kile.alert.sorry(\"कोई चयन नहीं मिला.\");\n"
"}\n"
"\n"
"function aroundTexCommand(cmd,r)\n"
"{\n"
"var c = view.cursorPosition();\n"
"\n"
"document.editBegin();\n"
"view.clearSelection();\n"
"document.insertText(r.end,\"}\");\n"
"document.insertText(r.start,cmd+\"{\");\n"
"\n"
"c.column = c.column + cmd.length + 2;\n"
"view.setCursorPosition(c);\n"
"दस्तावेज़.editEnd();\n"
"}"
