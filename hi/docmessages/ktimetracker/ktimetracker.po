#, no-c-format
msgid "active task"
msgstr "सक्रिय कार्य"

#. Tag: para
#: index.docbook:568
#, no-c-format
msgid "A task which has a timer running."
msgstr "एक कार्य जिसमें टाइमर चल रहा है।"

