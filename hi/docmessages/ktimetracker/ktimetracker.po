#, no-c-format
msgid "Edit"
msgstr "संपादन करना"

#. Tag: guiicon
#: index.docbook:488
#, no-c-format
msgid "Open"
msgstr "खुला"

#. Tag: guiicon
#: index.docbook:489
#, no-c-format
msgid "Save"
msgstr "बचाना"

#. Tag: para
#: index.docbook:492
#, no-c-format
msgid "The statusbar reports the name of the file where the data was saved."
msgstr "स्टेटसबार उस फ़ाइल का नाम बताता है जहाँ डेटा सहेजा गया था।"

