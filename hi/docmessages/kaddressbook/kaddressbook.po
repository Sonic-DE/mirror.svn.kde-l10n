#, no-c-format
msgid ""
"<screeninfo>A screenshot of &kaddressbook;'s <quote>File</quote> menu.</"
"screeninfo>"
msgstr ""
"<screeninfo>&kaaddressbook; के <quote>फ़ाइल</quote> मेनू का स्क्रीनशॉट.</"
"screeninfo>"

#. Tag: phrase
#: index.docbook:1084
#, no-c-format
msgid ""
"<phrase>A screenshot of &kaddressbook;'s <quote>File</quote> menu.</phrase>"
msgstr "<phrase>&kaaddressbook; के <quote>फ़ाइल</quote> मेनू का स्क्रीनशॉट.</phrase>"

#. Tag: para
#: index.docbook:1087
#, no-c-format
