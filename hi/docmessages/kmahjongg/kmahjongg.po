msgstr "बोर्ड संपादक दिखाता है."

#. Tag: screeninfo
#: index.docbook:293
#, no-c-format
msgid "<screeninfo>The board editor</screeninfo>"
msgstr "<screeninfo>बोर्ड संपादक</screeninfo>"

#. Tag: phrase
#: index.docbook:296
#, no-c-format
msgid "<phrase>The board editor</phrase>"
msgstr "<phrase>बोर्ड संपादक</phrase>"

#. Tag: para
#: index.docbook:300
#, no-c-format
msgid "Procedure to edit layout:"
msgstr "लेआउट संपादित करने की प्रक्रिया:"

#. Tag: para
#: index.docbook:303
#, no-c-format
msgid ""
"Use the board editor toolbar to create a new layout or to load and edit an "
"existing one."
msgstr ""
"नया लेआउट बनाने या मौजूदा लेआउट को लोड और संपादित करने के लिए बोर्ड संपादक टूलबार का "
"उपयोग करें।"

#. Tag: para
#: index.docbook:304
#, no-c-format
msgid ""
"Save the layout in your user's local home folder in <filename>"
"$<envar>XDG_DATA_HOME</envar>/kmahjongg/layouts</filename>"
msgstr ""
"लेआउट को अपने उपयोगकर्ता के स्थानीय होम फ़ोल्डर में <filename>$<envar>XDG_DATA_HOME</"
"envar>/kmahjongg/layouts</filename> में सहेजें"

#. Tag: para
#: index.docbook:305
#, no-c-format
msgid ""
"Create the <filename><replaceable>name_of_your_layout</replaceable>.desktop</"
"filename> file in the same folder."
msgstr ""
"उसी फ़ोल्डर में <filename><replaceable>name_of_your_layout</replaceable>."
"desktop</filename> फ़ाइल बनाएँ।"

#. Tag: para
#: index.docbook:306
#, no-c-format
msgid "Put the following lines in this file using your favorite text editor:"
msgstr "अपने पसंदीदा टेक्स्ट एडिटर का उपयोग करके इस फ़ाइल में निम्नलिखित पंक्तियाँ डालें:"

#. Tag: programlisting
#: index.docbook:307
#, no-c-format
msgid ""
"[KMahjonggLayout]\n"
"Name=<replaceable>name_of_your_layout</replaceable>\n"
"Description=<replaceable>description_of_your_layout</replaceable>\n"
"VersionFormat=1\n"
"Author=<replaceable>your_name</replaceable>\n"
"AuthorEmail=<replaceable>your_email</replaceable>\n"
"FileName=<replaceable>name_of_your_layout</replaceable>.layout"
msgstr ""
"[KMahjonggLayout]\n"
"नाम=<प्रतिस्थापनीय>आपके_लेआउट_का_नाम</प्रतिस्थापनीय>\n"
"विवरण=<प्रतिस्थापनीय>आपके_लेआउट_का_विवरण</प्रतिस्थापनीय>\n"
"संस्करण प्रारूप=1\n"
"लेखक=<प्रतिस्थापनीय>आपका_नाम</प्रतिस्थापनीय>\n"
"लेखक ईमेल=<प्रतिस्थापनीय>आपका_ईमेल</प्रतिस्थापनीय>\n"
"फ़ाइल नाम=<प्रतिस्थापनीय>आपके_लेआउट_का_नाम</प्रतिस्थापनीय>.लेआउट"

#. Tag: para
#: index.docbook:308
#, no-c-format
msgid "Reload &kmahjongg; to use your new layout."
msgstr "अपने नए लेआउट का उपयोग करने के लिए &kmahjongg; को पुनः लोड करें."

#. Tag: menuchoice
#: index.docbook:314
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>Q</keycap></keycombo></"
"shortcut> <guimenu>Game</guimenu> <guimenuitem>Quit</guimenuitem>"
msgstr ""
"<shortcut><keycombo Action='simul'>&Ctrl;<keycap>Q</keycap></keycombo></"
"shortcut> <guimenu>गेम</guimenu> <guimenuitem>छोड़ें</guimenuitem>"

#. Tag: para
#: index.docbook:319
#, no-c-format
msgid "<action>Quits</action> &kmahjongg;."
msgstr "<action>छोड़ता है</action> &kmahjongg;."

#. Tag: menuchoice
#: index.docbook:323
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>Z</keycap></keycombo></"
"shortcut> <guimenu>Move</guimenu> <guimenuitem>Undo</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>Z</keycap></keycombo></"
"shortcut> <guimenu>स्थानांतरित करें</guimenu> <guimenuitem>पूर्ववत करें</guimenuitem>"

#. Tag: para
#: index.docbook:328
#, no-c-format
msgid "<action>Undo</action> your last move."
msgstr "<action>अपनी अंतिम चाल को पूर्ववत करें</action>."

#. Tag: menuchoice
#: index.docbook:331
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;&Shift;<keycap>Z</keycap></"
"keycombo></shortcut> <guimenu>Move</guimenu> <guimenuitem>Redo</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;&Shift;<keycap>Z</keycap></"
"keycombo></shortcut> <guimenu>स्थानांतरित करें</guimenu> <guimenuitem>फिर से करें</"
"guimenuitem>"

#. Tag: para
#: index.docbook:336
#, no-c-format
msgid "<action>Redo</action> a move that was undone."
msgstr "<action>पुनः करें</action> जो कदम पूर्ववत किया गया था।"

#. Tag: menuchoice
#: index.docbook:339
#, no-c-format
msgid ""
"<shortcut><keycap>H</keycap></shortcut> <guimenu>Move</guimenu> "
"<guimenuitem>Hint</guimenuitem>"
msgstr ""
"<shortcut><keycap>H</keycap></shortcut> <guimenu>स्थानांतरित करें</guimenu> "
"<guimenuitem>संकेत</guimenuitem>"

#. Tag: para
#: index.docbook:344
#, no-c-format
msgid "<action>Gives a Hint</action> by flashing a matching pair of tiles."
msgstr "<action>एक संकेत देता है</action> टाइल्स की एक जोड़ी को चमकाकर।"

#. Tag: menuchoice
#: index.docbook:347
#, no-c-format
msgid ""
"<shortcut><keycap>D</keycap></shortcut> <guimenu>Move</guimenu> "
"<guimenuitem>Demo</guimenuitem>"
msgstr ""
"<शॉर्टकट><कीकैप>डी</कीकैप></शॉर्टकट> <गुइमेनू>मूव</गुइमेनू> <गुइमेनुइटम>डेमो</गुइमेनुइटम>"

#. Tag: para
#: index.docbook:352
#, no-c-format
msgid "<action>Starts the game Demo</action> mode."
msgstr "<action>गेम डेमो</action> मोड प्रारंभ करता है."

#. Tag: menuchoice
#: index.docbook:355
#, no-c-format
msgid "<guimenu>Move</guimenu> <guimenuitem>Shuffle</guimenuitem>"
msgstr "<guimenu>स्थानांतरित करें</guimenu> <guimenuitem>फेरबदल करें</guimenuitem>"

#. Tag: para
#: index.docbook:359
#, no-c-format
msgid "<action>Shuffles the tiles</action> on the board."
msgstr "<action>बोर्ड पर टाइलों को फेरबदल करता है</action>."

#. Tag: menuchoice
#: index.docbook:363
#, no-c-format
msgid ""
"<shortcut><keycap>G</keycap></shortcut> <guimenu>View</guimenu> "
"<guimenuitem>Rotate View Clockwise</guimenuitem>"
msgstr ""
"<shortcut><keycap>G</keycap></shortcut> <guimenu>देखें</guimenu> "
"<guimenuitem>दृश्य को दक्षिणावर्त घुमाएं</guimenuitem>"

#. Tag: para
#: index.docbook:368
#, no-c-format
msgid "<action>Rotates</action> the tile viewing angle clockwise."
msgstr "<action>टाइल देखने के कोण को दक्षिणावर्त घुमाता है</action>."

#. Tag: menuchoice
#: index.docbook:371
#, no-c-format
msgid ""
"<shortcut><keycap>F</keycap></shortcut> <guimenu>View</guimenu> "
"<guimenuitem>Rotate View Counterclockwise</guimenuitem>"
msgstr ""
"<shortcut><keycap>F</keycap></shortcut> <guimenu>देखें</guimenu> "
"<guimenuitem>दृश्य को वामावर्त घुमाएँ</guimenuitem>"

#. Tag: para
#: index.docbook:376
#, no-c-format
msgid "<action>Rotates</action> the tile viewing angle counter clockwise."
msgstr "<action>टाइल देखने के कोण को वामावर्त घुमाता है</action>."

#. Tag: para
#: index.docbook:379
#, no-c-format
msgid ""
"Additionally &kmahjongg; has the common &kde; <guimenu>Settings</guimenu> "
"and <guimenu>Help</guimenu> menu items, for more information read the "
"sections about the <ulink url=\"help:/fundamentals/menus.html#menus-settings"
"\">Settings Menu</ulink> and <ulink url=\"help:/fundamentals/menus."
"html#menus-help\">Help Menu</ulink> of the &kde; Fundamentals."
msgstr ""
"इसके अतिरिक्त &kmahjongg; में सामान्य &kde; <guimenu>सेटिंग्स</guimenu> और "
"<guimenu>सहायता</guimenu> मेनू आइटम हैं, अधिक जानकारी के लिए &kde; फंडामेंटल्स के "
"<ulink url=\"help:/fundamentals/menus.html#menus-settings\">सेटिंग्स मेनू</ulink> "
"और <ulink url=\"help:/fundamentals/menus.html#menus-help\">सहायता मेनू</ulink> "
"के बारे में अनुभाग पढ़ें।"

#. Tag: title
#: index.docbook:389
#, no-c-format
msgid "Frequently asked questions"
msgstr "अक्सर पूछे जाने वाले प्रश्नों"

#. Tag: para
#: index.docbook:394
#, no-c-format
msgid "I want to change the way this game looks. Can I?"
msgstr "मैं इस खेल का स्वरूप बदलना चाहता हूँ। क्या मैं ऐसा कर सकता हूँ?"

#. Tag: para
#: index.docbook:395
#, no-c-format
msgid ""
"Yes. To change the way &kmahjongg; looks use the <link linkend=\"menu"
"\">menubar</link> to open the <link linkend=\"configuration\">configuration "
"utility</link>."
msgstr ""
"हाँ। देखने का तरीका बदलने के लिए &amp;kmahjongg; का उपयोग करें<link linkend=\"menu"
"\"> मेनू पट्टी</link> खोलने के लिए<link linkend=\"configuration\"> कॉन्फ़िगरेशन "
"उपयोगिता</link> ."

#. Tag: para
#: index.docbook:398
#, no-c-format
msgid "Can I use the keyboard to play the game?"
msgstr "क्या मैं गेम खेलने के लिए कीबोर्ड का उपयोग कर सकता हूँ?"

#. Tag: para
#: index.docbook:399
#, no-c-format
msgid "No. This game does not feature a keyboard play mode yet."
msgstr "नहीं. इस गेम में अभी तक कीबोर्ड प्ले मोड की सुविधा नहीं है."

#. Tag: title
#: index.docbook:406
#, no-c-format
msgid "Game Configuration"
msgstr "गेम कॉन्फ़िगरेशन"

#. Tag: screeninfo
#: index.docbook:409
#, no-c-format
msgid "<screeninfo>Configure Dialog</screeninfo>"
msgstr "<screeninfo>संवाद कॉन्फ़िगर करें</screeninfo>"

#. Tag: phrase
#: index.docbook:415
#, no-c-format
msgid "<phrase>Configure Dialog</phrase>"
msgstr "<phrase>संवाद कॉन्फ़िगर करें</phrase>"

#. Tag: para
#: index.docbook:420
#, no-c-format
msgid ""
"<menuchoice><guimenu>Settings</guimenu><guimenuitem>Configure &kmahjongg;…</"
"guimenuitem></menuchoice> opens the <guilabel>Configure - &kmahjongg;</"
"guilabel> dialog."
msgstr ""
"<menuchoice><guimenu>सेटिंग्स</guimenu><guimenuitem>कॉन्फ़िगर &kmahjongg;…</"
"guimenuitem></menuchoice> <guilabel>कॉन्फ़िगर - &kmahjongg;</guilabel> संवाद "
"खोलता है।"

#. Tag: title
#: index.docbook:422
#, no-c-format
msgid "General options"
msgstr "आम विकल्प"

#. Tag: guilabel
#: index.docbook:425
#, no-c-format
msgid "Blink matching tiles when first one is selected"
msgstr "जब पहली टाइल चुनी जाती है तो मिलान वाली टाइलें झपकती हैं"

#. Tag: para
#: index.docbook:426
#, no-c-format
msgid ""
"This setting will make the game highlight the selected tile on mouse click, "
"and flash any matching tiles that have a free side at each move. No "
"additional tiles will be highlighted if there are no matching tiles with a "
"free side."
msgstr ""
"यह सेटिंग गेम को माउस क्लिक पर चयनित टाइल को हाइलाइट करने देगी, और प्रत्येक चाल पर "
"किसी भी मिलान वाली टाइल को फ्लैश करेगी, जिसका एक खाली पक्ष है। यदि कोई मिलान वाली "
"टाइल नहीं है, तो कोई अतिरिक्त टाइल हाइलाइट नहीं की जाएगी।"

#. Tag: guilabel
#: index.docbook:431
#, no-c-format
msgid "Generate solvable games"
msgstr "हल करने योग्य खेल उत्पन्न करें"

#. Tag: para
#: index.docbook:432
#, no-c-format
msgid "Selects only games that can be solved when you start a new game."
msgstr ""
"केवल उन खेलों का चयन करता है जिन्हें आपके द्वारा नया खेल शुरू करने पर हल किया जा सकता है।"

#. Tag: guilabel
#: index.docbook:437
#, no-c-format
msgid "Show removed tiles"
msgstr "हटाई गई टाइलें दिखाएं"

#. Tag: para
#: index.docbook:438
#, no-c-format
msgid ""
"If checked, this setting allows &kmahjongg; to show the removed tiles on the "
"board."
msgstr ""
"यदि चेक किया गया है, तो यह सेटिंग &kmahjongg; को बोर्ड पर हटाए गए टाइल्स को दिखाने "
"की अनुमति देती है।"

#. Tag: title
#: index.docbook:445
#, no-c-format
msgid "Board layout options"
msgstr "बोर्ड लेआउट विकल्प"

#. Tag: guilabel
#: index.docbook:448
#, no-c-format
msgid "Random Layout"
msgstr "यादृच्छिक लेआउट"

#. Tag: para
#: index.docbook:449
#, no-c-format
msgid ""
"Every new game will have a random layout of the existing one in the list."
msgstr "प्रत्येक नये खेल में सूची में विद्यमान खेल का एक यादृच्छिक लेआउट होगा।"

#. Tag: term
#: index.docbook:453
#, no-c-format
msgid "<guilabel>Board Layout</guilabel> selector"
msgstr "<guilabel>बोर्ड लेआउट</guilabel> चयनकर्ता"

#. Tag: para
#: index.docbook:454
#, no-c-format
msgid ""
"Use the <guilabel>Board Layout</guilabel> selector to pick a gameboard to "
"play. Different boards provide variable difficulty, depending on the number "
"of tiles and their position."
msgstr ""
"खेलने के लिए गेमबोर्ड चुनने के लिए <guilabel>बोर्ड लेआउट</guilabel> चयनकर्ता का उपयोग "
"करें। टाइलों की संख्या और उनकी स्थिति के आधार पर अलग-अलग बोर्ड अलग-अलग कठिनाई प्रदान "
"करते हैं।"

#. Tag: screeninfo
#: index.docbook:458
#, no-c-format
msgid "<screeninfo>Board Layout selector</screeninfo>"
msgstr "<screeninfo>बोर्ड लेआउट चयनकर्ता</screeninfo>"

#. Tag: phrase
#: index.docbook:463
#, no-c-format
msgid "<phrase>Board Layout selector</phrase>"
msgstr "<phrase>बोर्ड लेआउट चयनकर्ता</phrase>"

#. Tag: title
#: index.docbook:471
#, no-c-format
msgid "Tiles options"
msgstr "टाइल्स विकल्प"

#. Tag: term
#: index.docbook:474
#, no-c-format
msgid "<guilabel>Tiles</guilabel> selector"
msgstr "<guilabel>टाइल्स</guilabel> चयनकर्ता"

#. Tag: para
#: index.docbook:475
#, no-c-format
msgid ""
"Use the <guilabel>Tiles</guilabel> selector to choose graphics for the tiles."
msgstr ""
"टाइल्स के लिए ग्राफिक्स चुनने के लिए <guilabel>टाइल्स</guilabel> चयनकर्ता का उपयोग करें।"

#. Tag: screeninfo
#: index.docbook:479
#, no-c-format
msgid "Tile selector"
msgstr "टाइल चयनकर्ता"

#. Tag: phrase
#: index.docbook:484
#, no-c-format
msgid "Tiles selector"
msgstr "टाइल्स चयनकर्ता"

#. Tag: title
#: index.docbook:492
#, no-c-format
msgid "Background options"
msgstr "पृष्ठभूमि विकल्प"

#. Tag: term
#: index.docbook:495
#, no-c-format
msgid "<guilabel>Background</guilabel> selector"
msgstr "<guilabel>पृष्ठभूमि</guilabel> चयनकर्ता"

#. Tag: para
#: index.docbook:496
#, no-c-format
msgid ""
"Use the <guilabel>Background</guilabel> selector to choose a background "
"graphic for the game."
msgstr ""
"गेम के लिए पृष्ठभूमि ग्राफ़िक चुनने के लिए <guilabel>पृष्ठभूमि</guilabel> चयनकर्ता का "
"उपयोग करें।"

#. Tag: screeninfo
#: index.docbook:500
#, no-c-format
msgid "<screeninfo>Background selector</screeninfo>"
msgstr "<screeninfo>पृष्ठभूमि चयनकर्ता</screeninfo>"

#. Tag: phrase
#: index.docbook:505
#, no-c-format
msgid "<phrase>Background selector</phrase>"
msgstr "<phrase>पृष्ठभूमि चयनकर्ता</phrase>"

