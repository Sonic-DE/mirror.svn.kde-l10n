msgstr "<phrase> क्रमांकित गेम संवाद प्रारंभ करें</phrase>"

#. Tag: menuchoice
#: index.docbook:252
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>S</keycap></keycombo></"
"shortcut> <guimenu>Game</guimenu> <guimenuitem>Save</guimenuitem>"
msgstr ""
"<shortcut><keycombo Action='simul'>&Ctrl;<keycap>S</keycap></keycombo></"
"shortcut> <guimenu>गेम</guimenu> <guimenuitem>सहेजें</guimenuitem>"

#. Tag: para
#: index.docbook:257
#, no-c-format
msgid "<action>Saves</action> the current game."
msgstr "<action>वर्तमान गेम को सहेजता है</action>."

#. Tag: menuchoice
#: index.docbook:260
#, no-c-format
msgid ""
"<shortcut><keycap>P</keycap></shortcut> <guimenu>Game</guimenu> "
"<guimenuitem>Pause</guimenuitem>"
msgstr ""
"<शॉर्टकट><कीकैप>पी</कीकैप></शॉर्टकट> <गुइमेनू>गेम</गुइमेनू> <गुइमेनुइटम>रोकें</गुइमेनुइटम>"

#. Tag: action
#: index.docbook:265
#, no-c-format
msgid ""
"Pauses or resumes the game. While the game is paused, all tiles are hidden."
msgstr ""
"खेल को रोक देता है या फिर से शुरू करता है। जब खेल रुका होता है, तो सभी टाइलें छिपी रहती "
"हैं।"

#. Tag: menuchoice
#: index.docbook:268
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>H</keycap></keycombo></"
