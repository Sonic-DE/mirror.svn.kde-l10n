#: index.docbook:536
#, no-c-format
msgid "<keycap>H</keycap>"
msgstr "<keycap>एच</keycap>"

#. Tag: entry
#: index.docbook:536
#, no-c-format
msgid "Gives you a hint by flashing two matching tiles"
msgstr "दो मिलते-जुलते टाइल्स को फ्लैश करके आपको संकेत देता है"

