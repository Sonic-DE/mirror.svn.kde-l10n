#: index.docbook:514
#, no-c-format
msgid "Default Keybindings"
msgstr "डिफ़ॉल्ट कीबाइंडिंग"

#. Tag: para
#: index.docbook:516
#, no-c-format
msgid ""
"<menuchoice><guimenu>Settings</guimenu><guimenuitem>Configure Shortcuts…</"
"guimenuitem></menuchoice> allows you to change the default keyboard bindings."
msgstr ""
"<menuchoice><guimenu>सेटिंग्स</guimenu><guimenuitem>शॉर्टकट कॉन्फ़िगर करें...</"
"guimenuitem></menuchoice> आपको डिफ़ॉल्ट कीबोर्ड बाइंडिंग बदलने की अनुमति देता है।"

