"- - - - - - - -         - - - - - - - -          - - - - - - - -\n"
"  - - - - O - - -         - - O - O - - -          - - - - - - - -\n"
"R * * * * - - - -         - - - * - - - -          O - - - - - - -\n"
"  - - - - O - - -         - - - * - - - -        R - - - - - - - -\n"
"  - - - - - - - -         - - - * - - - -          - - - - - - - -\n"
"  - - - - - - - -         - - - * - - - -          - - - - - - - -\n"
"  - - - - - - - -       R * * * * - - - -          - - - - - - - -\n"
"  - - - - - - - -         - - - - O - - -          - - - - - - - -"
msgstr ""
"- - - - - - - - - - - - - - - - - - - - - - - - -\n"
