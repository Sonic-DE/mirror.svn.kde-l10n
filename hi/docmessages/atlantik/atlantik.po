"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>R</keycap></keycombo></"
"shortcut> <guimenu>Move</guimenu><guimenuitem>रोल डाइस</guimenuitem>"

#. Tag: action
#: index.docbook:144
#, no-c-format
msgid "Roll the dice."
msgstr "पासा फैंके।"

#. Tag: menuchoice
#: index.docbook:148
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>A</keycap></keycombo></"
"shortcut> <guimenu>Move</guimenu><guimenuitem>Auction</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>A</keycap></keycombo></"
"shortcut> <guimenu>स्थानांतरित करें</guimenu><guimenuitem>नीलामी</guimenuitem>"

#. Tag: para
#: index.docbook:150
#, no-c-format
msgid "Start an auction."
msgstr "नीलामी शुरू करें."

#. Tag: menuchoice
#: index.docbook:154
#, no-c-format
msgid ""
"<guimenu>Move</guimenu><guimenuitem>Use Card to Leave Jail</guimenuitem>"
msgstr ""
"<guimenu>स्थानांतरित करें</guimenu><guimenuitem>जेल से निकलने के लिए कार्ड का उपयोग "
"करें</guimenuitem>"

#. Tag: para
#: index.docbook:156
#, no-c-format
msgid "Use a card to leave jail."
msgstr "जेल से बाहर निकलने के लिए कार्ड का उपयोग करें।"

#. Tag: menuchoice
#: index.docbook:160
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>J</keycap></keycombo></"
