msgstr ""
"<शॉर्टकट> <कीकॉम्बो एक्शन = \"सिमुल\">&Alt;<कीकैप>डेल</कीकैप></कीकॉम्बो> </शॉर्टकट> "
"<गुइमेनू>संपादित करें</गुइमेनु> <गुइमेनुइटम>फ़ीड हटाएं</गुइमेनुइटम>"

#. Tag: para
#: index.docbook:793
#, no-c-format
msgid "<action>Delete</action> current feed"
msgstr "<action>वर्तमान फ़ीड हटाएं</action>"

