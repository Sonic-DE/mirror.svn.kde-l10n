"<shortcut> <keycap>F2</keycap> </shortcut> <guimenu>Edit</guimenu> "
"<guimenuitem>Edit Feed...</guimenuitem>"
msgstr ""
"<shortcut> <keycap>F2</keycap> </shortcut> <guimenu>संपादित करें</guimenu> "
"<guimenuitem>फ़ीड संपादित करें...</guimenuitem>"

#. Tag: para
#: index.docbook:782
#, no-c-format
msgid ""
"<action>Edit</action> current feed to change its properties in the "
"Properties dialog"
msgstr ""
"गुण संवाद में इसके गुणों को बदलने के लिए वर्तमान फ़ीड को <action>संपादित करें</action> करें"

#. Tag: menuchoice
#: index.docbook:786
#, no-c-format
