#, no-c-format
msgid "ROLES_OF_TRANSLATORS"
msgstr "अनुवादकों की भूमिकाएँ"

#. Tag: para
#: index.docbook:17
#, no-c-format
msgid ""
"The <emphasis>file</emphasis> protocol is used by all &kde; applications to "
"display locally available files."
msgstr ""
"<emphasis>फ़ाइल</emphasis> प्रोटोकॉल का उपयोग सभी &kde; अनुप्रयोगों द्वारा स्थानीय "
"रूप से उपलब्ध फ़ाइलों को प्रदर्शित करने के लिए किया जाता है।"

#. Tag: para
#: index.docbook:21
#, no-c-format
msgid ""
"Entering <userinput><command>file:/directoryname</command></userinput> in "
"&konqueror; lists the files of this folder."
msgstr ""
"&konqueror; में <userinput><command>file:/directoryname</command></userinput> "
"प्रविष्ट करने पर इस फ़ोल्डर की फ़ाइलें सूचीबद्ध हो जाती हैं।"
