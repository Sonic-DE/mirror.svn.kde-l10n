#, no-c-format
msgid "file"
msgstr "फ़ाइल"

#. Tag: author
#: index.docbook:12
#, no-c-format
msgid "&Ferdinand.Gassauer; &Ferdinand.Gassauer.mail;"
msgstr "&Ferdinand.Gassauer; &Ferdinand.Gassauer.mail;"

#. Tag: trans_comment
