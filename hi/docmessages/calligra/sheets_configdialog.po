#. Tag: author
#: configdialog.docbook:4
#, no-c-format
msgid "<firstname>Pamela</firstname> <surname>Robert</surname>"
msgstr "<पहला नाम>पामेला</पहला नाम> <उपनाम>रॉबर्ट</उपनाम>"

#. Tag: email
#: configdialog.docbook:8
#, no-c-format
msgid "pamroberts@blueyonder.co.uk"
msgstr "pamroberts@blueyonder.co.uk"

#. Tag: trans_comment
#: configdialog.docbook:11
#, no-c-format
msgid "ROLES_OF_TRANSLATORS"
msgstr "अनुवादकों की भूमिकाएँ"

#. Tag: title
#: configdialog.docbook:14
#, no-c-format
msgid "The &sheets; Configuration Dialog Box"
msgstr "&sheets; कॉन्फ़िगरेशन संवाद बॉक्स"

#. Tag: para
#: configdialog.docbook:16
#, no-c-format
msgid ""
"Selecting <menuchoice><guimenu>Settings</guimenu><guimenuitem> Configure "
"&sheets;...</guimenuitem></menuchoice> opens a dialog box with several "
"pages, selected with the icons at the left of the dialog box, which allow "
"you to change many aspects of &sheets;'s operation."
msgstr ""
"<menuchoice><guimenu>सेटिंग्स</guimenu><guimenuitem> &sheets;...कॉन्फ़िगर करें</"
"guimenuitem></menuchoice> का चयन करने पर कई पृष्ठों वाला एक संवाद बॉक्स खुलता है, जो "
"संवाद बॉक्स के बाईं ओर स्थित आइकनों से चयनित होता है, जो आपको &sheets; के संचालन के कई "
"पहलुओं को बदलने की अनुमति देता है।"

#. Tag: title
#: configdialog.docbook:22
#, no-c-format
msgid "Interface"
msgstr "इंटरफ़ेस"

#. Tag: phrase
#: configdialog.docbook:29
#, no-c-format
msgid "Interface Configuration."
msgstr "इंटरफ़ेस कॉन्फ़िगरेशन."

#. Tag: guilabel
#: configdialog.docbook:36
#, no-c-format
msgid "Cursor movement after pressing Enter:"
msgstr "एंटर दबाने के बाद कर्सर की गति:"

#. Tag: para
#: configdialog.docbook:37
#, no-c-format
msgid ""
"Select whether pressing the &Enter; key will move the cursor <guilabel>Down</"
"guilabel>, <guilabel>Up</guilabel>, <guilabel>Right</guilabel>, "
"<guilabel>Left</guilabel>, <guilabel>Down, First Column</guilabel> or "
"<guilabel>None</guilabel> as determined by the setting in this drop down "
"selection box."
msgstr ""
"चयन करें कि &Enter; कुंजी दबाने पर कर्सर <guilabel>नीचे</guilabel>, <guilabel>ऊपर</"
"guilabel>, <guilabel>दाएं</guilabel>, <guilabel>बाएं</guilabel>, "
"<guilabel>नीचे, प्रथम कॉलम</guilabel> या <guilabel>कोई नहीं</guilabel> जाएगा, "
"जैसा कि इस ड्रॉप डाउन चयन बॉक्स में सेटिंग द्वारा निर्धारित किया गया है।"

#. Tag: guilabel
#: configdialog.docbook:45
#, no-c-format
msgid "Function shown in the status bar:"
msgstr "स्टेटस बार में दिखाया गया कार्य:"

#. Tag: para
#: configdialog.docbook:46
#, no-c-format
msgid ""
"This drop down selection box can be used to choose the calculation performed "
"by the <link linkend=\"statusbarsum\">Statusbar Summary </link> function."
msgstr ""
"इस ड्रॉप डाउन चयन बॉक्स का उपयोग उपयोगकर्ता द्वारा की गई गणना को चुनने के लिए किया "
"जा सकता है।<link linkend=\"statusbarsum\"> स्टेटसबार सारांश</link> समारोह।"

#. Tag: guilabel
#: configdialog.docbook:53
#, no-c-format
msgid "Unit:"
msgstr "इकाई:"

#. Tag: para
#: configdialog.docbook:54
#, no-c-format
msgid "Choose the default unit that will be used in your sheets."
msgstr "अपनी शीट में उपयोग की जाने वाली डिफ़ॉल्ट इकाई चुनें."

#. Tag: guilabel
#: configdialog.docbook:59
#, no-c-format
msgid "Indentation step:"
msgstr "इंडेंटेशन चरण:"

#. Tag: para
#: configdialog.docbook:60
#, no-c-format
msgid ""
"Set the amount of indent that will be used in the cell when you choose the "
"<guilabel>Increase Indent</guilabel>/<guilabel>Decrease Indent</guilabel> "
"actions from the toolbar. These actions are not enabled by default in the "
"toolbar."
msgstr ""
"जब आप टूलबार से <guilabel>इंडेंट बढ़ाएँ</guilabel>/<guilabel>इंडेंट घटाएँ</guilabel> "
"क्रियाएँ चुनते हैं, तो सेल में उपयोग किए जाने वाले इंडेंट की मात्रा सेट करें। ये क्रियाएँ टूलबार में "
"डिफ़ॉल्ट रूप से सक्षम नहीं होती हैं।"

#. Tag: guilabel
#: configdialog.docbook:67
#, no-c-format
msgid "Capture all navigation keys while editing"
msgstr "संपादन करते समय सभी नेविगेशन कुंजियाँ कैप्चर करें"

#. Tag: para
#: configdialog.docbook:68
#, no-c-format
msgid ""
"Captures all navigation keys, &ie; the arrow keys, page up/down, tabulator "
"and backward tabulator key, while editing a cell with the embedded editor. "
"The embedded editor is the one appearing directly in the cell. If captured, "
"these keys are used for navigating in the editor. Otherwise, they are used "
"for cell navigation."
msgstr ""
"एम्बेडेड एडिटर के साथ सेल को संपादित करते समय सभी नेविगेशन कुंजियों, जैसे कि एरो कीज़, पेज "
"अप/डाउन, टेबुलेटर और बैकवर्ड टेबुलेटर की को कैप्चर करता है। एम्बेडेड एडिटर वह होता है जो "
"सीधे सेल में दिखाई देता है। यदि कैप्चर किया जाता है, तो इन कुंजियों का उपयोग एडिटर में "
"नेविगेट करने के लिए किया जाता है। अन्यथा, उनका उपयोग सेल नेविगेशन के लिए किया जाता है।"

#. Tag: para
#: configdialog.docbook:78
#, no-c-format
msgid ""
"The <guilabel>Colors</guilabel> section lets you choose the color of the "
"sheet grid. If you do not want the grid to appear at all, uncheck the "
"<guilabel>Show grid</guilabel> box in the <menuchoice><guimenu>Format</"
"guimenu> <guisubmenu>Sheet</guisubmenu><guimenuitem>Sheet Properties</"
"guimenuitem></menuchoice> dialog."
msgstr ""
"<guilabel>रंग</guilabel> अनुभाग आपको शीट ग्रिड का रंग चुनने देता है। यदि आप ग्रिड को "
"बिल्कुल भी प्रदर्शित नहीं करना चाहते हैं, तो <menuchoice><guimenu>स्वरूप</guimenu> "
"<guisubmenu>शीट</guisubmenu><guimenuitem>शीट गुण</guimenuitem></menuchoice> "
"संवाद में <guilabel>ग्रिड दिखाएँ</guilabel> बॉक्स को अनचेक करें।"

#. Tag: para
#: configdialog.docbook:83
#, no-c-format
msgid ""
"This section also lets you select the color of the lines used to indicate "
"the printed page borders when the <guimenuitem>Page Borders</guimenuitem> "
"box in the <guimenu>View</guimenu> menu is checked."
msgstr ""
"यह अनुभाग आपको मुद्रित पृष्ठ सीमाओं को इंगित करने के लिए प्रयुक्त पंक्तियों का रंग चुनने की "
"सुविधा भी देता है, जब <guimenu>दृश्य</guimenu> मेनू में <guimenuitem>पृष्ठ सीमाएं</"
"guimenuitem> बॉक्स को चेक किया जाता है।"

#. Tag: para
#: configdialog.docbook:86
#, no-c-format
msgid ""
"Select <guilabel>Custom</guilabel> from the current color to display the "
"standard &kde; <guilabel>Select Color</guilabel> dialog."
msgstr ""
"मानक &kde; <guilabel>रंग चुनें</guilabel> संवाद प्रदर्शित करने के लिए वर्तमान रंग से "
"<guilabel>कस्टम</guilabel> का चयन करें।"

#. Tag: guilabel
#: configdialog.docbook:92
#, no-c-format
msgid "Grid"
msgstr "ग्रिड"

#. Tag: para
#: configdialog.docbook:93
#, no-c-format
msgid ""
"Click here to change the grid color &ie; the color of the borders of each "
"cell."
msgstr "ग्रिड का रंग अर्थात प्रत्येक सेल की सीमाओं का रंग बदलने के लिए यहां क्लिक करें।"

#. Tag: guilabel
#: configdialog.docbook:98
#, no-c-format
msgid "Page border"
msgstr "पेज बोर्डर"

#. Tag: para
#: configdialog.docbook:99
#, no-c-format
msgid ""
"When the <menuchoice><guimenu>View</guimenu><guimenuitem>Show Page Borders</"
"guimenuitem></menuchoice> menu item is checked, the page borders are "
"displayed. Click here to choose another color for the borders than the "
"default red."
msgstr ""
"जब <menuchoice><guimenu>देखें</guimenu><guimenuitem>पेज बॉर्डर दिखाएँ</"
"guimenuitem></menuchoice> मेनू आइटम को चेक किया जाता है, तो पेज बॉर्डर प्रदर्शित होते "
"हैं। डिफ़ॉल्ट लाल के अलावा बॉर्डर के लिए कोई दूसरा रंग चुनने के लिए यहाँ क्लिक करें।"

#. Tag: title
#: configdialog.docbook:107
#, no-c-format
msgid "Open/Save"
msgstr "खोलें/सहेजें"

#. Tag: phrase
#: configdialog.docbook:114
#, no-c-format
msgid "Open/Save Configuration."
msgstr "कॉन्फ़िगरेशन खोलें/सहेजें."

#. Tag: guilabel
#: configdialog.docbook:121
#, no-c-format
msgid "Number of entries in Recent Files list:"
msgstr "हाल की फ़ाइलों की सूची में प्रविष्टियों की संख्या:"

#. Tag: para
#: configdialog.docbook:122
#, no-c-format
msgid ""
"Controls the maximum number of filenames that are shown when you select "
"<menuchoice><guimenu>File</guimenu><guisubmenu> Open Recent</guisubmenu></"
"menuchoice>."
msgstr ""
"जब आप <menuchoice><guimenu>फ़ाइल</guimenu><guisubmenu> हाल ही में खोलें</"
"guisubmenu></menuchoice> का चयन करते हैं, तो दिखाए जाने वाले फ़ाइल नामों की अधिकतम "
"संख्या को नियंत्रित करता है।"

#. Tag: guilabel
#: configdialog.docbook:129
#, no-c-format
msgid "Autosave interval:"
msgstr "स्वतःसहेज अंतराल:"

#. Tag: para
#: configdialog.docbook:130
#, no-c-format
msgid ""
"Here you can select the time between autosaves, or disable this feature "
"altogether by choosing <guilabel>No autosave</guilabel> (by selecting the "
"minimum value)."
msgstr ""
"यहां आप स्वतः सहेजे जाने के बीच का समय चुन सकते हैं, या <guilabel>कोई स्वतः सहेजा नहीं</"
"guilabel> चुनकर (न्यूनतम मान चुनकर) इस सुविधा को पूरी तरह अक्षम कर सकते हैं।"

#. Tag: guilabel
#: configdialog.docbook:137
#, no-c-format
msgid "Create backup file:"
msgstr "बैकअप फ़ाइल बनाएँ:"

#. Tag: para
#: configdialog.docbook:138
#, no-c-format
msgid ""
"Check this box if you want some backup files created. This is checked per "
"default."
msgstr ""
"यदि आप कुछ बैकअप फ़ाइलें बनाना चाहते हैं तो इस बॉक्स को चेक करें। यह डिफ़ॉल्ट रूप से चेक किया "
"गया है।"

#. Tag: title
#: configdialog.docbook:221
#, no-c-format
msgid "Plugins"
msgstr "प्लग-इन"

#. Tag: phrase
#: configdialog.docbook:228
#, no-c-format
msgid "Plugins Configuration."
msgstr "प्लगइन्स कॉन्फ़िगरेशन."

#. Tag: para
#: configdialog.docbook:233
#, no-c-format
msgid ""
"Check a plugin in the list to enable it. Display the <guilabel>About</"
"guilabel> dialog by clicking the info button at the right side of the list "
"item."
msgstr ""
"सूची में किसी प्लगइन को सक्षम करने के लिए उसे जाँचें। सूची आइटम के दाईं ओर स्थित जानकारी "
"बटन पर क्लिक करके <guilabel>About</guilabel> संवाद प्रदर्शित करें।"

#. Tag: title
#: configdialog.docbook:240
#, no-c-format
msgid "Spelling"
msgstr "वर्तनी"

#. Tag: phrase
#: configdialog.docbook:247
#, no-c-format
msgid "Spell Checker Configuration."
msgstr "वर्तनी परीक्षक कॉन्फ़िगरेशन."

#. Tag: para
#: configdialog.docbook:251
#, no-c-format
msgid "This page lets you configure the behavior of &sheets;'s spell checker."
msgstr "यह पृष्ठ आपको &sheets; के वर्तनी परीक्षक के व्यवहार को कॉन्फ़िगर करने देता है।"

#. Tag: para
#: configdialog.docbook:253
#, no-c-format
msgid ""
"For more information please refer to the <ulink url=\"help:kcontrol/"
"spellchecking\">Spell Checker</ulink> documentation."
msgstr ""
"अधिक जानकारी के लिए कृपया <ulink url=\"help:kcontrol/spellchecking\">वर्तनी "
"परीक्षक</ulink> दस्तावेज़ देखें।"

#. Tag: title
#: configdialog.docbook:314
#, no-c-format
msgid "Author"
msgstr "लेखक"

#. Tag: phrase
#: configdialog.docbook:321
#, no-c-format
msgid "Author Configuration."
msgstr "लेखक कॉन्फ़िगरेशन."

#. Tag: para
#: configdialog.docbook:325
#, no-c-format
msgid "Choose an author profile for your document."
msgstr "अपने दस्तावेज़ के लिए एक लेखक प्रोफ़ाइल चुनें."

#. Tag: para
#: configdialog.docbook:328
#, no-c-format
msgid ""
"You can add a new profile or delete the current profile using the buttons to "
"the right of the profiles drop-down list."
msgstr ""
"आप प्रोफाइल ड्रॉप-डाउन सूची के दाईं ओर स्थित बटन का उपयोग करके एक नई प्रोफाइल जोड़ "
"सकते हैं या वर्तमान प्रोफाइल को हटा सकते हैं।"
