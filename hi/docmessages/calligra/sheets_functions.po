#, no-c-format
msgid "Database"
msgstr "डेटाबेस"

#. Tag: title
#: functions.docbook:566
#, no-c-format
msgid "DAVERAGE"
msgstr "औसत"

#. Tag: para
#: functions.docbook:567
#, no-c-format
