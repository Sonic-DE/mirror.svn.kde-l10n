#. Tag: title
#: functions.docbook:426
#, no-c-format
msgid "POLA"
msgstr "से"

#. Tag: para
#: functions.docbook:427
#, no-c-format
msgid ""
"The POLA() function returns the angle (in radians) corresponding to the "
"position of a point in a cartesian landmark."
msgstr ""
"POLA() फ़ंक्शन कार्तीय लैंडमार्क में किसी बिंदु की स्थिति के अनुरूप कोण (रेडियन में) लौटाता है।"

#. Tag: para
#: functions.docbook:432
#, no-c-format
msgid "POLA(X;Y)"
msgstr "पोला(एक्स;वाई)"

#. Tag: seg
#: functions.docbook:436 functions.docbook:469
#, no-c-format
msgid "Value in X"
msgstr "एक्स में मान"

#. Tag: seg
#: functions.docbook:437 functions.docbook:470
#, no-c-format
msgid "Value in Y"
msgstr "Y में मान"

#. Tag: para
#: functions.docbook:440
#, no-c-format
msgid "POLA(12;12) returns 0.78539816"
msgstr "POLA(12;12) 0.78539816 लौटाता है"

#. Tag: para
#: functions.docbook:443
#, no-c-format
msgid "POLA(12;0) returns 0"
msgstr "POLA(12;0) 0 लौटाता है"

#. Tag: para
#: functions.docbook:446
#, no-c-format
msgid "POLA(0;12) returns 1.5707"
msgstr "POLA(0;12) 1.5707 लौटाता है"

#. Tag: title
#: functions.docbook:459
#, no-c-format
msgid "POLR"
msgstr "POLR"

#. Tag: para
#: functions.docbook:460
#, no-c-format
msgid ""
"The POLR() function returns the radius corresponding to the position of a "
"point in a cartesian landmark."
msgstr ""
"POLR() फ़ंक्शन कार्टेशियन लैंडमार्क में किसी बिंदु की स्थिति के अनुरूप त्रिज्या लौटाता है।"

#. Tag: para
#: functions.docbook:465
#, no-c-format
msgid "POLR(X;Y)"
msgstr "पीओएलआर(एक्स;वाई)"

#. Tag: para
#: functions.docbook:473
#, no-c-format
msgid "POLR(12;12) returns 16.9705"
msgstr "POLR(12;12) 16.9705 लौटाता है"

#. Tag: para
#: functions.docbook:476
#, no-c-format
msgid "POLR(12;0) returns 12"
msgstr "POLR(12;0) 12 लौटाता है"

#. Tag: title
#: functions.docbook:489
#, no-c-format
msgid "ROMAN"
msgstr "रोमन"

#. Tag: para
#: functions.docbook:490
#, no-c-format
msgid ""
"The ROMAN() function returns the number in Roman format. Only positive whole "
"numbers can be converted. The optional Format argument specifies the level "
"of conciseness, and defaults to 0."
msgstr ""
"ROMAN() फ़ंक्शन रोमन फ़ॉर्मेट में संख्या लौटाता है। केवल सकारात्मक पूर्ण संख्याओं को ही "
"परिवर्तित किया जा सकता है। वैकल्पिक फ़ॉर्मेट तर्क संक्षिप्तता के स्तर को निर्दिष्ट करता है, "
"और डिफ़ॉल्ट रूप से 0 होता है।"

#. Tag: para
#: functions.docbook:495
#, no-c-format
msgid "ROMAN(Number)"
msgstr "रोमन(संख्या)"

