msgstr "आउटपुट की न्यूनतम लंबाई"

#. Tag: para
#: functions.docbook:2031
#, no-c-format
msgid "BIN2HEX(\"1010\") returns \"a\""
msgstr "BIN2HEX(\"1010\") \"a\" लौटाता है"

#. Tag: para
#: functions.docbook:2034
