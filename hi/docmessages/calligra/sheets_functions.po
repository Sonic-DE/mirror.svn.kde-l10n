msgstr "रैंडलनॉर्म(0, 1)"

#. Tag: title
#: functions.docbook:7083
#, no-c-format
msgid "RANDPOISSON"
msgstr "रैंड पॉइसन"

#. Tag: para
#: functions.docbook:7084
#, no-c-format
msgid ""
"The RANDPOISSON() function returns a poisson-distributed pseudo-random "
"number."
msgstr "RANDPOISSON() फ़ंक्शन पॉइसन-वितरित छद्म-यादृच्छिक संख्या लौटाता है।"

#. Tag: para
#: functions.docbook:7089
#, no-c-format
msgid "RANDPOISSON(x)"
msgstr "रैंडपॉइसन(x)"

#. Tag: para
#: functions.docbook:7097
#, no-c-format
msgid "RANDPOISSON(4)"
msgstr "रैंडपॉइसन(4)"

#. Tag: title
#: functions.docbook:7108
#, no-c-format
msgid "ROOTN"
msgstr "रूटन"

#. Tag: para
#: functions.docbook:7109
#, no-c-format
msgid "The ROOTN() function returns the non-negative nth root of x."
msgstr "ROOTN() फ़ंक्शन x का गैर-ऋणात्मक nवाँ मूल लौटाता है।"

#. Tag: para
#: functions.docbook:7114
#, no-c-format
msgid "ROOTN(x;n)"
msgstr "रूटएन(x;n)"

#. Tag: para
#: functions.docbook:7122
#, no-c-format
msgid "ROOTN(9;2) equals 3"
msgstr "ROOTN(9;2) बराबर 3"

#. Tag: title
#: functions.docbook:7133
#, no-c-format
msgid "ROUND"
msgstr "गोल"

#. Tag: para
#: functions.docbook:7134
#, no-c-format
msgid ""
"The ROUND(value;[digits]) function returns value rounded. Digits is the "
"number of digits to which you want to round that number. If digits is zero "
"or omitted, value is rounded up to the nearest integer. If digits is smaller "
"than zero, the corresponding integer part of the number is rounded."
msgstr ""
"ROUND(value;[digits]) फ़ंक्शन राउंडेड वैल्यू लौटाता है। अंक उन अंकों की संख्या है, जिन तक "
"आप उस संख्या को राउंड करना चाहते हैं। यदि अंक शून्य है या छोड़ा गया है, तो मान को निकटतम "
"पूर्णांक तक राउंड किया जाता है। यदि अंक शून्य से छोटा है, तो संख्या का संगत पूर्णांक भाग "
"राउंड किया जाता है।"

#. Tag: para
#: functions.docbook:7139
#, no-c-format
msgid "ROUND(value;[digits])"
msgstr "ROUND(मूल्य;[अंक])"

#. Tag: seg
#: functions.docbook:7144 functions.docbook:7183 functions.docbook:7218
#, no-c-format
msgid "Digits"
msgstr "अंक"

#. Tag: para
#: functions.docbook:7147
#, no-c-format
msgid "ROUND(1.252;2) equals 1.25"
msgstr "ROUND(1.252;2) बराबर 1.25"

#. Tag: para
#: functions.docbook:7150
#, no-c-format
msgid "ROUND(-1.252;2) equals -1.25"
msgstr "ROUND(-1.252;2) बराबर -1.25"

#. Tag: para
#: functions.docbook:7153
#, no-c-format
msgid "ROUND(1.258;2) equals 1.26"
msgstr "ROUND(1.258;2) बराबर 1.26"

#. Tag: para
#: functions.docbook:7156
#, no-c-format
msgid "ROUND(-12.25;-1) equals -10"
msgstr "ROUND(-12.25;-1) बराबर -10"

#. Tag: para
#: functions.docbook:7159
#, no-c-format
msgid "ROUND(-1.252;0) equals -1"
msgstr "ROUND(-1.252;0) बराबर -1"

#. Tag: member
#: functions.docbook:7163
#, no-c-format
msgid "<link linkend=\"MROUND\">MROUND</link>&nbsp;"
msgstr "<link linkend=\"MROUND\">एमराउंड</link>"

#. Tag: title
#: functions.docbook:7172
#, no-c-format
msgid "ROUNDDOWN"
msgstr "राउंडडाउन"

#. Tag: para
#: functions.docbook:7173
#, no-c-format
msgid ""
"The ROUNDDOWN(value;[digits]) function returns value rounded so that its "
"absolute value is lesser. Digits is the number of digits to which you want "
"to round that number. If digits is zero or omitted, value is rounded down to "
"the nearest integer."
msgstr ""
"ROUNDDOWN(value;[digits]) फ़ंक्शन मान को गोल करके लौटाता है ताकि उसका निरपेक्ष मान "
"कम हो। अंक अंकों की वह संख्या है जिसके लिए आप उस संख्या को गोल करना चाहते हैं। यदि अंक "
"शून्य है या छोड़ा गया है, तो मान को निकटतम पूर्णांक तक गोल किया जाता है।"

#. Tag: para
#: functions.docbook:7178
#, no-c-format
msgid "ROUNDDOWN(value;[digits])"
msgstr "ROUNDDOWN(मूल्य;[अंक])"

#. Tag: para
#: functions.docbook:7186
#, no-c-format
msgid "ROUNDDOWN(1.252) equals 1"
msgstr "राउंडडाउन(1.252) बराबर 1"

#. Tag: para
#: functions.docbook:7189
#, no-c-format
msgid "ROUNDDOWN(1.252;2) equals 1.25"
msgstr "ROUNDDOWN(1.252;2) = 1.25"

#. Tag: para
#: functions.docbook:7192
#, no-c-format
msgid "ROUNDDOWN(-1.252;2) equals -1.25"
msgstr "राउंडडाउन(-1.252;2) बराबर -1.25"

#. Tag: para
#: functions.docbook:7195
#, no-c-format
msgid "ROUNDDOWN(-1.252) equals -1"
msgstr "राउंडडाउन(-1.252) बराबर -1"

#. Tag: title
#: functions.docbook:7207
#, no-c-format
msgid "ROUNDUP"
msgstr "बढ़ाना"

#. Tag: para
#: functions.docbook:7208
#, no-c-format
msgid ""
"The ROUNDUP(value;[digits]) function returns value rounded so that its "
"absolute value is greater. Digits is the number of digits to which you want "
"to round that number. If digits is zero or omitted, value is rounded up to "
"the nearest integer."
msgstr ""
"ROUNDUP(value;[digits]) फ़ंक्शन मान को राउंड करके लौटाता है ताकि उसका निरपेक्ष मान "
"अधिक हो। अंक अंकों की वह संख्या है जिसके लिए आप उस संख्या को राउंड करना चाहते हैं। यदि अंक "
"शून्य है या छोड़ा गया है, तो मान को निकटतम पूर्णांक तक राउंड किया जाता है।"

#. Tag: para
#: functions.docbook:7213
#, no-c-format
msgid "ROUNDUP(value;[digits])"
msgstr "ROUNDUP(मूल्य;[अंक])"

#. Tag: para
#: functions.docbook:7221
#, no-c-format
msgid "ROUNDUP(1.252) equals 2"
msgstr "ROUNDUP(1.252) बराबर 2"

#. Tag: para
#: functions.docbook:7224
#, no-c-format
msgid "ROUNDUP(1.252;2) equals 1.26"
msgstr "ROUNDUP(1.252;2) बराबर 1.26"

#. Tag: para
#: functions.docbook:7227
#, no-c-format
msgid "ROUNDUP(-1.252;2) equals -1.26"
msgstr "राउंडअप(-1.252;2) बराबर -1.26"

#. Tag: para
#: functions.docbook:7230
#, no-c-format
msgid "ROUNDUP(-1.252) equals -2"
msgstr "राउंडअप(-1.252) बराबर -2"

#. Tag: title
#: functions.docbook:7242
#, no-c-format
msgid "SERIESSUM"
msgstr "गंभीरता से"

#. Tag: para
#: functions.docbook:7243
#, no-c-format
msgid "The SERIESSUM() function returns the sum of a power series."
msgstr "SERIESSUM() फ़ंक्शन घात श्रृंखला का योग लौटाता है।"

#. Tag: para
#: functions.docbook:7248
#, no-c-format
msgid "SERIESSUM( X; N; M; Coefficients)"
msgstr "SERIESUM( X; N; M; गुणांक)"

#. Tag: seg
#: functions.docbook:7252
#, no-c-format
msgid "X the independent variable of the power series"
msgstr "X घात श्रृंखला का स्वतंत्र चर है"

#. Tag: seg
#: functions.docbook:7253
#, no-c-format
msgid "N the initial power to which X is to be raised"
msgstr "N वह प्रारंभिक घात है जिस तक X को बढ़ाया जाना है"

#. Tag: seg
#: functions.docbook:7254
#, no-c-format
msgid "M the increment by which to increase N for each term in the series"
msgstr "M वह वृद्धि है जिससे श्रृंखला में प्रत्येक पद के लिए N को बढ़ाया जाता है"

#. Tag: seg
#: functions.docbook:7255
#, no-c-format
msgid ""
"Coefficients a set of coefficients by which each successive power of the "
"variable X is multiplied"
msgstr ""
"गुणांक गुणांकों का एक समूह जिसके द्वारा चर X की प्रत्येक क्रमिक घात को गुणा किया जाता है"

#. Tag: para
#: functions.docbook:7258
#, no-c-format
msgid "SERIESSUM(2;0;2;{1;2}) return 9"
msgstr "SERIESUM(2;0;2;{1;2}) 9 लौटाता है"

#. Tag: title
#: functions.docbook:7264
#, no-c-format
msgid "SIGN"
msgstr "संकेत"

#. Tag: para
#: functions.docbook:7265
#, no-c-format
msgid ""
"This function returns -1 if the number is negative, 0 if the number is null "
"and 1 if the number is positive."
msgstr ""
"यदि संख्या ऋणात्मक है तो यह फ़ंक्शन -1 लौटाता है, यदि संख्या शून्य है तो 0 लौटाता है तथा "
"यदि संख्या धनात्मक है तो 1 लौटाता है।"

#. Tag: para
#: functions.docbook:7270
#, no-c-format
msgid "SIGN(value)"
msgstr "चिह्न(मूल्य)"

#. Tag: para
#: functions.docbook:7277
#, no-c-format
msgid "SIGN(5) equals 1"
msgstr "चिह्न(5) = 1"

#. Tag: para
#: functions.docbook:7280
#, no-c-format
msgid "SIGN(0) equals 0"
msgstr "SIGN(0) = 0"

#. Tag: para
#: functions.docbook:7283
#, no-c-format
msgid "SIGN(-5) equals -1"
msgstr "चिह्न (-5) = -1"

#. Tag: title
#: functions.docbook:7289
#, no-c-format
msgid "SQRT"
msgstr "एसक्यूआरटी"

#. Tag: para
#: functions.docbook:7290
#, no-c-format
msgid ""
"The SQRT() function returns the non-negative square root of the argument. It "
"is an error if the argument is negative."
msgstr ""
"SQRT() फ़ंक्शन तर्क का गैर-ऋणात्मक वर्गमूल लौटाता है। यदि तर्क ऋणात्मक है तो यह एक त्रुटि "
"है।"

#. Tag: para
#: functions.docbook:7295
#, no-c-format
msgid "SQRT(x)"
msgstr "एसक्यूआरटी(x)"

#. Tag: para
#: functions.docbook:7302
#, no-c-format
msgid "SQRT(9) equals 3"
msgstr "SQRT(9) बराबर 3"

#. Tag: para
#: functions.docbook:7305
#, no-c-format
msgid "SQRT(-9) is an error"
msgstr "SQRT(-9) एक त्रुटि है"

#. Tag: member
#: functions.docbook:7309
#, no-c-format
msgid "<link linkend=\"IMSQRT\">IMSQRT</link>&nbsp;"
msgstr "<link linkend=\"IMSQRT\">आईएमएसक्यूआरटी</link>"

#. Tag: title
#: functions.docbook:7316
#, no-c-format
msgid "SQRTPI"
msgstr "एसक्यूआरटीपीआई"

#. Tag: para
#: functions.docbook:7317
#, no-c-format
msgid ""
"The SQRTPI() function returns the non-negative square root of x * PI. It is "
"an error if the argument is negative."
msgstr ""
"SQRTPI() फ़ंक्शन x * PI का गैर-ऋणात्मक वर्गमूल लौटाता है। यदि तर्क ऋणात्मक है तो यह एक "
"त्रुटि है।"

#. Tag: para
#: functions.docbook:7322
#, no-c-format
msgid "SQRTPI(x)"
msgstr "एसक्यूआरटीपीआई(x)"

#. Tag: para
#: functions.docbook:7329
#, no-c-format
msgid "SQRTPI(2) equals 2.506628"
msgstr "SQRTPI(2) बराबर 2.506628"

#. Tag: title
#: functions.docbook:7335
#, no-c-format
msgid "SUBTOTAL"
msgstr "उप-योग"

#. Tag: para
#: functions.docbook:7336
#, no-c-format
msgid ""
"The SUBTOTAL() function returns a subtotal of a given list of arguments "
"ignoring other subtotal results in there. Function can be one of the "
"following numbers: 1 - Average, 2 - Count, 3 - CountA, 4 - Max, 5 - Min, 6 - "
"Product, 7 - StDev, 8 - StDevP, 9 - Sum, 10 - Var, 11 - VarP."
msgstr ""
"SUBTOTAL() फ़ंक्शन किसी दिए गए तर्कों की सूची का उप-योग लौटाता है, जिसमें अन्य उप-योग "
"परिणामों को अनदेखा किया जाता है। फ़ंक्शन निम्न संख्याओं में से एक हो सकता है: 1 - औसत, 2 - "
"गणना, 3 - गणनाA, 4 - अधिकतम, 5 - न्यूनतम, 6 - गुणनफल, 7 - मानक विचलन, 8 - मानक "
"विचलनP, 9 - योग, 10 - वार, 11 - वारP।"

#. Tag: para
#: functions.docbook:7341
#, no-c-format
msgid "SUBTOTAL(function; value)"
msgstr "SUBTOTAL(फ़ंक्शन; मान)"

#. Tag: seg
#: functions.docbook:7345
#, no-c-format
msgid "Function"
msgstr "समारोह"

#. Tag: para
#: functions.docbook:7349
#, no-c-format
msgid "If A1:A5 contains 7, 24, 23, 56 and 9:"
msgstr "यदि A1:A5 में 7, 24, 23, 56 और 9 हैं:"

#. Tag: para
#: functions.docbook:7352
#, no-c-format
msgid "SUBTOTAL(1; A1:A5) returns 23.8"
msgstr "SUBTOTAL(1; A1:A5) 23.8 लौटाता है"

#. Tag: para
#: functions.docbook:7355
#, no-c-format
msgid "SUBTOTAL(4; A1:A5) returns 56"
msgstr "SUBTOTAL(4; A1:A5) 56 लौटाता है"

#. Tag: para
#: functions.docbook:7358
#, no-c-format
msgid "SUBTOTAL(9; A1:A5) returns 119"
msgstr "SUBTOTAL(9; A1:A5) 119 लौटाता है"

#. Tag: para
#: functions.docbook:7361
#, no-c-format
msgid "SUBTOTAL(11; A1:A5) returns 307.76"
msgstr "SUBTOTAL(11; A1:A5) 307.76 लौटाता है"

#. Tag: member
#: functions.docbook:7365
#, no-c-format
msgid "<link linkend=\"AVERAGE\">AVERAGE</link>&nbsp;"
msgstr "<link linkend=\"AVERAGE\">औसत</link>"

#. Tag: member
#: functions.docbook:7371 functions.docbook:8851 functions.docbook:8880
#: functions.docbook:8915
#, no-c-format
msgid "<link linkend=\"STDEV\">STDEV</link>&nbsp;"
msgstr "<link linkend=\"STDEV\">एसटीडीईवी</link>"

#. Tag: member
#: functions.docbook:7372 functions.docbook:8820 functions.docbook:8852
#: functions.docbook:8916
#, no-c-format
msgid "<link linkend=\"STDEVP\">STDEVP</link>&nbsp;"
msgstr "<link linkend=\"STDEVP\">एसटीडीईवीपी</link>"

#. Tag: member
#: functions.docbook:7374 functions.docbook:9176 functions.docbook:9212
#: functions.docbook:9249 functions.docbook:9285
#, no-c-format
msgid "<link linkend=\"VAR\">VAR</link>&nbsp;"
msgstr "<link linkend=\"VAR\">वीएआर</link>"

#. Tag: member
#: functions.docbook:7375 functions.docbook:9141 functions.docbook:9177
#: functions.docbook:9214 functions.docbook:9287
#, no-c-format
msgid "<link linkend=\"VARP\">VARP</link>&nbsp;"
msgstr "<link linkend=\"VARP\">वीएआरपी</link>"

#. Tag: title
#: functions.docbook:7382
#, no-c-format
msgid "<title>SUM</title>"
msgstr "<title>जोड़</title>"

#. Tag: para
#: functions.docbook:7383
#, no-c-format
msgid ""
"The SUM() function calculates the sum of all the values given as parameters. "
"You can calculate the sum of a range SUM(A1:B5) or a list of values like "
"SUM(12;5;12.5)."
msgstr ""
"SUM() फ़ंक्शन पैरामीटर के रूप में दिए गए सभी मानों का योग निकालता है। आप SUM(A1:B5) "
"श्रेणी या SUM(12;5;12.5) जैसे मानों की सूची का योग निकाल सकते हैं।"

#. Tag: para
#: functions.docbook:7388 functions.docbook:7417
#, no-c-format
msgid "SUM(value;value;...)"
msgstr "SUM(मूल्य;मूल्य;...)"

#. Tag: para
#: functions.docbook:7395
#, no-c-format
msgid "SUM(12;5;7) equals 24"
msgstr "SUM(12;5;7) बराबर 24"

#. Tag: para
#: functions.docbook:7398
#, no-c-format
msgid "SUM(12.5;2) equals 14.5"
msgstr "SUM(12.5;2) बराबर 14.5"

#. Tag: member
#: functions.docbook:7402
#, no-c-format
msgid "<link linkend=\"SUMA\">SUMA</link>&nbsp;"
msgstr "<link linkend=\"SUMA\">सुमा</link>"

#. Tag: member
#: functions.docbook:7403 functions.docbook:7433
#, no-c-format
msgid "<link linkend=\"SUMSQ\">SUMSQ</link>&nbsp;"
msgstr "<link linkend=\"SUMSQ\">एसयूएमएसक्यू</link>"

#. Tag: title
#: functions.docbook:7411
#, no-c-format
msgid "SUMA"
msgstr "जोड़ना"

#. Tag: para
#: functions.docbook:7412
#, no-c-format
msgid ""
"The SUMA() function calculates the sum of all the values given as "
"parameters. You can calculate the sum of a range SUMA(A1:B5) or a list of "
"values like SUMA(12;5;12.5). If a parameter contains text or the boolean "
"value FALSE it is counted as 0, if a parameter evaluates to TRUE it is "
"counted as 1."
msgstr ""
"SUMA() फ़ंक्शन पैरामीटर के रूप में दिए गए सभी मानों का योग निकालता है। आप SUMA(A1:B5) "
"श्रेणी या SUMA(12;5;12.5) जैसे मानों की सूची का योग निकाल सकते हैं। यदि किसी पैरामीटर "
"में टेक्स्ट या बूलियन मान FALSE है तो उसे 0 के रूप में गिना जाता है, यदि पैरामीटर का "
"मूल्यांकन TRUE है तो उसे 1 के रूप में गिना जाता है।"

#. Tag: para
#: functions.docbook:7424
#, no-c-format
msgid "SUMA(12;5; 7) equals 24"
msgstr "SUMA(12;5; 7) बराबर 24"

#. Tag: para
#: functions.docbook:7427
#, no-c-format
msgid "SUMA(12.5; 2; TRUE) equals 15.5"
msgstr "SUMA(12.5; 2; TRUE) बराबर 15.5"

#. Tag: title
#: functions.docbook:7440
#, no-c-format
msgid "SUMIF"
msgstr "SUMIF"

#. Tag: para
#: functions.docbook:7441
#, no-c-format
msgid ""
"The SUMIF() function calculates the sum of all values given as parameters "
"which match the criteria. The sum range is optional. If not supplied, the "
"values in the check range are summed. The length of the check range should "
"be equal or less than the length of the sum range."
msgstr ""
"SUMIF() फ़ंक्शन मापदंडों के रूप में दिए गए सभी मानों का योग निकालता है जो मानदंड से मेल "
"खाते हैं। योग सीमा वैकल्पिक है। यदि नहीं दी गई है, तो चेक रेंज में मानों का योग किया जाता "
"है। चेक रेंज की लंबाई योग सीमा की लंबाई के बराबर या उससे कम होनी चाहिए।"

#. Tag: para
#: functions.docbook:7446
#, no-c-format
msgid "SUMIF(checkrange;criteria;sumrange)"
msgstr "SUMIF(चेकरेंज; मापदंड; sumrange)"

#. Tag: seg
#: functions.docbook:7450
#, no-c-format
msgid "Check range"
msgstr "सीमा की जाँच करें"

#. Tag: seg
#: functions.docbook:7452
#, no-c-format
msgid "Sum range"
msgstr "योग सीमा"

#. Tag: para
#: functions.docbook:7455
#, no-c-format
msgid "SUMIF(A1:A4;\">1\") sums all values in range A1:A4 which match >1"
msgstr ""
"SUMIF(A1:A4;\">1\") श्रेणी A1:A4 के सभी मानों का योग करता है जो >1 से मेल खाते हैं"

#. Tag: para
#: functions.docbook:7458
#, no-c-format
msgid ""
"SUMIF(A1:A4;\"=0\";B1:B4) sums all values in range B1:B4 if the "
"corresponding value in A1:A4 matches =0"
msgstr ""
"SUMIF(A1:A4;\"=0\";B1:B4) श्रेणी B1:B4 के सभी मानों का योग करता है यदि A1:A4 में "
"संगत मान =0 से मेल खाता है"

#. Tag: title
#: functions.docbook:7470
#, no-c-format
msgid "SUMSQ"
msgstr "एसयूएमएसक्यू"

#. Tag: para
#: functions.docbook:7471
#, no-c-format
msgid ""
"The SUMSQ() function calculates the sum of all the squares of values given "
"as parameters. You can calculate the sum of a range SUMSQ(A1:B5) or a list "
"of values like SUMSQ(12;5;12.5)."
msgstr ""
"SUMSQ() फ़ंक्शन पैरामीटर के रूप में दिए गए मानों के सभी वर्गों का योग निकालता है। आप "
"SUMSQ(A1:B5) श्रेणी या SUMSQ(12;5;12.5) जैसे मानों की सूची का योग निकाल सकते हैं।"

#. Tag: para
#: functions.docbook:7476
#, no-c-format
msgid "SUMSQ(value;value;...)"
msgstr "SUMSQ(मूल्य;मूल्य;...)"

#. Tag: para
#: functions.docbook:7483
#, no-c-format
msgid "SUMSQ(12;5;7) equals 218"
msgstr "SUMSQ(12;5;7) बराबर 218"

#. Tag: para
#: functions.docbook:7486
#, no-c-format
msgid "SUMSQ(12.5;2) equals 173"
msgstr "SUMSQ(12.5;2) बराबर 173"

#. Tag: title
#: functions.docbook:7497
#, no-c-format
msgid "TRANSPOSE"
msgstr "खिसकाना"

#. Tag: para
#: functions.docbook:7498
#, no-c-format
msgid ""
"Returns the transpose of a matrix, i.e. rows and columns of the matrix are "
"exchanged."
msgstr ""
"मैट्रिक्स का ट्रांसपोज़ लौटाता है, अर्थात मैट्रिक्स की पंक्तियों और स्तंभों का आदान-प्रदान "
"किया जाता है।"

#. Tag: para
#: functions.docbook:7503
#, no-c-format
msgid "TRANSPOSE(matrix)"
msgstr "ट्रांसपोज़(मैट्रिक्स)"

#. Tag: para
#: functions.docbook:7510
#, no-c-format
msgid "TRANSPOSE(A1:C3)"
msgstr "स्थानांतरण(A1:C3)"

#. Tag: title
#: functions.docbook:7516
#, no-c-format
msgid "TRUNC"
msgstr "तना"

#. Tag: para
#: functions.docbook:7517
#, no-c-format
msgid ""
"The TRUNC() function truncates a numeric value to a certain precision. If "
"the precision is omitted 0 is assumed."
msgstr ""
"TRUNC() फ़ंक्शन संख्यात्मक मान को एक निश्चित परिशुद्धता तक काटता है। यदि परिशुद्धता छोड़ "
"दी जाती है तो 0 मान लिया जाता है।"

#. Tag: para
#: functions.docbook:7522
#, no-c-format
msgid "TRUNC(value; precision)"
msgstr "TRUNC(मूल्य; परिशुद्धता)"

#. Tag: seg
#: functions.docbook:7527
#, no-c-format
msgid "Precision"
msgstr "शुद्धता"

#. Tag: para
#: functions.docbook:7530
#, no-c-format
msgid "TRUNC(1.2) returns 1"
msgstr "TRUNC(1.2) 1 लौटाता है"

#. Tag: para
#: functions.docbook:7533
#, no-c-format
msgid "TRUNC(213.232; 2) returns 213.23"
msgstr "TRUNC(213.232; 2) 213.23 लौटाता है"

#. Tag: title
#: functions.docbook:7546
#, no-c-format
msgid "Statistical"
msgstr "सांख्यिकीय"

#. Tag: title
#: functions.docbook:7549
#, no-c-format
msgid "AVEDEV"
msgstr "AVEDEV"

#. Tag: para
#: functions.docbook:7550
#, no-c-format
msgid ""
"The AVEDEV() function calculates the average of the absolute deviations of a "
"data set from their mean."
msgstr "AVEDEV() फ़ंक्शन किसी डेटा सेट के माध्य से उसके निरपेक्ष विचलन का औसत निकालता है।"

#. Tag: para
#: functions.docbook:7555
#, no-c-format
msgid "AVEDEV(value;value;...)"
msgstr "AVEDEV(मूल्य;मूल्य;...)"

#. Tag: seg
#: functions.docbook:7559 functions.docbook:7560 functions.docbook:7561
#: functions.docbook:7562 functions.docbook:7563 functions.docbook:7585
#: functions.docbook:7586 functions.docbook:7587 functions.docbook:7588
#: functions.docbook:7589 functions.docbook:7611 functions.docbook:7842
