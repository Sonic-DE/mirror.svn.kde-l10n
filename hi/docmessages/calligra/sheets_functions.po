msgstr "BAHTTEXT(संख्या)"

#. Tag: para
#: functions.docbook:9383
#, no-c-format
msgid "BAHTTEXT(23) returns \"ยสบสามบาทถวน\""
msgstr "BAHTTEXT(23) रिटर्न \"केवल तीन baht\""

#. Tag: title
#: functions.docbook:9389
#, no-c-format
msgid "CHAR"
msgstr "चार"

#. Tag: para
#: functions.docbook:9390
#, no-c-format
msgid "The CHAR() function returns the character specified by a number."
msgstr "CHAR() फ़ंक्शन संख्या द्वारा निर्दिष्ट वर्ण लौटाता है।"

#. Tag: para
