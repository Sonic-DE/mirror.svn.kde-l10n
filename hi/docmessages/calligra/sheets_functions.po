#. Tag: title
#: functions.docbook:366
#, no-c-format
msgid "INT2BOOL"
msgstr "INT2बूल"

#. Tag: para
#: functions.docbook:367
#, no-c-format
msgid ""
"The INT2BOOL() function returns a boolean value for a given integer number. "
"This method is intended for using an integer in methods which require a "
"boolean. It only accepts 0 or 1. If any other value is given, false is "
"returned."
msgstr ""
"INT2BOOL() फ़ंक्शन किसी दिए गए पूर्णांक संख्या के लिए बूलियन मान लौटाता है। यह विधि उन "
"विधियों में पूर्णांक का उपयोग करने के लिए अभिप्रेत है जिनके लिए बूलियन की आवश्यकता होती है। "
"यह केवल 0 या 1 स्वीकार करता है। यदि कोई अन्य मान दिया जाता है, तो गलत मान लौटाया "
"जाता है।"

#. Tag: para
#: functions.docbook:372
#, no-c-format
msgid "INT2BOOL(value)"
msgstr "INT2BOOL(मान)"

#. Tag: seg
#: functions.docbook:376
#, no-c-format
msgid "Integer value to convert"
msgstr "रूपांतरित करने के लिए पूर्णांक मान"

#. Tag: para
#: functions.docbook:379
#, no-c-format
msgid "INT2BOOL(1) returns true"
msgstr "INT2BOOL(1) सत्य लौटाता है"

#. Tag: para
#: functions.docbook:382
#, no-c-format
msgid "INT2BOOL(0) returns false"
msgstr "INT2BOOL(0) गलत रिटर्न करता है"

#. Tag: para
#: functions.docbook:385
#, no-c-format
msgid "OR(INT2BOOL(1); false) returns true"
msgstr "OR(INT2BOOL(1); false) सत्य लौटाता है"

#. Tag: member
#: functions.docbook:389
#, no-c-format
msgid "<link linkend=\"BOOL2INT\">BOOL2INT</link>&nbsp;"
msgstr "<link linkend=\"BOOL2INT\">BOOL2इंट</link>"

#. Tag: title
#: functions.docbook:396
#, no-c-format
msgid "NUM2STRING"
msgstr "NUM2स्ट्रिंग"

#. Tag: para
#: functions.docbook:397
#, no-c-format
msgid ""
"The NUM2STRING() function returns a string value for a given number. Note "
"that &sheets; can auto-convert numbers to strings if needed, so this "
"function should rarely be needed."
msgstr ""
"NUM2STRING() फ़ंक्शन किसी दिए गए नंबर के लिए एक स्ट्रिंग मान लौटाता है। ध्यान दें कि "
"&sheets; ज़रूरत पड़ने पर संख्याओं को स्ट्रिंग में अपने आप बदल सकता है, इसलिए इस फ़ंक्शन की "
"ज़रूरत शायद ही कभी पड़े।"

#. Tag: para
#: functions.docbook:402
#, no-c-format
msgid "NUM2STRING(value)"
msgstr "NUM2STRING(मान)"

#. Tag: seg
#: functions.docbook:406 functions.docbook:552
#, no-c-format
msgid "Number to convert into string"
msgstr "स्ट्रिंग में परिवर्तित करने के लिए संख्या"

