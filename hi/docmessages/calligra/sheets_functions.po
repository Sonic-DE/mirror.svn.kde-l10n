msgstr "PI() बराबर 3.141592654..."

#. Tag: title
#: functions.docbook:10763
#, no-c-format
msgid "RADIANS"
msgstr "रेडियंस"

#. Tag: para
#: functions.docbook:10764
#, no-c-format
msgid "This function transforms a degree angle to a radian angle."
msgstr "यह फ़ंक्शन डिग्री कोण को रेडियन कोण में परिवर्तित करता है।"

#. Tag: para
#: functions.docbook:10769
#, no-c-format
