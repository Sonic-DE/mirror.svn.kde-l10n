#: functions.docbook:5955
#, no-c-format
msgid "EXP(x)"
msgstr "एक्सपी(x)"

#. Tag: para
#: functions.docbook:5962
#, no-c-format
msgid "EXP(9) equals 8 103.08392758"
msgstr "EXP(9) बराबर 8 103.08392758"

#. Tag: para
#: functions.docbook:5965
#, no-c-format
msgid "EXP(-9) equals 0.00012341"
msgstr "EXP(-9) बराबर 0.00012341"

