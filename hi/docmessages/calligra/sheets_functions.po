msgid "<link linkend=\"RANDBINOM\">RANDBINOM</link>&nbsp;"
msgstr "<link linkend=\"RANDBINOM\">रैंडबिनोम</link>"

#. Tag: title
#: functions.docbook:7058
#, no-c-format
msgid "RANDNORM"
msgstr "मार्जिन मानदंड"

#. Tag: para
#: functions.docbook:7059
#, no-c-format
msgid ""
"The RANDNORM() function returns a Normal(Gaussian)-distributed pseudo-random "
"number."
msgstr "RANDNORM() फ़ंक्शन एक सामान्य(गौसियन)-वितरित छद्म-यादृच्छिक संख्या लौटाता है।"

#. Tag: para
#: functions.docbook:7064
#, no-c-format
msgid "RANDNORM(mu; sigma)"
msgstr "रैंडनॉर्म(म्यू; सिग्मा)"

#. Tag: seg
#: functions.docbook:7068
#, no-c-format
