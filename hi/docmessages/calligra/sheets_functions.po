#. Tag: title
#: functions.docbook:210
#, no-c-format
msgid "BOOL2INT"
msgstr "BOOL2इंट"

#. Tag: para
#: functions.docbook:211
#, no-c-format
msgid ""
"The BOOL2INT() function returns an integer value for a given boolean value. "
"This method is intended for using a boolean value in methods which require "
"an integer."
msgstr ""
"BOOL2INT() फ़ंक्शन किसी दिए गए बूलियन मान के लिए एक पूर्णांक मान लौटाता है। यह विधि "
"उन विधियों में बूलियन मान का उपयोग करने के लिए अभिप्रेत है, जिनमें पूर्णांक की आवश्यकता "
"होती है।"

#. Tag: para
#: functions.docbook:216
#, no-c-format
msgid "BOOL2INT(value)"
msgstr "BOOL2INT(मान)"

#. Tag: seg
#: functions.docbook:220 functions.docbook:247
#, no-c-format
msgid "Bool value to convert"
msgstr "परिवर्तित करने के लिए बूल मान"

