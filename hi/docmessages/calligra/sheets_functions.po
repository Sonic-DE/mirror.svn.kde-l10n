msgstr "परिवर्तित करने के लिए एक वर्ण स्ट्रिंग"

#. Tag: para
#: functions.docbook:335
#, no-c-format
msgid "CHARTOASCII(\"v\") returns 118"
msgstr "CHARTOASCII('v') 118 लौटाता है"

#. Tag: para
#: functions.docbook:338
#, no-c-format
