#. Tag: title
#: functions.docbook:237
#, no-c-format
msgid "BOOL2STRING"
msgstr "BOOL2स्ट्रिंग"

#. Tag: para
#: functions.docbook:238
#, no-c-format
msgid ""
"The BOOL2STRING() function returns a string value for a given boolean value. "
"This method is intended for using a boolean in methods which require a string"
msgstr ""
"BOOL2STRING() फ़ंक्शन किसी दिए गए बूलियन मान के लिए एक स्ट्रिंग मान लौटाता है। यह "
"विधि उन विधियों में बूलियन का उपयोग करने के लिए अभिप्रेत है जिनमें स्ट्रिंग की आवश्यकता "
"होती है"

#. Tag: para
#: functions.docbook:243
#, no-c-format
msgid "BOOL2STRING(value)"
msgstr "BOOL2STRING(मान)"

#. Tag: para
#: functions.docbook:250
#, no-c-format
msgid "BOOL2STRING(true) returns \"True\""
msgstr "BOOL2STRING(सत्य) \"सत्य\" लौटाता है"

#. Tag: para
#: functions.docbook:253
#, no-c-format
msgid "BOOL2STRING(false) returns \"False\""
msgstr "BOOL2STRING(false) \"गलत\" लौटाता है"

#. Tag: para
#: functions.docbook:256
#, no-c-format
msgid "upper(BOOL2STRING(find(\"nan\";\"banana\"))) returns TRUE"
msgstr "ऊपरी(BOOL2STRING(find(\"nan\";\"banana\"))) सत्य लौटाता है"

