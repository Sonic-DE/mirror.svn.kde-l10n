msgstr "बेस्सेल्क(X;N)"

#. Tag: para
#: functions.docbook:1954
#, no-c-format
msgid "BESSELK(3;9) returns 397.95880"
msgstr "BESSELK(3;9) 397.95880 लौटाता है"

#. Tag: title
#: functions.docbook:1967
#, no-c-format
msgid "BESSELY"
msgstr "बेसेली"

#. Tag: para
#: functions.docbook:1968
#, no-c-format
msgid ""
"The BESSELY() function returns the Bessel function, which is also called the "
"Weber function or the Neumann function."
msgstr ""
"BESSELY() फ़ंक्शन बेसेल फ़ंक्शन लौटाता है, जिसे वेबर फ़ंक्शन या न्यूमैन फ़ंक्शन भी कहा जाता है।"

#. Tag: para
#: functions.docbook:1973
#, no-c-format
msgid "BESSELY(X;N)"
msgstr "बेसेली(X;N)"

#. Tag: para
#: functions.docbook:1981
#, no-c-format
msgid "BESSELY(4;2) equals 0.215903595"
msgstr "बेसेली(4;2) बराबर 0.215903595"

#. Tag: title
#: functions.docbook:1995
#, no-c-format
msgid "BIN2DEC"
msgstr "BIN2DEC"

#. Tag: para
#: functions.docbook:1996
