#: functions.docbook:10924
#, no-c-format
msgid "TANH(0.8) equals 0.66403677"
msgstr "TANH(0.8) बराबर 0.66403677"

#. Tag: para
#: functions.docbook:10927
#, no-c-format
msgid "TANH(0) equals 0"
msgstr "TANH(0) बराबर 0"

