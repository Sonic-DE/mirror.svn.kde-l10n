#. Tag: title
#: functions.docbook:587
#, no-c-format
msgid "DCOUNT"
msgstr "डीकाउंट"

#. Tag: para
#: functions.docbook:588
#, no-c-format
msgid ""
"Counts the cells containing numeric values in a column of a database "
"specified by a set of conditions."
msgstr ""
"शर्तों के एक सेट द्वारा निर्दिष्ट डेटाबेस के एक कॉलम में संख्यात्मक मान वाले कक्षों की गणना "
"करता है।"

#. Tag: para
#: functions.docbook:593
#, no-c-format
msgid "DCOUNT(Database; \"Header\"; Conditions)"
msgstr "DCOUNT(डेटाबेस; \"हेडर\"; शर्तें)"

#. Tag: para
#: functions.docbook:602
#, no-c-format
msgid "DCOUNT(A1:C5; \"Salary\"; A9:A11)"
msgstr "DCOUNT(A1:C5; \"वेतन\"; A9:A11)"

#. Tag: member
#: functions.docbook:606
#, no-c-format
msgid "<link linkend=\"DCOUNTA\">DCOUNTA</link>&nbsp;"
msgstr "<link linkend=\"DCOUNTA\">डीकाउंटा</link>"

#. Tag: title
#: functions.docbook:613
#, no-c-format
msgid "DCOUNTA"
msgstr "डीकाउंटा"

#. Tag: para
#: functions.docbook:614
#, no-c-format
msgid ""
"Counts the cells containing numeric or alphanumeric values in a column of a "
"database specified by a set of conditions."
msgstr ""
"किसी डेटाबेस के स्तंभ में संख्यात्मक या अल्फ़ान्यूमेरिक मानों वाले कक्षों की गणना करता है, जिन्हें "
"शर्तों के एक सेट द्वारा निर्दिष्ट किया जाता है।"

#. Tag: para
#: functions.docbook:619
#, no-c-format
msgid "DCOUNTA(Database; \"Header\"; Conditions)"
msgstr "DCOUNTA(डेटाबेस; \"हेडर\"; शर्तें)"

