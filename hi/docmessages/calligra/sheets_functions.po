#. Tag: title
#: functions.docbook:518
#, no-c-format
msgid "SEXDEC"
msgstr "साठ"

#. Tag: para
#: functions.docbook:519
#, no-c-format
msgid ""
"The SEXDEC() function returns a decimal value. You can also supply a time "
"value."
msgstr "SEXDEC() फ़ंक्शन दशमलव मान लौटाता है। आप समय मान भी दे सकते हैं।"

#. Tag: para
#: functions.docbook:524
#, no-c-format
msgid "SEXDEC(time value) or SEXDEC(hours;minutes;seconds)"
msgstr "SEXDEC(समय मान) या SEXDEC(घंटे;मिनट;सेकंड)"

#. Tag: seg
#: functions.docbook:528 functions.docbook:1588
#, no-c-format
msgid "Hours"
msgstr "घंटे"

#. Tag: seg
#: functions.docbook:529 functions.docbook:1589
#, no-c-format
msgid "Minutes"
msgstr "मिनट"

#. Tag: seg
#: functions.docbook:530 functions.docbook:1590
#, no-c-format
msgid "Seconds"
msgstr "सेकंड"

#. Tag: para
#: functions.docbook:533
#, no-c-format
msgid "SEXDEC(1;5;7) returns 1.0852778"
msgstr "SEXDEC(1;5;7) 1.0852778 लौटाता है"

#. Tag: para
#: functions.docbook:536
#, no-c-format
msgid "DECSEX(\"8:05\") returns 8.08333333"
msgstr "DECSEX(\"8:05\") 8.08333333 लौटाता है"

#. Tag: title
#: functions.docbook:542
#, no-c-format
msgid "STRING"
msgstr "डोरी"

#. Tag: para
#: functions.docbook:543
#, no-c-format
msgid ""
"The STRING() function returns a string value for a given number. It is the "
"same as the NUM2STRING function."
msgstr ""
"STRING() फ़ंक्शन किसी दिए गए नंबर के लिए एक स्ट्रिंग मान लौटाता है। यह NUM2STRING "
"फ़ंक्शन के समान है।"

#. Tag: member
#: functions.docbook:556
#, no-c-format
msgid "<link linkend=\"NUM2STRING\">NUM2STRING</link>&nbsp;"
msgstr "<link linkend=\"NUM2STRING\">NUM2स्ट्रिंग</link>"

