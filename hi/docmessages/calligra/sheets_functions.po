#: functions.docbook:3358
#, no-c-format
msgid "DOLLARDE(1.02; 16) - stands for 1 and 2/16 - returns 1.125"
msgstr "DOLLARDE(1.02; 16) - 1 के लिए है और 2/16 - 1.125 देता है"

