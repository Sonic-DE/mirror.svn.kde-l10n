#. Tag: title
#: functions.docbook:3256
#, no-c-format
msgid "<title>DB</title>"
msgstr "<title>डाटाबेस</title>"

#. Tag: para
#: functions.docbook:3257
#, no-c-format
msgid ""
"The DB() function will calculate the depreciation of an asset for a given "
"period using the fixed-declining balance method. Month is optional, if "
"omitted it is assumed to be 12."
msgstr ""
"DB() फ़ंक्शन निश्चित-गिरावट शेष विधि का उपयोग करके किसी निश्चित अवधि के लिए किसी "
"परिसंपत्ति के मूल्यह्रास की गणना करेगा। महीना वैकल्पिक है, अगर छोड़ दिया जाए तो इसे 12 "
"माना जाता है।"

#. Tag: para
#: functions.docbook:3262
#, no-c-format
msgid "DB(cost; salvage value; life; period [;month])"
msgstr "DB(लागत; बचाव मूल्य; जीवन; अवधि [; महीना])"

