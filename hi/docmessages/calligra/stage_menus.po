msgstr ""
"<shortcut> <keycap>F3</keycap> </shortcut> <guimenu>संपादित करें</"
"guimenu><guimenuitem>अगला खोजें</guimenuitem>"

#. Tag: para
#: menus.docbook:529
#, no-c-format
msgid "Find the next occurrence of a piece of text within a presentation."
msgstr "किसी प्रस्तुति में पाठ के किसी भाग की अगली घटना का पता लगाएं।"

#. Tag: menuchoice
#: menus.docbook:535
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Shift;<keycap>F3</keycap></keycombo> "
"</shortcut> <guimenu>Edit</guimenu><guimenuitem>Find Previous</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Shift;<keycap>F3</keycap></keycombo> "
"</shortcut> <guimenu>संपादित करें</guimenu><guimenuitem>पिछला खोजें</guimenuitem>"

#. Tag: para
#: menus.docbook:543
#, no-c-format
msgid "Find the previous occurrence of a piece of text within a presentation."
msgstr "किसी प्रस्तुति में पाठ के किसी भाग की पिछली उपस्थिति का पता लगाएं।"

#. Tag: menuchoice
#: menus.docbook:550
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>R</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu><guimenuitem>Replace...</guimenuitem>"
msgstr ""
"<शॉर्टकट> <कीकॉम्बो एक्शन = \"सिमुल\">&Ctrl;<कीकैप>आर</कीकैप></कीकॉम्बो> </शॉर्टकट> "
"<गुइमेनू>संपादित करें</गुइमेनु><गुइमेनुइटम>बदलें...</गुइमेनुइटम>"

#. Tag: para
#: menus.docbook:558
#, no-c-format
msgid ""
"Replace one or more occurrences of a piece of text in your presentation with "
"a different piece of text."
msgstr ""
"अपनी प्रस्तुति में पाठ के एक या अधिक भाग को किसी भिन्न पाठ भाग से प्रतिस्थापित करें।"

#. Tag: title
#: menus.docbook:598
#, no-c-format
msgid "View Menu"
msgstr "मेनू देखें"

#. Tag: menuchoice
#: menus.docbook:604
#, no-c-format
msgid "<guimenu>View</guimenu> <guimenuitem>New View</guimenuitem>"
msgstr "<guimenu>देखें</guimenu> <guimenuitem>नया दृश्य</guimenuitem>"

#. Tag: para
#: menus.docbook:609
#, no-c-format
msgid ""
"<action>Opens another window with the same presentation loaded</action> so "
"you can work on more than one slide at a time."
msgstr ""
"<action>उसी प्रेजेंटेशन को लोड करके दूसरी विंडो खोलता है</action> ताकि आप एक समय में एक "
"से अधिक स्लाइड पर काम कर सकें।"

#. Tag: term
#: menus.docbook:684
#, no-c-format
msgid ""
"<menuchoice> <shortcut><keycombo action=\"simul\">&Ctrl;<keycap>F5</keycap></"
"keycombo></shortcut> <guimenu>View</guimenu> <guimenuitem>Normal</"
"guimenuitem> </menuchoice> <menuchoice> <shortcut><keycombo action=\"simul"
"\">&Ctrl;<keycap>F6</keycap></keycombo></shortcut> <guimenu>View</guimenu> "
"<guimenuitem>Notes</guimenuitem> </menuchoice> <menuchoice> "
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>F7</keycap></keycombo></"
"shortcut> <guimenu>View</guimenu> <guimenuitem>Slides Sorter</guimenuitem> </"
"menuchoice>"
msgstr ""
"<menuchoice> <shortcut><keycombo action=\"simul\">&Ctrl;<keycap>F5</keycap></"
"keycombo></shortcut> <guimenu>देखें</guimenu> <guimenuitem>सामान्य</guimenuitem> "
"</menuchoice> <menuchoice> <shortcut><keycombo action=\"simul\">&Ctrl;"
"<keycap>F6</keycap></keycombo></shortcut> <guimenu>देखें</guimenu> "
"<guimenuitem>नोट्स</guimenuitem> </menuchoice> <menuchoice> "
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>F7</keycap></keycombo></"
"shortcut> <guimenu>देखें</guimenu> <guimenuitem>स्लाइड सॉर्टर</guimenuitem> </"
"menuchoice>"

#. Tag: para
#: menus.docbook:702
#, no-c-format
msgid ""
"Switch with these actions between the view modes Normal, where you edit "
"slides, Notes, which shows a slide preview with a textbox for your "
"annotations for the actual slide and the Slides Sorter view, where you can "
"rename, cut, copy and paste slides and arrange them for your presentation."
msgstr ""
"इन क्रियाओं के साथ दृश्य मोड सामान्य के बीच स्विच करें, जहां आप स्लाइड संपादित करते हैं, "
"नोट्स, जो वास्तविक स्लाइड के लिए आपके एनोटेशन के लिए एक टेक्स्टबॉक्स के साथ एक स्लाइड "
"पूर्वावलोकन दिखाता है और स्लाइड्स सॉर्टर दृश्य, जहां आप स्लाइड्स का नाम बदल सकते हैं, उन्हें "
"काट सकते हैं, कॉपी और पेस्ट कर सकते हैं और उन्हें अपनी प्रस्तुति के लिए व्यवस्थित कर सकते हैं।"

#. Tag: menuchoice
#: menus.docbook:711
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>F8</keycap></keycombo></"
"shortcut> <guimenu>View</guimenu> <guimenuitem>Show Master Slides</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>F8</keycap></keycombo></"
"shortcut> <guimenu>देखें</guimenu> <guimenuitem>मास्टर स्लाइड दिखाएं</guimenuitem>"

#. Tag: para
#: menus.docbook:719
#, no-c-format
msgid ""
"<action>Toggle the display of the slide master</action> where you can put "
"objects that you want to appear on each slide in your presentation."
msgstr ""
"<action>स्लाइड मास्टर के प्रदर्शन को टॉगल करें</action> जहां आप उन ऑब्जेक्ट्स को रख सकते "
"हैं जिन्हें आप अपनी प्रस्तुति में प्रत्येक स्लाइड पर दिखाना चाहते हैं।"

#. Tag: menuchoice
#: menus.docbook:745
#, no-c-format
msgid "<guimenu>View</guimenu> <guimenuitem>Show Grid</guimenuitem>"
msgstr "<guimenu>देखें</guimenu> <guimenuitem>ग्रिड दिखाएं</guimenuitem>"

#. Tag: para
#: menus.docbook:751
#, no-c-format
msgid ""
"If enabled, &stage; will display a grid of dots representing the "
"intersections of imaginary horizontal and vertical lines. You can use these "
"dots to precisely position objects on the slide."
msgstr ""
"यदि सक्षम किया गया है, तो &stage; काल्पनिक क्षैतिज और ऊर्ध्वाधर रेखाओं के प्रतिच्छेदन को "
"दर्शाने वाले बिंदुओं का एक ग्रिड प्रदर्शित करेगा। आप स्लाइड पर ऑब्जेक्ट को सटीक रूप से रखने के "
"लिए इन बिंदुओं का उपयोग कर सकते हैं।"

#. Tag: menuchoice
#: menus.docbook:759
#, no-c-format
msgid "<guimenu>View</guimenu><guimenuitem> Snap to Grid</guimenuitem>"
msgstr "<guimenu>देखें</guimenu><guimenuitem> ग्रिड पर स्नैप करें</guimenuitem>"

#. Tag: para
#: menus.docbook:762
#, no-c-format
msgid ""
"If this is enabled, when dropping or moving objects on the slide the top "
"left corner of the object will <quote>snap</quote> or move, to the nearest "
"grid point."
msgstr ""
"यदि यह सक्षम है, तो स्लाइड पर ऑब्जेक्ट को छोड़ते या हिलाते समय ऑब्जेक्ट का ऊपरी बायां "
"कोना निकटतम ग्रिड बिंदु पर <quote>स्नैप</quote> हो जाएगा या चला जाएगा।"

#. Tag: para
#: menus.docbook:765
#, no-c-format
msgid ""
"This does reduce your freedom to freely position objects on the slide, "
"however it also helps to line up objects precisely. It is easily disabled or "
"enabled with this menu entry, allowing you the best of both worlds."
msgstr ""
"यह स्लाइड पर ऑब्जेक्ट को स्वतंत्र रूप से रखने की आपकी स्वतंत्रता को कम करता है, हालांकि यह "
"ऑब्जेक्ट को सटीक रूप से पंक्तिबद्ध करने में भी मदद करता है। इस मेनू प्रविष्टि के साथ इसे आसानी "
"से अक्षम या सक्षम किया जा सकता है, जिससे आपको दोनों दुनिया का सबसे अच्छा लाभ मिलता है।"

#. Tag: menuchoice
#: menus.docbook:774
#, no-c-format
msgid "<guimenu>View</guimenu> <guimenuitem>Show Guides</guimenuitem>"
msgstr "<guimenu>देखें</guimenu> <guimenuitem>मार्गदर्शिकाएँ दिखाएँ</guimenuitem>"

#. Tag: para
#: menus.docbook:780
#, no-c-format
msgid ""
"When working in &stage; you can drag a <quote>guide line</quote> from either "
"the horizontal or vertical ruler onto your document. This guide-line will "
"not print or display in the finished presentation, it is simply to help you "
"align objects on screen. If this item is enabled, these guide lines will be "
"visible. If this is disabled, they will not be visible."
msgstr ""
"&stage; में काम करते समय आप क्षैतिज या ऊर्ध्वाधर रूलर से अपने दस्तावेज़ पर <quote>गाइड "
"लाइन</quote> खींच सकते हैं। यह गाइड-लाइन तैयार प्रस्तुति में प्रिंट या प्रदर्शित नहीं होगी, "
"यह केवल स्क्रीन पर ऑब्जेक्ट को संरेखित करने में आपकी सहायता करने के लिए है। यदि यह आइटम "
"सक्षम है, तो ये गाइड लाइन दिखाई देंगी। यदि यह अक्षम है, तो वे दिखाई नहीं देंगी।"

#. Tag: para
#: menus.docbook:787
#, no-c-format
msgid ""
"Guide lines work across slides, allowing you to align objects the same way "
"across multiple slides."
msgstr ""
"गाइड लाइनें स्लाइडों पर काम करती हैं, जिससे आप ऑब्जेक्ट्स को एकाधिक स्लाइडों पर समान तरीके "
"से संरेखित कर सकते हैं।"

#. Tag: para
#: menus.docbook:790
#, no-c-format
msgid ""
"Disabling (hiding) guide lines does not delete them. If you have created "
"guide lines, and then disabled this item, enabling it again will retain the "
"guide lines you created."
msgstr ""
"गाइड लाइन को अक्षम (छिपाने) से वे मिटती नहीं हैं। यदि आपने गाइड लाइन बनाई हैं, और फिर "
"इस आइटम को अक्षम कर दिया है, तो इसे फिर से सक्षम करने से आपके द्वारा बनाई गई गाइड "
"लाइन बनी रहेंगी।"

#. Tag: menuchoice
#: menus.docbook:815
#, no-c-format
msgid "<guimenu>View</guimenu> <guisubmenu>Zoom</guisubmenu>"
msgstr "<मेनू>देखें</मेनू> <मेनू>ज़ूम करें</मेनू>"

#. Tag: para
#: menus.docbook:821
#, no-c-format
msgid ""
"This submenu allows you to zoom in or out of the slide. Several predefined "
"zoom levels are available, including <guimenuitem>Fit Page</guimenuitem> to "
"scale the entire slide so as to be visible in the size window you have open, "
"and <guimenuitem>Fit Page Width</guimenuitem> to scale the slide so it fills "
"the entire width of the window, although you may now have to scroll "
"vertically. There are also several other scaling choices, from "
"<guimenuitem>33%</guimenuitem> up to <guimenuitem>500%</guimenuitem>."
msgstr ""
"यह सबमेनू आपको स्लाइड को ज़ूम इन या आउट करने की अनुमति देता है। कई पूर्वनिर्धारित ज़ूम स्तर "
"उपलब्ध हैं, जिसमें <guimenuitem>फ़िट पेज</guimenuitem> शामिल है, जो पूरी स्लाइड को स्केल "
"करता है ताकि वह आपके द्वारा खोली गई आकार विंडो में दिखाई दे, और <guimenuitem>फ़िट पेज "
"चौड़ाई</guimenuitem> स्लाइड को स्केल करता है ताकि यह विंडो की पूरी चौड़ाई को भर दे, "
"हालाँकि अब आपको लंबवत स्क्रॉल करना पड़ सकता है। <guimenuitem>33%</guimenuitem> से "
"लेकर <guimenuitem>500%</guimenuitem> तक कई अन्य स्केलिंग विकल्प भी हैं।"

#. Tag: title
#: menus.docbook:840
#, no-c-format
msgid "Insert Menu"
msgstr "मेनू डालें"

#. Tag: menuchoice
#: menus.docbook:863
#, no-c-format
msgid "<guimenu>Insert</guimenu> <guisubmenu>Variable</guisubmenu>"
msgstr "<guimenu>सम्मिलित करें</guimenu> <guimenu>वेरिएबल</guimenu>"

#. Tag: para
#: menus.docbook:869
#, no-c-format
msgid ""
"Here you can insert a variable that is filled in with a value that may be "
"updated as you update the document."
msgstr ""
"यहां आप एक चर सम्मिलित कर सकते हैं जो एक मान से भरा होता है जिसे आपके द्वारा दस्तावेज़ को "
"अद्यतन करने पर अद्यतन किया जा सकता है।"

#. Tag: menuchoice
#: menus.docbook:921
#, no-c-format
msgid "<guimenu>Insert</guimenu><guimenuitem>Import Slideshow...</guimenuitem>"
msgstr ""
"<guimenu>सम्मिलित करें</guimenu><guimenuitem>स्लाइड शो आयात करें...</guimenuitem>"

#. Tag: para
#: menus.docbook:926
#, no-c-format
msgid ""
"<action>Insert an already existing presentation.</action> A standard &kde; "
"file open dialog will appear, allowing you to choose a "
"<guilabel>OpenDocument Presentation</guilabel> (.odp), which will be "
"inserted after the last slide in your current presentation."
msgstr ""
"<action>पहले से मौजूद प्रस्तुति सम्मिलित करें.</action> एक मानक &kde; फ़ाइल खोलने वाला "
"संवाद प्रकट होगा, जो आपको <guilabel>OpenDocument प्रस्तुति</guilabel> (.odp) चुनने "
"की अनुमति देगा, जिसे आपकी वर्तमान प्रस्तुति में अंतिम स्लाइड के बाद सम्मिलित किया जाएगा।"

#. Tag: menuchoice
#: menus.docbook:934
#, no-c-format
msgid ""
"<guimenu>Insert</guimenu> <guimenuitem>Insert Pictures as Slides...</"
"guimenuitem>"
msgstr ""
"<guimenu>सम्मिलित करें</guimenu> <guimenutem>छवियों को स्लाइड के रूप में सम्मिलित करें..."
"</guimenuitem>"

#. Tag: para
#: menus.docbook:940
#, no-c-format
msgid ""
"Use this menu item to insert one or more pictures, each is inserted on a new "
"slide. This is useful for the people who want to use &stage; to make a slide "
"show."
msgstr ""
"इस मेनू आइटम का उपयोग एक या अधिक चित्र सम्मिलित करने के लिए करें, प्रत्येक चित्र एक नई "
"स्लाइड पर डाला जाता है। यह उन लोगों के लिए उपयोगी है जो स्लाइड शो बनाने के लिए "
"&stage; का उपयोग करना चाहते हैं।"

#. Tag: menuchoice
#: menus.docbook:1061
#, no-c-format
msgid "<guimenu>Insert</guimenu> <guimenuitem>Scan Image...</guimenuitem>"
msgstr "<guimenu>सम्मिलित करें</guimenu> <guimenuitem>छवि स्कैन करें...</guimenuitem>"

#. Tag: para
#: menus.docbook:1067
#, no-c-format
msgid ""
"<action>Scan an image with a scanner.</action> This requires you have a "
"scanner installed. It opens a scan dialog to allow the use of the scanner."
msgstr ""
"<action>स्कैनर से छवि स्कैन करें.</action> इसके लिए आपके पास स्कैनर इंस्टॉल होना चाहिए। "
"यह स्कैनर के उपयोग की अनुमति देने के लिए एक स्कैन डायलॉग खोलता है।"

#. Tag: title
#: menus.docbook:1077
#, no-c-format
msgid "Format Menu"
msgstr "प्रारूप मेनू"

#. Tag: menuchoice
#: menus.docbook:1084
#, no-c-format
msgid "<guimenu>Format</guimenu> <guimenuitem>Font...</guimenuitem>"
msgstr "<guimenu>प्रारूप</guimenu> <guimenuitem>फ़ॉन्ट...</guimenuitem>"

#. Tag: para
#: menus.docbook:1091
#, no-c-format
msgid ""
"The <guilabel>Select Font</guilabel> dialog contains options for selected "
"segments of text."
msgstr "<guilabel>फ़ॉन्ट चुनें</guilabel> संवाद में पाठ के चयनित खंडों के लिए विकल्प होते हैं।"

#. Tag: para
#: menus.docbook:1094
#, no-c-format
msgid ""
"With this dialog, you can <action>change the font, style and size of "
"selected text</action>. The <interface>preview box</interface> at the bottom "
"allows you to <action>approximate changes before you make them</action>."
msgstr ""
"इस डायलॉग के साथ, आप <action>चयनित टेक्स्ट का फ़ॉन्ट, शैली और आकार बदल सकते हैं</"
"action>। नीचे स्थित <interface>पूर्वावलोकन बॉक्स</interface> आपको <action>परिवर्तन "
"करने से पहले उनका अनुमान लगाने</action> की अनुमति देता है।"

#. Tag: menuchoice
#: menus.docbook:1103
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> &Ctrl;&Alt;<keycap>P</keycap> </"
"keycombo> </shortcut> <guimenu>Format</guimenu> <guimenuitem>Paragraph...</"
"guimenuitem>"
msgstr ""
"<शॉर्टकट> <keycombo action=\"simul\"> &Ctrl;&Alt;<keycap>P</keycap> </"
"keycombo> </shortcut> <guimenu>स्वरूप</guimenu> <guimenuitem>पैराग्राफ...</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:1115
#, no-c-format
msgid ""
"The <guilabel>Paragraph Format</guilabel> dialog contains settings for "
"larger blocks of text, such as paragraphs. Using this dialog, you can set "
"indenting, line spacing, bullet/numbered list and border settings."
msgstr ""
"<guilabel>पैराग्राफ फ़ॉर्मेट</guilabel> संवाद में पैराग्राफ़ जैसे टेक्स्ट के बड़े ब्लॉक के लिए "
"सेटिंग होती है। इस संवाद का उपयोग करके, आप इंडेंटिंग, लाइन स्पेसिंग, बुलेट/नंबर वाली सूची और "
"बॉर्डर सेटिंग सेट कर सकते हैं।"

#. Tag: menuchoice
#: menus.docbook:1124
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Alt;<keycap>S</keycap></"
"keycombo> </shortcut> <guimenu>Format</guimenu> <guimenuitem>Style Manager</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Alt;<keycap>S</keycap></"
"keycombo> </shortcut> <guimenu>Format</guimenu> <guimenuitem>स्टाइल मैनेजर</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:1133
#, no-c-format
msgid ""
"The <guilabel>Style Manager</guilabel> allows you to create an entire set of "
"attributes that will be applied to selected text all at once."
msgstr ""
"<guilabel>शैली प्रबंधक</guilabel> आपको विशेषताओं का एक संपूर्ण सेट बनाने की अनुमति देता "
"है जो चयनित पाठ पर एक ही बार में लागू हो जाएगा।"

#. Tag: menuchoice
#: menus.docbook:1325
#, no-c-format
msgid "<guimenu>Format</guimenu> <guimenuitem>Page Layout...</guimenuitem>"
msgstr "<guimenu>प्रारूप</guimenu> <guimenuitem>पेज लेआउट...</guimenuitem>"

#. Tag: para
#: menus.docbook:1330
#, no-c-format
msgid ""
"Allows you to set the page details. You can specify the margins, the "
"orientation, either portrait (higher than wide) or Landscape (wider than "
"high) formats. There are many templates, such as screen, A4, US legal."
msgstr ""
"आपको पेज विवरण सेट करने की अनुमति देता है। आप मार्जिन, ओरिएंटेशन, पोर्ट्रेट (चौड़े से अधिक) "
"या लैंडस्केप (ऊंचे से अधिक चौड़े) प्रारूप निर्दिष्ट कर सकते हैं। स्क्रीन, A4, US लीगल जैसे कई "
"टेम्पलेट हैं।"

#. Tag: title
#: menus.docbook:1659
#, no-c-format
msgid "Slide Menu"
msgstr "स्लाइड मेनू"

#. Tag: menuchoice
#: menus.docbook:1664
#, no-c-format
msgid "<guimenu>Slide</guimenu> <guimenuitem>Insert Slide</guimenuitem>"
msgstr "<guimenu>स्लाइड</guimenu> <guimenuitem>स्लाइड डालें</guimenuitem>"

#. Tag: action
#: menus.docbook:1670
#, no-c-format
msgid "Insert a new slide after the current one."
msgstr "वर्तमान स्लाइड के बाद एक नई स्लाइड डालें।"

#. Tag: menuchoice
#: menus.docbook:1676
#, no-c-format
msgid "<guimenu>Slide</guimenu> <guimenuitem>Copy Slide</guimenuitem>"
msgstr "<guimenu>स्लाइड</guimenu> <guimenuitem>स्लाइड कॉपी करें</guimenuitem>"

#. Tag: action
#: menus.docbook:1682
#, no-c-format
msgid "Copy the current slide to the clipboard."
msgstr "वर्तमान स्लाइड को क्लिपबोर्ड पर कॉपी करें."

#. Tag: menuchoice
#: menus.docbook:1688
#, no-c-format
msgid "<guimenu>Slide</guimenu> <guimenuitem>Delete Slide</guimenuitem>"
msgstr "<guimenu>स्लाइड</guimenu> <guimenutem>स्लाइड हटाएं</guimenuitem>"

#. Tag: para
#: menus.docbook:1693
#, no-c-format
msgid ""
"<action>Delete the current page from the presentation.</action> You will be "
"asked to confirm this action."
msgstr ""
"<action>प्रस्तुति से वर्तमान पृष्ठ हटाएँ.</action> आपसे इस क्रिया की पुष्टि करने के लिए "
"कहा जाएगा."

#. Tag: menuchoice
#: menus.docbook:1700
#, no-c-format
msgid ""
"<shortcut><keycap>PageUp</keycap></shortcut> <guimenu>Slide</guimenu> "
"<guimenuitem>Previous Slide</guimenuitem>"
msgstr ""
"<shortcut><keycap>PageUp</keycap></shortcut> <guimenu>स्लाइड</guimenu> "
"<guimenuitem>पिछली स्लाइड</guimenuitem>"

#. Tag: para
#: menus.docbook:1707
#, no-c-format
msgid "Go back to the previous slide in the slide show."
msgstr "स्लाइड शो में पिछली स्लाइड पर वापस जाएँ।"

#. Tag: menuchoice
#: menus.docbook:1713
#, no-c-format
msgid ""
"<shortcut><keycap>PageDown</keycap></shortcut> <guimenu>Slide</guimenu> "
"<guimenuitem>Next Slide</guimenuitem>"
msgstr ""
"<shortcut><keycap>PageDown</keycap></shortcut> <guimenu>स्लाइड</guimenu> "
"<guimenuitem>अगली स्लाइड</guimenuitem>"

#. Tag: para
#: menus.docbook:1720
#, no-c-format
msgid "Go to the next slide in the slide show."
msgstr "स्लाइड शो में अगली स्लाइड पर जाएं।"

#. Tag: menuchoice
#: menus.docbook:1726
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>Home</keycap></keycombo></"
"shortcut> <guimenu>Slide</guimenu> <guimenuitem>First Slide</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>होम</keycap></keycombo></"
"shortcut> <guimenu>स्लाइड</guimenu> <guimenuitem>पहली स्लाइड</guimenuitem>"

#. Tag: para
#: menus.docbook:1733
#, no-c-format
msgid "Go directly to the first slide in the slide show."
msgstr "स्लाइड शो में सीधे पहली स्लाइड पर जाएं।"

#. Tag: menuchoice
#: menus.docbook:1739
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>End</keycap></keycombo></"
"shortcut> <guimenu>Slide</guimenu> <guimenuitem>Last Slide</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>अंत</keycap></keycombo></"
"shortcut> <guimenu>स्लाइड</guimenu> <guimenuitem>अंतिम स्लाइड</guimenuitem>"

#. Tag: para
#: menus.docbook:1746
#, no-c-format
msgid "Go immediately to the final slide in the slide show."
msgstr "स्लाइड शो में तुरंत अंतिम स्लाइड पर जाएं।"

#. Tag: title
#: menus.docbook:1753
#, no-c-format
msgid "Slide Show Menu"
msgstr "स्लाइड शो मेनू"

#. Tag: menuchoice
#: menus.docbook:1759
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Shift;<keycap>F5</keycap></keycombo></"
"shortcut> <guimenu>Slide Show</guimenu> <guisubmenu>Start Presentation</"
"guisubmenu> <guimenuitem>From Current Slide</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Shift;<keycap>F5</keycap></keycombo></"
"shortcut> <guimenu>स्लाइड शो</guimenu> <guisubmenu>प्रस्तुति आरंभ करें</guisubmenu> "
"<guimenuitem>वर्तमान स्लाइड से</guimenuitem>"

#. Tag: para
#: menus.docbook:1767
#, no-c-format
msgid "Begin the slideshow from the current slide."
msgstr "वर्तमान स्लाइड से स्लाइड शो शुरू करें।"

#. Tag: menuchoice
#: menus.docbook:1773
#, no-c-format
msgid ""
"<shortcut><keycap>F5</keycap></shortcut> <guimenu>Slide Show</guimenu> "
"<guisubmenu>Start Presentation</guisubmenu> <guimenuitem>From First Slide</"
"guimenuitem>"
msgstr ""
"<shortcut><keycap>F5</keycap></shortcut> <guimenu>स्लाइड शो</guimenu> "
"<guisubmenu>प्रस्तुति आरंभ करें</guisubmenu> <guimenuitem>पहली स्लाइड से</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:1781
#, no-c-format
msgid "Begin the slideshow from the first slide."
msgstr "स्लाइड शो पहली स्लाइड से शुरू करें।"

#. Tag: menuchoice
#: menus.docbook:1787
#, no-c-format
msgid ""
"<guimenu>Slide Show</guimenu> <guimenuitem>Configure Slide Show...</"
"guimenuitem>"
msgstr ""
"<guimenu>स्लाइड शो</guimenu> <guimenuitem>स्लाइड शो कॉन्फ़िगर करें...</guimenuitem>"

#. Tag: para
#: menus.docbook:1793
#, no-c-format
msgid ""
"You can set up the properties for the entire slide show here, including "
"whether to show the duration on screen, which of the slides in a "
"presentation to include, and several other global settings."
msgstr ""
"आप यहां संपूर्ण स्लाइड शो के लिए गुण सेट कर सकते हैं, जिसमें स्क्रीन पर अवधि दिखाना है या "
"नहीं, प्रस्तुति में कौन सी स्लाइड शामिल करनी है, तथा कई अन्य वैश्विक सेटिंग्स शामिल हैं।"

#. Tag: title
#: menus.docbook:1851
#, no-c-format
msgid "Settings Menu"
msgstr "सेटिंग्स मेनू"

#. Tag: para
#: menus.docbook:1853
#, no-c-format
msgid "The <guimenu>Settings</guimenu> menu allows you to customize &stage;."
msgstr "<guimenu>सेटिंग्स</guimenu> मेनू आपको &stage; को अनुकूलित करने की अनुमति देता है।"

#. Tag: menuchoice
#: menus.docbook:1860
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guisubmenu>Show Toolbar</guisubmenu>"
msgstr "<guimenu>सेटिंग्स</guimenu> <guisubmenu>टूलबार दिखाएं</guisubmenu>"

#. Tag: para
#: menus.docbook:1866
#, no-c-format
msgid "In this menu you can both enable and disable the display of toolbar."
msgstr "इस मेनू में आप टूलबार के प्रदर्शन को सक्षम और अक्षम दोनों कर सकते हैं।"

#. Tag: menuchoice
#: menus.docbook:1877
#, no-c-format
msgid ""
"<guimenu>Settings</guimenu> <guimenuitem>Configure Shortcuts...</guimenuitem>"
msgstr ""
"<guimenu>सेटिंग्स</guimenu> <guimenuitem>शॉर्टकट कॉन्फ़िगर करें...</guimenuitem>"

#. Tag: para
#: menus.docbook:1884
#, no-c-format
msgid ""
"<guimenuitem>Configure Shortcuts</guimenuitem> allows you to assign a "
"keyboard shortcut to actions that &stage; menus or icons contain."
msgstr ""
"<guimenuitem>शॉर्टकट कॉन्फ़िगर करें</guimenuitem> आपको उन क्रियाओं के लिए कीबोर्ड "
"शॉर्टकट निर्दिष्ट करने की अनुमति देता है जो &stage; मेनू या आइकन में शामिल हैं।"

#. Tag: screeninfo
#: menus.docbook:1889
#, no-c-format
msgid "Customize Shortcuts"
msgstr "शॉर्टकट अनुकूलित करें"

#. Tag: phrase
#: menus.docbook:1895
#, no-c-format
msgid "Customizing the shortcuts"
msgstr "शॉर्टकट को अनुकूलित करना"

#. Tag: para
#: menus.docbook:1900
#, no-c-format
msgid ""
"If you try to assign a shortcut that is already used, it will give you a "
"warning message. Highlight what you want to do (in the picture, I have "
"chosen to make a keyboard shortcut to <guilabel>About KDE</guilabel>)."
msgstr ""
"यदि आप पहले से उपयोग किए जा रहे शॉर्टकट को असाइन करने का प्रयास करते हैं, तो यह आपको "
"एक चेतावनी संदेश देगा। आप जो करना चाहते हैं उसे हाइलाइट करें (चित्र में, मैंने "
"<guilabel>About KDE</guilabel> के लिए कीबोर्ड शॉर्टकट बनाने का विकल्प चुना है)।"

#. Tag: para
#: menus.docbook:1905
#, no-c-format
msgid ""
"Click the radio button to the <guilabel>Custom</guilabel> key setting and "
"type the key you want to use. I assigned <keycap>Control</keycap> key and "
"<keycap>Y</keycap> to bring up the <quote>About KDE</quote> dialog box."
msgstr ""
"<guilabel>Custom</guilabel> कुंजी सेटिंग के लिए रेडियो बटन पर क्लिक करें और वह कुंजी "
"टाइप करें जिसे आप उपयोग करना चाहते हैं। मैंने <quote>About KDE</quote> संवाद बॉक्स लाने "
"के लिए <keycap>Control</keycap> कुंजी और <keycap>Y</keycap> असाइन किया है।"

#. Tag: para
#: menus.docbook:1910
#, no-c-format
msgid ""
"The button shows what has been assigned. Click <guibutton>OK</guibutton> to "
"make the changes, click <guibutton>Default</guibutton> to restore whatever "
"was assigned as default, click <guibutton>Cancel</guibutton> to do nothing "
"and leave the dialog."
msgstr ""
"बटन दिखाता है कि क्या असाइन किया गया है। परिवर्तन करने के लिए <guibutton>OK</"
"guibutton> पर क्लिक करें, जो भी डिफ़ॉल्ट के रूप में असाइन किया गया था उसे पुनर्स्थापित "
"करने के लिए <guibutton>Default</guibutton> पर क्लिक करें, कुछ भी न करने और संवाद "
"छोड़ने के लिए <guibutton>Cancel</guibutton> पर क्लिक करें।"

#. Tag: menuchoice
#: menus.docbook:1921
#, no-c-format
msgid ""
"<guimenu>Settings</guimenu> <guimenuitem>Configure Toolbars...</guimenuitem>"
msgstr ""
"<guimenu>सेटिंग्स</guimenu> <guimenuitem>टूलबार कॉन्फ़िगर करें...</guimenuitem>"

#. Tag: para
#: menus.docbook:1927
#, no-c-format
msgid ""
"Configure Toolbars allows you to add or delete icons on each of the toolbars."
msgstr "टूलबार कॉन्फ़िगर करने से आप प्रत्येक टूलबार पर आइकन जोड़ या हटा सकते हैं।"

#. Tag: screeninfo
#: menus.docbook:1931
#, no-c-format
msgid "<screeninfo>Configuring &stage; toolbars</screeninfo>"
msgstr "<screeninfo>टूलबार कॉन्फ़िगर करना</screeninfo>"

#. Tag: phrase
#: menus.docbook:1937
#, no-c-format
msgid "<phrase>Configuring &stage; toolbars</phrase>"
msgstr "<phrase>टूलबार कॉन्फ़िगर करना</phrase>"

#. Tag: para
#: menus.docbook:1942
#, no-c-format
msgid ""
"At the top is a drop down box to enable you to choose which toolbar you want "
"to modify. In the picture the <guilabel>File</guilabel> toolbar is selected. "
"If I want to add the <guiicon>Dockers</guiicon> icon to that toolbar, I "
"click the entry in the left window. The arrow pointing right becomes "
"available, if I click the arrow the <guiicon>Dockers</guiicon> entry is "
"added to the selected toolbar. The left arrow is available when you click in "
"the right side window. It allows you to remove an icon from a toolbar. The "
"up and down arrows become active when an item on the right side is selected. "
"You can also move the highlight in the right side window up and down with "
"the keyboard arrow keys. By clicking on the arrows with the mouse you can "
"change the order of the entries in the menu."
msgstr ""
"शीर्ष पर एक ड्रॉप डाउन बॉक्स है जिससे आप चुन सकते हैं कि आप किस टूलबार को संशोधित करना "
"चाहते हैं। चित्र में <guilabel>File</guilabel> टूलबार चयनित है। यदि मैं उस टूलबार में "
"<guiicon>Dockers</guiicon> आइकन जोड़ना चाहता हूँ, तो मैं बाईं विंडो में प्रविष्टि पर "
"क्लिक करता हूँ। दाईं ओर इंगित करने वाला तीर उपलब्ध हो जाता है, यदि मैं तीर पर क्लिक "
"करता हूँ तो <guiicon>Dockers</guiicon> प्रविष्टि चयनित टूलबार में जुड़ जाती है। जब आप "
"दाईं ओर की विंडो में क्लिक करते हैं तो बायाँ तीर उपलब्ध होता है। यह आपको टूलबार से कोई "
"आइकन हटाने की अनुमति देता है। जब दाईं ओर का कोई आइटम चुना जाता है तो ऊपर और नीचे के "
"तीर सक्रिय हो जाते हैं। आप कीबोर्ड के तीर कुंजियों के साथ दाईं ओर की विंडो में हाइलाइट को "
"ऊपर और नीचे भी ले जा सकते हैं। माउस के साथ तीरों पर क्लिक करके आप मेनू में प्रविष्टियों के "
"क्रम को बदल सकते हैं।"

#. Tag: menuchoice
#: menus.docbook:1961
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Themes</guimenuitem>"
msgstr "<guimenu>सेटिंग्स</guimenu> <guimenuitem>थीम्स</guimenuitem>"

#. Tag: para
#: menus.docbook:1965
#, no-c-format
msgid ""
"<action>Choose the color theme for &stage; window.</action> You can choose "
"one of the predefined color schemes or select <guimenuitem>Configuration...</"
"guimenuitem> to open <ulink url=\"help:/kcontrol/colors\">&systemsettings; "
"color selection module</ulink>."
msgstr ""
"<action>&stage; विंडो के लिए रंग थीम चुनें.</action> आप पूर्वनिर्धारित रंग योजनाओं में से "
"एक चुन सकते हैं या <ulink url=\"help:/kcontrol/colors\">&systemsettings; रंग चयन "
"मॉड्यूल</ulink> खोलने के लिए <guimenuitem>कॉन्फ़िगरेशन...</guimenuitem> का चयन कर "
"सकते हैं."

#. Tag: menuchoice
#: menus.docbook:1973
#, no-c-format
msgid ""
"<guimenu>Settings</guimenu> <guimenuitem>Configure Stage...</guimenuitem>"
msgstr "<guimenu>सेटिंग्स</guimenu> <guimenuitem>स्टेज कॉन्फ़िगर करें...</guimenuitem>"

#. Tag: para
#: menus.docbook:1979
#, no-c-format
msgid ""
"See the <link linkend=\"configure-dialog\">Configure &stage;</link> section "
"for a complete explanation of all &stage; settings."
msgstr ""
"देखें<link linkend=\"configure-dialog\"> &amp;स्टेज कॉन्फ़िगर करें</link> सभी &amp;"
"stage; सेटिंग्स की पूरी व्याख्या के लिए अनुभाग देखें."

