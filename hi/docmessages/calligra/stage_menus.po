msgstr "वर्तमान स्लाइड पर सभी ऑब्जेक्ट और टेक्स्ट का चयन करें।"

#. Tag: menuchoice
#: menus.docbook:490
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>A</keycap></"
"keycombo> </shortcut> <guimenu>Edit</guimenu> <guimenuitem>Deselect</"
"guimenuitem>"
msgstr ""
"<शॉर्टकट> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>A</keycap></"
"keycombo> </shortcut> <guimenu>संपादित करें</guimenu> <guimenuitem>अचयनित करें</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:499
#, no-c-format
msgid "Deselect any currently selected objects."
msgstr "वर्तमान में चयनित किसी भी ऑब्जेक्ट का चयन रद्द करें."

#. Tag: menuchoice
#: menus.docbook:505
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>F</keycap></keycombo></"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Find...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>F</keycap></keycombo></"
"shortcut> <guimenu>संपादित करें</guimenu> <guimenuitem>ढूंढें...</guimenuitem>"

#. Tag: action
#: menus.docbook:514
#, no-c-format
msgid "Search for text within the presentation."
msgstr "प्रस्तुति के भीतर पाठ खोजें."

