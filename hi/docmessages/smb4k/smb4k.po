#. Tag: para
#: index.docbook:766
#, no-c-format
msgid "&smb4k; provides two possibilities to open a mounted share:"
msgstr "&smb4k; माउंटेड शेयर को खोलने के लिए दो संभावनाएं प्रदान करता है:"

#. Tag: title
#: index.docbook:768
#, no-c-format
msgid "Open a share with &konsole;"
msgstr "&konsole; के साथ शेयर खोलें"

#. Tag: para
#: index.docbook:769
#, no-c-format
msgid ""
"You can open the mounted share in &konsole; by selecting the "
"<menuchoice><shortcut><keycombo action=\"simul\">&Ctrl;<keycap>L</keycap></"
"keycombo></shortcut><guimenuitem>Open with Konsole</guimenuitem></"
"menuchoice> action. This is useful if you need to run a shell script on the "
"share or do something similar."
msgstr ""
"आप <menuchoice><shortcut><keycombo action=\"simul\">&Ctrl;<keycap>L</"
"keycap></keycombo></shortcut><guimenuitem>Open with Konsole</guimenuitem></"
"menuchoice> क्रिया का चयन करके &konsole; में माउंटेड शेयर खोल सकते हैं। यह तब उपयोगी "
"होता है जब आपको शेयर पर शेल स्क्रिप्ट चलाने या कुछ ऐसा ही करने की आवश्यकता होती है।"

#. Tag: title
#: index.docbook:771
#, no-c-format
msgid "Open a share with the default file manager"
