msgstr "\"उपस्थिति\" कॉन्फ़िगरेशन टैब"

#. Tag: title
#: index.docbook:1529
#, no-c-format
msgid "Main Window"
msgstr "मुख्य विंडो"

#. Tag: guibutton
#: index.docbook:1534
#, no-c-format
msgid "Tab orientation"
msgstr "टैब अभिविन्यास"

#. Tag: para
#: index.docbook:1537
#, no-c-format
msgid ""
"Define the location of the tabs if the dock widgets in the main window are "
"arranged as tabs. The following values can be chosen:"
msgstr ""
"यदि मुख्य विंडो में डॉक विजेट टैब के रूप में व्यवस्थित हैं, तो टैब का स्थान निर्धारित करें। "
"निम्नलिखित मान चुने जा सकते हैं:"

#. Tag: guimenuitem
