#. Tag: cmdsynopsis
#: man-plasmoidviewer.1.docbook:25
#, no-c-format
msgid ""
"<command>plasmoidviewer</command> <group choice=\"opt\"><option>-v, --"
"version</option></group> <group choice=\"opt\"><option>-c, --containment</"
"option> <replaceable>name</replaceable></group> <group choice=\"opt"
"\"><option>-a, --applet</option> <replaceable>name</replaceable></group> "
"<group choice=\"opt\"><option>-f, --formfactor</option> <replaceable>name</"
"replaceable></group> <group choice=\"opt\"><option>-l, --location</option> "
"<replaceable>name</replaceable></group> <group choice=\"opt\"><option>-x, --"
"xPosition</option> <replaceable>xPosition</replaceable></group> <group "
"choice=\"opt\"><option>-y, --yPosition</option> <replaceable>yPosition</"
"replaceable></group> <group choice=\"opt\"><option>-s, --size</option> "
"<replaceable>widthXheight</replaceable></group> <group choice=\"opt"
"\"><option>-p, --pixmapcache</option> <replaceable>size</replaceable></"
"group> <group choice=\"opt\"><option>-t, --theme</option> <replaceable>name</"
"replaceable></group> <group choice=\"opt\"><option>-h, --help</option></"
"group> <arg choice=\"opt\">args</arg>"
msgstr ""
"<command>प्लास्मॉइडव्यूअर</command><group choice=\"opt\"><option value=\"-v, --"
"version\"> -v, --संस्करण</option></group><group choice=\"opt\"><option value="
"\"-c, --containment\"> -सी, --कंटेनमेंट</option><replaceable> नाम</replaceable></"
"group><group choice=\"opt\"><option value=\"-a, --applet\"> -ए, --एप्लेट</"
"option><replaceable> नाम</replaceable></group><group choice=\"opt\"><option "
"value=\"-f, --formfactor\"> -f, --फॉर्मफैक्टर</option><replaceable> नाम</"
"replaceable></group><group choice=\"opt\"><option value=\"-l, --location\"> -"
"l, --स्थान</option><replaceable> नाम</replaceable></group><group choice=\"opt"
"\"><option value=\"-x, --xPosition\"> -x, --xस्थिति</option><replaceable> "
"एक्सपोजिशन</replaceable></group><group choice=\"opt\"><option value=\"-y, --"
"yPosition\"> -y, --yस्थिति</option><replaceable> yस्थिति</replaceable></"
"group><group choice=\"opt\"><option value=\"-s, --size\"> -एस, --आकार</"
"option><replaceable> चौड़ाईXऊंचाई</replaceable></group><group choice=\"opt"
"\"><option value=\"-p, --pixmapcache\"> -p, --पिक्समैपकैश</option><replaceable> "
"आकार</replaceable></group><group choice=\"opt\"><option value=\"-t, --theme"
"\"> -टी, --थीम</option><replaceable> नाम</replaceable></group><group choice="
"\"opt\"><option value=\"-h, --help\"> -एच, --सहायता</option></group><arg "
"choice=\"opt\"> आर्ग</arg>"

#. Tag: title
#: man-plasmoidviewer.1.docbook:44
#, no-c-format
msgid "Description"
msgstr "विवरण"

#. Tag: para
#: man-plasmoidviewer.1.docbook:45
#, no-c-format
msgid ""
"<command>plasmoidviewer</command> is a graphical tool allowing developers to "
"test Plasma applets."
msgstr ""
"<command>plasmoidviewer</command> एक ग्राफिकल टूल है जो डेवलपर्स को प्लाज्मा एप्लेट्स "
"का परीक्षण करने की अनुमति देता है।"

#. Tag: para
#: man-plasmoidviewer.1.docbook:48
#, no-c-format
msgid ""
"Only installed applets will be found. <command>kbuildsycoca5</command> may "
"need to be run for newly-installed applets to be found."
msgstr ""
"केवल स्थापित एप्लेट ही मिलेंगे। नव-स्थापित एप्लेट ढूंढने के लिए <command>kbuildsycoca5</"
"command> चलाने की आवश्यकता हो सकती है।"

#. Tag: title
#: man-plasmoidviewer.1.docbook:54
#, no-c-format
msgid "Options"
msgstr "विकल्प"

#. Tag: option
#: man-plasmoidviewer.1.docbook:58
#, no-c-format
msgid "-v, --version"
msgstr "-v, --संस्करण"

#. Tag: para
#: man-plasmoidviewer.1.docbook:59
#, no-c-format
msgid "Displays version information."
msgstr "संस्करण जानकारी प्रदर्शित करता है."

#. Tag: option
#: man-plasmoidviewer.1.docbook:62
#, no-c-format
msgid "-c, --containment <replaceable>name</replaceable>"
msgstr "-c, --containment <प्रतिस्थापन योग्य>नाम</प्रतिस्थापन योग्य>"

#. Tag: para
#: man-plasmoidviewer.1.docbook:63
#, no-c-format
msgid "The name of the containment plugin."
msgstr "कंटेनमेंट प्लगइन का नाम."

#. Tag: option
#: man-plasmoidviewer.1.docbook:66
#, no-c-format
msgid "-a, --applet <replaceable>name</replaceable>"
msgstr "-a, --applet <प्रतिस्थापन योग्य>नाम</प्रतिस्थापन योग्य>"

#. Tag: para
#: man-plasmoidviewer.1.docbook:67
#, no-c-format
msgid "The name of the applet plugin."
msgstr "एप्लेट प्लगइन का नाम."

#. Tag: option
#: man-plasmoidviewer.1.docbook:70
#, no-c-format
msgid "-f, --formfactor <replaceable>name</replaceable>"
msgstr "-f, --formfactor <प्रतिस्थापन योग्य>नाम</प्रतिस्थापन योग्य>"

#. Tag: para
#: man-plasmoidviewer.1.docbook:71
#, no-c-format
msgid ""
"The formfactor to use (horizontal, vertical, mediacenter, planar or "
"application)."
msgstr "उपयोग करने हेतु फॉर्मफैक्टर (क्षैतिज, ऊर्ध्वाधर, मीडियासेंटर, प्लानर या अनुप्रयोग)।"

#. Tag: option
#: man-plasmoidviewer.1.docbook:74
#, no-c-format
msgid "-l, --location <replaceable>name</replaceable>"
msgstr "-l, --स्थान <प्रतिस्थापन योग्य>नाम</प्रतिस्थापन योग्य>"

#. Tag: para
#: man-plasmoidviewer.1.docbook:75
#, no-c-format
msgid ""
"The location constraint to start the Containment with (floating, desktop, "
"fullscreen, topedge, bottomedge, leftedge, rightedge)."
msgstr ""
"कंटेनमेंट को शुरू करने के लिए स्थान प्रतिबंध (फ्लोटिंग, डेस्कटॉप, फुलस्क्रीन, टॉपएज, बॉटमएज, "
"लेफ्टएज, राइटएज)।"

#. Tag: option
#: man-plasmoidviewer.1.docbook:79
#, no-c-format
msgid "-x, --xPosition <replaceable>xPosition</replaceable>"
msgstr "-x, --xPosition <प्रतिस्थापन योग्य>xPosition</प्रतिस्थापन योग्य>"

#. Tag: para
#: man-plasmoidviewer.1.docbook:80
#, no-c-format
msgid "Set the x position of the plasmoidviewer on the Plasma desktop."
msgstr "प्लाज़्मा डेस्कटॉप पर प्लाज़्मॉइडव्यूअर की x स्थिति सेट करें।"

#. Tag: option
#: man-plasmoidviewer.1.docbook:83
#, no-c-format
msgid "-y, --yPosition <replaceable>yPosition</replaceable>"
msgstr "-y, --yस्थिति <प्रतिस्थापनीय>yस्थिति</प्रतिस्थापनीय>"

#. Tag: para
#: man-plasmoidviewer.1.docbook:84
#, no-c-format
msgid "Set the y position of the plasmoidviewer on the Plasma desktop."
msgstr "प्लाज़्मा डेस्कटॉप पर प्लाज़्मॉइडव्यूअर की y स्थिति सेट करें।"

#. Tag: option
#: man-plasmoidviewer.1.docbook:87
#, no-c-format
msgid "-s, --size <replaceable>widthXheight</replaceable>"
msgstr "-s, --आकार <प्रतिस्थापन योग्य>चौड़ाईXऊंचाई</प्रतिस्थापन योग्य>"

#. Tag: para
#: man-plasmoidviewer.1.docbook:88
#, no-c-format
msgid "Set the window size of the plasmoidview."
msgstr "प्लास्मॉइडव्यू का विंडो आकार सेट करें."

#. Tag: option
#: man-plasmoidviewer.1.docbook:91
#, no-c-format
msgid "-p, --pixmapcache <replaceable>size</replaceable>"
msgstr "-p, --pixmapcache <प्रतिस्थापन योग्य>आकार</प्रतिस्थापन योग्य>"

#. Tag: para
#: man-plasmoidviewer.1.docbook:92
#, no-c-format
msgid "The size in KB to set the pixmap cache to."
msgstr "पिक्समैप कैश को सेट करने के लिए KB में आकार."

#. Tag: option
#: man-plasmoidviewer.1.docbook:95
#, no-c-format
msgid "-t, --theme <replaceable>name</replaceable>"
msgstr "-t, --theme <प्रतिस्थापन योग्य>नाम</प्रतिस्थापन योग्य>"

#. Tag: para
#: man-plasmoidviewer.1.docbook:96
#, no-c-format
msgid "The name of the theme which the shell will use."
msgstr "थीम का नाम जिसे शेल उपयोग करेगा."

#. Tag: option
#: man-plasmoidviewer.1.docbook:99
#, no-c-format
msgid "-h, --help"
msgstr "-एच, --सहायता"

#. Tag: para
#: man-plasmoidviewer.1.docbook:100
#, no-c-format
msgid "Displays this help."
msgstr "यह सहायता प्रदर्शित करता है."

#. Tag: replaceable
#: man-plasmoidviewer.1.docbook:103
#, no-c-format
msgid "args"
msgstr "आर्ग"

#. Tag: para
#: man-plasmoidviewer.1.docbook:104
#, no-c-format
msgid "Data that should be passed to the applet as 'externalData' event."
msgstr "डेटा जिसे 'externalData' इवेंट के रूप में एप्लेट को पास किया जाना चाहिए।"

#. Tag: title
#: man-plasmoidviewer.1.docbook:113
#, no-c-format
msgid "See Also"
msgstr "यह भी देखें"

#. Tag: para
#: man-plasmoidviewer.1.docbook:115
#, no-c-format
msgid ""
"More detailed user documentation is available from <ulink url=\"help:/plasma-"
"desktop\">help:/plasma-desktop</ulink> (either enter this <acronym>URL</"
"acronym> into &konqueror;, or run <userinput><command>khelpcenter</command> "
"<parameter>help:/plasma-desktop</parameter></userinput>)."
msgstr ""
"अधिक विस्तृत उपयोगकर्ता दस्तावेज़ <ulink url=\"help:/plasma-desktop\">help:/plasma-"
"desktop</ulink> से उपलब्ध है (या तो इस <acronym>URL</acronym> को &konqueror; में "
"दर्ज करें, या <userinput><command>khelpcenter</command> <parameter>help:/plasma-"
"desktop</parameter></userinput> चलाएँ)।"

#. Tag: title
