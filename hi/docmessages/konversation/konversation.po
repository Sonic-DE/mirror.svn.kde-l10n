msgstr ""
"नमूना आउटपुट: <replaceable>रैंडम फॉर्च्यून: कभी कोई गलती न करें। - अनाम, कर्नेल बग "
"रिपोर्ट के बारे में एक मेल चर्चा में</replaceable>"

#. Tag: userinput
#: index.docbook:2650
#, no-c-format
msgid ""
"<command>/exec </command> <replaceable>gauge</replaceable> "
"[<replaceable>percentage</replaceable>]"
msgstr ""
"<command>/exec </command> <replaceable>gauge</replaceable> "
"[<replaceable>percentage</replaceable>]"

#. Tag: para
#: index.docbook:2653
#, no-c-format
msgid ""
