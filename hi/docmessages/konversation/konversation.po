#. Tag: releaseinfo
#: index.docbook:79
#, no-c-format
msgid "&konversation; 1.6"
msgstr "&बातचीत; 1.6"

#. Tag: para
#: index.docbook:84
#, no-c-format
msgid ""
"&konversation; is a user-friendly &irc; client built on &Qt; and &kf5-full;."
msgstr ""
"&konversation; एक उपयोगकर्ता-अनुकूल &irc; क्लाइंट है जो &Qt; और &kf5-full; पर "
"निर्मित है।"

#. Tag: keyword
