msgstr "नमूना आउटपुट: <replaceable>https://tinyurl.com/y4rk8wa3</replaceable>"

#. Tag: userinput
#: index.docbook:2711 index.docbook:2716
#, no-c-format
msgid "<command>/exec </command> <replaceable>uptime</replaceable>"
msgstr "<command>/exec </command> <replaceable>अपटाइम</replaceable>"

#. Tag: para
#: index.docbook:2714
#, no-c-format
msgid ""
"This script outputs the result of the command \"uptime\" and formats it "
