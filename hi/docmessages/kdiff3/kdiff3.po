#. Tag: para
#: index.docbook:59
#, no-c-format
msgid "&kdiff3; is a file and folder diff and merge tool which"
msgstr "&kdiff3; एक फ़ाइल और फ़ोल्डर अंतर और मर्ज उपकरण है जो"

#. Tag: para
#: index.docbook:62
#, no-c-format
msgid "compares and merges two or three text input files or folders,"
msgstr "दो या तीन टेक्स्ट इनपुट फ़ाइलों या फ़ोल्डरों की तुलना और विलय करता है,"

#. Tag: para
#: index.docbook:63
#, no-c-format
msgid "shows the differences line by line and character by character(!),"
msgstr "पंक्ति दर पंक्ति और अक्षर दर अक्षर अंतर दिखाता है(!),"

#. Tag: para
#: index.docbook:64
#, no-c-format
msgid "provides an automatic merge-facility,"
msgstr "एक स्वचालित मर्ज-सुविधा प्रदान करता है,"

#. Tag: para
#: index.docbook:65
#, no-c-format
msgid "has an editor for comfortable solving of merge-conflicts,"
msgstr "मर्ज-संघर्षों के आरामदायक समाधान के लिए एक संपादक है,"

#. Tag: para
#: index.docbook:66
#, no-c-format
msgid "provides network transparency via KIO,"
msgstr "KIO के माध्यम से नेटवर्क पारदर्शिता प्रदान करता है,"

#. Tag: para
#: index.docbook:67
#, no-c-format
msgid "has options to highlight or hide changes in white-space or comments,"
msgstr ""
"इसमें रिक्त स्थान या टिप्पणियों में परिवर्तनों को हाइलाइट करने या छिपाने के विकल्प हैं,"

#. Tag: para
#: index.docbook:68
#, no-c-format
msgid "supports Unicode, UTF-8 and other file encodings,"
msgstr "यूनिकोड, UTF-8 और अन्य फ़ाइल एनकोडिंग का समर्थन करता है,"

#. Tag: para
#: index.docbook:69
#, no-c-format
msgid "prints differences,"
msgstr "प्रिंट मतभेद,"

#. Tag: para
#: index.docbook:70
#, no-c-format
msgid "supports version control keyword and history merging."
msgstr "संस्करण नियंत्रण कीवर्ड और इतिहास विलय का समर्थन करता है।"

