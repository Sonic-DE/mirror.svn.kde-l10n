#. Tag: title
#: man-kdiff3.1.docbook:8
#, no-c-format
msgid "KDiff3 User's Manual"
msgstr "KDiff3 उपयोगकर्ता मैनुअल"

#. Tag: author
#: man-kdiff3.1.docbook:9
#, no-c-format
msgid ""
"<firstname>Burkhard</firstname><surname>Lueck</surname> <contrib>KDiff3 man "
"page.</contrib> &Burkhard.Lueck.mail;"
msgstr ""
"<प्रथमनाम>बर्कहार्ड</प्रथमनाम><उपनाम>ल्यूक</उपनाम> <योगदान>KDiff3 मैन पेज।</contrib> "
"&Burkhard.Lueck.mail;"

#. Tag: date
#: man-kdiff3.1.docbook:13
#, no-c-format
msgid "2019-02-22"
msgstr "2019-02-22"

#. Tag: releaseinfo
#: man-kdiff3.1.docbook:14
#, no-c-format
msgid "kdiff3 1.8"
msgstr "kdiff3 1.8"

#. Tag: manvolnum
#: man-kdiff3.1.docbook:19
#, no-c-format
msgid "<manvolnum>1</manvolnum>"
msgstr "<मैनवोलन्यूम>1</मैनवोलन्यूम>"

#. Tag: refpurpose
#: man-kdiff3.1.docbook:24
#, no-c-format
msgid "Tool for Comparison and Merge of Files and Folders"
msgstr "फ़ाइलों और फ़ोल्डरों की तुलना और विलय के लिए उपकरण"

#. Tag: cmdsynopsis
#: man-kdiff3.1.docbook:28
#, no-c-format
msgid ""
"<command>kdiff3</command> <arg choice=\"opt\"><option>-u, --ignore</option></"
"arg> <arg choice=\"opt\"><option>--query</option></arg> <arg choice=\"opt"
"\"><option>--html</option></arg> <arg choice=\"opt\"><option>--abort</"
"option></arg> <arg choice=\"opt\"><option>-m, --merge</option></arg> <arg "
"choice=\"opt\"><option>-b, --base</option> <replaceable>file</replaceable></"
"arg> <arg choice=\"opt\"><option>-o, --output</option> <replaceable>file</"
"replaceable></arg> <arg choice=\"opt\"><option>--out</option> "
"<replaceable>file</replaceable></arg> <arg choice=\"opt\"><option>--noauto</"
"option></arg> <arg choice=\"opt\"><option>--auto</option></arg> <arg choice="
"\"opt\"><option>--L1</option> <replaceable>alias1</replaceable></arg> <arg "
"choice=\"opt\"><option>--L2</option> <replaceable>alias2</replaceable></arg> "
"<arg choice=\"opt\"><option>--L3</option> <replaceable>alias3</replaceable></"
"arg> <arg choice=\"opt\"><option>-L, --fname</option> <replaceable>alias</"
"replaceable></arg> <arg choice=\"opt\"><option>--cs</option> "
"<replaceable>string</replaceable></arg> <arg choice=\"opt\"><option>--"
"confighelp</option></arg> <arg choice=\"opt\"><option>--config</option> "
"<replaceable>file</replaceable></arg> <arg choice=\"opt"
"\"><option><replaceable>File1</replaceable></option></arg> <arg choice=\"opt"
"\"><option><replaceable>File2</replaceable></option></arg> <arg choice=\"opt"
"\"><option><replaceable>File3</replaceable></option></arg>"
msgstr ""
"<command>केडिफ3</command><arg choice=\"opt\"><option value=\"-u, --ignore\"> -"
"u, --अनदेखा करें</option></arg><arg choice=\"opt\"><option value=--query> --"
"सवाल</option></arg><arg choice=\"opt\"><option value=--html> --एचटीएमएल</"
"option></arg><arg choice=\"opt\"><option value=--abort> -- निरस्त करें</"
"option></arg><arg choice=\"opt\"><option value=\"-m, --merge\"> -एम, --मर्ज</"
"option></arg><arg choice=\"opt\"><option value=\"-b, --base\"> -बी, --बेस</"
"option><replaceable> फ़ाइल</replaceable></arg><arg choice=\"opt\"><option "
"value=\"-o, --output\"> -ओ, --आउटपुट</option><replaceable> फ़ाइल</"
"replaceable></arg><arg choice=\"opt\"><option value=--out> --बाहर</"
"option><replaceable> फ़ाइल</replaceable></arg><arg choice=\"opt\"><option "
"value=--noauto> --नोऑटो</option></arg><arg choice=\"opt\"><option value=--"
"auto> --ऑटो</option></arg><arg choice=\"opt\"><option value=--L1> --एल1</"
"option><replaceable> उपनाम1</replaceable></arg><arg choice=\"opt\"><option "
"value=--L2> --एल2</option><replaceable> उपनाम2</replaceable></arg><arg "
"choice=\"opt\"><option value=--L3> --एल3</option><replaceable> उपनाम3</"
"replaceable></arg><arg choice=\"opt\"><option value=\"-L, --fname\"> -एल, --"
"fname</option><replaceable> उपनाम</replaceable></arg><arg choice=\"opt"
"\"><option value=--cs> --सीएस</option><replaceable> डोरी</replaceable></"
"arg><arg choice=\"opt\"><option value=--confighelp> --कॉन्फ़िगरेशनसहायता</"
"option></arg><arg choice=\"opt\"><option value=--config> --कॉन्फ़िगरेशन</"
"option><replaceable> फ़ाइल</replaceable></arg><arg choice=\"opt"
"\"><option><replaceable> फ़ाइल1</replaceable></option></arg><arg choice=\"opt"
"\"><option><replaceable> करें 2</replaceable></option></arg><arg choice=\"opt"
"\"><option><replaceable> फ़ाइल3</replaceable></option></arg>"

#. Tag: title
#: man-kdiff3.1.docbook:54
#, no-c-format
msgid "Description"
msgstr "विवरण"

#. Tag: para
#: man-kdiff3.1.docbook:55
#, no-c-format
msgid "Compares two or three input files or folders."
msgstr "दो या तीन इनपुट फ़ाइलों या फ़ोल्डरों की तुलना करता है।"

#. Tag: title
#: man-kdiff3.1.docbook:60
#, no-c-format
msgid "Options"
msgstr "विकल्प"

#. Tag: option
#: man-kdiff3.1.docbook:63
#, no-c-format
msgid "-u, --ignore"
msgstr "-u, --अनदेखा करें"

#. Tag: para
#: man-kdiff3.1.docbook:64 man-kdiff3.1.docbook:70 man-kdiff3.1.docbook:76
#: man-kdiff3.1.docbook:82
#, no-c-format
msgid "Ignored. (User defined.)"
msgstr "अनदेखा किया गया. (उपयोगकर्ता परिभाषित.)"

#. Tag: option
#: man-kdiff3.1.docbook:69
#, no-c-format
msgid "--query"
msgstr "--सवाल"

#. Tag: option
#: man-kdiff3.1.docbook:75
#, no-c-format
msgid "--html"
msgstr "--एचटीएमएल"

#. Tag: option
#: man-kdiff3.1.docbook:81
#, no-c-format
msgid "--abort"
msgstr "-- निरस्त करें"

#. Tag: option
#: man-kdiff3.1.docbook:87
#, no-c-format
msgid "-m, --merge"
msgstr "-एम, --मर्ज"

#. Tag: para
#: man-kdiff3.1.docbook:88
#, no-c-format
msgid "Merge the input."
msgstr "इनपुट मर्ज करें."

#. Tag: term
#: man-kdiff3.1.docbook:93
#, no-c-format
msgid "<option>-b, --base</option> <replaceable>file</replaceable>"
msgstr ""
"<option value=\"-b, --base\">-बी, --बेस</option><replaceable> फ़ाइल</"
"replaceable>"

#. Tag: para
#: man-kdiff3.1.docbook:94
#, no-c-format
msgid "Explicit base file. For compatibility with certain tools."
msgstr "स्पष्ट आधार फ़ाइल। कुछ उपकरणों के साथ संगतता के लिए।"

#. Tag: term
#: man-kdiff3.1.docbook:99
#, no-c-format
msgid "<option>-o, --output</option> <replaceable>file</replaceable>"
msgstr ""
"<option value=\"-o, --output\">-ओ, --आउटपुट</option><replaceable> फ़ाइल</"
"replaceable>"

#. Tag: para
#: man-kdiff3.1.docbook:100
#, no-c-format
msgid "Output file. Implies -m. &eg;: -o newfile.txt"
msgstr "आउटपुट फ़ाइल. इसका तात्पर्य है -m. &eg;: -o newfile.txt"

#. Tag: term
#: man-kdiff3.1.docbook:105
#, no-c-format
msgid "<option>--out</option> <replaceable>file</replaceable>"
msgstr "<option value=--out>--बाहर</option><replaceable> फ़ाइल</replaceable>"

#. Tag: para
#: man-kdiff3.1.docbook:106
#, no-c-format
msgid "Output file, again. (For compatibility with certain tools.)"
msgstr "आउटपुट फ़ाइल, पुनः। (कुछ उपकरणों के साथ संगतता के लिए।)"

#. Tag: option
#: man-kdiff3.1.docbook:111
#, no-c-format
msgid "--auto"
msgstr "--ऑटो"

#. Tag: para
#: man-kdiff3.1.docbook:112
#, no-c-format
msgid ""
"No GUI if all conflicts are auto-solvable. (Needs <option>-o</option> "
"<replaceable>file</replaceable>)"
msgstr ""
"यदि सभी विवाद स्वतः समाधान योग्य हैं तो कोई GUI नहीं। (आवश्यकताएँ)<option value=-o> "
"-ओ</option><replaceable> फ़ाइल</replaceable> )"

#. Tag: option
#: man-kdiff3.1.docbook:118
#, no-c-format
msgid "--noauto"
msgstr "--नोऑटो"

#. Tag: para
#: man-kdiff3.1.docbook:119
#, no-c-format
msgid "Ignore --auto and always show GUI."
msgstr "--auto को अनदेखा करें और हमेशा GUI दिखाएं."

#. Tag: term
#: man-kdiff3.1.docbook:124
#, no-c-format
msgid "<option>--L1</option> <replaceable>alias1</replaceable>"
msgstr "<option value=--L1>--एल1</option><replaceable> उपनाम1</replaceable>"

#. Tag: para
#: man-kdiff3.1.docbook:125
#, no-c-format
msgid "Visible name replacement for input file 1 (base)."
msgstr "इनपुट फ़ाइल 1 (बेस) के लिए दृश्यमान नाम प्रतिस्थापन."

#. Tag: term
#: man-kdiff3.1.docbook:130
#, no-c-format
msgid "<option>--L2</option> <replaceable>alias2</replaceable>"
msgstr "<option value=--L2>--L2</option><replaceable> उपनाम2</replaceable>"

#. Tag: para
#: man-kdiff3.1.docbook:131
#, no-c-format
msgid "Visible name replacement for input file 2."
msgstr "इनपुट फ़ाइल के लिए दृश्य नाम प्रतिस्थापन 2."

#. Tag: term
#: man-kdiff3.1.docbook:136
#, no-c-format
msgid "<option>--L3</option> <replaceable>alias3</replaceable>"
msgstr "<option value=--L3>--L3</option><replaceable> उपनाम3</replaceable>"

#. Tag: para
#: man-kdiff3.1.docbook:137
#, no-c-format
msgid "Visible name replacement for input file 3."
msgstr "इनपुट फ़ाइल के लिए दृश्य नाम प्रतिस्थापन 3."

#. Tag: term
#: man-kdiff3.1.docbook:142
#, no-c-format
msgid "<option>-L, --fname</option> <replaceable>alias</replaceable>"
msgstr ""
"<option value=\"-L, --fname\">-एल, --fname</option><replaceable> उपनाम</"
"replaceable>"

#. Tag: para
#: man-kdiff3.1.docbook:143
#, no-c-format
msgid "Alternative visible name replacement. Supply this once for every input."
msgstr "वैकल्पिक दृश्यमान नाम प्रतिस्थापन। प्रत्येक इनपुट के लिए इसे एक बार प्रदान करें।"

#. Tag: term
#: man-kdiff3.1.docbook:148
#, no-c-format
msgid "<option>--cs</option> <replaceable>string</replaceable>"
msgstr "<option value=--cs>--सीएस</option><replaceable> डोरी</replaceable>"

#. Tag: para
#: man-kdiff3.1.docbook:149
#, no-c-format
msgid ""
"Override a config setting. Use once for every setting. &eg;: <option>--cs</"
"option> <replaceable>AutoAdvance=1</replaceable>."
msgstr ""
"कॉन्फ़िगरेशन सेटिंग को ओवरराइड करें। हर सेटिंग के लिए एक बार उपयोग करें। ⪚:<option "
"value=--cs> --सीएस</option><replaceable> ऑटोएडवांस=1</replaceable> ."

#. Tag: option
#: man-kdiff3.1.docbook:155
#, no-c-format
msgid "--confighelp"
msgstr "--कॉन्फ़िगरेशनसहायता"

#. Tag: para
#: man-kdiff3.1.docbook:156
#, no-c-format
msgid "Show list of config settings and current values."
msgstr "कॉन्फ़िगरेशन सेटिंग्स और वर्तमान मानों की सूची दिखाएँ."

#. Tag: term
#: man-kdiff3.1.docbook:161
#, no-c-format
msgid "<option>--config</option> <replaceable>file</replaceable>"
msgstr ""
"<option value=--config>--कॉन्फ़िगरेशन</option><replaceable> फ़ाइल</replaceable>"

#. Tag: para
#: man-kdiff3.1.docbook:162
#, no-c-format
msgid "Use a different config file."
msgstr "एक अलग कॉन्फ़िगरेशन फ़ाइल का उपयोग करें."

#. Tag: replaceable
#: man-kdiff3.1.docbook:167
#, no-c-format
msgid "File1"
msgstr "फ़ाइल1"

#. Tag: para
#: man-kdiff3.1.docbook:168
#, no-c-format
msgid "file1 to open (base, if not specified via --<option>base</option>)"
msgstr ""
"फ़ाइल1 खोलने के लिए (आधार, यदि -- के माध्यम से निर्दिष्ट नहीं है)<option value=base> "
"आधार</option> )"

#. Tag: replaceable
#: man-kdiff3.1.docbook:173
#, no-c-format
msgid "File2"
msgstr "करें 2"

#. Tag: para
#: man-kdiff3.1.docbook:174
#, no-c-format
msgid "file2 to open"
msgstr "फ़ाइल2 खोलने के लिए"

#. Tag: replaceable
#: man-kdiff3.1.docbook:179
#, no-c-format
msgid "File3"
msgstr "फ़ाइल3"

#. Tag: para
#: man-kdiff3.1.docbook:180
#, no-c-format
msgid "file3 to open"
msgstr "फ़ाइल3 खोलने के लिए"

#. Tag: title
#: man-kdiff3.1.docbook:189
#, no-c-format
msgid "See Also"
msgstr "यह भी देखें"

#. Tag: member
#: man-kdiff3.1.docbook:191
#, no-c-format
msgid ""
"More detailed user documentation is available from <ulink url=\"help:/"
"kdiff3\">help:/kdiff3</ulink> (either enter this &URL; into &konqueror;, or "
"run <userinput><command>khelpcenter</command> <parameter>help:/kdiff3</"
"parameter></userinput>)."
msgstr ""
"अधिक विस्तृत उपयोगकर्ता दस्तावेज़ <ulink url=\"help:/kdiff3\">help:/kdiff3</ulink> "
"से उपलब्ध है (या तो इस &URL; को &konqueror; में दर्ज करें, या "
"<userinput><command>khelpcenter</command> <parameter>help:/kdiff3</"
"parameter></userinput> चलाएँ)।"

#. Tag: member
#: man-kdiff3.1.docbook:196
#, no-c-format
msgid "kf6options(7)"
msgstr "kf6विकल्प(7)"

#. Tag: member
