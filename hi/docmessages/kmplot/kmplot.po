msgid "arccoth(x)"
msgstr "आर्ककोथ(x)"

#. Tag: para
#: index.docbook:791
#, no-c-format
msgid ""
"The hyperbolic tangent, inverse tangent, cotangent and inverse cotangent "
"respectively."
msgstr "क्रमशः हाइपरबोलिक स्पर्शज्या, व्युत्क्रम स्पर्शज्या, कोटेंजेंट और व्युत्क्रम कोटेंजेंट।"

#. Tag: title
