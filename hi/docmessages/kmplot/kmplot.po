#, no-c-format
msgid "Other Functions"
msgstr "अन्य कार्य"

#. Tag: term
#: index.docbook:802
#, no-c-format
msgid "sqr(x)"
msgstr "वर्ग(x)"

#. Tag: para
#: index.docbook:803
#, no-c-format
msgid "The square x^2 of x."
msgstr "x का वर्ग x^2."

#. Tag: term
#: index.docbook:807
#, no-c-format
msgid "sqrt(x)"
msgstr "वर्ग(x)"

#. Tag: para
#: index.docbook:808
#, no-c-format
msgid "The square root of x."
msgstr "X का वर्गमूल."

#. Tag: term
#: index.docbook:812
#, no-c-format
msgid "sign(x)"
msgstr "चिह्न(x)"

#. Tag: para
#: index.docbook:813
#, no-c-format
msgid ""
"The sign of x. Returns 1 if x is positive, 0 if x is zero, or &minus;1 if x "
"is negative."
msgstr ""
"x का चिह्न। यदि x धनात्मक है तो 1 लौटाता है, यदि x शून्य है तो 0 लौटाता है, या यदि x "
"ऋणात्मक है तो &minus;1 लौटाता है।"

#. Tag: term
#: index.docbook:817
#, no-c-format
msgid "H(x)"
msgstr "एच(एक्स)"

#. Tag: para
#: index.docbook:818
#, no-c-format
msgid ""
"The Heaviside Step Function. Returns 1 if x is positive, 0.5 if x is zero, "
"or 0 if x is negative."
msgstr ""
"हेवीसाइड स्टेप फ़ंक्शन। यदि x धनात्मक है तो 1 लौटाता है, यदि x शून्य है तो 0.5 लौटाता है, "
"या यदि x ऋणात्मक है तो 0 लौटाता है।"

#. Tag: term
#: index.docbook:822
#, no-c-format
msgid "exp(x)"
msgstr "एक्सप(x)"

#. Tag: para
#: index.docbook:823
#, no-c-format
msgid "The exponent e^x of x."
msgstr "x का घातांक e^x."

#. Tag: term
#: index.docbook:827
#, no-c-format
msgid "ln(x)"
msgstr "एलएन(एक्स)"

#. Tag: para
#: index.docbook:828
#, no-c-format
msgid "The natural logarithm (inverse exponent) of x."
msgstr "x का प्राकृतिक लघुगणक (प्रतिलोम घातांक)."

#. Tag: term
#: index.docbook:832
#, no-c-format
msgid "log(x)"
msgstr "लॉग(x)"

#. Tag: para
#: index.docbook:833
#, no-c-format
msgid "The logarithm of x to base 10."
msgstr "आधार 10 पर x का लघुगणक."

#. Tag: term
#: index.docbook:837
#, no-c-format
msgid "abs(x)"
msgstr "एब्स(x)"

#. Tag: para
#: index.docbook:838
#, no-c-format
msgid "The absolute value of x."
msgstr "x का निरपेक्ष मान."

#. Tag: term
#: index.docbook:842
#, no-c-format
msgid "floor(x)"
msgstr "मंजिल(x)"

#. Tag: para
#: index.docbook:843
#, no-c-format
msgid "Rounds x to closest integer less than or equal to x."
msgstr "x को x से कम या उसके बराबर निकटतम पूर्णांक तक पूर्णांकित करता है।"

#. Tag: term
#: index.docbook:847
#, no-c-format
msgid "ceil(x)"
msgstr "छत(x)"

#. Tag: para
#: index.docbook:848
#, no-c-format
msgid "Rounds x to the closest integer greater than or equal to x."
msgstr "x को x से बड़े या उसके बराबर निकटतम पूर्णांक तक पूर्णांकित करता है।"

#. Tag: term
#: index.docbook:852
#, no-c-format
msgid "round(x)"
msgstr "गोल(x)"

#. Tag: para
#: index.docbook:853
#, no-c-format
msgid "Rounds x to the closest integer."
msgstr "x को निकटतम पूर्णांक तक पूर्णांकित करता है।"

#. Tag: term
#: index.docbook:857
#, no-c-format
msgid "gamma(x)"
msgstr "गामा(x)"

#. Tag: para
#: index.docbook:858
#, no-c-format
msgid "The gamma function."
msgstr "गामा फ़ंक्शन."

#. Tag: term
#: index.docbook:862
#, no-c-format
msgid "factorial(x)"
msgstr "फैक्टोरियल(x)"

#. Tag: para
#: index.docbook:863
#, no-c-format
msgid "The factorial of x."
msgstr "x का फैक्टोरियल."

#. Tag: term
#: index.docbook:867
#, no-c-format
msgid ""
"min(x<subscript>1</subscript>,x<subscript>2</subscript>,...,x<subscript>n</"
"subscript>)"
msgstr ""
"न्यूनतम(x<subscript>1</subscript>,x<subscript>2</subscript>,...,x<subscript>n</"
"subscript>)"

#. Tag: para
#: index.docbook:868
#, no-c-format
msgid ""
"Returns the minimum of the set of numbers {x<subscript>1</subscript>,"
"x<subscript>2</subscript>,...,x<subscript>n</subscript>}."
msgstr ""
"संख्याओं के समूह {x<subscript>1</subscript>,x<subscript>2</subscript>,...,"
"x<subscript>n</subscript>} का न्यूनतम मान लौटाता है."

#. Tag: term
#: index.docbook:872
#, no-c-format
msgid ""
"max(x<subscript>1</subscript>,x<subscript>2</subscript>,...,x<subscript>n</"
"subscript>)"
msgstr ""
"अधिकतम(x<subscript>1</subscript>,x<subscript>2</subscript>,...,"
"x<subscript>n</subscript>)"

#. Tag: para
#: index.docbook:873
#, no-c-format
msgid ""
"Returns the maximum of the set of numbers {x<subscript>1</subscript>,"
"x<subscript>2</subscript>,...,x<subscript>n</subscript>}."
msgstr ""
"संख्याओं के समूह {x<subscript>1</subscript>,x<subscript>2</subscript>,...,"
"x<subscript>n</subscript>} का अधिकतम मान लौटाता है."

#. Tag: term
#: index.docbook:877
#, no-c-format
msgid ""
"mod(x<subscript>1</subscript>,x<subscript>2</subscript>,...,x<subscript>n</"
"subscript>)"
msgstr ""
"मॉड(x<subscript>1</subscript>,x<subscript>2</subscript>,...,x<subscript>n</"
"subscript>)"

#. Tag: para
#: index.docbook:878
#, no-c-format
msgid ""
"Returns the modulus (Euclidean length) of the set of numbers {x<subscript>1</"
"subscript>,x<subscript>2</subscript>,...,x<subscript>n</subscript>}."
msgstr ""
"संख्याओं के समूह {x<subscript>1</subscript>,x<subscript>2</subscript>,...,"
"x<subscript>n</subscript>} का मापांक (यूक्लिडियन लंबाई) लौटाता है।"

#. Tag: title
#: index.docbook:887
#, no-c-format
msgid "Predefined Constants"
msgstr "पूर्वनिर्धारित स्थिरांक"

