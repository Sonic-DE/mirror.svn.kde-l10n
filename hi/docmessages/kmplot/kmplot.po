msgstr ""
"ID <पैरामीटर>id</पैरामीटर> वाले फ़ंक्शन के पहले व्युत्पन्न की लाइन चौड़ाई लौटाता है। यदि "
"फ़ंक्शन मौजूद नहीं है, तो 0 लौटाया जाता है।"

#. Tag: term
#: index.docbook:1679
#, no-c-format
msgid "/parser org.kde.kmplot.Parser.functionF2LineWidth id"
msgstr "/पार्सर org.kde.kmplot.Parser.functionF2LineWidth आईडी"

#. Tag: para
#: index.docbook:1683
#, no-c-format
msgid ""
"Returns the line width of the second derivative of the function with the ID "
"<parameter>id</parameter>. If the function not exists, 0 is returned."
msgstr ""
"ID <पैरामीटर>id</पैरामीटर> वाले फ़ंक्शन के दूसरे व्युत्पन्न की लाइन चौड़ाई लौटाता है। यदि "
"फ़ंक्शन मौजूद नहीं है, तो 0 लौटाया जाता है।"

#. Tag: term
#: index.docbook:1687
#, no-c-format
msgid "/parser org.kde.kmplot.Parser.functionIntLineWidth id"
msgstr "/पार्सर org.kde.kmplot.Parser.functionIntLineWidth आईडी"

#. Tag: para
#: index.docbook:1691
#, no-c-format
msgid ""
"Returns the line width of the integral of the function with the ID "
"<parameter>id</parameter>. If the function not exists, 0 is returned."
msgstr ""
"ID <पैरामीटर>id</पैरामीटर> वाले फ़ंक्शन के इंटीग्रल की लाइन चौड़ाई लौटाता है। यदि फ़ंक्शन "
"मौजूद नहीं है, तो 0 लौटाया जाता है।"

#. Tag: term
#: index.docbook:1695
#, no-c-format
msgid "/parser org.kde.kmplot.Parser.setFunctionFLineWidth id linewidth"
msgstr "/parser org.kde.kmplot.Parser.setFunctionFLineWidth आईडी लाइनविड्थ"

#. Tag: para
#: index.docbook:1699
#, no-c-format
msgid ""
"Sets the line width of the function with the ID <parameter>id</parameter> to "
"<parameter>linewidth</parameter>. True is returned if the function exists, "
"otherwise false."
msgstr ""
"<पैरामीटर>id</पैरामीटर> आईडी वाले फ़ंक्शन की लाइन चौड़ाई को <पैरामीटर>लाइनविड्थ</"
"पैरामीटर> पर सेट करता है। यदि फ़ंक्शन मौजूद है, तो True लौटाया जाता है, अन्यथा false।"

#. Tag: term
#: index.docbook:1703
#, no-c-format
msgid "/parser org.kde.kmplot.Parser.setFunctionF1LineWidth id linewidth"
msgstr "/parser org.kde.kmplot.Parser.setFunctionF1LineWidth आईडी लाइनविड्थ"

#. Tag: para
#: index.docbook:1707
#, no-c-format
msgid ""
"Sets the line width of the first derivative of the function with the ID "
"<parameter>id</parameter> to <parameter>linewidth</parameter>. True is "
"returned if the function exists, otherwise false."
msgstr ""
"<पैरामीटर>id</पैरामीटर> आईडी वाले फ़ंक्शन के पहले व्युत्पन्न की लाइन चौड़ाई को "
"<पैरामीटर>लाइनविड्थ</पैरामीटर> पर सेट करता है। यदि फ़ंक्शन मौजूद है, तो True लौटाया "
"जाता है, अन्यथा false।"

#. Tag: term
#: index.docbook:1711
#, no-c-format
msgid "/parser org.kde.kmplot.Parser.setFunctionF2LineWidth id linewidth"
msgstr "/parser org.kde.kmplot.Parser.setFunctionF2LineWidth आईडी लाइनविड्थ"

#. Tag: para
#: index.docbook:1715
#, no-c-format
msgid ""
"Sets the line width of the second derivative of the function with the ID "
"<parameter>id</parameter> to <parameter>linewidth</parameter>. True is "
"returned if the function exists, otherwise false."
msgstr ""
"<पैरामीटर>id</पैरामीटर> ID वाले फ़ंक्शन के दूसरे व्युत्पन्न की लाइन चौड़ाई को "
"<पैरामीटर>linewidth</पैरामीटर> पर सेट करता है। यदि फ़ंक्शन मौजूद है, तो True लौटाया "
"जाता है, अन्यथा false।"

#. Tag: term
#: index.docbook:1719
#, no-c-format
msgid "/parser org.kde.kmplot.Parser.setFunctionIntLineWidth id linewidth"
msgstr "/parser org.kde.kmplot.Parser.setFunctionIntLineWidth आईडी लाइनविड्थ"

#. Tag: para
#: index.docbook:1723
#, no-c-format
msgid ""
"Sets the line width of the integral of the function with the ID "
"<parameter>id</parameter> to <parameter>linewidth</parameter>. True is "
"returned if the function exists, otherwise false."
msgstr ""
"<पैरामीटर>id</पैरामीटर> आईडी वाले फ़ंक्शन के इंटीग्रल की लाइन चौड़ाई को "
"<पैरामीटर>लाइनविड्थ</पैरामीटर> पर सेट करता है। यदि फ़ंक्शन मौजूद है, तो True लौटाया "
"जाता है, अन्यथा false।"

#. Tag: term
#: index.docbook:1727
#, no-c-format
msgid "/parser org.kde.kmplot.Parser.functionParameterList id"
msgstr "/पार्सर org.kde.kmplot.Parser.functionParameterList आईडी"

#. Tag: para
#: index.docbook:1731
#, no-c-format
msgid ""
"Returns a list with all the parameter values for the function with the ID "
"<parameter>id</parameter>."
msgstr ""
"<parameter>id</parameter> ID वाले फ़ंक्शन के लिए सभी पैरामीटर मानों वाली सूची लौटाता "
"है."

#. Tag: term
#: index.docbook:1735
#, no-c-format
msgid "/parser org.kde.kmplot.Parser.functionAddParameter id new_parameter"
msgstr "/parser org.kde.kmplot.Parser.functionAddParameter आईडी new_parameter"

#. Tag: para
#: index.docbook:1739
#, no-c-format
msgid ""
"Adds the parameter value <parameter>new_parameter</parameter> to the "
"function with the ID <parameter>id</parameter>. True is returned if the "
"operation succeed, otherwise false."
msgstr ""
"<parameter>new_parameter</parameter> को ID <parameter>id</parameter> वाले "
"फ़ंक्शन में पैरामीटर मान जोड़ता है। यदि ऑपरेशन सफल होता है तो True लौटाया जाता है, "
"अन्यथा false."

#. Tag: term
#: index.docbook:1743
#, no-c-format
msgid ""
"/parser org.kde.kmplot.Parser.functionRemoveParameter id remove_parameter"
msgstr ""
"/parser org.kde.kmplot.Parser.functionRemoveParameter आईडी remove_parameter"

#. Tag: para
#: index.docbook:1747
#, no-c-format
msgid ""
"Removes the parameter value <parameter>remove_parameter</parameter> from the "
"function with the ID <parameter>id</parameter>. True is returned if the "
"operation succeed, otherwise false."
msgstr ""
"<parameter>id</parameter> ID वाले फ़ंक्शन से पैरामीटर मान "
"<parameter>remove_parameter</parameter> को निकालता है। यदि ऑपरेशन सफल होता है "
"तो True लौटाया जाता है, अन्यथा false."

#. Tag: term
#: index.docbook:1751
#, no-c-format
msgid "/parser org.kde.kmplot.Parser.functionMinValue id"
msgstr "/पार्सर org.kde.kmplot.Parser.functionMinValue आईडी"

#. Tag: para
#: index.docbook:1755
#, no-c-format
msgid ""
"Returns the minimum plot range value of the function with the ID "
"<parameter>id</parameter>. If the function not exists or if the minimum "
"value is not defined, an empty string is returned."
msgstr ""
"<पैरामीटर>id</पैरामीटर> आईडी वाले फ़ंक्शन का न्यूनतम प्लॉट रेंज मान लौटाता है। यदि फ़ंक्शन "
"मौजूद नहीं है या न्यूनतम मान परिभाषित नहीं है, तो एक खाली स्ट्रिंग लौटाई जाती है।"

#. Tag: term
#: index.docbook:1759
#, no-c-format
msgid "/parser org.kde.kmplot.Parser.functionMaxValue id"
msgstr "/पार्सर org.kde.kmplot.Parser.functionMaxValue आईडी"

#. Tag: para
#: index.docbook:1763
#, no-c-format
msgid ""
"Returns the maximum plot range value of the function with the ID "
"<parameter>id</parameter>. If the function not exists or if the maximum "
"value is not defined, an empty string is returned."
msgstr ""
"ID <पैरामीटर>id</पैरामीटर> वाले फ़ंक्शन का अधिकतम प्लॉट रेंज मान लौटाता है। यदि फ़ंक्शन "
"मौजूद नहीं है या अधिकतम मान परिभाषित नहीं है, तो एक खाली स्ट्रिंग लौटाई जाती है।"

#. Tag: term
#: index.docbook:1767
#, no-c-format
msgid "/parser org.kde.kmplot.Parser.setFunctionMinValue id min"
msgstr "/parser org.kde.kmplot.Parser.setFunctionMinValue आईडी न्यूनतम"

#. Tag: para
#: index.docbook:1771
#, no-c-format
msgid ""
"Sets the minimum plot range value of the function with the ID <parameter>id</"
"parameter> to <parameter>min</parameter>. True is returned if the function "
"exists and the expression is valid, otherwise false."
msgstr ""
"<पैरामीटर>id</पैरामीटर> से <पैरामीटर>min</पैरामीटर> तक ID वाले फ़ंक्शन का न्यूनतम प्लॉट "
"रेंज मान सेट करता है। यदि फ़ंक्शन मौजूद है और अभिव्यक्ति मान्य है, तो True लौटाया जाता है, "
"अन्यथा false."

#. Tag: term
#: index.docbook:1775
#, no-c-format
msgid "/parser org.kde.kmplot.Parser.setFunctionMaxValue id max"
msgstr "/parser org.kde.kmplot.Parser.setFunctionMaxValue आईडी अधिकतम"

#. Tag: para
#: index.docbook:1779
#, no-c-format
msgid ""
"Sets the maximum plot range value of the function with the ID <parameter>id</"
"parameter> to <parameter>max</parameter>. True is returned if the function "
"exists and the expression is valid, otherwise false."
msgstr ""
"<पैरामीटर>id</पैरामीटर> आईडी वाले फ़ंक्शन के अधिकतम प्लॉट रेंज मान को <पैरामीटर>max</"
"पैरामीटर> पर सेट करता है। यदि फ़ंक्शन मौजूद है और अभिव्यक्ति मान्य है, तो True लौटाया "
"जाता है, अन्यथा false."

#. Tag: term
#: index.docbook:1784
#, no-c-format
msgid "/parser org.kde.kmplot.Parser.functionStartXValue id"
msgstr "/पार्सर org.kde.kmplot.Parser.functionStartXValue आईडी"

#. Tag: para
#: index.docbook:1788
#, no-c-format
msgid ""
"Returns the initial x point for the integral of the function with the ID "
"<parameter>id</parameter>. If the function not exists or if the x-point-"
"expression is not defined, an empty string is returned."
msgstr ""
"ID <पैरामीटर>id</पैरामीटर> वाले फ़ंक्शन के इंटीग्रल के लिए प्रारंभिक x बिंदु लौटाता है। यदि "
"फ़ंक्शन मौजूद नहीं है या x-बिंदु-अभिव्यक्ति परिभाषित नहीं है, तो एक खाली स्ट्रिंग लौटाई "
"जाती है।"

#. Tag: term
#: index.docbook:1792
#, no-c-format
msgid "/parser org.kde.kmplot.Parser.functionStartYValue id"
msgstr "/पार्सर org.kde.kmplot.Parser.functionStartYValue आईडी"

#. Tag: para
#: index.docbook:1796
#, no-c-format
msgid ""
"Returns the initial y point for the integral of the function with the ID "
"<parameter>id</parameter>. If the function not exists or if the y-point-"
"expression is not defined, an empty string is returned."
msgstr ""
"<पैरामीटर>id</पैरामीटर> आईडी वाले फ़ंक्शन के इंटीग्रल के लिए प्रारंभिक y बिंदु लौटाता है। "
"यदि फ़ंक्शन मौजूद नहीं है या यदि y-बिंदु-अभिव्यक्ति परिभाषित नहीं है, तो एक खाली स्ट्रिंग "
"लौटाई जाती है।"

#. Tag: term
#: index.docbook:1800
#, no-c-format
msgid "/parser org.kde.kmplot.Parser.setFunctionStartValue id x y"
msgstr "/पार्सर org.kde.kmplot.Parser.setFunctionStartValue आईडी x y"

#. Tag: para
#: index.docbook:1804
#, no-c-format
msgid ""
"Sets the initial x and y point for the integral of the function with the ID "
"<parameter>id</parameter> to <parameter>x</parameter> and <parameter>y</"
"parameter>. True is returned if the function exists and the expression is "
"valid, otherwise false."
msgstr ""
"<पैरामीटर>id</पैरामीटर> से <पैरामीटर>x</पैरामीटर> और <पैरामीटर>y</पैरामीटर> तक के "
"फ़ंक्शन के इंटीग्रल के लिए प्रारंभिक x और y बिंदु सेट करता है। यदि फ़ंक्शन मौजूद है और "
