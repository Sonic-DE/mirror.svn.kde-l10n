#. Tag: para
#: index.docbook:31
#, no-c-format
msgid ""
"&kdesu; is a graphical front end for the &UNIX; <command>su</command> "
"command."
msgstr "&kdesu; &UNIX; <command>su</command> कमांड के लिए एक ग्राफिकल फ्रंट एंड है।"

#. Tag: keyword
#: index.docbook:35
#, no-c-format
msgid "<keyword>KDE</keyword>"
msgstr "<कीवर्ड>कहां</कीवर्ड>"

#. Tag: keyword
#: index.docbook:36
#, no-c-format
msgid "<keyword>su</keyword>"
msgstr "<कीवर्ड>su</कीवर्ड>"

#. Tag: keyword
#: index.docbook:37
#, no-c-format
msgid "password"
msgstr "पासवर्ड"

#. Tag: keyword
#: index.docbook:38
#, no-c-format
