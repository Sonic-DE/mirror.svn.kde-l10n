#. Tag: para
#: index.docbook:32
#, no-c-format
msgid ""
"The wallet subsystem provides a convenient and secure way to manage all your "
"passwords."
msgstr ""
"वॉलेट सबसिस्टम आपके सभी पासवर्ड प्रबंधित करने का एक सुविधाजनक और सुरक्षित तरीका प्रदान "
"करता है।"

#. Tag: keyword
#: index.docbook:39
#, no-c-format
msgid "<keyword>KDE</keyword>"
msgstr "<कीवर्ड>कहां</कीवर्ड>"

#. Tag: keyword
