#. Tag: title
#: index.docbook:2589
#, no-c-format
msgid "&no-i18n-cmd_delete;"
msgstr "&no-i18n-cmd_delete;"

#. Tag: title
#: index.docbook:2591
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_delete;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_delete;</command>()"

#. Tag: para
#: index.docbook:2592
#, no-c-format
msgid ""
"Deletes the currently selected range of samples. If the selection is empty, "
"this command does nothing. Affects all tracks."
msgstr ""
"वर्तमान में चयनित नमूनों की श्रेणी को हटाता है। यदि चयन रिक्त है, तो यह आदेश कुछ नहीं "
"करता। सभी ट्रैक को प्रभावित करता है।"

#. Tag: title
#: index.docbook:2601
#, no-c-format
msgid "&no-i18n-cmd_delete_track;"
msgstr "&no-i18n-cmd_delete_track;"

#. Tag: title
#: index.docbook:2603
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_delete_track;</"
"command>(<replaceable>index</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_delete_track;</"
"command>(<replaceable>index</replaceable>)"

#. Tag: para
#: index.docbook:2604
#, no-c-format
msgid ""
"Deletes a track, identified by its index (starting from zero). If no track "
"with the given index exists, this command exits with an error."
msgstr ""
"किसी ट्रैक को हटाता है, जिसे उसके इंडेक्स (शून्य से शुरू) द्वारा पहचाना जाता है। यदि दिए गए "
"इंडेक्स वाला कोई ट्रैक मौजूद नहीं है, तो यह कमांड एक त्रुटि के साथ बाहर निकल जाता है।"

#. Tag: entry
#: index.docbook:2610 index.docbook:2733 index.docbook:2772 index.docbook:2800
#: index.docbook:3563 index.docbook:3577 index.docbook:3592
#, no-c-format
msgid "<parameter>index</parameter>:"
msgstr "<पैरामीटर>सूचकांक</पैरामीटर>:"

#. Tag: entry
#: index.docbook:2610
#, no-c-format
msgid "index of the track to delete, starting with 0"
msgstr "हटाए जाने वाले ट्रैक का सूचकांक, 0 से शुरू होता है"

#. Tag: title
#: index.docbook:2615
#, no-c-format
msgid "&no-i18n-cmd_dump_metadata;"
msgstr "&no-i18n-cmd_dump_metadata;"

#. Tag: title
#: index.docbook:2617
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_dump_metadata;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_dump_metadata;</"
"command>()"

#. Tag: para
#: index.docbook:2618
#, no-c-format
msgid ""
"Prints a list of all meta data entries to the console, for diagnostic "
"purposes. (Only available when &kwave; has been compiled with the option "
"<literal>WITH_DEBUG</literal> switched on)."
msgstr ""
"निदान प्रयोजनों के लिए, कंसोल पर सभी मेटा डेटा प्रविष्टियों की सूची प्रिंट करता है। (केवल "
"तब उपलब्ध होता है जब &kwave; को <literal>WITH_DEBUG</literal> विकल्प चालू करके "
"संकलित किया गया हो)।"

#. Tag: title
#: index.docbook:2627
#, no-c-format
msgid "&no-i18n-tag;e"
msgstr "&no-i18n-tag;ई"

#. Tag: title
#: index.docbook:2630
#, no-c-format
msgid "&no-i18n-cmd_expandtolabel;"
msgstr "&no-i18n-cmd_expandtolabel;"

#. Tag: title
#: index.docbook:2632
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_expandtolabel;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_expandtolabel;</"
"command>()"

#. Tag: para
#: index.docbook:2633
#, no-c-format
msgid ""
"Expands the current selection to the labels left and right from the current "
"selection borders. If the border of selection already is on a label, it "
"stays unchanged. If there is no label left or right of the current "
"selection, it will be expanded to the start or end of the file."
msgstr ""
"वर्तमान चयन को वर्तमान चयन सीमाओं से बाएँ और दाएँ लेबल तक विस्तारित करता है। यदि चयन "
"की सीमा पहले से ही किसी लेबल पर है, तो वह अपरिवर्तित रहती है। यदि वर्तमान चयन के बाएँ "
"या दाएँ कोई लेबल नहीं है, तो उसे फ़ाइल के आरंभ या अंत तक विस्तारित किया जाएगा।"

#. Tag: title
#: index.docbook:2644
#, no-c-format
msgid "&no-i18n-tag;f"
msgstr "&no-i18n-tag;f"

#. Tag: title
#: index.docbook:2647
#, no-c-format
msgid "&no-i18n-cmd_fileinfo;"
msgstr "&no-i18n-cmd_fileinfo;"

#. Tag: title
#: index.docbook:2649
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_fileinfo;</"
"command>(<replaceable>index</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_fileinfo;</"
"command>(<replaceable>index</replaceable>)"

#. Tag: para
#: index.docbook:2650
#, no-c-format
msgid "Set a file info entry to a new value."
msgstr "फ़ाइल जानकारी प्रविष्टि को नए मान पर सेट करें."

#. Tag: entry
#: index.docbook:2655
#, no-c-format
msgid "<parameter>keyword</parameter>:"
msgstr "<पैरामीटर>कीवर्ड</पैरामीटर>:"

#. Tag: entry
#: index.docbook:2655
#, no-c-format
msgid "keyword of the entry"
msgstr "प्रविष्टि का कीवर्ड"

#. Tag: entry
#: index.docbook:2656
#, no-c-format
msgid "<parameter>value</parameter>:"
msgstr "<पैरामीटर>मान</पैरामीटर>:"

#. Tag: entry
#: index.docbook:2656
#, no-c-format
msgid "value of the entry"
msgstr "प्रविष्टि का मूल्य"

#. Tag: title
#: index.docbook:2661
#, no-c-format
msgid "&no-i18n-cmd_forward;"
msgstr "&no-i18n-cmd_फॉरवर्ड;"

#. Tag: title
#: index.docbook:2663
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_forward;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_forward;</command>()"

#. Tag: para
#: index.docbook:2664
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Forward</guibutton> toolbar button. If the "
"playback is currently running, it skips forward by 1/10 of the visible "
"range. If the playback is not running, this does the same as the command "
"<command>&no-i18n-cmd_view_scroll_right;</command>()."
msgstr ""
"<guibutton>फॉरवर्ड</guibutton> टूलबार बटन के अनुरूप है। यदि प्लेबैक वर्तमान में चल रहा "
"है, तो यह दृश्यमान सीमा के 1/10 भाग से आगे की ओर जाता है। यदि प्लेबैक नहीं चल रहा है, तो "
"यह कमांड <command>&no-i18n-cmd_view_scroll_right;</command>() के समान ही कार्य "
"करता है।"

#. Tag: para
#: index.docbook:2673
#, no-c-format
msgid ""
"<link linkend=\"cmd_sect_view_scroll_right\"><command>&no-i18n-tag;&no-i18n-"
"cmd_view_scroll_right;</command>()</link>, <link linkend=\"cmd_sect_rewind"
"\"><command>&no-i18n-tag;&no-i18n-cmd_rewind;</command>()</link>"
msgstr ""
"<link linkend=\"cmd_sect_view_scroll_right\"><command>&amp;no-i18n-tag;&amp;"
"no-i18n-cmd_view_scroll_right;</command> ()</link> ,<link linkend="
"\"cmd_sect_rewind\"><command> &amp;no-i18n-टैग;&amp;no-i18n-cmd_rewind;</"
"command> ()</link>"

#. Tag: title
#: index.docbook:2681
#, no-c-format
msgid "&no-i18n-tag;g"
msgstr "&no-i18n-tag;जी"

#. Tag: title
#: index.docbook:2684
#, no-c-format
msgid "&no-i18n-cmd_goto;"
msgstr "&no-i18n-cmd_goto;"

#. Tag: title
#: index.docbook:2686
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_goto;</command>(<replaceable>pos</"
"replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_goto;</command>(<replaceable>pos</"
"replaceable>)"

#. Tag: para
#: index.docbook:2687
#, no-c-format
msgid ""
"Sets the cursor to the given position and makes it visible in current view. "
"After this the selection has zero length."
msgstr ""
"कर्सर को दिए गए स्थान पर सेट करता है और इसे वर्तमान दृश्य में दृश्यमान बनाता है। इसके बाद "
"चयन की लंबाई शून्य हो जाती है।"

#. Tag: entry
#: index.docbook:2693 index.docbook:2711 index.docbook:2756
#, no-c-format
msgid "<parameter>pos</parameter>:"
msgstr "<पैरामीटर>स्थिति</पैरामीटर>:"

#. Tag: entry
#: index.docbook:2693
#, no-c-format
msgid "position in samples where to go to"
msgstr "नमूनों में स्थिति जहां जाना है"

#. Tag: title
#: index.docbook:2698
#, no-c-format
msgid "&no-i18n-tag;i"
msgstr "&no-i18n-tag;i"

#. Tag: title
#: index.docbook:2701
#, no-c-format
msgid "&no-i18n-cmd_insert_at;"
msgstr "&no-i18n-cmd_insert_at;"

#. Tag: title
#: index.docbook:2703
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_insert_at;</"
"command>(<replaceable>pos</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_insert_at;</"
"command>(<replaceable>pos</replaceable>)"

#. Tag: para
#: index.docbook:2704
#, no-c-format
msgid ""
"Inserts the content of the clipboard at the given position, like the command "
"<command>&no-i18n-cmd_paste;</command>(). If the clipboard is currently "
"empty, this function does nothing."
msgstr ""
"क्लिपबोर्ड की सामग्री को दिए गए स्थान पर सम्मिलित करता है, जैसे कमांड <command>&no-"
"i18n-cmd_paste;</command>()। यदि क्लिपबोर्ड वर्तमान में खाली है, तो यह फ़ंक्शन कुछ नहीं "
"करता है।"

#. Tag: entry
#: index.docbook:2711
#, no-c-format
msgid "position in samples where to insert"
msgstr "नमूनों में वह स्थान जहाँ डालना है"

#. Tag: title
#: index.docbook:2719
#, no-c-format
msgid "&no-i18n-cmd_insert_track;"
msgstr "&no-i18n-cmd_insert_track;"

#. Tag: title
#: index.docbook:2721
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_insert_track;</"
"command>(<replaceable>index</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_insert_track;</"
"command>(<replaceable>index</replaceable>)"

#. Tag: para
#: index.docbook:2722
#, no-c-format
msgid ""
"Inserts a new track at the given index, using the current length and sample "
"rate settings of the signal. If the index is higher than or equal to the "
"current number of tracks, it will be appended as the last track, same as by "
"the command <command>&no-i18n-cmd_add_track;</command>(). The index of all "
"existing tracks at and after the given index will be incremented by one."
msgstr ""
"सिग्नल की वर्तमान लंबाई और सैंपल दर सेटिंग का उपयोग करके दिए गए इंडेक्स पर एक नया ट्रैक "
"सम्मिलित करता है। यदि इंडेक्स वर्तमान ट्रैक की संख्या से अधिक या उसके बराबर है, तो इसे "
"अंतिम ट्रैक के रूप में जोड़ा जाएगा, जैसा कि कमांड <command>&no-i18n-cmd_add_track;</"
"command>() द्वारा किया जाता है। दिए गए इंडेक्स पर और उसके बाद सभी मौजूदा ट्रैक का "
"इंडेक्स एक से बढ़ जाएगा।"

#. Tag: entry
#: index.docbook:2733
#, no-c-format
msgid "index of the track to insert, starting with 0"
msgstr "सम्मिलित किए जाने वाले ट्रैक का सूचकांक, 0 से शुरू होता है"

#. Tag: link
#: index.docbook:2737
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_add_track;</command>()"
msgstr "<कमांड>&no-i18n-tag;&no-i18n-cmd_add_track;</कमांड>()"

#. Tag: title
#: index.docbook:2743
#, no-c-format
msgid "&no-i18n-tag;l"
msgstr "&no-i18n-tag;l"

#. Tag: title
#: index.docbook:2746
#, no-c-format
msgid "&no-i18n-cmd_label_add;"
msgstr "&no-i18n-cmd_label_add;"

#. Tag: title
#: index.docbook:2748
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_label_add;</"
"command>(<replaceable>pos</replaceable>[,<replaceable>text</replaceable>])"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_label_add;</"
"command>(<replaceable>pos</replaceable>[,<replaceable>text</replaceable>])"

#. Tag: para
#: index.docbook:2749
#, no-c-format
msgid ""
"Add a new label at a given position. If the given position already contains "
"a label, then this command does nothing. The label can be given an optional "
"description."
msgstr ""
"किसी दिए गए स्थान पर नया लेबल जोड़ें। यदि दिए गए स्थान पर पहले से ही कोई लेबल है, तो "
"यह कमांड कुछ नहीं करता। लेबल को वैकल्पिक विवरण दिया जा सकता है।"

#. Tag: entry
#: index.docbook:2756
#, no-c-format
msgid "position in samples where to insert the label"
msgstr "नमूनों में वह स्थान जहाँ लेबल डालना है"

#. Tag: entry
#: index.docbook:2757 index.docbook:3055
#, no-c-format
msgid "<parameter>text</parameter>:"
msgstr "<पैरामीटर>टेक्स्ट</पैरामीटर>:"

#. Tag: entry
#: index.docbook:2757
#, no-c-format
msgid "some descriptive text (optional)"
msgstr "कुछ वर्णनात्मक पाठ (वैकल्पिक)"

#. Tag: title
#: index.docbook:2762
#, no-c-format
msgid "&no-i18n-cmd_label_delete;"
msgstr "&no-i18n-cmd_label_delete;"

#. Tag: title
#: index.docbook:2764
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_label_delete;</"
"command>(<replaceable>index</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_label_delete;</"
"command>(<replaceable>index</replaceable>)"

#. Tag: para
#: index.docbook:2765
#, no-c-format
msgid ""
"Deletes a label, identified by its index (starting from zero), or all labels "
"when using the special value -1 as index. If no label with the given index "
"exists, this command does nothing."
msgstr ""
"इंडेक्स के रूप में विशेष मान -1 का उपयोग करते समय, इसके इंडेक्स (शून्य से शुरू) द्वारा पहचाने "
"जाने वाले लेबल को हटाता है, या सभी लेबल को हटाता है। यदि दिए गए इंडेक्स वाला कोई लेबल "
"मौजूद नहीं है, तो यह कमांड कुछ नहीं करता है।"

#. Tag: entry
#: index.docbook:2772
#, no-c-format
msgid ""
"index of the label to delete, starting with 0 or -1 to delete all labels"
msgstr "हटाए जाने वाले लेबल का सूचकांक, 0 से शुरू करें या सभी लेबल हटाने के लिए -1 से शुरू करें"

#. Tag: title
#: index.docbook:2778
#, no-c-format
msgid "&no-i18n-cmd_label_edit;"
msgstr "&no-i18n-cmd_label_edit;"

#. Tag: screeninfo
#: index.docbook:2780 index.docbook:4379 index.docbook:4419 index.docbook:4564
#: index.docbook:4923 index.docbook:5231 index.docbook:5424 index.docbook:5460
#: index.docbook:5550 index.docbook:5643 index.docbook:5706 index.docbook:5750
#: index.docbook:5868 index.docbook:5943 index.docbook:6061 index.docbook:6154
#: index.docbook:6460 index.docbook:6685 index.docbook:6799 index.docbook:6810
#: index.docbook:6948 index.docbook:7002
#, no-c-format
msgid "Screenshot"
msgstr "स्क्रीनशॉट"

#. Tag: phrase
#: index.docbook:2786
#, no-c-format
msgid "Screenshot of the label editing dialog"
msgstr "लेबल संपादन संवाद का स्क्रीनशॉट"

#. Tag: title
#: index.docbook:2791
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_label_edit;</"
"command>(<replaceable>index</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_label_edit;</"
"command>(<replaceable>index</replaceable>)"

#. Tag: para
#: index.docbook:2792
#, no-c-format
msgid ""
"Opens a dialog window in which the user can edit the position and the "
"description of a label, which is identified by its index (starting from "
"zero). If no label with the given index exists, this command does nothing."
msgstr ""
"एक संवाद विंडो खोलता है जिसमें उपयोगकर्ता किसी लेबल की स्थिति और विवरण को संपादित कर "
"सकता है, जिसे उसके सूचकांक (शून्य से शुरू) द्वारा पहचाना जाता है। यदि दिए गए सूचकांक वाला "
"कोई लेबल मौजूद नहीं है, तो यह कमांड कुछ नहीं करता है।"

#. Tag: entry
#: index.docbook:2800
#, no-c-format
msgid "index of the label to edit, starting with 0"
msgstr "संपादित करने के लिए लेबल का सूचकांक, 0 से शुरू होता है"

#. Tag: title
#: index.docbook:2805
#, no-c-format
msgid "&no-i18n-cmd_loadbatch;"
msgstr "&no-i18n-cmd_loadbatch;"

#. Tag: title
#: index.docbook:2807
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_loadbatch;</"
"command>(<replaceable>filename</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_loadbatch;</"
"command>(<replaceable>फ़ाइलनाम</replaceable>)"

#. Tag: para
#: index.docbook:2808
#, no-c-format
msgid ""
"Opens a &kwave; script file and processes the commands in it. Uses the "
"context of the currently opened file or the current main window if no file "
"is loaded."
msgstr ""
"&kwave; स्क्रिप्ट फ़ाइल खोलता है और उसमें दिए गए आदेशों को संसाधित करता है। वर्तमान में "
"खोली गई फ़ाइल के संदर्भ का उपयोग करता है या यदि कोई फ़ाइल लोड नहीं की गई है तो "
"वर्तमान मुख्य विंडो का उपयोग करता है।"

#. Tag: entry
#: index.docbook:2815 index.docbook:3138 index.docbook:3164 index.docbook:3460
#: index.docbook:3493 index.docbook:4234
#, no-c-format
msgid "<parameter>filename</parameter>:"
msgstr "<पैरामीटर>फ़ाइलनाम</पैरामीटर>:"

#. Tag: entry
#: index.docbook:2816
#, no-c-format
msgid "name of the kwave script file including path and extension"
msgstr "kwave स्क्रिप्ट फ़ाइल का नाम पथ और एक्सटेंशन सहित"

#. Tag: title
#: index.docbook:2821
#, no-c-format
msgid "&no-i18n-cmd_loop;"
msgstr "&no-i18n-cmd_loop;"

#. Tag: title
#: index.docbook:2823
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_loop;</command>()"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_loop;</command>()"

#. Tag: para
#: index.docbook:2824
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Loop</guibutton> toolbar button. Starts the "
"playback (if it is not already running) and lets it play in a loop."
msgstr ""
"<guibutton>लूप</guibutton> टूलबार बटन के अनुरूप है। प्लेबैक शुरू करता है (यदि यह पहले से "
"नहीं चल रहा है) और इसे लूप में चलाने देता है।"

#. Tag: link
#: index.docbook:2832
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_playback_start;</command>()"
msgstr "<कमांड>&no-i18n-tag;&no-i18n-cmd_playback_start;</कमांड>()"

#. Tag: title
#: index.docbook:2838
#, no-c-format
msgid "&no-i18n-tag;m"
msgstr "&no-i18n-tag;म"

#. Tag: title
#: index.docbook:2841
#, no-c-format
msgid "&no-i18n-cmd_menu;"
msgstr "&no-i18n-cmd_menu;"

#. Tag: title
#: index.docbook:2843
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_menu;</command> "
"(<replaceable>command</replaceable>, <replaceable>path</replaceable>, "
"[<replaceable>hotkey</replaceable>], [<replaceable>id</replaceable>])"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_menu;</command> "
"(<replaceable>command</replaceable>, <replaceable>path</replaceable>, "
"[<replaceable>hotkey</replaceable>], [<replaceable>id</replaceable>])"

#. Tag: para
#: index.docbook:2849
#, no-c-format
msgid ""
"This is a very powerful command, which is used to add a new entry to the "
"menu or to modify an existing entry. It determines which <emphasis>command</"
"emphasis> is executed when the menu entry is activated, which "
"<emphasis>icon</emphasis> is shown in the menu and which <emphasis>hotkey</"
"emphasis> is used. Each menu entry can be <emphasis>disabled</emphasis> or "
"<emphasis>hidden</emphasis>, can be assigned a unique <emphasis>id</"
"emphasis> and can also join a <emphasis>menu group</emphasis>."
msgstr ""
"यह एक बहुत शक्तिशाली कमांड है, जिसका उपयोग मेनू में एक नई प्रविष्टि जोड़ने या किसी मौजूदा "
"प्रविष्टि को संशोधित करने के लिए किया जाता है। यह निर्धारित करता है कि मेनू प्रविष्टि "
"सक्रिय होने पर कौन सा <emphasis>कमांड</emphasis> निष्पादित किया जाता है, मेनू में कौन "
"सा <emphasis>आइकन</emphasis> दिखाया जाता है और कौन सी <emphasis>हॉटकी</"
"emphasis> का उपयोग किया जाता है। प्रत्येक मेनू प्रविष्टि को <emphasis>अक्षम</"
"emphasis> या <emphasis>छिपाया</emphasis> किया जा सकता है, उसे एक अद्वितीय "
"<emphasis>आईडी</emphasis> दिया जा सकता है और वह <emphasis>मेनू समूह</emphasis> में "
"भी शामिल हो सकता है।"

#. Tag: para
#: index.docbook:2860
#, no-c-format
msgid "You normally do not need this command within a &kwave; script!"
msgstr "आपको सामान्यतः &kwave; स्क्रिप्ट में इस कमांड की आवश्यकता नहीं होती है!"

#. Tag: entry
#: index.docbook:2867
#, no-c-format
msgid ""
"A text command (including parameters) or a command list that will be "
"executed when the menu entry gets activated. If a menu entry does not have a "
"corresponding command (for example if it is a sub menu and not menu entry), "
"you should use the special command <command>ignore</command>()."
msgstr ""
"एक टेक्स्ट कमांड (पैरामीटर सहित) या एक कमांड सूची जो मेनू प्रविष्टि सक्रिय होने पर "
"निष्पादित की जाएगी। यदि किसी मेनू प्रविष्टि में कोई संगत कमांड नहीं है (उदाहरण के लिए "
"यदि यह एक उप मेनू है और मेनू प्रविष्टि नहीं है), तो आपको विशेष कमांड <command>ignore</"
"command>() का उपयोग करना चाहिए।"

#. Tag: entry
#: index.docbook:2876
#, no-c-format
msgid "<parameter>path</parameter>:"
msgstr "<पैरामीटर>पथ</पैरामीटर>:"

#. Tag: entry
#: index.docbook:2877
#, no-c-format
msgid ""
"The path within the menu, using a <quote><token>/</token></quote> as "
"separator. The last part of the path can be a <emphasis>sub command</"
"emphasis> which modifies some property of the menu entry (see <link linkend="
"\"menu_sub_commands\">below</link>). The last portion of the path (that is "
"not a sub command) produces a menu entry, the parts before produce the main "
"menu entry or sub menus that lead to it. Main menu entries or sub menus are "
"automatically created when a menu entry is created, you do not need them "
"manually."
msgstr ""
"मेनू के भीतर पथ, एक का उपयोग कर<quote><token> /</token></quote> विभाजक के रूप में। "
"पथ का अंतिम भाग एक हो सकता है<emphasis> उप आदेश</emphasis> जो मेनू प्रविष्टि की कुछ "
"संपत्ति को संशोधित करता है (देखें<link linkend=\"menu_sub_commands\"> नीचे</link> )। "
"पथ का अंतिम भाग (जो उप आदेश नहीं है) एक मेनू प्रविष्टि बनाता है, इससे पहले के भाग मुख्य मेनू "
"प्रविष्टि या उप मेनू बनाते हैं जो उस तक ले जाते हैं। जब कोई मेनू प्रविष्टि बनाई जाती है तो "
"मुख्य मेनू प्रविष्टियाँ या उप मेनू स्वचालित रूप से बन जाते हैं, आपको उन्हें मैन्युअल रूप से बनाने की "
"आवश्यकता नहीं होती है।"

#. Tag: entry
#: index.docbook:2890
#, no-c-format
msgid "<parameter>hotkey</parameter>:"
msgstr "<पैरामीटर>हॉटकी</पैरामीटर>:"

#. Tag: entry
#: index.docbook:2891
#, no-c-format
msgid ""
"A bitmask that consists of a combination of predefined <emphasis>keys</"
"emphasis> and <emphasis>modifiers</emphasis>, concatenated with a "
"<quote><token>+</token></quote>. The <emphasis>key</emphasis> can be either "
"a digit, an upper case letter, a function key (<quote>F1</quote> ... "
"<quote>F12</quote>) or any other key name understood by the Qt class "
"<quote><literal>QKeySequence</literal></quote>, including key names for "
"predefined actions (like for example <quote><literal>::Copy</literal></"
"quote>). Typical <emphasis>modifiers</emphasis> are <quote><literal>SHIFT</"
"literal></quote>, <quote><literal>ALT</literal></quote> and "
"<quote><literal>CTRL</literal></quote>."
msgstr ""
"एक बिटमास्क जिसमें पूर्वनिर्धारित <emphasis>कुंजियाँ</emphasis> और <emphasis>संशोधक</"
"emphasis> का संयोजन होता है, जिसे <quote><token>+</token></quote> के साथ संयोजित "
"किया जाता है। <emphasis>कुंजी</emphasis> या तो एक अंक, एक अपर केस अक्षर, एक फ़ंक्शन "
"कुंजी (<quote>F1</quote> ... <quote>F12</quote>) या Qt वर्ग द्वारा समझे जाने वाले "
"किसी भी अन्य कुंजी नाम हो सकते हैं <quote><literal>QKeySequence</literal></quote>, "
"जिसमें पूर्वनिर्धारित क्रियाओं के लिए कुंजी नाम शामिल हैं (जैसे कि उदाहरण के लिए "
"<quote><literal>::Copy</literal></quote>)। विशिष्ट <emphasis>संशोधक</emphasis> "
"हैं <quote><literal>SHIFT</literal></quote>, <quote><literal>ALT</literal></"
"quote> और <quote><literal>CTRL</literal></quote>."

#. Tag: entry
#: index.docbook:2909
#, no-c-format
msgid "<parameter>id</parameter>:"
msgstr "<पैरामीटर>आईडी</पैरामीटर>:"

#. Tag: entry
#: index.docbook:2910
#, no-c-format
msgid ""
"A unique id that can be internally used to identify this menu entry or "
"menu / sub menu. Only uppercase letters, digits and <quote><literal>_</"
"literal></quote> should be used and it should start with "
"<quote><literal>ID_</literal></quote>. It is in your own responsibility to "
"make sure that the same id is not used twice."
msgstr ""
"एक अद्वितीय आईडी जिसका उपयोग इस मेनू प्रविष्टि या मेनू / उप मेनू की पहचान करने के लिए "
"आंतरिक रूप से किया जा सकता है। केवल बड़े अक्षर, अंक और <quote><literal>_</literal></"
"quote> का उपयोग किया जाना चाहिए और इसे <quote><literal>ID_</literal></quote> "
"से शुरू होना चाहिए। यह सुनिश्चित करना आपकी अपनी जिम्मेदारी है कि एक ही आईडी का दो "
"बार उपयोग न किया जाए।"

#. Tag: title
#: index.docbook:2920
#, no-c-format
msgid "Sub Commands"
msgstr "उप कमांड"

#. Tag: entry
#: index.docbook:2922
#, no-c-format
msgid "<command>&no-i18n-tag;#checkable</command>:"
msgstr "<command>&no-i18n-tag;#checkable</command>:"

#. Tag: entry
#: index.docbook:2923
#, no-c-format
msgid ""
"Makes the menu entry <emphasis>checkable</emphasis>, so that it can be "
"switched on or off."
msgstr ""
"मेनू प्रविष्टि को <emphasis>जांच योग्य</emphasis> बनाता है, ताकि इसे चालू या बंद किया "
"जा सके।"

#. Tag: entry
#: index.docbook:2928
#, no-c-format
msgid "<command>&no-i18n-tag;#disabled</command>:"
msgstr "<command>&no-i18n-tag;#disabled</command>:"

#. Tag: entry
#: index.docbook:2929
#, no-c-format
msgid "<emphasis>Disables</emphasis> the menu, sub menu or menu entry."
msgstr "<emphasis>मेनू, उपमेनू या मेनू प्रविष्टि को अक्षम करता है</emphasis>."

#. Tag: entry
#: index.docbook:2933
#, no-c-format
msgid "<command>&no-i18n-tag;#enabled</command>:"
msgstr "<command>&no-i18n-tag;#enabled</command>:"

#. Tag: entry
#: index.docbook:2934
#, no-c-format
msgid "<emphasis>Enables</emphasis> the menu, sub menu or menu entry."
msgstr "<emphasis>मेनू, उपमेनू या मेनू प्रविष्टि को सक्षम करता है</emphasis>."

#. Tag: entry
#: index.docbook:2938
#, no-c-format
msgid "<command>#exclusive</command>(<replaceable>group</replaceable>):"
msgstr "<command>#exclusive</command>(<replaceable>group</replaceable>):"

#. Tag: entry
#: index.docbook:2939
#, no-c-format
msgid ""
"Adds the menu entry to an <emphasis>exclusive</emphasis> "
"<emphasis><replaceable>group</replaceable></emphasis> (one of many "
"selection). The group that is given as parameter should not be used for any "
"other purpose. Only one entry within that group can be selected at a time."
msgstr ""
"मेनू प्रविष्टि को <emphasis>अनन्य</emphasis> <emphasis><replaceable>समूह</"
"replaceable></emphasis> (कई चयनों में से एक) में जोड़ता है। पैरामीटर के रूप में दिया गया "
"समूह किसी अन्य उद्देश्य के लिए उपयोग नहीं किया जाना चाहिए। उस समूह के भीतर एक समय में "
"केवल एक प्रविष्टि का चयन किया जा सकता है।"

#. Tag: entry
#: index.docbook:2947
#, no-c-format
msgid "<command>#group</command>(<replaceable>list</replaceable>):"
msgstr "<command>#group</command>(<replaceable>सूची</replaceable>):"

#. Tag: para
#: index.docbook:2948
#, no-c-format
msgid ""
"Adds the menu, sub menu or menu entry to one or more a <emphasis>groups</"
"emphasis>, so that the application can enable/disable a bunch of menu "
"entries without need to know all their unique ids. Multiple groups can be "
"passed as a list with a <quote><literal>,</literal></quote> as separator. "
"Group names have to start with a <quote><literal>@</literal></quote>. The "
"following groups are predefined:"
msgstr ""
"मेनू, उप मेनू या मेनू प्रविष्टि को एक या अधिक <emphasis>समूहों</emphasis> में जोड़ता है, "
"ताकि एप्लिकेशन मेनू प्रविष्टियों के समूह को सक्षम/अक्षम कर सके, बिना उनकी सभी विशिष्ट "
"आईडी जानने की आवश्यकता के। एकाधिक समूहों को <quote><literal>,</literal></quote> "
"को विभाजक के रूप में सूची के रूप में पास किया जा सकता है। समूह के नाम <quote><literal>@</"
"literal></quote> से शुरू होने चाहिए। निम्नलिखित समूह पूर्वनिर्धारित हैं:"

#. Tag: term
#: index.docbook:2959
#, no-c-format
msgid "<command>&no-i18n-tag;@CLIPBOARD</command>:"
msgstr "<command>&no-i18n-tag;@CLIPBOARD</command>:"

#. Tag: para
#: index.docbook:2961
#, no-c-format
msgid "Only enabled when the clipboard is not empty."
msgstr "केवल तभी सक्षम किया जाता है जब क्लिपबोर्ड खाली न हो."

#. Tag: term
#: index.docbook:2967
#, no-c-format
msgid "<command>&no-i18n-tag;@LABELS</command>:"
msgstr "<command>&no-i18n-tag;@LABELS</command>:"

#. Tag: para
#: index.docbook:2969
#, no-c-format
msgid "Only enabled when the current signal contains at least one label."
msgstr "केवल तभी सक्षम किया जाता है जब वर्तमान सिग्नल में कम से कम एक लेबल हो।"

#. Tag: term
#: index.docbook:2976
#, no-c-format
msgid "<command>&no-i18n-tag;@NOT_CLOSED</command>:"
msgstr "<command>&no-i18n-tag;@NOT_CLOSED</command>:"

#. Tag: para
#: index.docbook:2978
#, no-c-format
msgid ""
"Enabled when the current signal is not closed (the signal might be empty or "
"zero length)."
msgstr ""
"सक्षम तब होता है जब वर्तमान सिग्नल बंद नहीं होता (सिग्नल रिक्त या शून्य लंबाई का हो "
"सकता है)।"

#. Tag: term
#: index.docbook:2985
#, no-c-format
msgid "<command>&no-i18n-tag;@SELECTION</command>:"
msgstr "<command>&no-i18n-tag;@SELECTION</command>:"

#. Tag: para
#: index.docbook:2987
#, no-c-format
msgid ""
"Enabled when the selection is not empty (more than one sample is selected)."
msgstr "सक्षम तब होता है जब चयन रिक्त न हो (एक से अधिक नमूने चयनित हों)."

#. Tag: term
#: index.docbook:2994
#, no-c-format
msgid "<command>&no-i18n-tag;@SIGNAL</command>:"
msgstr "<command>&no-i18n-tag;@SIGNAL</command>:"

#. Tag: para
#: index.docbook:2996
#, no-c-format
msgid ""
"Enabled when there is some signal loaded and it is not empty or zero length."
msgstr ""
"यह सुविधा तब सक्षम होती है जब कोई सिग्नल लोड हो और वह खाली या शून्य लंबाई का न हो।"

#. Tag: entry
#: index.docbook:3005
#, no-c-format
msgid "<command>&no-i18n-tag;#hidden</command>:"
msgstr "<command>&no-i18n-tag;#hidden</command>:"

#. Tag: entry
#: index.docbook:3006
#, no-c-format
msgid "<emphasis>Hides</emphasis> the menu, sub menu or menu entry."
msgstr "<emphasis>मेनू, उपमेनू या मेनू प्रविष्टि को छुपाता है</emphasis>."

#. Tag: entry
#: index.docbook:3009
#, no-c-format
msgid "<command>#icon</command>(<replaceable>name</replaceable>):"
msgstr "<command>#icon</command>(<replaceable>name</replaceable>):"

#. Tag: entry
#: index.docbook:3010
#, no-c-format
msgid ""
"Assigns an <emphasis>icon</emphasis> to the menu entry. The icon "
"<emphasis><replaceable>name</replaceable></emphasis> should correspond to an "
"icon file (without path and file extension) that is installed on the system "
"or with &kwave;."
msgstr ""
"मेनू प्रविष्टि को एक <emphasis>आइकन</emphasis> असाइन करता है। आइकन "
"<emphasis><replaceable>name</replaceable></emphasis> को एक आइकन फ़ाइल (पथ और "
"फ़ाइल एक्सटेंशन के बिना) के अनुरूप होना चाहिए जो सिस्टम पर या &kwave; के साथ स्थापित है।"

#. Tag: entry
#: index.docbook:3018
#, no-c-format
msgid ""
"<command>#listmenu</command>(<replaceable>id</replaceable>,"
"<replaceable>command</replaceable>):"
msgstr ""
"<command>#listmenu</command>(<replaceable>id</replaceable>,"
"<replaceable>command</replaceable>):"

#. Tag: entry
#: index.docbook:3019
#, no-c-format
msgid ""
"Inserts a placeholder for a list of menu entries into a sub menu. The unique "
"<emphasis><replaceable>id</replaceable></emphasis> specified in this sub "
"command is used to add/remove or clear the list of menu entries. The "
"<emphasis><replaceable>command</replaceable></emphasis> parameter has to "
"contain <quote><literal>%1</literal></quote> as parameter, which will be "
"replaced with the text of the menu entry when it is activated. This sub "
"command is internally used for the list of recent files, list of tracks and "
"window list."
msgstr ""
"उप-मेनू में मेनू प्रविष्टियों की सूची के लिए प्लेसहोल्डर सम्मिलित करता है। इस उप-कमांड में "
"निर्दिष्ट अद्वितीय <emphasis><replaceable>id</replaceable></emphasis> का उपयोग "
"मेनू प्रविष्टियों की सूची को जोड़ने/हटाने या साफ़ करने के लिए किया जाता है। "
"<emphasis><replaceable>command</replaceable></emphasis> पैरामीटर में पैरामीटर के "
"रूप में <quote><literal>%1</literal></quote> शामिल होना चाहिए, जिसे सक्रिय होने पर "
"मेनू प्रविष्टि के टेक्स्ट से बदल दिया जाएगा। यह उप-कमांड आंतरिक रूप से हाल की फ़ाइलों की "
"सूची, ट्रैक की सूची और विंडो सूची के लिए उपयोग किया जाता है।"

#. Tag: entry
#: index.docbook:3033
#, no-c-format
msgid "<command>&no-i18n-tag;#separator</command>:"
msgstr "<command>&no-i18n-tag;#separator</command>:"

#. Tag: entry
#: index.docbook:3034
#, no-c-format
msgid "Inserts a separator into a sub menu."
msgstr "उपमेनू में विभाजक सम्मिलित करता है।"

#. Tag: title
#: index.docbook:3044
#, no-c-format
msgid "&no-i18n-cmd_msgbox;"
msgstr "&no-i18n-cmd_msgbox;"

#. Tag: title
#: index.docbook:3046
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_msgbox;</command>(<replaceable>text</"
"replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_msgbox;</command>(<replaceable>text</"
"replaceable>)"

#. Tag: para
#: index.docbook:3047
#, no-c-format
msgid ""
"Shows a message box with some <emphasis><replaceable>text</replaceable></"
"emphasis> and the two buttons <guibutton>OK</guibutton> (returns without "
"error code) and <guibutton>Cancel</guibutton> (returns and error code). You "
"can use this command to give the user a possibility to abort a running "
"script."
msgstr ""
"कुछ <emphasis><replaceable>text</replaceable></emphasis> और दो बटन "
"<guibutton>OK</guibutton> (त्रुटि कोड के बिना रिटर्न) और <guibutton>Cancel</"
"guibutton> (त्रुटि कोड और रिटर्न) के साथ एक संदेश बॉक्स दिखाता है। आप उपयोगकर्ता को "
"चल रही स्क्रिप्ट को निरस्त करने की संभावना देने के लिए इस कमांड का उपयोग कर सकते हैं।"

#. Tag: entry
#: index.docbook:3056
#, no-c-format
msgid ""
"A message that will be shown in the message box, should contain a question "
"that can be answered with <guibutton>OK</guibutton> or <guibutton>Cancel</"
"guibutton>."
msgstr ""
"संदेश बॉक्स में दिखाए जाने वाले संदेश में एक प्रश्न होना चाहिए जिसका उत्तर <guibutton>OK</"
"guibutton> या <guibutton>Cancel</guibutton> से दिया जा सके।"

#. Tag: title
#: index.docbook:3066
#, no-c-format
msgid "&no-i18n-tag;n"
msgstr "&no-i18n-tag;n"

#. Tag: title
#: index.docbook:3069
#, no-c-format
msgid "&no-i18n-cmd_newsignal;"
msgstr "&no-i18n-cmd_newsignal;"

#. Tag: title
#: index.docbook:3071
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_newsignal;</"
"command>( <replaceable>samples</replaceable>, <replaceable>rate</"
"replaceable>, <replaceable>bits</replaceable>, <replaceable>tracks</"
"replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_newsignal;</"
"command>( <replaceable>नमूने</replaceable>, <replaceable>दर</replaceable>, "
"<replaceable>बिट्स</replaceable>, <replaceable>ट्रैक</replaceable>)"

#. Tag: para
#: index.docbook:3077
#, no-c-format
msgid ""
"Creates a new signal, with a given length in <emphasis><replaceable>samples</"
"replaceable></emphasis>, a <emphasis><replaceable>rate</replaceable></"
"emphasis> in samples per second (floating point number), a number of "
"<emphasis><replaceable>bits</replaceable></emphasis> per sample and number "
"of <emphasis><replaceable>tracks</replaceable></emphasis>. You can calculate "
"the length in samples by multiplying the desired length in seconds with the "
"sample rate."
msgstr ""
"<emphasis><replaceable>samples</replaceable></emphasis> में दी गई लंबाई, प्रति "
"सेकंड सैंपल में एक <emphasis><replaceable>दर</replaceable></emphasis> (फ़्लोटिंग पॉइंट "
"नंबर), प्रति सैंपल <emphasis><replaceable>बिट्स</replaceable></emphasis> की संख्या "
"और <emphasis><replaceable>ट्रैक</replaceable></emphasis> की संख्या के साथ एक नया "
"सिग्नल बनाता है। आप सेकंड में वांछित लंबाई को सैंपल दर से गुणा करके सैंपल में लंबाई की गणना कर "
"सकते हैं।"

#. Tag: entry
#: index.docbook:3089
#, no-c-format
msgid "<parameter>samples</parameter>:"
msgstr "<पैरामीटर>नमूने</पैरामीटर>:"

#. Tag: entry
#: index.docbook:3090
#, no-c-format
msgid "Length of the signal in samples."
msgstr "नमूनों में सिग्नल की लंबाई."

#. Tag: entry
#: index.docbook:3091
#, no-c-format
msgid "<parameter>rate</parameter>:"
msgstr "<पैरामीटर>दर</पैरामीटर>:"

#. Tag: entry
#: index.docbook:3092
#, no-c-format
msgid "<entry>Sample rate in samples per second.</entry>"
msgstr "<entry>प्रति सेकंड नमूनों में नमूना दर.</entry>"

#. Tag: entry
#: index.docbook:3093
#, no-c-format
msgid "<parameter>bits</parameter>:"
msgstr "<पैरामीटर>बिट्स</पैरामीटर>:"

#. Tag: entry
#: index.docbook:3094
#, no-c-format
msgid ""
"Number of bits per sample, must not be zero, should be a number from 8...32."
msgstr ""
"प्रति नमूने बिट्स की संख्या शून्य नहीं होनी चाहिए, 8...32 के बीच की संख्या होनी चाहिए।"

#. Tag: entry
#: index.docbook:3096
#, no-c-format
msgid "<parameter>tracks</parameter>:"
msgstr "<पैरामीटर>ट्रैक</पैरामीटर>:"

#. Tag: entry
#: index.docbook:3097
#, no-c-format
msgid "Number of tracks."
msgstr "ट्रैकों की संख्या."

#. Tag: title
#: index.docbook:3102
#, no-c-format
msgid "&no-i18n-cmd_next;"
msgstr "&no-i18n-cmd_next;"

#. Tag: title
#: index.docbook:3104
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_next;</command>()"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_next;</command>()"

#. Tag: para
#: index.docbook:3105
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Next</guibutton> toolbar button. If the "
"playback is currently running, it skips forward to the next label. If the "
"playback is not running, this does the same as the command <command>&no-i18n-"
"cmd_view_scroll_next_label;</command>()."
msgstr ""
"<guibutton>Next</guibutton> टूलबार बटन के अनुरूप है। यदि प्लेबैक वर्तमान में चल रहा है, "
"तो यह अगले लेबल पर आगे बढ़ता है। यदि प्लेबैक नहीं चल रहा है, तो यह कमांड <command>&no-"
"i18n-cmd_view_scroll_next_label;</command>() के समान ही कार्य करता है।"

#. Tag: para
#: index.docbook:3114
#, no-c-format
msgid ""
"<link linkend=\"cmd_sect_view_scroll_next_label\"><command>&no-i18n-tag;&no-"
"i18n-cmd_view_scroll_next_label;</command>()</link>, <link linkend="
"\"cmd_sect_prev\"><command>&no-i18n-tag;&no-i18n-cmd_prev;</command>()</link>"
msgstr ""
"<link linkend=\"cmd_sect_view_scroll_next_label\"><command>&amp;no-i18n-tag;"
"&amp;no-i18n-cmd_view_scroll_next_label;</command> ()</link> ,<link linkend="
"\"cmd_sect_prev\"><command> &amp;no-i18n-टैग;&amp;no-i18n-cmd_prev;</command> "
"()</link>"

#. Tag: title
#: index.docbook:3122
#, no-c-format
msgid "&no-i18n-tag;o"
msgstr "&no-i18n-tag;o"

#. Tag: title
#: index.docbook:3125
#, no-c-format
msgid "&no-i18n-cmd_open;"
msgstr "&no-i18n-cmd_open;"

#. Tag: title
#: index.docbook:3127
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_open;</"
"command>([<replaceable>filename</replaceable>])"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_open;</"
"command>([<replaceable>फ़ाइलनाम</replaceable>])"

#. Tag: para
#: index.docbook:3128
#, no-c-format
msgid ""
"Opens a file, which can be either a sound file or a &kwave; script. If no "
"file name is passed, then a dialog window will be opened that allows to "
"select an existing file. Depending on the &GUI; mode the file will be opened "
"in the context of a new sub-window (MDI and tab) or in a new main window "
"(SDI, if there was already something loaded)."
msgstr ""
"एक फ़ाइल खोलता है, जो या तो एक ध्वनि फ़ाइल या &kwave; स्क्रिप्ट हो सकती है। यदि कोई "
"फ़ाइल नाम पास नहीं किया गया है, तो एक संवाद विंडो खुलेगी जो किसी मौजूदा फ़ाइल को चुनने "
"की अनुमति देती है। &GUI; मोड के आधार पर फ़ाइल एक नई उप-विंडो (MDI और टैब) या एक नई "
"मुख्य विंडो (SDI, यदि पहले से कुछ लोड किया गया था) के संदर्भ में खोली जाएगी।"

#. Tag: entry
#: index.docbook:3139
#, no-c-format
msgid "name of a file including path and extension"
msgstr "पथ और एक्सटेंशन सहित फ़ाइल का नाम"

#. Tag: link
#: index.docbook:3143 index.docbook:3332
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_close;</command>()"
msgstr "<कमांड>&no-i18n-tag;&no-i18n-cmd_close;</कमांड>()"

#. Tag: title
#: index.docbook:3149
#, no-c-format
msgid "&no-i18n-cmd_openrecent;"
msgstr "&no-i18n-cmd_openrecent;"

#. Tag: title
#: index.docbook:3151
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_openrecent;</"
"command>(<replaceable>filename</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_openrecent;</"
"command>(<replaceable>फ़ाइलनाम</replaceable>)"

#. Tag: para
#: index.docbook:3152
#, no-c-format
msgid ""
"Practically the same as the command <command>&no-i18n-cmd_open;</command>(), "
"but intended to be used internally for the list of recently opened files in "
"the menu <menuchoice> <guimenu>File</guimenu><guimenu>Open Recent</guimenu> "
"</menuchoice>. In this command the parameter <replaceable>filename</"
"replaceable> is not optional."
msgstr ""
"व्यावहारिक रूप से यह कमांड <command>&no-i18n-cmd_open;</command>() के समान है, "
"लेकिन इसका उपयोग हाल ही में मेनू <menuchoice> <guimenu>फ़ाइल</guimenu><guimenu>हाल "
"ही में खोलें</guimenu> </menuchoice> में खोली गई फ़ाइलों की सूची के लिए आंतरिक रूप से "
"किया जाना है। इस कमांड में पैरामीटर <replaceable>filename</replaceable> वैकल्पिक "
"नहीं है।"

#. Tag: entry
#: index.docbook:3165
#, no-c-format
msgid "entry of the list of recently opened files"
msgstr "हाल ही में खोली गई फ़ाइलों की सूची की प्रविष्टि"

#. Tag: link
#: index.docbook:3169
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_open;</command>()"
msgstr "<कमांड>&no-i18n-tag;&no-i18n-cmd_open;</कमांड>()"

#. Tag: title
#: index.docbook:3175
#, no-c-format
msgid "&no-i18n-tag;p"
msgstr "&no-i18n-टैग;पी"

#. Tag: title
#: index.docbook:3178
#, no-c-format
msgid "&no-i18n-cmd_paste;"
msgstr "&no-i18n-cmd_paste;"

#. Tag: title
#: index.docbook:3180
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_paste;</command>()"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_paste;</command>()"

#. Tag: para
#: index.docbook:3181
#, no-c-format
msgid ""
"Replaces the current selection with the content of the clipboard. If the "
"clipboard is empty, this command does nothing. The sample rate of the "
"inserted data is adjusted to match the sample rate of the current signal if "
"necessary. Only enabled tracks are affected, disabled tracks remain "
"unchanged. Please be aware that this might produce a time shift between "
"enabled and disabled tracks! If the number of tracks of the clipboard data "
"differs from the number of enabled tracks, then the data is mixed to be "
"spread equally over all selected tracks."
msgstr ""
"वर्तमान चयन को क्लिपबोर्ड की सामग्री से बदल देता है। यदि क्लिपबोर्ड खाली है, तो यह "
"कमांड कुछ नहीं करता है। यदि आवश्यक हो तो सम्मिलित डेटा की नमूना दर को वर्तमान सिग्नल "
"की नमूना दर से मिलान करने के लिए समायोजित किया जाता है। केवल सक्षम ट्रैक प्रभावित होते "
"हैं, अक्षम ट्रैक अपरिवर्तित रहते हैं। कृपया ध्यान रखें कि इससे सक्षम और अक्षम ट्रैक के बीच समय "
"में बदलाव हो सकता है! यदि क्लिपबोर्ड डेटा के ट्रैक की संख्या सक्षम ट्रैक की संख्या से भिन्न "
"होती है, तो डेटा को सभी चयनित ट्रैक पर समान रूप से फैलाने के लिए मिलाया जाता है।"

#. Tag: link
#: index.docbook:3196
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_copy;</command>()"
msgstr "<कमांड>&no-i18n-tag;&no-i18n-cmd_copy;</कमांड>()"

#. Tag: title
#: index.docbook:3202
#, no-c-format
msgid "&no-i18n-cmd_pause;"
msgstr "&no-i18n-cmd_pause;"

#. Tag: para
#: index.docbook:3205
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Pause</guibutton> toolbar button and lets the "
"playback pause if it is currently running, or continue if it is currently "
"paused."
msgstr ""
"यह <guibutton>रोकें</guibutton> टूलबार बटन के अनुरूप है और यदि प्लेबैक वर्तमान में चल रहा "
"है तो उसे रोक देता है, या यदि वर्तमान में रुका हुआ है तो उसे जारी रखने देता है।"

#. Tag: link
#: index.docbook:3213
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_continue;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_continue;</command>()"

#. Tag: title
#: index.docbook:3219
#, no-c-format
msgid "&no-i18n-cmd_playback_start;"
msgstr "&no-i18n-cmd_playback_start;"

#. Tag: title
#: index.docbook:3221
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_playback_start;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_playback_start;</"
"command>()"

#. Tag: para
#: index.docbook:3222
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Start</guibutton> toolbar button and lets the "
"playback start if it is currently paused."
msgstr ""
"<guibutton>प्रारंभ</guibutton> टूलबार बटन के अनुरूप है और यदि प्लेबैक वर्तमान में रुका हुआ "
"है तो उसे प्रारंभ करने देता है।"

#. Tag: title
#: index.docbook:3230
#, no-c-format
msgid "&no-i18n-cmd_plugin;"
msgstr "&no-i18n-cmd_plugin;"

#. Tag: title
#: index.docbook:3232
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_plugin;</command>(<replaceable>name</"
"replaceable>, [<replaceable>parameter</replaceable> ...])"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_plugin;</command>(<replaceable>नाम</"
"replaceable>, [<replaceable>पैरामीटर</replaceable> ...])"

#. Tag: para
#: index.docbook:3233
#, no-c-format
msgid ""
"Executes a plugin, with an optional list of parameters. If no parameter list "
"is given, then the setup function of the plugin will be called, using the "
"parameters of the previous invocation or default parameters as input "
"(normally shows a setup dialog, depending on the plugin). Please refer to "
"the chapter about <link linkend=\"plugins\">plugins</link> for a description "
"of the various plugins."
msgstr ""
"प्लगइन को निष्पादित करता है, जिसमें पैरामीटर की वैकल्पिक सूची होती है। यदि कोई पैरामीटर "
"सूची नहीं दी गई है, तो प्लगइन के सेटअप फ़ंक्शन को पिछले इनवोकेशन के पैरामीटर या डिफ़ॉल्ट "
"पैरामीटर को इनपुट के रूप में उपयोग करके कॉल किया जाएगा (आमतौर पर प्लगइन के आधार पर एक "
"सेटअप डायलॉग दिखाता है)। कृपया इस बारे में अध्याय देखें<link linkend=\"plugins\"> प्लग-"
"इन</link> विभिन्न प्लगइन्स के विवरण के लिए यहां क्लिक करें।"

#. Tag: entry
#: index.docbook:3244 index.docbook:3268 index.docbook:3290
#, no-c-format
msgid "<parameter>name</parameter>:"
msgstr "<पैरामीटर>नाम</पैरामीटर>:"

#. Tag: entry
#: index.docbook:3245 index.docbook:3269 index.docbook:3291
#, no-c-format
msgid "the (internal) name of a &kwave; plugin"
msgstr "&kwave; प्लगइन का (आंतरिक) नाम"

#. Tag: entry
#: index.docbook:3246 index.docbook:3270 index.docbook:3292
#, no-c-format
msgid "<parameter>parameter</parameter>:"
msgstr "<पैरामीटर>पैरामीटर</पैरामीटर>:"

#. Tag: entry
#: index.docbook:3247 index.docbook:3293
#, no-c-format
msgid "a list of parameters understood by the plugin (optional)"
msgstr "प्लगइन द्वारा समझे जाने वाले मापदंडों की सूची (वैकल्पिक)"

#. Tag: para
#: index.docbook:3250
#, no-c-format
msgid ""
"<link linkend=\"cmd_sect_plugin_execute\"><command>&no-i18n-tag;&no-i18n-"
"cmd_plugin_execute;</command>()</link>, <link linkend=\"cmd_sect_plugin_setup"
"\"><command>&no-i18n-tag;&no-i18n-cmd_plugin_setup;</command>()</link>"
msgstr ""
"<link linkend=\"cmd_sect_plugin_execute\"><command>&amp;no-i18n-टैग;&amp;no-"
"i18n-cmd_plugin_execute;</command> ()</link> ,<link linkend="
"\"cmd_sect_plugin_setup\"><command> &amp;no-i18n-tag;&amp;no-i18n-"
"cmd_plugin_setup;</command> ()</link>"

#. Tag: title
#: index.docbook:3258
#, no-c-format
msgid "&no-i18n-cmd_plugin_execute;"
msgstr "&no-i18n-cmd_plugin_execute;"

#. Tag: title
#: index.docbook:3260
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_plugin_execute;</"
"command>(<replaceable>name</replaceable>, [<replaceable>parameter</"
"replaceable> ...])"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_plugin_execute;</"
"command>(<replaceable>name</replaceable>, [<replaceable>parameter</"
"replaceable> ...])"

#. Tag: para
#: index.docbook:3261
#, no-c-format
msgid ""
"Similar to the command <command>&no-i18n-cmd_plugin;</command>(), but "
"without calling the setup function of the plugin if no parameters were "
"passed."
msgstr ""
"कमांड <command>&no-i18n-cmd_plugin;</command>() के समान, लेकिन यदि कोई पैरामीटर "
"पास नहीं किया गया है तो प्लगइन के सेटअप फ़ंक्शन को कॉल किए बिना।"

#. Tag: entry
#: index.docbook:3271
#, no-c-format
msgid "a list of parameters understood by the plugin"
msgstr "प्लगइन द्वारा समझे जाने वाले मापदंडों की सूची"

#. Tag: title
#: index.docbook:3276
#, no-c-format
msgid "&no-i18n-cmd_plugin_setup;"
msgstr "&no-i18n-cmd_plugin_setup;"

#. Tag: title
#: index.docbook:3278
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_plugin_setup;</"
"command>(<replaceable>name</replaceable>, [<replaceable>parameter</"
"replaceable> ...])"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_plugin_setup;</"
"command>(<replaceable>name</replaceable>, [<replaceable>parameter</"
"replaceable> ...])"

#. Tag: para
#: index.docbook:3279
#, no-c-format
msgid ""
"Calls the <emphasis>setup</emphasis> function of a plugin, with an optional "
"list of parameters. If no parameter list is given, the parameters of the "
"previous invocation or default parameters will be used as input. This "
"normally shows a setup dialog, depending on the plugin. Please refer to the "
"chapter about <link linkend=\"plugins\">plugins</link> for a description of "
"the various plugins."
msgstr ""
"कॉल<emphasis> स्थापित करना</emphasis> प्लगइन का फ़ंक्शन, जिसमें पैरामीटर की वैकल्पिक "
"सूची होती है। यदि कोई पैरामीटर सूची नहीं दी गई है, तो पिछले इनवोकेशन या डिफ़ॉल्ट "
"पैरामीटर के पैरामीटर इनपुट के रूप में उपयोग किए जाएंगे। यह आमतौर पर प्लगइन के आधार पर एक "
"सेटअप डायलॉग दिखाता है। कृपया इस बारे में अध्याय देखें<link linkend=\"plugins\"> प्लग-"
"इन</link> विभिन्न प्लगइन्स के विवरण के लिए यहां क्लिक करें।"

#. Tag: title
#: index.docbook:3298
#, no-c-format
msgid "&no-i18n-cmd_prev;"
msgstr "&no-i18n-cmd_prev;"

#. Tag: title
#: index.docbook:3300
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_prev;</command>()"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_prev;</command>()"

#. Tag: para
#: index.docbook:3301
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Previous</guibutton> toolbar button. If the "
"playback is currently running, it skips back to the previous label or start "
"of the selection. If the playback is not running, this does the same as the "
"command <command>&no-i18n-cmd_view_scroll_prev_label;</command>()."
msgstr ""
"<guibutton>पिछला</guibutton> टूलबार बटन के अनुरूप है। यदि प्लेबैक वर्तमान में चल रहा है, "
"तो यह पिछले लेबल या चयन की शुरुआत पर वापस चला जाता है। यदि प्लेबैक नहीं चल रहा है, तो "
"यह कमांड <command>&no-i18n-cmd_view_scroll_prev_label;</command>() के समान ही "
"कार्य करता है।"

#. Tag: para
#: index.docbook:3310
#, no-c-format
msgid ""
"<link linkend=\"cmd_sect_view_scroll_next_label\"><command>&no-i18n-tag;&no-"
"i18n-cmd_view_scroll_prev_label;</command>()</link>, <link linkend="
"\"cmd_sect_next\"><command>&no-i18n-tag;&no-i18n-cmd_next;</command>()</link>"
msgstr ""
"<link linkend=\"cmd_sect_view_scroll_next_label\"><command>&amp;no-i18n-टैग;"
"&amp;no-i18n-cmd_view_scroll_prev_label;</command> ()</link> ,<link linkend="
"\"cmd_sect_next\"><command> &amp;no-i18n-टैग;&amp;no-i18n-cmd_next;</command> "
"()</link>"

#. Tag: title
#: index.docbook:3318
#, no-c-format
msgid "&no-i18n-tag;q"
msgstr "&no-i18n-tag;q"

#. Tag: title
#: index.docbook:3321
#, no-c-format
msgid "&no-i18n-cmd_quit;"
msgstr "&no-i18n-cmd_quit;"

#. Tag: title
#: index.docbook:3323
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_quit;</command>()"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_quit;</command>()"

#. Tag: para
#: index.docbook:3324
#, no-c-format
msgid ""
"Closes the current main window, including all sub-windows. In SDI mode this "
"is the same as the command <command>&no-i18n-cmd_close;</command>()."
msgstr ""
"सभी उप-विंडो सहित वर्तमान मुख्य विंडो को बंद करता है। SDI मोड में यह कमांड "
"<command>&no-i18n-cmd_close;</command>() के समान है।"

#. Tag: title
#: index.docbook:3338
#, no-c-format
msgid "&no-i18n-tag;r"
msgstr "&no-i18n-tag;आर"

#. Tag: title
#: index.docbook:3341
#, no-c-format
msgid "&no-i18n-cmd_redo;"
msgstr "&no-i18n-cmd_redo;"

#. Tag: title
#: index.docbook:3343
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_redo;</command>()"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_redo;</command>()"

#. Tag: para
#: index.docbook:3344
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Redo</guibutton> toolbar button and repeats "
"one operation that has been reverted with <command>&no-i18n-cmd_undo;</"
"command>()."
msgstr ""
"<guibutton>Redo</guibutton> टूलबार बटन के अनुरूप है और एक ऑपरेशन को दोहराता है जिसे "
"<command>&no-i18n-cmd_undo;</command>() के साथ वापस किया गया है।"

#. Tag: link
#: index.docbook:3352 index.docbook:3368 index.docbook:3826
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_undo;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_undo;</command>()"

#. Tag: title
#: index.docbook:3358
#, no-c-format
msgid "&no-i18n-cmd_redo_all;"
msgstr "&no-i18n-cmd_redo_all;"

#. Tag: title
#: index.docbook:3360
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_redo_all;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_redo_all;</command>()"

#. Tag: para
#: index.docbook:3361
#, no-c-format
msgid ""
"Similar to <command>&no-i18n-cmd_redo;</command>(), but re-does as many "
"operations as possible."
msgstr ""
"<command>&no-i18n-cmd_redo;</command>() के समान, लेकिन यथासंभव अधिक से अधिक "
"ऑपरेशनों को पुनः करता है।"

#. Tag: title
#: index.docbook:3374
#, no-c-format
msgid "&no-i18n-cmd_reenable_dna;"
msgstr "&no-i18n-cmd_reenable_dna;"

#. Tag: title
#: index.docbook:3376
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_reenable_dna;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_reenable_dna;</command>()"

#. Tag: para
#: index.docbook:3377
#, no-c-format
msgid ""
"Some message boxes offer the possibility to prevent them from appearing "
"again (<quote>do not ask again</quote>). This command makes all of them "
"appear again."
msgstr ""
"कुछ संदेश बॉक्स उन्हें दोबारा दिखने से रोकने की संभावना प्रदान करते हैं (<quote>दोबारा न "
"पूछें</quote>)। यह कमांड उन सभी को दोबारा दिखाता है।"

#. Tag: title
#: index.docbook:3386
#, no-c-format
msgid "&no-i18n-cmd_reset_toolbars;"
msgstr "&no-i18n-cmd_reset_toolbars;"

#. Tag: title
#: index.docbook:3388
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_reset_toolbars;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_reset_toolbars;</"
"command>()"

#. Tag: para
#: index.docbook:3389
#, no-c-format
msgid ""
"Resets all toolbar settings, like location, icon size and text location back "
"to defaults."
msgstr ""
"सभी टूलबार सेटिंग्स, जैसे स्थान, आइकन आकार और पाठ स्थान को डिफ़ॉल्ट पर रीसेट करता है।"

#. Tag: title
#: index.docbook:3397
#, no-c-format
msgid "&no-i18n-cmd_revert;"
msgstr "&no-i18n-cmd_रिवर्ट;"

#. Tag: title
#: index.docbook:3399
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_revert;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_revert;</command>()"

#. Tag: para
#: index.docbook:3400
#, no-c-format
msgid ""
"Reverts the currently loaded file back to the last saved state, discarding "
"all changes that are not saved."
msgstr ""
"वर्तमान में लोड की गई फ़ाइल को अंतिम सहेजी गई स्थिति में वापस लाता है, तथा सहेजे नहीं गए "
"सभी परिवर्तनों को हटा देता है।"

#. Tag: title
#: index.docbook:3408
#, no-c-format
msgid "&no-i18n-cmd_rewind;"
msgstr "&no-i18n-cmd_रिवाइंड;"

#. Tag: title
#: index.docbook:3410
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_rewind;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_rewind;</command>()"

#. Tag: para
#: index.docbook:3411
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Rewind</guibutton> toolbar button. If the "
"playback is currently running, it skips backward by 1/10 of the visible "
"range. If the playback is not running, this does the same as the command "
"<command>&no-i18n-cmd_view_scroll_left;</command>()."
msgstr ""
"<guibutton>Rewind</guibutton> टूलबार बटन के अनुरूप है। यदि प्लेबैक वर्तमान में चल रहा "
"है, तो यह दृश्यमान सीमा के 1/10 भाग से पीछे की ओर जाता है। यदि प्लेबैक नहीं चल रहा है, "
"तो यह कमांड <command>&no-i18n-cmd_view_scroll_left;</command>() के समान ही "
"कार्य करता है।"

#. Tag: para
#: index.docbook:3420
#, no-c-format
msgid ""
"<link linkend=\"cmd_sect_view_scroll_left\"><command>&no-i18n-tag;&no-i18n-"
"cmd_view_scroll_left;</command>()</link>, <link linkend=\"cmd_sect_forward"
"\"><command>&no-i18n-tag;&no-i18n-cmd_forward;</command>()</link>"
msgstr ""
"<link linkend=\"cmd_sect_view_scroll_left\"><command>&amp;no-i18n-टैग;&amp;no-"
"i18n-cmd_view_scroll_left;</command> ()</link> ,<link linkend="
"\"cmd_sect_forward\"><command> &amp;no-i18n-टैग;&amp;no-i18n-cmd_forward;</"
"command> ()</link>"

#. Tag: title
#: index.docbook:3428
#, no-c-format
msgid "&no-i18n-tag;s"
msgstr "&no-i18n-टैग;एस"

#. Tag: title
#: index.docbook:3431
#, no-c-format
msgid "&no-i18n-cmd_save;"
msgstr "&no-i18n-cmd_save;"

#. Tag: title
#: index.docbook:3433
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_save;</command>()"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_save;</command>()"

#. Tag: para
#: index.docbook:3434
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Save</guibutton> toolbar button. Saves the "
"current file if it has modifications. If the file does not already have a "
"name (&eg; a file that has just been created and does not yet have a file "
"name), this command does the same as <command>&no-i18n-cmd_saveas;</"
"command>()."
msgstr ""
"<guibutton>सहेजें</guibutton> टूलबार बटन के अनुरूप। यदि फ़ाइल में संशोधन हैं तो वर्तमान "
"फ़ाइल को सहेजता है। यदि फ़ाइल का पहले से कोई नाम नहीं है (&eg; एक फ़ाइल जो अभी बनाई "
"गई है और जिसका अभी तक कोई फ़ाइल नाम नहीं है), तो यह कमांड <command>&no-i18n-"
"cmd_saveas;</command>() के समान ही कार्य करता है।"

#. Tag: link
#: index.docbook:3444
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_saveas;</command>()"
msgstr "<कमांड>&no-i18n-tag;&no-i18n-cmd_saveas;</कमांड>()"

#. Tag: title
#: index.docbook:3450
#, no-c-format
msgid "&no-i18n-cmd_saveas;"
msgstr "&no-i18n-cmd_saveas;"

#. Tag: title
#: index.docbook:3452
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_saveas;</"
"command>([<replaceable>filename</replaceable>])"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_saveas;</"
"command>([<replaceable>फ़ाइलनाम</replaceable>])"

#. Tag: para
#: index.docbook:3453
#, no-c-format
msgid ""
"Saves the currently opened file under a given file name. If no file name is "
"given as parameter, a dialog will be shown to select the directory and to "
"enter a file name."
msgstr ""
"वर्तमान में खोली गई फ़ाइल को दिए गए फ़ाइल नाम के अंतर्गत सहेजता है। यदि पैरामीटर के रूप में "
"कोई फ़ाइल नाम नहीं दिया गया है, तो निर्देशिका का चयन करने और फ़ाइल नाम दर्ज करने के "
"लिए एक संवाद दिखाया जाएगा।"

#. Tag: entry
#: index.docbook:3461
#, no-c-format
msgid "file name for saving (optional)"
msgstr "सहेजने के लिए फ़ाइल नाम (वैकल्पिक)"

#. Tag: title
#: index.docbook:3466
#, no-c-format
msgid "&no-i18n-cmd_saveselect;"
msgstr "&no-i18n-cmd_saveselect;"

#. Tag: title
#: index.docbook:3468
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_saveselect;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_saveselect;</command>()"

#. Tag: para
#: index.docbook:3469
#, no-c-format
msgid ""
"This command does the same as <command>&no-i18n-cmd_save;</command>(), but "
"saves only the currently selected range and the activated tracks instead of "
"the whole file."
msgstr ""
"यह कमांड <command>&no-i18n-cmd_save;</command>() के समान ही कार्य करता है, लेकिन "
"संपूर्ण फ़ाइल के बजाय केवल वर्तमान में चयनित श्रेणी और सक्रिय ट्रैक्स को ही सहेजता है।"

#. Tag: link
#: index.docbook:3477
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_save;</command>()"
msgstr "<कमांड>&no-i18n-tag;&no-i18n-cmd_save;</कमांड>()"

#. Tag: title
#: index.docbook:3483
#, no-c-format
msgid "&no-i18n-cmd_select_gui_type;"
msgstr "&no-i18n-cmd_select_gui_type;"

#. Tag: title
#: index.docbook:3485
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_select_gui_type;</"
"command>(<replaceable>mode</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_select_gui_type;</"
"command>(<replaceable>मोड</replaceable>)"

#. Tag: para
#: index.docbook:3486
#, no-c-format
msgid ""
"Select a &GUI; mode, which can be either SDI, MDI or Tab mode. Please be "
"aware that this change will immediately take effect!"
msgstr ""
"&GUI; मोड चुनें, जो SDI, MDI या टैब मोड हो सकता है। कृपया ध्यान रखें कि यह परिवर्तन "
"तुरंत प्रभावी होगा!"

#. Tag: entry
#: index.docbook:3494
#, no-c-format
msgid ""
"name of the mode, must be either <quote>SDI</quote>, <quote>MDI</quote> or "
"<quote>TAB</quote>."
msgstr ""
"मोड का नाम या तो <quote>SDI</quote>, <quote>MDI</quote> या <quote>TAB</"
"quote> होना चाहिए।"

#. Tag: title
#: index.docbook:3502
#, no-c-format
msgid "&no-i18n-cmd_select_track_all;"
msgstr "&no-i18n-cmd_select_track_all;"

#. Tag: title
#: index.docbook:3504 index.docbook:3521
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_select_track_all;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_select_track_all;</"
"command>()"

#. Tag: para
#: index.docbook:3505
#, no-c-format
msgid ""
"Mark all tracks <quote>enabled</quote>. This is the same as calling the "
"command <command>&no-i18n-tag;&no-i18n-cmd_select_track_on;</command>() for "
"all existing tracks."
msgstr ""
"सभी ट्रैक को <quote>सक्षम</quote> चिह्नित करें। यह सभी मौजूदा ट्रैक के लिए "
"<command>&no-i18n-tag;&no-i18n-cmd_select_track_on;</command>() कमांड को कॉल "
"करने के समान है।"

#. Tag: link
#: index.docbook:3513
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_select_track_on;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_select_track_on;</command>()"

#. Tag: title
#: index.docbook:3519
#, no-c-format
msgid "&no-i18n-cmd_select_track_invert;"
msgstr "&no-i18n-cmd_select_track_invert;"

#. Tag: para
#: index.docbook:3522
#, no-c-format
msgid ""
"Invert the <quote>enabled</quote> state of all tracks. This is the same as "
"calling the command <command>&no-i18n-cmd_select_track_toggle;</command>() "
"for all existing tracks."
msgstr ""
"सभी ट्रैक्स की <quote>enabled</quote> स्थिति को उलट दें। यह सभी मौजूदा ट्रैक्स के लिए "
"<command>&no-i18n-cmd_select_track_toggle;</command>() कमांड को कॉल करने के "
"समान है।"

#. Tag: link
#: index.docbook:3531
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_select_track_toggle;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_select_track_toggle;</command>()"

#. Tag: title
#: index.docbook:3537
#, no-c-format
msgid "&no-i18n-cmd_select_track_none;"
msgstr "&no-i18n-cmd_select_track_none;"

#. Tag: title
#: index.docbook:3539
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_select_track_none;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_select_track_none;</"
"command>()"

#. Tag: para
#: index.docbook:3540
#, no-c-format
msgid ""
"Mark all tracks <quote>disabled</quote>. This is the same as calling the "
"command <command>&no-i18n-cmd_select_track_off;</command>() for all existing "
"tracks."
msgstr ""
"सभी ट्रैक को <quote>अक्षम</quote> चिह्नित करें। यह सभी मौजूदा ट्रैक के लिए "
"<command>&no-i18n-cmd_select_track_off;</command>() कमांड को कॉल करने के समान है।"

#. Tag: link
#: index.docbook:3548
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_select_track_off;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_select_track_off;</command>()"

#. Tag: title
#: index.docbook:3554
#, no-c-format
msgid "&no-i18n-cmd_select_track_off;"
msgstr "&no-i18n-cmd_select_track_off;"

#. Tag: title
#: index.docbook:3556
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_select_track_off;</"
"command>(<replaceable>index</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_select_track_off;</"
"command>(<replaceable>index</replaceable>)"

#. Tag: para
#: index.docbook:3557
#, no-c-format
msgid ""
"Disables a single track, so that it does not get affected by most operations."
msgstr "एकल ट्रैक को अक्षम कर देता है, ताकि वह अधिकांश परिचालनों से प्रभावित न हो।"

#. Tag: entry
#: index.docbook:3564 index.docbook:3578 index.docbook:3593
#, no-c-format
msgid "index of the track, starting with zero"
msgstr "ट्रैक का सूचकांक, शून्य से शुरू"

#. Tag: title
#: index.docbook:3569
#, no-c-format
msgid "&no-i18n-cmd_select_track_on;"
msgstr "&no-i18n-cmd_select_track_on;"

#. Tag: title
#: index.docbook:3571
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_select_track_on;</"
"command>(<replaceable>index</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_select_track_on;</"
"command>(<replaceable>index</replaceable>)"

#. Tag: para
#: index.docbook:3572
#, no-c-format
msgid "Enables a single track, so that it gets affected by all operations."
msgstr "एकल ट्रैक को सक्षम करता है, ताकि यह सभी कार्यों से प्रभावित हो।"

#. Tag: title
#: index.docbook:3583
#, no-c-format
msgid "&no-i18n-cmd_select_track_toggle;"
msgstr "&no-i18n-cmd_select_track_toggle;"

#. Tag: title
#: index.docbook:3585
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_select_track_toggle;</"
"command>(<replaceable>index</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_select_track_toggle;</"
"command>(<replaceable>index</replaceable>)"

#. Tag: para
#: index.docbook:3586
#, no-c-format
msgid ""
"Enables a track if it is currently disabled, or disables it if it is "
"currently enabled."
msgstr ""
"यदि कोई ट्रैक वर्तमान में अक्षम है तो उसे सक्षम करता है, या यदि वह वर्तमान में सक्षम है तो "
"उसे अक्षम करता है।"

#. Tag: title
#: index.docbook:3598
#, no-c-format
msgid "&no-i18n-cmd_selectall;"
msgstr "&no-i18n-cmd_selectall;"

#. Tag: title
#: index.docbook:3600
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectall;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectall;</command>()"

#. Tag: para
#: index.docbook:3601
#, no-c-format
msgid ""
"Selects the range of the whole signal, from the first to the last sample."
msgstr "प्रथम से अंतिम नमूने तक सम्पूर्ण सिग्नल की रेंज का चयन करता है।"

#. Tag: title
#: index.docbook:3609
#, no-c-format
msgid "&no-i18n-cmd_selectnext;"
msgstr "&no-i18n-cmd_selectnext;"

#. Tag: title
#: index.docbook:3611
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectnext;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectnext;</command>()"

#. Tag: para
#: index.docbook:3612
#, no-c-format
msgid ""
"Selects a range of samples that starts right after the current selection, "
"using the same length as the current selection. The selection is "
"automatically clipped to the end of the signal. For example: if you have "
"selected samples 1000 ... 1019, then the result will be a selection from "
"sample 1020 ... 1039."
msgstr ""
"वर्तमान चयन के ठीक बाद शुरू होने वाले नमूनों की एक श्रृंखला का चयन करता है, वर्तमान चयन के "
"समान लंबाई का उपयोग करते हुए। चयन स्वचालित रूप से सिग्नल के अंत में क्लिप हो जाता है। "
"उदाहरण के लिए: यदि आपने नमूने 1000 ... 1019 का चयन किया है, तो परिणाम नमूना "
"1020 ... 1039 से चयन होगा।"

#. Tag: link
#: index.docbook:3622
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_selectprev;</command>()"
msgstr "<कमांड>&no-i18n-tag;&no-i18n-cmd_selectprev;</कमांड>()"

#. Tag: title
#: index.docbook:3628
#, no-c-format
msgid "&no-i18n-cmd_selectnextlabels;"
msgstr "&no-i18n-cmd_selectnextlabels;"

#. Tag: title
#: index.docbook:3630
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectnextlabels;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectnextlabels;</"
"command>()"

#. Tag: para
#: index.docbook:3631
#, no-c-format
msgid ""
"Selects a range of samples between the next two labels after the current "
"selection. If nothing is selected, it selects from the start of the signal "
"up to the first label. Otherwise the left border of the new selection will "
"be the position of first label after the selection (or the last label if "
"there are no more labels right from the selection), and the right border of "
"the new selection will be the first label after the left border of the new "
"selection (or the end of the signal if there is none). This command returns "
"an error when there are no labels at all."
msgstr ""
"वर्तमान चयन के बाद अगले दो लेबल के बीच नमूनों की एक श्रृंखला का चयन करता है। यदि कुछ भी "
"चयनित नहीं है, तो यह सिग्नल की शुरुआत से लेकर पहले लेबल तक का चयन करता है। अन्यथा नए "
"चयन की बाईं सीमा चयन के बाद पहले लेबल की स्थिति होगी (या अंतिम लेबल यदि चयन से दाईं "
"ओर कोई और लेबल नहीं है), और नए चयन की दाईं सीमा नए चयन की बाईं सीमा के बाद पहला "
"लेबल होगी (या सिग्नल का अंत यदि कोई नहीं है)। यह कमांड तब त्रुटि लौटाता है जब कोई लेबल "
"नहीं होता है।"

#. Tag: link
#: index.docbook:3645
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_selectprevlabels;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_selectprevlabels;</command>()"

#. Tag: title
#: index.docbook:3651
#, no-c-format
msgid "&no-i18n-cmd_selectnone;"
msgstr "&no-i18n-cmd_selectnone;"

#. Tag: title
#: index.docbook:3653
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectnone;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectnone;</command>()"

#. Tag: para
#: index.docbook:3654
#, no-c-format
msgid "Resets the selection to zero length."
msgstr "चयन को शून्य लंबाई पर रीसेट करता है."

#. Tag: title
#: index.docbook:3661
#, no-c-format
msgid "&no-i18n-cmd_selectprev;"
msgstr "&no-i18n-cmd_selectprev;"

#. Tag: title
#: index.docbook:3663
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectprev;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectprev;</command>()"

#. Tag: para
#: index.docbook:3664
#, no-c-format
msgid ""
"Selects a range of samples that starts left from the current selection, "
"using the same length as the current selection. The selection is "
"automatically clipped to the start of the signal. For example: if you have "
"selected samples 1000 ... 1019, then the result will be a selection from "
"sample 980 ... 999."
msgstr ""
"वर्तमान चयन के बाईं ओर से शुरू होने वाले नमूनों की एक श्रृंखला का चयन करता है, वर्तमान चयन "
"के समान लंबाई का उपयोग करते हुए। चयन स्वचालित रूप से सिग्नल की शुरुआत में क्लिप हो जाता "
"है। उदाहरण के लिए: यदि आपने नमूने 1000 ... 1019 का चयन किया है, तो परिणाम नमूना "
"980 ... 999 से चयन होगा।"

#. Tag: link
#: index.docbook:3674
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_selectnext;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_selectnext;</command>()"

#. Tag: title
#: index.docbook:3680
#, no-c-format
msgid "&no-i18n-cmd_selectprevlabels;"
msgstr "&no-i18n-cmd_selectprevlabels;"

#. Tag: title
#: index.docbook:3682
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectprevlabels;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectprevlabels;</"
"command>()"

#. Tag: para
#: index.docbook:3683
#, no-c-format
msgid ""
"Selects a range of samples between the previous two labels before the "
"current selection. If nothing is selected, it selects from the start of the "
"signal up to the first label. Otherwise the right border of the new "
"selection will be the position of first label before the selection (or the "
"first label if there are no more labels left from the selection), and the "
"left border of the new selection will be the first label before the right "
"border of the new selection (or the start of the signal if there is none). "
"This command returns an error when there are no labels at all."
msgstr ""
"वर्तमान चयन से पहले पिछले दो लेबल के बीच नमूनों की एक श्रृंखला का चयन करता है। यदि कुछ भी "
"चयनित नहीं है, तो यह सिग्नल की शुरुआत से लेकर पहले लेबल तक का चयन करता है। अन्यथा नए "
"चयन की दाईं सीमा चयन से पहले पहले लेबल की स्थिति होगी (या पहला लेबल यदि चयन से कोई "
"और लेबल नहीं बचा है), और नए चयन की बाईं सीमा नए चयन की दाईं सीमा से पहले पहला लेबल "
"होगी (या सिग्नल की शुरुआत यदि कोई नहीं है)। यह कमांड तब त्रुटि लौटाता है जब कोई लेबल "
"नहीं होता है।"

#. Tag: link
#: index.docbook:3697
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_selectnextlabels;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_selectnextlabels;</command>()"

#. Tag: title
#: index.docbook:3703
#, no-c-format
msgid "&no-i18n-cmd_selecttoleft;"
msgstr "&no-i18n-cmd_selecttoleft;"

#. Tag: title
#: index.docbook:3705
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selecttoleft;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selecttoleft;</command>()"

#. Tag: para
#: index.docbook:3706
#, no-c-format
msgid ""
"Sets the start of the selection to the start of the signal, the end of the "
"current selection stays unchanged."
msgstr ""
"चयन की शुरुआत को सिग्नल की शुरुआत पर सेट करता है, वर्तमान चयन का अंत अपरिवर्तित रहता है।"

#. Tag: link
#: index.docbook:3713
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_selecttoright;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_selecttoright;</command>()"

#. Tag: title
#: index.docbook:3719
#, no-c-format
msgid "&no-i18n-cmd_selecttoright;"
msgstr "&no-i18n-cmd_selecttoright;"

#. Tag: title
#: index.docbook:3721
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selecttoright;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selecttoright;</"
"command>()"

#. Tag: para
#: index.docbook:3722
#, no-c-format
msgid ""
"Sets the end of the selection to the end of the signal, the start of the "
"current selection stays unchanged."
msgstr ""
"चयन के अंत को सिग्नल के अंत पर सेट करता है, वर्तमान चयन की शुरुआत अपरिवर्तित रहती है।"

#. Tag: link
#: index.docbook:3729
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_selecttoleft;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_selecttoleft;</command>()"

#. Tag: title
#: index.docbook:3735
#, no-c-format
msgid "&no-i18n-cmd_selectvisible;"
msgstr "&no-i18n-cmd_selectvisible;"

#. Tag: title
#: index.docbook:3737
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectvisible;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectvisible;</"
"command>()"

#. Tag: para
#: index.docbook:3738
#, no-c-format
msgid "Selects the range of samples that is visible in the current window."
msgstr "वर्तमान विंडो में दिखाई देने वाले नमूनों की श्रेणी का चयन करता है।"

#. Tag: title
#: index.docbook:3746
#, no-c-format
msgid "&no-i18n-cmd_start;"
msgstr "&no-i18n-cmd_start;"

#. Tag: title
#: index.docbook:3748
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_start;</command>()"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_start;</command>()"

#. Tag: para
#: index.docbook:3749
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Start</guibutton> toolbar button and lets the "
"playback start from the beginning of the selection or continue if it is "
"currently paused."
msgstr ""
"<guibutton>प्रारंभ</guibutton> टूलबार बटन के अनुरूप है और प्लेबैक को चयन के आरंभ से आरंभ "
"करने देता है या यदि यह वर्तमान में रुका हुआ है तो जारी रखने देता है।"

#. Tag: link
#: index.docbook:3757
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_stop;</command>()"
msgstr "<कमांड>&no-i18n-tag;&no-i18n-cmd_stop;</कमांड>()"

#. Tag: title
#: index.docbook:3763
#, no-c-format
msgid "&no-i18n-cmd_stop;"
msgstr "&no-i18n-cmd_stop;"

#. Tag: title
#: index.docbook:3765
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_stop;</command>()"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_stop;</command>()"

#. Tag: para
#: index.docbook:3766
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Stop</guibutton> toolbar button and lets the "
"playback stop if it is currently running."
msgstr ""
"यह <guibutton>Stop</guibutton> टूलबार बटन के अनुरूप है और यदि प्लेबैक वर्तमान में चल "
"रहा है तो उसे रोकने देता है।"

#. Tag: link
#: index.docbook:3773
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_start;</command>()"
msgstr "<कमांड>&no-i18n-tag;&no-i18n-cmd_start;</कमांड>()"

#. Tag: title
#: index.docbook:3779
#, no-c-format
msgid "&no-i18n-cmd_sync;"
msgstr "&no-i18n-cmd_sync;"

#. Tag: title
#: index.docbook:3781
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_sync;</command>()"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_sync;</command>()"

#. Tag: para
#: index.docbook:3782
#, no-c-format
msgid ""
"Waits until all commands which have been started asynchronously have "
"finished. If nothing is currently queued for delayed execution this command "
"has no effect."
msgstr ""
"तब तक प्रतीक्षा करता है जब तक कि एसिंक्रोनस रूप से शुरू किए गए सभी कमांड समाप्त नहीं हो "
"जाते। यदि विलंबित निष्पादन के लिए वर्तमान में कुछ भी कतार में नहीं है, तो इस कमांड का कोई "
"प्रभाव नहीं पड़ता है।"

#. Tag: link
#: index.docbook:3790
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_delayed;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_delayed;</command>()"

#. Tag: title
#: index.docbook:3797
