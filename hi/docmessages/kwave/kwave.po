msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_close;</command>()"

#. Tag: para
#: index.docbook:2476
#, no-c-format
msgid ""
"Closes the current file. If the &GUI; is configured to MDI or Tab mode, this "
"also closes the corresponding sub-window."
msgstr ""
"वर्तमान फ़ाइल को बंद करता है। यदि &GUI; को MDI या टैब मोड में कॉन्फ़िगर किया गया है, "
"तो यह संबंधित उप-विंडो को भी बंद कर देता है।"

#. Tag: para
#: index.docbook:2482
#, no-c-format
msgid ""
"<link linkend=\"cmd_sect_open\"><command>&no-i18n-tag;&no-i18n-cmd_open;</"
"command>(<replaceable>filename</replaceable>)</link>, <link linkend="
"\"cmd_sect_quit\"><command>&no-i18n-tag;&no-i18n-cmd_quit;</command>()</link>"
msgstr ""
"<link linkend=\"cmd_sect_open\"><command>&amp;no-i18n-टैग;&amp;no-i18n-"
"cmd_open;</command> (<replaceable> फ़ाइल नाम</replaceable> )</link> ,<link "
"linkend=\"cmd_sect_quit\"><command> &amp;no-i18n-टैग;&amp;no-i18n-cmd_quit;</"
"command> ()</link>"

#. Tag: title
#: index.docbook:2490
#, no-c-format
msgid "&no-i18n-cmd_continue;"
msgstr "&no-i18n-cmd_continue;"

#. Tag: title
#: index.docbook:2492 index.docbook:3204
#, no-c-format
