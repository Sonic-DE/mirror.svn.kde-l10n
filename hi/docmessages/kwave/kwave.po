#. Tag: title
#: index.docbook:3800
#, no-c-format
msgid "&no-i18n-cmd_undo;"
msgstr "&no-i18n-cmd_undo;"

#. Tag: title
#: index.docbook:3802
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_undo;</command>()"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_undo;</command>()"

#. Tag: para
#: index.docbook:3803
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Undo</guibutton> toolbar button and reverts "
"the last operation."
msgstr ""
"<guibutton>पूर्ववत करें</guibutton> टूलबार बटन के अनुरूप है और अंतिम ऑपरेशन को पूर्ववत "
"करता है।"

#. Tag: link
#: index.docbook:3810
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_redo;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_redo;</command>()"

#. Tag: title
#: index.docbook:3816
#, no-c-format
msgid "&no-i18n-cmd_undo_all;"
msgstr "&no-i18n-cmd_undo_all;"

#. Tag: title
#: index.docbook:3818
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_undo_all;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_undo_all;</command>()"

#. Tag: para
#: index.docbook:3819
#, no-c-format
msgid ""
"Similar to <command>&no-i18n-tag;&no-i18n-cmd_undo;</command>(), but reverts "
"as many operations as possible."
msgstr ""
"<command>&no-i18n-tag;&no-i18n-cmd_undo;</command>() के समान, लेकिन यथासंभव "
"अधिक से अधिक ऑपरेशनों को पूर्ववत करता है।"

#. Tag: title
#: index.docbook:3832
#, no-c-format
msgid "&no-i18n-tag;v"
msgstr "&no-i18n-tag;v"

#. Tag: title
#: index.docbook:3835
#, no-c-format
msgid "&no-i18n-cmd_view_scroll_end;"
msgstr "&no-i18n-cmd_view_scroll_end;"

#. Tag: title
#: index.docbook:3837
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_end;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_end;</"
"command>()"

#. Tag: para
#: index.docbook:3838
#, no-c-format
msgid "Scrolls the current view to the <emphasis>end</emphasis> of the signal."
msgstr "वर्तमान दृश्य को सिग्नल के <emphasis>अंत</emphasis> तक स्क्रॉल करता है।"

#. Tag: link
#: index.docbook:3842
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_start;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_start;</command>()"

#. Tag: title
#: index.docbook:3848
#, no-c-format
msgid "&no-i18n-cmd_view_scroll_left;"
msgstr "&no-i18n-cmd_view_scroll_left;"

#. Tag: title
#: index.docbook:3850
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_left;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_left;</"
"command>()"

#. Tag: para
#: index.docbook:3851
#, no-c-format
msgid ""
"Scrolls the current view by 1/10 of the currently visible range towards the "
"start of the signal. If the start of the signal is reached the visible area "
"starts at offset zero."
msgstr ""
"वर्तमान दृश्य को वर्तमान दृश्यमान सीमा के 1/10 भाग से सिग्नल की शुरुआत की ओर स्क्रॉल करता "
"है। यदि सिग्नल की शुरुआत तक पहुँच जाता है तो दृश्यमान क्षेत्र ऑफ़सेट शून्य से शुरू होता है।"

#. Tag: link
#: index.docbook:3859
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_right;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_right;</command>()"

#. Tag: title
#: index.docbook:3865
#, no-c-format
msgid "&no-i18n-cmd_view_scroll_next;"
msgstr "&no-i18n-cmd_view_scroll_next;"

#. Tag: title
#: index.docbook:3867
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_next;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_next;</"
"command>()"

#. Tag: para
#: index.docbook:3868
#, no-c-format
msgid ""
"Scrolls the current view towards the end of the signal by the currently "
"visible range."
msgstr "वर्तमान दृश्य को वर्तमान दृश्यमान सीमा तक सिग्नल के अंत की ओर स्क्रॉल करता है।"

#. Tag: link
#: index.docbook:3875
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_prev;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_prev;</command>()"

#. Tag: title
#: index.docbook:3881
#, no-c-format
msgid "&no-i18n-cmd_view_scroll_next_label;"
msgstr "&no-i18n-cmd_view_scroll_next_label;"

#. Tag: title
#: index.docbook:3883
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_next_label;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_next_label;</"
"command>()"

#. Tag: para
#: index.docbook:3884
#, no-c-format
msgid ""
"Scrolls right and tries to show the next label centered in the view. If "
"there was no label right from the current position, it will scroll to the "
"end of the signal."
msgstr ""
"दाईं ओर स्क्रॉल करें और दृश्य में केंद्र में अगला लेबल दिखाने का प्रयास करें। यदि वर्तमान स्थिति "
"से कोई लेबल सही नहीं था, तो यह सिग्नल के अंत तक स्क्रॉल करेगा।"

#. Tag: link
#: index.docbook:3892
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_prev_label;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_prev_label;</command>()"

#. Tag: title
#: index.docbook:3898
#, no-c-format
msgid "&no-i18n-cmd_view_scroll_prev;"
msgstr "&no-i18n-cmd_view_scroll_prev;"

#. Tag: title
#: index.docbook:3900
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_prev;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_prev;</"
"command>()"

#. Tag: para
#: index.docbook:3901
#, no-c-format
msgid ""
"Scrolls the current view towards the start of the signal by the currently "
"visible range."
msgstr "वर्तमान दृश्य को वर्तमान दृश्यमान सीमा तक सिग्नल के आरंभ की ओर स्क्रॉल करता है।"

#. Tag: link
#: index.docbook:3908
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_next;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_next;</command>()"

#. Tag: title
#: index.docbook:3914
#, no-c-format
msgid "&no-i18n-cmd_view_scroll_prev_label;"
msgstr "&no-i18n-cmd_view_scroll_prev_label;"

#. Tag: title
#: index.docbook:3916
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_prev_label;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_prev_label;</"
"command>()"

#. Tag: para
#: index.docbook:3917
#, no-c-format
msgid ""
"Scrolls left and tries to show the previous label centered in the view. If "
"there was no label left from the current position, it will scroll to the "
"start of the signal."
msgstr ""
"बाईं ओर स्क्रॉल करता है और दृश्य में केंद्र में पिछले लेबल को दिखाने का प्रयास करता है। यदि "
"वर्तमान स्थिति से कोई लेबल नहीं बचा है, तो यह सिग्नल की शुरुआत तक स्क्रॉल करेगा।"

#. Tag: link
#: index.docbook:3925
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_next_label;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_next_label;</command>()"

#. Tag: title
#: index.docbook:3931
#, no-c-format
msgid "&no-i18n-cmd_view_scroll_right;"
msgstr "&no-i18n-cmd_view_scroll_right;"

#. Tag: title
#: index.docbook:3933
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_right;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_right;</"
"command>()"

#. Tag: para
#: index.docbook:3934
#, no-c-format
msgid ""
"Scrolls the current view by 1/10 of the currently visible range towards the "
"end of the signal. If the end of the signal is reached the visible area ends "
"at the end of the signal."
msgstr ""
"वर्तमान दृश्य को वर्तमान में दृश्यमान सीमा के 1/10 भाग तक सिग्नल के अंत की ओर स्क्रॉल करता "
"है। यदि सिग्नल के अंत तक पहुँच जाता है तो दृश्यमान क्षेत्र सिग्नल के अंत में समाप्त हो जाता है।"

#. Tag: link
#: index.docbook:3942
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_left;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_left;</command>()"

#. Tag: title
#: index.docbook:3948
#, no-c-format
msgid "&no-i18n-cmd_view_scroll_start;"
msgstr "&no-i18n-cmd_view_scroll_start;"

#. Tag: title
#: index.docbook:3950
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_start;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_start;</"
"command>()"

#. Tag: para
#: index.docbook:3951
#, no-c-format
msgid "Scrolls the current view to the start of the signal."
msgstr "वर्तमान दृश्य को सिग्नल के आरंभ तक स्क्रॉल करता है."

#. Tag: link
#: index.docbook:3955
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_end;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_end;</command>()"

#. Tag: title
#: index.docbook:3961
#, no-c-format
msgid "&no-i18n-cmd_view_zoom_all;"
msgstr "&no-i18n-cmd_view_zoom_all;"

#. Tag: title
#: index.docbook:3963
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_zoom_all;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_zoom_all;</"
"command>()"

#. Tag: para
#: index.docbook:3964
#, no-c-format
msgid ""
"Adjusts the zoom factor so that the complete signal is visible in the "
"current view."
msgstr "ज़ूम कारक को समायोजित करता है ताकि वर्तमान दृश्य में संपूर्ण सिग्नल दिखाई दे।"

#. Tag: title
#: index.docbook:3972
#, no-c-format
msgid "&no-i18n-cmd_view_zoom_in;"
msgstr "&no-i18n-cmd_view_zoom_in;"

#. Tag: title
#: index.docbook:3974
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_view_zoom_in;</"
"command>([<replaceable>position</replaceable>])"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_view_zoom_in;</"
"command>([<replaceable>स्थिति</replaceable>])"

#. Tag: para
#: index.docbook:3975
#, no-c-format
msgid ""
"Reduces the zoom factor (in samples per pixel) by 30%, so that more details "
"get visible. If a <replaceable>position</replaceable> is given, it tries to "
"show that position centered in the current view, otherwise the center of the "
"view before the zoom change is used for centering. The minimum zoom factor "
"is limited to a minimum of five samples per width of the view."
msgstr ""
"ज़ूम फ़ैक्टर (प्रति पिक्सेल नमूनों में) को 30% तक कम करता है, ताकि अधिक विवरण दिखाई दे सकें। "
"यदि कोई <प्रतिस्थापन योग्य>स्थिति</प्रतिस्थापन योग्य> दी गई है, तो यह उस स्थिति को "
"वर्तमान दृश्य में केंद्रित दिखाने का प्रयास करता है, अन्यथा ज़ूम परिवर्तन से पहले दृश्य के केंद्र "
"का उपयोग केंद्रीकरण के लिए किया जाता है। न्यूनतम ज़ूम फ़ैक्टर दृश्य की चौड़ाई के अनुसार न्यूनतम "
"पाँच नमूनों तक सीमित है।"

#. Tag: entry
#: index.docbook:3987 index.docbook:4024
#, no-c-format
msgid "<parameter>position</parameter>:"
msgstr "<पैरामीटर>स्थिति</पैरामीटर>:"

#. Tag: entry
#: index.docbook:3988
#, no-c-format
msgid "a zero based position in samples to center the view (optional)"
msgstr "दृश्य को केन्द्रित करने के लिए नमूनों में शून्य आधारित स्थिति (वैकल्पिक)"

#. Tag: link
#: index.docbook:3992
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_view_zoom_out;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_view_zoom_out;</command>()"

#. Tag: title
#: index.docbook:3998
#, no-c-format
msgid "&no-i18n-cmd_view_zoom_normal;"
msgstr "&no-i18n-cmd_view_zoom_normal;"

#. Tag: title
#: index.docbook:4000
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_zoom_normal;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_zoom_normal;</"
"command>()"

#. Tag: para
#: index.docbook:4001
#, no-c-format
msgid ""
"Sets the zoom factor to one pixel per sample (factor 1.0) and tries to keep "
"the previous center of the view."
msgstr ""
"ज़ूम कारक को प्रति नमूना एक पिक्सेल (कारक 1.0) पर सेट करता है और दृश्य के पिछले केंद्र को "
"बनाए रखने का प्रयास करता है।"

#. Tag: title
#: index.docbook:4009
#, no-c-format
msgid "&no-i18n-cmd_view_zoom_out;"
msgstr "&no-i18n-cmd_view_zoom_out;"

#. Tag: title
#: index.docbook:4011
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_view_zoom_out;"
"([<replaceable>position</replaceable>])</command>"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_view_zoom_out;([<replaceable>स्थिति</"
"replaceable>])</command>"

#. Tag: para
#: index.docbook:4012
#, no-c-format
msgid ""
"Increases the zoom factor (in samples per pixel) by 30%, so that less "
"details get visible. If a <replaceable>position</replaceable> is given, it "
"tries to show that position centered in the current view, otherwise the "
"center of the view before the zoom change is used for centering. The maximum "
"zoom factor is limited to the number of samples of the complete signal and "
"the width of the view."
msgstr ""
"ज़ूम फैक्टर (प्रति पिक्सेल नमूनों में) को 30% तक बढ़ाता है, ताकि कम विवरण दिखाई दें। यदि "
"कोई <प्रतिस्थापन योग्य>स्थिति</प्रतिस्थापन योग्य> दी गई है, तो यह उस स्थिति को वर्तमान "
"दृश्य में केंद्रित दिखाने का प्रयास करता है, अन्यथा ज़ूम परिवर्तन से पहले दृश्य के केंद्र का उपयोग "
"केंद्रीकरण के लिए किया जाता है। अधिकतम ज़ूम फैक्टर पूरे सिग्नल के नमूनों की संख्या और दृश्य की "
"चौड़ाई तक सीमित है।"

#. Tag: entry
#: index.docbook:4025
#, no-c-format
msgid "a zero based position is samples to center the view (optional)"
msgstr "शून्य आधारित स्थिति दृश्य को केन्द्रित करने के लिए नमूने हैं (वैकल्पिक)"

#. Tag: link
#: index.docbook:4029
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_view_zoom_in;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_view_zoom_in;</command>()"

#. Tag: title
#: index.docbook:4035
#, no-c-format
msgid "&no-i18n-cmd_view_zoom_selection;"
msgstr "&no-i18n-cmd_view_zoom_selection;"

#. Tag: title
#: index.docbook:4037
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_zoom_selection;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_zoom_selection;</"
"command>()"

#. Tag: para
#: index.docbook:4038
#, no-c-format
msgid ""
"Adjusts the view (zoom factor and start of visible area) so that it matches "
"the current selection. This command does nothing if the selection is empty."
msgstr ""
"दृश्य (ज़ूम फ़ैक्टर और दृश्यमान क्षेत्र की शुरुआत) को समायोजित करता है ताकि यह वर्तमान चयन से "
"मेल खाए। यदि चयन खाली है तो यह कमांड कुछ नहीं करता है।"

#. Tag: title
#: index.docbook:4047
#, no-c-format
msgid "&no-i18n-tag;w"
msgstr "&no-i18n-tag;w"

#. Tag: title
#: index.docbook:4050
#, no-c-format
msgid "&no-i18n-cmd_window_activate;"
msgstr "&no-i18n-cmd_window_activate;"

#. Tag: title
#: index.docbook:4052
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_activate;</"
"command>(<replaceable>title</replaceable>])"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_activate;</"
"command>(<replaceable>शीर्षक</replaceable>])"

#. Tag: para
#: index.docbook:4053
#, no-c-format
msgid ""
"Activates a sub-window, identified by its window <replaceable>title</"
"replaceable>. If the sub-window is minimized it will be restored. Only "
"available if in MDI and Tab mode. This command is internally used by the "
"<guisubmenu>Window</guisubmenu> menu."
msgstr ""
"एक उप-विंडो को सक्रिय करता है, जिसे इसकी विंडो <प्रतिस्थापनीय>शीर्षक</प्रतिस्थापनीय> "
"द्वारा पहचाना जाता है। यदि उप-विंडो को छोटा किया जाता है तो उसे पुनर्स्थापित किया "
"जाएगा। केवल MDI और टैब मोड में उपलब्ध है। यह कमांड आंतरिक रूप से <guisubmenu>विंडो</"
"guisubmenu> मेनू द्वारा उपयोग किया जाता है।"

#. Tag: entry
#: index.docbook:4061
#, no-c-format
msgid "<parameter>title</parameter>:"
msgstr "<पैरामीटर>शीर्षक</पैरामीटर>:"

#. Tag: entry
#: index.docbook:4062
#, no-c-format
msgid "the title of the sub-window that should be activated"
msgstr "उस उप-विंडो का शीर्षक जिसे सक्रिय किया जाना चाहिए"

#. Tag: title
#: index.docbook:4067
#, no-c-format
msgid "&no-i18n-cmd_window_cascade;"
msgstr "&no-i18n-cmd_window_cascade;"

#. Tag: title
#: index.docbook:4069
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_cascade;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_cascade;</"
"command>()"

#. Tag: para
#: index.docbook:4070
#, no-c-format
msgid ""
"Cascades all sub-windows when in MDI mode. All sub-windows that are "
"currently minimized stay minimized, they will not be restored."
msgstr ""
"MDI मोड में होने पर सभी उप-विंडो को कैस्केड करता है। सभी उप-विंडो जो वर्तमान में न्यूनतम "
"हैं, न्यूनतम ही रहेंगी, उन्हें पुनर्स्थापित नहीं किया जाएगा।"

#. Tag: title
#: index.docbook:4078
#, no-c-format
msgid "&no-i18n-cmd_window_click;"
msgstr "&no-i18n-cmd_window_click;"

#. Tag: title
#: index.docbook:4080
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_click;</"
"command>( <replaceable>class</replaceable>, <replaceable>x</replaceable>, "
"<replaceable>y</replaceable> )"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_click;</"
"command>( <replaceable>class</replaceable>, <replaceable>x</replaceable>, "
"<replaceable>y</replaceable> )"

#. Tag: para
#: index.docbook:4085
#, no-c-format
msgid ""
"Sends a mouse click event to window, identified by its <replaceable>class</"
"replaceable> name. The event will only be sent to the first window that has "
"the given class name, therefore you should make sure that you have only one "
"instance of the given window when this command gets executed."
msgstr ""
"विंडो पर माउस क्लिक इवेंट भेजता है, जिसे उसके <replaceable>क्लास</replaceable> नाम से "
"पहचाना जाता है। इवेंट केवल उस पहली विंडो पर भेजा जाएगा जिसका क्लास नाम दिया गया है, "
"इसलिए आपको यह सुनिश्चित करना चाहिए कि जब यह कमांड निष्पादित हो तो आपके पास दी गई "
"विंडो का केवल एक इंस्टेंस हो।"

#. Tag: entry
#: index.docbook:4095 index.docbook:4119 index.docbook:4153 index.docbook:4204
#: index.docbook:4232 index.docbook:4257
#, no-c-format
msgid "<parameter>class</parameter>:"
msgstr "<पैरामीटर>क्लास</पैरामीटर>:"

#. Tag: entry
#: index.docbook:4096 index.docbook:4120 index.docbook:4154 index.docbook:4205
#: index.docbook:4233 index.docbook:4258
#, no-c-format
msgid "name of the window class"
msgstr "विंडो क्लास का नाम"

#. Tag: entry
#: index.docbook:4097 index.docbook:4155
#, no-c-format
msgid "<parameter>x</parameter>:"
msgstr "<पैरामीटर>x</पैरामीटर>:"

#. Tag: entry
#: index.docbook:4098 index.docbook:4156
#, no-c-format
msgid "x position, relative to the left border of the window (in pixels)"
msgstr "x स्थिति, विंडो की बाईं सीमा के सापेक्ष (पिक्सेल में)"

#. Tag: entry
#: index.docbook:4099 index.docbook:4157
#, no-c-format
msgid "<parameter>y</parameter>:"
msgstr "<पैरामीटर>y</पैरामीटर>:"

#. Tag: entry
#: index.docbook:4100 index.docbook:4158
#, no-c-format
msgid "y position, relative to the top border of the window (in pixels)"
msgstr "y स्थिति, विंडो की ऊपरी सीमा के सापेक्ष (पिक्सेल में)"

#. Tag: title
#: index.docbook:4105
#, no-c-format
msgid "&no-i18n-cmd_window_close;"
msgstr "&no-i18n-cmd_window_close;"

#. Tag: title
#: index.docbook:4107
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_close;</"
"command>( <replaceable>class</replaceable> )"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_close;</"
"command>( <replaceable>क्लास</replaceable> )"

#. Tag: para
#: index.docbook:4110
#, no-c-format
msgid ""
"Closes a window, identified by its <replaceable>class</replaceable> name. "
"Only the first window that has the given class name will be closed, "
"therefore you should make sure that you have only one instance of the given "
"window when this command gets executed."
msgstr ""
"<प्रतिस्थापनीय>क्लास</प्रतिस्थापनीय> नाम से पहचानी जाने वाली विंडो को बंद करता है। केवल "
"वह पहली विंडो बंद होगी जिसमें दिया गया क्लास नाम है, इसलिए आपको यह सुनिश्चित करना "
"चाहिए कि जब यह कमांड निष्पादित हो तो आपके पास दी गई विंडो का केवल एक इंस्टेंस हो।"

#. Tag: title
#: index.docbook:4125
#, no-c-format
msgid "&no-i18n-cmd_window_minimize;"
msgstr "&no-i18n-cmd_window_minimize;"

#. Tag: title
#: index.docbook:4127
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-cmd_window_minimize;</command>"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-cmd_window_minimize;</command>"

#. Tag: para
#: index.docbook:4128
#, no-c-format
msgid ""
"Minimizes the currently active sub-window when in MDI mode or the current "
"toplevel window when in SDI or Tab mode."
msgstr ""
"MDI मोड में होने पर वर्तमान में सक्रिय उप-विंडो को छोटा कर देता है, या SDI या टैब मोड में "
"होने पर वर्तमान शीर्ष-स्तरीय विंडो को छोटा कर देता है।"

#. Tag: title
#: index.docbook:4136
#, no-c-format
msgid "&no-i18n-cmd_window_mousemove;"
msgstr "&no-i18n-cmd_window_mousemove;"

#. Tag: title
#: index.docbook:4138
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_resize;</"
"command>( <replaceable>class</replaceable>, <replaceable>x</replaceable>, "
"<replaceable>y</replaceable> )"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_resize;</"
"command>( <replaceable>class</replaceable>, <replaceable>x</replaceable>, "
"<replaceable>y</replaceable> )"

#. Tag: para
#: index.docbook:4143
#, no-c-format
msgid ""
"Sends a mouse move event to window, identified by its <replaceable>class</"
"replaceable> name. The event will only be sent to the first window that has "
"the given class name, therefore you should make sure that you have only one "
"instance of the given window when this command gets executed."
msgstr ""
"विंडो पर माउस मूव इवेंट भेजता है, जिसे उसके <रिप्लेसेबल>क्लास</रिप्लेसेबल> नाम से पहचाना "
"जाता है। इवेंट केवल उस पहली विंडो पर भेजा जाएगा जिसका क्लास नाम दिया गया है, इसलिए "
"आपको यह सुनिश्चित करना चाहिए कि जब यह कमांड निष्पादित हो तो आपके पास दी गई विंडो "
"का केवल एक इंस्टेंस हो।"

#. Tag: title
#: index.docbook:4163
#, no-c-format
msgid "&no-i18n-cmd_window_next_sub;"
msgstr "&no-i18n-cmd_window_next_sub;"

#. Tag: title
#: index.docbook:4165
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_next_sub;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_next_sub;</"
"command>()"

#. Tag: para
#: index.docbook:4166
#, no-c-format
msgid ""
"Activates the <emphasis>next</emphasis> sub-window when in MDI or Tab mode. "
"If the next sub-window is minimized it will be restored."
msgstr ""
"MDI या टैब मोड में होने पर <emphasis>अगली</emphasis> उप-विंडो को सक्रिय करता है। "
"यदि अगली उप-विंडो को छोटा किया जाता है तो उसे पुनर्स्थापित किया जाएगा।"

#. Tag: title
#: index.docbook:4174
#, no-c-format
msgid "&no-i18n-cmd_window_prev_sub;"
msgstr "&no-i18n-cmd_window_prev_sub;"

#. Tag: title
#: index.docbook:4176
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_prev_sub;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_prev_sub;</"
"command>()"

#. Tag: para
#: index.docbook:4177
#, no-c-format
msgid ""
"Activates the <emphasis>previous</emphasis> sub-window when in MDI or Tab "
"mode. If the previous sub-window is minimized it will be restored."
msgstr ""
"MDI या टैब मोड में होने पर <emphasis>पिछली</emphasis> उप-विंडो को सक्रिय करता है। "
"यदि पिछली उप-विंडो को छोटा किया जाता है तो उसे पुनर्स्थापित किया जाएगा।"

#. Tag: title
#: index.docbook:4185
#, no-c-format
msgid "&no-i18n-cmd_window_resize;"
msgstr "&no-i18n-cmd_window_resize;"

#. Tag: title
#: index.docbook:4187
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_resize;</"
"command>( <replaceable>class</replaceable>, <replaceable>width</"
"replaceable>, <replaceable>height</replaceable> )"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_resize;</"
"command>( <replaceable>class</replaceable>, <replaceable>width</"
"replaceable>, <replaceable>height</replaceable> )"

#. Tag: para
#: index.docbook:4192
#, no-c-format
msgid ""
"Changes the size of a window, identified by its <replaceable>class</"
"replaceable> name to a new <replaceable>width</replaceable> and "
"<replaceable>height</replaceable>. The change will only be applied to the "
"first window that has the given class name, therefore you should make sure "
"that you have only one instance of the given window when this command gets "
"executed."
msgstr ""
"किसी विंडो के आकार को बदलता है, जिसे उसके <प्रतिस्थापनीय>क्लास</प्रतिस्थापनीय> नाम से "
"पहचाना जाता है, एक नए <प्रतिस्थापनीय>चौड़ाई</प्रतिस्थापनीय> और <प्रतिस्थापनीय>ऊंचाई</"
"प्रतिस्थापनीय> में। यह परिवर्तन केवल उस पहली विंडो पर लागू होगा जिसमें दिया गया क्लास "
"नाम है, इसलिए आपको यह सुनिश्चित करना चाहिए कि जब यह कमांड निष्पादित हो तो आपके पास "
"दी गई विंडो का केवल एक इंस्टेंस हो।"

#. Tag: entry
#: index.docbook:4206
#, no-c-format
msgid "<parameter>width</parameter>:"
msgstr "<पैरामीटर>चौड़ाई</पैरामीटर>:"

#. Tag: entry
#: index.docbook:4207
#, no-c-format
msgid "new width of the window (in pixels)"
msgstr "विंडो की नई चौड़ाई (पिक्सेल में)"

#. Tag: entry
#: index.docbook:4208
#, no-c-format
msgid "<parameter>height</parameter>:"
msgstr "<पैरामीटर>ऊंचाई</पैरामीटर>:"

#. Tag: entry
#: index.docbook:4209
#, no-c-format
msgid "new height of the window (in pixels)"
msgstr "विंडो की नई ऊंचाई (पिक्सेल में)"

#. Tag: title
#: index.docbook:4214
#, no-c-format
msgid "&no-i18n-cmd_window_screenshot;"
msgstr "&no-i18n-cmd_window_screenshot;"

#. Tag: title
#: index.docbook:4216
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_screenshot;</"
"command>( <replaceable>class</replaceable>, <replaceable>filename</"
"replaceable> )"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_screenshot;</"
"command>( <replaceable>class</replaceable>, <replaceable>filename</"
"replaceable> )"

#. Tag: para
#: index.docbook:4220
#, no-c-format
msgid ""
"Takes a screenshot of a window, identified by its <replaceable>class</"
"replaceable> and saves it to a file. The screenshot will be taken from the "
"first window that has the given class name, therefore you should make sure "
"that you have only one instance of the given window when this command gets "
"executed. Currently the format of the file is hardcoded and has to be "
"<literal>*.png</literal>."
msgstr ""
"किसी विंडो का स्क्रीनशॉट लेता है, जिसे उसके <replaceable>class</replaceable> द्वारा "
"पहचाना जाता है और उसे फ़ाइल में सहेजता है। स्क्रीनशॉट उस पहली विंडो से लिया जाएगा जिसका "
"क्लास नाम दिया गया है, इसलिए आपको यह सुनिश्चित करना चाहिए कि जब यह कमांड निष्पादित "
"हो तो आपके पास दी गई विंडो का केवल एक इंस्टेंस हो। वर्तमान में फ़ाइल का प्रारूप हार्डकोडेड "
"है और इसे <literal>*.png</literal> होना चाहिए।"

#. Tag: entry
#: index.docbook:4235
#, no-c-format
msgid ""
"name of the file to save the screenshot, must have the extension <literal>*."
"png</literal>"
msgstr ""
"स्क्रीनशॉट को सहेजने के लिए फ़ाइल का नाम, एक्सटेंशन <literal>*.png</literal> होना "
"चाहिए"

#. Tag: title
#: index.docbook:4241
#, no-c-format
msgid "&no-i18n-cmd_window_sendkey;"
msgstr "&no-i18n-cmd_window_sendkey;"

#. Tag: title
#: index.docbook:4243
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_sendkey;</"
"command>( <replaceable>class</replaceable>, <replaceable>key code</"
"replaceable> )"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_sendkey;</"
"command>( <replaceable>class</replaceable>, <replaceable>key code</"
"replaceable> )"

#. Tag: para
#: index.docbook:4247
#, no-c-format
msgid ""
"Sends a key press and release event to a window, identified by its "
"<replaceable>class</replaceable> name. The key will only be sent to the "
"first window that has the given class name, therefore you should make sure "
"that you have only one instance of the given window when this command gets "
"executed."
msgstr ""
"एक कुंजी प्रेस और रिलीज इवेंट को एक विंडो पर भेजता है, जिसे उसके <प्रतिस्थापन योग्य>क्लास</"
"प्रतिस्थापन योग्य> नाम से पहचाना जाता है। कुंजी केवल उस पहली विंडो पर भेजी जाएगी जिसका "
"दिया गया क्लास नाम है, इसलिए आपको यह सुनिश्चित करना चाहिए कि जब यह कमांड निष्पादित "
"हो तो आपके पास दी गई विंडो का केवल एक इंस्टेंस हो।"

#. Tag: entry
#: index.docbook:4259
#, no-c-format
msgid "<parameter>key code</parameter>:"
msgstr "<पैरामीटर>कुंजी कोड</पैरामीटर>:"

#. Tag: entry
#: index.docbook:4260
#, no-c-format
msgid ""
"the key code that should be sent, using the same syntax as used for setting "
"up menus"
msgstr ""
"कुंजी कोड जिसे भेजा जाना चाहिए, उसी वाक्यविन्यास का उपयोग करते हुए जैसा कि मेनू सेट करने "
"के लिए उपयोग किया जाता है"

#. Tag: para
#: index.docbook:4264
#, no-c-format
msgid ""
"Description of the parameter <link linkend=\"cmd_menu_param_hotkey"
"\"><parameter>hotkey</parameter></link> of the <command>&no-i18n-cmd_menu;</"
"command>() command."
msgstr ""
"पैरामीटर का विवरण<link linkend=\"cmd_menu_param_hotkey\"><parameter> हॉटकी</"
"parameter></link> की<command> &amp;no-i18n-cmd_menu;</command> () आज्ञा।"

#. Tag: title
#: index.docbook:4273
#, no-c-format
msgid "&no-i18n-cmd_window_tile;"
msgstr "&no-i18n-cmd_window_tile;"

#. Tag: title
#: index.docbook:4275
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_tile;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_tile;</command>()"

#. Tag: para
#: index.docbook:4276
#, no-c-format
msgid ""
"Tiles all sub-windows when in MDI mode, using some scheme of &plasma;. All "
"sub-windows that are currently minimized stay minimized, they will not be "
"restored."
msgstr ""
"एमडीआई मोड में होने पर सभी उप-विंडो को टाइल करता है, &plasma; की कुछ योजना का "
"उपयोग करते हुए। सभी उप-विंडो जो वर्तमान में न्यूनतम हैं, न्यूनतम ही रहेंगी, उन्हें पुनर्स्थापित "
"नहीं किया जाएगा।"

#. Tag: title
#: index.docbook:4285
#, no-c-format
msgid "&no-i18n-cmd_window_tile_vertical;"
msgstr "&no-i18n-cmd_window_tile_vertical;"

#. Tag: title
#: index.docbook:4287
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_tile_vertical;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_tile_vertical;</"
"command>()"

#. Tag: para
#: index.docbook:4288
#, no-c-format
msgid ""
"Tiles all sub-windows vertically when in MDI mode. All windows that are "
"currently minimized stay minimized, they will not be restored."
msgstr ""
"MDI मोड में होने पर सभी उप-विंडो को लंबवत रूप से टाइल करता है। सभी विंडो जो वर्तमान में "
"न्यूनतम हैं, न्यूनतम ही रहेंगी, उन्हें पुनर्स्थापित नहीं किया जाएगा।"

#. Tag: title
#: index.docbook:4305
#, no-c-format
msgid "Plugins"
msgstr "प्लग-इन"

#. Tag: title
#: index.docbook:4307
#, no-c-format
msgid "Plugin Reference"
msgstr "प्लगइन संदर्भ"

#. Tag: index
#: index.docbook:4308
#, no-c-format
msgid ""
"&no-i18n-tag; <indexdiv><title>a</title> <indexentry><primaryie><link "
"linkend=\"plugin_sect_about\" endterm=\"plugin_title_about\"></link></"
"primaryie></indexentry> <indexentry><primaryie><link linkend="
"\"plugin_sect_amplifyfree\" endterm=\"plugin_title_amplifyfree\"></link></"
"primaryie></indexentry> </indexdiv> <indexdiv><title>b</title> "
