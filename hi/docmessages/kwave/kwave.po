#, no-c-format
msgid "playback method"
msgstr "प्लेबैक विधि"

#. Tag: para
#: index.docbook:6098
#, no-c-format
msgid "The method used for playback, see <filename>PlayBackParam.h</filename>."
msgstr "प्लेबैक के लिए प्रयुक्त विधि के लिए, <filename>PlayBackParam.h</filename> देखें।"

