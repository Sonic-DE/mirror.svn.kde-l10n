msgstr "जब फोकस पुश बटन पर होता है, तो यह बटन दबाता है"

#. Tag: member
#: index.docbook:475
#, no-c-format
msgid "<keycap>E</keycap> or <keycap>$</keycap>"
msgstr "<keycap>E</keycap> या <keycap>$</keycap>"

#. Tag: member
#: index.docbook:476 index.docbook:505
#, no-c-format
msgid ""
"Validation of input number considered as a value expressed in the reference "
