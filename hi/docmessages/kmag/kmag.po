"shortcut> <guimenu>View</guimenu> <guimenuitem>Start/Stop</guimenuitem>"
msgstr ""
"<शॉर्टकट> <keycombo action=\"simul\"> <keycap>F5</keycap></keycombo> </"
"shortcut> <guimenu>देखें</guimenu> <guimenuitem>प्रारंभ/रोकें</guimenuitem>"

#. Tag: para
#: index.docbook:293
#, no-c-format
msgid ""
"Start/Stop updating of the display. Stopping the update will zero the "
"processing power required (CPU usage)"
msgstr ""
"डिस्प्ले का अपडेट शुरू/बंद करें। अपडेट रोकने से आवश्यक प्रोसेसिंग पावर (सीपीयू उपयोग) शून्य हो "
"जाएगी"

#. Tag: menuchoice
#: index.docbook:299
#, no-c-format
msgid "<guimenu>View</guimenu> <guimenuitem>Zoom</guimenuitem>"
msgstr "<guimenu>देखें</guimenu> <guimenuitem>ज़ूम करें</guimenuitem>"

#. Tag: para
#: index.docbook:303
#, no-c-format
msgid "Select the zoom factor."
msgstr "ज़ूम फैक्टर का चयन करें."

#. Tag: menuchoice
#: index.docbook:307
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>-</keycap></keycombo> </"
"shortcut> <guimenu>View</guimenu> <guimenuitem>Zoom Out</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>-</keycap></keycombo> </"
"shortcut> <guimenu>देखें</guimenu> <guimenuitem>ज़ूम आउट</guimenuitem>"

#. Tag: para
#: index.docbook:315
#, no-c-format
msgid "Click on this button to zoom-out on the selected region."
msgstr "चयनित क्षेत्र पर ज़ूम-आउट करने के लिए इस बटन पर क्लिक करें।"

#. Tag: menuchoice
#: index.docbook:319
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>+</keycap></keycombo> </"
"shortcut> <guimenu>View</guimenu> <guimenuitem>Zoom In</guimenuitem>"
msgstr ""
"<शॉर्टकट> <keycombo action=\"simul\">&Ctrl; <keycap>+</keycap></keycombo> </"
"shortcut> <guimenu>देखें</guimenu> <guimenuitem>ज़ूम इन</guimenuitem>"

#. Tag: para
#: index.docbook:327
#, no-c-format
msgid "Click on this button to zoom-in on the selected region."
msgstr "चयनित क्षेत्र पर ज़ूम-इन करने के लिए इस बटन पर क्लिक करें।"

#. Tag: menuchoice
#: index.docbook:331
#, no-c-format
msgid "<guimenu>View</guimenu> <guimenuitem>Rotation</guimenuitem>"
msgstr "<guimenu>देखें</guimenu> <guimenuitem>रोटेशन</guimenuitem>"

#. Tag: para
#: index.docbook:335
#, no-c-format
msgid ""
"Select the rotation degree (<guimenuitem>No Rotation (0 Degrees)</"
"guimenuitem>, <guimenuitem>Left (90 Degrees)</guimenuitem>, "
"<guimenuitem>Upside Down (180 Degrees)</guimenuitem>, <guimenuitem>Right "
"(270 Degrees)</guimenuitem>."
msgstr ""
"रोटेशन डिग्री का चयन करें (<guimenuitem>कोई रोटेशन नहीं (0 डिग्री)</guimenuitem>, "
"<guimenuitem>बाएं (90 डिग्री)</guimenuitem>, <guimenuitem>उल्टा (180 डिग्री)</"
"guimenuitem>, <guimenuitem>दाएं (270 डिग्री)</guimenuitem>।"

#. Tag: menuchoice
#: index.docbook:341
#, no-c-format
msgid "<guimenu>View</guimenu> <guimenuitem>Refresh</guimenuitem>"
msgstr "<guimenu>देखें</guimenu> <guimenuitem>ताज़ा करें</guimenuitem>"

#. Tag: para
#: index.docbook:345
#, no-c-format
msgid ""
"Select the refresh rate (<guimenuitem>Very Low</guimenuitem>, "
"<guimenuitem>Low</guimenuitem>, <guimenuitem>Medium</guimenuitem>, "
"<guimenuitem>High</guimenuitem>, <guimenuitem>Very High</guimenuitem>). The "
"higher the rate, the more computing power (CPU) will be needed."
msgstr ""
"रिफ्रेश दर (<guimenuitem>बहुत कम</guimenuitem>, <guimenuitem>कम</guimenuitem>, "
"<guimenuitem>मध्यम</guimenuitem>, <guimenuitem>उच्च</guimenuitem>, "
"<guimenuitem>बहुत उच्च</guimenuitem>) का चयन करें। दर जितनी अधिक होगी, उतनी ही "
"अधिक कंप्यूटिंग शक्ति (सीपीयू) की आवश्यकता होगी।"

#. Tag: menuchoice
#: index.docbook:353
#, no-c-format
msgid "<guimenu>View</guimenu> <guisubmenu>Colors</guisubmenu>"
msgstr "<guimenu>देखें</guimenu> <guimenu>रंग</guimenu>"

#. Tag: para
#: index.docbook:357
#, no-c-format
msgid ""
"Select different color vision deficiencies to simulate color blindness. This "
"is not useful for people with color blindness, but good for designing "
"accessible interfaces."
msgstr ""
"रंग दृष्टि दोष का अनुकरण करने के लिए अलग-अलग रंग दृष्टि दोष चुनें। यह रंग दृष्टि दोष वाले "
"लोगों के लिए उपयोगी नहीं है, लेकिन सुलभ इंटरफेस डिजाइन करने के लिए अच्छा है।"

#. Tag: title
#: index.docbook:366
#, no-c-format
msgid "The Settings Menu"
msgstr "सेटिंग्स मेनू"

#. Tag: menuchoice
#: index.docbook:371
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> <keycap>F2</keycap></keycombo> </"
"shortcut> <guimenu>Settings</guimenu> <guimenuitem>Follow Mouse Mode</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> <keycap>F2</keycap></keycombo> </"
"shortcut> <guimenu>सेटिंग्स</guimenu> <guimenuitem>माउस मोड का अनुसरण करें</"
"guimenuitem>"

#. Tag: para
#: index.docbook:379
#, no-c-format
msgid ""
"In this mode the area around the mouse cursor is shown in a normal window."
msgstr "इस मोड में माउस कर्सर के आसपास का क्षेत्र एक सामान्य विंडो में दिखाया जाता है।"

#. Tag: menuchoice
#: index.docbook:383
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> <keycap>F3</keycap></keycombo> </"
"shortcut> <guimenu>Settings</guimenu> <guimenuitem>Selection Window Mode</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> <keycap>F3</keycap></keycombo> </"
"shortcut> <guimenu>सेटिंग्स</guimenu> <guimenuitem>चयन विंडो मोड</guimenuitem>"

#. Tag: para
#: index.docbook:391
#, no-c-format
msgid ""
"In this mode a selection window is opened. The selected area is shown in a "
"normal window."
msgstr ""
"इस मोड में एक चयन विंडो खोली जाती है। चयनित क्षेत्र एक सामान्य विंडो में दिखाया जाता है।"

#. Tag: menuchoice
#: index.docbook:395
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> <keycap>F4</keycap></keycombo> </"
"shortcut> <guimenu>Settings</guimenu> <guimenuitem>Whole Screen Mode</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> <keycap>F4</keycap></keycombo> </"
"shortcut> <guimenu>सेटिंग्स</guimenu> <guimenuitem>संपूर्ण स्क्रीन मोड</guimenuitem>"

#. Tag: para
#: index.docbook:403
#, no-c-format
msgid "In this mode the whole screen is magnified in the zoom window."
msgstr "इस मोड में संपूर्ण स्क्रीन ज़ूम विंडो में बड़ी हो जाती है।"

#. Tag: menuchoice
#: index.docbook:407
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> <keycap>F6</keycap></keycombo> </"
"shortcut> <guimenu>Settings</guimenu> <guimenuitem>Hide Mouse Cursor</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> <keycap>F6</keycap></keycombo> </"
"shortcut> <guimenu>सेटिंग्स</guimenu> <guimenuitem>माउस कर्सर छिपाएं</guimenuitem>"

#. Tag: para
#: index.docbook:415 index.docbook:482
#, no-c-format
msgid "Show or hide the mouse cursor in the magnified image."
msgstr "आवर्धित छवि में माउस कर्सर दिखाएं या छिपाएं।"

#. Tag: menuchoice
#: index.docbook:419
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> <keycap>F7</keycap></keycombo> </"
"shortcut> <guimenu>Settings</guimenu> <guimenuitem>Stays On Top</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> <keycap>F7</keycap></keycombo> </"
"shortcut> <guimenu>सेटिंग्स</guimenu> <guimenuitem>शीर्ष पर रहता है</guimenuitem>"

#. Tag: para
#: index.docbook:427 index.docbook:487
#, no-c-format
msgid "The &kmagnifier; window stays on top of other windows."
msgstr "&kmagnifier; विंडो अन्य विंडो के ऊपर रहती है।"

#. Tag: para
#: index.docbook:431
#, no-c-format
msgid ""
"Additionally &kmagnifier; has the common &kde; <guimenu>Settings</guimenu> "
"and <guimenu>Help</guimenu> menu items, for more information read the "
"sections about the <ulink url=\"help:/fundamentals/menus.html#menus-settings"
"\">Settings Menu</ulink> and <ulink url=\"help:/fundamentals/menus."
"html#menus-help\">Help Menu</ulink> of the &kde; Fundamentals."
msgstr ""
"इसके अतिरिक्त &kmagnifier; में सामान्य &kde; <guimenu>सेटिंग्स</guimenu> और "
"<guimenu>सहायता</guimenu> मेनू आइटम हैं, अधिक जानकारी के लिए &kde; फंडामेंटल्स के "
"<ulink url=\"help:/fundamentals/menus.html#menus-settings\">सेटिंग्स मेनू</ulink> "
"और <ulink url=\"help:/fundamentals/menus.html#menus-help\">सहायता मेनू</ulink> "
"के बारे में अनुभाग पढ़ें।"

#. Tag: title
#: index.docbook:442
#, no-c-format
msgid "Command Reference"
msgstr "कमांड संदर्भ"

#. Tag: para
#: index.docbook:444
#, no-c-format
msgid ""
"&kmagnifier; automatically uses all your default shortcuts for saving file, "
"opening new window, printing, starting/stopping refresh (reload button in "
"&konqueror;), zoom-in, zoom-out &etc;"
msgstr ""
"&kmagnifier; फ़ाइल को सहेजने, नई विंडो खोलने, प्रिंट करने, रिफ्रेश शुरू करने/रोकने "
"(&konqueror; में पुनः लोड बटन), ज़ूम-इन, ज़ूम-आउट आदि के लिए स्वचालित रूप से आपके सभी "
"डिफ़ॉल्ट शॉर्टकट का उपयोग करता है।"

#. Tag: title
#: index.docbook:449
#, no-c-format
msgid "Default Keyboard Shortcuts"
msgstr "डिफ़ॉल्ट कीबोर्ड शॉर्टकट"

#. Tag: keycombo
#: index.docbook:453
#, no-c-format
msgid "&Ctrl;<keycap>S</keycap>"
msgstr "&Ctrl;<keycap>एस</keycap>"

#. Tag: para
#: index.docbook:454
#, no-c-format
msgid "This will save the contents of the zoom window to a file."
msgstr "इससे ज़ूम विंडो की सामग्री एक फ़ाइल में सहेज ली जाएगी।"

#. Tag: keycap
#: index.docbook:459
#, no-c-format
msgid "<keycap>F2</keycap>"
msgstr "<कीकैप>F2</कीकैप>"

#. Tag: para
#: index.docbook:460
#, no-c-format
msgid "Switch to \"Follow Mouse Mode\"."
msgstr "\"फ़ॉलो माउस मोड\" पर स्विच करें।"

#. Tag: keycap
#: index.docbook:464
#, no-c-format
msgid "<keycap>F3</keycap>"
msgstr "<कीकैप>F3</कीकैप>"

#. Tag: para
#: index.docbook:465
#, no-c-format
msgid "Switch to \"Selection Window Mode\"."
msgstr "\"चयन विंडो मोड\" पर स्विच करें।"

#. Tag: keycap
#: index.docbook:469
#, no-c-format
msgid "<keycap>F4</keycap>"
msgstr "<कीकैप>F4</कीकैप>"

#. Tag: para
#: index.docbook:470
#, no-c-format
msgid "Switch to \"Whole Screen Mode\"."
msgstr "\"संपूर्ण स्क्रीन मोड\" पर स्विच करें।"

#. Tag: keycap
#: index.docbook:474
#, no-c-format
msgid "<keycap>F5</keycap>"
msgstr "<कीकैप>F5</कीकैप>"

#. Tag: para
#: index.docbook:475
#, no-c-format
msgid ""
"This will start the refresh of the zoom window if it is stopped, or stops "
"the refresh of the zoom window if the refresh is currently on."
msgstr ""
"यदि ज़ूम विंडो बंद है तो यह उसका रिफ्रेश शुरू कर देगा, या यदि रिफ्रेश वर्तमान में चालू है तो "
"ज़ूम विंडो का रिफ्रेश रोक देगा।"

#. Tag: keycap
#: index.docbook:481
#, no-c-format
msgid "<keycap>F6</keycap>"
msgstr "<कीकैप>F6</कीकैप>"

#. Tag: keycap
#: index.docbook:486
#, no-c-format
msgid "<keycap>F7</keycap>"
msgstr "<कीकैप>F7</कीकैप>"

#. Tag: keycombo
#: index.docbook:491
#, no-c-format
msgid "&Ctrl;<keycap>N</keycap>"
msgstr "&Ctrl;<keycap>एन</keycap>"

#. Tag: para
#: index.docbook:492
#, no-c-format
msgid "This will open a new &kmagnifier; window."
msgstr "इससे एक नई &kmagnifier; विंडो खुल जाएगी."

#. Tag: keycombo
#: index.docbook:495
#, no-c-format
msgid "&Ctrl;<keycap>P</keycap>"
msgstr "&Ctrl;<keycap>पी</keycap>"

#. Tag: para
#: index.docbook:496
#, no-c-format
msgid ""
"This will open the print dialog for printing the contents of the zoom window."
msgstr "इससे ज़ूम विंडो की सामग्री को प्रिंट करने के लिए प्रिंट संवाद खुल जाएगा।"

#. Tag: keycombo
#: index.docbook:500
#, no-c-format
msgid "&Ctrl;<keycap>C</keycap>"
msgstr "&Ctrl;<कीकैप>सी</कीकैप>"

#. Tag: para
#: index.docbook:501
#, no-c-format
msgid "This will copy the zoom window contents to the clipboard."
msgstr "इससे ज़ूम विंडो की सामग्री क्लिपबोर्ड पर कॉपी हो जाएगी।"

#. Tag: keycombo
#: index.docbook:506
#, no-c-format
msgid "&Ctrl;<keycap>M</keycap>"
msgstr "&Ctrl;<keycap>एम</keycap>"

#. Tag: para
#: index.docbook:507
#, no-c-format
msgid "Show/Hide the menubar."
msgstr "मेनूबार दिखाएँ/छिपाएँ."

#. Tag: keycombo
#: index.docbook:511
#, no-c-format
msgid "&Ctrl;<keycap>-</keycap>"
msgstr "&Ctrl;<कीकैप>-</कीकैप>"

#. Tag: para
#: index.docbook:512
#, no-c-format
msgid "Zoom out"
msgstr "ज़ूम आउट"

#. Tag: keycombo
#: index.docbook:515
#, no-c-format
msgid "&Ctrl;<keycap>+</keycap>"
msgstr "&Ctrl;<कीकैप>+</कीकैप>"

#. Tag: para
#: index.docbook:516
#, no-c-format
msgid "Zoom in"
msgstr "ज़ूम इन"

#. Tag: keycombo
#: index.docbook:519
#, no-c-format
msgid "&Ctrl;<keycap>Q</keycap>"
msgstr "&Ctrl;<keycap>क्यू</keycap>"

#. Tag: para
#: index.docbook:520
#, no-c-format
msgid "Quits the application."
msgstr "अनुप्रयोग से बाहर निकलें."

