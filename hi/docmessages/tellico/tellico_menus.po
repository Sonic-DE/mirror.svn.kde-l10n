#. Tag: title
#: menus.docbook:2
#, no-c-format
msgid "Command Reference"
msgstr "कमांड संदर्भ"

#. Tag: title
#: menus.docbook:13
#, no-c-format
msgid "The Main &tellico; Window"
msgstr "मुख्य विंडो"

#. Tag: para
#: menus.docbook:15
#, no-c-format
msgid ""
"Each menu item is discussed below. When there is a keyboard shortcut that "
"performs a menu item function, the default shortcut is listed with the menu "
"item."
msgstr ""
"प्रत्येक मेनू आइटम पर नीचे चर्चा की गई है। जब कोई कीबोर्ड शॉर्टकट होता है जो मेनू आइटम "
"फ़ंक्शन करता है, तो डिफ़ॉल्ट शॉर्टकट मेनू आइटम के साथ सूचीबद्ध होता है।"

#. Tag: title
#: menus.docbook:20
#, no-c-format
msgid "The File Menu"
msgstr "फ़ाइल मेनू"

#. Tag: menuchoice
#: menus.docbook:27
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>New</guimenuitem>"
msgstr "<guimenu>फ़ाइल</guimenu> <guimenuitem>नया</guimenuitem>"

#. Tag: para
#: menus.docbook:34
#, no-c-format
msgid ""
"This command <action>creates a new collection</action>. &tellico; supports "
"<link linkend=\"collection-types\">12 default collection types</link> along "
"with an empty user-defined custom collection. Any custom-saved collection "
"templates will also be available."
msgstr ""
"यह आदेश<action> एक नया संग्रह बनाता है</action> . &amp;tellico; का समर्थन करता "
"है<link linkend=\"collection-types\"> 12 डिफ़ॉल्ट संग्रह प्रकार</link> साथ ही एक "
"खाली उपयोगकर्ता-परिभाषित कस्टम संग्रह भी उपलब्ध होगा। कोई भी कस्टम-सेव्ड संग्रह टेम्पलेट "
"भी उपलब्ध होगा।"

#. Tag: menuchoice
#: menus.docbook:40
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>O</keycap></keycombo> </shortcut> "
"<guimenu>File</guimenu> <guimenuitem>Open...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>O</keycap></keycombo> </shortcut> "
"<guimenu>फ़ाइल</guimenu> <guimenuitem>खोलें...</guimenuitem>"

#. Tag: para
#: menus.docbook:50
#, no-c-format
msgid "This command <action>opens a &tellico; file</action>."
msgstr "यह आदेश <action>एक &tellico; फ़ाइल खोलता है</action>."

#. Tag: menuchoice
#: menus.docbook:56
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Open Recent</guimenuitem>"
msgstr "<guimenu>फ़ाइल</guimenu> <guimenuitem>हाल ही में खोलें</guimenuitem>"

#. Tag: para
#: menus.docbook:63
#, no-c-format
msgid ""
"This command <action>opens a file</action> from a submenu that contains a "
"list of recently opened files."
msgstr ""
"यह कमांड <action>एक फ़ाइल खोलता है</action> एक सबमेनू से जिसमें हाल ही में खोली गई "
"फ़ाइलों की सूची होती है।"

#. Tag: menuchoice
#: menus.docbook:70
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>S</keycap></keycombo> </shortcut> "
"<guimenu>File</guimenu> <guimenuitem>Save...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>S</keycap></keycombo> </shortcut> "
"<guimenu>फ़ाइल</guimenu> <guimenuitem>सहेजें...</guimenuitem>"

#. Tag: para
#: menus.docbook:80
#, no-c-format
msgid ""
"This command <action>saves the collection</action>. If the file is "
"<emphasis>Untitled</emphasis> then <guimenuitem>Save...</guimenuitem> is "
"equivalent to <guimenuitem>Save As</guimenuitem>. It is only enabled when "
"the collection has been modified."
msgstr ""
"यह कमांड <action>संग्रह को सहेजता है</action>। यदि फ़ाइल <emphasis>शीर्षकहीन</"
"emphasis> है तो <guimenuitem>सहेजें...</guimenuitem> <guimenuitem>इस रूप में सहेजें</"
"guimenuitem> के बराबर है। यह केवल तभी सक्षम होता है जब संग्रह को संशोधित किया गया हो।"

#. Tag: menuchoice
#: menus.docbook:89
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;&Shift;<keycap>S</keycap></keycombo> </shortcut> "
"<guimenu>File</guimenu> <guimenuitem>Save As...</guimenuitem>"
msgstr ""
"<शॉर्टकट> <कीकॉम्बो>&Ctrl;&Shift;<कीकैप>S</कीकैप></कीकॉम्बो> </शॉर्टकट> "
"<guimenu>फ़ाइल</guimenu> <guimenuitem>इस रूप में सहेजें...</guimenuitem>"

#. Tag: para
#: menus.docbook:99
#, no-c-format
msgid "This command <action>saves the collection to a new file</action>."
msgstr "यह आदेश <action>संग्रह को एक नई फ़ाइल में सहेजता है</action>."

#. Tag: menuchoice
#: menus.docbook:105
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Save As Template...</guimenuitem>"
msgstr "<guimenu>फ़ाइल</guimenu> <guimenuitem>टेम्पलेट के रूप में सहेजें...</guimenuitem>"

#. Tag: para
#: menus.docbook:112
#, no-c-format
msgid ""
"This command <action>saves the collection as a new template</action>. Only "
"the fields are saved, and the custom collection type can be created via the "
"<guimenuitem>New Collection</guimenuitem> command."
msgstr ""
"यह कमांड <action>संग्रह को नए टेम्पलेट के रूप में सहेजता है</action>। केवल फ़ील्ड सहेजे जाते "
"हैं, और कस्टम संग्रह प्रकार <guimenuitem>नया संग्रह</guimenuitem> कमांड के माध्यम से "
"बनाया जा सकता है।"

#. Tag: menuchoice
#: menus.docbook:118
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>P</keycap></keycombo> </shortcut> "
"<guimenu>File</guimenu> <guimenuitem>Print...</guimenuitem>"
msgstr ""
"<शॉर्टकट> <keycombo>&Ctrl;<keycap>P</keycap></keycombo> </shortcut> "
"<guimenu>फ़ाइल</guimenu> <guimenuitem>प्रिंट...</guimenuitem>"

#. Tag: para
#: menus.docbook:128
#, no-c-format
msgid ""
"This command <action>prints the collection</action>. Printing options may be "
"set in the <interface>Configuration Dialog</interface>."
msgstr ""
"यह आदेश <action>संग्रह को प्रिंट करता है</action>। मुद्रण विकल्प <interface>कॉन्फ़िगरेशन "
"संवाद</interface> में सेट किए जा सकते हैं।"

#. Tag: menuchoice
#: menus.docbook:134
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Print Preview</guimenuitem>"
msgstr "<guimenu>फ़ाइल</guimenu> <guimenuitem>प्रिंट पूर्वावलोकन</guimenuitem>"

#. Tag: para
#: menus.docbook:141
#, no-c-format
msgid ""
"This command <action>shows a preview of the printed collection</action>."
msgstr "यह आदेश <action>मुद्रित संग्रह का पूर्वावलोकन दिखाता है</action>."

#. Tag: menuchoice
#: menus.docbook:147
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Import</guimenuitem>"
msgstr "<guimenu>फ़ाइल</guimenu> <guimenuitem>आयात करें</guimenuitem>"

#. Tag: para
#: menus.docbook:154
#, no-c-format
msgid ""
"This command <action>imports data from another file</action>. &tellico; can "
"import data from a number of <link linkend=\"importing\">other formats</"
"link>."
msgstr ""
"यह आदेश<action> किसी अन्य फ़ाइल से डेटा आयात करता है</action> . &amp;tellico; अनेक "
"स्थानों से डेटा आयात कर सकता है<link linkend=\"importing\"> अन्य प्रारूप</link> ."

#. Tag: menuchoice
#: menus.docbook:160
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Export</guimenuitem>"
msgstr "<guimenu>फ़ाइल</guimenu> <guimenuitem>निर्यात करें</guimenuitem>"

#. Tag: para
#: menus.docbook:167
#, no-c-format
msgid ""
"This command <action>exports the collection to another format</action>. "
"&tellico; can export data to a number of <link linkend=\"exporting\">other "
"formats</link>."
msgstr ""
"यह आदेश<action> संग्रह को दूसरे प्रारूप में निर्यात करता है</action> . &amp;tellico; "
"अनेक स्थानों पर डेटा निर्यात कर सकता है<link linkend=\"exporting\"> अन्य प्रारूप</"
"link> ."

#. Tag: menuchoice
#: menus.docbook:173
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>Q</keycap></keycombo> </shortcut> "
"<guimenu>File</guimenu> <guimenuitem>Quit</guimenuitem>"
msgstr ""
"<शॉर्टकट> <keycombo>&Ctrl;<keycap>Q</keycap></keycombo> </shortcut> "
"<guimenu>फ़ाइल</guimenu> <guimenuitem>छोड़ें</guimenuitem>"

#. Tag: para
#: menus.docbook:183
#, no-c-format
msgid ""
"This command <action>closes the &tellico; window</action>. If the collection "
"has unsaved changes, you will be prompted to save them before continuing."
msgstr ""
"यह कमांड <action>&tellico; विंडो को बंद कर देता है</action>। यदि संग्रह में बिना सहेजे "
"गए परिवर्तन हैं, तो आपको आगे बढ़ने से पहले उन्हें सहेजने के लिए कहा जाएगा।"

#. Tag: title
#: menus.docbook:193
#, no-c-format
msgid "The Edit Menu"
msgstr "संपादन मेनू"

#. Tag: menuchoice
#: menus.docbook:201
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>Z</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Undo</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>Z</keycap></keycombo> </shortcut> "
"<guimenu>संपादित करें</guimenu> <guimenuitem>पूर्ववत करें</guimenuitem>"

#. Tag: para
#: menus.docbook:211
#, no-c-format
msgid ""
"This command <action>undoes the previous action</action>. Not all actions "
"are supported by Undo."
msgstr ""
"यह आदेश <action>पिछली कार्रवाई को पूर्ववत करता है</action>। सभी क्रियाएँ पूर्ववत "
"द्वारा समर्थित नहीं हैं।"

#. Tag: menuchoice
#: menus.docbook:217
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;&Shift;<keycap>Z</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Redo</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;&Shift;<keycap>Z</keycap></keycombo> </shortcut> "
"<guimenu>संपादित करें</guimenu> <guimenuitem>फिर से करें</guimenuitem>"

#. Tag: para
#: menus.docbook:227
#, no-c-format
msgid "This command <action>reverts a previous Undo</action>."
msgstr "यह आदेश <action>पिछले पूर्ववत करें को पूर्ववत करता है</action>."

#. Tag: menuchoice
#: menus.docbook:233
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>X</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Cut</guimenuitem>"
msgstr ""
"<शॉर्टकट> <कीकॉम्बो>&Ctrl;<कीकैप>X</कीकैप></कीकॉम्बो> </शॉर्टकट> <गुइमेनू>संपादित करें</"
"गुइमेनू> <गुइमेनूआइटम>काटें</गुइमेनूआइटम>"

#. Tag: para
#: menus.docbook:243
#, no-c-format
msgid ""
"This command <action>removes the selected text</action>, if any, and "
"<action>places a copy of the removed text in the clipboard</action>."
msgstr ""
"यह आदेश <action>चयनित पाठ को हटाता है</action>, यदि कोई हो, और <action>हटाए गए "
"पाठ की एक प्रतिलिपि क्लिपबोर्ड में रखता है</action>."

#. Tag: menuchoice
#: menus.docbook:249
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>C</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Copy</guimenuitem>"
msgstr ""
"<शॉर्टकट> <कीकॉम्बो>&Ctrl;<कीकैप>C</कीकैप></कीकॉम्बो> </शॉर्टकट> <guimenu>संपादित "
"करें</guimenu> <guimenuitem>कॉपी करें</guimenuitem>"

#. Tag: para
#: menus.docbook:259
#, no-c-format
msgid ""
"This command <action>copies the selected text</action>, if any, to the "
"clipboard."
msgstr ""
"यह आदेश <action>चयनित पाठ को</action>, यदि कोई हो, क्लिपबोर्ड पर कॉपी करता है।"

#. Tag: menuchoice
#: menus.docbook:265
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>V</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Paste</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>V</keycap></keycombo> </shortcut> "
"<guimenu>संपादित करें</guimenu> <guimenuitem>पेस्ट करें</guimenuitem>"

#. Tag: para
#: menus.docbook:275
#, no-c-format
msgid ""
"This command <action>pastes the text in the clipboard</action>, if any, into "
"the editor at the cursor position."
msgstr ""
"यह कमांड <action>क्लिपबोर्ड में मौजूद टेक्स्ट को, यदि कोई हो, कर्सर की स्थिति पर एडिटर "
"में पेस्ट करता है।"

#. Tag: menuchoice
#: menus.docbook:281
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>A</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Select All</guimenuitem>"
msgstr ""
"<शॉर्टकट> <कीकॉम्बो>&Ctrl;<कीकैप>A</कीकैप></कीकॉम्बो> </शॉर्टकट> <guimenu>संपादित "
"करें</guimenu> <guimenuitem>सभी का चयन करें</guimenuitem>"

#. Tag: para
#: menus.docbook:291
#, no-c-format
msgid ""
"This command <action>selects all the entries</action> in the collection, in "
"the <interface>Column View</interface>."
msgstr ""
"यह आदेश <action>संग्रह में, <interface>स्तंभ दृश्य</interface> में सभी प्रविष्टियों का चयन "
"करता है</action>."

#. Tag: menuchoice
#: menus.docbook:297
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;&Shift;<keycap>A</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Deselect</guimenuitem>"
msgstr ""
"<शॉर्टकट> <कीकॉम्बो>&Ctrl;&Shift;<कीकैप>A</कीकैप></कीकॉम्बो> </शॉर्टकट> "
"<guimenu>संपादित करें</guimenu> <guimenuitem>अचयनित करें</guimenuitem>"

#. Tag: para
#: menus.docbook:307
#, no-c-format
msgid ""
"This command <action>deselects all the entries</action> in the collection."
msgstr "यह आदेश <action>संग्रह में सभी प्रविष्टियों को अचयनित कर देता है</action>."

#. Tag: menuchoice
#: menus.docbook:313
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>I</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Internet Search...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>I</keycap></keycombo> </shortcut> "
"<guimenu>संपादित करें</guimenu> <guimenuitem>इंटरनेट खोज...</guimenuitem>"

#. Tag: para
#: menus.docbook:323
#, no-c-format
msgid ""
"This command <action>opens the <interface>Internet Search Dialog</"
"interface></action> to search for and import entries from various Internet "
"sites, including <ulink url=\"http://amazon.com\">Amazon.com</ulink>."
msgstr ""
"यह आदेश <action> <interface>इंटरनेट खोज संवाद</interface></action> को खोलता है, "
"जिससे <ulink url=\"http://amazon.com\">Amazon.com</ulink> सहित विभिन्न इंटरनेट "
"साइटों से प्रविष्टियों को खोजा और आयात किया जा सकता है।"

#. Tag: menuchoice
#: menus.docbook:329
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>J</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Advanced Filter...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>J</keycap></keycombo> </shortcut> "
"<guimenu>संपादित करें</guimenu> <guimenuitem>उन्नत फ़िल्टर...</guimenuitem>"

#. Tag: para
#: menus.docbook:339
#, no-c-format
msgid ""
"This command <action>opens the <interface>Advanced Filter Dialog</"
"interface></action>."
msgstr ""
"यह आदेश <action> <interface>उन्नत फ़िल्टर संवाद</interface></action> खोलता है।"

#. Tag: title
#: menus.docbook:350
#, no-c-format
msgid "The Collection Menu"
msgstr "संग्रह मेनू"

#. Tag: menuchoice
#: menus.docbook:357
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>N</keycap></keycombo> </shortcut> "
"<guimenu>Collection</guimenu> <guimenuitem>New Entry</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>N</keycap></keycombo> </shortcut> "
"<guimenu>संग्रह</guimenu> <guimenuitem>नई प्रविष्टि</guimenuitem>"

#. Tag: para
#: menus.docbook:367
#, no-c-format
msgid ""
"This command <action>opens the <interface>Entry Editor</interface> to edit a "
"new entry</action>."
msgstr ""
"यह आदेश <action>नई प्रविष्टि संपादित करने के लिए <interface>प्रविष्टि संपादक</"
"interface> खोलता है</action>."

#. Tag: menuchoice
#: menus.docbook:373
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>E</keycap></keycombo> </shortcut> "
"<guimenu>Collection</guimenu> <guimenuitem>Edit Entry</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>E</keycap></keycombo> </shortcut> "
"<guimenu>संग्रह</guimenu> <guimenuitem>प्रविष्टि संपादित करें</guimenuitem>"

#. Tag: para
#: menus.docbook:383
#, no-c-format
msgid ""
"This command <action>opens the <interface>Entry Editor</interface> to edit "
"the selected entries</action>."
msgstr ""
"यह आदेश <action>चयनित प्रविष्टियों को संपादित करने के लिए <interface>प्रविष्टि संपादक</"
"interface> को खोलता है</action>."

#. Tag: menuchoice
#: menus.docbook:389
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>Y</keycap></keycombo> </shortcut> "
"<guimenu>Collection</guimenu> <guimenuitem>Duplicate Entry</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>Y</keycap></keycombo> </shortcut> "
"<guimenu>संग्रह</guimenu> <guimenuitem>डुप्लिकेट प्रविष्टि</guimenuitem>"

#. Tag: para
#: menus.docbook:399
#, no-c-format
msgid ""
"This command <action>copies, or duplicates, the selected entries</action> as "
"new entries in the collection."
msgstr ""
"यह आदेश <action>चयनित प्रविष्टियों की प्रतिलिपि बनाता है या उनकी प्रतिलिपि बनाता है</"
"action> संग्रह में नई प्रविष्टियों के रूप में।"

#. Tag: menuchoice
#: menus.docbook:405
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>D</keycap></keycombo> </shortcut> "
"<guimenu>Collection</guimenu> <guimenuitem>Delete Entry</guimenuitem>"
msgstr ""
"<शॉर्टकट> <कीकॉम्बो>&Ctrl;<कीकैप>D</कीकैप></कीकॉम्बो> </शॉर्टकट> <गुइमेनू>संग्रह</गुइमेनू> "
"<गुइमेनूआइटम>प्रविष्टि मिटाएँ</गुइमेनूआइटम>"

