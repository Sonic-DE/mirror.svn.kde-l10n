"                   const QString&amp; <replaceable>audioURL</replaceable>,\n"
"                   int <replaceable>volumePercent</replaceable>,\n"
"                   const QString&amp; <replaceable>startDateTime</"
"replaceable>,\n"
"                   int <replaceable>lateCancel</replaceable>,\n"
"                   unsigned <replaceable>flags</replaceable>,\n"
"                   const QString&amp; <replaceable>recurrence</"
"replaceable>,\n"
"                   int <replaceable>subRepeatInterval</replaceable>, \n"
"                   int <replaceable>subRepeatCount</replaceable>)"
msgstr ""
"bool scheduleAudio(const QString&amp; <replaceable>name</replaceable>,\n"
"const QString&amp; <replaceable>audioURL</replaceable>,\n"
"int <replaceable>volumePercent</replaceable>,\n"
"const QString&amp; <replaceable>startDateTime</replaceable>,\n"
"int <replaceable>lateCancel</replaceable>,\n"
"unsigned <replaceable>flags</replaceable>,\n"
"const QString&amp; <replaceable>recurrence</replaceable>,\n"
"int <replaceable>subRepeatInterval</replaceable>, \n"
"int <replaceable>subRepeatCount</replaceable>)"

#. Tag: synopsis
#: index.docbook:4636
#, no-c-format
msgid ""
"bool scheduleAudio(const QString&amp; <replaceable>name</replaceable>,\n"
"                   const QString&amp; <replaceable>audioURL</replaceable>,\n"
"                   int <replaceable>volumePercent</replaceable>,\n"
"                   const QString&amp; <replaceable>startDateTime</"
"replaceable>,\n"
"                   int <replaceable>lateCancel</replaceable>,\n"
"                   unsigned <replaceable>flags</replaceable>,\n"
"                   int <replaceable>recurType</replaceable>,\n"
"                   int <replaceable>recurInterval</replaceable>,\n"
"                   int <replaceable>recurCount</replaceable>)"
msgstr ""
"bool scheduleAudio(const QString&amp; <replaceable>name</replaceable>,\n"
"const QString&amp; <replaceable>audioURL</replaceable>,\n"
"int <replaceable>volumePercent</replaceable>,\n"
"const QString&amp; <replaceable>startDateTime</replaceable>,\n"
"int <replaceable>lateCancel</replaceable>,\n"
"unsigned <replaceable>flags</replaceable>,\n"
"int <replaceable>recurType</replaceable>,\n"
"int <replaceable>recurInterval</replaceable>,\n"
"int <replaceable>recurCount</replaceable>)"

#. Tag: synopsis
#: index.docbook:4637
#, no-c-format
msgid ""
"bool scheduleAudio(const QString&amp; <replaceable>name</replaceable>,\n"
"                   const QString&amp; <replaceable>audioURL</replaceable>,\n"
"                   int <replaceable>volumePercent</replaceable>,\n"
"                   const QString&amp; <replaceable>startDateTime</"
"replaceable>,\n"
"                   int <replaceable>lateCancel</replaceable>,\n"
"                   unsigned <replaceable>flags</replaceable>,\n"
"                   int <replaceable>recurType</replaceable>,\n"
"                   int <replaceable>recurInterval</replaceable>,\n"
"                   const QString&amp; <replaceable>endDateTime</replaceable>)"
msgstr ""
"bool scheduleAudio(const QString&amp; <replaceable>name</replaceable>,\n"
"const QString&amp; <replaceable>audioURL</replaceable>,\n"
"int <replaceable>volumePercent</replaceable>,\n"
"const QString&amp; <replaceable>startDateTime</replaceable>,\n"
"int <replaceable>lateCancel</replaceable>,\n"
"unsigned <replaceable>flags</replaceable>,\n"
"int <replaceable>recurType</replaceable>,\n"
"int <replaceable>recurInterval</replaceable>,\n"
"const QString&amp; <replaceable>endDateTime</replaceable>)"

#. Tag: para
#: index.docbook:4652
#, no-c-format
msgid "Specifies the audio file which is to be played."
msgstr "वह ऑडियो फ़ाइल निर्दिष्ट करता है जिसे चलाया जाना है."

#. Tag: parameter
#: index.docbook:4657
#, no-c-format
msgid "volumePercent"
msgstr "आयतन प्रतिशत"

#. Tag: para
#: index.docbook:4659
#, no-c-format
msgid ""
"Specifies the volume level to use, as a percentage of full volume. Specify "
"-1 to use the default volume."
msgstr ""
"पूर्ण वॉल्यूम के प्रतिशत के रूप में उपयोग किए जाने वाले वॉल्यूम स्तर को निर्दिष्ट करता है। "
"डिफ़ॉल्ट वॉल्यूम का उपयोग करने के लिए -1 निर्दिष्ट करें।"

#. Tag: para
#: index.docbook:4786
#, no-c-format
msgid ""
"<function>scheduleAudio()</function> is a &DBus; call to schedule the "
"specified audio file to be played at the specified date and time. Apart from "
"specifying a volume and omitting the message color and font parameters, its "
"usage is identical to <link linkend=\"scheduleMessage-descrip"
"\"><function>scheduleMessage</function></link> - see the description of that "
"function for further details."
msgstr ""
"<function>शेड्यूलऑडियो()</function> &amp;DBus; निर्दिष्ट ऑडियो फ़ाइल को निर्दिष्ट "
"दिनांक और समय पर चलाने के लिए शेड्यूल करने के लिए कॉल है। वॉल्यूम निर्दिष्ट करने और संदेश रंग "
"और फ़ॉन्ट पैरामीटर को छोड़ने के अलावा, इसका उपयोग समान है<link linkend="
"\"scheduleMessage-descrip\"><function> शेड्यूलसंदेश</function></link> - अधिक "
"जानकारी के लिए उस फ़ंक्शन का विवरण देखें।"

#. Tag: refentrytitle
#: index.docbook:4797
#, no-c-format
msgid "<refentrytitle>edit</refentrytitle>"
msgstr "<refentrytitle>संपादित करें</refentrytitle>"

#. Tag: refname
#: index.docbook:4800
#, no-c-format
msgid "<refname>edit</refname>"
msgstr "<refname>संपादित करें</refname>"

#. Tag: refpurpose
#: index.docbook:4801
#, no-c-format
msgid ""
"Display the <link linkend=\"alarm-edit-dlg\">Alarm Edit dialog</link> to "
"edit an alarm."
msgstr ""
"प्रदर्शित करें<link linkend=\"alarm-edit-dlg\"> अलार्म संपादन संवाद</link> अलार्म "
"संपादित करने के लिए."

#. Tag: synopsis
#: index.docbook:4805
#, no-c-format
msgid "bool edit(const QString&amp; <replaceable>eventID</replaceable>)"
msgstr ""
"bool संपादन(const QString&amp; <प्रतिस्थापन योग्य>eventID</प्रतिस्थापन योग्य>)"

#. Tag: para
#: index.docbook:4813
#, no-c-format
msgid ""
"Specifies the unique ID of the event to be edited, optionally prefixed by "
"the configuration name or numeric ID of the resource containing the event, "
"in the format <replaceable>[resourceID:]eventUID</replaceable>."
msgstr ""
"संपादित किए जाने वाले ईवेंट की अद्वितीय ID निर्दिष्ट करता है, वैकल्पिक रूप से ईवेंट वाले "
"संसाधन के कॉन्फ़िगरेशन नाम या संख्यात्मक ID द्वारा उपसर्गित, "
"<replaceable>[resourceID:]eventUID</replaceable> प्रारूप में।"

#. Tag: title
#: index.docbook:4823 index.docbook:4877 index.docbook:4909
#, no-c-format
msgid "Return value"
msgstr "वापसी मूल्य"

#. Tag: para
#: index.docbook:4824
#, no-c-format
msgid ""
"<returnvalue>false</returnvalue> if the specified alarm could not be found "
"or is read-only, <returnvalue>true</returnvalue> otherwise."
msgstr ""
"यदि निर्दिष्ट अलार्म नहीं मिल पाया या केवल पढ़ने के लिए है तो <returnvalue>false</"
"returnvalue>, अन्यथा <returnvalue>true</returnvalue>."

#. Tag: para
#: index.docbook:4833
#, no-c-format
msgid ""
"<function>edit()</function> is a &DBus; call to display the <link linkend="
"\"alarm-edit-dlg\">Alarm Edit dialog</link> to edit the specified alarm."
msgstr ""
"<function>संपादन करना()</function> यह एक &amp;DBus; कॉल है जो प्रदर्शित करता "
"है<link linkend=\"alarm-edit-dlg\"> अलार्म संपादन संवाद</link> निर्दिष्ट अलार्म को "
"संपादित करने के लिए."

#. Tag: refentrytitle
#: index.docbook:4842
#, no-c-format
msgid "<refentrytitle>editNew</refentrytitle>"
msgstr "<refentrytitle>नया संपादित करें</refentrytitle>"

#. Tag: refname
#: index.docbook:4845
#, no-c-format
msgid "<refname>editNew</refname>"
msgstr "<refname>नया संपादित करें</refname>"

#. Tag: refpurpose
#: index.docbook:4846
#, no-c-format
msgid ""
"Display the <link linkend=\"alarm-edit-dlg\">Alarm Edit dialog</link> to "
"edit a new alarm."
msgstr ""
"प्रदर्शित करें<link linkend=\"alarm-edit-dlg\"> अलार्म संपादन संवाद</link> नया "
"अलार्म संपादित करने के लिए."

#. Tag: synopsis
#: index.docbook:4850
#, no-c-format
msgid "bool editNew(int <replaceable>type</replaceable>)"
msgstr "bool editNew(int <प्रतिस्थापन योग्य>प्रकार</प्रतिस्थापन योग्य>)"

#. Tag: synopsis
#: index.docbook:4851
#, no-c-format
msgid ""
"bool editNew(const QString&amp; <replaceable>templateName</replaceable>)"
msgstr ""
"bool editNew(const QString&amp; <प्रतिस्थापन योग्य>टेम्पलेटनाम</प्रतिस्थापन योग्य>)"

#. Tag: parameter
#: index.docbook:4857
#, no-c-format
msgid "type"
msgstr "प्रकार"

#. Tag: para
#: index.docbook:4859
#, no-c-format
msgid ""
"Specifies the alarm type. The permissible values are DISPLAY, COMMAND, "
"EMAIL, AUDIO. These are defined in class <classname>KAlarmIface</classname> "
"in <filename>kalarmiface.h</filename>."
msgstr ""
"अलार्म प्रकार निर्दिष्ट करता है। स्वीकार्य मान DISPLAY, COMMAND, EMAIL, AUDIO हैं। "
"इन्हें <filename>kalarmiface.h</filename> में क्लास <classname>KAlarmIface</"
"classname> में परिभाषित किया गया है।"

#. Tag: parameter
#: index.docbook:4867
#, no-c-format
msgid "templateName"
msgstr "टेम्पलेटनाम"

#. Tag: para
#: index.docbook:4869
#, no-c-format
msgid "Specifies the name of an alarm template to base the new alarm on."
msgstr "नए अलार्म को आधार बनाने के लिए अलार्म टेम्पलेट का नाम निर्दिष्ट करता है।"

#. Tag: para
#: index.docbook:4878
#, no-c-format
msgid ""
"<returnvalue>false</returnvalue> if <parameter>type</parameter> has an "
"invalid value, or if no template with the name <parameter>templateName</"
"parameter> can be found; <returnvalue>true</returnvalue> otherwise."
msgstr ""
"<returnvalue>false</returnvalue> यदि <parameter>type</parameter> में कोई अमान्य "
"मान है, या यदि <parameter>templateName</parameter> नाम वाला कोई टेम्पलेट नहीं मिल "
"पाता है; अन्यथा <returnvalue>true</returnvalue>."

#. Tag: para
#: index.docbook:4888
#, no-c-format
msgid ""
"<function>editNew()</function> is a &DBus; call to display the <link linkend="
"\"alarm-edit-dlg\">Alarm Edit dialog</link> to edit a new alarm. If an alarm "
"type is specified as a parameter, a blank dialog is displayed. "
"Alternatively, if an alarm template name is specified as a parameter, the "
"dialog is preset with details from the template."
msgstr ""
"<function>संपादित करेंनया()</function> यह एक &amp;DBus; कॉल है जो प्रदर्शित करता "
"है<link linkend=\"alarm-edit-dlg\"> अलार्म संपादन संवाद</link> नया अलार्म संपादित "
"करने के लिए। यदि अलार्म प्रकार को पैरामीटर के रूप में निर्दिष्ट किया जाता है, तो एक रिक्त "
"संवाद प्रदर्शित होता है। वैकल्पिक रूप से, यदि अलार्म टेम्पलेट नाम को पैरामीटर के रूप में "
"निर्दिष्ट किया जाता है, तो संवाद टेम्पलेट से विवरण के साथ प्रीसेट होता है।"

#. Tag: refentrytitle
#: index.docbook:4899
#, no-c-format
msgid "<refentrytitle>list</refentrytitle>"
msgstr "<refentrytitle>सूची</refentrytitle>"

#. Tag: refname
#: index.docbook:4902
#, no-c-format
msgid "<refname>list</refname>"
msgstr "<refname>सूची</refname>"

#. Tag: refpurpose
#: index.docbook:4903
#, no-c-format
msgid "Return a list of scheduled alarms."
msgstr "निर्धारित अलार्मों की सूची लौटाएँ."

#. Tag: synopsis
#: index.docbook:4906
#, no-c-format
msgid "QString list()"
msgstr "क्यूस्ट्रिंग सूची()"

#. Tag: para
#: index.docbook:4910
#, no-c-format
msgid ""
"List of alarms, separated by newlines, each in the format "
"<returnvalue><replaceable>resource_id</replaceable>:<replaceable>UID</"
"replaceable> <replaceable>time</replaceable> <replaceable>text</"
"replaceable></returnvalue>"
msgstr ""
"अलार्मों की सूची, नई पंक्तियों से अलग, प्रत्येक प्रारूप में "
"<returnvalue><replaceable>resource_id</replaceable>:<replaceable>UID</"
"replaceable> <replaceable>time</replaceable> <replaceable>text</"
"replaceable></returnvalue>"

#. Tag: para
#: index.docbook:4918
#, no-c-format
msgid ""
"<function>list()</function> is a &DBus; call to return a string containing a "
"summary of scheduled alarms. The list shows brief details of each pending "
"alarm: its resource identifier, UID, next scheduled time and message text or "
"file."
msgstr ""
"<function>list()</function> एक &DBus; कॉल है जो शेड्यूल किए गए अलार्म का सारांश "
"युक्त स्ट्रिंग लौटाता है। सूची प्रत्येक लंबित अलार्म का संक्षिप्त विवरण दिखाती है: इसका "
"संसाधन पहचानकर्ता, UID, अगला शेड्यूल किया गया समय और संदेश पाठ या फ़ाइल।"

#. Tag: title
#: index.docbook:4929
#, no-c-format
msgid "Command Line Interface"
msgstr "कमांड लाइन इंटरफ़ेस"

#. Tag: para
#: index.docbook:4931
#, no-c-format
msgid ""
"Command line options are provided to enable other programs to start up "
"&kalarm; if it is not already running, in order to trigger or cancel "
"scheduled alarms, or schedule new alarms. The reason for using command line "
"options for this purpose is that if &kalarm; were started without any "
"command line parameters and then sent &DBus; requests, it would start in its "
"default graphical mode, which is clearly undesirable for an inter-program "
"request."
msgstr ""
"कमांड लाइन विकल्प अन्य प्रोग्राम को चालू करने में सक्षम बनाने के लिए प्रदान किए जाते हैं यदि "
"&kalarm; पहले से चालू नहीं है, ताकि शेड्यूल किए गए अलार्म को ट्रिगर या रद्द किया जा सके, "
"या नए अलार्म शेड्यूल किए जा सकें। इस उद्देश्य के लिए कमांड लाइन विकल्पों का उपयोग करने का "
"कारण यह है कि यदि &kalarm; को बिना किसी कमांड लाइन पैरामीटर के शुरू किया गया और "
"फिर &DBus; अनुरोध भेजे गए, तो यह अपने डिफ़ॉल्ट ग्राफ़िकल मोड में शुरू होगा, जो कि अंतर-"
"प्रोग्राम अनुरोध के लिए स्पष्ट रूप से अवांछनीय है।"

#. Tag: para
#: index.docbook:4939
#, no-c-format
msgid ""
"Programs should first check whether &kalarm; is already running; if it is, "
"they should instead use &DBus; calls to request these operations."
msgstr ""
"प्रोग्रामों को पहले यह जांचना चाहिए कि क्या &kalarm; पहले से चल रहा है; यदि चल रहा है, "
"तो उन्हें इन कार्यों के लिए अनुरोध करने हेतु &DBus; कॉल का उपयोग करना चाहिए।"

#. Tag: para
#: index.docbook:4943
#, no-c-format
msgid ""
"The command line options for scheduling a new alarm are as described in the "
"chapter <link linkend=\"cmdline-operation\">Command Line Operation</link>. "
"The options for triggering and canceling scheduled alarms are as follows:"
msgstr ""
"नए अलार्म को शेड्यूल करने के लिए कमांड लाइन विकल्प अध्याय में वर्णित हैं<link linkend="
"\"cmdline-operation\"> कमांड लाइन ऑपरेशन</link> अनुसूचित अलार्म को ट्रिगर करने और "
"रद्द करने के विकल्प इस प्रकार हैं:"

#. Tag: para
#: index.docbook:4948
#, no-c-format
msgid ""
"Normal users may also if they wish use these command line options (assuming "
"that they can supply the necessary parameter information)."
msgstr ""
"सामान्य उपयोगकर्ता भी यदि चाहें तो इन कमांड लाइन विकल्पों का उपयोग कर सकते हैं (यह "
"मानते हुए कि वे आवश्यक पैरामीटर जानकारी प्रदान कर सकते हैं)।"

#. Tag: option
#: index.docbook:4962
#, no-c-format
msgid "--cancelEvent <replaceable>eventID</replaceable>"
msgstr "--cancelEvent <प्रतिस्थापन योग्य>इवेंटआईडी</प्रतिस्थापन योग्य>"

#. Tag: entry
#: index.docbook:4963
#, no-c-format
msgid ""
"Cancel the alarm with the specified event ID. The event ID is the unique ID "
"of the event, optionally prefixed by the ID of the resource containing the "
"event, in the format <replaceable>[resourceID:]eventUID</replaceable>. The "
"action taken is the same as for the <link linkend=\"cancelEvent"
"\">cancelEvent()</link> &DBus; call. <option>--triggerEvent</option> cannot "
"be specified with this option."
msgstr ""
"निर्दिष्ट ईवेंट आईडी के साथ अलार्म रद्द करें। ईवेंट आईडी ईवेंट की अद्वितीय आईडी है, वैकल्पिक "
"रूप से ईवेंट वाले संसाधन की आईडी द्वारा उपसर्ग किया गया है, प्रारूप में<replaceable> "
"[संसाधनआईडी:]इवेंटयूआईडी</replaceable> की गई कार्रवाई उसी प्रकार की है जैसा कि<link "
"linkend=\"cancelEvent\"> कैंसलइवेंट()</link> &amp;DBus; कॉल.<option value=--"
"triggerEvent> --ट्रिगरइवेंट</option> इस विकल्प के साथ निर्दिष्ट नहीं किया जा सकता."

#. Tag: option
#: index.docbook:4973
#, no-c-format
msgid "--triggerEvent <replaceable>eventID</replaceable>"
msgstr "--triggerEvent <प्रतिस्थापन योग्य>इवेंटआईडी</प्रतिस्थापन योग्य>"

#. Tag: entry
#: index.docbook:4974
#, no-c-format
msgid ""
"Trigger the alarm with the specified event ID. The event ID is the unique ID "
"of the event, optionally prefixed by the ID of the resource containing the "
"event, in the format <replaceable>[resourceID:]eventUID</replaceable>. The "
"action taken is the same as for the <link linkend=\"triggerEvent"
"\">triggerEvent()</link> &DBus; call. <option>--cancelEvent</option> cannot "
"be specified with this option."
msgstr ""
"निर्दिष्ट ईवेंट आईडी के साथ अलार्म ट्रिगर करें। ईवेंट आईडी ईवेंट की अद्वितीय आईडी है, "
"वैकल्पिक रूप से ईवेंट वाले संसाधन की आईडी द्वारा उपसर्ग किया गया है, प्रारूप "
"में<replaceable> [संसाधनआईडी:]इवेंटयूआईडी</replaceable> की गई कार्रवाई उसी प्रकार की "
"है जैसा कि<link linkend=\"triggerEvent\"> ट्रिगरइवेंट()</link> &amp;DBus; कॉल."
"<option value=--cancelEvent> --इवेंट रद्द करें</option> इस विकल्प के साथ निर्दिष्ट "
"नहीं किया जा सकता."

#. Tag: para
#: index.docbook:4987
#, no-c-format
msgid "Examples are:"
msgstr "उदाहरण हैं:"

#. Tag: screen
#: index.docbook:4989
#, no-c-format
msgid ""
"<prompt>%</prompt> <userinput><command>kalarm</command> <option>--"
"triggerEvent <replaceable>&kalarm;-387486299.702</replaceable></option></"
"userinput>\n"
"<prompt>%</prompt> <userinput><command>kalarm</command> <option>--"
"cancelEvent <replaceable>&kalarm;-388886299.793</replaceable></option></"
"userinput>"
msgstr ""
"<prompt>%</prompt><userinput><command> कलार्म</command><option> --"
"ट्रिगरइवेंट<replaceable> &amp;कलार्म;-387486299.702</replaceable></option></"
"userinput><prompt> %</prompt><userinput><command> कलार्म</command><option> --"
"इवेंट रद्द करें<replaceable> &amp;कलार्म;-388886299.793</replaceable></option></"
"userinput>"

#. Tag: title
#: index.docbook:4997
#, no-c-format
msgid "Questions and Answers"
msgstr "प्रश्न और उत्तर"

#. Tag: para
#: index.docbook:5002
#, no-c-format
msgid "What configuration files does &kalarm; use?"
msgstr "&kalarm; कौन सी कॉन्फ़िगरेशन फ़ाइलों का उपयोग करता है?"

#. Tag: para
#: index.docbook:5005
#, no-c-format
msgid ""
"&kalarm;'s configuration is held in the following files in the folder "
"<command>qtpaths --paths GenericConfigLocation</command> :"
msgstr ""
"&kalarm; का कॉन्फ़िगरेशन <command>qtpaths --paths GenericConfigLocation</"
"command> फ़ोल्डर में निम्न फ़ाइलों में रखा गया है:"

#. Tag: simpara
#: index.docbook:5010
#, no-c-format
msgid "<filename>kalarmrc</filename> holds your &kalarm; preferences."
msgstr "<filename>kalarmrc</filename> आपकी &kalarm; प्राथमिकताएं रखता है।"

#. Tag: simpara
#: index.docbook:5015
#, no-c-format
msgid ""
"<filename>kalarmresources</filename> holds the list of alarm calendars "
"currently used by &kalarm;."
msgstr ""
"<filename>kalarmresources</filename> में &kalarm; द्वारा वर्तमान में उपयोग किए जाने "
"वाले अलार्म कैलेंडर की सूची होती है।"

#. Tag: para
#: index.docbook:5024
#, no-c-format
msgid "Where does &kalarm; store its alarms?"
msgstr "&kalarm; अपने अलार्म कहां संग्रहीत करता है?"

#. Tag: para
#: index.docbook:5028
#, no-c-format
msgid ""
"When &kalarm; is run the first time, it creates the following alarm "
"calendars in the folder <command>qtpaths --paths GenericDataLocation</"
"command> :"
msgstr ""
"जब &kalarm; को पहली बार चलाया जाता है, तो यह <command>qtpaths --paths "
"GenericDataLocation</command> फ़ोल्डर में निम्नलिखित अलार्म कैलेंडर बनाता है:"

#. Tag: simpara
#: index.docbook:5034
#, no-c-format
msgid "<filename>kalarm/calendar.ics</filename>, which holds active alarms."
msgstr "<filename>kalarm/calendar.ics</filename>, जो सक्रिय अलार्म रखता है।"

#. Tag: simpara
#: index.docbook:5039
#, no-c-format
msgid "<filename>kalarm/expired.ics</filename>, which holds archived alarms."
msgstr "<filename>kalarm/expired.ics</filename>, जो संग्रहीत अलार्म रखता है।"

#. Tag: simpara
#: index.docbook:5044
#, no-c-format
msgid "<filename>kalarm/template.ics</filename>, which holds alarm templates."
msgstr "<filename>kalarm/template.ics</filename>, जो अलार्म टेम्पलेट्स रखता है।"

#. Tag: simpara
#: index.docbook:5049
#, no-c-format
msgid ""
"<filename>kalarm/displaying.ics</filename>, which is a special calendar file "
"to hold details of alarms currently being displayed, which allows &kalarm;, "
"when it is restarted, to redisplay alarms which were being displayed when it "
"last stopped."
msgstr ""
"<filename>kalarm/displaying.ics</filename>, जो वर्तमान में प्रदर्शित हो रहे अलार्मों "
"का विवरण रखने के लिए एक विशेष कैलेंडर फ़ाइल है, जो &kalarm; को पुनः आरंभ होने पर, उन "
"अलार्मों को पुनः प्रदर्शित करने की अनुमति देता है, जो पिछली बार बंद होने पर प्रदर्शित हो "
"रहे थे।"

#. Tag: para
#: index.docbook:5056
#, no-c-format
msgid ""
"You can subsequently replace these calendars, except <filename>displaying."
"ics</filename>, or create additional alarm calendars in any location which "
"you choose. You can find out which calendar files are currently in use by "
"viewing each calendar's details in the alarm calendars list."
msgstr ""
"आप बाद में इन कैलेंडर को बदल सकते हैं, सिवाय <filename>displaying.ics</filename> के, "
"या अपने द्वारा चुने गए किसी भी स्थान पर अतिरिक्त अलार्म कैलेंडर बना सकते हैं। आप अलार्म "
"कैलेंडर सूची में प्रत्येक कैलेंडर का विवरण देखकर पता लगा सकते हैं कि वर्तमान में कौन सी कैलेंडर "
"फ़ाइलें उपयोग में हैं।"

#. Tag: para
#: index.docbook:5066
#, no-c-format
msgid "What format are alarms stored in?"
msgstr "अलार्म किस प्रारूप में संग्रहीत किये जाते हैं?"

#. Tag: para
#: index.docbook:5069
#, no-c-format
msgid ""
"The calendar files in which &kalarm; stores its alarms are text files whose "
"format is defined by the document <ulink url=\"http://www.w3.org/2002/12/cal/"
"rfc2445.html\">RFC2445 - Internet Calendaring and Scheduling Core Object "
"Specification (iCalendar)</ulink>. This is the standard format used by all "
"kdepim applications. &kalarm; uses certain non-standard properties, in "
"conformance with RFC2445. These are documented in the <filename>DESIGN-"
"kalarmcalendar.html</filename> file which is distributed with &kalarm;."
msgstr ""
"कैलेंडर फ़ाइलें जिनमें &kalarm; अपने अलार्म संग्रहीत करता है, वे टेक्स्ट फ़ाइलें हैं जिनका प्रारूप "
"दस्तावेज़ <ulink url=\"http://www.w3.org/2002/12/cal/rfc2445.html\">RFC2445 - "
"इंटरनेट कैलेंडरिंग और शेड्यूलिंग कोर ऑब्जेक्ट स्पेसिफिकेशन (iCalendar)</ulink> द्वारा "
"परिभाषित किया गया है। यह सभी kdepim अनुप्रयोगों द्वारा उपयोग किया जाने वाला मानक "
"प्रारूप है। &kalarm; RFC2445 के अनुरूप कुछ गैर-मानक गुणों का उपयोग करता है। इन्हें "
"<filename>DESIGN-kalarmcalendar.html</filename> फ़ाइल में प्रलेखित किया गया है जिसे "
"&kalarm; के साथ वितरित किया जाता है।"

#. Tag: para
#: index.docbook:5083
#, no-c-format
msgid "What is the function of &kalarm;'s Akonadi plugin?"
msgstr "&kalarm; के Akonadi प्लगइन का कार्य क्या है?"

#. Tag: para
#: index.docbook:5086
#, no-c-format
msgid ""
"&kalarm; uses its Akonadi plugin to provide all features which depend on "
"&akonadi; (the &kde; &PIM; cross-desktop storage service). If this plugin is "
"not installed and enabled, &kalarm; will lack the following features:"
msgstr ""
"&kalarm; अपने Akonadi प्लगइन का उपयोग उन सभी सुविधाओं को प्रदान करने के लिए करता है "
"जो &akonadi; (&kde; &PIM; क्रॉस-डेस्कटॉप स्टोरेज सेवा) पर निर्भर करती हैं। यदि यह "
"प्लगइन इंस्टॉल और सक्षम नहीं है, तो &kalarm; में निम्नलिखित सुविधाएँ नहीं होंगी:"

#. Tag: simpara
#: index.docbook:5092
#, no-c-format
msgid ""
"Sending emails via &kmail;, leaving &Sendmail; as the only option to send "
"emails (see <link linkend=\"preferences-email\">Email preferences</link>)."
msgstr ""
"&amp;kmail; के माध्यम से ईमेल भेजना, ईमेल भेजने के लिए &amp;Sendmail; को एकमात्र विकल्प "
"के रूप में छोड़ना (देखें)<link linkend=\"preferences-email\"> ईमेल प्राथमिकताएं</"
"link> )."

#. Tag: simpara
#: index.docbook:5097
#, no-c-format
msgid "Drag and drop of emails."
msgstr "ईमेल को खींचें और छोड़ें."

#. Tag: simpara
#: index.docbook:5100
#, no-c-format
msgid "Selection of email addresses from &kaddressbook;."
msgstr "&kaaddressbook; से ईमेल पते का चयन."

#. Tag: simpara
#: index.docbook:5103
#, no-c-format
msgid "Import of birthdays from &kaddressbook;."
msgstr "&kaaddressbook; से जन्मदिन का आयात."

#. Tag: simpara
#: index.docbook:5106
#, no-c-format
msgid ""
"Migration of &akonadi; alarm calendar resources on the first run of a new "
"version of &kalarm;."
msgstr ""
"&kalarm; के नए संस्करण के प्रथम रन पर &akonadi; अलार्म कैलेंडर संसाधनों का स्थानांतरण।"

#. Tag: para
#: index.docbook:5111
#, no-c-format
msgid ""
"If the plugin is installed, it can be enabled or disabled in the <link "
"linkend=\"preferences-general\">General</link> tab of the Configuration "
"dialog."
msgstr ""
"यदि प्लगइन स्थापित है, तो इसे सक्षम या अक्षम किया जा सकता है<link linkend="
"\"preferences-general\"> सामान्य</link> कॉन्फ़िगरेशन संवाद के टैब पर क्लिक करें."

#. Tag: para
#: index.docbook:5119
#, no-c-format
msgid "What is the program <application>kalarmautostart</application>?"
msgstr "<application>kalarmautostart</application> प्रोग्राम क्या है?"

#. Tag: para
#: index.docbook:5122
#, no-c-format
msgid ""
"<application>kalarmautostart</application> is a little helper program whose "
"function is to autostart &kalarm; at login."
msgstr ""
"<application>kalarmautostart</application> एक छोटा सहायक प्रोग्राम है जिसका "
"कार्य लॉगइन पर &kalarm; को स्वचालित रूप से प्रारंभ करना है।"

#. Tag: para
#: index.docbook:5125
#, no-c-format
msgid ""
"&kalarm; is usually restored by the session manager at login (to redisplay "
"its windows in the same state as they were when you logged off). But if it "
"was not running when you logged off, it would not be started by the session "
"manager and therefore needs to be autostarted. The problem is that when an "
"application is both session managed and autostarted, there is no guarantee "
"as to which will occur first. If autostart gets in first, it will prevent "
"the session manager from restoring the application's state."
msgstr ""
"&kalarm; को आम तौर पर लॉग इन करने पर सत्र प्रबंधक द्वारा बहाल किया जाता है (इसकी "
"विंडो को उसी स्थिति में पुनः प्रदर्शित करने के लिए जैसा कि आपने लॉग ऑफ करते समय किया "
"था)। लेकिन अगर यह लॉग ऑफ करते समय नहीं चल रहा था, तो इसे सत्र प्रबंधक द्वारा शुरू नहीं "
"किया जाएगा और इसलिए इसे ऑटोस्टार्ट करने की आवश्यकता है। समस्या यह है कि जब कोई "
"एप्लिकेशन सत्र प्रबंधित और ऑटोस्टार्ट दोनों होता है, तो इस बात की कोई गारंटी नहीं होती "
"है कि पहले कौन होगा। यदि ऑटोस्टार्ट पहले आता है, तो यह सत्र प्रबंधक को एप्लिकेशन की "
"स्थिति को बहाल करने से रोक देगा।"

#. Tag: para
#: index.docbook:5134
#, no-c-format
msgid ""
"To avoid this problem, <application>kalarmautostart</application> is "
"autostarted at login instead of &kalarm;. All it does is wait for a short "
"time (to ensure that the session manager has time to do its job) before "
"starting &kalarm;, at which point it terminates."
msgstr ""
"इस समस्या से बचने के लिए, <application>kalarmautostart</application> को लॉगिन पर "
"&kalarm; के बजाय ऑटोस्टार्ट किया जाता है। यह केवल &kalarm; शुरू करने से पहले थोड़े समय "
"तक प्रतीक्षा करता है (यह सुनिश्चित करने के लिए कि सत्र प्रबंधक को अपना काम करने का समय "
"मिल जाए), जिसके बाद यह समाप्त हो जाता है।"

#. Tag: para
#: index.docbook:5144
#, no-c-format
msgid "How can I use &kalarm; on a non-&plasma; desktop?"
msgstr "मैं &kalarm; का उपयोग गैर-&plasma; डेस्कटॉप पर कैसे कर सकता हूँ?"

#. Tag: para
#: index.docbook:5147
#, no-c-format
msgid ""
"To run &kalarm; on a non-&plasma; desktop, the main requirement is to ensure "
"that &kalarm; is run automatically whenever you log in. More detailed "
"instructions are contained in the <filename>INSTALL</filename> file which is "
"distributed with &kalarm;."
msgstr ""
"किसी गैर-&plasma; डेस्कटॉप पर &kalarm; चलाने के लिए, मुख्य आवश्यकता यह सुनिश्चित करना "
"है कि जब भी आप लॉग इन करें तो &kalarm; स्वचालित रूप से चले। अधिक विस्तृत निर्देश "
"<filename>INSTALL</filename> फ़ाइल में निहित हैं जो &kalarm; के साथ वितरित की जाती "
"है।"

