msgstr "<guimenu>गेम</guimenu> <guimenuitem>नया</guimenuitem>"

#. Tag: entry
#: index.docbook:251
#, no-c-format
msgid ""
"Starts a new game. If a game is currently played clears the field and sets "
"the level to 1."
msgstr ""
"एक नया खेल शुरू होता है। यदि वर्तमान में कोई खेल खेला जा रहा है तो फ़ील्ड को साफ़ कर देता "
"है और स्तर को 1 पर सेट कर देता है।"

#. Tag: phrase
#: index.docbook:264
#, no-c-format
msgid "Pause Button"
msgstr "पॉज़ बटन"

#. Tag: guiicon
#: index.docbook:269
#, no-c-format
msgid "Pause"
