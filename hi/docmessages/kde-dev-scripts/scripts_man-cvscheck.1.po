#, no-c-format
msgid "Authors"
msgstr "लेखक"

#. Tag: para
#: man-cvscheck.1.docbook:124
#, no-c-format
msgid ""
"cvscheck was written by &Dirk.Mueller; &Dirk.Mueller.mail; and &Sirtaj.Singh."
"Kang; &Sirtaj.Singh.Kang.mail;"
msgstr ""
"cvscheck को &Dirk.Mueller; &Dirk.Mueller.mail; और &Sirtaj.Singh.Kang; "
"&Sirtaj.Singh.Kang.mail; द्वारा लिखा गया था"

#. Tag: para
#: man-cvscheck.1.docbook:127
#, no-c-format
msgid ""
"This manual page was prepared by <personname><firstname>Ben</firstname> "
"<surname>Burton</surname></personname> <email>bab@debian.org</email> for the "
"Debian GNU/Linux system (but may be used by others)."
msgstr ""
"यह मैनुअल पृष्ठ <personname><firstname>Ben</firstname> <surname>Burton</"
"surname></personname> <email>bab@debian.org</email> द्वारा Debian GNU/Linux "
"सिस्टम के लिए तैयार किया गया था (लेकिन इसका उपयोग अन्य लोगों द्वारा भी किया जा सकता "
"है)।"
