#. (itstool) path: component/name
#: org.kde.kmousetool.appdata.xml:9
msgid "KMouseTool"
msgstr "KMouseTool"

#. (itstool) path: component/summary
#: org.kde.kmousetool.appdata.xml:10
msgid "Automatic clicks to reduce the effects of repetitive strain injury"
msgstr ""
"Hiiren automaattinapsautukset rasitusvammojen vaikutusten vähentämiseksi"

#. (itstool) path: description/p
#: org.kde.kmousetool.appdata.xml:12
msgid ""
"KMouseTool clicks the mouse for you, so you don't have to. KMouseTool works "
"with any mouse or pointing device."
msgstr ""
"KMouseTool napsauttaa hiirtä puolestasi, jottei sinun tarvitse. KMouseTool "
"toimii kaikilla hiirillä ja osoitinlaitteilla."

#~ msgid "Automatic Mouse Click"
#~ msgstr "Automaattinen hiiren napsautus"
