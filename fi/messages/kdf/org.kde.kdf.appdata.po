msgid "KDiskFree"
msgstr "KDiskFree"

#. (itstool) path: component/summary
#: org.kde.kdf.appdata.xml:10
msgid "View Disk Usage"
msgstr "Näytä levynkäyttö"

#. (itstool) path: description/p
#: org.kde.kdf.appdata.xml:12
msgid ""
"KDiskFree displays the available file devices (hard drive partitions, floppy "
"and CD drives, etc.) along with information on their capacity, free space, "
"type and mount point. It also allows you to mount and unmount drives and "
"view them in a file manager."
msgstr ""
"KDiskFree näyttää saatavilla olevat tiedostolaitteet (kiintolevyosiot, "
"levyke- ja CD-asemat jne.) tietoineen: kapasiteetti, vapaa tila, tyyppi ja "
"liitospiste. Se antaa myös liittää ja irrottaa asemia ja katsoa niitä "
"tiedostonhallinnassa."

