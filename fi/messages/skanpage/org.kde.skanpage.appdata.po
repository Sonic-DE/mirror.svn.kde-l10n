msgstr "Kuvanluku taso- ja ADF-skannereilta"

#. (itstool) path: ul/li
#: org.kde.skanpage.appdata.xml:21
msgid "Configurable options for scanning device"
msgstr "Kuvanlukulaitteiden mukautettavat asetukset"

#. (itstool) path: ul/li
