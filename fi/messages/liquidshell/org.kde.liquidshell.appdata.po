#. (itstool) path: component/name
#: org.kde.liquidshell.appdata.xml:4
msgid "liquidshell"
msgstr "liquidshell"

#. (itstool) path: component/summary
#. (itstool) path: description/p
#: org.kde.liquidshell.appdata.xml:5 org.kde.liquidshell.appdata.xml:10
msgid "liquidshell is an alternative to plasmashell"
msgstr "liquidshell on plasmashellin vaihtoehto"

#. (itstool) path: description/p
#: org.kde.liquidshell.appdata.xml:11
msgid ""
"It does not use QtQuick but instead relies on QtWidgets, therefore no "
"hardware graphics acceleration is needed."
msgstr ""
"Se ei käytä QtQuickiä vaan luottaa QtWidgetsiin, joten se ei vaadi "
"laitteistokiihdytystä."

#. (itstool) path: description/p
#: org.kde.liquidshell.appdata.xml:13
msgid "Main Features:"
msgstr "Keskeiset ominaisuudet:"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:15
msgid "Wallpaper per virtual desktop"
msgstr "Virtuaalityöpöydittäiset taustakuvat"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:16
msgid "No animations, no CPU hogging, low Memory footprint"
msgstr "Ei animointeja tai suorittimen rohmuamista; vähäinen muistinkulutus"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:17
msgid "Instant startup"
msgstr "Välitön käynnistys"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:18
msgid "No use of activities"
msgstr "Ei käytä aktiviteetteja"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:19
msgid "QtWidgets based, therefore follows widget style from systemsettings"
msgstr ""
"Perustuu QtWidgetsiin, joten noudattaa järjestelmäasetusten "
"käyttöliittymäalkiotyyliä"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:20
msgid ""
"Icons are used from your globally defined icon theme from systemsettings"
msgstr ""
"Käyttää järjestelmäasetuksissa määritetyn yleisen kuvaketeeman kuvakkeita"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:21
msgid ""
"Colors are used from your globally defined color theme from systemsettings"
msgstr "Käyttää järjestelmäasetuksissa määritettyjä yleisiä väriasetuksia"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:22
msgid ""
"Can additionally be styled with css by passing the commandline option -"
"stylesheet filename.css (see included example stylesheet.css)"
msgstr ""
"Tyyliä voi vielä CSS:llä muokata komentorivivalitsinta ”-stylesheet tiedosto."
"css” käyttäen (ks. esimerkkitiedostoa stylesheet.css)"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:23
msgid ""
"uses existing KDE dialogs for most configurations, e.g. StartMenu, Virtual "
"Desktops, Bluetooth, Network"
msgstr ""
"Käyttää useimmiten olemassa olevia KDE-valintaikkunoita, esim. "
"käynnistysvalikko, virtuaalityöpöydät, Bluetooth, verkko"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:24
