#. (itstool) path: component/name
#: org.kde.kgraphviewer.appdata.xml:9
msgid "KGraphViewer"
msgstr "KGraphViewer"

#. (itstool) path: component/summary
#: org.kde.kgraphviewer.appdata.xml:10
msgid "A Graphviz DOT graph viewer"
msgstr "Graphviz DOT -graafikatselin"

#. (itstool) path: description/p
#: org.kde.kgraphviewer.appdata.xml:12
msgid ""
"KGraphViewer is a Graphviz DOT graph file viewer, aimed to replace the other "
"outdated Graphviz tools. Graphs are commonly used in scientific domains and "
"particularly in computer science."
msgstr ""
"KGraphViewer on Graphviz DOT -graafitiedostokatselin, jonka tavoitteena on "
"korvata vanhentuneet GraphViz-työkalut. Graafeja käytetään usein "
"tieteellisillä aloilla ja erityisesti tietojenkäsittelyssä."

#. (itstool) path: description/p
#: org.kde.kgraphviewer.appdata.xml:16
msgid "Features:"
msgstr "Ominaisuudet:"

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:18
msgid "Zooming"
msgstr "Suurennus"

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:19
msgid "Threaded loading of several graphs in tabs"
msgstr "Useamman graafin säikeistetty lataus välilehtiin"

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:20
msgid "Saving of the recent files list"
msgstr "Viimeaikaisten tiedostojen luettelon tallennus"

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:21
msgid "Manual reload of files"
msgstr "Tiedostojen uudelleenlataus käsin"

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:22
msgid "Display of a bird-eye view of the graph"
msgstr "Graafin näyttö lintuperspektiivissä"

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:23
msgid "Moving of the graph by dragging"
msgstr "Graafin siirto vetämällä"

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:24
msgid "Full featured printing"
msgstr "Tulostus kaikilla ominaisuuksilla"

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:25
msgid "Perfect drawing of all graphviz example graphs"
msgstr "Kaikkien graphviz-esimerkkigraafien täydellinen piirto"

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:26
msgid "Automatically choose dot for directed graphs and neato for undirected"
msgstr ""
"Valitse dot automaattisesti suunnatuille graafeille ja neato "
"suuntaamattomille"

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:27
msgid ""
"Possibility to use an arbitrary layout algorithm as soon as it produces xdot "
"format"
msgstr ""
"Mahdollisuus käyttää mitä tahansa asettelualgoritmia, kunhan se tuottaa xdot-"
"muotoa"

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:28
msgid ""
"Automatic reloading with user confirmation of (externally) modified files "
"(configurable)"
msgstr ""
"Automaattinen uudelleenlataus mutta käyttäjä vahvistaa (ulkoisesti) "
"muuttuneet tiedostot (mukautettavissa)"

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:29
msgid "Open new instances as new tabs in the old one (configurable)"
msgstr ""
"Avaa uudet instanssit uusiksi välilehdiksi vanhaan instanssiin "
"(mukautettavissa)"
