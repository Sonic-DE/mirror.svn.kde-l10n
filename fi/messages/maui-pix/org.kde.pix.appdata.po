#. (itstool) path: component/name
#: org.kde.pix.appdata.xml:7
msgid "Pix"
msgstr "Pix"

#. (itstool) path: component/summary
#: org.kde.pix.appdata.xml:8
msgid "Image Gallery"
msgstr "Kuvagalleria"

#. (itstool) path: description/p
#: org.kde.pix.appdata.xml:14
msgid ""
"Pix is an image gallery and image viewer. Pix can be used to open images "
"with other applications like an image editor, add tags to the files, add "
"annotations to pictures, rotate and share them."
msgstr ""
"Pix on kuvagalleria ja -katselin. Pixiä voi käyttää avaamaan toisten "
"sovellusten kuten kuvankäsittelyohjelmien kuvat, lisäämään kuviin "
"luokituksia ja merkintöjä sekä kääntämään ja jakamaan kuvia."

