#: org.kde.kcalc.desktop:80
msgctxt "Comment"
msgid ""
"Calculator which offers many mathematical functions, such as trigonometric "
"functions, logic operations, and statistical calculations"
msgstr ""
"Laskin, joka tarjoaa monia matemaattisia funktioita kuten trigonometriset "
"funktiot, loogiset operaatiot ja tilastolaskennan"

#: org.kde.kcalc.desktop:125
msgctxt "GenericName"
msgid "Scientific Calculator"
msgstr "Tieteellinen laskin"
