msgctxt "Name"
msgid "Tokodon"
msgstr "Tokodon"

#: org.kde.tokodon.desktop:44
msgctxt "GenericName"
msgid "Browse the Fediverse"
msgstr "Selaa fediversumia"

#: org.kde.tokodon.desktop:76
msgctxt "Comment"
msgid "Client for the Mastodon"
msgstr "Mastodon-asiakas"

#: src/tokodon.notifyrc:46
msgctxt "Comment"
msgid "A client for Mastodon, the decentralized social media"
msgstr "Asiakas Mastodonille, hajautetulle sosiaaliselle medialle"

#: src/tokodon.notifyrc:82
msgctxt "Name"
msgid "Favorite"
msgstr "Merkitse suosikiksi"

#: src/tokodon.notifyrc:118
msgctxt "Comment"
msgid "Someone favorited your post"
msgstr "Julkaisusi merkittiin suosikiksi"

# Tämä on (hyvässä ja huonossa!) Mastodonin WWW-käyttöliittymässä käytetty käännös
#: src/tokodon.notifyrc:154
msgctxt "Name"
msgid "Boost"
msgstr "Tehosta"

#: src/tokodon.notifyrc:188
msgctxt "Comment"
msgid "Someone boosted your post"
msgstr "Julkaisusi tehostettiin"

#: src/tokodon.notifyrc:225 src/tokodon.notifyrc:364
msgctxt "Name"
msgid "Follow"
msgstr "Seuraa"

#: src/tokodon.notifyrc:261
msgctxt "Comment"
msgid "Someone followed you"
msgstr "Joku seurasi sinua"

#: src/tokodon.notifyrc:298
msgctxt "Name"
msgid "Follow Request"
