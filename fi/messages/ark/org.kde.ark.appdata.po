msgid "Features:"
msgstr "Ominaisuudet:"

#. (itstool) path: ul/li
#: org.kde.ark.appdata.xml:21
msgid "Several formats supported: gzip, bzip2, zip, rar, 7z and more"
msgstr "Tukee useita tiedostomuotoja: gzip, bzip2, zip, rar, 7z ja monia muita"

#. (itstool) path: ul/li
#: org.kde.ark.appdata.xml:22
