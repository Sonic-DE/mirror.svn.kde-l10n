#. (itstool) path: component/name
#: org.kde.dragonplayer.appdata.xml:9
msgid "Dragon Player"
msgstr "Dragon Player"

#. (itstool) path: component/summary
#: org.kde.dragonplayer.appdata.xml:10
msgid "Play video files and streams"
msgstr "Toista videotiedostoja ja suoratoistovirtoja"

#. (itstool) path: description/p
#: org.kde.dragonplayer.appdata.xml:12
msgid ""
"Dragon Player is a video player focusing on simplicity instead of features. "
"Its easy-to-use interface is designed to get out of your way and simply play "
"your video files and streams."
msgstr ""
"Dragon Player on videosoitin, joka keskittyy ominaisuuksien sijaan "
"yksinkertaisuuteen. Sen helppokäyttöinen käyttöliittymä on suunniteltu "
"pysymään poissa tieltä toistaessasi videotiedostoja ja suoratoistovirtoja."

#. (itstool) path: description/p
#: org.kde.dragonplayer.appdata.xml:15
msgid "Features:"
msgstr "Ominaisuudet:"

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:17
msgid ""
"Click to play or pause, and double-click to enter or exit full screen mode."
msgstr ""
"Toista tai keskeytä napsauttamalla ja siirry koko näytön tilaan tai poistu "
"siitä kaksoisnapsautuksella."

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:18
msgid ""
"Choose the subtitle language, and automatically load the right one for your "
"language, if possible."
msgstr "Valitse tekstityskieli ja yritä automaattisesti ladata oikea."

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:19
msgid "Choose the audio track."
msgstr "Valitse ääniraita."

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:20
msgid "Choose the video track."
msgstr "Valitse videoraita."

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:21
msgid "Adjust the volume by scrolling."
msgstr "Säädä äänenvoimakkuutta vierittämällä."

#~ msgid "Video player with focus on simplicity"
#~ msgstr "Yksinkertaisuuteen pyrkivä videosoitin"

#~ msgid "Simple Interface"
#~ msgstr "Yksinkertainen käyttöliittymä"

#~ msgid ""
#~ "Resuming videos: Starts playing a video where you were watching it last "
#~ "time"
#~ msgstr "Videoiden jatkaminen: käynnistä video siitä, mihin viimeksi jäit"

#~ msgid ""
#~ "Support for subtitles: Automatically loads subtitles with the matching "
#~ "name"
#~ msgstr ""
#~ "Tekstityksen tuki: lataa samannimiset tekstitystiedostot automaattisesti"

#~ msgid "Video display settings (brightness, contrast)"
#~ msgstr "Videonäytön asetukset (kirkkaus ja kontrasti)"

#~ msgid ""
#~ "Due to using Solid and Phonon DragonPlayer is independent of any "
#~ "multimedia framework or hardware abstraction layer"
#~ msgstr ""
#~ "Solidin ja Phononin ansiosta Dragon Player ei ole riippuvainen muista "
#~ "multimediakirjastoista tai laitteistosta"

#~ msgid "Supports playing CDs and DVDs"
#~ msgstr "Tukee CD- ja DVD-toistoa"
