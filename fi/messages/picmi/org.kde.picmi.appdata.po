#. (itstool) path: component/name
#: org.kde.picmi.appdata.xml:14
msgid "Picmi"
msgstr "Picmi"

#. (itstool) path: component/summary
#: org.kde.picmi.appdata.xml:15
msgid "Puzzle game based on number logic"
msgstr "Lukulogiikkaan perustuva arvoituspeli"

#. (itstool) path: description/p
#: org.kde.picmi.appdata.xml:17
msgid ""
"The goal is to reveal the hidden pattern in the board by coloring or leaving "
"blank the cells in a grid according to numbers given at the side of the "
"grid. This is a single player game."
msgstr ""
"Tavoitteena on paljastaa laudan salainen hahmo värittämällä tai jättämällä "
"tyhjiksi ruudukon soluja sen sivulla annettujen lukujen mukaan. Tämä on "
"yksinpeli."
