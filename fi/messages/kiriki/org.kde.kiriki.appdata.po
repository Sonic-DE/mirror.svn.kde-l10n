#. (itstool) path: component/name
#: org.kde.kiriki.appdata.xml:9
msgid "Kiriki"
msgstr "Kiriki"

#. (itstool) path: component/summary
#: org.kde.kiriki.appdata.xml:10
msgid "Yahtzee-like Dice Game"
msgstr "Yatzy-mainen noppapeli"

#. (itstool) path: description/p
#: org.kde.kiriki.appdata.xml:12
msgid ""
"Kiriki is an addictive and fun dice game, designed to be played by as many "
"as six players. Participants have to collect points by rolling five dice for "
"up to three times per single turn."
msgstr ""
"Kiriki on hauska ja koukuttava noppapeli, joka on suunniteltu jopa kuudelle "
"pelaajalle. Pelaajat keräävät pisteitä heittämällä viittä noppaa enintään "
"kolmesti kullakin vuorolla."
