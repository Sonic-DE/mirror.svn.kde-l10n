#~ "Skripti torrentien automaattiseen poistoon, kun niiden lataus tai "
#~ "jakaminen on valmistunut"

#~ msgctxt "Name"
#~ msgid "Automatic Resume"
#~ msgstr "Automaattinen jatkaminen"

#~ msgctxt "Comment"
#~ msgid ""
#~ "Script to automatically resume after some time, when the suspended state "
