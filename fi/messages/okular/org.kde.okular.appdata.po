#. (itstool) path: component/name
#: org.kde.okular.appdata.xml:7
msgid "Okular"
msgstr "Okular"

#. (itstool) path: component/summary
#: org.kde.okular.appdata.xml:8
msgid "View and annotate documents"
msgstr "Lue tiedostoja ja tee niihin merkintöjä"

#. (itstool) path: description/p
#: org.kde.okular.appdata.xml:10
msgid ""
"Okular is a universal document viewer developed by KDE. Okular works on "
"multiple platforms, including but not limited to Linux, Windows, Mac OS X, "
"*BSD, etc."
msgstr ""
"Okular on KDE:n kehittämä yleiskäyttöinen asiakirjakatselin. Okular toimii "
"useissa ympäristöissä kuten Linuxissa, Windowsissa, Mac OS X:ssä, *BSD:ssä "
"jne."

#. (itstool) path: description/p
#: org.kde.okular.appdata.xml:13
msgid "Features:"
msgstr "Ominaisuuksia:"

#. (itstool) path: ul/li
#: org.kde.okular.appdata.xml:15
msgid ""
"Supported Formats: PDF, PS, Tiff, DjVu, Images, DVI, XPS, Fiction Book, "
"Comic Book, Plucker, EPub, Fax"
msgstr ""
"Tuetut tiedostomuodot: PDF, PS, TIFF, DjVu, kuvatiedostot, DVI, XPS, "
"FictionBook, sarjakuvakirjat, Plucker, EPub, faksit"

#. (itstool) path: ul/li
#: org.kde.okular.appdata.xml:16
msgid "Sidebar with contents, thumbnails, reviews and bookmarks"
msgstr "Sivupaneeli, jossa sisältö, pienoiskuvat, tarkastelut ja kirjanmerkit"

#. (itstool) path: ul/li
#: org.kde.okular.appdata.xml:17
msgid "Annotations support"
msgstr "Merkintöjen tuki"

#. (itstool) path: screenshot/caption
#: org.kde.okular.appdata.xml:22
msgid "Reading manual in Okular"
msgstr "Oppaan lukeminen Okularissa"

