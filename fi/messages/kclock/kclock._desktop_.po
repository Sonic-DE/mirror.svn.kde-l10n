msgid "A simple clock application in Kirigami."
msgstr "Yksinkertainen Kirigami-kellosovellus."

#: org.kde.kclock.desktop.in:54
msgctxt "Comment"
msgid "Set alarms and timers, use a stopwatch, and manage world clocks"
msgstr ""
"Aseta hälytyksiä ja ajastuksia, käytä sekuntikelloa ja hallitse "
"maailmankelloa"

