#: kclock-runner.desktop:5
msgctxt "Name|plasma runner"
msgid "Clock"
msgstr "Kello"

#: kclock-runner.desktop:39
msgctxt "Comment"
msgid "Find timers and start/stop them"
msgstr "Etsi ajastimia ja käynnistä tai pysäytä niitä"

#: kclock-runner.desktop:84
msgctxt "X-Plasma-Runner-Syntax-Descriptions"
msgid ""
"Finds timers whose name match :q:,Lists all timers and allows to start/stop "
"them.,Lists all alarms and allows to enable/disable them."
msgstr ""
"Etsi ajastimia, joiden nimi vastaa hakua :q:,Luettelee kaikki ajastimet ja "
"antaa käynnistää ja pysäyttää niitä.,Luettelee kaikki hälytykset ja antaa "
"ottaa niitä käyttöön tai poistaa käytöstä."

#: org.kde.kclockd-autostart.desktop:53
