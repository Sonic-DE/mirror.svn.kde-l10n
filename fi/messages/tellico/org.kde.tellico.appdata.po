#. (itstool) path: component/name
#: org.kde.tellico.appdata.xml:9
msgid "Tellico"
msgstr "Tellico"

#. (itstool) path: component/summary
#: org.kde.tellico.appdata.xml:10
msgid "Collection Manager"
msgstr "Kokoelmahallinta"

#. (itstool) path: description/p
#: org.kde.tellico.appdata.xml:12
msgid ""
"Tellico is an application for organizing your collections. It provides "
"default templates for books, bibliographies, videos, music, video games, "
"coins, stamps, trading cards, comic books, and wines. It allows you to enter "
"your collection in a catalogue database, saving many different properties "
"like title, author, etc."
msgstr ""
"Tellico on sovellus kokoelmiesi järjestämiseen. Se tarjoaa oletusmallit "
"kirjoille, lähdeluetteloille, videoille, musiikille, videopeleille, "
"kolikoille, postimerkeille, keräilykorteille, sarjakuville ja viineille. Sen "
"avulla voit syöttää kokoelmasi luettelotietokantaan eri ominaisuudet kuten "
"otsikon, tekijän jne. säilyttäen."

#. (itstool) path: description/p
#: org.kde.tellico.appdata.xml:17
msgid "Features:"
msgstr "Ominaisuuksia:"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:19
msgid ""
"Supports default collections of books, bibliographic entries, videos, music, "
"video games, comic books, coins, stamps, trading cards, wines, board games, "
"and file catalogs"
msgstr ""
"Tukee kirjojen, lähdeluettelotietueiden, videoiden, musiikin, videopelien, "
"sarjakuvien, kolikoiden, postimerkkien, keräilykuvien, viinien, lautapelien "
"ja tiedostoluettelojen oletuskokoelmia"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:20
msgid "Supports user-defined custom collections"
msgstr "Tukee käyttäjän mukauttamia kokoelmia"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:21
msgid ""
"Supports any number of user-defined fields, of several different types: "
"text, paragraph, list, checkbox, number, URL, date, images, and combinations"
msgstr ""
"Tukee rajattomasti käyttäjän määrittämiä useamman tyypin kenttiä (teksti, "
"kappale, luettelo, valintaruutu, luku-, verkko-osoite, päiväys, kuvat ja "
"niiden yhdistelmät)"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:22
msgid "Handles entries with multiple authors, genres, keywords, etc"
msgstr ""
"Käsittelee tietueet, joissa on useampia tekijöitä, tyylilajeja, avainsanoja "
"jne."

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:23
msgid "Automatically formats titles and names"
msgstr "Muotoilee otsikot ja nimet automaattisesti"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:24
msgid "Supports collection searching and view filtering"
msgstr "Tukee kokoelmien hakua ja näkymien suodatusta"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:25
msgid "Sorts and groups collection by various properties"
msgstr "Lajittelee ja ryhmittelee kokoelmia eri ominaisuuksien mukaan"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:26
msgid "Allows customizable entry templates through XSLT"
msgstr "Sallii mukautetut tietuemallit XSLT:n avulla"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:27
msgid "Imports MODS, Bibtex, RIS, CSV, PDF metadata, and many other formats"
msgstr ""
"Tuo MODS-, BibTeX-, RIS-, CSV-, PDF-metatieto- ja muista tiedostomuodoista"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:28
msgid "Exports to Bibtex, ONIX, CSV, HTML, and other formats"
msgstr "Vie BibTeX-, ONIX-, CSV-, HTML- ja muihin tiedostomuotoihin"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:29
msgid ""
"Imports information directly from Amazon.com, IMDb, z39.50 servers, PubMed, "
"SRU servers, CrossRef.org, various other websites, and from external scripts"
msgstr ""
"Tuo tietoa suoraan Amazon.comista, IMDb:stä, z39.50-palvelimilta, "
"PubMedistä, SRU-palvelimilta, CrossRef.orgista, muilta verkkosivuilta ja "
"ulkoisista skripteistä"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:30
msgid "Imports CDDB data for cataloging audio CDs"
msgstr "Tuo ääni-CD:iden luokitteluun tarvittavat CDDB-tiedot"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:31
msgid "Scans and imports audio file collections, such as mp3 or ogg"
msgstr "Etsii ja tuo äänitiedostojen kuten MP3:ten ja Oggien kokoelmia"

