#. (itstool) path: component/name
#: org.kde.kamoso.appdata.xml:11
msgid "Kamoso"
msgstr "Kamoso"

#. (itstool) path: component/summary
#: org.kde.kamoso.appdata.xml:12
msgid "Use your webcam to take pictures and make videos"
msgstr "Ota kuvia ja tee videoita web-kamerallasi"

#. (itstool) path: description/p
#: org.kde.kamoso.appdata.xml:14
msgid ""
"Kamoso is a simple and friendly program to use your camera. Use it to take "
"pictures and make videos to share."
msgstr ""
"Kamoso on yksinkertainen ja helppo ohjelma kameran käyttöön. Voit ottaa "
"sillä jaettavia kuvia ja videoita."

#. (itstool) path: screenshot/caption
#: org.kde.kamoso.appdata.xml:21
msgid "Kamoso main window"
msgstr "Kamoson pääikkuna"

#~ msgid ""
#~ "Kamoso is a great program to use your webcam to take pictures or make "
#~ "videos. It probably should be the best webcam recorder for Linux. This "
#~ "guide will help you use Kamoso once you have installed it. We tried to "
#~ "make it simple and friendly."
#~ msgstr ""
#~ "Kamoso on ohjelma kuvien ottamiseen ja videoiden tekemiseen "
#~ "nettikameralla. Se on todennäköisesti yksi parhaista nettikameran kuvaa "
#~ "tallentavista ohjelmista, jotka on Linuxille."
