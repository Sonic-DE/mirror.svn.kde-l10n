#: kcm_sddm.actions:2
msgctxt "Name"
msgid "SDDM"
msgstr "SDDM"

#: kcm_sddm.actions:58
msgctxt "Name"
msgid "Save Settings"
msgstr "Tallenna asetukset"

#: kcm_sddm.actions:109
msgctxt "Description"
msgid "Save Settings in SDDM"
msgstr "Tallenna SDDM-asetukset"

#: kcm_sddm.actions:163
msgctxt "Name"
msgid "Install an SDDM theme"
msgstr "Asenna SDDM-teema"

#: kcm_sddm.actions:213
msgctxt "Description"
msgid "Extract a zip file containing an SDDM theme to the SDDM theme location"
msgstr "Pura SDDM-teeman sisältävä Zip-tiedosto SDDM-teemakansioon"

#: kcm_sddm.actions:254
msgctxt "Name"
msgid "Uninstall an SDDM theme"
msgstr "Poista SDDM-teema"

#: kcm_sddm.actions:304
msgctxt "Description"
msgid "Remove a previously installed SDDM theme"
msgstr "Poista aiemmin asennettu SDDM-teema"

#: kcm_sddm.actions:345
msgctxt "Name"
msgid "Synchronize Settings"
msgstr "Synkronoi asetukset"

#: kcm_sddm.actions:391
msgctxt "Description"
msgid "Synchronize user settings with SDDM settings"
msgstr "Tahdista käyttäjän ja SDDM:n asetukset"

#: kcm_sddm.actions:432
msgctxt "Name"
msgid "Reset Settings"
msgstr "Alusta asetukset"

#: kcm_sddm.actions:478
msgctxt "Description"
msgid "Reset SDDM settings to factory default state"
msgstr "Palauta SDDM-asetukset tehdasoletuksikseen"

