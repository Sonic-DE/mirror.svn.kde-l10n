#: org.kde.sweeper.desktop:75
msgctxt "GenericName"
msgid "System Cleaner"
msgstr "Järjestelmän puhdistus"

#: org.kde.sweeper.desktop:142
msgctxt "Comment"
msgid ""
"Helps to clean unwanted traces the user leaves on the system and to regain "
"disk space removing unused temporary files"
msgstr ""
"Auttaa poistamaan käyttäjän järjestelmään jättämät turhat jäljet sekä "
"lisäämään levytilaa poistamalla vanhat väliaikaistiedostot"
