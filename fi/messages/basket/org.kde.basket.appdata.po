#. (itstool) path: component/name
#: org.kde.basket.appdata.xml:10
msgid "Basket"
msgstr "Basket"

#. (itstool) path: component/summary
#: org.kde.basket.appdata.xml:11
msgid "Notes and to-dos organizer"
msgstr "Muistiinpano- ja tehtäväjärjestäjä"

#. (itstool) path: description/p
#: org.kde.basket.appdata.xml:13
msgid ""
"This application provides as many baskets as you wish, and you can drag and "
"drop."
msgstr ""
"Sovellus tarjoaa niin monta koria kuin haluat, ja se tukee vetämistä ja "
"pudottamista."

#. (itstool) path: description/p
#: org.kde.basket.appdata.xml:14
msgid ""
"Objects can be edited, copied, dragged... So, you can arrange them as you "
"want !"
msgstr ""
"Kohteita voi muokata, kopioida, vetää… Voit siis järjestää niitä miten "
"haluat!"

#. (itstool) path: description/p
#: org.kde.basket.appdata.xml:15
msgid "It allows to arrange notes, track to-dos and much more."
msgstr ""
"Muistiinpanoja voi järjestää, tehtävien etenemistä seurata ja paljon muuta."

#~ msgid "KDE Community"
#~ msgstr "KDE-yhteisö"
