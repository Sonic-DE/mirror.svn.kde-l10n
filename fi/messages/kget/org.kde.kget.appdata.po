#. (itstool) path: component/name
#: org.kde.kget.appdata.xml:9
msgid "KGet"
msgstr "KGet"

#. (itstool) path: component/summary
#: org.kde.kget.appdata.xml:10
msgid "Download manager"
msgstr "Lataustenhallinta"

#. (itstool) path: description/p
#: org.kde.kget.appdata.xml:12
msgid "KGet is a versatile and user-friendly download manager."
msgstr "KGet on monipuolinen ja käyttäjäystävällinen lataustenhallintaohjelma."

#. (itstool) path: description/p
#: org.kde.kget.appdata.xml:15
msgid "Features:"
msgstr "Ominaisuudet:"

#. (itstool) path: ul/li
#: org.kde.kget.appdata.xml:17
msgid "Downloading files from FTP and HTTP(S) sources."
msgstr "Tiedostojen lataus FTP- ja HTTP(S)-lähteistä."

#. (itstool) path: ul/li
#: org.kde.kget.appdata.xml:18
msgid ""
"Pausing and resuming of downloading files, as well as the ability to restart "
"a download."
msgstr ""
"Tiedostojen latauksen keskeytys ja jatkaminen kuten myös latauksen "
"uudelleenkäynnistys."

#. (itstool) path: ul/li
#: org.kde.kget.appdata.xml:19
msgid "Tells lots of information about current and pending downloads."
msgstr "Antaa runsaasti tietoa käynnistä olevasta ja odottavista latauksista."

#. (itstool) path: ul/li
#: org.kde.kget.appdata.xml:20
msgid "Embedding into system tray."
msgstr "Upotus järjestelmän ilmoitusalueelle."

#. (itstool) path: ul/li
#: org.kde.kget.appdata.xml:21
msgid "Integration with the Konqueror web browser."
msgstr "Yhdistyy Konqueror-verkkoselaimeen."

#. (itstool) path: ul/li
#: org.kde.kget.appdata.xml:22
msgid ""
"Metalink support which contain multiple URLs for downloads, along with "
"checksums and other information."
msgstr ""
"Tukee metalinkkejä, jotka sisältävät useampia latauslinkkejä "
"tarkistussummineen ja muine tietoineen."

#. (itstool) path: screenshot/caption
#: org.kde.kget.appdata.xml:31
msgid "Downloading files with KGet"
msgstr "Tiedostojen lataaminen KGetillä"
