#: org.kde.systemdgenie.metainfo.xml:11
msgid "systemdGenie"
msgstr "systemdGenie"

#. (itstool) path: component/summary
#: org.kde.systemdgenie.metainfo.xml:12
msgid "System service manager"
msgstr "Järjestelmäpalvelujen hallinta"

#. (itstool) path: description/p
#: org.kde.systemdgenie.metainfo.xml:14
msgid ""
"systemdGenie allows graphical management of systemd units, including user "
"units, and provides control over logind sessions. It also includes an "
"integrated text editor for easy modification of unit and configuration files."
msgstr ""
"systemdGenie mahdollistaa systemd-yksiköiden graafisen hallinnoinnin, myös "
"käyttäjän yksiköiden, ja tarjoaa logind-istuntojen hallinnan. Siihen "
"sisältyy tekstimuokkain, jolla yksiköiden ja asetustiedostojen muuttaminen "
"on helppoa."
