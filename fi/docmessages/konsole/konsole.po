#. Tag: programlisting
#: index.docbook:1883
#, no-c-format
msgid ""
"QTabBar::tab {\n"
"    min-width: 200px\n"
"}"
msgstr ""

#. Tag: para
#: index.docbook:1886
#, no-c-format
msgid "Only the selected tab will be at least 200 pixels in width"
msgstr ""

#. Tag: programlisting
#: index.docbook:1888
#, no-c-format
msgid ""
"QTabBar::tab::selected {\n"
"    min-width: 200px\n"
"}"
msgstr ""

#. Tag: para
#: index.docbook:1891
#, no-c-format
msgid "Any of these can be combined in one file"
msgstr ""

#. Tag: programlisting
#: index.docbook:1893
#, no-c-format
