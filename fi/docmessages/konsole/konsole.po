#~ msgid ""
#~ "It can be hidden and restored by toggling <guimenuitem>Show Toolbar</"
#~ "guimenuitem> in the <guimenu>Settings</guimenu> menu or by clicking the "
#~ "textured <quote>handle</quote> at the side of the bar. The bar contains a "
#~ "<guiicon>New</guiicon> icon and icons for the current sessions. Clicking "
#~ "<guiicon>New</guiicon> opens a new <quote>Shell</quote> session."
#~ msgstr ""
#~ "Voit piilottaa tai palauttaa sen valitsemalla <guimenu>Asetukset</"
#~ "guimenu>-valikosta <guimenuitem>Näytä työkalurivi</guimenuitem> tai "
#~ "napsauttamalla kuvioitua kohtaa työkalurivin reunasta. Työkalurivi "
#~ "sisältää <guiicon>Uusi</guiicon>-painikkeen ja painikkeet nykyisille "
#~ "istunnoille. Uuden komentotulkin saa avattua napsauttamalla "
#~ "<guiicon>Uusi</guiicon>-painiketta."

#~ msgid ""
#~ "Double-clicking a session tab opens a dialog box enabling you to change "
#~ "the name of that session. <keycombo action=\"simul\">&Alt;&Ctrl;"
#~ "<keycap>S</keycap> </keycombo> can also be used to rename the active "
#~ "session."
#~ msgstr ""
#~ "Voit nimetä istunnon uudelleen kaksoisnapsauttamalla istuntopainiketta "
#~ "tai käyttämällä <keycombo action=\"simul\">&Alt; &Ctrl;<keycap>S</keycap> "
#~ "</keycombo> -näppäinyhdistelmää aktiiviselle istunnolle."

#~ msgid "Clicking an existing session's icon makes that session active."
#~ msgstr "Istuntopainikkeen painaminen tekee kyseisen istunnon aktiiviseksi."

