msgstr ""
"<action>Avaa vianilmoittamisikkunan</action>, josta voit ilmoittaa viasta "
"tai lisätä ominaisuuden <quote>toivelistalle</quote>."

#. Tag: menuchoice
#: ui.docbook:1249
#, no-c-format
msgid "<guimenu>Help</guimenu> <guimenuitem>Donate</guimenuitem>"
msgstr ""

#. Tag: para
#: ui.docbook:1253
#, no-c-format
msgid ""
"Opens the <ulink url=\"https://www.kde.org/community/donations\">Donations "
"page</ulink> where you can support &kde; and its projects."
msgstr ""

#. Tag: menuchoice
#: ui.docbook:1258
#, no-c-format
msgid ""
"<guimenu>Help</guimenu> <guimenuitem>Switch Application Language...</"
"guimenuitem>"
msgstr ""
"<guimenu>Ohje</guimenu> <guimenuitem>Vaihda sovelluksen kieltä…</guimenuitem>"

#. Tag: para
#: ui.docbook:1262
#, no-c-format
msgid ""
"<action>Opens a dialog</action> where you can edit the <guilabel>Primary "
"language</guilabel> and <guilabel>Fallback language</guilabel> for this "
