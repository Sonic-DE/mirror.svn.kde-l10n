#. (itstool) path: component/name
#: org.kde.skanlite.appdata.xml:10
msgid "Skanlite"
msgstr "Skanlite"

#. (itstool) path: component/summary
#: org.kde.skanlite.appdata.xml:11
msgid "Image Scanning Application"
msgstr "Təsviri tarama tətbiqi"

#. (itstool) path: description/p
#: org.kde.skanlite.appdata.xml:13
msgid ""
"Skanlite is a simple image scanning application to scan and save images. It "
"is optimized for scanning with flatbed scanners. Skanlite can capture not "
"only photos and documents, but also transparent slides and filmstrips, with "
"supported scanners."
msgstr ""
"Skanlite şəkilləri taramaq və saxlamaq üçün sadə təsvir tarama tətbiqidir. "
"Bu planşet skanerlərlə uyğunlaşdırılmış bir tarama cihazıdır. Skanlite "
"təkcəşəkillərin və sənədlərin görüntüsünü deyil həmçinin dəstəkləyən skaner "
"olduqda, şəffaf slaydların və diaflimlərin surətini oxuyaraq görüntüləyə "
"bilir."

#. (itstool) path: description/p
#: org.kde.skanlite.appdata.xml:17
msgid "Features:"
msgstr "İmkanlar:"

