msgctxt "Name"
msgid "KDE"
msgstr "KDE"

#: daemon/chargethreshold_helper_actions.actions:63
msgctxt "Name"
msgid "Get current battery charge limit"
msgstr "Batareyanın dolması limitinin göstəricisini əldə etmək"

#: daemon/chargethreshold_helper_actions.actions:110
msgctxt "Description"
msgid "Authenticate to see the current battery charge limit."
msgstr ""
"Batareyanın cari yüklənmə həddini görmək üçün kimlik doğrulamasından keçin."

#: daemon/chargethreshold_helper_actions.actions:158
msgctxt "Name"
msgid "Set battery charge limit"
msgstr "Batareyanın dolması limitini təyin etmək"

#: daemon/chargethreshold_helper_actions.actions:205
msgctxt "Description"
msgid "Authenticate to set the battery charge limit."
msgstr "Batareyanın yüklənmə həddini görmək üçün kimlik doğrulamasından keçin."

#: daemon/chargethreshold_helper_actions.actions:253
msgctxt "Name"
msgid "Check battery conservation mode"
msgstr "Batareya yükünün saxlanılması rejimini yoxlayın"

#: daemon/chargethreshold_helper_actions.actions:296
msgctxt "Description"
msgid "Authenticate to check the current state of battery conservation mode."
msgstr ""
"Batareya yükünün saxlanılmasının cari vəziyyətini yoxlamaq üçün kimlik "
"doğrulamasından keçin."

#: daemon/chargethreshold_helper_actions.actions:343
msgctxt "Name"
msgid "Set battery conservation mode"
msgstr "Batareyanın yükünün saxlanılması rejimini təyin edin"

#: daemon/chargethreshold_helper_actions.actions:386
msgctxt "Description"
msgid "Authenticate to set the battery conservation mode."
msgstr ""
"Batareyanın yükünün saxlanılması rejimini təyin etmək üçün kimlik "
"doğrulamasından keçin."

#: daemon/controllers/backlight_helper_actions.actions:63
msgctxt "Name"
msgid "Get maximum brightness value"
msgstr "Ən yüksək parlaqlıq əldə etmək"

#: daemon/controllers/backlight_helper_actions.actions:119
msgctxt "Description"
msgid "Authenticate to see the maximum brightness level."
msgstr ""
"Ən yüksək parlaqlıq səviyyəsini görmək üçün kimlik doğrulamasından keçin."

#: daemon/controllers/backlight_helper_actions.actions:167
msgctxt "Name"
msgid "Get brightness"
msgstr "Parlaqlıq əldə etmək"

#: daemon/controllers/backlight_helper_actions.actions:223
msgctxt "Description"
msgid "Authenticate to see the brightness level."
msgstr "Parlaqlıq səviyyəsini görmək üçün kimlik doğrulamasından keçin."

#: daemon/controllers/backlight_helper_actions.actions:271
msgctxt "Name"
msgid "Set brightness"
msgstr "Parlaqlıq təyin etmək"

#: daemon/controllers/backlight_helper_actions.actions:327
msgctxt "Description"
msgid "Authenticate to set the brightness level."
msgstr "Parlaqlıq səviyyəsini təyin etmək üçün kimlik doğrulamasından keçin."

#: daemon/controllers/backlight_helper_actions.actions:374
msgctxt "Name"
msgid "Get syspath"
msgstr "Sistem yolu əldə etmək"

#: daemon/controllers/backlight_helper_actions.actions:428
msgctxt "Description"
msgid "Authenticate to see the syspath."
msgstr "Sistem yolunu görmək üçün kimlik doğrulamasından keçin."

#: daemon/discretegpu_helper_actions.actions:63
msgctxt "Name"
msgid "Check for existence of discrete GPU"
msgstr "Diskret qrafik kartının varlığını yoxlayın"

#: daemon/discretegpu_helper_actions.actions:107
msgctxt "Description"
msgid "Authenticate to check for the existence of a discrete GPU."
msgstr ""
"Diskret qrafik kartının varlığını yoxlamaq üçün kimlik doğrulamasından keçin."

#: daemon/powerdevil.desktop.cmake:4 powerdevil.notifyrc:2
msgctxt "Name"
msgid "Power Management"
msgstr "Enerjiyə Nəzarət"

#: daemon/powerdevil.desktop.cmake:65
msgctxt "Comment"
msgid "Battery, Display and CPU power management and notification"
msgstr "Batareya, Ekran parlaqlığı və CPU-nun enerjiyə qənaətini ayarlamaq"

#: daemon/wakeupsource_helper_actions.actions:63
msgctxt "Name"
msgid "Set the wakeup count"
msgstr "Oyanma sayını təyin edin"

#: daemon/wakeupsource_helper_actions.actions:96
msgctxt "Description"
msgid ""
"This allows to read wakeup count on next wakeup to identify wakeup source"
msgstr ""
"Bu, oyanma mənbəyini müəyyən etmək üçün, növbəti oyanma zamanı oyanma sayını "
"oxumağa icazə verir"

#: powerdevil.notifyrc:58
msgctxt "Comment"
msgid "Power Management System"
msgstr "El. Enerjisinin İdarəedilməsi Sistemi"

#: powerdevil.notifyrc:116
msgctxt "Name"
msgid "Warning"
msgstr "Xəbərdarlıq"

#: powerdevil.notifyrc:171
msgctxt "Comment"
msgid "Used for warning notifications"
msgstr "Xəbərdarlıq bildirişləri üçün istifadə olunur"

#: powerdevil.notifyrc:228
msgctxt "Name"
msgid "Notification"
msgstr "Bildiriş"

#: powerdevil.notifyrc:285
msgctxt "Comment"
msgid "Used for standard notifications"
msgstr "Standart bildirişlər üçün istifadə olunur"

#: powerdevil.notifyrc:342
msgctxt "Name"
msgid "Critical notification"
msgstr "Kritik bildirişlər"

#: powerdevil.notifyrc:398
msgctxt "Comment"
msgid "Notifies a critical event"
msgstr "Kritik hadisələri bildirir"

#: powerdevil.notifyrc:455
msgctxt "Name"
msgid "Battery Low"
msgstr "Batareya Zəifdir"

#: powerdevil.notifyrc:511
msgctxt "Comment"
msgid "Battery has reached low level"
msgstr "Batareyanın yükü aşağı səviyyədədir"

#: powerdevil.notifyrc:558
msgctxt "Name"
msgid "Battery Critical"
msgstr "Kritik Səviyyə"

#: powerdevil.notifyrc:614
msgctxt "Comment"
msgid ""
"Battery has reached critical level. This notification triggers a countdown "
"before doing the configured action, hence it is strongly advised to leave it "
"on."
msgstr ""
"Batareyanın yükü kritik səviyyəyə çatıb, Bu xəbərdarlıq seçilmiş fəaliyyəti "
"icra etmədən öncə vaxt qazanmağa imkan verir, ona görə də bunu açıq "
"saxlamanız tövsiyyə olunur."

#: powerdevil.notifyrc:662
msgctxt "Name"
msgid "Charge Complete"
msgstr "Batareya doldu"

#: powerdevil.notifyrc:716
msgctxt "Comment"
msgid "The battery is fully charged"
msgstr "Batareya tam doldu"

#: powerdevil.notifyrc:777
msgctxt "Name"
msgid "Peripheral Battery Low"
msgstr "Cihazın batareyası zəifdir"

#: powerdevil.notifyrc:829
msgctxt "Comment"
msgid "The battery in a connected device, such as mouse or keyboard, is low"
msgstr "Siçan və ya Klaviatura kimi qoşulmuş cihazlardakı batareyası zəifdir"

#: powerdevil.notifyrc:887
msgctxt "Name"
msgid "Power source connected"
msgstr "Qida mənbəyinə qoşulub"

#: powerdevil.notifyrc:934
msgctxt "Comment"
msgid "The power source has been connected"
msgstr "Elektrik qida mənbəyinə qoşuldu"

#: powerdevil.notifyrc:987
msgctxt "Name"
msgid "Power source disconnected"
msgstr "Qida mənbəyindən ayrıldı"

#: powerdevil.notifyrc:1034
msgctxt "Comment"
msgid "The power source has been disconnected"
msgstr "Elektrik qida mənbəyindən ayrıldı"

