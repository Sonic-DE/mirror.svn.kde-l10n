#: gui/org.kde.pimdataexporter.desktop:2
msgctxt "Name"
msgid "PIM Data Exporter"
msgstr "PİM verilənlərinin ixracatçısı"

#: gui/org.kde.pimdataexporter.desktop:45
msgctxt "GenericName"
msgid "Saves and restores all data from PIM apps"
msgstr "PİM tətbiqlərindən bütün verilənləri saxlayır və bərpa edir"

#: gui/org.kde.pimdataexporter.desktop:85
msgctxt "Comment"
msgid ""
"PIM Setting Exporter allows to save all data from PIM apps and restore them "
"in other systems."
msgstr ""
"PİM Ayarlar İxracatçısı PİM tətbiqlərindən bütün verilənləri saxlamağa və "
"onları başqa sistemdə bərpa etməyə imkan verir."
