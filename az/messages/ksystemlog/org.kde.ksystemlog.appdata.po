msgid "KSystemLog"
msgstr "KSystemLog"

#. (itstool) path: component/summary
#: org.kde.ksystemlog.appdata.xml:7
msgid "system log viewer"
msgstr "sistem jurnalı göstəricisi"

#. (itstool) path: description/p
#: org.kde.ksystemlog.appdata.xml:9
msgid ""
"KSystemLog show all logs of your system, grouped by General (Default system "
"log, Authentication, Kernel, X.org...), and optional Services (Apache, Cups, "
"etc, ...). It includes many features to read nicely your log files:"
msgstr ""
"KsystemLog, sisteminizin bütün jurnalını ümumi qruplaşdırılmış (Standart "
"sistem jurnalı, Kimlik doğrulaması, Nüvə bidirişləri jurnalı, X.org "
"jurnalı...) və əlavə xidmətlər (Apache, Cups və s...) şəklində baxmağa imkan "
"verir. Bu tətbiq, jurnal faylları ilə sadə şəkildə işləmək aşağıdakı "
"funksiyaları təqdim edir:"

#. (itstool) path: ul/li
#: org.kde.ksystemlog.appdata.xml:13
msgid "Colorize log lines depending on their severities"
msgstr "Üstünlüyündən asılı olaraq jurnal sətirlərinin rənglənməsi"

#. (itstool) path: ul/li
#: org.kde.ksystemlog.appdata.xml:14
msgid "Tabbed view to allow displaying several logs at the same time"
msgstr "Bir neçə jurnalın eyni vaxtda vərəqlər şəkildində göstərilməsi"

#. (itstool) path: ul/li
#: org.kde.ksystemlog.appdata.xml:15
msgid "Auto display new lines logged"
msgstr "Yeni jurnal sətirlərinin avtomatik göstərilməsi"

#. (itstool) path: ul/li
#: org.kde.ksystemlog.appdata.xml:16
msgid "Detailed information for each log lines"
msgstr "Hər jurnal sətri haqqında ətraflı məlumat"
