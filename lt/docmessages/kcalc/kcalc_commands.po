#~ msgstr ""
#~ "<guimenu>Nustatymai</guimenu> <guimenuitem>Konfigūruoti sparčiuosius "
#~ "klavišus...</guimenuitem>"

#~ msgid "Configure the keyboard shortcuts used by &kcalc;."
#~ msgstr "Konfigūruoti &kcalc; naudojamus sparčiuosius klavišus."

#~ msgid ""
#~ "<guimenu>Settings</guimenu> <guimenuitem>Configure &kcalc;...</"
#~ "guimenuitem>"
#~ msgstr ""
#~ "<guimenu>Nustatymai</guimenu> <guimenuitem>Konfigūruoti &kcalc;...</"
#~ "guimenuitem>"

#~ msgid "<action>Display</action> the &kcalc; settings dialog."
#~ msgstr "<action>Rodyti</action> &kcalc; nustatymų dialogą."

