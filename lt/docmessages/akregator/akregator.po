msgid "<guilabel>Archive</guilabel>"
msgstr "<guilabel>Archyvas</guilabel>"

#. Tag: guilabel
#: index.docbook:692
#, no-c-format
msgid "Archive backend:"
msgstr "Archyvavimo įrankis:"

#. Tag: para
