#| "screeninfo>"
msgid ""
"<screeninfo>&skrooge; displaying pie charts of expenses per category</"
"screeninfo>"
msgstr "<screeninfo>&appname; rodo išlaidų kategorijose grafiką</screeninfo>"

#. Tag: phrase
