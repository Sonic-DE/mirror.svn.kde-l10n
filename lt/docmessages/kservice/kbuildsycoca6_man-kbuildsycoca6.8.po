#. Tag: title
#: man-kbuildsycoca6.8.docbook:56
#, no-c-format
msgid "Description"
msgstr "Aprašymas"

#. Tag: para
#: man-kbuildsycoca6.8.docbook:58
#, fuzzy, no-c-format
#| msgid ""
#| "<command>kbuildsycoca4</command>, as part of the &kde; command line tools "
#| "ensures the proper operation of &kde; by reading in all the <literal role="
#| "\"extension\">.desktop</literal>, <literal role=\"extension\">.xml</"
#| "literal>, and <literal role=\"extension\">.protocol</literal> files to "
#| "construct a binary database."
msgid ""
"<command>kbuildsycoca6</command> builds binary cache of the data stored in "
"<literal role=\"extension\">.desktop</literal> and &MIME; type <literal role="
"\"extension\">.xml</literal> files that the KService framework uses to find "
"plugins, applications and other services."
msgstr ""
"<command>kbuildsycoca4</command>, kaip &kde; komandinės eilutės įrankių "
"dalis, užtikrina tinkamą &kde; veikimą, perskaitydama visus <literal role="
"\"extension\">.desktop</literal>, <literal role=\"extension\">.xml</literal> "
"ir <literal role=\"extension\">.protocol</literal> failus ir sukuria "
"dvejetainę duomenų bazę."

#. Tag: para
#: man-kbuildsycoca6.8.docbook:65
#, no-c-format
msgid ""
"The KService library uses this database to efficiently provide the "
"information requested of it."
msgstr ""

#. Tag: para
#: man-kbuildsycoca6.8.docbook:70
#, no-c-format
msgid ""
"Users do not normally need to run this application directly; KService will "
"run it if necessary, when any of the files whose data is cached are changed."
msgstr ""

