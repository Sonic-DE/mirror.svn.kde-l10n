#: files/plasma-setup.desktop.in:9 src/auth/org.kde.plasmasetup.actions:8
msgctxt "Name"
msgid "Plasma Setup"
msgstr "Plasma sąranka"

#: files/plasma-setup.desktop.in:39
msgctxt "Comment"
msgid "Run the initial system setup for KDE"
msgstr "Paleisti pradinę KDE sistemos sąranką"

#: src/auth/org.kde.plasmasetup.actions:42
msgctxt "Name"
msgid "Create User"
msgstr "Sukurti naudotoją"

#: src/auth/org.kde.plasmasetup.actions:71
msgctxt "Description"
msgid "Create the initial user account"
msgstr "Sukurti pradinę naudotojo paskyrą"

#: src/auth/org.kde.plasmasetup.actions:103
msgctxt "Name"
msgid "Create Completion Flag File"
msgstr "Sukurti užbaigimo vėliavėlės failą"

#: src/auth/org.kde.plasmasetup.actions:131
msgctxt "Description"
msgid "Write the /etc/plasma-setup-done marker to prevent rerunning setup"
msgstr ""
"Įrašyti /etc/plasma-setup-done žymeklį, kad būtų neleista iš naujo paleisti "
"sąranką"

#: src/auth/org.kde.plasmasetup.actions:162
msgctxt "Name"
msgid "Create New User Autostart Hook"
msgstr "Sukurti naujo naudotojo automatinio paleidimo gaudyklę"

#: src/auth/org.kde.plasmasetup.actions:191
msgctxt "Description"
msgid "Create an autostart hook for the newly created user"
msgstr "Sukurti naujai sukurtam naudotojui automatinio paleidimo gaudyklę"

#: src/auth/org.kde.plasmasetup.actions:223
msgctxt "Name"
msgid "Remove Autologin"
msgstr "Šalinti automatinį prisijungimą"

#: src/auth/org.kde.plasmasetup.actions:252
msgctxt "Description"
msgid "Remove Display Manager autologin configuration"
msgstr "Šalinti monitoriaus tvarkytuvės automatinio prisijungimo konfigūraciją"

#: src/auth/org.kde.plasmasetup.actions:282
msgctxt "Name"
msgid "Set New User Global Theme"
msgstr "Nustatyti naujam naudotojui visuotinį apipavidalinimą"

#: src/auth/org.kde.plasmasetup.actions:311
msgctxt "Description"
msgid "Set the global theme for the new user"
msgstr "Nustatyti naujam naudotojui visuotinį apipavidalinimą"

#: src/auth/org.kde.plasmasetup.actions:343
msgctxt "Name"
msgid "Set New User Display Scaling"
msgstr "Nustatyti naujam naudotojui atvaizdavimo mastelį"

#: src/auth/org.kde.plasmasetup.actions:372
msgctxt "Description"
msgid "Set display scaling for the new user"
msgstr "Nustatyti naujam naudotojui atvaizdavimo mastelį"

#: src/auth/org.kde.plasmasetup.actions:404
msgctxt "Name"
msgid "Set New User Home Directory Ownership"
msgstr "Nustatyti naujo naudotojo namų katalogo nuosavybę"

#: src/auth/org.kde.plasmasetup.actions:433
msgctxt "Description"
msgid "Set ownership of the new users home directory to the newly created user"
msgstr ""
"Nustatyti naujai sukurtam naudotojui naujų naudotojų namų katalogo nuosavybę"

#: src/auth/org.kde.plasmasetup.actions:465
msgctxt "Name"
msgid "Set New User Temporary Autologin"
msgstr "Nustatyti naujo naudotojo laikiną automatinį prisijungimą"

#: src/auth/org.kde.plasmasetup.actions:494
msgctxt "Description"
msgid ""
"Set display manager temporary autologin configuration for the newly created "
"user"
msgstr ""
"Nustatyti naujam naudotojui monitoriaus tvarkytuvės laikiną automatinio "
"prisijungimo konfigūraciją"
