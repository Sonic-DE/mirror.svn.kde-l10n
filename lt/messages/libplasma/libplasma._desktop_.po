#: templates/cpp-plasmoid6/cpp-plasmoid6.kdevtemplate:2
msgctxt "Name"
msgid "Plasma QML/C++ Applet (Qt6)"
msgstr "Plasma QML/C++ programėlė (Qt6)"

#: templates/cpp-plasmoid6/cpp-plasmoid6.kdevtemplate:44
msgctxt "Comment"
msgid ""
"A Plasma Applet template written in an hybrid mix of QML and C++: a Plasma "
"applet template displaying a SVG picture and a text"
msgstr ""
"Plasma programėlės šablonas, sukurtas naudojant hibridinį QML ir C++ mišinį: "
"Plasma programėlės šablonas, atvaizduojantis SVG paveikslą ir tekstą"

#: templates/plasma6-wallpaper/plasma6-wallpaper.kdevtemplate:2
msgctxt "Name"
msgid "Simple Plasma Wallpaper (Qt6)"
msgstr "Paprastas Plasma darbalaukio fonas (Qt6)"

#: templates/plasma6-wallpaper/plasma6-wallpaper.kdevtemplate:45
msgctxt "Comment"
msgid ""
"Simple Plasma Wallpaper template: a Plasma wallpaper template displaying a "
"text"
msgstr ""
"Paprastas Plasma darbalaukio fono šablonas: Plasma darbalaukio fono "
"šablonas, atvaizduojantis tekstą"

#: templates/plasma6-wallpaper-with-qml-extension/plasma6-wallpaper-with-qml-extension.kdevtemplate:2
msgctxt "Name"
msgid "Simple Plasma Wallpaper with QML extension (Qt6)"
msgstr "Paprastas Plasma darbalaukio fonas su QML plėtiniu (Qt6)"

#: templates/plasma6-wallpaper-with-qml-extension/plasma6-wallpaper-with-qml-extension.kdevtemplate:44
msgctxt "Comment"
msgid ""
"A Plasma wallpaper which uses custom API provided by an own QML extension "
"plugin"
msgstr ""
"Plasma darbalaukio fonas, naudojantis tinkintą API, kurį teikia nuosavas QML "
"plėtinio įskiepis"

#: templates/qml-plasmoid6/qml-plasmoid6.kdevtemplate:2
msgctxt "Name"
msgid "Plasma QML Applet (Qt6)"
msgstr "Plasma QML programėlė (Qt6)"

#: templates/qml-plasmoid6/qml-plasmoid6.kdevtemplate:45
msgctxt "Comment"
msgid ""
"Plasma QML Applet template: a Plasma applet template displaying a SVG "
"picture and a text"
msgstr ""
"Plasma QML programėlės šablonas: Plasma programėlės šablonas, "
"atvaizduojantis SVG paveikslą ir tekstą"

