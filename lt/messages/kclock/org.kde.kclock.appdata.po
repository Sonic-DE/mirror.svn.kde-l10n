#. (itstool) path: component/name
#: org.kde.kclock.appdata.xml:12
msgid "Clock"
msgstr "Laikrodis"

#. (itstool) path: component/summary
#: org.kde.kclock.appdata.xml:13
msgid "Keep time and set alarms"
msgstr "Sekti laiką ir nusistatyti žadintuvus"

#. (itstool) path: description/p
#: org.kde.kclock.appdata.xml:18
msgid ""
"A universal clock application for desktop and mobile. Clock includes a "
"stopwatch and a world clock, and allows you to set multiple alarms and "
"timers."
msgstr ""
"Universali laikrodžio programa, skirta kompiuteriams ir mobiliesiems "
"įrenginiams. Laikrodis leidžia nustatyti daug žadintuvų bei laikmačių, be "
"to, jame yra chronometras ir pasaulio laikrodžiai."

#. (itstool) path: description/p
#: org.kde.kclock.appdata.xml:19
msgid ""
"It contains alarm, timer, stopwatch and timezone functionalities. Alarms and "
"timers are able to wake the device from suspend on Plasma."
msgstr ""
"Ją sudaro žadintuvo, laikmačio, chronometro ir laiko juostų funkcionalumai. "
"Plasma aplinkoje žadintuvai ir laikmačiai turi galimybę pažadinti sistemą iš "
"pristabdymo būsenos."

#. (itstool) path: screenshot/caption
#: org.kde.kclock.appdata.xml:33
msgid "Mobile view"
msgstr "Mobilusis rodinys"

#. (itstool) path: screenshot/caption
#: org.kde.kclock.appdata.xml:37
msgid "Desktop view"
msgstr "Darbalaukio rodinys"

#. (itstool) path: screenshot/caption
#: org.kde.kclock.appdata.xml:41
msgid "Timers page"
msgstr "Laikmačių puslapis"

#. (itstool) path: screenshot/caption
#: org.kde.kclock.appdata.xml:45
msgid "Timer page"
msgstr "Laikmačio puslapis"

#. (itstool) path: screenshot/caption
#: org.kde.kclock.appdata.xml:49
msgid "Stopwatch page"
msgstr "Chronometro puslapis"

#. (itstool) path: screenshot/caption
#: org.kde.kclock.appdata.xml:53
msgid "Alarms page"
msgstr "Žadintuvų puslapis"

#. (itstool) path: description/p
#: org.kde.kclock.appdata.xml:111
msgid "New features and bugfixes in this release:"
msgstr "Naujos ypatybės ir klaidų ištaisymai šioje laidoje:"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:113
msgid "Fixed timer add one minute button."
msgstr "Ištaisytas laikmačio vienos minutės pridėjimo mygtukas."

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:114
msgid "Switched to tab bar based sidebar (similar to bottom navigation bar)."
msgstr ""
"Perjungta į kortelių juosta pagrįstą šoninę juostą (panašią į apatinę "
"naršymo juostą)."

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:131
msgid "Support for background daemon when using flatpak"
msgstr "Foninės tarnybos palaikymas, kai naudojamas Flatpak"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:132
msgid "Fix excessive log generation on non-Plasma system"
msgstr "Ištaisytas perteklinis žurnalo generavimas ne Plasma sistemose"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:140
msgid "Fix \"Clock daemon not found\" popup message"
msgstr "Ištaisytas iškylantysis „Nerasta laikrodžio tarnyba“ pranešimas"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:141
msgid "Various bugfixes and user interface improvements"
msgstr "Įvairūs klaidų ištaisymai ir naudotojo sąsajos patobulinimai"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:142
msgid "Add a sound picker component for listing alarm sounds"
msgstr ""
"Pridėtas garsų parinkiklio komponentas, skirtas išvardyti žadintuvo garsus"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:143
msgid "Start snooze only after button is pressed"
msgstr "Snaudimas pradedamas tik paspaudžius mygtuką"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:144
msgid "Fix alarms not working on PinePhone"
msgstr "Ištaisyti PinePhone telefonuose neveikiantys žadintuvai"

#. (itstool) path: description/p
#: org.kde.kclock.appdata.xml:150 org.kde.kclock.appdata.xml:167
msgid "Changes:"
msgstr "Pakeitimai:"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:152
msgid "Kirigami's bottom navigation bar component is now used for mobile"
msgstr ""
"Dabar mobiliuosiuose įrenginiuose yra naudojamas Kirigami apatinės naršymo "
"juostos komponentas"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:153
msgid "A Plasma style sidebar is now used on desktop"
msgstr ""
"Dabar, darbalaukio aplinkoje yra naudojama Plasma stiliaus šoninė juosta"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:154
msgid "The system tray item now only shows when alarms are pending"
msgstr ""
"Dabar, sistemos dėklo elementas rodomas tik tada, kai yra laukiančių "
"žadintuvų"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:155
msgid "The daemon automatically stops if no alarms and timers are pending"
msgstr ""
"Tarnyba automatiškai sustabdoma, jei nėra laukiančių žadintuvų ar laikmačių"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:156
msgid "Action bars are now used on the timer and alarms forms page"
msgstr ""
"Dabar, laikmačio ir žadintuvų formos puslapyje yra naudojamos veiksmo juostos"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:157
msgid "The settings button has been moved to the top actions bar"
msgstr "Nuostatų mygtukas perkeltas į viršutinę veiksmų juostą"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:169
msgid ""
"Watch DBus for PowerDevil, so wake from suspend always works if PowerDevil "
"is found"
msgstr ""
"Stebima, ar DBus yra PowerDevil, kad prikėlimas iš pristabdymo visada "
"veiktų, jei yra randamas PowerDevil"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:170
msgid "Use consistent dialog style on the settings page"
msgstr "Nuostatų puslapyje naudojamas atitinkamas dialogo stilius"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:171
msgid "After editing an alarm, the alarm now automatically is activated"
msgstr "Dabar, po žadintuvo taisymo, žadintuvas automatiškai aktyvuojamas"

#. (itstool) path: description/p
#: org.kde.kclock.appdata.xml:178
msgid "New features and bugfixes:"
msgstr "Naujos ypatybės ir klaidų ištaisymai:"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:180
msgid "Added the ability to set timer presets"
msgstr "Pridėta galimybė nustatyti išankstines laikmačio parinktis"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:181
msgid "Added ability to increase timer duration by 1m as timer is running"
msgstr ""
"Pridėta galimybė didinti laikmačio trukmę po 1 minutę, kol laikmatis veikia"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:182
msgid ""
"Fixed multiple alarm sounds and notifications being played for one alarm"
msgstr ""
"Ištaisyta klaida, kai vienam žadintuvui skambėjo daug žadintuvo garsų ir "
"buvo rodoma daug pranešimų"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:183
msgid "Fixed errors that prevented the application from working in a Flatpak"
msgstr "Ištaisytos klaidos, kurios neleido programai veikti Flatpak aplinkoje"

