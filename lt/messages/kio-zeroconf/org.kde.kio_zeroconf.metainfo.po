msgid "Zeroconf Support"
msgstr "Zeroconf palaikymas"

#. (itstool) path: component/summary
#: org.kde.kio_zeroconf.metainfo.xml:10
msgid "Browse local network services in Dolphin's Network page"
msgstr "Naršyti Dolphin tinklo puslapyje vietinio tinklo tarnybas"

#. (itstool) path: description/p
#: org.kde.kio_zeroconf.metainfo.xml:12
msgid ""
"Adds an entry to Dolphin's Network page to show local services such as "
"printers which advertise themselves with DNSSD (called Avahi or Bonjour by "
"other projects)."
msgstr ""
"Į programos Dolphin tinklo puslapį, prideda įrašą, skirtą rodyti vietines "
"tarnybas, tokias kaip spausdintuvai, kurie skelbiasi naudodami DNSSD "
"(kituose projektuose dar vadinamą kaip Avahi ar Bonjour)"
