#. (itstool) path: component/name
#: org.kde.liquidshell.appdata.xml:4
msgid "liquidshell"
msgstr "liquidshell"

#. (itstool) path: component/summary
#. (itstool) path: description/p
#: org.kde.liquidshell.appdata.xml:5 org.kde.liquidshell.appdata.xml:10
msgid "liquidshell is an alternative to plasmashell"
msgstr "liquidshell yra plasmashell alternatyva"

#. (itstool) path: description/p
#: org.kde.liquidshell.appdata.xml:11
msgid ""
"It does not use QtQuick but instead relies on QtWidgets, therefore no "
"hardware graphics acceleration is needed."
msgstr ""
"Jis nenaudoja QtQuick, tačiau vietoj to, remiasi QtWidgets ir todėl, "
"nereikalauja aparatinės įrangos grafikos spartinimo."

#. (itstool) path: description/p
#: org.kde.liquidshell.appdata.xml:13
msgid "Main Features:"
msgstr "Pagrindinės ypatybės:"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:15
msgid "Wallpaper per virtual desktop"
msgstr "Atskiras darbalaukio fonas kiekvienam virtualiam darbalaukiui"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:16
msgid "No animations, no CPU hogging, low Memory footprint"
msgstr ""
"Jokių animacijų, jokio perteklinio procesoriaus naudojimo, naudoja mažai "
"atminties"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:17
msgid "Instant startup"
msgstr "Greita paleistis"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:18
msgid "No use of activities"
msgstr "Nenaudoja veiklų"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:19
msgid "QtWidgets based, therefore follows widget style from systemsettings"
msgstr ""
"Pagrįstas QtWidgets, todėl naudoja valdiklių stilių iš sistemos nuostatų"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:20
msgid ""
"Icons are used from your globally defined icon theme from systemsettings"
msgstr ""
"Piktogramos yra naudojamos iš jūsų visuotinai sistemos nuostatose apibrėžto "
"piktogramų apipavidalinimo"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:21
msgid ""
"Colors are used from your globally defined color theme from systemsettings"
msgstr ""
"Spalvos yra naudojamos iš jūsų visuotinai sistemos nuostatose apibrėžto "
"spalvų apipavidalinimo"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:22
msgid ""
"Can additionally be styled with css by passing the commandline option -"
"stylesheet filename.css (see included example stylesheet.css)"
msgstr ""
"Gali būti papildomai stilizuojamas naudojant css, perduodant komandų eilutės "
"parinktį -stylesheet failo_pavadinimas.css (žiūrėkite pridėtą pavyzdį "
"stylesheet.css)"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:23
msgid ""
"uses existing KDE dialogs for most configurations, e.g. StartMenu, Virtual "
"Desktops, Bluetooth, Network"
msgstr ""
"Daugumai konfigūracijų naudoja esamus KDE dialogus, pvz., Paleidimo meniu, "
"Virtualūs darbalaukiai, Bluetooth, Tinklas"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:24
msgid "One bottom DesktopPanel"
msgstr "Vienas apatinis darbalaukio skydelis"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:25
msgid "Desktop Applets"
msgstr "Darbalaukio programėlės"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:43
msgid "Added install options (sleep/shutdown after install)"
msgstr "Pridėtos įdiegimo parinktys (pristabdyti/išjungti po įdiegimo)"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:44
msgid "Improved EULA handling on package installation"
msgstr ""
"Patobulintas galutinio naudotojo licencijos sutarties apdorojimas įdiegiant "
"paketą"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:45
msgid "Added long format of time and date display to calendar popup"
msgstr ""
"Į kalendoriaus iškylantįjį langą pridėtas ilgas laiko ir datos atvaizdavimo "
"formatas"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:46
msgid "Create default folder for storing quicklaunch apps"
msgstr ""
"Sukurtas numatytasis aplankas, skirtas saugoti greitojo paleidimo programas"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:47
msgid "SysLoad widget width depends on CPU count"
msgstr "Sistemos apkrovos valdiklio plotis priklauso nuo procesorių skaičiaus"

#. (itstool) path: ul/li
#. (itstool) path: description/p
#: org.kde.liquidshell.appdata.xml:48 org.kde.liquidshell.appdata.xml:54
msgid "Bugfixes and adjustments to newer KDE components"
msgstr "Naujesniems KDE komponentams atlikti klaidų ištaisymai ir derinimai"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:60
msgid "Notifications show how long they remain open (small animation)"
msgstr "Pranešimai rodo, kiek ilgai jie išliks atverti (maža animacija)"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:61
msgid "Weather Applet shows moon phase"
msgstr "Orų programėlė rodo mėnulio fazę"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:62
msgid "Disk Usage Applet watches for mount/unmount to react quicker for update"
msgstr ""
"Disko naudojimo programėlė stebi prijungimus/atjungimus, kad greičiau "
"reaguotų atnaujinimui"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:63
msgid "Display improvements in software updates component"
msgstr "Rodomi patobulinimai programinės įrangos atnaujinimų komponente"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:64
msgid ""
"Added DBUS-Menu support (some apps don't provide own menu but only via DBUS, "
"e.g. MS teams)"
msgstr ""
"Pridėtas DBUS meniu palaikymas (kai kurios programos nepateikia nuosavo "
"meniu, bet tik per DBUS, pvz., MS teams)"
