msgstr "Peržiūra su galutinio skenavimo pasirinkimo ypatybe"

#. (itstool) path: ul/li
#: org.kde.skanlite.appdata.xml:22
msgid "Scanning multiple selections of an image"
msgstr "Kelių paveikslo pasirinkimų skenavimas"

#. (itstool) path: screenshot/caption
