msgid "Features:"
msgstr "Ypatybės:"

#. (itstool) path: ul/li
#: org.kde.okular.appdata.xml:15
msgid ""
"Supported Formats: PDF, PS, Tiff, DjVu, Images, DVI, XPS, Fiction Book, "
"Comic Book, Plucker, EPub, Fax"
msgstr ""
"Palaikomi formatai: PDF, PS, Tiff, DjVu, paveikslai, DVI, XPS, Fiction Book, "
"komiksų knygos, Plucker, EPub, faksas"

#. (itstool) path: ul/li
#: org.kde.okular.appdata.xml:16
