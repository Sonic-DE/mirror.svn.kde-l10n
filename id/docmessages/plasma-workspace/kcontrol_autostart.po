#. Tag: guimenuitem
#: index.docbook:115
#, no-c-format
msgid "Add Program"
msgstr "Tambahkan Program"

#. Tag: para
#: index.docbook:117
#, fuzzy, no-c-format
#| msgid ""
#| "Clicking this button displays the standard &plasma; <guilabel>Choose "
#| "Application</guilabel> dialog and allows you to choose which program you "
