#. Tag: para
#: index.docbook:123
#, fuzzy, no-c-format
#| msgid "1, 2 or 3 yellow stars - for 2 to 6 years old."
msgid "1, 2 or 3 yellow stars — for 2 to 6 years old."
msgstr ""
"1, 2 atau 3 bintang berwarna kuning - untuk anak berusia 2 hingga 6 tahun."

#. Tag: para
#: index.docbook:125
#, fuzzy, no-c-format
#| msgid "1, 2 or 3 red stars - greater than 6 years old."
msgid "1, 2 or 3 red stars — greater than 6 years old."
msgstr ""
"1, 2 atau 3 bintang berwana merah - untuk anak berumur lebih dari 6 tahun."

#. Tag: para
#: index.docbook:129
#, fuzzy, no-c-format
#| msgid ""
