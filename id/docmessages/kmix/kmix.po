#, no-c-format
msgid "Select Master Channel"
msgstr "Pilih Channel Master"

#. Tag: screeninfo
#: index.docbook:199
#, no-c-format
msgid "<screeninfo>&kmix; Master Channel</screeninfo>"
msgstr "<screeninfo>Channel Master &kmix;</screeninfo>"

#. Tag: phrase
