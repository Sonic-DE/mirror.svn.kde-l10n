#, no-c-format
msgid "<phrase>&kmix; Master Channel</phrase>"
msgstr "<phrase>Channel Master &kmix;</phrase>"

#. Tag: para
#: index.docbook:209
#, no-c-format
msgid "Select your &kmix; master channel."
msgstr "Pilih channel master &kmix;mu."

#. Tag: title
#: index.docbook:213
#, no-c-format
msgid "Configure &kmix;"
msgstr "Konfigurasikan &kmix;"

#. Tag: title
#: index.docbook:215
#, no-c-format
msgid "General configuration"
msgstr "Konfigurasi umum"

#. Tag: screeninfo
#: index.docbook:219
#, no-c-format
msgid "<screeninfo>General configuration of &kmix;</screeninfo>"
msgstr "<screeninfo>Konfigurasi umum &kmix;</screeninfo>"

#. Tag: phrase
#: index.docbook:225
#, no-c-format
msgid "<phrase>General configuration of &kmix;</phrase>"
msgstr "<phrase>Konfigurasi umum &kmix;</phrase>"

#. Tag: para
#: index.docbook:229
#, no-c-format
msgid "Configure general &kmix; parameters."
msgstr "Parameter konfigurasi umum &kmix;."

#. Tag: menuchoice
#: index.docbook:233
#, no-c-format
msgid "<guimenu>Behavior</guimenu> <guimenuitem>Volume Overdrive</guimenuitem>"
msgstr ""
"<guimenu>Perilaku</guimenu> <guimenuitem>Overdrive Volume</guimenuitem>"

#. Tag: para
#: index.docbook:237
#, no-c-format
msgid ""
"Check this box to allow volume to be more than recommended value (sometimes "
"PulseAudio maximal volume exceeds the normal value). &kmix; restart is "
"needed for this setting to take effect."
msgstr ""
"Centang kotak ini untuk memperkenankan volume lebih dari nilai yang "
"dianjurkan (terkadang volume maksimal PulseAudio melebihi nilai normal). "
"Memulai ulang &kmix; diperlukan supaya pengaturan ini berpengaruh."

#. Tag: para
#: index.docbook:239
#, no-c-format
msgid ""
"Uncheck this item if there are audible sound distortions at the maximal "
"volume."
msgstr ""
"Hapus centang butir ini jika kedengaran distorsi suara di volume maksimal."

#. Tag: menuchoice
#: index.docbook:247
#, no-c-format
msgid "<guimenu>Behavior</guimenu> <guimenuitem>Volume Feedback</guimenuitem>"
msgstr "<guimenu>Perilaku</guimenu> <guimenuitem>Volume Feedback</guimenuitem>"

#. Tag: action
#: index.docbook:251
#, no-c-format
msgid "Check this box to enable audible feedback on volume change."
msgstr ""
"Centang kotak ini untuk memfungsikan respons bersuara pada perubahan volume."

#. Tag: menuchoice
#: index.docbook:255
#, no-c-format
msgid "<guimenu>Behavior</guimenu> <guimenuitem>Volume step</guimenuitem>"
msgstr "<guimenu>Perilaku</guimenu> <guimenuitem>Langkah volume</guimenuitem>"

#. Tag: para
#: index.docbook:260
#, no-c-format
msgid "Set the volume step as a percentage of the volume range."
msgstr "Setel langkah volume sebagai persentase rentang volume."

#. Tag: para
#: index.docbook:263
#, no-c-format
msgid ""
"This affects changing the volume via hot keys, with the mouse wheel over the "
"system tray icon, or moving sliders by a page step."
msgstr ""
"Ini memengaruhi perubahan volume melalui tombol pintas, dengan roda mouse di "
"atas ikon baki sistem, atau menggerakkan penggeser demi langkah halaman."

#. Tag: para
#: index.docbook:266
#, no-c-format
msgid "&kmix; must be restarted for this change to take effect."
msgstr "&kmix; harus dimulai ulang agar perubahan ini berlaku."

#. Tag: menuchoice
#: index.docbook:273
#, no-c-format
msgid ""
"<guimenu>Visual</guimenu> <guimenuitem>Show slider tickmarks</guimenuitem>"
msgstr ""
"<guimenu>Visual</guimenu> <guimenuitem>Tampilkan tanda titik geseran</"
"guimenuitem>"

#. Tag: action
#: index.docbook:277
#, no-c-format
msgid "Check this box to show tickmarks on the sliders."
msgstr "Centang kotak ini untuk menampilkan tanda titik pada geseran."

#. Tag: menuchoice
#: index.docbook:281
#, no-c-format
msgid ""
"<guimenu>Visual</guimenu> <guimenuitem>Show control labels</guimenuitem>"
msgstr ""
"<guimenu>Visual</guimenu> <guimenuitem>Tampilkan label kontrol</guimenuitem>"

#. Tag: action
#: index.docbook:285
#, no-c-format
msgid "Check this box to show labels of controls."
msgstr "Centang kotak ini untuk menampilkan label pada kendali."

#. Tag: menuchoice
#: index.docbook:289
#, no-c-format
msgid ""
"<guimenu>Visual</guimenu> <guimenuitem>Show On Screen Display (OSD)</"
"guimenuitem>"
msgstr ""
"<guimenu>Visual</guimenu> <guimenuitem>Tampilkan On Screen Display (OSD)</"
"guimenuitem>"

#. Tag: action
#: index.docbook:293
#, no-c-format
msgid "Check this box to enable OSD show on hovering &kmix; tray widget."
msgstr ""
"Centang kotak ini untuk memfungsikan tampilan OSD saat melayang di widget "
"tray &kmix;."

#. Tag: menuchoice
#: index.docbook:297
#, no-c-format
msgid ""
"<guimenu>Slider orientation (main window)</guimenu> <guimenuitem>Horizontal</"
"guimenuitem>"
msgstr ""
"<guimenu>Orientasi penggeser (jendela utama)</guimenu> "
"<guimenuitem>Mendatar</guimenuitem>"

#. Tag: action
#: index.docbook:301
#, no-c-format
msgid "Check this radio button to orientate the control slider horizontally."
msgstr ""
"Centang tombol radio ini untuk mengorientasi penggeser kendali secara "
"mendatar."

#. Tag: menuchoice
#: index.docbook:305
#, no-c-format
msgid ""
"<guimenu>Slider orientation (main window)</guimenu> <guimenuitem>Vertical</"
"guimenuitem>"
msgstr ""
"<guimenu>Orientasi geser (jendela utama)</guimenu> <guimenuitem>Tegak</"
"guimenuitem>"

#. Tag: action
#: index.docbook:309
#, no-c-format
msgid "Check this radio button to orientate the control slider vertically."
msgstr ""
"Centang tombol radio ini untuk mengorientasi penggeser kendali secara "
"menegak."

#. Tag: menuchoice
#: index.docbook:313
#, no-c-format
msgid ""
"<guimenu>Slider orientation (system tray popup)</guimenu> "
"<guimenuitem>Horizontal/Vertical</guimenuitem>"
msgstr ""
"<guimenu>Orientasi penggeser (sembulan baki sistem)</guimenu> "
"<guimenuitem>Mendatar/Tegak</guimenuitem>"

#. Tag: para
#: index.docbook:317
#, no-c-format
msgid ""
"Same as the previous two radio buttons but for the system tray volume "
"control (the panel that is shown after &LMB; click on &kmix; tray icon)."
msgstr ""
"Sama seperti halnya dua tombol radio sebelumnya tetapi untuk kendali volume "
"baki sistem (panel tersebut tampil setelah klik &LMB; pada ikon tray &kmix;)."

#. Tag: title
#: index.docbook:324
#, no-c-format
msgid "Start configuration"
msgstr "Mulai konfigurasi"

#. Tag: screeninfo
#: index.docbook:328
#, no-c-format
msgid "<screeninfo>Start configuration of &kmix;</screeninfo>"
msgstr "<screeninfo>Mulai konfigurasi &kmix;</screeninfo>"

#. Tag: phrase
#: index.docbook:334
#, no-c-format
msgid "<phrase>Start configuration of &kmix;</phrase>"
msgstr "<phrase>Mulai konfigurasi &kmix;</phrase>"

#. Tag: para
#: index.docbook:338
#, no-c-format
msgid "This page allows you to configure various &kmix; start parameters."
msgstr ""
"Halaman ini memperkenankan kamu untuk mengkonfigurasi berbagai parameter "
"pemulaian &kmix;."

#. Tag: menuchoice
#: index.docbook:342
#, no-c-format
msgid ""
"<guimenu>Startup</guimenu> <guimenuitem>Start KMix on desktop startup</"
"guimenuitem>"
msgstr ""
"<guimenu>Pemulaian</guimenu> <guimenuitem>Jalankan KMix saat pemulaian "
"desktop</guimenuitem>"

#. Tag: action
#: index.docbook:346
#, no-c-format
msgid "Check this box to enable &kmix; autostart with desktop environment."
msgstr ""
"Centang kotak ini untuk memfungsikan autostart &kmix; dengan lingkungan "
"desktop."

#. Tag: menuchoice
#: index.docbook:350
#, no-c-format
msgid ""
"<guimenu>Startup</guimenu> <guimenuitem>Restore previous volume settings on "
"desktop startup</guimenuitem>"
msgstr ""
"<guimenu>Pemulaian</guimenu> <guimenuitem>Kembalikan pengaturan volume "
"sebelumnya saat pemulaian desktop</guimenuitem>"

#. Tag: action
#: index.docbook:354
#, no-c-format
msgid ""
"Check this box to enable volume levels and switches restoration to their "
"last used settings on desktop start."
msgstr ""
"Centang kotak ini untuk memfungsikan tingkat volume dan mengalihkan "
"pemulihan ke pengaturan yang digunakan terakhir saat start desktop."

#. Tag: para
#: index.docbook:356
#, no-c-format
msgid ""
"The volume of PulseAudio or MPRIS2 dynamic controls will not be restored."
msgstr ""
"Volume PulseAudio atau MPRIS2 dynamic controls tidak akan dikembalikan."

#. Tag: title
#: index.docbook:367
#, no-c-format
msgid "Volume control configuration"
msgstr "Konfigurasi kendali volume"

#. Tag: screeninfo
#: index.docbook:371
#, no-c-format
msgid "<screeninfo>Volume control configuration of &kmix;</screeninfo>"
msgstr "<screeninfo>Konfigurasi kendali volume &kmix;</screeninfo>"

#. Tag: phrase
#: index.docbook:377
#, no-c-format
msgid "<phrase>Volume control configuration of &kmix;</phrase>"
msgstr "<phrase>Konfigurasi kendali volume &kmix;</phrase>"

#. Tag: para
#: index.docbook:381
#, no-c-format
msgid ""
"This page allows you to configure various &kmix; popup volume control "
"parameters."
msgstr ""
"Halaman ini memperkenankan kamu untuk mengkonfigurasi berbagai parameter "
"kendali volume sembulan &kmix;."

#. Tag: guilabel
#: index.docbook:385
#, no-c-format
msgid "Dock in system tray"
msgstr "Dock dalam baki sistem"

#. Tag: action
#: index.docbook:387
#, no-c-format
msgid "Check this box to dock &kmix; in system tray."
msgstr "Centang kotak ini untuk dock &kmix; dalam baki sistem."

#. Tag: para
#: index.docbook:391
#, no-c-format
msgid ""
"It is possible to select mixers that will be shown in the volume control "
"using the corresponding list on this page."
msgstr ""
"Ini memungkinkan untuk memilih mixer yang akan ditampilkan dalam kendali "
"volume menggunakan daftar yang sesuai pada halaman ini."

#. Tag: title
#: index.docbook:400
#, no-c-format
msgid "Advanced usage"
msgstr "Penggunaan tingkat-lanjut"

#. Tag: title
#: index.docbook:402
#, no-c-format
msgid "Remote controlling and scripting via &DBus;"
msgstr "Pengendalian jarak jauh dan penskripan via &DBus;"

#. Tag: para
#: index.docbook:403
#, no-c-format
msgid ""
"You can control &kmix; via &DBus;. This is for advanced users who want to "
"achieve special tasks, like muting the PC every day at 10 pm, or for any "
"other scripting task."
msgstr ""
"Kamu bisa mengendalikan &kmix; via &DBus;. Ini adalah untuk pengguna tingkat "
"lanjut yang mau melakukan tugas khusus, seperti membungkam PC setiap hari "
"pukul 10 malam, atau untuk tugas penskripan apapun lainnya."

#. Tag: para
#: index.docbook:407
#, no-c-format
msgid "List all &kmix; related &DBus; methods and properties"
msgstr "Daftar semua &kmix; sehubungan properti dan metode DBus"

#. Tag: programlisting
#: index.docbook:409
#, no-c-format
msgid "qdbus org.kde.kmix"
msgstr "qdbus org.kde.kmix"

#. Tag: para
#: index.docbook:412
#, no-c-format
msgid "Getting volume level (0-100%):"
msgstr "Mendapatkan level volume (0-100%):"

#. Tag: programlisting
#: index.docbook:414
#, no-c-format
msgid ""
"qdbus org.kde.kmix /Mixers/0/Master_0 org.freedesktop.DBus.Properties.Get "
"org.kde.KMix.Control volume"
msgstr ""
"qdbus org.kde.kmix /Mixers/0/Master_0 org.freedesktop.DBus.Properties.Get "
"org.kde.KMix.Control volume"

#. Tag: para
#: index.docbook:417
#, no-c-format
msgid "Setting volume level (0-100%):"
msgstr "Set level volume (0-100%):"

#. Tag: programlisting
#: index.docbook:419
#, no-c-format
msgid ""
"qdbus org.kde.kmix /Mixers/0/Master_0 org.freedesktop.DBus.Properties.Set "
"org.kde.KMix.Control volume 70"
msgstr ""
"qdbus org.kde.kmix /Mixers/0/Master_0 org.freedesktop.DBus.Properties.Set "
"org.kde.KMix.Control volume 70"

