msgstr ""
"<guimenu>Pengaturan</guimenu> <guimenuitem>Pengaturan Audio</guimenuitem>"

#. Tag: para
#: index.docbook:173
#, no-c-format
msgid ""
"<action>Open <ulink url=\"help:/kcontrol/phonon\">&phonon; &systemsettings; "
"module</ulink></action> to configure the sound and video device preference "
"and the backends used by &kde; multimedia API, &phonon;."
msgstr ""
"<action>Buka <ulink url=\"help:/kcontrol/phonon\">modul &phonon; "
"&systemsettings;</ulink></action> untuk mengkonfigurasi preferensi peranti "
"sound dan video dan backend yang digunakan oleh &kde; multimedia API, "
"&phonon;."

#. Tag: title
