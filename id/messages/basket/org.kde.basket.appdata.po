#. (itstool) path: component/name
#: org.kde.basket.appdata.xml:10
msgid "Basket"
msgstr "Basket"

#. (itstool) path: component/summary
#: org.kde.basket.appdata.xml:11
msgid "Notes and to-dos organizer"
msgstr "Pengelola catatan dan wacana"

#. (itstool) path: description/p
#: org.kde.basket.appdata.xml:13
msgid ""
"This application provides as many baskets as you wish, and you can drag and "
"drop."
msgstr ""
"Aplikasi ini menyediakan keranjang sebanyak yang kamu inginkan, dan kamu "
"bisa melakukan seret dan taruh."

#. (itstool) path: description/p
#: org.kde.basket.appdata.xml:14
msgid ""
"Objects can be edited, copied, dragged... So, you can arrange them as you "
"want !"
msgstr ""
"Objek bisa diedit, disalin, diseret ... Jadi, kamu bisa mengaturnya sesuai "
"keinginanmu!"

#. (itstool) path: description/p
#: org.kde.basket.appdata.xml:15
msgid "It allows to arrange notes, track to-dos and much more."
msgstr ""
"Yang memungkinkan untuk mengatur catatan, melacak wacana dan banyak lagi."

#~ msgid "KDE Community"
