#: src/org.kde.kgoldrunner.desktop:2
msgctxt "Name"
msgid "KGoldrunner"
msgstr "KGoldrunner"

#: src/org.kde.kgoldrunner.desktop:73
msgctxt "GenericName"
msgid "Hunt Gold, Dodge Enemies and Solve Puzzles"
msgstr "Memburu Emas, Menghindari Musuh, dan Memecahkan Teka-teki"

#: src/org.kde.kgoldrunner.desktop:127
msgctxt "Comment"
msgid "A game of action and puzzle-solving"
msgstr "Sebuah permainan aksi dan pemecahan teka-teki"

#: themes/black-on-white.desktop:2
msgctxt "Name"
msgid "Black on White"
msgstr "Hitam di Atas Putih"

#: themes/black-on-white.desktop:60
msgctxt "Description"
msgid "A monochrome, black on white theme for KGoldrunner"
msgstr "Sebuah tema monokrom, hitam di atas putih untuk KGoldrunner"

#: themes/default.desktop:2
msgctxt "Name"
msgid "KGoldRunner Default"
msgstr "KGoldRunner Baku"

#: themes/default.desktop:59
msgctxt "Description"
msgid "A light and clean theme for KDE4"
msgstr "Sebuah tema terang dan jelas untuk KDE4"

#: themes/egypt.desktop:2
msgctxt "Name"
msgid "The Treasure of Egypt"
msgstr "Harta Karun Mesir"

#: themes/egypt.desktop:57
msgctxt "Description"
msgid "Help Matt Goldrunner escape the traps of ancient Egypt."
msgstr "Bantu Matt Goldrunner meloloskan diri dari jebakan Mesir kuno."

#: themes/kgr_geek.desktop:2
msgctxt "Name"
msgid "Geek City"
msgstr "Kota Angker"

#: themes/kgr_geek.desktop:56
msgctxt "Description"
msgid "The hero is trapped inside a computer."
msgstr "Pahlawan yang terjebak di dalam sebuah komputer."

#: themes/nostalgia-blues.desktop:2
msgctxt "Name"
msgid "Nostalgia Blues"
msgstr "Biru-biru Nostalgia"

#: themes/nostalgia-blues.desktop:54
msgctxt "Description"
msgid ""
"A theme for KGoldrunner that brings back that 8-bit look... now in blue!"
msgstr ""
"Sebuah tema untuk KGoldrunner yang membawa kembali suasana 8-bit... sekarang "
"dalam warna biru!"

#: themes/nostalgia.desktop:2
msgctxt "Name"
msgid "Nostalgia"
msgstr "Nostalgia"

#: themes/nostalgia.desktop:58
msgctxt "Description"
msgid "A scalable theme for KGoldrunner that brings back that 8-bit look..."
msgstr ""
"Sebuah tema yang dapat diskalakan untuk KGoldrunner yang membawa kembali "
"suasana 8-bit..."
