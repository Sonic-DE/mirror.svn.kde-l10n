msgid "Zeroconf Support"
msgstr "Dukungan Zeroconf"

#. (itstool) path: component/summary
#: org.kde.kio_zeroconf.metainfo.xml:10
msgid "Browse local network services in Dolphin's Network page"
msgstr "Telusuri layanan jaringan lokal di halaman Jaringan si Dolphin"

#. (itstool) path: description/p
#: org.kde.kio_zeroconf.metainfo.xml:12
msgid ""
"Adds an entry to Dolphin's Network page to show local services such as "
"printers which advertise themselves with DNSSD (called Avahi or Bonjour by "
"other projects)."
msgstr ""
"Menambahkan entri ke halaman Jaringan si Dolphin untuk menampilkan layanan "
"lokal sepertihalnya printer yang mengiklankan dirinya sendiri dengan DNSSD "
"(disebut Avahi atau Bonjour berdasarkan proyek lain)"
