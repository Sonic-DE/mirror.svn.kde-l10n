#. (itstool) path: component/name
#: org.kde.kget.appdata.xml:9
msgid "KGet"
msgstr "KGet"

#. (itstool) path: component/summary
#: org.kde.kget.appdata.xml:10
#, fuzzy
#| msgid "Download Manager"
msgid "Download manager"
msgstr "Unduh Manager"

#. (itstool) path: description/p
#: org.kde.kget.appdata.xml:12
msgid "KGet is a versatile and user-friendly download manager."
msgstr "KGet adalah unduh manager yang serbaguna dan mudah digunakan."

#. (itstool) path: description/p
#: org.kde.kget.appdata.xml:15
msgid "Features:"
msgstr "Fitur-fitur:"

#. (itstool) path: ul/li
#: org.kde.kget.appdata.xml:17
msgid "Downloading files from FTP and HTTP(S) sources."
msgstr "Mengunduh file dari sumber-sumber FTP dan HTTP(S)"

#. (itstool) path: ul/li
#: org.kde.kget.appdata.xml:18
msgid ""
"Pausing and resuming of downloading files, as well as the ability to restart "
"a download."
msgstr ""
"Menjeda dan melanjutkan pengunduhan file-file, begitu pula kemampuan untuk "
"memulai kembali sebuah unduh-an."

#. (itstool) path: ul/li
#: org.kde.kget.appdata.xml:19
msgid "Tells lots of information about current and pending downloads."
msgstr ""
"Memberikan banyak informasi tentang unduh-an yang ada sekarang dan yang "
"sedang dihentikan."

#. (itstool) path: ul/li
#: org.kde.kget.appdata.xml:20
msgid "Embedding into system tray."
msgstr "Menanamkan ke dalam baki sistem."

#. (itstool) path: ul/li
#: org.kde.kget.appdata.xml:21
msgid "Integration with the Konqueror web browser."
msgstr "Integrasi dengan web browser Konqueror."

#. (itstool) path: ul/li
#: org.kde.kget.appdata.xml:22
msgid ""
"Metalink support which contain multiple URLs for downloads, along with "
"checksums and other information."
msgstr ""
"Dukungan Metalink yang terdiri dari banyak bagian URL untuk unduh-an, "
"bersamaan dengan checksums dan informasi lain."

#. (itstool) path: screenshot/caption
#: org.kde.kget.appdata.xml:31
msgid "Downloading files with KGet"
msgstr "Mengunduh file-file menggunakan KGet"
