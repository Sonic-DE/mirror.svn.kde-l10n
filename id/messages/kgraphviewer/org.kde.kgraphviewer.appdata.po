#. (itstool) path: component/name
#: org.kde.kgraphviewer.appdata.xml:9
msgid "KGraphViewer"
msgstr "KGraphViewer"

#. (itstool) path: component/summary
#: org.kde.kgraphviewer.appdata.xml:10
msgid "A Graphviz DOT graph viewer"
msgstr "Sebuah penampil grafik Graphviz DOT"

#. (itstool) path: description/p
#: org.kde.kgraphviewer.appdata.xml:12
msgid ""
"KGraphViewer is a Graphviz DOT graph file viewer, aimed to replace the other "
"outdated Graphviz tools. Graphs are commonly used in scientific domains and "
"particularly in computer science."
msgstr ""
"KGraphViewer adalah sebuah penampil file grafik Graphviz DOT, ditujukan "
"untuk mengganti alat grafis lainnya yang kedaluwarsa."

#. (itstool) path: description/p
#: org.kde.kgraphviewer.appdata.xml:16
msgid "Features:"
msgstr "Fitur:"

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:18
msgid "Zooming"
msgstr "Pengezooman"

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:19
msgid "Threaded loading of several graphs in tabs"
msgstr "Pemuatan berutas dari beberapa grafik dalam tab-tab"

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:20
msgid "Saving of the recent files list"
msgstr "Penyimpanan daftar file-file terkini"

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:21
msgid "Manual reload of files"
msgstr "Pemuatan-ulang manual file-file"

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:22
msgid "Display of a bird-eye view of the graph"
msgstr "Mendisplaikan sebuah tampilan mata burung pada grafik"

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:23
msgid "Moving of the graph by dragging"
msgstr "Pemindahan grafik dengan penyeretan"

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:24
msgid "Full featured printing"
msgstr "Pencetakan yang penuh fitur"

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:25
msgid "Perfect drawing of all graphviz example graphs"
msgstr "Penggambaran sempurna dari semua grafik-grafik contoh graphviz"

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:26
msgid "Automatically choose dot for directed graphs and neato for undirected"
msgstr ""
"Memilih secara otomatis titik untuk grafik yang dilangsungkan dan neato "
"untuk yang takdilangsungkan"

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:27
msgid ""
"Possibility to use an arbitrary layout algorithm as soon as it produces xdot "
"format"
msgstr ""
"Secara mungkin untuk menggunakan sebuah algoritma tataletak sesukanya "
"setelah menghasilkan format xdot "

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:28
msgid ""
"Automatic reloading with user confirmation of (externally) modified files "
"(configurable)"
msgstr ""
"Memuat-ulang otomatis dengan konfirmasi pengguna dari (secara external) file-"
"file yang dimodifikasi (dapatdikonfigurasi)"

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:29
msgid "Open new instances as new tabs in the old one (configurable)"
msgstr ""
"Buka instansi baru sebagai tab-tab baru di dalam lawasnya "
"(dapatdikonfigurasi) "
