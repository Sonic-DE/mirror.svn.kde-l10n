msgid "File Manager"
msgstr "Pengelola File"

#. (itstool) path: description/p
#: org.kde.krusader.appdata.xml:13
msgid ""
"Krusader is an advanced twin panel (commander style) file manager for KDE "
"Plasma and other desktops in the *nix world"
msgstr ""
"Krusader adalah pengelola file panel kembar (gaya komandan) terkemuka untuk "
"KDE Plasma dan desktop lain di dunia *nix"

