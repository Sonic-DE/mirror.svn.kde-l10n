msgstr "Fitur:"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:16
msgid "Extensive archive handling"
msgstr "Menangani arsip secara leluasa"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:17
msgid "Mounted filesystem support"
msgstr "Dukungan filesystem yang dikaitkan"

#. (itstool) path: ul/li
