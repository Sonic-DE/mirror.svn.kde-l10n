#. (itstool) path: component/name
#: org.kde.skanlite.appdata.xml:10
msgid "Skanlite"
msgstr "Skanlite"

#. (itstool) path: component/summary
#: org.kde.skanlite.appdata.xml:11
msgid "Image Scanning Application"
msgstr "Aplikasi Pemindaian Citra"

#. (itstool) path: description/p
#: org.kde.skanlite.appdata.xml:13
msgid ""
"Skanlite is a simple image scanning application to scan and save images. It "
"is optimized for scanning with flatbed scanners. Skanlite can capture not "
"only photos and documents, but also transparent slides and filmstrips, with "
"supported scanners."
msgstr ""
"Skanlite adalah aplikasi pemindaian citra yang sederhana untuk memindai dan "
"menyimpan citra. Dioptimisasikan untuk pemindaian dengan pemindai flatbed. "
"Skanlite dapat menangkap tidak hanya citra dan dokumen, tetapi juga dengan "
"slide dan strip film yang transparan, dengan pemindai yang didukung."

#. (itstool) path: description/p
#: org.kde.skanlite.appdata.xml:17
msgid "Features:"
msgstr "Fitur:"

#. (itstool) path: ul/li
#: org.kde.skanlite.appdata.xml:19
msgid ""
"Save dialog for every image scanned or saving the images immediately in a "
"specified folder with auto-generated names and format"
msgstr ""
"Dialog penyimpanan untuk setiap citra yang dipindai atau penyimpanan citra "
"langsung ke dalam sebuah folder yang ditentukan dengan nama dan format yang "
"dihasilkan secara otomatis"

#. (itstool) path: ul/li
#: org.kde.skanlite.appdata.xml:20
msgid "Support for networks scanners"
msgstr "Mendukung pemindaian jaringan"

#. (itstool) path: ul/li
#: org.kde.skanlite.appdata.xml:21
msgid "Preview with selection feature for the final scan"
msgstr "Pratinjau dengan fitur pemilihan untuk pemindaian akhir"

#. (itstool) path: ul/li
#: org.kde.skanlite.appdata.xml:22
msgid "Scanning multiple selections of an image"
msgstr "Pemindaian pemilihan multipel pada sebuah citra"

#. (itstool) path: screenshot/caption
#: org.kde.skanlite.appdata.xml:27
msgid "Skanlite's basic options screen with a scanned image visible"
msgstr "Layar opsi dasar Skanlite dengan gambar pindaian yang terlihat"
