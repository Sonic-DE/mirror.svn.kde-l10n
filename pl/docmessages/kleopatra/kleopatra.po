"-->[Key Filter #<replaceable>n</replaceable>]\n"
"Name=expired, but not revoked\n"
"was-validated=true\n"
"is-expired=true\n"
"is-revoked=false\n"
"is-root-certificate=true\n"
"; ( specificity 4 )<!--\n"
"     -->"
msgstr ""
"<!--\n"
"--> [Key Filter #<replaceable>n</replaceable>]\n"
"Name=wygasły, ale nie unieważniony\n"
"was-validated=true\n"
"is-expired=true\n"
"is-revoked=false\n"
"is-root-certificate=true\n"
"; ( specificity 4 )<!--\n"
"     -->"

