"<menuchoice><guimenu>Idź</guimenu> <guimenuitem>W przód</guimenuitem></"
"menuchoice>."

#. Tag: para
#: index.docbook:1257
#, no-c-format
msgid ""
"There are multiple ways of scrolling the viewing area. One is to use the "
"<keysym>Up</keysym> and <keysym>Down</keysym> keys. You may also use the "
"scrollbar, your mousewheel or the <keysym>PgUp</keysym> and <keysym>PgDn</"
"keysym> keys."
msgstr ""

#. Tag: para
#: index.docbook:1263
#, fuzzy, no-c-format
#| msgid ""
#| "If you want to stop the download for any reason then use the <keycap>Esc</"
