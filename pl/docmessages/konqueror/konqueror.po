#. Tag: para
#: index.docbook:998
#, fuzzy, no-c-format
#| msgid ""
#| "Use <keycombo action=\"simul\">&Ctrl;<keycap>U</keycap></keycombo> or the "
#| "Menubar <menuchoice><guimenu>Edit</guimenu> <guimenuitem>Unselect All</"
#| "guimenuitem></menuchoice> option or just &LMB; click on a clear area of "
#| "the view to cancel the selection."
msgid ""
"Use the Menubar <menuchoice><guimenu>Edit</guimenu><guisubmenu>Selection</"
"guisubmenu> <guimenuitem>Unselect All</guimenuitem></menuchoice> option or "
"just &LMB; click on a clear area of the view to cancel the selection."
msgstr ""
"Za pomocą kombinacji <keycombo action=\"simul\">&Ctrl;<keycap>U</keycap></"
