#. Tag: title
#: index.docbook:314
#, no-c-format
msgid "Creating Custom &killbots; Themes"
msgstr "Tworzenie własnych motywów &killbots;"

#. Tag: para
#: index.docbook:315
#, no-c-format
msgid ""
"Like most other &kde; games, a &killbots; theme consists of three files."
msgstr ""
"Tak jak większość gier dla &kde;, motyw &killbots; składa się z trzech "
"plików."

#. Tag: title
#: index.docbook:318
#, no-c-format
msgid "The Desktop File"
msgstr "Plik Desktop"

#. Tag: para
#: index.docbook:319
#, fuzzy, no-c-format
#| msgid ""
#| "The desktop file follows standard <filename>INI</filename> syntax. The "
#| "key-value pairs store information about the theme and point to the other "
#| "files included in the theme. The following example is taken from the "
