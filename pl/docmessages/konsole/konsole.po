msgstr ""
"Kliknij na poleceniu <menuchoice><guimenu>Ustawienia</"
"guimenu><guimenuitem>Zarządzanie profilami...</guimenuitem> </menuchoice>"

#. Tag: para
#: index.docbook:161
#, fuzzy, no-c-format
#| msgid "Click on the button <guibutton>New Profile...</guibutton>."
msgid "Switch to the <guibutton>Profiles</guibutton> page."
msgstr "Naciśnij przycisk <guibutton>Nowy profil...</guibutton>."

#. Tag: para
#: index.docbook:163
#, no-c-format
msgid "Click on the button <guibutton>New Profile...</guibutton>."
msgstr "Naciśnij przycisk <guibutton>Nowy profil...</guibutton>."

#. Tag: para
#: index.docbook:165
#, no-c-format
msgid ""
"Fill in the first entry with a name. This is the name that will show in the "
