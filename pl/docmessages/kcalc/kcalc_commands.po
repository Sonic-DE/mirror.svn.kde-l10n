#. Tag: title
#: commands.docbook:3
#, no-c-format
msgid "Command Reference"
msgstr "Wykaz poleceń"

#. Tag: title
#: commands.docbook:6
#, no-c-format
msgid "Menu Items"
msgstr ""

#. Tag: para
#: commands.docbook:8
#, no-c-format
msgid "A brief overview of some special menu items in &kcalc;:"
msgstr ""

#. Tag: menuchoice
#: commands.docbook:12
#, no-c-format
msgid "<guimenu>Constants</guimenu> <guimenuitem>Mathematics</guimenuitem>"
msgstr "<guimenu>Stałe</guimenu> <guimenuitem>Matematyka</guimenuitem>"

#. Tag: action
#: commands.docbook:16
#, fuzzy, no-c-format
#| msgid "Display Pi, Euler Number or Golder Ratio."
msgid "Display Pi, Euler Number or Golden Ratio."
msgstr "Wstawia liczbę Pi, liczbę Eulera  lub złoty podział."

#. Tag: menuchoice
#: commands.docbook:21
#, no-c-format
msgid ""
"<guimenu>Constants</guimenu> <guimenuitem>Electromagnetism</guimenuitem>"
msgstr "<guimenu>Stałe</guimenu> <guimenuitem>Elektromagnetyzm</guimenuitem>"

#. Tag: action
#: commands.docbook:25
#, no-c-format
msgid ""
"Display Light Speed, Elementary Charge, Impedance of Vacuum, Permeability of "
"Vacuum or Permittivity of Vacuum."
msgstr ""
"Wstawia prędkość światła, ładunek elementarny, impedancję próżni, "
"przenikalność próżni lub przenikalność elektryczną próżni."

#. Tag: menuchoice
#: commands.docbook:31
#, no-c-format
msgid ""
"<guimenu>Constants</guimenu> <guimenuitem>Atomic &amp; Nuclear</guimenuitem>"
msgstr "<guimenu>Stałe</guimenu> <guimenuitem>Atomowe i jądrowe</guimenuitem>"

#. Tag: action
#: commands.docbook:35
#, no-c-format
msgid ""
"Display Planck's Constant, Elementary Charge or Fine-Structure Constant."
msgstr ""
"Wstawia stałą Plancka, ładunek elementarny lub stałą struktury subtelnej."

#. Tag: menuchoice
#: commands.docbook:41
#, no-c-format
msgid "<guimenu>Constants</guimenu> <guimenuitem>Thermodynamics</guimenuitem>"
msgstr "<guimenu>Stałe</guimenu> <guimenuitem>Termodynamika</guimenuitem>"

#. Tag: action
#: commands.docbook:45
#, no-c-format
msgid ""
"Display Boltzmann Constant, Atomic Mass Unit, Molar Gas Constant, Stefan-"
"Boltzmann Constant or Avogadro's Number."
msgstr ""
"Wstawia stałą Boltzmanna, jednostkę masy atomowej, stałą molową stałą "
"Stefana-Boltzmanna lub liczbę Avogadro."

#. Tag: menuchoice
#: commands.docbook:51
#, no-c-format
msgid "<guimenu>Constants</guimenu> <guimenuitem>Gravitation</guimenuitem>"
msgstr "<guimenu>Stałe</guimenu> <guimenuitem>Grawitacja</guimenuitem>"

#. Tag: para
#: commands.docbook:55
#, no-c-format
msgid "Display Constant of Gravitation or Earth Acceleration."
msgstr "Wstawia stałą grawitacji lub przyspieszenie ziemskie."

#. Tag: menuchoice
#: commands.docbook:60
#, fuzzy, no-c-format
#| msgid "<guimenu>Settings</guimenu> <guimenuitem>Hide All</guimenuitem>"
msgid "<guimenu>Settings</guimenu> <guimenuitem>Simple Mode</guimenuitem>"
