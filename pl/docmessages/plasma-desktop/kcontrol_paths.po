#. Tag: guilabel
#: index.docbook:65
#, no-c-format
msgid "Desktop path:"
msgstr "Ścieżka do pulpitu:"

#. Tag: para
#: index.docbook:66
#, fuzzy, no-c-format
#| msgid ""
#| "The Desktop folder contains all the files which you see on your desktop. "
#| "The default path is usually <filename class=\"directory\">~/Desktop</"
#| "filename> but you can change here the location of this folder."
msgid ""
"The Desktop folder contains all the files which you see in a "
"<guilabel>Folder View</guilabel> widget on your desktop. The default path is "
"usually <filename class=\"directory\">~/Desktop</filename> but you can "
"change here the location of this folder."
msgstr ""
"Katalog Pulpit zawiera wszystkie pliki widoczne na pulpicie. Domyślną "
"ścieżką jest zazwyczaj <filename class=\"directory\">~/Desktop</filename>, "
"lecz można zmienić położenie tego katalogu."

