#. Tag: title
#: index.docbook:404
#, no-c-format
msgid "Frequently asked questions"
msgstr "Najczęściej zadawane pytania"

#. Tag: para
#: index.docbook:409
#, no-c-format
msgid "I want to change the way this game looks. Can I?"
msgstr "Chciałbym zmienić wygląd gry. Czy mogę?"

#. Tag: para
#: index.docbook:410
#, fuzzy, no-c-format
#| msgid ""
#| "Yes. To change &kbounce; visual theme you can use "
#| "<menuchoice><guimenu>Settings</guimenu><guimenuitem>Configure &kbounce;..."
#| "</guimenuitem></menuchoice> option on the menubar."
msgid ""
"Yes. To change &kbounce; visual theme you can use "
"<menuchoice><guimenu>Settings</guimenu><guimenuitem>Configure &kbounce;…</"
"guimenuitem></menuchoice> option on the menubar."
msgstr ""
"Tak. Zmienić wygląd &kbounce; możesz wybierając opcję "
"<menuchoice><guimenu>Ustawienia</guimenu><guimenuitem>Konfiguracja "
"&kbounce;...</guimenuitem></menuchoice> z menu."

#. Tag: para
#: index.docbook:413
#, no-c-format
msgid "I have made a mistake. Can I undo?"
msgstr "Zrobiłem błąd. Czy mogę cofnąć ruch?"

#. Tag: para
#: index.docbook:414
#, no-c-format
msgid "&kbounce; does not have an <quote>Undo</quote> feature."
msgstr "&kbounce; nie zawiera opcji <quote>Cofnij</quote>."

#. Tag: para
#: index.docbook:417
#, no-c-format
msgid "Can I use the keyboard to play this game?"
msgstr "Czy mogę używać klawiatury do grania w tą grę?"

#. Tag: para
#: index.docbook:418
#, no-c-format
msgid "No. &kbounce; cannot be played using keyboard."
msgstr "Nie. W grę &kbounce; nie można grać używając klawiatury."

#. Tag: para
#: index.docbook:421
#, no-c-format
msgid ""
"I have to quit the game now, but I am not finished yet. Can I save my "
"progress?"
msgstr "Muszę zakończyć grę w trakcie rozgrywki. Czy mogę zapisać jej stan?"

#. Tag: para
#: index.docbook:422
#, no-c-format
msgid "&kbounce; does not have a <quote>Save</quote> feature at the moment."
msgstr "&kbounce; jeszcze nie posiada jeszcze opcji <quote>Zapisz</quote>."

