#. Tag: para
#: configure.docbook:130
#, fuzzy, no-c-format
#| msgid ""
#| "You can find a quick introduction to the <guilabel>Identities</guilabel> "
#| "page in the <link linkend=\"getting-started\">Getting Started</link> "
#| "section."
