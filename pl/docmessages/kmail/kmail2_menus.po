#. Tag: para
#: menus.docbook:167
#, fuzzy, no-c-format
#| msgid ""
#| "<action>Sets &kmail; to offline mode.</action> This turns off all network "
#| "jobs. This is useful when working with messages without a network "
#| "connection. This selection will become <menuchoice><guimenu>File</"
#| "guimenu><guimenuitem>Work Online</guimenuitem></menuchoice>, which needs "
