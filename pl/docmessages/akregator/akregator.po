#. Tag: para
#: index.docbook:389
#, fuzzy, no-c-format
#| msgid ""
#| "You should leave this option enabled whenever possible. Disabling this "
#| "option leads to increased network traffic. The traffic caused by "
#| "aggregators not using caching increases the costs for providers and may "
