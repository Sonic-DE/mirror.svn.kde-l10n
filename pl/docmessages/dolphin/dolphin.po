#: index.docbook:1302
#, no-c-format
msgid "Details"
msgstr "Szczegóły"

#. Tag: para
#: index.docbook:1305
#, no-c-format
msgid ""
"<guilabel>Expandable folders</guilabel> determines whether any folders that "
"have subfolders are displayed in a tree view, where the sub items can be "
"expanded by &LMB; clicking the <guiicon>&gt;</guiicon> icon and collapsed by "
"clicking the <guiicon>v</guiicon> icon."
msgstr ""
"<guilabel>Rozwijalne katalogi</guilabel> określa czy katalogi, które mają "
"podkatalogi są wyświetlane w widoku drzewa, gdzie podelementy można rozwinąć "
