#. Tag: title
#: index.docbook:1290
#, no-c-format
msgid "Compact"
msgstr "Kompaktowy"

#. Tag: para
#: index.docbook:1293
#, no-c-format
msgid ""
"<guilabel>Maximum width</guilabel> controls the maximum width that is "
"reserved for the text of a file item."
msgstr ""
"<guilabel>Największa szerokość</guilabel> określa największą szerokość "
"zajętą dla testu pliku."

