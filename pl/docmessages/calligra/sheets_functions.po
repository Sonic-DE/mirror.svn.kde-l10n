#: functions.docbook:379
#, no-c-format
msgid "INT2BOOL(1) returns true"
msgstr "INT2BOOL(1) zwraca true"

#. Tag: para
#: functions.docbook:382
#, no-c-format
msgid "INT2BOOL(0) returns false"
msgstr "INT2BOOL(0) zwraca false"

