#, no-c-format
msgid ""
"MDURATION(\"2004-02-01\"; \"2004-05-31\"; 0.08; 0.09; 2; 0) returns "
"0.316321106"
msgstr ""
"MDURATION(\"2004-02-01\"; \"2004-05-31\"; 0.08; 0.09; 2; 0) zwraca "
"0.316321106"

