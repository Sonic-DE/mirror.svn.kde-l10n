#. Tag: para
#: part.docbook:414
#, fuzzy, no-c-format
#| msgid ""
#| "You can control the search mode by selecting the options <guilabel>Plain "
#| "Text</guilabel>, <guilabel>Whole Words</guilabel>, <guilabel>Escape "
#| "Sequences</guilabel> or <guilabel>Regular Expression</guilabel> described "
#| "above."
msgid ""
"You can control the search mode by selecting the options <guilabel>Plain "
"Text</guilabel>, <guilabel>Whole Words</guilabel>, <guilabel>Escape "
"Sequences</guilabel> or <guilabel>Regular Expression</guilabel> from the "
"drop down box."
msgstr ""
"Można ustawiać pożądany tryb szukania i zamiany wybierając opcje "
"<guilabel>Zwykły tekst</guilabel>, <guilabel>Całe wyrazy</guilabel>, "
"<guilabel>Sekwencje sterujące</guilabel> lub <guilabel>Wyrażenie regularne</"
"guilabel>, które zostały opisane powyżej."

#. Tag: para
#: part.docbook:418
#, fuzzy, no-c-format
#| msgid ""
#| "If selected, the search string is interpreted as a regular expression. "
#| "The <guibutton>Add</guibutton> button will be enabled and allows you to "
#| "add regular expression items to the search pattern from a predefined list."
msgid ""
"If <guilabel>Escape sequences</guilabel> or <guilabel>Regular expression</"
