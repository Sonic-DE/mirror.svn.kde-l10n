#. Tag: term
#: fundamentals.docbook:587
#, no-c-format
msgid "This manual"
msgstr "Niniejszy podręcznik"

#. Tag: para
#: fundamentals.docbook:590
#, fuzzy, no-c-format
#| msgid ""
#| "Offers detailed documentation on all menu commands, configuration "
