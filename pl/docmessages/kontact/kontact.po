#. Tag: title
#: index.docbook:759
#, no-c-format
msgid "Module-related Arguments"
msgstr "Argumenty związane z modułami"

#. Tag: para
#: index.docbook:761
#, no-c-format
msgid "To get a list of available &kontact; modules, you can type:"
msgstr ""
"Aby uzyskać listę dostępnych modułów programu &kontact;, należy wpisać:"

#. Tag: para
#: index.docbook:763
#, no-c-format
msgid "<prompt>&percnt;</prompt> <command>kontact --list</command>"
msgstr "<prompt>&percnt;</prompt> <command>kontact --list</command>"

#. Tag: para
#: index.docbook:767
#, no-c-format
msgid "Then, to start &kontact; with a module active, type:"
msgstr "Następnie, aby uruchomić kontact z aktywnym modułem wpisz:"

#. Tag: para
#: index.docbook:769
#, no-c-format
