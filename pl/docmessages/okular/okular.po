#. Tag: guilabel
#: index.docbook:2695
#, no-c-format
msgid "Invert Colors"
msgstr "Odwróć kolory"

#. Tag: para
#: index.docbook:2697
#, no-c-format
msgid ""
"<action>Inverts</action> colors on the view, &ie; black objects will be "
"shown white."
msgstr ""
"<action>Odwraca</action> kolory stron, czyli obiekty w czarnym kolorze staną "
"się białe."

#. Tag: guilabel
#: index.docbook:2701
#, no-c-format
msgid "Change Paper Color"
msgstr "Zmień kolor papieru"

#. Tag: para
#: index.docbook:2703
#, no-c-format
msgid ""
"<action>Changes</action> the paper's color, &ie; the document's background."
msgstr "<action>Zmienia</action> kolor tła stron."

#. Tag: para
#: index.docbook:2704
#, no-c-format
msgid ""
"The color can be selected using the <guilabel>Paper color</guilabel> swatch "
"below."
