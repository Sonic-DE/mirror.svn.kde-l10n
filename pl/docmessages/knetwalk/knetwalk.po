#. Tag: para
#: index.docbook:56
#, no-c-format
msgid ""
"The object of the game is to start the LAN, connecting all the terminals to "
"the server, in as few turns as possible."
msgstr ""
"Celem gry jest uruchomienie sieci LAN, poprzez podłączenie wszystkich "
"terminali do serwera, w jak najmniejszej liczbie ruchów."

#. Tag: title
#: index.docbook:60
#, no-c-format
msgid "How to Play"
msgstr "Jak grać"

#. Tag: title
#: index.docbook:62
#, no-c-format
msgid "Objective:"
