#. Tag: title
#: index.docbook:2364
#, no-c-format
msgid "Displaying &kalarm; in the System Tray"
msgstr "Wyświetlanie &kalarm-dopelniacz; na tacce systemowej"

#. Tag: para
#: index.docbook:2366
#, fuzzy, no-c-format
#| msgid ""
#| "You must be running the &kde; desktop or another suitable window manager "
