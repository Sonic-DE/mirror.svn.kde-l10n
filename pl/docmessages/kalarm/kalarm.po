#. Tag: guimenuitem
#: index.docbook:2355
#, no-c-format
msgid "Quit"
msgstr "Zakończ"

#. Tag: action
#: index.docbook:2356
#, no-c-format
msgid "Closes the &kalarm; system tray icon and main windows."
