#~ msgstr ""
#~ "<link linkend=\"color-options\">Zakładka <guilabel>Opcje</guilabel></"
#~ "link>, służy to zmiany ustawień bieżącego zestawu kolorów."

#~ msgid ""
#~ "<link linkend=\"color-colors\">The <guilabel>Colors</guilabel> tab</"
#~ "link>, used to change the colors of the current scheme."
#~ msgstr ""
#~ "<link linkend=\"color-colors\">Zakładka <guilabel>Kolory</guilabel></"
#~ "link>, służy do zmiany kolorów dla bieżącego zestawu."

#~ msgid ""
#~ "<link linkend=\"color-effects\">The state effects tabs</link> "
#~ "(<guilabel>Inactive</guilabel>, <guilabel>Disabled</guilabel>), used to "
#~ "change the state effects of the current scheme."
