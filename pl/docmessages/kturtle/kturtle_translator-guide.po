#~ "replaceable> jest kodem Twojego kraju (litera 2- lub 4- kod <acronym>ISO</"
#~ "acronym>)."

#~ msgid ""
#~ "In line 4 of the file, there is <sgmltag class=\"starttag\">language name="
#~ "\"en_US\"</sgmltag>...: here you change <quote>en_US</quote> to your "
#~ "language's <acronym>ISO</acronym> code (2 or 4 letters)."
