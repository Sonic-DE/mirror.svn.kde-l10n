#~ msgid ""
#~ "Translate into your own language the content of the <sgmltag class="
#~ "\"starttag\">item</sgmltag> tag (&ie; the information between <sgmltag "
#~ "class=\"starttag\">item</sgmltag> and <sgmltag class=\"endtag\">item</"
#~ "sgmltag>). This content must match the <filename>logokeyword</filename> "
#~ "file. For example, translate <quote>while</quote> in: <sgmltag class="
#~ "\"starttag\">item</sgmltag> while <sgmltag class=\"endtag\">item</"
#~ "sgmltag> and leave the spaces as they are (one at the beginning and one "
#~ "at the end). Please do not translate anything else."
#~ msgstr ""
#~ "Przetłumacz na swój język zawartość tagu <sgmltag class=\"starttag"
#~ "\">item</sgmltag> (&ie; informacje pomiędzy <sgmltag class=\"starttag"
#~ "\">item</sgmltag> oraz <sgmltag class=\"endtag\">item</sgmltag>). Ta "
#~ "zawartość musi pasować do pliku <filename>logokeyword</filename>. Na "
#~ "przykład, przetłumacz <quote>while</quote> w: <sgmltag class=\"starttag"
#~ "\">item</sgmltag> while <sgmltag class=\"endtag\">item</sgmltag> i "
#~ "pozostaw spacje na swoim miejscu (jedną na początku i jedną na końcu). "
#~ "Nie tłumacz niczego innego."

