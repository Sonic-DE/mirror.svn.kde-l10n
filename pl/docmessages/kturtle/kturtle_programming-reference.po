"trygonometryczne <userinput>sin</userinput>, <userinput>cos</userinput> i "
"<userinput>tan</userinput>. Wejściem tych poleceń jest <link linkend=\"number"
"\">liczba</link> X."

#. Tag: term
#: programming-reference.docbook:473
#, no-c-format
msgid ""
"arcsin<indexterm><primary>arcsin</primary></indexterm>, "
"arccos<indexterm><primary>arccos</primary></indexterm>, arctan"
msgstr ""
"arcsin<indexterm><primary>arcsin</primary></indexterm>, "
"arccos<indexterm><primary>arccos</primary></indexterm>, arctan"

#. Tag: primary
