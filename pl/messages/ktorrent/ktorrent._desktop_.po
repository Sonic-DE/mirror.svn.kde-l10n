#: ktorrent/ktorrent.notifyrc:4
msgctxt "Comment"
msgid "KTorrent"
msgstr "KTorrent"

#: ktorrent/ktorrent.notifyrc:67
msgctxt "Name"
msgid "Torrent silently opened"
msgstr "Torrent został otworzony po cichu"

#: ktorrent/ktorrent.notifyrc:117
msgctxt "Name"
msgid "Torrent stopped by error"
msgstr "Torrent zatrzymany przez błąd"

