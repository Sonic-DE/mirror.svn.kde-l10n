msgctxt "Name"
msgid "Torrent cannot be started"
msgstr "Nie można uruchomić torrenta"

#: ktorrent/ktorrent.notifyrc:574
msgctxt "Name"
msgid "Torrent cannot be loaded silently"
msgstr "Nie można wczytać torrenta bez potwierdzenia"

