#~ msgstr ""
#~ "Obsługa prostych działań na obrazach: obrót, odbicie w poziomie, odbicie "
#~ "w pionie oraz zmiana rozmiaru"

#~ msgid ""
#~ "Gwenview displaying an image, with additional metadata shown in the "
#~ "sidebar"
#~ msgstr "Gwenview wyświetla obraz z dodatkowymi metadanymi na pasku bocznym"

