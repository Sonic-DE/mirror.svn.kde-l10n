#. (itstool) path: component/name
#: org.kde.skanlite.appdata.xml:10
msgid "Skanlite"
msgstr "Skanlite"

#. (itstool) path: component/summary
#: org.kde.skanlite.appdata.xml:11
msgid "Image Scanning Application"
msgstr "Program do skanowania obrazów"

#. (itstool) path: description/p
#: org.kde.skanlite.appdata.xml:13
msgid ""
"Skanlite is a simple image scanning application to scan and save images. It "
"is optimized for scanning with flatbed scanners. Skanlite can capture not "
"only photos and documents, but also transparent slides and filmstrips, with "
"supported scanners."
msgstr ""
"Skanlite jest prostą aplikacją do skanowania i zapisywania obrazów. Jest "
"dostosowana do skanowania na płaskich skanerach. Skanlite może skanować nie "
"tylko zdjęcia i dokumenty, ale także przezrocza oraz taśmy filmowe na "
"skanerach, które to obsługują."

#. (itstool) path: description/p
#: org.kde.skanlite.appdata.xml:17
msgid "Features:"
msgstr "Możliwości:"

#. (itstool) path: ul/li
#: org.kde.skanlite.appdata.xml:19
msgid ""
"Save dialog for every image scanned or saving the images immediately in a "
"specified folder with auto-generated names and format"
msgstr ""
"Okno dialogowe zapisywania dla każdego zeskanowanego obrazu lub zapisywanie "
"obrazów bezpośrednio w podanym katalogu z samodzielnie utworzonymi nazwami i "
"wybranym formatem"

#. (itstool) path: ul/li
#: org.kde.skanlite.appdata.xml:20
msgid "Support for networks scanners"
msgstr "Obsługa skanerów w sieci"

#. (itstool) path: ul/li
#: org.kde.skanlite.appdata.xml:21
msgid "Preview with selection feature for the final scan"
msgstr "Podgląd z możliwością zaznaczenia ostatecznego skanowania"

#. (itstool) path: ul/li
#: org.kde.skanlite.appdata.xml:22
msgid "Scanning multiple selections of an image"
msgstr "Skanowanie wielu obszarów obrazu"

#. (itstool) path: screenshot/caption
#: org.kde.skanlite.appdata.xml:27
msgid "Skanlite's basic options screen with a scanned image visible"
msgstr "Podstawowy ekran ustawień Skanlite z widocznym zeskanowanym obrazem"
