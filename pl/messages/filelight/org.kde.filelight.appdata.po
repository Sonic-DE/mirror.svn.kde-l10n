#. (itstool) path: component/name
#: org.kde.filelight.appdata.xml:10
msgid "Filelight"
msgstr "Filelight"

#. (itstool) path: component/summary
#: org.kde.filelight.appdata.xml:11
msgid "Show disk usage and delete unused files"
msgstr "Pokaż wykorzystanie dysku i usuń nieużywane pliki"

#. (itstool) path: description/p
#: org.kde.filelight.appdata.xml:13
msgid ""
"Filelight is an application to visualize the disk usage on your computer by "
"showing folders using an easy-to-understand view of concentric rings. "
"Filelight makes it simple to free up space!"
msgstr ""
"Filelight jest aplikacją do obrazowania wykorzystania przestrzeni dyskowej "
"na twoim komputerze za pomocą łatwych do zrozumienia współśrodkowych "
"pierścieni. Filelight ułatwia zwalnianie miejsca!"

#. (itstool) path: description/p
#: org.kde.filelight.appdata.xml:16
msgid "Features:"
msgstr "Możliwości:"

#. (itstool) path: ul/li
#: org.kde.filelight.appdata.xml:18
msgid "Scan local, remote, or removable disks"
msgstr "Przeszukiwanie miejscowych, zdalnych, wymiennych dysków"

#. (itstool) path: ul/li
#: org.kde.filelight.appdata.xml:19
msgid "View detailed information about files and folders"
msgstr "Oglądanie szczegółowych danych o plikach i katalogach"

#. (itstool) path: ul/li
#: org.kde.filelight.appdata.xml:20
msgid "Delete files or folders that are taking up too much space"
msgstr "Usuwanie plików i katalogów, które zajmują za dużo miejsca"

#. (itstool) path: ul/li
#: org.kde.filelight.appdata.xml:21
msgid "Integration into the Dolphin, Konqueror, and Krusader file managers"
msgstr ""
"Integracja z przeglądarkami plików takimi jak: Dolphin, Konqueror i Krusader"

#. (itstool) path: ul/li
#: org.kde.filelight.appdata.xml:22
msgid "Configurable color schemes"
msgstr "Zestawy barwne do ustawienia"

#~ msgid ""
#~ "Filelight creates an interactive map of concentric segmented-rings that "
#~ "helps visualize disk usage on your computer"
#~ msgstr ""
#~ "Filelight tworzy interaktywną mapę współśrodkowych, dzielonych "
#~ "pierścieni, co ma na celu zobrazowanie wykorzystania przestrzeni dyskowej "
#~ "na twoim komputerze"

#~ msgid ""
#~ "Filelight is an application to visualize the disk usage on your computer"
#~ msgstr ""
#~ "Filelight jest apikacją do zobrazowania wykorzystania przestrzeni "
#~ "dyskowej na twoim komputerze"

#~ msgid "File system navigation by mouse clicks"
#~ msgstr "Poruszanie się po systemie plików poprzez mysz"

#~ msgid ""
#~ "Files and directories can be copied or removed directly from the context "
#~ "menu"
#~ msgstr ""
#~ "Pliki i katalogi można kopiować lub usuwać bezpośrednio z menu podręcznego"
