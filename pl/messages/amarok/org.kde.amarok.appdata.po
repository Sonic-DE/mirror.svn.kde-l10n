msgid "Features:"
msgstr "Możliwości:"

#. (itstool) path: ul/li
#: org.kde.amarok.appdata.xml:23
msgid "Dynamic playlists matching different criteria"
msgstr "Dynamiczne listy odtwarzania spełniające różne warunki"

#. (itstool) path: ul/li
#: org.kde.amarok.appdata.xml:24
msgid "Collection managing with rating support"
msgstr "Zarządzanie zbiorem wraz z obsługą ocen"

#. (itstool) path: ul/li
#: org.kde.amarok.appdata.xml:25
msgid "Support for basic iPod, MTP and UMS music player devices"
msgstr ""
"Obsługa dla podstawowych urządzeń odtwarzających muzykę takich jak iPod, MTP "
"oraz UMS"

#. (itstool) path: ul/li
#: org.kde.amarok.appdata.xml:26
msgid "Integrated Internet services: last.fm, Magnatune, Ampache and more."
msgstr "Zintegrowane usługi internetowe: last.fm, Magnatune, Ampache i więcej."

