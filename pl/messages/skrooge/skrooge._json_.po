#, fuzzy
#| msgctxt "Comment"
#| msgid ""
#| "An import backend for Skrooge using woob.\\n You must install woob and "
#| "configure correctly the bank module before using this backend.\\n\\n "
#| "Parameters:\\n 1-The list of accounts to import separated by '|'. If you "
#| "don't pass parameter then all accounts will be imported.\\n Example: "
#| "123@ca|456@bp\\n 2-The first date of imported operations in format YYYY-"
