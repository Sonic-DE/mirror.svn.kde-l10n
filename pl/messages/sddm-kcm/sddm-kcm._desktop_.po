#: kcm_sddm.actions:2
msgctxt "Name"
msgid "SDDM"
msgstr "SDDM"

#: kcm_sddm.actions:58
msgctxt "Name"
msgid "Save Settings"
msgstr "Zapisz ustawienia"

#: kcm_sddm.actions:109
msgctxt "Description"
msgid "Save Settings in SDDM"
msgstr "Zapisz ustawienia w SDDM"

#: kcm_sddm.actions:163
msgctxt "Name"
msgid "Install an SDDM theme"
msgstr "Wgraj wygląd SDDM"

#: kcm_sddm.actions:213
msgctxt "Description"
msgid "Extract a zip file containing an SDDM theme to the SDDM theme location"
msgstr "Wypakuj plik zip zawierający wygląd SDDM do katalogu wyglądów SDDM"

#: kcm_sddm.actions:254
msgctxt "Name"
msgid "Uninstall an SDDM theme"
msgstr "Usuń wygląd SDDM"

#: kcm_sddm.actions:304
msgctxt "Description"
msgid "Remove a previously installed SDDM theme"
msgstr "Usuń poprzednio wgrany wygląd SDDM"

#: kcm_sddm.actions:345
msgctxt "Name"
msgid "Synchronize Settings"
msgstr "Synchronizuj ustawienia"

#: kcm_sddm.actions:391
msgctxt "Description"
msgid "Synchronize user settings with SDDM settings"
msgstr "Synchronizuje ustawienia użytkownika z ustawieniami SDDM"

#: kcm_sddm.actions:432
msgctxt "Name"
msgid "Reset Settings"
msgstr "Wyzeruj ustawienia"

#: kcm_sddm.actions:478
msgctxt "Description"
msgid "Reset SDDM settings to factory default state"
msgstr "Wyzeruj ustawienia SDDM do domyślnych"

