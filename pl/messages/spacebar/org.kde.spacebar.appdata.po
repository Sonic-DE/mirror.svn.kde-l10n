msgid "Spacebar"
msgstr "Spacebar"

#. (itstool) path: component/summary
#: org.kde.spacebar.appdata.xml:5
msgid "SMS/MMS messaging client"
msgstr "Program do wiadomości SMS/MMS"

#. (itstool) path: description/p
#: org.kde.spacebar.appdata.xml:12
msgid ""
"Spacebar is a SMS/MMS messaging client. It allows you to send text messages, "
"pictures and other files over a cellular network."
msgstr ""
"Spacebar to program do wiadomości SMS/MMS. Umożliwia wysyłanie wiadomości "
"tekstowych, zdjęć i innych plików w sieciach komórkowych."

#~ msgid "KDE Community"
#~ msgstr "Społeczność KDE"

#~ msgid ""
#~ "Spacebar is a telepathy client for Plasma Mobile, that is primarily "
#~ "written for sending and receiving SMS/MMS."
#~ msgstr ""
#~ "Spacebar jest klientem telepathy dla Plasma Mobile, który został głównie "
#~ "napisany do wysyłania i odbierania SMS/MMS."
