#. (itstool) path: component/name
#: org.kde.tellico.appdata.xml:9
msgid "Tellico"
msgstr "Tellico"

#. (itstool) path: component/summary
#: org.kde.tellico.appdata.xml:10
msgid "Collection Manager"
msgstr "Zarządzanie zbiorem"

#. (itstool) path: description/p
#: org.kde.tellico.appdata.xml:12
msgid ""
"Tellico is an application for organizing your collections. It provides "
"default templates for books, bibliographies, videos, music, video games, "
"coins, stamps, trading cards, comic books, and wines. It allows you to enter "
"your collection in a catalogue database, saving many different properties "
"like title, author, etc."
msgstr ""
"Tellico jest programem do porządkowania twoich zbiorów. Dostarcza domyślnych "
"szablonów dla książek, bibliografii, filmów, muzyki, gier wideo, monet, "
"znaczków, kart handlowych, komiksów i win. Umożliwia wprowadzenie całego "
"twojego zbioru do bazy danych katalogu, zapisując przy tym wiele różnych "
"właściwości takich jak tytuł, autor, itp."

#. (itstool) path: description/p
#: org.kde.tellico.appdata.xml:17
msgid "Features:"
msgstr "Cechy:"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:19
msgid ""
"Supports default collections of books, bibliographic entries, videos, music, "
"video games, comic books, coins, stamps, trading cards, wines, board games, "
"and file catalogs"
msgstr ""
"Obsługa domyślnych zbiorów książek, bibliografii, filmów, muzyki, gier "
"wideo, monet, znaczków, kart handlowych, komiksów i win, gier planszowych "
"oraz katalogów plików"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:20
msgid "Supports user-defined custom collections"
msgstr "Obsługa zbiorów określonych przez użytkownika"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:21
msgid ""
"Supports any number of user-defined fields, of several different types: "
"text, paragraph, list, checkbox, number, URL, date, images, and combinations"
msgstr ""
"Obsługa dowolnej liczby pól określonych przez użytkownika, wielu różnych "
"rodzajów: tekst, akapit, spis, pole zaznaczane, liczba, adres URL, data, "
"obraz i ich kombinacje"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:22
msgid "Handles entries with multiple authors, genres, keywords, etc"
msgstr "Obsługa wpisów z wieloma autorami, gatunkami, słowami kluczowymi, itp."

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:23
msgid "Automatically formats titles and names"
msgstr "Samoczynne formatowanie tytułów i nazw"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:24
msgid "Supports collection searching and view filtering"
msgstr "Obsługa przedukiwania zbiorów i filtrowanych widoków"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:25
msgid "Sorts and groups collection by various properties"
msgstr "Szeregowanie i grupowanie zbiorów według różnych właściwości"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:26
msgid "Allows customizable entry templates through XSLT"
msgstr "Własne szablony wpisów dzięki XSLT"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:27
msgid "Imports MODS, Bibtex, RIS, CSV, PDF metadata, and many other formats"
msgstr ""
"Importowanie MODS, Bibtex, RIS, CSV, metadanych PDF i wielu innych formatów"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:28
msgid "Exports to Bibtex, ONIX, CSV, HTML, and other formats"
msgstr "Eksportowanie Bibtex, ONIX, CSV, HTML i innych formatów"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:29
msgid ""
"Imports information directly from Amazon.com, IMDb, z39.50 servers, PubMed, "
"SRU servers, CrossRef.org, various other websites, and from external scripts"
msgstr ""
"Importowanie szczegółów bezpośrednio z Amazon.com, IMDb, serwerów z39.50, "
"PubMed, serwerów SRU, CrossRef.org i różnych innych stron sieciowych, a "
"także z zewnętrznych skryptów"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:30
msgid "Imports CDDB data for cataloging audio CDs"
msgstr "Importowanie danych CDDB do katalogowanie płyt muzycznych"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:31
msgid "Scans and imports audio file collections, such as mp3 or ogg"
msgstr ""
"Przeszukiwanie i importowanie zbiorów plików dźwiękowych, takich jak mp3 czy "
"ogg"

