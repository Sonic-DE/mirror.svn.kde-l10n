#: src/helper/kcmgrub2.actions:2
msgctxt "Name"
msgid "GRUB2 Bootloader Control Module"
msgstr "Moduł sterowania dla programu rozruchowego GRUB2"

#: src/helper/kcmgrub2.actions:50
msgctxt "Name"
msgid "Restore the default GRUB2 Bootloader settings"
msgstr "Przywróć domyślne ustawienia programu rozruchowego GRUB2"

#: src/helper/kcmgrub2.actions:94
msgctxt "Description"
msgid ""
"Administrator authorization is required to restore the default GRUB2 "
"Bootloader settings"
msgstr ""
"Do przywrócenia domyślnych ustawień programu rozruchowego GRUB2 potrzebne są "
"uprawnienia administratora"

#: src/helper/kcmgrub2.actions:141
msgctxt "Name"
msgid "Install the GRUB2 Bootloader"
msgstr "Zainstaluj program rozruchowy GRUB2"

#: src/helper/kcmgrub2.actions:187
msgctxt "Description"
msgid "Administrator authorization is required to install the GRUB2 Bootloader"
msgstr ""
"Do zainstalowania programu rozruchowego GRUB2 potrzebne są uprawnienia "
"administratora"

#: src/helper/kcmgrub2.actions:235
msgctxt "Name"
msgid "Load the GRUB2 Bootloader settings"
msgstr "Wczytaj ustawienia programu rozruchowego GRUB2"

#: src/helper/kcmgrub2.actions:281
msgctxt "Description"
msgid ""
"Administrator authorization is required to load the GRUB2 Bootloader settings"
msgstr "Do wczytania ustawień GRUB2 potrzebne są uprawnienia administratora"

#: src/helper/kcmgrub2.actions:329
msgctxt "Name"
msgid "Save the GRUB2 Bootloader settings"
msgstr "Zapisz ustawienia programu rozruchowego GRUB2"

#: src/helper/kcmgrub2.actions:374
msgctxt "Description"
msgid ""
"Administrator authorization is required to save the GRUB2 Bootloader settings"
msgstr ""
"Do zapisania ustawień programu rozruchowego GRUB2 potrzebne są uprawnienia "
"administratora"

