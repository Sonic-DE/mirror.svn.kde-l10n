#. (itstool) path: component/name
#: org.kde.krusader.appdata.xml:7
msgid "Krusader"
msgstr "Krusader"

#. (itstool) path: component/summary
#: org.kde.krusader.appdata.xml:8
msgid "File Manager"
msgstr "Zarządzanie plikami"

#. (itstool) path: description/p
#: org.kde.krusader.appdata.xml:13
msgid ""
"Krusader is an advanced twin panel (commander style) file manager for KDE "
"Plasma and other desktops in the *nix world"
msgstr ""
"Krusader jest zaawansowanym programem (działającym na poleceniach) do "
"zarządzania plikami w KDE Plazma i innych pulpitach ze świat *nix"

#. (itstool) path: description/p
#: org.kde.krusader.appdata.xml:14
msgid "Features:"
msgstr "Możliwości:"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:16
msgid "Extensive archive handling"
msgstr "Rozszerzona obsługa archiwów"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:17
msgid "Mounted filesystem support"
msgstr "Obsługa zamontowanych systemów plików"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:18
msgid "FTP support"
msgstr "Obsługa FTP"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:19
msgid "Advanced search module"
msgstr "Rozbudowany moduł wyszukiwania"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:20
msgid "Internal viewer/editor"
msgstr "Wewnętrzna przeglądarka/edytor"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:21
msgid "Folder synchronisation"
msgstr "Synchronizacja katalogów"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:22
msgid "File content comparisons"
msgstr "Porównywanie zawartości plików"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:23
msgid "Powerful batch renaming"
msgstr "Zaawansowana wsadowa zmiana nazwy"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:24
msgid ""
"Support for a wide variety of archive formats and can handle other KIO "
"slaves such as smb or fish."
msgstr ""
"Obsługa wielu formatów archiwow i innych podległych KIO takich jak smb lub "
"fish."

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:25
msgid "Completely customizable and very user friendly"
msgstr "Całkowicie dostosowalny i bardzo przyjazny użytkownikowi"

