#: files/plasma-setup.desktop.in:9 src/auth/org.kde.plasmasetup.actions:8
msgctxt "Name"
msgid "Plasma Setup"
msgstr "Ustawienia Plazmy"

#: files/plasma-setup.desktop.in:39
msgctxt "Comment"
msgid "Run the initial system setup for KDE"
msgstr "Wykonaj początkowe ustawienia systemu dla KDE"

#: src/auth/org.kde.plasmasetup.actions:42
msgctxt "Name"
msgid "Create User"
msgstr "Utwórz użytkownika"

#: src/auth/org.kde.plasmasetup.actions:71
msgctxt "Description"
msgid "Create the initial user account"
msgstr "Utwórz konto pierwszego użytkownika"

#: src/auth/org.kde.plasmasetup.actions:103
msgctxt "Name"
msgid "Create Completion Flag File"
msgstr "Utwórz plik flagowy uzupełnień"

#: src/auth/org.kde.plasmasetup.actions:131
msgctxt "Description"
msgid "Write the /etc/plasma-setup-done marker to prevent rerunning setup"
msgstr ""
"Zapisz znacznik w /etc/plasma-setup-done aby uniemożliwić ponowne otwieranie "
"ustawień"

#: src/auth/org.kde.plasmasetup.actions:162
msgctxt "Name"
msgid "Create New User Autostart Hook"
msgstr "Utwórz nowy haczyk wykonywany na starcie"

#: src/auth/org.kde.plasmasetup.actions:191
msgctxt "Description"
msgid "Create an autostart hook for the newly created user"
msgstr ""
"Utwórz nowy haczyk wykonywany na starcie dla nowo utworzonego użytkownika"

#: src/auth/org.kde.plasmasetup.actions:223
msgctxt "Name"
msgid "Remove Autologin"
msgstr "Usuń autologowanie"

#: src/auth/org.kde.plasmasetup.actions:252
msgctxt "Description"
msgid "Remove Display Manager autologin configuration"
msgstr "Usuń ustawienia autologowania z zarządzania wyświetlaniem"

#: src/auth/org.kde.plasmasetup.actions:282
msgctxt "Name"
msgid "Set New User Global Theme"
msgstr "Ustaw globalny wygląd nowego użytkownika"

#: src/auth/org.kde.plasmasetup.actions:311
msgctxt "Description"
msgid "Set the global theme for the new user"
msgstr "Ustaw globalny wygląd dla nowego użytkownika"

#: src/auth/org.kde.plasmasetup.actions:343
msgctxt "Name"
msgid "Set New User Display Scaling"
msgstr "Ustaw skalowanie wyświetlacza nowego użytkownika"

#: src/auth/org.kde.plasmasetup.actions:372
msgctxt "Description"
msgid "Set display scaling for the new user"
msgstr "Ustaw skalowanie wyświetlacza dla nowego użytkownika"

#: src/auth/org.kde.plasmasetup.actions:404
msgctxt "Name"
msgid "Set New User Home Directory Ownership"
msgstr "Ustaw właściciela katalogu nowego użytkownika"

#: src/auth/org.kde.plasmasetup.actions:433
msgctxt "Description"
msgid "Set ownership of the new users home directory to the newly created user"
msgstr "Ustaw właściciela katalogu domowego dla nowo utworzonego użytkownika"

#: src/auth/org.kde.plasmasetup.actions:465
msgctxt "Name"
msgid "Set New User Temporary Autologin"
msgstr "Ustaw tymczasowe autologowanie nowego użytkownika"

#: src/auth/org.kde.plasmasetup.actions:494
msgctxt "Description"
msgid ""
"Set display manager temporary autologin configuration for the newly created "
"user"
msgstr ""
"Ustaw tymczasowe autologowanie w zarządzaniu wyświetlaniem dla nowo "
"utworzonego użytkownika"

#~ msgctxt "Name"
#~ msgid "Disable Systemd Unit"
#~ msgstr "Wyłącz jednostkę systemd"

#~ msgctxt "Description"
#~ msgid "Disable the systemd unit for Plasma Setup"
#~ msgstr "Wyłącz jednostkę systemd dla Ustawień Plazmy"
