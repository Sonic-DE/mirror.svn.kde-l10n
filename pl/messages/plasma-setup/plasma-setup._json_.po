#: modules/account/metadata.json
msgctxt "Description"
msgid "Allow the user to set the account name."
msgstr "Zezwól użytkownikowi na nadanie nazwy kontu."

#: modules/cellular/metadata.json
msgctxt "Description"
msgid "Allow the user to configure the cellular network."
msgstr "Zezwól użytkownikowi na ustawienie sieci komórkowej."

#: modules/finished/metadata.json
msgctxt "Description"
msgid ""
"Shown when the initial system setup is completed, and the user can commit "
"the changes."
msgstr ""
"Pokazywane po ukończeniu początkowych ustawień i gdy użytkownik może "
"zatwierdzić zmiany."

#: modules/hostname/metadata.json
msgctxt "Description"
msgid "Allow the user to set the system hostname."
msgstr "Zezwól użytkownikowi na nadanie nazwy gospodarza."

#: modules/keyboard/metadata.json
msgctxt "Description"
msgid "Allow the user to choose the keyboard layout."
msgstr "Zezwól użytkownikowi na wybranie układu klawiatury."

#: modules/language/metadata.json
msgctxt "Description"
msgid "Allow the user to set the system language."
msgstr "Zezwól użytkownikowi na zmianę języka systemowego."

#: modules/prepare/metadata.json
msgctxt "Description"
msgid "Allows the user to configure the environment before using it."
msgstr "Zezwól użytkownikowi na ustawienie środowiska przed jego użyciem."

#: modules/time/metadata.json
msgctxt "Description"
msgid "Allow the user to set the timezone."
msgstr "Zezwól użytkownikowi na ustawienie strefy czasowej"

#: modules/wifi/metadata.json
msgctxt "Description"
msgid "Allow the user to connect to a Wi-Fi network."
msgstr "Zezwól użytkownikowi na połączenie się z siecią Wi-Fi."

