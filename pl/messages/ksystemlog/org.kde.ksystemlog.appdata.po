#. (itstool) path: component/name
#: org.kde.ksystemlog.appdata.xml:6
msgid "KSystemLog"
msgstr "KSystemLog"

#. (itstool) path: component/summary
#: org.kde.ksystemlog.appdata.xml:7
msgid "system log viewer"
msgstr "Przeglądarka dziennika systemowego"

#. (itstool) path: description/p
#: org.kde.ksystemlog.appdata.xml:9
msgid ""
"KSystemLog show all logs of your system, grouped by General (Default system "
"log, Authentication, Kernel, X.org...), and optional Services (Apache, Cups, "
"etc, ...). It includes many features to read nicely your log files:"
msgstr ""
"KSystemLog pokazuje wszystkie dzienniki systemu, zgrupowane wg ogólnych "
"(domyślny dziennik systemu, uwierzytelnienie, jądro, X.org...), oraz "
"opcjonalnych usług (Apache, Cups, itp.). Zawiera wiele ułatwień do czytania "
"plików dziennika:"

#. (itstool) path: ul/li
#: org.kde.ksystemlog.appdata.xml:13
msgid "Colorize log lines depending on their severities"
msgstr "Zabarwianie wierszy dziennika w zależności od ich znaczenia"

#. (itstool) path: ul/li
#: org.kde.ksystemlog.appdata.xml:14
msgid "Tabbed view to allow displaying several logs at the same time"
msgstr ""
"Widok w kartach umożliwiający przeglądanie kilku dzienników jednocześnie"

#. (itstool) path: ul/li
#: org.kde.ksystemlog.appdata.xml:15
msgid "Auto display new lines logged"
msgstr "Wyświetlanie nowych wierszy, które trafiły do dziennika"

#. (itstool) path: ul/li
#: org.kde.ksystemlog.appdata.xml:16
msgid "Detailed information for each log lines"
msgstr "Szczegółowe dane dla każdego wiersza dziennika"
