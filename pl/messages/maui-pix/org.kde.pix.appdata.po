#. (itstool) path: component/name
#: org.kde.pix.appdata.xml:7
msgid "Pix"
msgstr "Pix"

#. (itstool) path: component/summary
#: org.kde.pix.appdata.xml:8
msgid "Image Gallery"
msgstr "Galeria obrazów"

#. (itstool) path: description/p
#: org.kde.pix.appdata.xml:14
msgid ""
"Pix is an image gallery and image viewer. Pix can be used to open images "
"with other applications like an image editor, add tags to the files, add "
"annotations to pictures, rotate and share them."
msgstr ""
"Pix jest galerią obrazów i ich przeglądarką. Pix można użyć do otwierania "
"obrazów w innych aplikacjach takich jak edytory obrazów, dodawania "
"znaczników do plików, opisywania obrazów, ich obrotu, a także udostępniania."

