#: org.kde.kjournaldbrowser.appdata.xml:14
msgid "Journald Browser"
msgstr "Przeglądarka Journald"

#. (itstool) path: component/summary
#: org.kde.kjournaldbrowser.appdata.xml:15
msgid "Browser for journald databases"
msgstr "Przeglądarka dla baz danych journald"

#. (itstool) path: description/p
#: org.kde.kjournaldbrowser.appdata.xml:17
msgid ""
"Journald-browser is a reference implementation of the kjournald library and "
"provides a flexible tool to browse in local, remote and offline journald "
"databases."
msgstr ""
"Przeglądarka Journald jest wzorcową implementacją biblioteki kjournald i "
"dostarcza elastycznego narzędzia do przeglądania baz danych journald "
"lokalnych, zdalnych i odłączonych od sieci."

