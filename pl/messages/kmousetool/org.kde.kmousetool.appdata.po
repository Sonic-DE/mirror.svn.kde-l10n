#. (itstool) path: component/name
#: org.kde.kmousetool.appdata.xml:9
msgid "KMouseTool"
msgstr "KMouseTool"

#. (itstool) path: component/summary
#: org.kde.kmousetool.appdata.xml:10
msgid "Automatic clicks to reduce the effects of repetitive strain injury"
msgstr ""
"Samoczynne kliknięcia, aby ograniczyć efekt kontuzji spowodowanych "
"powtarzaną czynnością"

#. (itstool) path: description/p
#: org.kde.kmousetool.appdata.xml:12
msgid ""
"KMouseTool clicks the mouse for you, so you don't have to. KMouseTool works "
"with any mouse or pointing device."
msgstr ""
"KMouseTool klika myszą za ciebie, abyś sam nie musiał ego robić. KMouseTool "
"działa z każdą myszą lub urządzeniem wskazującym."

#~ msgid "Automatic Mouse Click"
#~ msgstr "Automatyczne kliknięcia myszą"
