msgstr "Twórz i układaj puzzle od 4 do 10 000 kawałków"

#. (itstool) path: ul/li
#: org.kde.palapeli.appdata.xml:21
msgid "Piece-holders for helping solve large puzzles"
msgstr "Pojemniki na puzzle pomagające w układaniu dużych puzzli"
