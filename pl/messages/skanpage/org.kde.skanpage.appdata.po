#. (itstool) path: component/name
#: org.kde.skanpage.appdata.xml:14
msgid "Skanpage"
msgstr "Skanpage"

#. (itstool) path: component/summary
#: org.kde.skanpage.appdata.xml:15
msgid "Scan multi-page documents and images"
msgstr "Skanuj wielostronicowe dokumenty i obrazy"

#. (itstool) path: description/p
#: org.kde.skanpage.appdata.xml:17
msgid ""
"Skanpage is a simple scanning application optimized for multi-page document "
"scanning. It can also scan and save single-page documents and images."
msgstr ""
"Skanpage jest prostym programem opracowany do wielostronicowego skanowania "
"dokumentów. Może także skanować i zapisywać jednostronnicowe dokumenty i "
"obrazy."

#. (itstool) path: description/p
#: org.kde.skanpage.appdata.xml:18
msgid "Features:"
msgstr "Możliwości:"

#. (itstool) path: ul/li
#: org.kde.skanpage.appdata.xml:20
msgid "Scanning from flatbed and ADF scanners"
msgstr "Skanowanie na skanerach płaskich oraz ADF"

#. (itstool) path: ul/li
#: org.kde.skanpage.appdata.xml:21
msgid "Configurable options for scanning device"
msgstr "Możliwość zmiany ustawień urządzenia skanującego"

#. (itstool) path: ul/li
#: org.kde.skanpage.appdata.xml:22
msgid "Reordering, rotation, and deletion of scanned pages"
msgstr "Zmiana kolejności, obrót i usuwanie zeskanowanych stron"

#. (itstool) path: ul/li
#: org.kde.skanpage.appdata.xml:23
msgid "Saving to multi-page PDF documents and image files"
msgstr "Zapisywanie wielostronicowych dokumentów PDF i plików obrazów"

#. (itstool) path: screenshot/caption
#: org.kde.skanpage.appdata.xml:29
msgid "Skanpage main window"
msgstr "Główne okno Skanpage"

