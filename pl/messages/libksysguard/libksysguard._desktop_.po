#: faces/systemmonitor-faces.knsrc:2
msgctxt "Name"
msgid "System monitor Sensor Display Styles"
msgstr "Sposób wyświetlania mierników w monitorze systemowym"

#: faces/systemmonitor-presets.knsrc:2
msgctxt "Name"
msgid "System monitor Sensor Presets"
msgstr "Nastawy mierników w monitorze systemowym"

#: processcore/actions.actions:2
msgctxt "Name"
msgid "KSysGuard"
msgstr "Monitor systemowy"

#: processcore/actions.actions:82
msgctxt "Name"
msgid "Kill or stop etc a process"
msgstr "Zniszcz lub zatrzymaj itp. proces"

#: processcore/actions.actions:148
msgctxt "Description"
msgid "Sends a given signal to a given process"
msgstr "Wysyła podany sygnał do podanego procesu"

#: processcore/actions.actions:218
msgctxt "Name"
msgid "Change the priority of a process"
msgstr "Zmień priorytet procesu"

#: processcore/actions.actions:286
msgctxt "Description"
msgid "Change the niceness of a given process"
msgstr "Zmień priorytet przydzielania (niceness) podanego procesu"

#: processcore/actions.actions:355
msgctxt "Name"
msgid "Change IO Scheduler and priority"
msgstr "Zmień program planujący obłożenie WE/WY i priorytet"

#: processcore/actions.actions:420
msgctxt "Description"
msgid "Change how the read and writes of a given process are prioritized"
msgstr ""
"Zmień sposób ustalania priorytetów operacji odczytu i zapisu podanego procesu"

#: processcore/actions.actions:487
msgctxt "Name"
msgid "Change CPU Scheduler and priority"
msgstr "Zmień program planujący obłożenie procesora i priorytet"

#: processcore/actions.actions:552
msgctxt "Description"
msgid ""
"Change which CPU scheduler is to schedule the running of a given process"
msgstr ""
"Zmień program planujący obłożenie procesora, który jest używany do "
"przydziału wykonywania podanego procesu"

