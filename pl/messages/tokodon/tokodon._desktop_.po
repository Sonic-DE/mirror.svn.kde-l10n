msgctxt "Name"
msgid "Update"
msgstr "Uaktualnij"

#: src/tokodon.notifyrc:472
msgctxt "Comment"
msgid "Someone edited a post"
msgstr "Ktoś zmienił twój wpis"

#: src/tokodon.notifyrc:508
msgctxt "Name"
msgid "Poll"
msgstr "Pokój"

#: src/tokodon.notifyrc:540
msgctxt "Comment"
msgid "Someone's poll ended"
msgstr "Czyjeś głosowanie dobiegło końca"

#: src/tokodon.notifyrc:574
msgctxt "Name"
msgid "Status"
msgstr "Stan"

#: src/tokodon.notifyrc:606
msgctxt "Comment"
msgid "Someone posted a new status"
msgstr "Ktoś wysłał nowy stan"

#: src/tokodon.notifyrc:641
msgctxt "Name"
msgid "Quote"
msgstr "Cytowanie"

