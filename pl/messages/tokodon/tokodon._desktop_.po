msgctxt "Comment"
msgid "Someone quoted you"
msgstr "Ktoś cię zacytował"

#: src/tokodon.notifyrc:687
msgctxt "Name"
msgid "Annual Report"
msgstr "Roczne sprawozdanie"

#: src/tokodon.notifyrc:715
