msgid "Krusader"
msgstr "Krusader"

#. (itstool) path: component/summary
#: org.kde.krusader.appdata.xml:8
msgid "File Manager"
msgstr "Διαχειριστής αρχείων"

#. (itstool) path: description/p
#: org.kde.krusader.appdata.xml:13
msgid ""
"Krusader is an advanced twin panel (commander style) file manager for KDE "
"Plasma and other desktops in the *nix world"
msgstr ""
"Ο Krusader είναι ένας προηγμένος διαχειριστής αρχείων με δίδυμο πάνελ (σε "
"στιλ commander) για το KDE Plasma και άλλες επιφάνειες εργασίας στον κόσμο "
"των *nix"

#. (itstool) path: description/p
#: org.kde.krusader.appdata.xml:14
msgid "Features:"
msgstr "Χαρακτηριστικά:"

#. (itstool) path: ul/li
