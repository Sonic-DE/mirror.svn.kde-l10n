msgid "FTP support"
msgstr "υποστήριξη FTP"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:19
msgid "Advanced search module"
msgstr "Άρθρωμα προηγμένης αναζήτησης"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:20
