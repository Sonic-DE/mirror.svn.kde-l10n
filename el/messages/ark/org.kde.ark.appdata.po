msgid "Several formats supported: gzip, bzip2, zip, rar, 7z and more"
msgstr ""
"Υποστηρίζονται πολλοί τύποι αποθήκευσης: gzip, bzip2, zip, rar, 7z και άλλοι"

#. (itstool) path: ul/li
