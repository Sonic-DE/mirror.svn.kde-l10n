#. (itstool) path: component/name
#: org.kde.kmousetool.appdata.xml:9
msgid "KMouseTool"
msgstr "KMouseTool"

#. (itstool) path: component/summary
#: org.kde.kmousetool.appdata.xml:10
msgid "Automatic clicks to reduce the effects of repetitive strain injury"
msgstr ""
"Αυτόματα κλικ για να μειωθούν οι συνέπειες των κακώσεων λόγω "
"επαναλαμβανόμενης καταπόνησης"

#. (itstool) path: description/p
#: org.kde.kmousetool.appdata.xml:12
msgid ""
"KMouseTool clicks the mouse for you, so you don't have to. KMouseTool works "
"with any mouse or pointing device."
msgstr ""
"Το KMouseTool κάνει κλικ το ποντίκι, έτσι εσείς δεν χρειάζεται να το κάνετε. "
"Το KMouseTool λειτουργεί με κάθε ποντίκι ή συσκευή με δείκτη."

#~ msgid "Automatic Mouse Click"
#~ msgstr "Αυτόματο κλικ ποντικιού"
