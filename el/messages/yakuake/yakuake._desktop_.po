#: data/org.kde.yakuake.desktop:2
msgctxt "Name"
msgid "Yakuake"
msgstr "Yakuake"

#: data/org.kde.yakuake.desktop:65
msgctxt "GenericName"
msgid "Drop-down Terminal"
msgstr "Τερματικό καθοδικής κύλισης"

#: data/org.kde.yakuake.desktop:128
msgctxt "Comment"
msgid "A drop-down terminal emulator based on KDE Konsole technology."
msgstr ""
"Μία εφαρμογή τερματικού καθοδικής κύλισης βασισμένη στην τεχνολογία KDE "
"Konsole."

