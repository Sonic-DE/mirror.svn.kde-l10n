#: data/konversation.notifyrc:66
msgctxt "Name"
msgid "New message"
msgstr "Νέο μήνυμα"

#: data/konversation.notifyrc:124
msgctxt "Comment"
msgid "New message arrived in a channel"
msgstr "Νέο μήνυμα έφτασε στο κανάλι"

#: data/konversation.notifyrc:181
msgctxt "Name"
msgid "Nick written"
msgstr "Το ψευδώνυμο γράφτηκε"

#: data/konversation.notifyrc:235
msgctxt "Comment"
msgid "Someone wrote your nick in a message"
msgstr "Κάποιος έγραψε το ψευδώνυμό σας σε ένα μήνυμα"

#: data/konversation.notifyrc:291
msgctxt "Name"
msgid "Highlight triggered"
msgstr "Η έμφαση πυροδοτήθηκε"

#: data/konversation.notifyrc:341
msgctxt "Comment"
msgid "Someone triggered a highlight"
msgstr "Κάποιος πυροδότησε μια έμφαση"

#: data/konversation.notifyrc:394
msgctxt "Name"
msgid "Private message"
msgstr "Προσωπικό μήνυμα"

#: data/konversation.notifyrc:448
msgctxt "Comment"
msgid "You received a private message"
msgstr "Λάβατε ένα προσωπικό μήνυμα"

#: data/konversation.notifyrc:505
msgctxt "Name"
msgid "Nick changed"
msgstr "Το ψευδώνυμο άλλαξε"

#: data/konversation.notifyrc:559
msgctxt "Comment"
msgid "Someone changed their nick"
msgstr "Κάποιος άλλαξε το ψευδώνυμό του"

#: data/konversation.notifyrc:615
msgctxt "Name"
msgid "Incoming file"
msgstr "Εισερχόμενο αρχείο"

#: data/konversation.notifyrc:672
msgctxt "Comment"
msgid "Someone wants to transmit a file to you over DCC"
msgstr "Κάποιος θέλει να σας στείλει ένα αρχείο μέσω DCC"

#: data/konversation.notifyrc:728
msgctxt "Name"
msgid "DCC transfer error"
msgstr "Σφάλμα μεταφοράς DCC"

#: data/konversation.notifyrc:779
msgctxt "Comment"
msgid "An error occurred in a DCC transfer"
msgstr "Ένα σφάλμα παρουσιάστηκε σε μια μεταφορά DCC"

#: data/konversation.notifyrc:832
msgctxt "Name"
msgid "DCC transfer complete"
msgstr "Η μεταφορά DCC ολοκληρώθηκε"

#: data/konversation.notifyrc:883
msgctxt "Comment"
msgid "A DCC transfer successfully completed"
msgstr "Μια μεταφορά DCC ολοκληρώθηκε επιτυχώς"

#: data/konversation.notifyrc:936
msgctxt "Name"
msgid "Nick joined channel"
msgstr "Το ψευδώνυμο συνδέθηκε στο κανάλι"

#: data/konversation.notifyrc:988
msgctxt "Comment"
msgid "New nick joined a channel"
msgstr "Νέο ψευδώνυμο συνδέθηκε σε ένα κανάλι"

#: data/konversation.notifyrc:1043
msgctxt "Name"
msgid "Nick left channel"
msgstr "Το ψευδώνυμο έφυγε από το κανάλι"

#: data/konversation.notifyrc:1096
msgctxt "Comment"
msgid "A nick left a channel"
msgstr "Ένα ψευδώνυμο έφυγε από ένα κανάλι"

#: data/konversation.notifyrc:1152
msgctxt "Name"
msgid "Mode change"
msgstr "Αλλαγή κατάστασης"

#: data/konversation.notifyrc:1205
msgctxt "Comment"
msgid "A user or channel mode was changed"
msgstr "Η κατάσταση ενός χρήστης ή καναλιού άλλαξε"

#: data/konversation.notifyrc:1261
msgctxt "Name"
msgid "Nick online"
msgstr "Το ψευδώνυμο είναι σε σύνδεση"

#: data/konversation.notifyrc:1307
msgctxt "Comment"
msgid "A user on your watched nicks list has come online"
msgstr ""
"Ένας χρήστης από τη λίστα ψευδώνυμων παρακολούθησης συνδέθηκε στο δίκτυο"

#: data/konversation.notifyrc:1362
msgctxt "Name"
msgid "Query"
msgstr "Ερώτηση"

#: data/konversation.notifyrc:1419
msgctxt "Comment"
msgid "Someone started a conversation (query) with you"
msgstr "Κάποιος ξεκίνησε μια συζήτηση (ερώτηση) μαζί σας"

#: data/konversation.notifyrc:1474
msgctxt "Name"
msgid "Kick"
msgstr "Απομάκρυνση"

#: data/konversation.notifyrc:1530
msgctxt "Comment"
msgid "Someone kicked you out of a channel"
msgstr "Κάποιος σας απομάκρυνε από ένα κανάλι"

#: data/konversation.notifyrc:1585
msgctxt "Name"
msgid "Connection failure"
msgstr "Αποτυχία σύνδεσης"

#: data/konversation.notifyrc:1640
msgctxt "Comment"
msgid "Failed to connect to server"
msgstr "Η σύνδεση με τον εξυπηρετητή απέτυχε"

#: data/konversation.notifyrc:1697
msgctxt "Name"
msgid "You joined a channel"
msgstr "Συνδεθήκατε σε ένα κανάλι"

#: data/konversation.notifyrc:1749
msgctxt "Comment"
msgid "You joined a channel"
msgstr "Συνδεθήκατε σε ένα κανάλι"

#: data/konversation.notifyrc:1804
msgctxt "Name"
msgid "DCC Chat"
msgstr "Συζήτηση DCC"

#: data/konversation.notifyrc:1860
msgctxt "Comment"
msgid "Someone started a DCC chat with you"
msgstr "Κάποιος ξεκίνησε μια συζήτηση DCC μαζί σας"

