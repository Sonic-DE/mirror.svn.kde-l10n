msgid "Create and play puzzles ranging from 4 to 10,000 pieces"
msgstr "Δημιουργήστε και παίξετε με παζλ από 4 έως και 10000 κομμάτια"

#. (itstool) path: ul/li
#: org.kde.palapeli.appdata.xml:21
msgid "Piece-holders for helping solve large puzzles"
msgstr "Βάσεις κομματιών για βοήθεια στην επίλυση μεγάλων παζλ"
