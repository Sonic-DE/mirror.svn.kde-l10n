#. Tag: title
#: index.docbook:1916
#, fuzzy, no-c-format
#| msgid "Saving Settings &amp; Profiles"
msgid "Saving Settings"
msgstr "Αποθήκευση ρυθμίσεων &amp; προφίλ"

#. Tag: para
#: index.docbook:1917
#, fuzzy, no-c-format
#| msgid ""
#| "But you can also specify different <guimenu>View</guimenu> menu settings "
