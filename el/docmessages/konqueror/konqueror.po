msgstr ""
"<menuchoice> <guimenu>Επεξεργασία</guimenu> <guisubmenu>Επιλογή</guisubmenu> "
"<guimenuitem>Αποεπιλογή αντικειμένων που ταιριάζουν...</guimenuitem></"
"menuchoice> (Λειτουργία διαχειριστή αρχείων)"

#. Tag: para
#: index.docbook:2855
#, fuzzy, no-c-format
#| msgid ""
#| "Unselect files or folders via a dialog similar to the one used by "
