#: index.docbook:280
#, no-c-format
msgid "<phrase>System Tray settings dialog</phrase>"
msgstr "<phrase>Διάλογος ρυθμίσεων Πλαισίου Συστήματος</phrase>"

#. Tag: title
#: index.docbook:287
#, no-c-format
msgid "Device Notifier"
