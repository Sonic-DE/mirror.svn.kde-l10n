#, no-c-format
msgid "&plasma; Widgets"
msgstr "Γραφικά συστατικά του &plasma;"

#. Tag: para
#: index.docbook:83
#, no-c-format
msgid "Applets, or small applications that live on the desktop."
msgstr "Μικροεφαρμογές (applet) που κατοικούν στην επιφάνεια εργασίας."

