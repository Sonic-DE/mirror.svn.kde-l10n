#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:136 org.kde.kweather.appdata.xml:144
#: org.kde.kweather.appdata.xml:152
msgid "User interface improvements and bugfixes"
msgstr "Millores en la interfície d'usuari i correccions d'errors"

#. (itstool) path: description/p
#: org.kde.kweather.appdata.xml:159 org.kde.kweather.appdata.xml:174
#: org.kde.kweather.appdata.xml:185
msgid "Changes:"
msgstr "Canvis:"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:161
msgid "Performance improvements in Dynamic view"
msgstr "Millores de rendiment a la vista dinàmica"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:162
msgid "Dynamic view action bar rewritten to be inline to content"
msgstr ""
"Barra d'acció de vista dinàmica reescrita per a estar inclosa al contingut"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:163
msgid "Allow setting non-current location in default forecasts page"
msgstr ""
"Permet establir la ubicació no actual a la pàgina de previsions "
"predeterminades"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:164
msgid "Added ability to fetch temperature units from system locale"
msgstr ""
"Afegeix la capacitat d'obtenir unitats de temperatura de la configuració "
"regional del sistema"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:165
msgid "Fixed timezone format not being correctly read for local location time"
msgstr ""
"Corregeix el format del fus horari que no es llegia correctament per a "
"l'hora local de la ubicació"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:176
msgid "Rewrote the weather plasmoid"
msgstr "Reescrit el plasmoide meteorològic"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:177
msgid "Use inline page indicator for flat mode forecasts"
msgstr "Usa l'indicador de pàgina inclosa per a les previsions en mode pla"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:178
msgid "Fix location ordering not persisting"
msgstr "Corregeix l'ordre de les ubicacions que no persisteix"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:187
msgid "Reworked the locations page to better handle long location names"
msgstr ""
"Refà la pàgina d'ubicacions per gestionar millor els noms de les ubicacions "
"llargues"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:188
msgid "Add maximum width to dynamic forecast to better deal with widescreen"
msgstr ""
"Afegeix l'amplada màxima a la previsió dinàmica per gestionar millor les "
"pantalles amples"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:189
msgid "Remove plasmoid (it is being reworked!)"
msgstr "Elimina el plasmoide (s'està tornant a fer!)"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:190
msgid "Fixed default page not being loaded when new locations are added"
msgstr ""
"Corregeix la pàgina predeterminada que no es carregava quan s'afegien "
"ubicacions noves"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:191
msgid "Unify application settings location"
msgstr "Unifica la configuració de la ubicació a l'aplicació"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:192
msgid "Enable qml debugging when in debug mode"
msgstr "Activa la depuració del QML quan és en el mode de depuració"

