msgid "View real-time weather forecasts"
msgstr "Visualitza previsions meteorològiques en temps real"

#. (itstool) path: description/p
#: org.kde.kweather.appdata.xml:28
msgid ""
"A convergent weather application for Plasma. Has flat and dynamic/animated "
"views for showing forecasts and other information."
msgstr ""
"Una aplicació convergent de meteorologia per al Plasma. Té vistes planes i "
"dinàmiques/animades per a mostrar els pronòstics i altra informació."

