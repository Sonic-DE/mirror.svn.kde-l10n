#: fileitemactionplugin/kdeconnectsendfile.json
msgctxt "Name"
msgid "Send file via KDE Connect"
msgstr "Envia el fitxer a través del KDE Connect"

#: plasmoid/package/metadata.json
msgctxt "Name"
msgid "KDE Connect"
msgstr "KDE Connect"

#: plugins/battery/kdeconnect_battery.json
msgctxt "Name"
msgid "Battery monitor"
msgstr "Monitor de la bateria"

#: plugins/clipboard/kdeconnect_clipboard.json
msgctxt "Name"
msgid "Clipboard synchronization"
msgstr "Sincronització del porta-retalls"

#: plugins/connectivity-report/kdeconnect_connectivity_report.json
msgctxt "Name"
msgid "Connectivity monitor"
msgstr "Monitor de la connectivitat"

#: plugins/contacts/kdeconnect_contacts.json
msgctxt "Name"
msgid "Sync Contacts"
msgstr "Sincronització dels contactes"

#: plugins/digitizer/kdeconnect_digitizer.json
msgctxt "Name"
msgid "Drawing tablet"
msgstr "Tauleta de dibuix"

#: plugins/findmyphone/kdeconnect_findmyphone.json
msgctxt "Name"
msgid "Find other devices"
msgstr "Troba altres dispositius"

#: plugins/findthisdevice/kdeconnect_findthisdevice.json
msgctxt "Name"
msgid "Find this device"
msgstr "Troba aquest dispositiu"

#: plugins/lockdevice/kdeconnect_lockdevice.json
msgctxt "Name"
msgid "Lock Device"
msgstr "Bloqueig de dispositiu"

#: plugins/mmtelephony/kdeconnect_mmtelephony.json
msgctxt "Name"
msgid "ModemManager Telephony integration"
msgstr "Integració amb la telefonia del ModemManager"

#: plugins/mousepad/kdeconnect_mousepad.json
msgctxt "Name"
msgid "Receive remote input"
msgstr "Rep entrada remota"

#: plugins/mpriscontrol/kdeconnect_mpriscontrol.json
msgctxt "Name"
msgid "Multimedia control receiver"
msgstr "Receptor del comandament multimèdia"

#: plugins/mprisremote/kdeconnect_mprisremote.json
msgctxt "Name"
msgid "Send multimedia control commands"
msgstr "Envia ordres de control multimèdia"

#: plugins/notifications/kdeconnect_notifications.json
msgctxt "Name"
msgid "Receive notifications"
msgstr "Recepció de notificacions"

#: plugins/pausemusic/kdeconnect_pausemusic.json
msgctxt "Name"
msgid "Pause media during calls"
msgstr "Pausa als fitxers multimèdia durant les trucades"

#: plugins/ping/kdeconnect_ping.json
msgctxt "Name"
msgid "Ping"
msgstr "Ping"

#: plugins/presenter/kdeconnect_presenter.json
msgctxt "Name"
msgid "Presenter"
msgstr "Presentador"

#: plugins/remotecommands/kdeconnect_remotecommands.json
msgctxt "Name"
msgid "Send commands to execute"
msgstr "Envia ordres a executar"

#: plugins/remotecontrol/kdeconnect_remotecontrol.json
msgctxt "Name"
msgid "Send remote mouse input"
msgstr "Envia l'entrada remota de ratolí"

#: plugins/remotekeyboard/kdeconnect_remotekeyboard.json
msgctxt "Name"
msgid "Send remote keyboard input"
msgstr "Envia l'entrada remota de teclat"

#: plugins/remotesystemvolume/kdeconnect_remotesystemvolume.json
msgctxt "Name"
msgid "Remote volume control"
msgstr "Control remot del volum"

#: plugins/runcommand/kdeconnect_runcommand.json
msgctxt "Name"
msgid "Execute remote commands"
msgstr "Executa ordres remotes"

#: plugins/screensaver-inhibit/kdeconnect_screensaver_inhibit.json
msgctxt "Name"
msgid "Inhibit screensaver"
msgstr "Inhibeix l'estalvi de pantalla"

#: plugins/sendnotifications/kdeconnect_sendnotifications.json
msgctxt "Name"
msgid "Send notifications"
msgstr "Envia notificacions"

#: plugins/sftp/kdeconnect_sftp.json
msgctxt "Name"
msgid "Remote filesystem browser"
msgstr "Navegador del sistema de fitxers remot"

#: plugins/shareinputdevices/kdeconnect_shareinputdevices.json
msgctxt "Name"
msgid "Share input devices"
msgstr "Comparteix els dispositius d'entrada"

#: plugins/share/kdeconnect_share.json
msgctxt "Name"
msgid "Share and receive"
msgstr "Comparteix i rep"

#: plugins/sms/kdeconnect_sms.json
msgctxt "Name"
msgid "SMS integration"
msgstr "Integració amb els SMS"

#: plugins/systemvolume/kdeconnect_systemvolume.json
msgctxt "Name"
msgid "Receive volume controls"
msgstr "Rebre els controls de volum"

#: plugins/telephony/kdeconnect_telephony.json
msgctxt "Name"
msgid "Telephony integration"
msgstr "Integració amb la telefonia"

#: plugins/virtualmonitor/kdeconnect_virtualmonitor.json
msgctxt "Name"
msgid "Virtual Monitor"
msgstr "Monitor virtual"

#: fileitemactionplugin/kdeconnectsendfile.json
msgctxt "Description"
msgid "Send file to other device using KDE Connect"
msgstr "Envia fitxers a un altre dispositiu mitjançant el KDE Connect"

#: plasmoid/package/metadata.json
msgctxt "Description"
msgid "Manage connected devices"
msgstr "Gestiona els dispositius connectats"

#: plugins/battery/kdeconnect_battery.json
msgctxt "Description"
msgid "Share the battery status between devices"
msgstr "Comparteix l'estat de la bateria entre dispositius"

#: plugins/clipboard/kdeconnect_clipboard.json
msgctxt "Description"
msgid "Share the clipboard between devices"
msgstr "Comparteix el porta-retalls entre dispositius"

#: plugins/connectivity-report/kdeconnect_connectivity_report.json
msgctxt "Description"
msgid "Show your phone's network signal strength"
msgstr "Mostra la intensitat del senyal de xarxa del vostre telèfon"

#: plugins/contacts/kdeconnect_contacts.json
msgctxt "Description"
msgid "Synchronize contacts from the connected device"
msgstr "Sincronitza els contactes des del dispositiu connectat"

#: plugins/digitizer/kdeconnect_digitizer.json
msgctxt "Description"
msgid "Use your device as a pressure sensitive drawing tablet"
msgstr "Useu el dispositiu com a una tauleta de dibuix sensible a la pressió"

#: plugins/findmyphone/kdeconnect_findmyphone.json
msgctxt "Description"
msgid "Find your lost phone by making it play an alarm sound"
msgstr "Troba el vostre telèfon perdut fent que reprodueixi un so d'alarma"

#: plugins/findthisdevice/kdeconnect_findthisdevice.json
msgctxt "Description"
msgid "Find this device by making it play an alarm sound"
msgstr "Troba aquest dispositiu fent que reprodueixi un so d'alarma"

#: plugins/lockdevice/kdeconnect_lockdevice.json
msgctxt "Description"
msgid "Remotely lock and unlock your screen"
msgstr "Bloqueja i desbloqueja la pantalla de forma remota"

#: plugins/mmtelephony/kdeconnect_mmtelephony.json
#: plugins/telephony/kdeconnect_telephony.json
msgctxt "Description"
msgid "Show notifications for incoming calls"
msgstr "Mostra les notificacions de les trucades entrants"

#: plugins/mousepad/kdeconnect_mousepad.json
msgctxt "Description"
msgid "Use your phone as a touchpad and keyboard"
msgstr "Empra el telèfon com un ratolí tàctil i teclat"

#: plugins/mpriscontrol/kdeconnect_mpriscontrol.json
msgctxt "Description"
msgid "Remote control your music and videos"
msgstr "Comandament a distància de la vostra música i vídeos"

#: plugins/mprisremote/kdeconnect_mprisremote.json
msgctxt "Description"
msgid "Control multimedia players from this device"
msgstr "Controla els reproductors multimèdia des d'aquest dispositiu"

#: plugins/notifications/kdeconnect_notifications.json
msgctxt "Description"
msgid "Show device's notifications on this computer and keep them in sync"
msgstr ""
"Mostra les notificacions del dispositiu a l'ordinador i les manté "
"sincronitzades"

#: plugins/pausemusic/kdeconnect_pausemusic.json
msgctxt "Description"
msgid "Pause music/videos during a phone call"
msgstr "Fa una pausa a la música/vídeos durant una trucada telefònica"

#: plugins/ping/kdeconnect_ping.json
msgctxt "Description"
msgid "Send and receive pings"
msgstr "Envia i rep pings"

#: plugins/presenter/kdeconnect_presenter.json
msgctxt "Description"
msgid "Use your mobile device as a presentation pointer"
msgstr "Usa el dispositiu mòbil com a punter de presentacions"

#: plugins/remotecommands/kdeconnect_remotecommands.json
msgctxt "Description"
msgid "Trigger commands predefined on the remote device"
msgstr "Activa ordres predefinides en el dispositiu remot"

#: plugins/remotecontrol/kdeconnect_remotecontrol.json
msgctxt "Description"
msgid "Use your mouse to send input to another device"
msgstr "Empreu el vostre ratolí per a enviar l'entrada a un altre dispositiu"

#: plugins/remotekeyboard/kdeconnect_remotekeyboard.json
msgctxt "Description"
msgid "Use your keyboard to send input to another device"
msgstr "Empreu el vostre teclat per a enviar l'entrada a un altre dispositiu"

#: plugins/remotesystemvolume/kdeconnect_remotesystemvolume.json
msgctxt "Description"
msgid "Control the volume of the connected device"
msgstr "Controla el volum del dispositiu connectat"

#: plugins/runcommand/kdeconnect_runcommand.json
msgctxt "Description"
msgid "Execute predefined commands remotely"
msgstr "Executa ordres predefinides de forma remota"

#: plugins/screensaver-inhibit/kdeconnect_screensaver_inhibit.json
msgctxt "Description"
msgid "Inhibit the screensaver when the device is connected"
msgstr "Inhibeix l'estalvi de pantalla quan el dispositiu està connectat"

#: plugins/sendnotifications/kdeconnect_sendnotifications.json
msgctxt "Description"
msgid ""
"Broadcast this computer's notifications, so they can be shown on other "
"devices."
msgstr ""
"Fa difusió de les notificacions d'aquest ordinador, de manera que es poden "
"mostrar en altres dispositius."

#: plugins/sftp/kdeconnect_sftp.json
msgctxt "Description"
msgid "Browse the remote device filesystem using SFTP"
msgstr "Navega pel sistema de fitxers del dispositiu remot emprant SFTP"

#: plugins/shareinputdevices/kdeconnect_shareinputdevices.json
msgctxt "Description"
msgid "Share mouse and keyboard with the remote device"
msgstr "Comparteix el ratolí i el teclat amb el dispositiu remot"

#: plugins/share/kdeconnect_share.json
msgctxt "Description"
msgid "Receive and send files, URLs, or plain text"
msgstr "Rep i envia fitxers, URL o text pla"

#: plugins/sms/kdeconnect_sms.json
msgctxt "Description"
msgid "Send and receive SMS"
msgstr "Envia i rep SMS"

#: plugins/systemvolume/kdeconnect_systemvolume.json
msgctxt "Description"
msgid "Enable volume to be controlled from the connected device"
msgstr "Permet que el volum es controli des del dispositiu connectat"

#: plugins/virtualmonitor/kdeconnect_virtualmonitor.json
msgctxt "Description"
msgid "Use your devices as virtual monitors"
msgstr "Useu els vostres dispositius com a monitors virtuals"

