#: src/helper/kcmgrub2.actions:2
msgctxt "Name"
msgid "GRUB2 Bootloader Control Module"
msgstr "Mòdul de control del gestor d'arrencada Grub2"

#: src/helper/kcmgrub2.actions:50
msgctxt "Name"
msgid "Restore the default GRUB2 Bootloader settings"
msgstr "Restaura l'arranjament per omissió del gestor d'arrencada Grub2"

#: src/helper/kcmgrub2.actions:94
msgctxt "Description"
msgid ""
"Administrator authorization is required to restore the default GRUB2 "
"Bootloader settings"
msgstr ""
"Es requereix autorització de l'administrador per a restaurar la configuració "
"del gestor d'arrencada Grub2"

#: src/helper/kcmgrub2.actions:141
msgctxt "Name"
msgid "Install the GRUB2 Bootloader"
msgstr "Instal·la el gestor d'arrencada Grub2"

#: src/helper/kcmgrub2.actions:187
msgctxt "Description"
msgid "Administrator authorization is required to install the GRUB2 Bootloader"
msgstr ""
"Es requereix autorització de l'administrador per a instal·lar el gestor "
"d'arrencada Grub2"

#: src/helper/kcmgrub2.actions:235
msgctxt "Name"
msgid "Load the GRUB2 Bootloader settings"
msgstr "Carrega la configuració del gestor d'arrencada Grub2"

#: src/helper/kcmgrub2.actions:281
msgctxt "Description"
msgid ""
"Administrator authorization is required to load the GRUB2 Bootloader settings"
msgstr ""
"Es requereix autorització de l'administrador per a carregar la configuració "
"del gestor d'arrencada Grub2"

#: src/helper/kcmgrub2.actions:329
msgctxt "Name"
msgid "Save the GRUB2 Bootloader settings"
msgstr "Desa la configuració del gestor d'arrencada Grub2"

#: src/helper/kcmgrub2.actions:374
msgctxt "Description"
msgid ""
"Administrator authorization is required to save the GRUB2 Bootloader settings"
msgstr ""
"Es requereix autorització de l'administrador per a desar la configuració del "
"gestor d'arrencada Grub2"

