#: src/helper/systemdgenie.actions:46
msgctxt "Name"
msgid "Save a systemd unit file"
msgstr "Desa un fitxer d'una unitat del «systemd»"

#: src/helper/systemdgenie.actions:88
msgctxt "Description"
msgid "Administrator authorization is required to save the systemd unit file"
msgstr ""
"Es requereix autorització com a administrador per a desar el fitxer d'una "
"unitat del «systemd»"

#: src/helper/systemdgenie.actions:134
msgctxt "Name"
msgid "Manipulate systemd over D-Bus"
msgstr "Manipula el «systemd» sobre D-Bus"

#: src/helper/systemdgenie.actions:176
msgctxt "Description"
msgid "Administrator authorization is required to manipulate systemd"
msgstr ""
"Es requereix autorització com a administrador per a manipular el «systemd»"

#: src/org.kde.systemdgenie.desktop:2
msgctxt "Name"
msgid "systemdGenie"
msgstr "systemdGenie"

#: src/org.kde.systemdgenie.desktop:32
msgctxt "GenericName"
msgid "systemd Management Tool"
msgstr "Eina per a la gestió del «systemd»"

#: src/org.kde.systemdgenie.desktop:62
msgctxt "Comment"
msgid "Manage systemd units, timers, sessions and config files"
msgstr ""
"Gestiona les unitats del sistema, els temporitzadors, les sessions i els "
"fitxers de configuració"
