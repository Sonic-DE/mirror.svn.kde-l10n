#. (itstool) path: component/name
#: org.kde.liquidshell.appdata.xml:4
msgid "liquidshell"
msgstr "liquidshell"

#. (itstool) path: component/summary
#. (itstool) path: description/p
#: org.kde.liquidshell.appdata.xml:5 org.kde.liquidshell.appdata.xml:10
msgid "liquidshell is an alternative to plasmashell"
msgstr "El liquidshell és una alternativa al plasmashell"

#. (itstool) path: description/p
#: org.kde.liquidshell.appdata.xml:11
msgid ""
"It does not use QtQuick but instead relies on QtWidgets, therefore no "
"hardware graphics acceleration is needed."
msgstr ""
"No usa el «QtQuick», sinó que es basa en els «QtWidgets», per tant, no cal "
"acceleració gràfica per maquinari."

#. (itstool) path: description/p
#: org.kde.liquidshell.appdata.xml:13
msgid "Main Features:"
msgstr "Característiques principals:"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:15
msgid "Wallpaper per virtual desktop"
msgstr "Fons de pantalla per a l'escriptori virtual"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:16
msgid "No animations, no CPU hogging, low Memory footprint"
msgstr "No hi ha animacions, sense acaparar la CPU, consum baix de la memòria"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:17
msgid "Instant startup"
msgstr "Inici instantani"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:18
msgid "No use of activities"
msgstr "No empra les activitats"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:19
msgid "QtWidgets based, therefore follows widget style from systemsettings"
msgstr ""
"Està basat en els «QtWidgets», per tant, segueix l'estil dels ginys indicat "
"per l'arranjament del sistema"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:20
msgid ""
"Icons are used from your globally defined icon theme from systemsettings"
msgstr ""
"Les icones s'usen des del tema d'icones definit globalment des de "
"l'arranjament del sistema"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:21
msgid ""
"Colors are used from your globally defined color theme from systemsettings"
msgstr ""
"Els colors s'usen des del tema de color definit globalment des de "
"l'arranjament del sistema"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:22
msgid ""
"Can additionally be styled with css by passing the commandline option -"
"stylesheet filename.css (see included example stylesheet.css)"
msgstr ""
"També es pot dissenyar amb css passant l'opció de línia d'ordres «-"
"stylesheet nom_fitxer.css» (vegeu l'exemple inclòs a stylesheet.css)"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:23
msgid ""
"uses existing KDE dialogs for most configurations, e.g. StartMenu, Virtual "
"Desktops, Bluetooth, Network"
msgstr ""
"Usa els diàlegs existents del KDE per a la majoria de les configuracions, p. "
"ex. Menú d'inici, Escriptoris virtuals, Bluetooth, Xarxa"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:24
msgid "One bottom DesktopPanel"
msgstr "Un plafó d'escriptori a la part inferior"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:25
msgid "Desktop Applets"
msgstr "Miniaplicacions de l'escriptori"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:43
msgid "Added install options (sleep/shutdown after install)"
msgstr ""
"S'han afegit opcions d'instal·lació (adorm/aturada després d'instal·lar)"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:44
msgid "Improved EULA handling on package installation"
msgstr "S'ha millorat la gestió de l'EULA a la instal·lació del paquet"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:45
msgid "Added long format of time and date display to calendar popup"
msgstr ""
"S'ha afegit un format llarg de visualització de data i hora a la finestra "
"emergent de calendari"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:46
msgid "Create default folder for storing quicklaunch apps"
msgstr ""
"Crea una carpeta predeterminada per a emmagatzemar aplicacions de llançament "
"ràpid"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:47
msgid "SysLoad widget width depends on CPU count"
msgstr "L'amplada del giny SysLoad depèn del nombre de CPU"

#. (itstool) path: ul/li
#. (itstool) path: description/p
#: org.kde.liquidshell.appdata.xml:48 org.kde.liquidshell.appdata.xml:54
msgid "Bugfixes and adjustments to newer KDE components"
msgstr "Correccions d'errors i ajustos als components KDE més nous"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:60
msgid "Notifications show how long they remain open (small animation)"
msgstr ""
"Les notificacions mostren quant de temps romanen obertes (animació petita)"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:61
msgid "Weather Applet shows moon phase"
msgstr "La miniaplicació meteorològica mostra la fase de lluna"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:62
msgid "Disk Usage Applet watches for mount/unmount to react quicker for update"
msgstr ""
"La miniaplicació d'ús de disc controla el muntatge/desmuntatge per a "
"reaccionar més ràpid a l'actualització"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:63
msgid "Display improvements in software updates component"
msgstr "Mostra les millores en el component d'actualitzacions de programari"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:64
msgid ""
"Added DBUS-Menu support (some apps don't provide own menu but only via DBUS, "
"e.g. MS teams)"
msgstr ""
"S'ha afegit la implementació de DBUS-Menu (algunes aplicacions no "
"proporcionen un menú propi, sinó només a través de DBUS, per exemple, el "
"Teams de MS)"
