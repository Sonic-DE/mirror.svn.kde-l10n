#. (itstool) path: component/name
#: org.kde.ksirk.appdata.xml:10
msgid "KsirK"
msgstr "KsirK"

#. (itstool) path: component/summary
#: org.kde.ksirk.appdata.xml:11
msgid "World Domination Strategy Game"
msgstr "Joc d'estratègia de dominació mundial"

#. (itstool) path: description/p
#: org.kde.ksirk.appdata.xml:13
msgid ""
"KsirK is a computerized version of the well known strategic board game Risk. "
"The goal of the game is simply to conquer the world by attacking your "
"neighbors with your armies."
msgstr ""
"El KsirK és una versió per a ordinador del famós joc d'estratègia de tauler "
"Risk. L'objectiu del joc és senzillament conquerir el món atacant els veïns "
"amb els batallons."

#. (itstool) path: description/p
#: org.kde.ksirk.appdata.xml:17
msgid "Features:"
msgstr "Característiques:"

#. (itstool) path: ul/li
#: org.kde.ksirk.appdata.xml:19
msgid "Support for 1-6 human or computer (AI) players"
msgstr "Permet entre 1 i 6 jugadors humans o ordinadors (IA)"

#. (itstool) path: ul/li
#: org.kde.ksirk.appdata.xml:20
msgid "Multi-player gaming over a network"
msgstr "Partides multijugador en xarxa"

#. (itstool) path: ul/li
#: org.kde.ksirk.appdata.xml:21
msgid "You can easily create new skins with SVG graphics and the skin editor"
msgstr ""
"Es poden crear amb facilitat aparences noves amb gràfics SVG i l'editor "
"d'aparences"

#. (itstool) path: ul/li
#: org.kde.ksirk.appdata.xml:22
msgid "Hot New Stuff support. You can easily download and install new skins"
msgstr ""
"Permet obtenir novetats candents. Es poden descarregar i instal·lar amb "
"facilitat aparences noves"

