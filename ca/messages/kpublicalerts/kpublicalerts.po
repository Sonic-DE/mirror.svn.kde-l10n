#: app/caputil.cpp:50
msgid "Extreme — Extraordinary threat to life or property"
msgstr "Extrema: Amenaça extraordinària a la vida o les propietats"

#: app/caputil.cpp:51
msgid "Severe — Significant threat to life or property"
msgstr "Severa: Amenaça significativa a la vida o les propietats"

#: app/caputil.cpp:52
msgid "Moderate — Possible threat to life or property"
msgstr "Moderada: Amenaça possible a la vida o les propietats"

#: app/caputil.cpp:53
msgid "Minor — Minimal to no known threat to life or property"
msgstr "Menor: Amenaça mínima o no coneguda a la vida o les propietats"

#: app/caputil.cpp:57
msgid "Responsive action should be taken immediately"
msgstr "S'han d'emprendre immediatament accions de resposta"

#: app/caputil.cpp:58
msgid "Responsive action should be taken soon"
msgstr "S'han d'emprendre aviat accions de resposta"

#: app/caputil.cpp:59
msgid "Responsive action be taken in the near future"
msgstr "S'han d'emprendre aviat accions de resposta en el futur pròxim"

#: app/caputil.cpp:60
msgid "Responsive action is no longer required"
msgstr "No s'han d'emprendre accions de resposta"

#: app/caputil.cpp:64
msgid "Occurred or ongoing"
msgstr "Ha ocorregut o està en curs"

#: app/caputil.cpp:65
msgid "Likely (> 50%)"
msgstr "Probable (> 50%)"

#: app/caputil.cpp:66
msgid "Possible but not likely (< 50%)"
msgstr "Possible però no probable (< 50%)"

#: app/caputil.cpp:67
msgid "Not expected to occur"
msgstr "No s'espera que passi"

#: app/caputil.cpp:71
msgid "Geophysical"
msgstr "Geofísic"

#: app/caputil.cpp:72
msgid "Meteorological"
msgstr "Meteorològic"

#: app/caputil.cpp:73
msgid "General emergency and public safety"
msgstr "Emergència general i seguretat pública"

#: app/caputil.cpp:74
msgid "Law enforcement, military, homeland and local/private security"
msgstr "Ordre públic, militar, seguretat nacional i local/privada"

#: app/caputil.cpp:75
msgid "Rescue and recovery"
msgstr "Salvament i recuperació"

#: app/caputil.cpp:76
msgid "Fire"
msgstr "Foc"

#: app/caputil.cpp:77
msgid "Medical and public health"
msgstr "Salut mèdica i pública"

#: app/caputil.cpp:78
msgid "Pollution and other environmental event"
msgstr "Contaminació i altres esdeveniments mediambientals"

#: app/caputil.cpp:79
msgid "Transportation"
msgstr "Transports"

#: app/caputil.cpp:80
msgid "Utility, telecommunication, other non-transport infrastructure"
msgstr ""
"Instal·lacions, telecomunicacions, altres infraestructures no de transport"

#: app/caputil.cpp:81
msgid ""
"Chemical, biological, radiological, nuclear or high-yield explosive threat "
"or attack"
msgstr "Amenaça o atac químic, biològic, radiològic, nuclear o explosiu potent"

#: app/caputil.cpp:82
msgid "Other event"
msgstr "Altres esdeveniments"

#: app/caputil.cpp:86
msgid "Take shelter in place or per instructions."
msgstr "Cerqueu refugi al lloc o segons instruccions."

#: app/caputil.cpp:87
msgid "Relocate as instructed."
msgstr "Traslladeu-vos segons les instruccions."

#: app/caputil.cpp:88
msgid "Make preparations as per the instructions."
msgstr "Feu els preparatius segons les instruccions."

#: app/caputil.cpp:89
msgid "Execute activities identified in the instructions."
msgstr "Executeu les activitats identificades a les instruccions."

#: app/caputil.cpp:90
msgid "Avoid the subject event as per the instructions."
msgstr "Eviteu l'esdeveniment de l'assumpte segons les instruccions."

#: app/caputil.cpp:91
msgid "Attend to information sources as described in the instructions."
msgstr ""
"Presteu atenció a les fonts d'informació tal com es descriu a les "
"instruccions."

#: app/caputil.cpp:92
msgid "Evaluate the information in this message."
msgstr "Avalueu la informació d'aquest missatge."

#: app/caputil.cpp:93
msgid ""
"The subject event no longer poses a threat or concern and any follow on "
"action is described in the instructions."
msgstr ""
"L'esdeveniment de l'assumpte ja no suposa una amenaça o preocupació i "
"qualsevol seguiment de l'acció es descriu a les instruccions."

#: app/caputil.cpp:94
msgid "No action recommended."
msgstr "No es recomana cap acció."

