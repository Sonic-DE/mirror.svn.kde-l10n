#: org.kde.accountwizard.appdata.xml:9
msgid "Account Wizard"
msgstr "Assistent de comptes"

#. (itstool) path: component/summary
#: org.kde.accountwizard.appdata.xml:10
msgid "Configure accounts"
msgstr "Configuració de comptes"

#. (itstool) path: description/p
#: org.kde.accountwizard.appdata.xml:12
msgid ""
"Accountwizard allows to edit, create, delete accounts. Accountwizard "
"supports IMAP/POP3/Kolab account type. Account information can be found by "
"using ispd service."
msgstr ""
"L'assistent de comptes permet editar, crear i suprimir comptes. L'assistent "
"admet tipus de compte IMAP/POP3/Kolab. La informació del compte es pot "
"trobar fent servir el servei de l'«ispd»."

#~ msgid "Accountwizard allows to edit, create, delete accounts."
#~ msgstr "L'assistent de comptes permet editar, crear i suprimir comptes."
