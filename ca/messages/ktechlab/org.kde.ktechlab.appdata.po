#. (itstool) path: component/name
#: org.kde.ktechlab.appdata.xml:11
msgid "KTechlab"
msgstr "KTechlab"

#. (itstool) path: component/summary
#: org.kde.ktechlab.appdata.xml:12
msgid "IDE for microcontrollers and electronics"
msgstr "IDE per a microcontroladors i electrònica"

#. (itstool) path: description/p
#: org.kde.ktechlab.appdata.xml:14
msgid ""
"KTechlab is an IDE for microcontrollers and electronics designed to be as "
"easy to use and unintrusive as possible."
msgstr ""
"El KTechlab és un IDE per a microcontroladors i electrònica dissenyat per a "
"ser tan fàcil d'usar i discret com sigui possible."

#. (itstool) path: description/p
#: org.kde.ktechlab.appdata.xml:17
msgid "Features:"
msgstr "Característiques:"

#. (itstool) path: ul/li
#: org.kde.ktechlab.appdata.xml:19
msgid "Wide range of components with editable characteristics"
msgstr "Gran varietat de components amb característiques modificables"

#. (itstool) path: ul/li
#: org.kde.ktechlab.appdata.xml:20
msgid "Visual editor for circuits"
msgstr "Editor visual per als circuits"

#. (itstool) path: ul/li
#: org.kde.ktechlab.appdata.xml:21
msgid "Context help for the components"
msgstr "Ajuda contextual per als components"

#. (itstool) path: ul/li
#: org.kde.ktechlab.appdata.xml:22
msgid "Two modes of connector routing: automatic and manual"
msgstr "Dos modes d'encaminament per al connector: automàtic i manual"

#. (itstool) path: ul/li
#: org.kde.ktechlab.appdata.xml:23
msgid ""
"Several ways to define the PIC logic: assembly code, Microbe (own high level "
"programming language) code, C code, and visual FlowCode"
msgstr ""
"Diverses maneres de definir el PIC lògic: codi en assemblador, codi en "
"Microbe (llenguatge de programació propi d'alt nivell), codi en C i FlowCode "
"visual"

#. (itstool) path: ul/li
#: org.kde.ktechlab.appdata.xml:24
msgid "Interconversion of the programming code between supported languages"
msgstr "Interconversió del codi de programació entre els llenguatges admesos"

#. (itstool) path: ul/li
#: org.kde.ktechlab.appdata.xml:25
msgid "Inbuilt debugger"
msgstr "Depurador incorporat"

#. (itstool) path: ul/li
#: org.kde.ktechlab.appdata.xml:26
msgid "Simulation with oscilloscope and probes"
msgstr "Simulació amb oscil·loscopi i sondes"

#. (itstool) path: ul/li
#: org.kde.ktechlab.appdata.xml:27
msgid "Uploading the assembly code to PIC using hardware programmer"
msgstr "Puja el codi en assemblador al PIC emprant el programador de maquinari"

#. (itstool) path: description/p
#: org.kde.ktechlab.appdata.xml:41
msgid ""
"This release should compile and run on systems where KDELibs4Support "
"libraries are not available."
msgstr ""
"Aquest llançament hauria de compilar i executar-se en sistemes on les "
"biblioteques KDELibs4Support no estan disponibles."
