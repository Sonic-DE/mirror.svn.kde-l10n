msgid "Sweeper"
msgstr "Escombriaire"

#: org.kde.sweeper.desktop:75
msgctxt "GenericName"
msgid "System Cleaner"
msgstr "Netejador del sistema"

#: org.kde.sweeper.desktop:142
msgctxt "Comment"
msgid ""
"Helps to clean unwanted traces the user leaves on the system and to regain "
"disk space removing unused temporary files"
msgstr ""
"Ajuda a netejar el rastre no desitjat que va deixant l'usuari al sistema i "
"es recupera l'espai del disc eliminant els fitxers temporals no usats"
