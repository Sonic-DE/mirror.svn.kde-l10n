#: files/plasma-setup.desktop.in:9 src/auth/org.kde.plasmasetup.actions:8
msgctxt "Name"
msgid "Plasma Setup"
msgstr "Configuració del Plasma"

#: files/plasma-setup.desktop.in:39
msgctxt "Comment"
msgid "Run the initial system setup for KDE"
msgstr "Executa la configuració inicial del sistema KDE"

#: src/auth/org.kde.plasmasetup.actions:42
msgctxt "Name"
msgid "Create User"
msgstr "Creació d'un usuari"

#: src/auth/org.kde.plasmasetup.actions:71
msgctxt "Description"
msgid "Create the initial user account"
msgstr "Crea el compte d'usuari inicial"

#: src/auth/org.kde.plasmasetup.actions:103
msgctxt "Name"
msgid "Create Completion Flag File"
msgstr "Crea un fitxer d'indicadors de compleció"

#: src/auth/org.kde.plasmasetup.actions:131
msgctxt "Description"
msgid "Write the /etc/plasma-setup-done marker to prevent rerunning setup"
msgstr ""
"Escriu el marcador /etc/plasma-setup-done per a evitar tornar a executar la "
"configuració"

#: src/auth/org.kde.plasmasetup.actions:162
msgctxt "Name"
msgid "Create New User Autostart Hook"
msgstr "Ganxo d'inici automàtic de creació d'usuari nou"

#: src/auth/org.kde.plasmasetup.actions:191
msgctxt "Description"
msgid "Create an autostart hook for the newly created user"
msgstr "Crea un ganxo d'inici automàtic per al nou usuari creat"

#: src/auth/org.kde.plasmasetup.actions:223
msgctxt "Name"
msgid "Remove Autologin"
msgstr "Elimina l'inici de sessió automàtic"

#: src/auth/org.kde.plasmasetup.actions:252
msgctxt "Description"
msgid "Remove Display Manager autologin configuration"
msgstr ""
"Elimina la configuració d'inici de sessió automàtic del gestor de pantalla"

#: src/auth/org.kde.plasmasetup.actions:282
msgctxt "Name"
msgid "Set New User Global Theme"
msgstr "Estableix el tema global d'usuari nou"

#: src/auth/org.kde.plasmasetup.actions:311
msgctxt "Description"
msgid "Set the global theme for the new user"
msgstr "Estableix el tema global per a l'usuari nou"

#: src/auth/org.kde.plasmasetup.actions:343
msgctxt "Name"
msgid "Set New User Display Scaling"
msgstr "Estableix l'escalat de pantalla d'usuari nou"

#: src/auth/org.kde.plasmasetup.actions:372
msgctxt "Description"
msgid "Set display scaling for the new user"
msgstr "Estableix l'escalat de pantalla per a l'usuari nou"

#: src/auth/org.kde.plasmasetup.actions:404
msgctxt "Name"
msgid "Set New User Home Directory Ownership"
msgstr "Estableix la propietat del directori d'inici d'usuari nou"

#: src/auth/org.kde.plasmasetup.actions:433
msgctxt "Description"
msgid "Set ownership of the new users home directory to the newly created user"
msgstr ""
"Estableix la propietat del directori d'inici dels usuaris nous a l'usuari "
"creat nou"

#: src/auth/org.kde.plasmasetup.actions:465
msgctxt "Name"
msgid "Set New User Temporary Autologin"
msgstr "Estableix l'inici de sessió automàtic temporal d'usuari nou"

#: src/auth/org.kde.plasmasetup.actions:494
msgctxt "Description"
msgid ""
"Set display manager temporary autologin configuration for the newly created "
"user"
msgstr ""
"Estableix la configuració de l'inici de sessió automàtic temporal del gestor "
"de pantalla per a l'usuari creat nou"

#~ msgctxt "Name"
#~ msgid "Disable Systemd Unit"
#~ msgstr "Desactiva la unitat del Systemd"

#~ msgctxt "Description"
#~ msgid "Disable the systemd unit for Plasma Setup"
#~ msgstr "Desactiva la unitat del «systemd» per a la configuració del Plasma"

#~ msgctxt "Name"
#~ msgid "KDE Initial System Setup"
#~ msgstr "Configuració inicial del sistema KDE"
