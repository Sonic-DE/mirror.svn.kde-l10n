msgid "Application that allows you to translate and speak text using Mozhi"
msgstr "Una aplicació que us permet traduir i pronunciar text utilitzant Mozhi"

#. (itstool) path: description/p
#: org.kde.CrowTranslate.metainfo.xml:18
msgid ""
"Application written in C++ / Qt that allows you to translate and speak text "
"using Mozhi."
msgstr ""
"Una aplicació escrita en C++/Qt que us permet traduir i pronunciar text "
"utilitzant Mozhi."

