#. (itstool) path: ul/li
#: org.kde.CrowTranslate.metainfo.xml:21
msgid ""
"Multiple translation engines provided by Mozhi (some instances can disable "
"specific engines)*"
msgstr ""
"Diversos motors de traducció subministrats per Mozhi (algunes instàncies "
"poden desactivar motors específics)*"

