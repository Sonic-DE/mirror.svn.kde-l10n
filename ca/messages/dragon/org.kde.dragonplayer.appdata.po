#. (itstool) path: component/name
#: org.kde.dragonplayer.appdata.xml:9
msgid "Dragon Player"
msgstr "Dragon Player"

#. (itstool) path: component/summary
#: org.kde.dragonplayer.appdata.xml:10
msgid "Play video files and streams"
msgstr "Reprodueix fitxers i fluxos de vídeo"

#. (itstool) path: description/p
#: org.kde.dragonplayer.appdata.xml:12
msgid ""
"Dragon Player is a video player focusing on simplicity instead of features. "
"Its easy-to-use interface is designed to get out of your way and simply play "
"your video files and streams."
msgstr ""
"El Dragon Player és un reproductor de vídeo que se centra en la simplicitat "
"en lloc de les característiques. La seva interfície fàcil d'utilitzar està "
"dissenyada perquè no s'interposi en el vostre camí i que simplement pugueu "
"reproduir els fitxers i fluxos de vídeo."

#. (itstool) path: description/p
#: org.kde.dragonplayer.appdata.xml:15
msgid "Features:"
msgstr "Característiques:"

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:17
msgid ""
"Click to play or pause, and double-click to enter or exit full screen mode."
msgstr ""
"Feu clic per a reproduir o fer una pausa i feu doble clic per a entrar o "
"sortir del mode de pantalla completa."

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:18
msgid ""
"Choose the subtitle language, and automatically load the right one for your "
"language, if possible."
msgstr ""
"Trieu l'idioma dels subtítols i carregueu automàticament els adequats de "
"l'idioma que vulgueu, si és possible."

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:19
msgid "Choose the audio track."
msgstr "Trieu la pista d'àudio."

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:20
msgid "Choose the video track."
msgstr "Trieu la pista de vídeo."

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:21
msgid "Adjust the volume by scrolling."
msgstr "Ajusteu el volum amb el desplaçament."
