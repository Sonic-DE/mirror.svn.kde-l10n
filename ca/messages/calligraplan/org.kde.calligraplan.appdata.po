#. (itstool) path: component/name
#: org.kde.calligraplan.appdata.xml:7
msgid "Plan"
msgstr "Plan"

#. (itstool) path: component/summary
#: org.kde.calligraplan.appdata.xml:8
msgid "Project Management"
msgstr "Gestió de projectes"

#. (itstool) path: description/p
#: org.kde.calligraplan.appdata.xml:10
msgid ""
"Plan is a project management application. It is intended for managing "
"moderately large projects with multiple resources."
msgstr ""
"El Plan és una aplicació de gestió de projectes. Està pensat per a gestionar "
"projectes moderadament grans amb múltiples recursos."

#. (itstool) path: description/p
#: org.kde.calligraplan.appdata.xml:13
msgid "Features:"
msgstr "Característiques:"

#. (itstool) path: ul/li
#: org.kde.calligraplan.appdata.xml:15
msgid "Multiple views: Gant Charts, Resource View, Accounts View"
msgstr ""
"Vistes múltiples: Diagrames de Gant, vista de recursos, vista de comptes"

#. (itstool) path: ul/li
#: org.kde.calligraplan.appdata.xml:16
msgid ""
"Uses standard structures: Work breakdown structure (WBS), Resource breakdown "
"structure (RBS), Cost breakdown structure (CBS)"
msgstr ""
"Usa estructures estàndard: Estructura de descomposició de treballs (WBS), "
"Estructura de descomposició de recursos (RBS), Estructura de descomposició "
"de costos (CBS)"

#. (itstool) path: ul/li
#: org.kde.calligraplan.appdata.xml:17
msgid "Configurable level of detail on Gantt Chart"
msgstr "Es pot configurar el nivell de detall en el diagrama de Gantt"

#. (itstool) path: ul/li
#: org.kde.calligraplan.appdata.xml:18
msgid "Supports Summarytasks, Tasks, and milestones"
msgstr "Permet resums de tasques, tasques i fites"

#. (itstool) path: ul/li
#: org.kde.calligraplan.appdata.xml:19
msgid "Configurable Scheduling Constraints"
msgstr "Es poden configurar restriccions de planificació"

#. (itstool) path: description/p
#: org.kde.calligraplan.appdata.xml:38
msgid "Fix version in the cmake"
msgstr "Corregeix la versió al «cmake»"

