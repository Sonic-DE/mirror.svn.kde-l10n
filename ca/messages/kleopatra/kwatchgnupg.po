msgstr "[%1] S'ha aturat el registre"

#: kwatchgnupgmainwin.cpp:110
#, kde-format
msgid ""
"The watchgnupg logging program could not be found.\n"
"Please make sure that watchgnupg is installed."
msgstr ""
"No s'ha pogut trobar el programa d'enregistrament watchgnupg.\n"
"Assegureu-vos que el watchgnupg estigui instal·lat."

#: kwatchgnupgmainwin.cpp:111 kwatchgnupgmainwin.cpp:121
#, kde-format
msgid "[%1] Failed to start %2"
msgstr "[%1] Ha fallat en engegar %2"

#: kwatchgnupgmainwin.cpp:120
#, kde-format
msgid ""
"The watchgnupg logging process could not be started.\n"
"Please make sure that watchgnupg is installed properly."
msgstr ""
"No s'ha pogut engegar el procés de registre del watchgnupg.\n"
"Assegureu-vos que el watchgnupg estigui instal·lat adequadament."

#: kwatchgnupgmainwin.cpp:125
#, kde-format
msgid "[%1] Log started"
msgstr "[%1] S'ha engegat el registre"

#: kwatchgnupgmainwin.cpp:134
#, kde-format
msgid ""
"The watchgnupg logging process died.\n"
"Do you want to try to restart it?"
msgstr ""
"Ha mort el procés de registre del watchgnupg.\n"
"El voleu provar de tornar a engegar?"

#: kwatchgnupgmainwin.cpp:136
#, kde-format
msgctxt "@action:button"
msgid "Try Restart"
msgstr "Intenta reengegar-lo"

#: kwatchgnupgmainwin.cpp:137
#, kde-format
msgctxt "@action:button"
msgid "Do Not Try"
msgstr "No ho intentis"

#: kwatchgnupgmainwin.cpp:139
#, kde-format
msgid "====== Restarting logging process ====="
msgstr "===== S'està reengegant el procés del registre ====="

#: kwatchgnupgmainwin.cpp:143
#, kde-format
msgid ""
"The watchgnupg logging process is not running.\n"
"This log window is unable to display any useful information."
msgstr ""
"El procés del registre watchgnupg no s'està executant.\n"
"Aquesta finestra de registre no pot mostrar cap informació útil."

