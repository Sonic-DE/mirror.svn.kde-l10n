#: kcm_sddm.actions:2
msgctxt "Name"
msgid "SDDM"
msgstr "SDDM"

#: kcm_sddm.actions:58
msgctxt "Name"
msgid "Save Settings"
msgstr "Desa la configuració"

#: kcm_sddm.actions:109
msgctxt "Description"
msgid "Save Settings in SDDM"
msgstr "Desa la configuració a l'SDDM"

#: kcm_sddm.actions:163
msgctxt "Name"
msgid "Install an SDDM theme"
msgstr "Instal·la un tema de l'SDDM"

#: kcm_sddm.actions:213
msgctxt "Description"
msgid "Extract a zip file containing an SDDM theme to the SDDM theme location"
msgstr ""
"Extreu un fitxer ZIP que contingui un tema de l'SDDM a la ubicació de temes "
"de l'SDDM"

#: kcm_sddm.actions:254
msgctxt "Name"
msgid "Uninstall an SDDM theme"
msgstr "Desinstal·la un tema de l'SDDM"

#: kcm_sddm.actions:304
msgctxt "Description"
msgid "Remove a previously installed SDDM theme"
msgstr "Elimina un tema de l'SDDM instal·lat anteriorment"

#: kcm_sddm.actions:345
msgctxt "Name"
msgid "Synchronize Settings"
msgstr "Paràmetres de sincronització"

#: kcm_sddm.actions:391
msgctxt "Description"
msgid "Synchronize user settings with SDDM settings"
msgstr "Sincronitza els paràmetres de l'usuari amb els paràmetres de l'SDDM"

#: kcm_sddm.actions:432
msgctxt "Name"
msgid "Reset Settings"
msgstr "Reinicia la configuració"

#: kcm_sddm.actions:478
msgctxt "Description"
msgid "Reset SDDM settings to factory default state"
msgstr "Reinicia els paràmetres de l'SDDM a l'estat predeterminat inicial"

#: sddmtheme.knsrc:4
msgctxt "Name"
msgid "Login Screen"
msgstr "Pantalla d'inici de sessió"
