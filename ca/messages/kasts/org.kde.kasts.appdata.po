msgstr "una cua de reproducció"

#. (itstool) path: ul/li
#: org.kde.kasts.appdata.xml:233
msgid "notification panel and lockscreen media controls"
msgstr ""
"controls multimèdia del plafó de notificacions i de la pantalla de bloqueig"

#. (itstool) path: ul/li
#: org.kde.kasts.appdata.xml:234
msgid "inhibits systemd suspend while listening to podcasts"
msgstr "inhibeix la suspensió del sistema mentre s'està escoltant pòdcasts"

#. (itstool) path: ul/li
#: org.kde.kasts.appdata.xml:235
msgid "convergent UI; looks good on mobile and desktop"
msgstr "IU convergent; es veu bé en el mòbil i l'escriptori"

