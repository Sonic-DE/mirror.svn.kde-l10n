#~ msgid "Opening wallet failed"
#~ msgstr "Ha fallat l'obertura de la cartera"

#~ msgctxt "Comment"
#~ msgid "The network wallet could not be opened"
#~ msgstr "No s'ha pogut obrir la cartera de xarxa"

#~ msgctxt "Name"
#~ msgid "Credentials not accessible"
#~ msgstr "Credencials no accessibles"

