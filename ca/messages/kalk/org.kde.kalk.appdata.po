#: org.kde.kalk.appdata.xml:104
msgid "General bugfixing and code quality improvements"
msgstr "Correcció general d'errors i millores en la qualitat del codi"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:112
msgid "Rearrange trigonometric functions to be together"
msgstr "Reordena les funcions trigonomètriques perquè estiguin juntes"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:113
msgid "Various user-interface improvements"
msgstr "Diverses millores de la interfície d'usuari"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:120
msgid "Rework sidebar design"
msgstr "Refà el disseny de la barra lateral"

#. (itstool) path: description/p
#: org.kde.kalk.appdata.xml:133
msgid "Changes:"
msgstr "Canvis:"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:135
msgid "Updated the application icon"
msgstr "Actualitza la icona de l'aplicació"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:136
msgid "Added support for parentheses keyboard input"
msgstr "Afegeix la implementació d'entrada de teclat dels parèntesis"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:137
msgid "Fixed the calculator drawer opening when the application opens"
msgstr ""
"Corregeix l'obertura del calaix de la calculadora quan s'obra l'aplicació"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:138
msgid ""
"Changed backspace icon to use a proper system icon instead of a font "
"provided one"
msgstr ""
"Canvia la icona de retrocés per a utilitzar una icona de sistema adequada en "
"lloc de la proporcionada a la lletra"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:139
msgid "Added keyboard support to unit converter"
msgstr "Afegeix la implementació del teclat al convertidor d'unitats"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:140
msgid "Fixed page change animation for binary calculator"
msgstr "Corregeix l'animació del canvi de pàgina de la calculadora binària"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:141
msgid "Enabled qml debugging when compiled in debug mode"
msgstr "Activa la depuració del QML quan es compila en mode de depuració"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:142
msgid "Added ability to recognize the decimal separator in other locales"
msgstr ""
"Afegeix la capacitat de reconèixer el separador decimal en altres "
"configuracions regionals"

