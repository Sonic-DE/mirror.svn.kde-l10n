#. (itstool) path: component/name
#: org.kde.skanlite.appdata.xml:10
msgid "Skanlite"
msgstr "Skanlite"

#. (itstool) path: component/summary
#: org.kde.skanlite.appdata.xml:11
msgid "Image Scanning Application"
msgstr "Aplicació de digitalització d'imatges"

#. (itstool) path: description/p
#: org.kde.skanlite.appdata.xml:13
msgid ""
"Skanlite is a simple image scanning application to scan and save images. It "
"is optimized for scanning with flatbed scanners. Skanlite can capture not "
"only photos and documents, but also transparent slides and filmstrips, with "
"supported scanners."
msgstr ""
"L'Skanlite és una aplicació d'escaneig d'imatges per a escanejar imatges i "
"desar-les. Està optimitzada per a l'escaneig amb escàners de superfície "
"plana. L'Skanlite no només pot capturar fotos i documents, també "
"diapositives transparents i tires de pel·lícula, amb els escàners acceptats."

#. (itstool) path: description/p
#: org.kde.skanlite.appdata.xml:17
msgid "Features:"
msgstr "Característiques:"

#. (itstool) path: ul/li
#: org.kde.skanlite.appdata.xml:19
msgid ""
"Save dialog for every image scanned or saving the images immediately in a "
"specified folder with auto-generated names and format"
msgstr ""
"Diàleg per a desar cada imatge escanejada o desar les imatges immediatament "
"en una carpeta especificada amb noms i format generats automàticament"

#. (itstool) path: ul/li
#: org.kde.skanlite.appdata.xml:20
msgid "Support for networks scanners"
msgstr "Implementació per a escàners en xarxa"

#. (itstool) path: ul/li
#: org.kde.skanlite.appdata.xml:21
msgid "Preview with selection feature for the final scan"
msgstr "Vista prèvia amb la característica de selecció per a l'escaneig final"

#. (itstool) path: ul/li
#: org.kde.skanlite.appdata.xml:22
msgid "Scanning multiple selections of an image"
msgstr "Escaneig de múltiples seleccions d'una imatge"

#. (itstool) path: screenshot/caption
#: org.kde.skanlite.appdata.xml:27
msgid "Skanlite's basic options screen with a scanned image visible"
msgstr ""
"Pantalla d'opcions bàsiques de l'Skanlite amb una imatge escanejada visible"

