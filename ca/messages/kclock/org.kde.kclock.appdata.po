#~ msgstr ""
#~ "Establiu alarmes i temporitzadors, useu un cronòmetre i gestioneu els "
#~ "rellotges mundials"

#~ msgid "A universal clock application for desktop and mobile."
#~ msgstr "Una aplicació universal de rellotge per a l'escriptori i mòbil."

