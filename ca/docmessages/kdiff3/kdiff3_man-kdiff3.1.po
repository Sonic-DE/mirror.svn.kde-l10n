#. Tag: title
#: man-kdiff3.1.docbook:8
#, no-c-format
msgid "KDiff3 User's Manual"
msgstr "Manual d'usuari del KDiff3"

#. Tag: author
#: man-kdiff3.1.docbook:9
#, no-c-format
msgid ""
"<firstname>Burkhard</firstname><surname>Lueck</surname> <contrib>KDiff3 man "
"page.</contrib> &Burkhard.Lueck.mail;"
msgstr ""
"<firstname>Burkhard</firstname><surname>Lueck</surname> <contrib>Pàgina de "
"manual del KDiff3.</contrib> &Burkhard.Lueck.mail;"

#. Tag: date
#: man-kdiff3.1.docbook:13
#, no-c-format
msgid "2019-02-22"
msgstr "22 de febrer de 2019"

#. Tag: releaseinfo
#: man-kdiff3.1.docbook:14
#, no-c-format
msgid "kdiff3 1.8"
msgstr "kdiff3 1.8"

#. Tag: manvolnum
#: man-kdiff3.1.docbook:19
#, no-c-format
msgid "<manvolnum>1</manvolnum>"
msgstr "<manvolnum>1</manvolnum>"

#. Tag: refpurpose
#: man-kdiff3.1.docbook:24
#, no-c-format
msgid "Tool for Comparison and Merge of Files and Folders"
msgstr "Eina per a comparar i fusionar fitxers i carpetes"

#. Tag: cmdsynopsis
#: man-kdiff3.1.docbook:28
#, no-c-format
msgid ""
"<command>kdiff3</command> <arg choice=\"opt\"><option>-u, --ignore</option></"
"arg> <arg choice=\"opt\"><option>--query</option></arg> <arg choice=\"opt"
"\"><option>--html</option></arg> <arg choice=\"opt\"><option>--abort</"
"option></arg> <arg choice=\"opt\"><option>-m, --merge</option></arg> <arg "
"choice=\"opt\"><option>-b, --base</option> <replaceable>file</replaceable></"
"arg> <arg choice=\"opt\"><option>-o, --output</option> <replaceable>file</"
"replaceable></arg> <arg choice=\"opt\"><option>--out</option> "
"<replaceable>file</replaceable></arg> <arg choice=\"opt\"><option>--noauto</"
"option></arg> <arg choice=\"opt\"><option>--auto</option></arg> <arg choice="
"\"opt\"><option>--L1</option> <replaceable>alias1</replaceable></arg> <arg "
"choice=\"opt\"><option>--L2</option> <replaceable>alias2</replaceable></arg> "
"<arg choice=\"opt\"><option>--L3</option> <replaceable>alias3</replaceable></"
"arg> <arg choice=\"opt\"><option>-L, --fname</option> <replaceable>alias</"
"replaceable></arg> <arg choice=\"opt\"><option>--cs</option> "
"<replaceable>string</replaceable></arg> <arg choice=\"opt\"><option>--"
"confighelp</option></arg> <arg choice=\"opt\"><option>--config</option> "
"<replaceable>file</replaceable></arg> <arg choice=\"opt"
"\"><option><replaceable>File1</replaceable></option></arg> <arg choice=\"opt"
"\"><option><replaceable>File2</replaceable></option></arg> <arg choice=\"opt"
"\"><option><replaceable>File3</replaceable></option></arg>"
msgstr ""
"<command>kdiff3</command> <arg choice=\"opt\"><option>-u, --ignore</option></"
"arg> <arg choice=\"opt\"><option>--query</option></arg> <arg choice=\"opt"
"\"><option>--html</option></arg> <arg choice=\"opt\"><option>--abort</"
"option></arg> <arg choice=\"opt\"><option>-m, --merge</option></arg> <arg "
"choice=\"opt\"><option>-b, --base</option> <replaceable>file</replaceable></"
"arg> <arg choice=\"opt\"><option>-o, --output</option> <replaceable>fitxer</"
"replaceable></arg> <arg choice=\"opt\"><option>--out</option> "
"<replaceable>fitxer</replaceable></arg> <arg choice=\"opt\"><option>--"
"noauto</option></arg> <arg choice=\"opt\"><option>--auto</option></arg> <arg "
"choice=\"opt\"><option>--L1</option> <replaceable>àlies_1</replaceable></"
"arg> <arg choice=\"opt\"><option>--L2</option> <replaceable>àlies_2</"
"replaceable></arg> <arg choice=\"opt\"><option>--L3</option> "
"<replaceable>àlies_3</replaceable></arg> <arg choice=\"opt\"><option>-L, --"
"fname</option> <replaceable>àlies</replaceable></arg> <arg choice=\"opt"
"\"><option>--cs</option> <replaceable>cadena</replaceable></arg> <arg choice="
"\"opt\"><option>--confighelp</option></arg> <arg choice=\"opt\"><option>--"
"config</option> <replaceable>fitxer</replaceable></arg> <arg choice=\"opt"
"\"><option><replaceable>fitxer_1</replaceable></option></arg> <arg choice="
"\"opt\"><option><replaceable>fitxer_2</replaceable></option></arg> <arg "
"choice=\"opt\"><option><replaceable>fitxer_3</replaceable></option></arg>"

#. Tag: title
#: man-kdiff3.1.docbook:54
#, no-c-format
msgid "Description"
msgstr "Descripció"

#. Tag: para
#: man-kdiff3.1.docbook:55
#, no-c-format
msgid "Compares two or three input files or folders."
msgstr "Compara dos o tres fitxers o carpetes des de l'entrada."

#. Tag: title
#: man-kdiff3.1.docbook:60
#, no-c-format
msgid "Options"
msgstr "Opcions"

#. Tag: option
#: man-kdiff3.1.docbook:63
#, no-c-format
msgid "-u, --ignore"
msgstr "-u, --ignore"

# skip-rule: punctuation-period-no
#. Tag: para
#: man-kdiff3.1.docbook:64 man-kdiff3.1.docbook:70 man-kdiff3.1.docbook:76
#: man-kdiff3.1.docbook:82
#, no-c-format
msgid "Ignored. (User defined.)"
msgstr "Ignorat. (Definit per l'usuari)."

#. Tag: option
#: man-kdiff3.1.docbook:69
#, no-c-format
msgid "--query"
msgstr "--query"

#. Tag: option
#: man-kdiff3.1.docbook:75
#, no-c-format
msgid "--html"
msgstr "--html"

#. Tag: option
#: man-kdiff3.1.docbook:81
#, no-c-format
msgid "--abort"
msgstr "--abort"

#. Tag: option
#: man-kdiff3.1.docbook:87
#, no-c-format
msgid "-m, --merge"
msgstr "-m, --merge"

#. Tag: para
#: man-kdiff3.1.docbook:88
#, no-c-format
msgid "Merge the input."
msgstr "Fusiona l'entrada."

#. Tag: term
#: man-kdiff3.1.docbook:93
#, no-c-format
msgid "<option>-b, --base</option> <replaceable>file</replaceable>"
msgstr "<option>-b, --base</option> <replaceable>fitxer</replaceable>"

#. Tag: para
#: man-kdiff3.1.docbook:94
#, no-c-format
msgid "Explicit base file. For compatibility with certain tools."
msgstr "Fitxer base explícit. Per compatibilitat amb certes eines."

#. Tag: term
#: man-kdiff3.1.docbook:99
#, no-c-format
msgid "<option>-o, --output</option> <replaceable>file</replaceable>"
msgstr "<option>-o, --output</option> <replaceable>fitxer</replaceable>"

#. Tag: para
#: man-kdiff3.1.docbook:100
#, no-c-format
msgid "Output file. Implies -m. &eg;: -o newfile.txt"
msgstr "Fitxer de sortida. Implica -m. &pex;: -o fitxernou.txt"

#. Tag: term
#: man-kdiff3.1.docbook:105
#, no-c-format
msgid "<option>--out</option> <replaceable>file</replaceable>"
msgstr "<option>--out</option> <replaceable>fitxer</replaceable>"

# skip-rule: punctuation-period-no
#. Tag: para
#: man-kdiff3.1.docbook:106
#, no-c-format
msgid "Output file, again. (For compatibility with certain tools.)"
msgstr ""
"Fitxer de sortida, un altre cop. (Per compatibilitat amb certes eines)."

#. Tag: option
#: man-kdiff3.1.docbook:111
#, no-c-format
msgid "--auto"
msgstr "--auto"

# skip-rule: punctuation-period-no
#. Tag: para
#: man-kdiff3.1.docbook:112
#, no-c-format
msgid ""
"No GUI if all conflicts are auto-solvable. (Needs <option>-o</option> "
"<replaceable>file</replaceable>)"
msgstr ""
"Sense IGU si tots els conflictes es poden resoldre automàticament. (Cal "
"<option>-o</option> <replaceable>fitxer</replaceable>)."

#. Tag: option
#: man-kdiff3.1.docbook:118
#, no-c-format
msgid "--noauto"
msgstr "--noauto"

#. Tag: para
#: man-kdiff3.1.docbook:119
#, no-c-format
msgid "Ignore --auto and always show GUI."
msgstr "Ignora --auto i mostra sempre la IGU."

#. Tag: term
#: man-kdiff3.1.docbook:124
#, no-c-format
msgid "<option>--L1</option> <replaceable>alias1</replaceable>"
msgstr "<option>--L1</option> <replaceable>àlies_1</replaceable>"

#. Tag: para
#: man-kdiff3.1.docbook:125
#, no-c-format
msgid "Visible name replacement for input file 1 (base)."
msgstr "Reemplaçament del nom visible pel fitxer de sortida 1 (base)."

#. Tag: term
#: man-kdiff3.1.docbook:130
#, no-c-format
msgid "<option>--L2</option> <replaceable>alias2</replaceable>"
msgstr "<option>--L2</option> <replaceable>àlies_2</replaceable>"

#. Tag: para
#: man-kdiff3.1.docbook:131
#, no-c-format
msgid "Visible name replacement for input file 2."
msgstr "Reemplaçament del nom visible pel fitxer de sortida 2."

#. Tag: term
#: man-kdiff3.1.docbook:136
#, no-c-format
msgid "<option>--L3</option> <replaceable>alias3</replaceable>"
msgstr "<option>--L3</option> <replaceable>àlies_3</replaceable>"

#. Tag: para
#: man-kdiff3.1.docbook:137
#, no-c-format
msgid "Visible name replacement for input file 3."
msgstr "Reemplaçament del nom visible pel fitxer de sortida 3."

#. Tag: term
#: man-kdiff3.1.docbook:142
#, no-c-format
msgid "<option>-L, --fname</option> <replaceable>alias</replaceable>"
msgstr "<option>-L, --fname</option> <replaceable>àlies</replaceable>"

#. Tag: para
#: man-kdiff3.1.docbook:143
#, no-c-format
msgid "Alternative visible name replacement. Supply this once for every input."
msgstr ""
"Reemplaçament del nom visible alternatiu. Proporcioneu-lo per a cada sortida."

#. Tag: term
#: man-kdiff3.1.docbook:148
#, no-c-format
msgid "<option>--cs</option> <replaceable>string</replaceable>"
msgstr "<option>--cs</option> <replaceable>cadena</replaceable>"

#. Tag: para
#: man-kdiff3.1.docbook:149
#, no-c-format
msgid ""
"Override a config setting. Use once for every setting. &eg;: <option>--cs</"
"option> <replaceable>AutoAdvance=1</replaceable>."
msgstr ""
"Sobreescriu l'opció de la configuració. Useu-ho per a cada opció. &pex;: "
"<option>--cs</option> <replaceable>AutoAdvance=1</replaceable>."

#. Tag: option
#: man-kdiff3.1.docbook:155
#, no-c-format
msgid "--confighelp"
msgstr "--confighelp"

#. Tag: para
#: man-kdiff3.1.docbook:156
#, no-c-format
msgid "Show list of config settings and current values."
msgstr "Mostra una llista de les opcions de configuració i els valors actuals."

#. Tag: term
#: man-kdiff3.1.docbook:161
#, no-c-format
msgid "<option>--config</option> <replaceable>file</replaceable>"
msgstr "<option>--config</option> <replaceable>fitxer</replaceable>"

#. Tag: para
#: man-kdiff3.1.docbook:162
#, no-c-format
msgid "Use a different config file."
msgstr "Usa un fitxer de configuració diferent."

#. Tag: replaceable
#: man-kdiff3.1.docbook:167
#, no-c-format
msgid "File1"
msgstr "fitxer_1"

# skip-rule: punctuation-period-no
#. Tag: para
#: man-kdiff3.1.docbook:168
#, no-c-format
msgid "file1 to open (base, if not specified via --<option>base</option>)"
msgstr ""
"Fitxer 1 a obrir (base, si no s'especifica via <option>--base</option>)."

#. Tag: replaceable
#: man-kdiff3.1.docbook:173
#, no-c-format
msgid "File2"
msgstr "fitxer_2"

# skip-rule: punctuation-period-no
#. Tag: para
#: man-kdiff3.1.docbook:174
#, no-c-format
msgid "file2 to open"
msgstr "Fitxer 2 a obrir."

#. Tag: replaceable
#: man-kdiff3.1.docbook:179
#, no-c-format
msgid "File3"
msgstr "fitxer_3"

# skip-rule: punctuation-period-no
#. Tag: para
#: man-kdiff3.1.docbook:180
#, no-c-format
msgid "file3 to open"
msgstr "Fitxer 3 a obrir."

#. Tag: title
#: man-kdiff3.1.docbook:189
#, no-c-format
msgid "See Also"
msgstr "Vegeu també"

#. Tag: member
#: man-kdiff3.1.docbook:191
#, no-c-format
msgid ""
"More detailed user documentation is available from <ulink url=\"help:/"
"kdiff3\">help:/kdiff3</ulink> (either enter this &URL; into &konqueror;, or "
"run <userinput><command>khelpcenter</command> <parameter>help:/kdiff3</"
"parameter></userinput>)."
msgstr ""
"Hi ha disponible documentació d'usuari més detallada des de <ulink url="
"\"help:/kdiff3\">help:/kdiff3</ulink> (podeu emprar aquest &URL; al "
"&konqueror; o bé executar <userinput><command>khelpcenter</command> "
"<parameter>help:/kdiff3</parameter></userinput>)."

