#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Show Statusbar</guimenuitem>"
msgstr ""
"<guimenu>Arranjament</guimenu> <guimenuitem>Mostra la barra d'estat</"
"guimenuitem>"

#. Tag: para
#: index.docbook:4589
#, no-c-format
msgid "Hide or show the status bar."
msgstr "Mostra o oculta la barra d'estat."

#. Tag: menuchoice
#: index.docbook:4594
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Dock Widgets</guimenuitem>"
msgstr ""
"<guimenu>Arranjament</guimenu> <guimenuitem>Acobla els ginys</guimenuitem>"

#. Tag: para
#: index.docbook:4600
#, no-c-format
msgid "Hide or show the dock widgets in the main window."
msgstr "Oculta o mostra els ginys acoblats a la finestra principal."

#. Tag: menuchoice
#: index.docbook:4604
#, no-c-format
msgid ""
"<guimenu>Settings</guimenu> <guisubmenu>Dock Widgets</guisubmenu> "
"<guimenuitem>Network Neighborhood</guimenuitem>"
msgstr ""
"<guimenu>Arranjament</guimenu> <guisubmenu>Acobla els ginys</guisubmenu> "
"<guimenuitem>Veïnatge de xarxa</guimenuitem>"

