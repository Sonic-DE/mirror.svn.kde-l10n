"<guimenu>File</guimenu> <guisubmenu>Profiles</guisubmenu> <guimenuitem>Work</"
"guimenuitem>"
msgstr ""
"<guimenu>Fitxer</guimenu> <guisubmenu>Profiles</guisubmenu> "
"<guimenuitem>Treball</guimenuitem>"

# skip-rule: punctuation-period-no
#. Tag: para
