"shortcut> <guimenu>Mou</guimenu> <guimenuitem>Carrega una posició</"
"guimenuitem>"

#. Tag: action
#: index.docbook:180
#, no-c-format
msgid "Loads the most recently saved position."
msgstr "Carrega la posició desada més recent."

#. Tag: menuchoice
#: index.docbook:184
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>S</keycap></keycombo> </"
"shortcut> <guimenu>Move</guimenu> <guimenuitem>Save Position</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>S</keycap></keycombo> </"
"shortcut> <guimenu>Desa</guimenu> <guimenuitem>Desa la posició</guimenuitem>"

