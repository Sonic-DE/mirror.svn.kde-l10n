#, no-c-format
msgid "--stdout"
msgstr "--stdout"

#. Tag: para
#: man-meinproc6.1.docbook:146
#, no-c-format
msgid "Output whole document to stdout."
msgstr "Envia tot el document cap a stdout."

#. Tag: term
#: man-meinproc6.1.docbook:153
#, no-c-format
msgid "<option>--stylesheet</option> <parameter>xsl</parameter>"
msgstr "<option>--stylesheet</option> <parameter>xsl</parameter>"

