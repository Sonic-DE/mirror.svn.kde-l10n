msgid "Simple source metrics for C and C++"
msgstr "Una simple aplicació estadística per a fitxers de codi C i C++."

#. Tag: cmdsynopsis
#: man-cxxmetric.1.docbook:24
#, no-c-format
msgid ""
"<command>cxxmetric</command> <group><option><replaceable>file</replaceable></"
"option></group>"
msgstr ""
"<command>cxxmetric</command> <group><option><replaceable>fitxer</"
"replaceable></option></group>"

#. Tag: title
#: man-cxxmetric.1.docbook:33
#, no-c-format
msgid "Description"
msgstr "Descripció"

#. Tag: para
#: man-cxxmetric.1.docbook:35
#, no-c-format
msgid ""
"cxxmetric counts lines of code, comment and blank space and calculates "
"various other statistics for each given source file. Source files must be in "
"C or C++."
msgstr ""
"cxxmetric compta les línies de codi, comentaris i els espais en blanc, i "
"calcula diverses estadístiques per a cadascun dels fitxers de codi. Dits "
"fitxers hauran d'estar escrits en C o C++."

#. Tag: para
#: man-cxxmetric.1.docbook:39
#, no-c-format
msgid "This utility is part of the KDE Software Development Kit."
msgstr ""
"Aquesta utilitat forma part del joc de desenvolupament de programari del "
"&kde;."

