#. Tag: refpurpose
#: man-cvslastlog.1.docbook:20
#, no-c-format
msgid "Prints the log entry for the last commit for a file."
msgstr "Imprimeix el registre per a l'última comissió d'un fitxer."

#. Tag: cmdsynopsis
#: man-cvslastlog.1.docbook:24
#, no-c-format
msgid ""
"<command>cvslastlog</command> <group><option><replaceable>filename</"
"replaceable></option></group>"
msgstr ""
"<command>cvslastlog</command> <group><option><replaceable>nom_fitxer</"
"replaceable></option></group>"

#. Tag: title
#: man-cvslastlog.1.docbook:32
#, no-c-format
msgid "Description"
msgstr "Descripció"

#. Tag: para
#: man-cvslastlog.1.docbook:34
#, no-c-format
msgid ""
"<command>cvslastlog</command> shows the log associated with the last CVS "
"commit for the given file. It depends on the version of the local file, not "
"the one on the server."
msgstr ""
"<command>cvslastlog</command> mostra el registre associat amb l'última "
"comissió al CVS per al fitxer indicat. Aquest dependrà de la versió local "
"del fitxer, no de la que hi ha al servidor."

#. Tag: para
#: man-cvslastlog.1.docbook:38
#, no-c-format
msgid "This utility is part of the &kde; Software Development Kit."
msgstr ""
"Aquesta utilitat forma part del joc de desenvolupament de programari del "
"&kde;."

