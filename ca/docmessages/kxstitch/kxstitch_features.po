#. Tag: title
#: features.docbook:2
#, no-c-format
msgid "Features"
msgstr "Característiques"

#. Tag: para
#: features.docbook:3
#, no-c-format
msgid "The current feature list and other planned features is shown here."
msgstr ""
"La llista de característiques actual i altres característiques planificades "
"es mostren aquí."

#. Tag: para
#: features.docbook:5
#, no-c-format
msgid "Creation of new patterns"
msgstr "Creació de patrons nous"

#. Tag: para
#: features.docbook:7
#, no-c-format
msgid "User defined size"
msgstr "Mida definida per l'usuari"

#. Tag: para
#: features.docbook:8
#, no-c-format
msgid "Selection of material color"
msgstr "Selecció del color del material"

#. Tag: para
#: features.docbook:9
#, no-c-format
msgid "Insertion of a background images for tracing"
msgstr "Inserció d'imatges de fons per al seguiment"

#. Tag: para
#: features.docbook:10
#, no-c-format
msgid "Importing of various image formats"
msgstr "Importació de diversos formats d'imatge"

#. Tag: para
#: features.docbook:11
#, no-c-format
msgid "Importing options allow"
msgstr "Es permeten opcions d'importació"

