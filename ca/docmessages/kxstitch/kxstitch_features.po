#: features.docbook:26
#, no-c-format
msgid "Filled polygons"
msgstr "Polígons emplenats"

#. Tag: para
#: features.docbook:27
#, no-c-format
msgid "Painting"
msgstr "Pintat"

#. Tag: para
#: features.docbook:28
#, no-c-format
msgid "Lines"
msgstr "Línies"

#. Tag: para
#: features.docbook:29
#, no-c-format
msgid "Erasing stitches, knots and backstitches"
msgstr "Esborrat de les puntades, nusos i repunts"

