#: features.docbook:14
#, no-c-format
msgid "Limiting colors to a specific palette"
msgstr "Limitació dels colors a una paleta específica"

#. Tag: para
#: features.docbook:15
#, no-c-format
msgid "Scaling to a finished size"
msgstr "Escalat a una mida final"

