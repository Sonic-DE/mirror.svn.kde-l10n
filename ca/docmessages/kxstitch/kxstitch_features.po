#: features.docbook:30
#, no-c-format
msgid "Color selection from existing stitches"
msgstr "Selecció del color des de les puntades existents"

#. Tag: para
#: features.docbook:31
#, no-c-format
msgid "Swapping two colors"
msgstr "Intercanvi de dos colors"

#. Tag: para
#: features.docbook:32
#, no-c-format
msgid "Replace one color with another"
msgstr "Substitució d'un color amb un altre"

