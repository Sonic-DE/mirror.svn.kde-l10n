#. Tag: guimenuitem
#: commands.docbook:494
#, no-c-format
msgid "Configure &kxstitch;"
msgstr "Configura el &kxstitch;"

#. Tag: action
#: commands.docbook:495
#, no-c-format
msgid ""
"Open &kxstitch; <link linkend=\"ConfigurationDialog\">configuration dialog</"
"link>."
msgstr ""
"Obre el <link linkend=\"ConfigurationDialog\">diàleg de configuració</link> "
"del &kxstitch;."

#. Tag: title
#: commands.docbook:503
#, no-c-format
msgid "The Help Menu"
msgstr "El menú Ajuda"

#. Tag: para
#: commands.docbook:504
#, no-c-format
msgid ""
"Additionally &kxstitch; has the common &kde; Help menu items, for more "
"information read the section about the <ulink url=\"help:/fundamentals/menus."
"html#menus-help\">Help Menu</ulink> of the &kde; Fundamentals."
msgstr ""
"De manera addicional, el &kxstitch; té la configuració comuna al &kde; i els "
"elements del menú <guimenu>Ajuda</guimenu>. Per a obtenir més informació, "
"llegiu la secció sobre <ulink url=\"help:/fundamentals/menus.html#menus-help"
"\">El menú Ajuda</ulink> en els Fonaments del &kde;."
