#: index.docbook:1313
#, no-c-format
msgid "%B : user's Bourne prompt sigil ($ = normal user, # = superuser)"
msgstr ""
"%B : secretisme de l'indicador de Bourne de l'usuari ($ = usuari normal, # = "
