#: index.docbook:1315 index.docbook:1327
#, no-c-format
msgid "%# : session number"
msgstr "%# : número de la sessió"

#. Tag: para
#: index.docbook:1318
#, no-c-format
msgid "&konsole; will substitute these tokens for remote tabs:"
msgstr "El &konsole; substituirà aquests testimonis a les pestanyes remotes:"

# skip-rule: t-sp_2p
#. Tag: para
#: index.docbook:1321
#, no-c-format
msgid "%c : current program"
msgstr "%c : programa actual"

