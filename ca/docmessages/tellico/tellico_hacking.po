#: hacking.docbook:344
#, no-c-format
msgid ""
"<![CDATA[\n"
"  <key char=\"À\">\n"
"    <string>{\\`A}</string>\n"
"    <string>\\`{A}</string>\n"
"  </key>\n"
"]]>"
msgstr ""
"<![CDATA[\n"
"  <key char=\"À\">\n"
"    <string>{\\`A}</string>\n"
"    <string>\\`{A}</string>\n"
"  </key>\n"
"]]>"

