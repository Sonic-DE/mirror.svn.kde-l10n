"shortcut> <guimenu>Fitxer</guimenu> <guimenuitem>Desa la captura de pantalla "
"com a...</guimenuitem>"

#. Tag: para
#: index.docbook:230
#, no-c-format
msgid "Saves the zoomed view to an image file."
msgstr "Desa la vista ampliada a un fitxer d'imatge."

#. Tag: menuchoice
#: index.docbook:234
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>P</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Print...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>P</keycap></keycombo> </"
"shortcut> <guimenu>Fitxer</guimenu> <guimenuitem>Imprimeix...</guimenuitem>"

#. Tag: para
#: index.docbook:242
#, no-c-format
msgid "Prints the current zoomed view."
msgstr "Imprimeix la vista ampliada actual."

#. Tag: menuchoice
#: index.docbook:246
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>Q</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Quit</guimenuitem>"
msgstr ""
