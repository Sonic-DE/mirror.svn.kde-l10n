#. Tag: term
#: man-skladnik.6.docbook:84
#, no-c-format
msgid "<option>--desktopfile</option> <parameter>FILENAME</parameter>"
msgstr "<option>--desktopfile</option> <parameter>NOM_FITXER</parameter>"

#. Tag: para
#: man-skladnik.6.docbook:86
#, no-c-format
msgid ""
"Use FILENAME as the base file name of the desktop entry for this application."
msgstr ""
"Usa NOM_FITXER com a nom de fitxer base de l'entrada «desktop» per a aquesta "
"aplicació."

