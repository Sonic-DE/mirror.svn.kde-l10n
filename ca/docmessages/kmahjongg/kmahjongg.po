msgstr "<screeninfo>Inicia el diàleg de Partida numerada</screeninfo>"

#. Tag: phrase
#: index.docbook:246
#, no-c-format
msgid "<phrase>Start a Numbered Game Dialog</phrase>"
msgstr "<phrase>Inicia el diàleg de Partida numerada</phrase>"

#. Tag: menuchoice
#: index.docbook:252
