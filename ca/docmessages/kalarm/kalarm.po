#, no-c-format
msgid "<refname>scheduleEmail</refname>"
msgstr "<refname>scheduleEmail</refname>"

#. Tag: refpurpose
#: index.docbook:4436
#, no-c-format
msgid "schedule a new alarm which sends an email."
msgstr "programa una alarma nova que enviarà un correu electrònic."

#. Tag: synopsis
