#. Tag: para
#: index.docbook:17
#, no-c-format
msgid ""
"The <emphasis>file</emphasis> protocol is used by all &kde; applications to "
"display locally available files."
msgstr ""
"El protocol <emphasis>file</emphasis>, és utilitzat per totes les "
"aplicacions del &kde; per a mostrar els fitxers disponibles localment."

#. Tag: para
#: index.docbook:21
#, no-c-format
msgid ""
"Entering <userinput><command>file:/directoryname</command></userinput> in "
"&konqueror; lists the files of this folder."
msgstr ""
"Introduint <userinput><command>file:/nom_carpeta</command></userinput> en el "
"&konqueror; es mostren els fitxers d'aquesta carpeta."
