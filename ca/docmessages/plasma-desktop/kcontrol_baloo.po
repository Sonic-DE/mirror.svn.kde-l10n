#. Tag: title
#: index.docbook:8
#, no-c-format
msgid "File Search"
msgstr "Cerca de fitxers"

#. Tag: author
#: index.docbook:11
#, no-c-format
msgid "<firstname>Vishesh</firstname> <surname>Handa</surname>"
msgstr "<firstname>Vishesh</firstname> <surname>Handa</surname>"

#. Tag: trans_comment
#: index.docbook:15
#, no-c-format
msgid "ROLES_OF_TRANSLATORS"
msgstr "&traductor.Antoni.Bella;"

#. Tag: date
#: index.docbook:18
#, no-c-format
msgid "2023-01-30"
msgstr "30 de gener de 2023"

#. Tag: releaseinfo
#: index.docbook:19
#, no-c-format
msgid "Plasma 5.27"
msgstr "Plasma 5.27"

#. Tag: keyword
#: index.docbook:22
#, no-c-format
msgid "Plasma"
msgstr "Plasma"

#. Tag: keyword
#: index.docbook:23
#, no-c-format
msgid "Systemsettings"
msgstr "Arranjament del sistema"

#. Tag: keyword
#: index.docbook:24
#, no-c-format
msgid "search"
msgstr "cerca"

#. Tag: keyword
#: index.docbook:25
#, no-c-format
