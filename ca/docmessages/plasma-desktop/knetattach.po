#. Tag: para
#: index.docbook:41
#, no-c-format
msgid ""
"&knetattach; is a wizard which makes it easier to integrate your network "
"resources with your &kde; Desktop."
msgstr ""
"El &knetattach; és un assistent que facilita la integració dels recursos de "
"xarxa amb el vostre escriptori &kde;."

#. Tag: keyword
#: index.docbook:52
#, no-c-format
msgid "<keyword>KDE</keyword>"
msgstr "<keyword>KDE</keyword>"

#. Tag: keyword
#: index.docbook:53
