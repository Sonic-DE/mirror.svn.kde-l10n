#. Tag: para
#: index.docbook:719
#, no-c-format
msgid ""
"If you haven't saved the project before the project is saved under a "
"temporary project file name."
msgstr ""
"Si no heu desat el projecte abans, el projecte es desarà amb un nom temporal "
"de fitxer de projecte."

#. Tag: menuchoice
#: index.docbook:724
#, no-c-format
msgid "<guimenu>File</guimenu><guimenuitem>Save As</guimenuitem>"
msgstr "<guimenu>Fitxer</guimenu> <guimenuitem>Desa com a</guimenuitem>"

#. Tag: action
#: index.docbook:727
#, no-c-format
msgid "Saves the actual project under a different name."
msgstr "Desa el projecte real amb un nom diferent."

#. Tag: menuchoice
#: index.docbook:733
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>P</keycap></keycombo></shortcut> "
"<guimenu>File</guimenu><guimenuitem>Print</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>P</keycap></keycombo> </shortcut> "
"<guimenu>Fitxer</guimenu> <guimenuitem>Imprimeix</guimenuitem>"

