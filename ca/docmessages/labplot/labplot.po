#. Tag: action
#: index.docbook:1928
#, no-c-format
msgid ""
"Taylor coefficient x<superscript>n</superscript> / n! for x >= 0, n >= 0"
msgstr ""
"coeficient de Taylor x<superscript>n</superscript> / n! per x >= 0, n >= 0"

#. Tag: entry
#: index.docbook:1929
#, no-c-format
msgid "poch(a,x)"
msgstr "poch(a,x)"

#. Tag: action
#: index.docbook:1929
#, no-c-format
msgid ""
"Pochhammer symbol (a)<subscript>x</subscript> := &Gamma;(a + x)/&Gamma;(x)"
msgstr ""
"símbol de Pochhammer (a)<subscript>x</subscript> := &Gamma;(a + x)/&Gamma;(x)"

#. Tag: entry
#: index.docbook:1930
#, no-c-format
msgid "lnpoch(a,x)"
msgstr "lnpoch(a,x)"

#. Tag: action
#: index.docbook:1930
#, no-c-format
msgid ""
"logarithm of the Pochhammer symbol (a)<subscript>x</subscript> := &Gamma;(a "
"+ x)/&Gamma;(x)"
msgstr ""
"logaritme del símbol de Pochhammer (a)<subscript>x</subscript> := &Gamma;(a "
"+ x)/&Gamma;(x)"

#. Tag: entry
#: index.docbook:1931
#, no-c-format
msgid "pochrel(a,x)"
msgstr "pochrel(a,x)"

#. Tag: action
#: index.docbook:1931
#, no-c-format
msgid ""
"relative Pochhammer symbol ((a,x) - 1)/x where (a,x) = (a)<subscript>x</"
"subscript> := &Gamma;(a + x)/&Gamma;(a)"
msgstr ""
"símbol de Pochhammer relatiu ((a,x) - 1)/x on (a,x) = (a)<subscript>x</"
"subscript> := &Gamma;(a + x)/&Gamma;(a)"

