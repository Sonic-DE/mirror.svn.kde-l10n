#: index.docbook:1898
#, no-c-format
msgid ""
"2(exp(x)-1-x)/x<superscript>2</superscript> using an algorithm that is "
"accurate for small x"
msgstr ""
"2(exp(x)-1-x)/x<superscript>2</superscript> utilitzant un algorisme que és "
"acurat per a x petit"

#. Tag: entry
#: index.docbook:1899
#, no-c-format
msgid "expreln(n,x)"
msgstr "expreln(n,x)"

# skip-rule: rst-link0italic
#. Tag: action
#: index.docbook:1899
#, no-c-format
