#: index.docbook:1905
#, no-c-format
msgid "chi(x)"
msgstr "chi(x)"

#. Tag: action
#: index.docbook:1905
#, no-c-format
msgid ""
"integral Chi(x) := Re[ &gamma;<subscript>E</subscript> + log(x) + &int;"
"<subscript>0</subscript><superscript>x</superscript> (cosh[t]-1)/t dt ]"
msgstr ""
"integral Chi(x) := Re[ &gamma;<subscript>E</subscript> + log(x) + &int;"
"<subscript>0</subscript><superscript>x</superscript> (cosh[t]-1)/t dt ]"

#. Tag: entry
#: index.docbook:1906
#, no-c-format
msgid "Ei3(x)"
msgstr "Ei3(x)"

#. Tag: action
#: index.docbook:1906
#, no-c-format
msgid ""
"exponential integral Ei<subscript>3</subscript>(x) = &int;<subscript>0</"
"subscript><superscript>x</superscript> exp(-t<superscript>3</superscript>) "
"dt for x &gt;= 0"
msgstr ""
"integral exponencial Ei<subscript>3</subscript>(x) = &int;<subscript>0</"
"subscript><superscript>x</superscript> exp(-t<superscript>3</superscript>) "
"dt per x &gt;= 0"

#. Tag: entry
#: index.docbook:1907
#, no-c-format
msgid "si(x)"
msgstr "si(x)"

#. Tag: action
#: index.docbook:1907
#, no-c-format
msgid ""
"Sine integral Si(x) = &int;<subscript>0</subscript><superscript>x</"
"superscript> sin(t)/t dt"
msgstr ""
"integral del sinus Si(x) = &int;<subscript>0</subscript><superscript>x</"
"superscript> sin(t)/t dt"

#. Tag: entry
#: index.docbook:1908
#, no-c-format
msgid "ci(x)"
msgstr "ci(x)"

#. Tag: action
#: index.docbook:1908
#, no-c-format
msgid ""
"Cosine integral Ci(x) = -&int;<subscript>x</subscript><superscript>&infin;</"
"superscript> cos(t)/t dt for x &gt; 0"
msgstr ""
"integral del cosinus Ci(x) = -&int;<subscript>x</"
"subscript><superscript>&infin;</superscript> cos(t)/t dt per x &gt; 0"

#. Tag: entry
#: index.docbook:1909
#, no-c-format
msgid "atanint(x)"
msgstr "atanint(x)"

#. Tag: action
#: index.docbook:1909
#, no-c-format
msgid ""
"Arctangent integral AtanInt(x) = &int;<subscript>0</"
"subscript><superscript>x</superscript> arctan(t)/t dt"
msgstr ""
"integral de l'arctangent AtanInt(x) = &int;<subscript>0</"
"subscript><superscript>x</superscript> arctan(t)/t dt"

#. Tag: entry
#: index.docbook:1910
#, no-c-format
msgid "Fm1(x)"
msgstr "Fm1(x)"

# skip-rule: t-e_sola
#. Tag: action
#: index.docbook:1910
#, no-c-format
msgid ""
"complete Fermi-Dirac integral with an index of -1, F<subscript>-1</"
"subscript>(x) = e<superscript>x</superscript> / (1 + e<superscript>x</"
"superscript>)"
msgstr ""
"integral de Fermi-Dirac completa amb un índex de -1, F<subscript>-1</"
"subscript>(x) = e<superscript>x</superscript> / (1 + e<superscript>x</"
"superscript>)"

#. Tag: entry
#: index.docbook:1911
#, no-c-format
msgid "F0(x)"
msgstr "F0(x)"

# skip-rule: t-e_sola
#. Tag: action
#: index.docbook:1911
#, no-c-format
msgid ""
"complete Fermi-Dirac integral with an index of 0, F<subscript>0</"
"subscript>(x) = ln(1 + e<superscript>x</superscript>)"
msgstr ""
"integral de Fermi-Dirac completa amb un índex de 0, F<subscript>0</"
"subscript>(x) = ln(1 + e<superscript>x</superscript>)"

#. Tag: entry
#: index.docbook:1912
#, no-c-format
msgid "F1(x)"
msgstr "F1(x)"

#. Tag: action
#: index.docbook:1912
#, no-c-format
msgid ""
"complete Fermi-Dirac integral with an index of 1, F<subscript>1</"
"subscript>(x) = &int;<subscript>0</subscript><superscript>&infin;</"
"superscript> (t /(exp(t-x)+1)) dt"
msgstr ""
"integral de Fermi-Dirac completa amb un índex de 1, F<subscript>1</"
"subscript>(x) = &int;<subscript>0</subscript><superscript>&infin;</"
"superscript> (t /(exp(t-x)+1)) dt"

#. Tag: entry
#: index.docbook:1913
#, no-c-format
msgid "F2(x)"
msgstr "F2(x)"

#. Tag: action
#: index.docbook:1913
#, no-c-format
msgid ""
"complete Fermi-Dirac integral with an index of 2, F<subscript>2</"
"subscript>(x) = (1/2) &int;<subscript>0</subscript><superscript>&infin;</"
"superscript> (t<superscript>2</superscript> /(exp(t-x)+1)) dt"
msgstr ""
"integral de Fermi-Dirac completa amb un índex de 2, F<subscript>2</"
"subscript>(x) = (1/2) &int;<subscript>0</subscript><superscript>&infin;</"
"superscript> (t<superscript>2</superscript> /(exp(t-x)+1)) dt"

