#: index.docbook:1938
#, no-c-format
msgid ""
"Gegenbauer polynomial C<superscript>&lambda;</superscript><subscript>1</"
"subscript>(x)"
msgstr ""
"Polinomi de Gegenbauer C<superscript>&lambda;</superscript><subscript>1</"
"subscript>(x)"

#. Tag: entry
#: index.docbook:1939
#, no-c-format
msgid "C2(&lambda;,x)"
msgstr "C2(&lambda;,x)"

#. Tag: action
#: index.docbook:1939
#, no-c-format
msgid ""
"Gegenbauer polynomial C<superscript>&lambda;</superscript><subscript>2</"
"subscript>(x)"
msgstr ""
"Polinomi de Gegenbauer C<superscript>&lambda;</superscript><subscript>2</"
"subscript>(x)"

#. Tag: entry
