#: index.docbook:1926
#, no-c-format
msgid "combinatorial factor `n choose m' = n!/(m!(n-m)!)"
msgstr "factor combinatori «n tria m» = n!/(m!(n-m)!)"

#. Tag: entry
#: index.docbook:1927
#, no-c-format
msgid "lnchoose(n,m)"
msgstr "lnchoose(n,m)"

# skip-rule: rst-link0italic
#. Tag: action
#: index.docbook:1927
#, no-c-format
msgid "logarithm of `n choose m'"
msgstr "logaritme de «n tria m»"

#. Tag: entry
#: index.docbook:1928
#, no-c-format
msgid "taylor(n,x)"
msgstr "taylor(n,x)"

