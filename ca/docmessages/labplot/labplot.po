msgstr ""
"exponencial relativa a n, que és la n-sima generalització de les funcions "
"«exprel»"

#. Tag: entry
#: index.docbook:1900
#, no-c-format
msgid "E1(x)"
msgstr "E1(x)"

#. Tag: action
#: index.docbook:1900
#, no-c-format
msgid ""
"exponential integral E<subscript>1</subscript>(x), E<subscript>1</"
"subscript>(x) := Re &int;<subscript>1</subscript><superscript>&infin;</"
"superscript> exp(-xt)/t dt"
msgstr ""
"integral exponencial E<subscript>1</subscript>(x), E<subscript>1</"
"subscript>(x) := Re &int;<subscript>1</subscript><superscript>&infin;</"
"superscript> exp(-xt)/t dt"

#. Tag: entry
#: index.docbook:1901
#, no-c-format
msgid "E2(x)"
msgstr "E2(x)"

#. Tag: action
#: index.docbook:1901
#, no-c-format
msgid ""
"second-order exponential integral E<subscript>2</subscript>(x), "
"E<subscript>2</subscript>(x) := Re &int;<subscript>1</"
"subscript><superscript>&infin;</superscript> exp(-xt)/t<superscript>2</"
"superscript> dt"
msgstr ""
"integral exponencial de segon ordre E<subscript>2</subscript>(x), "
"E<subscript>2</subscript>(x) := Re &int;<subscript>1</"
"subscript><superscript>&infin;</superscript> exp(-xt)/t<superscript>2</"
"superscript> dt"

#. Tag: entry
#: index.docbook:1902
#, no-c-format
msgid "En(x)"
msgstr "En(x)"

#. Tag: action
#: index.docbook:1902
#, no-c-format
msgid ""
"exponential integral E_n(x) of order n, E<subscript>n</subscript>(x) := Re "
"&int;<subscript>1</subscript><superscript>&infin;</superscript> exp(-xt)/"
"t<superscript>n</superscript> dt)"
msgstr ""
"integral exponencial E_n(x) d'ordre n, E<subscript>n</subscript>(x) := Re "
"&int;<subscript>1</subscript><superscript>&infin;</superscript> exp(-xt)/"
"t<superscript>n</superscript> dt)"

#. Tag: entry
#: index.docbook:1903
#, no-c-format
msgid "Ei(x)"
msgstr "Ei(x)"

#. Tag: action
#: index.docbook:1903
#, no-c-format
msgid ""
"exponential integral E_i(x), Ei(x) := PV(&int;<subscript>-x</"
"subscript><superscript>&infin;</superscript> exp(-t)/t dt)"
msgstr ""
"integral exponencial E_i(x), Ei(x) := PV(&int;<subscript>-x</"
"subscript><superscript>&infin;</superscript> exp(-t)/t dt)"

#. Tag: entry
#: index.docbook:1904
#, no-c-format
msgid "shi(x)"
msgstr "shi(x)"

#. Tag: action
#: index.docbook:1904
#, no-c-format
msgid ""
"Shi(x) = &int;<subscript>0</subscript><superscript>x</superscript> sinh(t)/t "
"dt"
msgstr ""
"Shi(x) = &int;<subscript>0</subscript><superscript>x</superscript> sinh(t)/t "
"dt"

