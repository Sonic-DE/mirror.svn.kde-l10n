#: index.docbook:1933
#, no-c-format
msgid ""
"normalized incomplete Gamma Function P(a,x) = 1/&Gamma;(a) &int;"
"<subscript>x</subscript><superscript>&infin;</superscript> "
"t<superscript>a-1</superscript> exp(-t) dt for a &gt; 0, x &gt;= 0"
msgstr ""
"funció gamma incompleta normalitzada P(a,x) = 1/&Gamma;(a) &int;"
"<subscript>x</subscript><superscript>&infin;</superscript> "
"t<superscript>a-1</superscript> exp(-t) dt per a &gt; 0, x &gt;= 0"

#. Tag: entry
#: index.docbook:1934
#, no-c-format
msgid "gammaincP(a,x)"
msgstr "gammaincP(a,x)"

#. Tag: action
#: index.docbook:1934
#, no-c-format
msgid ""
"complementary normalized incomplete Gamma Function P(a,x) = 1/&Gamma;(a) "
"&int;<subscript>0</subscript><superscript>x</superscript> t<superscript>a-1</"
"superscript> exp(-t) dt for a &gt; 0, x &gt;= 0"
msgstr ""
"funció gamma incompleta normalitzada complementària P(a,x) = 1/&Gamma;(a) "
"&int;<subscript>0</subscript><superscript>x</superscript> t<superscript>a-1</"
"superscript> exp(-t) dt per a &gt; 0, x &gt;= 0"

#. Tag: entry
#: index.docbook:1935
#, no-c-format
msgid "beta(a,b)"
msgstr "beta(a,b)"

#. Tag: action
#: index.docbook:1935
#, no-c-format
msgid ""
"Beta Function, B(a,b) = &Gamma;(a) &Gamma;(b)/&Gamma;(a+b) for a &gt; 0, b "
"&gt; 0"
msgstr ""
"funció beta, B(a,b) = &gamma;(a) &gamma;(b)/&Gamma;(a+b) per a &gt; 0, b "
"&gt; 0"

#. Tag: entry
#: index.docbook:1936
#, no-c-format
msgid "lnbeta(a,b)"
msgstr "lnbeta(a,b)"

#. Tag: action
#: index.docbook:1936
#, no-c-format
msgid "logarithm of the Beta Function, log(B(a,b)) for a &gt; 0, b &gt; 0"
msgstr "logaritme de la funció beta, log(B(a,b)) per a &gt; 0, b &gt; 0"

#. Tag: entry
#: index.docbook:1937
#, no-c-format
msgid "betainc(a,b,x)"
msgstr "betainc(a,b,x)"

#. Tag: action
#: index.docbook:1937
#, no-c-format
msgid ""
"normalize incomplete Beta function B_x(a,b)/B(a,b) for a &gt; 0, b &gt; 0"
msgstr ""
"normalitza la funció beta incompleta B_x(a,b)/B(a,b) per a &gt; 0, b &gt; 0"

#. Tag: entry
#: index.docbook:1938
#, no-c-format
