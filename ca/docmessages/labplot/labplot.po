"<subscript>x</subscript><superscript>&infin;</superscript> exp(-"
"t<superscript>2</superscript>/2) dt"
msgstr ""
"cua superior de la funció de probabilitat gaussiana Q(x) = (1/(2&pi;)) &int;"
"<subscript>x</subscript><superscript>&infin;</superscript> exp(-"
"t<superscript>2</superscript>/2) dt"

#. Tag: entry
#: index.docbook:1893
#, no-c-format
msgid "hazard(x)"
msgstr "hazard(x)"

#. Tag: action
#: index.docbook:1893
#, no-c-format
