msgstr "logaritme de la funció d'error complementària log(erfc(x))"

#. Tag: entry
#: index.docbook:1891
#, no-c-format
msgid "erf_Z(x)"
msgstr "erf_Z(x)"

#. Tag: action
#: index.docbook:1891
#, no-c-format
