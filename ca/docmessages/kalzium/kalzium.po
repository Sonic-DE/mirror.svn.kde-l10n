"\"><guimenuitem>State of matter</guimenuitem></ulink>&nbsp;"
msgstr ""
"<ulink url=\"https://ca.wikipedia.org/wiki/Estat_de_la_matèria"
"\"><guimenuitem>Estat de la matèria</guimenuitem></ulink>&nbsp;"

#. Tag: para
#: index.docbook:454
#, no-c-format
msgid ""
