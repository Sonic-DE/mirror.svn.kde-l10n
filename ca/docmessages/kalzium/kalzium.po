#. Tag: para
#: index.docbook:461
#, no-c-format
msgid ""
"<ulink url=\"https://en.wikipedia.org/wiki/Boiling_Point"
"\"><guimenuitem>Boiling Point</guimenuitem></ulink>&nbsp;"
msgstr ""
"<ulink url=\"https://ca.wikipedia.org/wiki/Punt_d'ebullició"
"\"><guimenuitem>Punt d'ebullició</guimenuitem></ulink>&nbsp;"

#. Tag: para
#: index.docbook:463
#, no-c-format
msgid ""
"<ulink url=\"https://en.wikipedia.org/wiki/Melting_Point"
"\"><guimenuitem>Melting Point</guimenuitem></ulink>&nbsp;"
msgstr ""
"<ulink url=\"https://ca.wikipedia.org/wiki/Punt_de_fusió\"><guimenuitem>Punt "
