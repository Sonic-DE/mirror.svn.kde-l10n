#. Tag: para
#: index.docbook:130
#, no-c-format
msgid ""
"The Glossary (<menuchoice> <guimenu>Tools</guimenu> <guimenuitem>Glossary..."
"</guimenuitem> </menuchoice>) explains the most important chemical words and "
"shows you pictures of the most common tools along with an explanation."
msgstr ""
"El glossari (<menuchoice> <guimenu>Eines</guimenu> <guimenuitem>Glossari...</"
"guimenuitem> </menuchoice>) explica els conceptes químics més importants i "
"mostra imatges de les eines més habituals juntament amb una descripció "
"d'aquestes."

#. Tag: screeninfo
#: index.docbook:133
#, no-c-format
msgid "<screeninfo>The Glossary</screeninfo>"
msgstr "<screeninfo>El glossari</screeninfo>"

