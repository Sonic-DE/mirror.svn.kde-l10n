msgstr "<phrase>Seleccionant el canal mestre del &kmix;</phrase>"

#. Tag: para
#: index.docbook:209
#, no-c-format
msgid "Select your &kmix; master channel."
msgstr "Seleccioneu el canal mestre del &kmix;."

