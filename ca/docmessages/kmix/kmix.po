"<guimenu>Arranjament</guimenu> <guimenuitem>Arranjament de l'àudio</"
"guimenuitem>"

#. Tag: para
#: index.docbook:173
#, no-c-format
msgid ""
"<action>Open <ulink url=\"help:/kcontrol/phonon\">&phonon; &systemsettings; "
"module</ulink></action> to configure the sound and video device preference "
"and the backends used by &kde; multimedia API, &phonon;."
msgstr ""
"<action>Obre el <ulink url=\"help:/kcontrol/phonon\">mòdul &phonon; al "
"&systemsettings;</ulink></action> per a configurar el so i la preferència "
"del dispositiu de vídeo, així com els dorsals emprats per l'API multimèdia "
"del &kde;, &phonon;."

