#, no-c-format
msgid "Selects all transactions in the ledger."
msgstr "Selecciona totes les operacions del llibre major."

#. Tag: menuchoice
#: reference.docbook:726
#, no-c-format
msgid "<guimenu>Transaction</guimenu><guimenuitem>Print check</guimenuitem>"
msgstr "<guimenu>Operació</guimenu><guimenuitem>Imprimeix el xec</guimenuitem>"

#. Tag: para
#: reference.docbook:730
#, no-c-format
msgid ""
"Prints the contents of the selected transaction in the displayed ledger, "
"formatted according to the selected template. See the section on configuring "
"the <link linkend=\"details.settings.plugins\">Print check</link> plugin for "
"more information."
msgstr ""
"Imprimeix el contingut de l'operació seleccionada al llibre major mostrat, "
"amb un format d'acord amb la plantilla seleccionada. Vegeu la secció sobre "
"configurar el connector <link linkend=\"details.settings.plugins\">Imprimir "
"un xec</link> per a més informació."

