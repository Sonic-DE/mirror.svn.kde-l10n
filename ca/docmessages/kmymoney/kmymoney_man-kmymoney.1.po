#, no-c-format
msgid "--lang"
msgstr "--lang"

# skip-rule: punctuation-period-no
#. Tag: para
#: man-kmymoney.1.docbook:138
#, no-c-format
msgid "Language to be used"
msgstr "L'idioma a emprar."

#. Tag: option
#: man-kmymoney.1.docbook:143
#, no-c-format
msgid "<option>-n</option>"
msgstr "<option>-n</option>"

# skip-rule: punctuation-period-no
#. Tag: para
#: man-kmymoney.1.docbook:145
#, no-c-format
msgid "Do not open last used file"
msgstr "No obris el darrer fitxer utilitzat."

#. Tag: option
#: man-kmymoney.1.docbook:150
#, no-c-format
msgid "--timers"
msgstr "--timers"

# skip-rule: punctuation-period-no
#. Tag: para
#: man-kmymoney.1.docbook:152
#, no-c-format
msgid "Enable performance timers"
msgstr "Activa els temporitzadors de rendiment."

#. Tag: option
#: man-kmymoney.1.docbook:157
#, no-c-format
msgid "--nocatch"
msgstr "--nocatch"

# skip-rule: punctuation-period-no
#. Tag: para
#: man-kmymoney.1.docbook:159
#, no-c-format
msgid "Do not globally catch uncaught exceptions"
msgstr "No captura globalment les excepcions no capturades."

#. Tag: option
#: man-kmymoney.1.docbook:164
#, no-c-format
msgid "--trace"
msgstr "--trace"

#. Tag: para
#: man-kmymoney.1.docbook:166
#, no-c-format
msgid ""
"Turn on program traces. This option is only available when &kmymoney; is "
"compiled in debug mode."
msgstr ""
"Engega els traçats del programa. Aquesta opció només està disponible quan el "
"&kmymoney; es compila en el mode de depuració."

#. Tag: option
#: man-kmymoney.1.docbook:174
#, no-c-format
msgid "--dump-actions"
msgstr "--dump-actions"

#. Tag: para
#: man-kmymoney.1.docbook:176
#, no-c-format
msgid ""
"Dump the names of all defined QAction objects to stdout and quit. This "
"option is only available when &kmymoney; is compiled in debug mode."
msgstr ""
"Bolca els noms de tots els objectes QAction definits a la sortida estàndard "
"i surt. Aquesta opció només està disponible quan el &kmymoney; es compila en "
"el mode de depuració."

