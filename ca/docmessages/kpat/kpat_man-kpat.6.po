msgstr "<option>--solvegame</option> <replaceable> fitxer</replaceable>"

# skip-rule: punctuation-period-no
#. Tag: para
#: man-kpat.6.docbook:72
#, no-c-format
msgid "Try to find a solution to the given savegame"
msgstr "Intenta trobar una solució de la partida desada que s'ha indicat."

#. Tag: term
#: man-kpat.6.docbook:77
#, no-c-format
msgid "<option>--solve</option> <replaceable> num</replaceable>"
msgstr "<option>--solve</option> <replaceable> núm.</replaceable>"

# skip-rule: punctuation-period-no
