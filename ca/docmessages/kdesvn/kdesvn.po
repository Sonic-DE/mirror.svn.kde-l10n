msgid "diff"
msgstr "diff"

# skip-rule: punctuation-period-no
#. Tag: entry
#: index.docbook:1157
#, no-c-format
msgid "Diff two revisions of item or diff two items at specific revision"
msgstr ""
"Crea un diff de dues revisions de l'element o el diff de dos elements en una "
"revisió específica."

#. Tag: entry
#: index.docbook:1158 index.docbook:1208
#, no-c-format
msgid "-r startrev:endrev"
msgstr "-r rev_inici:rev_final"

#. Tag: entry
#: index.docbook:1161
