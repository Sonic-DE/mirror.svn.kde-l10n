msgstr "Subversion"

#. Tag: entry
#: index.docbook:1373
#, no-c-format
msgid "Start check for updates when open a working copy"
msgstr "Inicia la comprovació d'actualitzacions en obrir una còpia de treball"

# skip-rule: punctuation-period-no
#. Tag: entry
#: index.docbook:1374
#, no-c-format
