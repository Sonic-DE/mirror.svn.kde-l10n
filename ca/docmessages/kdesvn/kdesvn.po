# skip-rule: punctuation-period-no
#. Tag: entry
#: index.docbook:1334
#, no-c-format
msgid ""
"When an item isn't in normal subversion state it may get an overlay. (See "
"<xref linkend=\"overlay-meaning\"/>)"
msgstr ""
"Quan un element no està en l'estat normal de Subversion es pot obtenir una "
