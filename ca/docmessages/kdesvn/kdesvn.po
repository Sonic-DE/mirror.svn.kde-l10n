msgstr "Obtén el contingut de l'element i el desa."

#. Tag: entry
#: index.docbook:1143
#, no-c-format
msgid "-r revision -o &lt;outputfile&gt; (output is required!)"
msgstr "-r revision -o &lt;fitxer_sortida&gt; (la sortida és requerida!)"

#. Tag: entry
#: index.docbook:1146
#, no-c-format
