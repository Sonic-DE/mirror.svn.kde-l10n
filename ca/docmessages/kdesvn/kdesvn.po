msgstr "-r revisió"

#. Tag: entry
#: index.docbook:1131
#, no-c-format
msgid "copy (or cp)"
msgstr "copy (o cp)"

#. Tag: entry
#: index.docbook:1132
#, no-c-format
msgid ""
"Copy item inside working copy or repository. If target isn't given, &kdesvn; "
"will prompt."
msgstr ""
"Copia un element dins de la còpia de treball o en el repositori. Si no "
"s'indica la destinació, el &kdesvn; us la demanarà."

#. Tag: entry
#: index.docbook:1136
#, no-c-format
msgid "move (or mv, rename)"
msgstr "move (o mv, rename)"

#. Tag: entry
#: index.docbook:1137
#, no-c-format
