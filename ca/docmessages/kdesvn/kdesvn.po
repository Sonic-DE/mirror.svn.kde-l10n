msgstr "Especifica la mida de les icones a la vista en llista principal."

#. Tag: entry
#: index.docbook:1329
#, no-c-format
msgid "Show file info"
msgstr "Mostra la informació del fitxer"

# skip-rule: punctuation-period-no
#. Tag: entry
#: index.docbook:1330
#, no-c-format
