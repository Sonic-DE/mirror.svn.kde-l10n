"Move/Rename item inside working copy or repository. If target isn't given, "
"&kdesvn; will prompt."
msgstr ""
"Mou/Reanomena un element dins de la còpia de treball o en el repositori. Si "
"no s'indica la destinació, el &kdesvn; us la demanarà."

#. Tag: entry
#: index.docbook:1141 index.docbook:1255
#, no-c-format
msgid "<entry>get</entry>"
msgstr "<entry>get</entry>"

# skip-rule: punctuation-period-no
