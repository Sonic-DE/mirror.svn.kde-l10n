#. Tag: title
#: resourceassignmentganttview.docbook:2
#, no-c-format
msgid "<title>Description</title>"
msgstr "<title>Descripció</title>"

#. Tag: para
#: resourceassignmentganttview.docbook:3
#, no-c-format
msgid ""
"The Resource Assignment Gantt View displays the scheduled task-resource "
"assignments in a Gantt chart."
msgstr ""
"La Vista de Gantt de l'assignació de recursos mostra les assignacions dels "
"recursos de tasques planificades en un gràfic de Gantt."

#. Tag: title
#: resourceassignmentganttview.docbook:24
#, no-c-format
msgid "Data"
msgstr "Dades"

#. Tag: para
#: resourceassignmentganttview.docbook:25
#, no-c-format
msgid "The following columns are displayed as default:"
msgstr "De manera predeterminada es mostren les columnes següents:"

#. Tag: guilabel
#: resourceassignmentganttview.docbook:32
#, no-c-format
msgid "Column"
msgstr "Columna"

#. Tag: guilabel
#: resourceassignmentganttview.docbook:33
#, no-c-format
msgid "<guilabel>Description</guilabel>"
msgstr "<guilabel>Descripció</guilabel>"

#. Tag: para
#: resourceassignmentganttview.docbook:39
#, no-c-format
msgid "Name"
msgstr "Nom"

#. Tag: para
#: resourceassignmentganttview.docbook:42
#, no-c-format
msgid "The name of the object (Resource group, resource, task)"
msgstr "El nom de l'objecte (grup de recursos, recurs, tasca)"

#. Tag: para
#: resourceassignmentganttview.docbook:47
#, no-c-format
msgid "Type"
msgstr "Tipus"

#. Tag: para
#: resourceassignmentganttview.docbook:50
#, no-c-format
msgid "Object type"
msgstr "Tipus d'objecte"

#. Tag: para
#: resourceassignmentganttview.docbook:55
#, no-c-format
msgid "Start Time"
msgstr "Temps de començament"

#. Tag: para
#: resourceassignmentganttview.docbook:58
#, no-c-format
msgid "The start of the assignment"
msgstr "L'inici de l'assignació"

#. Tag: para
#: resourceassignmentganttview.docbook:63
#, no-c-format
msgid "End Time"
msgstr "Temps de finalització"

#. Tag: para
#: resourceassignmentganttview.docbook:66
#, no-c-format
msgid "The end of the assignment"
msgstr "El final de l'assignació"

#. Tag: title
#: resourceassignmentganttview.docbook:73
#, no-c-format
msgid "Editing data"
msgstr "Editar les dades"

#. Tag: para
#: resourceassignmentganttview.docbook:74
#, no-c-format
msgid "The task description and progress can be edited using the context menu."
msgstr ""
"La descripció i el progrés de la tasca es poden editar utilitzant el menú "
"contextual."

#. Tag: title
#: resourceassignmentganttview.docbook:77
#, no-c-format
msgid "Configuration"
msgstr "Configurar"

#. Tag: para
#: resourceassignmentganttview.docbook:84
#, no-c-format
msgid ""
"Using the context menu, the view can be configured using the configure "
"dialog."
msgstr ""
"Utilitzant el menú contextual, la vista es podrà configurar utilitzant el "
"diàleg de configuració."

#. Tag: para
#: resourceassignmentganttview.docbook:84
#, no-c-format
msgid "The configure dialog enables you to select which columns to display."
msgstr "El diàleg de configuració permet seleccionar quines columnes mostrar."

#. Tag: phrase
#: resourceassignmentganttview.docbook:97
#, no-c-format
