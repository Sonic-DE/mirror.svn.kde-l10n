#. Tag: title
#: resourceassignmentview.docbook:2
#, no-c-format
msgid "<title>Description</title>"
msgstr "<title>Descripció</title>"

#. Tag: para
#: resourceassignmentview.docbook:3
#, no-c-format
msgid ""
"The Resource Assignment View displays the scheduled task-resource "
"assignments in a table."
msgstr ""
"La Vista de l'assignació de recursos mostra les assignacions dels recursos "
"de tasques planificades en una taula."

#. Tag: para
#: resourceassignmentview.docbook:5
#, no-c-format
msgid "This view can severely impact performance in large projects."
msgstr "Aquesta vista pot afectar greument el compliment en projectes grans."

#. Tag: title
#: resourceassignmentview.docbook:26
#, no-c-format
msgid "Data"
msgstr "Dades"

#. Tag: para
#: resourceassignmentview.docbook:27
#, no-c-format
msgid "The following columns are displayed as default:"
msgstr "De manera predeterminada es mostren les columnes següents:"

#. Tag: guilabel
#: resourceassignmentview.docbook:34
#, no-c-format
msgid "Column"
msgstr "Columna"

#. Tag: guilabel
#: resourceassignmentview.docbook:35
#, no-c-format
msgid "<guilabel>Description</guilabel>"
msgstr "<guilabel>Descripció</guilabel>"

#. Tag: para
#: resourceassignmentview.docbook:41
#, no-c-format
msgid "Name"
msgstr "Nom"

#. Tag: para
#: resourceassignmentview.docbook:44
#, no-c-format
msgid "The name of the object (Resource group, resource, task)"
msgstr "El nom de l'objecte (grup de recursos, recurs, tasca)"

#. Tag: para
#: resourceassignmentview.docbook:49
#, no-c-format
msgid "Total"
msgstr "Total"

#. Tag: para
#: resourceassignmentview.docbook:52
#, no-c-format
msgid "The total assignment for a resource"
msgstr "L'assignació total per a un recurs"

#. Tag: para
#: resourceassignmentview.docbook:57
#, no-c-format
msgid "Dates"
msgstr "Dates"

#. Tag: para
#: resourceassignmentview.docbook:60
#, no-c-format
msgid ""
"The total assignments for a resource per day and the assignments for the "
"resource per task."
msgstr ""
"Les assignacions totals per a un recurs per dia i les assignacions per al "
"recurs per tasca."

#. Tag: title
#: resourceassignmentview.docbook:67
#, no-c-format
msgid "Editing data"
msgstr "Editar les dades"

#. Tag: para
#: resourceassignmentview.docbook:68
#, no-c-format
msgid "The task description and progress can be edited using the context menu."
msgstr ""
"La descripció i el progrés de la tasca es poden editar utilitzant el menú "
"contextual."
