#. Tag: title
#: taskexecutionview.docbook:2
#, no-c-format
msgid "<title>Description</title>"
msgstr "<title>Descripció</title>"

#. Tag: para
#: taskexecutionview.docbook:3
#, no-c-format
msgid ""
"The Task Execution View is used to inspect task performance information."
msgstr ""
"La vista Execució de la tasca s'utilitza per a inspeccionar la informació "
"sobre el compliment de la tasca."

#. Tag: title
#: taskexecutionview.docbook:20
#, no-c-format
msgid "Data"
msgstr "Dades"

#. Tag: para
#: taskexecutionview.docbook:27
#, no-c-format
msgid ""
"Progress information can be edited in-line as described <link linkend="
"\"using-the-views\">here</link> or by using the task progress dialog."
msgstr ""
"La informació sobre el progrés es pot editar a la línia com es descriu <link "
"linkend=\"using-the-views\">aquí</link> o emprant el diàleg de progrés de la "
"tasca."

