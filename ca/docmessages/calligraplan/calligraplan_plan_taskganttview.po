#, no-c-format
msgid "Name"
msgstr "Nom"

#. Tag: para
#: taskganttview.docbook:43
#, no-c-format
msgid "The name of the task."
msgstr "El nom de la tasca."

#. Tag: para
#: taskganttview.docbook:48
#, no-c-format
msgid "Start Time"
msgstr "Temps de començament"

#. Tag: para
#: taskganttview.docbook:51
#, no-c-format
msgid "The scheduled start time."
msgstr "El temps de començament planificat."

#. Tag: para
#: taskganttview.docbook:56
#, no-c-format
msgid "End Time"
msgstr "Temps de finalització"

#. Tag: para
#: taskganttview.docbook:59
#, no-c-format
msgid "The scheduled end time."
msgstr "El temps de finalització planificat."

