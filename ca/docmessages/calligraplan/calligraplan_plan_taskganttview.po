#. Tag: title
#: taskganttview.docbook:2
#, no-c-format
msgid "<title>Description</title>"
msgstr "<title>Descripció</title>"

#. Tag: para
#: taskganttview.docbook:3
#, no-c-format
msgid "The Gantt view is used to show tasks in a timeline."
msgstr ""
"La vista de Gantt s'utilitza per a mostrar les tasques en una línia de temps."

#. Tag: phrase
#: taskganttview.docbook:14
#, no-c-format
msgid "<phrase>Gantt View</phrase>"
msgstr "<phrase>Vista de Gantt</phrase>"

#. Tag: para
#: taskganttview.docbook:17
#, no-c-format
msgid "<para>Gantt View</para>"
msgstr "<para>Vista de Gantt</para>"

#. Tag: title
#: taskganttview.docbook:23
#, no-c-format
msgid "Editing data"
msgstr "Editar les dades"

#. Tag: para
#: taskganttview.docbook:24
#, no-c-format
msgid "Task description and progress can be edited using the context menu."
msgstr ""
"La descripció i el progrés de la tasca es poden editar utilitzant el menú "
"contextual."

#. Tag: para
#: taskganttview.docbook:26
#, no-c-format
msgid "The following columns are displayed as default:"
msgstr "De manera predeterminada es mostren les columnes següents:"

