#. Tag: para
#: menu-commands.docbook:229
#, no-c-format
msgid "Renaming MP3/OGG Vorbis files based on their ID3 tags"
msgstr ""
"Reanomena els fitxers MP3/OGG Vorbis basant-se en les seves etiquetes ID3"

#. Tag: para
#: menu-commands.docbook:233
#, no-c-format
msgid "Setting access and modification dates"
msgstr "Estableix les dates d'accés i de modificació"

#. Tag: para
#: menu-commands.docbook:236
#, no-c-format
msgid "Changing permissions and file ownership"
msgstr "Canvia els permisos i el propietari del fitxer"

#. Tag: para
#: menu-commands.docbook:239
#, no-c-format
