#. Tag: title
#: useraction-xml.docbook:8
#, no-c-format
msgid "useractions.xml"
msgstr "useractions.xml"

#. Tag: para
#: useraction-xml.docbook:9
#, no-c-format
msgid ""
"This appendix gives several examples of <filename>useractions.xml</filename> "
"files. With this you can begin to discover the power of the <link linkend="
"\"useractions\">UserActions</link> and start learning how to use them. Once "
"you understand how to write UserActions you will find that &krusader; is an "
"even more powerful, customizable tool."
msgstr ""
"Aquest apèndix ofereix diversos exemples de fitxers <filename>useractions."
"xml</filename>. Amb aquests, podreu començar a descobrir la potència de les "
"<link linkend=\"useractions\">Accions d'usuari</link> i començar a aprendre "
"a emprar-les. Una vegada enteneu com escriure Accions d'usuari, trobareu que "
"el &krusader; és una eina encara més potent i personalitzable."

#. Tag: para
#: useraction-xml.docbook:15
#, no-c-format
msgid ""
"Please consider uploading your UserActions at <ulink url=\"https://store.kde."
"org\">store.kde.org</ulink> as we are collecting them. If your UserAction is "
"selected by us it will be shipped with &krusader; at the next release."
msgstr ""
"Considereu pujar les vostres Accions d'usuari a la <ulink url=\"https://"
"store.kde.org\">store.kde.org</ulink>, ja que les estem recopilant. Si "
"seleccionem la vostra Acció d'usuari, serà publicada amb el &krusader; a la "
"pròxima versió."

#. Tag: para
#: useraction-xml.docbook:20
#, no-c-format
msgid "Runs <command>uptime</command>"
msgstr "Executa <command>uptime</command>"

#. Tag: programlisting
#: useraction-xml.docbook:21
#, no-c-format
msgid ""
"&lt;!DOCTYPE KrusaderUserActions>\n"
" &lt;KrusaderUserActions>\n"
"  &lt;action name=\"uptime\" >\n"
"  &lt;title>Up-time&lt;/title>\n"
"  &lt;tooltip>tells how long since the computer has been booted&lt;/"
"tooltip>\n"
"  &lt;icon>clock&lt;/icon>\n"
"  &lt;category>information&lt;/category>\n"
"  &lt;description same_as=\"tooltip\" />\n"
"  &lt;command executionmode=\"collect_output\" >uptime&lt;/command>\n"
"  &lt;defaultshortcut>Alt+Ctrl+U&lt;/defaultshortcut>\n"
" &lt;/action>\n"
"&lt;/KrusaderUserActions>"
msgstr ""
"&lt;!DOCTYPE KrusaderUserActions&gt;\n"
" &lt;KrusaderUserActions&gt;\n"
"  &lt;action name=\"uptime\" &gt;\n"
"  &lt;title&gt;Up-time&lt;/title&gt;\n"
"  &lt;tooltip&gt;tells how long since the computer has been booted&lt;/"
"tooltip&gt;\n"
"  &lt;icon&gt;clock&lt;/icon&gt;\n"
"  &lt;category&gt;information&lt;/category&gt;\n"
"  &lt;description same_as=\"tooltip\" /&gt;\n"
"  &lt;command executionmode=\"collect_output\" &gt;uptime&lt;/command&gt;\n"
"  &lt;defaultshortcut&gt;Alt+Ctrl+U&lt;/defaultshortcut&gt;\n"
" &lt;/action&gt;\n"
"&lt;/KrusaderUserActions&gt;"

#. Tag: para
#: useraction-xml.docbook:24
#, no-c-format
msgid "Runs <command>ls -l</command>"
msgstr "Executa <command>ls -l</command>"

#. Tag: programlisting
#: useraction-xml.docbook:25
#, no-c-format
msgid ""
"&lt;!DOCTYPE KrusaderUserActions>\n"
" &lt;KrusaderUserActions>\n"
"  &lt;action name=\"ls -l\" >\n"
"  &lt;title>ls -l in current dir&lt;/title>\n"
"  &lt;description same_as=\"tooltip\" />\n"
"  &lt;command executionmode=\"collect_output\" >ls -l %aPath% %oPath%&lt;/"
"command>\n"
" &lt;/action>\n"
"&lt;/KrusaderUserActions>"
msgstr ""
"&lt;!DOCTYPE KrusaderUserActions&gt;\n"
" &lt;KrusaderUserActions&gt;\n"
"  &lt;action name=\"ls -l\" &gt;\n"
"  &lt;title&gt;ls -l in current dir&lt;/title&gt;\n"
"  &lt;description same_as=\"tooltip\" /&gt;\n"
"  &lt;command executionmode=\"collect_output\" &gt;ls -l %aPath% %oPath%&lt;/"
"command&gt;\n"
" &lt;/action&gt;\n"
"&lt;/KrusaderUserActions&gt;"

#. Tag: para
#: useraction-xml.docbook:28
#, no-c-format
msgid "Echo Placeholder"
msgstr "Mostra el marcador de posició"

#. Tag: programlisting
#: useraction-xml.docbook:29
#, no-c-format
msgid ""
"&lt;!DOCTYPE KrusaderUserActions>\n"
" &lt;KrusaderUserActions>\n"
"  &lt;action name=\"test_placeholder\" >\n"
"  &lt;title>Echo Placeholder&lt;/title>\n"
"  &lt;tooltip>Echo's the placeholder values&lt;/tooltip>\n"
"  &lt;category>Testing&lt;/category>\n"
"  &lt;description same_as=\"tooltip\" />\n"
"  &lt;command executionmode=\"collect_output\" onmultiplefiles=\"call_each\" "
">echo -e &quot;aPath %aPath()%  \\naCurrent: %aCurrent()%&quot;&lt;/"
"command>\n"
" &lt;/action>\n"
"&lt;/KrusaderUserActions>"
msgstr ""
"&lt;!DOCTYPE KrusaderUserActions&gt;\n"
" &lt;KrusaderUserActions&gt;\n"
"  &lt;action name=\"test_placeholder\" &gt;\n"
"  &lt;title&gt;Echo Placeholder&lt;/title&gt;\n"
"  &lt;tooltip&gt;Echo's the placeholder values&lt;/tooltip&gt;\n"
"  &lt;category&gt;Testing&lt;/category&gt;\n"
"  &lt;description same_as=\"tooltip\" /&gt;\n"
"  &lt;command executionmode=\"collect_output\" onmultiplefiles=\"call_each\" "
"&gt;echo -e &quot;aPath %aPath()%  \\naCurrent: %aCurrent()%&quot;&lt;/"
"command&gt;\n"
" &lt;/action&gt;\n"
"&lt;/KrusaderUserActions&gt;"

#. Tag: para
#: useraction-xml.docbook:32
#, no-c-format
msgid "This useraction copies current path and filename to clipboard:"
msgstr ""
"Aquesta acció d'usuari copia el camí i el nom del fitxer actual al porta-"
"retalls:"

#. Tag: programlisting
#: useraction-xml.docbook:33
#, no-c-format
msgid ""
"&lt;!DOCTYPE KrusaderUserActions>\n"
"&lt;KrusaderUserActions>\n"
" &lt;action name=\"clipboard current\" >\n"
"  &lt;title>Copy to Clipboard&lt;/title>\n"
"  &lt;tooltip>Copy to clipboard&lt;/tooltip>\n"
"  &lt;icon>klipper&lt;/icon>\n"
"  &lt;category>System&lt;/category>\n"
"  &lt;description>Copy current path and filename to clipboard&lt;/"
"description>\n"
"  &lt;command>%_Clipboard(&quot;%aCurrent%&quot;)%&lt;/command>\n"
"  &lt;defaultshortcut>Win+C&lt;/defaultshortcut>\n"
" &lt;/action>\n"
"&lt;/KrusaderUserActions>"
msgstr ""
"&lt;!DOCTYPE KrusaderUserActions&gt;\n"
"&lt;KrusaderUserActions&gt;\n"
" &lt;action name=\"clipboard current\" &gt;\n"
"  &lt;title&gt;Copy to Clipboard&lt;/title&gt;\n"
"  &lt;tooltip&gt;Copy to clipboard&lt;/tooltip&gt;\n"
"  &lt;icon&gt;klipper&lt;/icon&gt;\n"
"  &lt;category&gt;System&lt;/category&gt;\n"
"  &lt;description&gt;Copy current path and filename to clipboard&lt;/"
"description&gt;\n"
"  &lt;command&gt;%_Clipboard(&quot;%aCurrent%&quot;)%&lt;/command&gt;\n"
"  &lt;defaultshortcut&gt;Win+C&lt;/defaultshortcut&gt;\n"
" &lt;/action&gt;\n"
"&lt;/KrusaderUserActions&gt;"

#. Tag: para
#: useraction-xml.docbook:36
#, no-c-format
msgid ""
"Selects <literal role=\"extension\">.diff</literal> and <literal role="
"\"extension\">*.h</literal> in the active panel:"
msgstr ""
"Selecciona un <literal role=\"extension\">.diff</literal> i un <literal role="
"\"extension\">*.h</literal> al plafó actiu:"

#. Tag: programlisting
#: useraction-xml.docbook:37
#, no-c-format
msgid ""
"&lt;!DOCTYPE KrusaderUserActions>\n"
"&lt;KrusaderUserActions>\n"
" &lt;action name=\"test_select\" >\n"
"  &lt;title>Add selection *.diff and *.h&lt;/title>\n"
"  &lt;category>Selection&lt;/category>\n"
"  &lt;command>%aSelect(&quot;*.diff&quot;, &quot;add&quot;)% %aSelect(&quot;"
"*.h&quot;, &quot;add&quot;)%&lt;/command>\n"
" &lt;/action>\n"
"&lt;/KrusaderUserActions>"
msgstr ""
"&lt;!DOCTYPE KrusaderUserActions&gt;\n"
"&lt;KrusaderUserActions&gt;\n"
" &lt;action name=\"test_select\" &gt;\n"
"  &lt;title&gt;Add selection *.diff and *.h&lt;/title&gt;\n"
"  &lt;category&gt;Selection&lt;/category&gt;\n"
"  &lt;command&gt;%aSelect(&quot;*.diff&quot;, &quot;add&quot;)% "
"%aSelect(&quot;*.h&quot;, &quot;add&quot;)%&lt;/command&gt;\n"
" &lt;/action&gt;\n"
"&lt;/KrusaderUserActions&gt;"

#. Tag: para
#: useraction-xml.docbook:40
#, no-c-format
msgid "Active panel changes to <filename>mnt/floppy</filename> (bookmark):"
msgstr ""
"Canvis al plafó actiu a <filename>mnt/floppy</filename> (adreça d'interès):"

#. Tag: programlisting
#: useraction-xml.docbook:41
#, no-c-format
msgid ""
"&lt;!DOCTYPE KrusaderUserActions>\n"
"&lt;KrusaderUserActions>\n"
"&lt;action name=\"mnt/floppy bookmark\" >\n"
"  &lt;title>Jump to /mnt/floppy&lt;/title>\n"
"  &lt;category>Bookmarks&lt;/category>\n"
"  &lt;command>%aGoto(&quot;/mnt/floppy&quot;, &quot;yes&quot;)%&lt;/"
"command>\n"
" &lt;/action>\n"
"&lt;/KrusaderUserActions>"
msgstr ""
"&lt;!DOCTYPE KrusaderUserActions&gt;\n"
"&lt;KrusaderUserActions&gt;\n"
"&lt;action name=\"mnt/floppy bookmark\" &gt;\n"
"  &lt;title&gt;Jump to /mnt/floppy&lt;/title&gt;\n"
"  &lt;category&gt;Bookmarks&lt;/category&gt;\n"
"  &lt;command&gt;%aGoto(&quot;/mnt/floppy&quot;, &quot;yes&quot;)%&lt;/"
"command&gt;\n"
" &lt;/action&gt;\n"
"&lt;/KrusaderUserActions&gt;"

#. Tag: para
#: useraction-xml.docbook:44
#, no-c-format
msgid ""
"Select in the non-active panel, all filenames that are highlighted in the "
"active panel:"
msgstr ""
"Selecciona al plafó no actiu, tots els noms de fitxer que estan ressaltats "
"al plafó actiu:"

#. Tag: programlisting
#: useraction-xml.docbook:45
#, no-c-format
msgid ""
"&lt;!DOCTYPE KrusaderUserActions>\n"
"&lt;KrusaderUserActions>\n"
" &lt;action name=\"asdfasdf\" >\n"
"  &lt;title>Select in Other Panel&lt;/title>\n"
"  &lt;category>Selection&lt;/category>\n"
"  &lt;description>Select all filenames that are selected in the active "
"panel, also in the non-active panel&lt;/description>\n"
"  &lt;command>%oSelect(&quot;%aList(&quot;selected&quot;, &quot; &quot;, "
"&quot;Yes&quot;)%&quot;)%&lt;/command>\n"
" &lt;/action>\n"
"&lt;/KrusaderUserActions>"
msgstr ""
"&lt;!DOCTYPE KrusaderUserActions&gt;\n"
"&lt;KrusaderUserActions&gt;\n"
" &lt;action name=\"asdfasdf\" &gt;\n"
"  &lt;title&gt;Select in Other Panel&lt;/title&gt;\n"
"  &lt;category&gt;Selection&lt;/category&gt;\n"
"  &lt;description&gt;Select all filenames that are selected in the active "
"panel, also in the non-active panel&lt;/description&gt;\n"
"  &lt;command&gt;%oSelect(&quot;%aList(&quot;selected&quot;, &quot; &quot;, "
"&quot;Yes&quot;)%&quot;)%&lt;/command&gt;\n"
" &lt;/action&gt;\n"
"&lt;/KrusaderUserActions&gt;"

#. Tag: para
#: useraction-xml.docbook:48
#, no-c-format
msgid ""
"Make a backup of the current file/folder to <filename>foo.bak</filename> "
"into the current folder:"
msgstr ""
"Fa una còpia de seguretat del fitxer/carpeta actual a <filename>qualsevol."
"bak</filename> a dins de la carpeta actual:"

# skip-rule: k-Shift-1
#. Tag: programlisting
#: useraction-xml.docbook:49
#, no-c-format
msgid ""
"&lt;!DOCTYPE KrusaderUserActions>\n"
"&lt;KrusaderUserActions>\n"
" &lt;action name=\"backup current\" >\n"
"  &lt;title>Backup in Current Directory&lt;/title>\n"
"  &lt;tooltip>Backup in current folder&lt;/tooltip>\n"
"  &lt;icon>document-save-as&lt;/icon>\n"
"  &lt;category>System&lt;/category>\n"
"  &lt;description same_as=\"tooltip\" />\n"
"  &lt;command>%_Copy(&quot;%aCurrent%&quot;, &quot;%_Ask(&quot;new "
"name&quot;, &quot;%aCurrent%.bak&quot;)%&quot;)%&lt;/command>\n"
"  &lt;defaultshortcut>Shift+F5&lt;/defaultshortcut>\n"
" &lt;/action>\n"
"&lt;/KrusaderUserActions>"
msgstr ""
"&lt;!DOCTYPE KrusaderUserActions&gt;\n"
"&lt;KrusaderUserActions&gt;\n"
" &lt;action name=\"backup current\" &gt;\n"
"  &lt;title&gt;Backup in Current Directory&lt;/title&gt;\n"
"  &lt;tooltip&gt;Backup in current folder&lt;/tooltip&gt;\n"
"  &lt;icon&gt;document-save-as&lt;/icon&gt;\n"
"  &lt;category&gt;System&lt;/category&gt;\n"
"  &lt;description same_as=\"tooltip\" /&gt;\n"
"  &lt;command&gt;%_Copy(&quot;%aCurrent%&quot;, &quot;%_Ask(&quot;new "
"name&quot;, &quot;%aCurrent%.bak&quot;)%&quot;)%&lt;/command&gt;\n"
"  &lt;defaultshortcut&gt;Shift+F5&lt;/defaultshortcut&gt;\n"
" &lt;/action&gt;\n"
"&lt;/KrusaderUserActions&gt;"

