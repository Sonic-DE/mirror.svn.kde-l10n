#. Tag: para
#: useraction-xml.docbook:56
#, no-c-format
msgid "Sets the selected picture as wallpaper:"
msgstr "Estableix la imatge seleccionada com a fons de pantalla:"

#. Tag: programlisting
#: useraction-xml.docbook:57
#, no-c-format
msgid ""
