#, no-c-format
msgid "Opens <link linkend=\"synchronizer\">Synchronizer</link>:"
msgstr "Obre el <link linkend=\"synchronizer\">Sincronitzador</link>:"

#. Tag: programlisting
#: useraction-xml.docbook:69
#, no-c-format
msgid ""
"&lt;!DOCTYPE KrusaderUserActions>\n"
"&lt;KrusaderUserActions>\n"
" &lt;action name=\"synchronizer\" >\n"
"  &lt;title>Synchronizer&lt;/title>\n"
"  &lt;command>%_Sync(&quot;Sync 2&quot;)%&lt;/command>\n"
" &lt;/action>\n"
"&lt;/KrusaderUserActions>"
msgstr ""
"&lt;!DOCTYPE KrusaderUserActions&gt;\n"
"&lt;KrusaderUserActions&gt;\n"
" &lt;action name=\"synchronizer\" &gt;\n"
"  &lt;title&gt;Synchronizer&lt;/title&gt;\n"
"  &lt;command&gt;%_Sync(&quot;Sync 2&quot;)%&lt;/command&gt;\n"
" &lt;/action&gt;\n"
"&lt;/KrusaderUserActions&gt;"
