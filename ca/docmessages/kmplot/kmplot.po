#. Tag: term
#: index.docbook:872
#, no-c-format
msgid ""
"max(x<subscript>1</subscript>,x<subscript>2</subscript>,...,x<subscript>n</"
"subscript>)"
msgstr ""
"max(x<subscript>1</subscript>,x<subscript>2</subscript>,...,x<subscript>n</"
"subscript>)"

#. Tag: para
#: index.docbook:873
#, no-c-format
msgid ""
"Returns the maximum of the set of numbers {x<subscript>1</subscript>,"
"x<subscript>2</subscript>,...,x<subscript>n</subscript>}."
msgstr ""
"Retorna el màxim del conjunt de números {x<subscript>1</subscript>,"
"x<subscript>2</subscript>,...,x<subscript>n</subscript>}."

#. Tag: term
#: index.docbook:877
#, no-c-format
msgid ""
"mod(x<subscript>1</subscript>,x<subscript>2</subscript>,...,x<subscript>n</"
"subscript>)"
msgstr ""
"mod(x<subscript>1</subscript>,x<subscript>2</subscript>,...,x<subscript>n</"
"subscript>)"

#. Tag: para
