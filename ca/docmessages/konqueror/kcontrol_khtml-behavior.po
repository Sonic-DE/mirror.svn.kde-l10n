#. Tag: title
#: index.docbook:10 index.docbook:28
#, no-c-format
msgid "Web Browsing"
msgstr "Navegació Web"

#. Tag: author
#: index.docbook:12
#, no-c-format
msgid "&Krishna.Tateneni; &Krishna.Tateneni.mail;"
msgstr "&Krishna.Tateneni; &Krishna.Tateneni.mail;"

#. Tag: trans_comment
#: index.docbook:13
#, no-c-format
msgid "ROLES_OF_TRANSLATORS"
msgstr "&traductor.Antoni.Bella;"

#. Tag: date
#: index.docbook:16
#, no-c-format
msgid "2019-11-04"
msgstr "4 de novembre de 2019"

#. Tag: releaseinfo
#: index.docbook:17
#, no-c-format
msgid "Applications 19.12"
msgstr "Aplicacions 19.12"

#. Tag: keyword
#: index.docbook:20
#, no-c-format
