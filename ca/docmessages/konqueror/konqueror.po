msgstr "Us permet activar o desactivar l'ús de Galetes en el &konqueror;."

#. Tag: guimenuitem
#: index.docbook:2009
#, no-c-format
msgid "<guimenuitem>Plugins</guimenuitem>"
msgstr "<guimenuitem>Connectors</guimenuitem>"

#. Tag: para
#: index.docbook:2010
#, no-c-format
msgid ""
"Allows you to turn the use of the &konqueror; plugins you have installed on "
"or off."
msgstr ""
"Us permet activar o desactivar l'ús dels connectors que tingueu instal·lats "
"en el &konqueror;."

#. Tag: guimenuitem
#: index.docbook:2014
#, no-c-format
msgid "Autoload Images"
msgstr "Carrega automàticament les imatges"

#. Tag: para
#: index.docbook:2015
#, no-c-format
