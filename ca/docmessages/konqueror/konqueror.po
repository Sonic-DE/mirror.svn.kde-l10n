msgstr ""
"Us permet activar o desactivar la càrrega d'imatges en les pàgines web."

#. Tag: guimenuitem
#: index.docbook:2019
#, no-c-format
msgid "Enable Proxy"
msgstr "Habilita el servidor intermediari"

#. Tag: para
#: index.docbook:2020
#, no-c-format
msgid ""
