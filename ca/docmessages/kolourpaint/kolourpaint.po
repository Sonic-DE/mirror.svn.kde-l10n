msgid "<link linkend=\"image-clear\">Clear</link>"
msgstr "<link linkend=\"image-clear\">Neteja</link>"

#. Tag: link
#: index.docbook:1085
#, no-c-format
msgid "<link linkend=\"image-emboss\">Emboss</link>"
msgstr "<link linkend=\"image-emboss\">Relleu</link>"

#. Tag: link
#: index.docbook:1086
#, no-c-format
msgid "<link linkend=\"image-flatten\">Flatten</link>"
msgstr "<link linkend=\"image-flatten\">Aplana</link>"

#. Tag: link
#: index.docbook:1087
#, no-c-format
msgid "<link linkend=\"image-flip\">Flip (upside down)</link>"
msgstr "<link linkend=\"image-flip\">Inverteix (capgirada)</link>"

#. Tag: link
#: index.docbook:1088
#, no-c-format
msgid "<link linkend=\"image-invert\">Invert</link>"
