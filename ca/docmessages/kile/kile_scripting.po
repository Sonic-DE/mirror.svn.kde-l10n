#, no-c-format
msgid "This widget contains six icons, which offer different tasks:"
msgstr "Aquest giny conté sis icones, les quals ofereixen tasques diferents:"

#. Tag: para
#: scripting.docbook:41
#, no-c-format
msgid "Run the selected script."
msgstr "Executa l'script seleccionat."

#. Tag: para
#: scripting.docbook:42
#, no-c-format
msgid "Create a new script."
msgstr "Crea un script nou."

#. Tag: para
#: scripting.docbook:43
#, no-c-format
