msgstr "<screeninfo>El plafó Crear scripts a la barra lateral</screeninfo>"

#. Tag: phrase
#: scripting.docbook:32
#, no-c-format
msgid "<phrase>Scripting panel in the sidebar</phrase>"
msgstr "<phrase>El plafó Crear scripts a la barra lateral</phrase>"

#. Tag: para
