#, no-c-format
msgid "attackOne.png"
msgstr "attackOne.png"

#. Tag: entry
#: index.docbook:555
#, no-c-format
msgid "Chooses to start an attack with one army."
msgstr "Tria iniciar un atac amb un batalló."

#. Tag: filename
#: index.docbook:559
#, no-c-format
msgid "attackTwo.png"
msgstr "attackTwo.png"

#. Tag: entry
#: index.docbook:560
#, no-c-format
msgid "Chooses to start an attack with two armies."
msgstr "Tria iniciar un atac amb dos batallons."

#. Tag: filename
#: index.docbook:564
#, no-c-format
msgid "attackThree.png"
msgstr "attackThree.png"

#. Tag: entry
#: index.docbook:565
#, no-c-format
msgid "Chooses to start an attack with three armies."
msgstr "Tria iniciar un atac amb tres batallons."

#. Tag: filename
#: index.docbook:569
#, no-c-format
msgid "defendOne.png"
msgstr "defendOne.png"

#. Tag: entry
#: index.docbook:570
#, no-c-format
msgid "Chooses to defend an attacked country with one army."
msgstr "Tria defensar un país atacat amb un batalló."

#. Tag: filename
#: index.docbook:574
#, no-c-format
msgid "defendTwo.png"
msgstr "defendTwo.png"

#. Tag: entry
#: index.docbook:575
#, no-c-format
msgid "Chooses to defend an attacked country with two armies."
msgstr "Tria defensar un país atacat amb dos batallons."

#. Tag: filename
#: index.docbook:579
#, no-c-format
msgid "moveArmies.png"
msgstr "moveArmies.png"

#. Tag: entry
#: index.docbook:580
#, no-c-format
msgid ""
"Chooses to start the moving of armies between two countries (last action in "
"the turn)."
msgstr ""
"Tria iniciar el moviment dels batallons entre dos països (última acció en el "
"torn)."

#. Tag: title
