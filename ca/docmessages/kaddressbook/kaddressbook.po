#, no-c-format
msgid ""
"<phrase>A screenshot of &kaddressbook;'s <quote>Contact List</quote> context "
"menu.</phrase>"
msgstr ""
"<phrase>Una captura de pantalla del menú contextual a la «Llista de "
"contactes» del &kaddressbook;.</phrase>"

#. Tag: para
