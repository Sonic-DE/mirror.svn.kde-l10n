msgid "<guilabel>Stop</guilabel>"
msgstr "<guilabel>Atura</guilabel>"

#. Tag: para
#: index.docbook:7017
#, no-c-format
msgid "Stops all playback in progress."
msgstr "Atura la reproducció en curs."

#. Tag: guilabel
#: index.docbook:7025
#, no-c-format
msgid "Stop after current Track"
msgstr "Atura després de la peça actual"

#. Tag: para
#: index.docbook:7028
#, no-c-format
msgid ""
"Waits until the current track ends before stopping the playback. This is "
"useful when using a playlist."
msgstr ""
"Espera fins que acabi la peça actual abans d'aturar la reproducció. Això és "
"útil quan s'utilitza una llista de reproducció."

#. Tag: guilabel
#: index.docbook:7036
#, no-c-format
msgid "<guilabel>Next Track</guilabel>"
msgstr "<guilabel>Peça següent</guilabel>"

#. Tag: para
#: index.docbook:7039
#, no-c-format
msgid "Skips playback to the next media file in your playlist."
msgstr ""
