msgstr "<guilabel>Actualitza la col·lecció</guilabel>"

#. Tag: para
#: index.docbook:7560
#, no-c-format
msgid "Checks the tracks in your collection and updates the database."
msgstr "Comprova les peces de la col·lecció i actualitza la base de dades."

#. Tag: guilabel
#: index.docbook:7565
#, no-c-format
msgid "Synchronize Statistics.."
msgstr "Sincronitza les estadístiques..."

#. Tag: para
#: index.docbook:7568
