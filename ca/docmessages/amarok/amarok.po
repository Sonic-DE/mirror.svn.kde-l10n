#: index.docbook:1626 index.docbook:3095 index.docbook:3160 index.docbook:3268
#: index.docbook:3544 index.docbook:3942 index.docbook:4534 index.docbook:4713
#: index.docbook:5020 index.docbook:5106 index.docbook:5264 index.docbook:5451
#: index.docbook:5699 index.docbook:6891 index.docbook:6974 index.docbook:7260
#: index.docbook:7519 index.docbook:7596 index.docbook:7721 index.docbook:7822
#: index.docbook:8345
#, no-c-format
msgid "<entry>Description</entry>"
msgstr "<entry>Descripció</entry>"

#. Tag: guilabel
#: index.docbook:1269
#, no-c-format
msgid "Bookmark Media Sources View"
msgstr "Anota la vista d'orígens de suports a les adreces d'interès"

#. Tag: para
#: index.docbook:1272
#, no-c-format
msgid ""
"Adds the current <emphasis>Media Sources</emphasis> view configuration to "
"the bookmark list."
msgstr ""
"Afegeix la configuració de vista actual d'<emphasis>Orígens de suports</"
"emphasis> a la llista d'adreces d'interès."

#. Tag: guilabel
#: index.docbook:1277
#, no-c-format
msgid "Copy Current View Bookmark to Clipboard"
msgstr "Copia les adreces d'interès de la vista actual al porta-retalls"

#. Tag: para
#: index.docbook:1280
#, no-c-format
msgid "Copies bookmark to the system clipboard."
msgstr "Copia l'adreça d'interès al porta-retalls del sistema."

#. Tag: guilabel
#: index.docbook:1285 index.docbook:7525
#, no-c-format
msgid "<guilabel>Bookmark Manager</guilabel>"
msgstr "<guilabel>Gestor d'adreces d'interès</guilabel>"

#. Tag: para
#: index.docbook:1288
#, no-c-format
msgid ""
"Displays a list of all available bookmarks in a new window, with options to "
"edit them."
msgstr ""
"Mostra una llista de totes les adreces d'interès disponibles en una finestra "
"nova, amb opcions per a editar-les."

#. Tag: emphasis
#: index.docbook:1293
#, no-c-format
msgid "Bookmark List"
msgstr "Llista d'adreces d'interès"

#. Tag: para
#: index.docbook:1296
#, no-c-format
msgid "Lists all your bookmarks for faster selection."
msgstr "Llista totes les adreces d'interès per a una selecció més ràpida."

#. Tag: title
#: index.docbook:1304
#, no-c-format
msgid "<title>Local Music</title>"
msgstr "<title>Música local</title>"

#. Tag: para
#: index.docbook:1305
#, no-c-format
msgid ""
"Displays the music from your default collection folder, sorted as specified. "
"Both the regular (non-merged) view and <emphasis>Merged</emphasis> view of "
"the same collection are shown, with the same sorting. Click the icon "
"<inlinemediaobject> <imageobject> <imagedata fileref=\"Icon-view-list-tree."
"png\" format=\"PNG\"/> </imageobject> </inlinemediaobject> to toggle between "
"views."
msgstr ""
"Mostra la música de la vostra carpeta de col·leccions predeterminada, "
"ordenada com s'especifica. Es mostren tant la vista normal (no fusionada) "
"com la <emphasis>Fusionada</emphasis> de la mateixa col·lecció, amb la "
"mateixa ordenació. Feu clic a la icona <inlinemediaobject> <imageobject> "
"<imagedata fileref=\"Icon-view-list-tree.png\" format=\"PNG\"/> </"
"imageobject> </inlinemediaobject> per a commutar entre les vistes."

#. Tag: phrase
#: index.docbook:1321
#, no-c-format
msgid "<phrase>Regular non-merged view</phrase>"
msgstr "<phrase>Vista no fusionada normal</phrase>"

#. Tag: para
#: index.docbook:1324
#, no-c-format
msgid "<para>Regular non-merged view</para>"
msgstr "<para>Vista no fusionada normal</para>"

#. Tag: phrase
#: index.docbook:1338
#, no-c-format
msgid "<phrase>Merged view</phrase>"
msgstr "<phrase>Vista fusionada</phrase>"

#. Tag: para
#: index.docbook:1341
#, no-c-format
msgid "<para>Merged view</para>"
msgstr "<para>Vista fusionada</para>"

#. Tag: para
#: index.docbook:1350
#, no-c-format
msgid ""
"Click the icon <inlinemediaobject> <imageobject> <imagedata fileref=\"Icon-"
"preferences-other.png\" format=\"PNG\"/> </imageobject> </inlinemediaobject> "
"to change the sorting criteria, using the following menu:"
msgstr ""
"Feu clic a la icona <inlinemediaobject> <imageobject> <imagedata fileref="
"\"Icon-preferences-other.png\" format=\"PNG\"/> </imageobject> </"
"inlinemediaobject> per a canviar els criteris d'ordenació, utilitzant el "
"menú següent:"

#. Tag: guilabel
#: index.docbook:1377
#, no-c-format
msgid "Artist/Album"
msgstr "Artista/Àlbum"

#. Tag: para
#: index.docbook:1380
#, no-c-format
msgid ""
"Shows the collection sorted by artists and album names. If two entries have "
"the same artist they will be sorted by album."
msgstr ""
"Mostra la col·lecció ordenada per noms d'artistes i d'àlbums. Si dues "
"entrades tenen el mateix artista, s'ordenaran per àlbum."

#. Tag: guilabel
#: index.docbook:1385
#, no-c-format
msgid "Album/Artist"
msgstr "Àlbum/Artista"

#. Tag: para
#: index.docbook:1388
#, no-c-format
msgid "Shows the collection sorted by album and artist names."
msgstr "Mostra la col·lecció ordenada per noms d'àlbums i artistes."

#. Tag: guilabel
#: index.docbook:1393
#, no-c-format
msgid "Genre/Artist"
msgstr "Gènere/Artista"

#. Tag: para
#: index.docbook:1396
#, no-c-format
msgid ""
"Shows the collection sorted by genre and artist. If two entries have the "
"same genre they will be sorted by artist."
msgstr ""
"Mostra la col·lecció ordenada per gènere i artista. Si dues entrades tenen "
"el mateix gènere, s'ordenaran per artista."

#. Tag: guilabel
#: index.docbook:1401
#, no-c-format
msgid "Genre/Artist/Album"
msgstr "Gènere/Artista/Àlbum"

#. Tag: para
#: index.docbook:1404
#, no-c-format
msgid ""
"Shows the collection sorted by genre, artist and album. If two entries have "
"the same artist they will be sorted by album."
msgstr ""
"Mostra la col·lecció ordenada per gènere, artista i àlbum. Si dues entrades "
"tenen el mateix artista, s'ordenaran per àlbum."

#. Tag: guilabel
#: index.docbook:1409
#, no-c-format
msgid "Levels"
msgstr "Nivells"

#. Tag: para
#: index.docbook:1412
#, no-c-format
msgid "Designate the window cascade order of your elements."
msgstr "Designa l'ordre en cascada de les finestres dels elements."

#. Tag: guilabel
#: index.docbook:1417
#, no-c-format
msgid "Show Years"
msgstr "Mostra els anys"

#. Tag: para
#: index.docbook:1420
#, no-c-format
msgid "Check if you want years to be displayed."
msgstr "Marqueu-ho si voleu que es mostrin els anys."

#. Tag: guilabel
#: index.docbook:1425
#, no-c-format
msgid "Show Track Numbers"
msgstr "Mostra el nombre de la peça"

#. Tag: para
#: index.docbook:1428
#, no-c-format
msgid "Check if you want track numbers to be displayed."
msgstr "Marqueu-ho si voleu que es mostrin els números de les peces."

#. Tag: guilabel
#: index.docbook:1433
#, no-c-format
msgid "Show Cover Art"
msgstr "Mostra la caràtula"

#. Tag: para
#: index.docbook:1436
#, no-c-format
msgid "Check if you want cover art to be displayed."
msgstr "Marqueu-ho si voleu que es mostri la caràtula."

#. Tag: title
#: index.docbook:1443
#, no-c-format
msgid "<title>Internet</title>"
msgstr "<title>Internet</title>"

#. Tag: para
#: index.docbook:1444
#, no-c-format
msgid ""
"Shows your internet collection, added and configured in "
"<menuchoice><guimenu>Settings</guimenu><guisubmenu>Configure Amarok...</"
"guisubmenu><guimenuitem>Plugins</guimenuitem></menuchoice>. More <link "
"linkend=\"internet-services\">about configuring Internet Services</link>. "
"There are some scripts which add Internet Services; see <link linkend="
"\"scripts\">Scripts</link> for more information."
msgstr ""
"Mostra la vostra col·lecció d'Internet, afegida i configurada a "
"<menuchoice><guimenu>Arranjament</guimenu><guisubmenu>Configura l'Amarok...</"
"guisubmenu><guimenuitem>Connectors</guimenuitem></menuchoice>. Més <link "
"linkend=\"internet-services\">sobre la configuració dels serveis d'Internet</"
"link>. Hi ha alguns scripts que afegeixen serveis d'Internet; vegeu <link "
"linkend=\"scripts\">Scripts</link> per a més informació."

#. Tag: guilabel
#: index.docbook:1458
#, no-c-format
msgid "Cool Streams"
msgstr "Fluxos de qualitat"

#. Tag: para
#: index.docbook:1461
#, no-c-format
msgid "Lists quality radio streams."
msgstr "Llista els fluxos de ràdio de qualitat."

#. Tag: guilabel
#: index.docbook:1466 index.docbook:3189
#, no-c-format
msgid "Jamendo"
msgstr "Jamendo"

#. Tag: para
#: index.docbook:1469
#, no-c-format
msgid ""
"Connects with <guilabel>Jamendo</guilabel>, a growing free music database."
msgstr ""
"Connecta amb <guilabel>Jamendo</guilabel>, una base de dades de música "
"lliure en creixement."

#. Tag: guilabel
#: index.docbook:1474 index.docbook:3200
#, no-c-format
msgid "Last.fm"
msgstr "Last.fm"

#. Tag: para
#: index.docbook:1477
#, no-c-format
msgid ""
"Connects with <guilabel>Last.fm</guilabel>; embedding the site experience in "
"&amarok;."
msgstr ""
"Connecta amb <guilabel>Last.fm</guilabel>; incrusta l'experiència del lloc "
"en l'&amarok;."

#. Tag: guilabel
#: index.docbook:1482
#, no-c-format
msgid "Librivox.org"
msgstr "Librivox.org"

#. Tag: para
#: index.docbook:1485
#, no-c-format
msgid ""
"Connects with <guilabel>Librivox</guilabel>, an extensive collection of free "
"audio books."
msgstr ""
"Connecta amb <guilabel>Librivox</guilabel>, una extensa col·lecció "
"d'audiollibres gratuïts."

#. Tag: guilabel
#: index.docbook:1490
#, no-c-format
msgid "Magnatune.com"
msgstr "Magnatune.com"

#. Tag: para
#: index.docbook:1493
#, no-c-format
msgid ""
"Connects with <guilabel>Magnatune</guilabel>, a great online music store."
msgstr ""
"Connecta amb <guilabel>Magnatune</guilabel>, una gran botiga de música en "
"línia."

#. Tag: guilabel
#: index.docbook:1498 index.docbook:3222
#, no-c-format
msgid "MP3 Music Store"
msgstr "Botiga de música MP3"

#. Tag: para
#: index.docbook:1501
#, no-c-format
msgid ""
"Connects with <guilabel>Amazon MP3 Store</guilabel>, an online music store."
msgstr ""
"Connecta amb <guilabel>Amazon MP3 Store</guilabel>, una botiga de música en "
"línia."

#. Tag: guilabel
#: index.docbook:1506 index.docbook:3244
#, no-c-format
msgid "Podcast Directory"
msgstr "Directori de pòdcasts"

#. Tag: para
#: index.docbook:1509
#, no-c-format
msgid ""
"Shows a large list of podcasts. If you choose to subscribe, the podcast menu "
"will be automatically updated."
msgstr ""
"Mostra una gran llista de pòdcasts. Si opteu per subscriure-us, el menú "
"pòdcast s'actualitzarà automàticament."

#. Tag: para
#: index.docbook:1517
#, no-c-format
msgid "Media Sources Playlists menu:"
msgstr "Menú de llistes de reproducció d'orígens de suport:"

#. Tag: guilabel
#: index.docbook:1544
#, no-c-format
msgid "<guilabel>Dynamic Playlists</guilabel>"
msgstr "<guilabel>Llistes de reproducció dinàmiques</guilabel>"

#. Tag: para
#: index.docbook:1547
#, no-c-format
msgid ""
"Dynamically updating parameter-based playlist; more on this <link linkend="
"\"dynamic-playlists\">here</link>."
msgstr ""
"Llista de reproducció basada en paràmetres actualitzada dinàmicament; més "
"sobre això <link linkend=\"dynamic-playlists\">aquí</link>."

#. Tag: guilabel
#: index.docbook:1552
#, no-c-format
msgid "<guilabel>Saved Playlists</guilabel>"
msgstr "<guilabel>Llistes de reproducció desades</guilabel>"

#. Tag: para
#: index.docbook:1555
#, no-c-format
msgid ""
"Saved and imported playlists; more on this <link linkend=\"saved-playlists"
"\">here</link>."
msgstr ""
"Llistes de reproducció desades i importades; més sobre això <link linkend="
"\"saved-playlists\">aquí</link>."

#. Tag: guilabel
#: index.docbook:1560
#, no-c-format
msgid "Automated Playlist Generator"
msgstr "Generador automàtic de llistes de reproducció"

#. Tag: para
#: index.docbook:1563
#, no-c-format
msgid ""
"Creates playlists by specific criteria; more on this <link linkend="
"\"automatic-playlist-generator\">here</link>."
msgstr ""
"Crea llistes de reproducció segons criteris específics; més sobre això <link "
"linkend=\"automatic-playlist-generator\">aquí</link>."

#. Tag: title
#: index.docbook:1570
#, no-c-format
msgid "<title>Files</title>"
msgstr "<title>Fitxers</title>"

#. Tag: para
#: index.docbook:1571
#, no-c-format
msgid ""
"The &amarok; <emphasis>file browser</emphasis> helps you add music to your "
"collection, or simply play tracks from your hard drive."
msgstr ""
"El <emphasis>navegador de fitxers</emphasis> de l'&amarok; us ajuda a afegir "
"música a la vostra col·lecció, o simplement reproduir peces del vostre disc "
"dur."

#. Tag: para
#: index.docbook:1573
#, no-c-format
msgid ""
"Navigate through your files using the icon buttons: <inlinemediaobject> "
"<imageobject> <imagedata fileref=\"Icon-go-previous.png\" format=\"PNG\"/> </"
"imageobject> </inlinemediaobject> (previous), <inlinemediaobject> "
"<imageobject> <imagedata fileref=\"Icon-go-next.png\" format=\"PNG\"/> </"
"imageobject> </inlinemediaobject> (next), <inlinemediaobject> <imageobject> "
"<imagedata fileref=\"Icon-go-up.png\" format=\"PNG\"/> </imageobject> </"
"inlinemediaobject> (up), <inlinemediaobject> <imageobject> <imagedata "
"fileref=\"Icon-go-home.png\" format=\"PNG\"/> </imageobject> </"
"inlinemediaobject> (home), or <inlinemediaobject> <imageobject> <imagedata "
"fileref=\"Icon-folder-remote.png\" format=\"PNG\"/> </imageobject> </"
"inlinemediaobject> (places), very similar to a web browser menu; or click on "
"anywhere in the <emphasis>breadcrumbs</emphasis> to go directly to that "
"level."
msgstr ""
"Navegueu pels vostres fitxers utilitzant els botons d'icona: "
"<inlinemediaobject> <imageobject> <imagedata fileref=\"Icon-go-previous.png"
"\" format=\"PNG\"/> </imageobject> </inlinemediaobject> (anterior), "
"<inlinemediaobject> <imageobject> <imagedata fileref=\"Icon-go-next.png\" "
"format=\"PNG\"/> </imageobject> </inlinemediaobject> (següent), "
"<inlinemediaobject> <imageobject> <imagedata fileref=\"Icon-go-up.png\" "
"format=\"PNG\"/> </imageobject> </inlinemediaobject> (amunt), "
"<inlinemediaobject> <imageobject> <imagedata fileref=\"Icon-go-home.png\" "
"format=\"PNG\"/> </imageobject> </inlinemediaobject> (inici), o "
"<inlinemediaobject> <imageobject> <imagedata fileref=\"Icon-folder-remote.png"
"\" format=\"PNG\"/> </imageobject> </inlinemediaobject> (llocs), molt "
"similar al menú d'un navegador web; o feu clic a qualsevol lloc dels "
"<emphasis>fils d'Ariadna</emphasis> per a anar directament a aquest nivell."

#. Tag: para
#: index.docbook:1588
#, no-c-format
msgid ""
"If you would rather search or filter for something rather than navigating to "
"it, use the <emphasis>filter field</emphasis> to find the desired content. "
"Partially type the name of the file and it will be displayed as in this "
"example."
msgstr ""
"Si preferiu cercar o filtrar alguna cosa en lloc de navegar-hi, utilitzeu el "
"<emphasis>camp de filtre</emphasis> per a trobar el contingut desitjat. "
"Introduïu parcialment el nom del fitxer i es mostrarà com en aquest exemple."

#. Tag: title
#: index.docbook:1604
#, no-c-format
msgid "<title>Podcasts</title>"
msgstr "<title>Pòdcasts</title>"

#. Tag: para
#: index.docbook:1605
#, no-c-format
msgid ""
"Lists your subscribed podcasts; from here you can listen, organize, add, "
"import or unsubscribe podcasts."
msgstr ""
"Llista els pòdcasts subscrits; des d'aquí podeu escoltar, organitzar, "
"afegir, importar o cancel·lar la subscripció dels pòdcasts."

#. Tag: guilabel
#: index.docbook:1632
#, no-c-format
msgid "Add Podcast"
msgstr "Afegeix un pòdcast"

#. Tag: para
#: index.docbook:1635
#, no-c-format
msgid ""
"Add a podcast URL: <emphasis>RSS 1.0/2.0</emphasis> or <emphasis>Atom feed</"
"emphasis>."
msgstr ""
"Afegeix un URL de pòdcast: <emphasis>RSS 1.0/2.0</emphasis> o "
"<emphasis>canal Atom</emphasis>."

#. Tag: para
#: index.docbook:1643
#, no-c-format
msgid "Add a folder to the podcast navigation menu."
msgstr "Afegeix una carpeta al menú de navegació de pòdcasts."

#. Tag: guilabel
#: index.docbook:1648
#, no-c-format
msgid "Visible Sources"
msgstr "Orígens visibles"

#. Tag: para
#: index.docbook:1651
#, no-c-format
msgid "Selects what category of podcasts you can view."
msgstr "Selecciona quina categoria de pòdcasts podeu veure."

#. Tag: guilabel
#: index.docbook:1656
#, no-c-format
msgid "Merged View"
msgstr "Vista fusionada"

#. Tag: para
#: index.docbook:1659
#, no-c-format
msgid "Displays the podcasts in a merged or unmerged view."
msgstr "Mostra els pòdcasts en una vista fusionada o sense fusionar."

#. Tag: para
#: index.docbook:1667
#, no-c-format
msgid "Checks all podcasts for updates and downloads any available."
msgstr ""
"Marca tots els pòdcasts per a actualitzar i baixa tots els disponibles."

#. Tag: para
#: index.docbook:1675
#, no-c-format
msgid "Imports an OPML file from your hard drive."
msgstr "Importa un fitxer OPML del vostre disc dur."

#. Tag: title
#: index.docbook:1683
#, no-c-format
msgid "The Context pane"
msgstr "La subfinestra de context"

#. Tag: para
#: index.docbook:1684
#, no-c-format
msgid ""
"The <emphasis>Context</emphasis> pane is a panel to which you can add "
"various applets which offer information and media on the current music. A "
"connection to the Internet is required for the most useful use of these "
"little applications, which will fetch lyrics, information, photos, and even "
"guitar or bass tabs, depending on which applets you choose to display."
msgstr ""
"La subfinestra de <emphasis>Context</emphasis> és un plafó al qual podeu "
"afegir diverses miniaplicacions que ofereixen informació i multimèdia sobre "
"la música actual. Es requereix una connexió a Internet per a l'ús més útil "
"d'aquestes petites aplicacions, que obtindran lletres, informació, fotos, i "
"fins i tot tabulatures de guitarra o baix, depenent de les miniaplicacions "
"que trieu mostrar."

#. Tag: title
#: index.docbook:1686
#, no-c-format
msgid "Using the Context pane"
msgstr "Ús de la subfinestra de context"

#. Tag: phrase
#: index.docbook:1695
#, no-c-format
msgid "<phrase>Context pane when not playing</phrase>"
msgstr "<phrase>Subfinestra de context quan no es reprodueix</phrase>"

#. Tag: para
#: index.docbook:1698
#, no-c-format
msgid "<para>Context pane when not playing</para>"
msgstr "<para>Subfinestra de context quan no es reprodueix</para>"

#. Tag: para
#: index.docbook:1703
#, no-c-format
msgid ""
"Pictured is the <emphasis>Context</emphasis> pane when no track is playing. "
"If it is hidden, use <menuchoice><guimenu>View</"
"guimenu><guimenuitem>Context</guimenuitem></menuchoice> to display it. The "
"pane is divided in two parts:"
msgstr ""
"Hi ha dibuixada la subfinestra de <emphasis>Context</emphasis> quan no "
"s'està reproduint cap peça. Si està oculta, utilitzeu "
"<menuchoice><guimenu>Visualitza</guimenu><guimenuitem>Context</guimenuitem></"
"menuchoice> per a mostrar-la. La subfinestra es divideix en dues parts:"

#. Tag: para
#: index.docbook:1706
#, no-c-format
msgid ""
"The applet panel itself, where you can interact with some of the applets, "
"such as editing lyrics or changing settings."
msgstr ""
"El mateix plafó de miniaplicacions, on es pot interactuar amb algunes de les "
"miniaplicacions, com ara editar lletres o canviar de configuració."

#. Tag: para
#: index.docbook:1707
#, no-c-format
msgid ""
"The lower portion of the panel, where you can expand and collapse applets "
"and manipulate them in various ways once you click the <emphasis>Configure "
"Applets</emphasis> icon <inlinemediaobject> <imageobject> <imagedata fileref="
"\"Icon-configure.png\" format=\"PNG\"/> </imageobject> </inlinemediaobject>."
msgstr ""
"La part inferior del plafó, on podeu expandir i reduir miniaplicacions i "
"manipular-les de diverses maneres una vegada feu clic a la icona "
"<emphasis>Configura les miniaplicacions</emphasis> <inlinemediaobject> "
"<imageobject> <imagedata fileref=\"Icon-configure.png\" format=\"PNG\"/> </"
"imageobject> </inlinemediaobject>."

#. Tag: title
#: index.docbook:1709
#, no-c-format
msgid "Configuring Applets"
msgstr "Configuració de les miniaplicacions"

#. Tag: para
#: index.docbook:1723
#, no-c-format
msgid ""
"Once you click <inlinemediaobject> <imageobject> <imagedata fileref=\"Icon-"
"configure.png\" format=\"PNG\"/> </imageobject> </inlinemediaobject> in the "
"lower portion of the <emphasis>Context</emphasis> pane changes slightly; "
"each applet tab gets an <inlinemediaobject> <imageobject> <imagedata fileref="
"\"Icon-application-exit.png\" format=\"PNG\"/> </imageobject> </"
"inlinemediaobject> icon that you can click to remove it, and a list of "
"applets appear. To add new applet, simply click on the applet, and it will "
"appear in the pane, ready to be used. To change the applet display order, "
"click the tabs and drag them around the bar."
msgstr ""
"Un cop feu clic a <inlinemediaobject> <imageobject> <imagedata fileref="
"\"Icon-configure.png\" format=\"PNG\"/> </imageobject> </inlinemediaobject> "
"a la part inferior de la subfinestra <emphasis>Context</emphasis>, aquesta "
"canvia lleugerament; cada pestanya de la miniaplicació obté una icona "
"<inlinemediaobject> <imageobject> <imagedata fileref=\"Icon-application-exit."
"png\" format=\"PNG\"/> </imageobject> </inlinemediaobject> que podeu fer "
"clic per a eliminar-la, i apareixerà una llista de miniaplicacions. Per a "
"afegir una miniaplicació nova, simplement feu clic a la miniaplicació, i "
"apareixerà a la subfinestra, llesta per a ser utilitzada. Per a canviar "
"l'ordre de visualització de la miniaplicació, feu clic a les pestanyes i "
"arrossegueu-les al voltant de la barra."

#. Tag: title
#: index.docbook:1727
#, no-c-format
msgid "Applets"
msgstr "Miniaplicacions"

#. Tag: para
#: index.docbook:1728
#, no-c-format
msgid ""
"There are several applets available to dock in your <emphasis>Context</"
"emphasis> pane; below is a description of each."
msgstr ""
"Hi ha diverses miniaplicacions disponibles per a acoblar a la subfinestra "
"<emphasis>Context</emphasis>; a continuació hi ha una descripció de "
"cadascuna."

#. Tag: guilabel
#: index.docbook:1736
#, no-c-format
msgid "Applet"
msgstr "Miniaplicació"

#. Tag: guilabel
#: index.docbook:1739
#, no-c-format
msgid "<guilabel>Icon</guilabel>"
msgstr "<guilabel>Icona</guilabel>"

#. Tag: guilabel
#: index.docbook:1742
#, no-c-format
msgid "<guilabel>Description</guilabel>"
msgstr "<guilabel>Descripció</guilabel>"

#. Tag: guilabel
#: index.docbook:1747
#, no-c-format
msgid "Current Track"
msgstr "Peça actual"

#. Tag: para
#: index.docbook:1764
#, no-c-format
msgid ""
"Information about the current track. You may rate it by clicking on the "
"stars, add a position marker, or edit track metadata. When not playing, the "
"applet displays collection information and <emphasis>Recently Played Tracks</"
"emphasis>, which allows you to view the tracks and add them to the playlist."
msgstr ""
"Informació sobre la peça actual. Podeu valorar-la fent clic a les estrelles, "
"afegir un marcador de posició o editar les metadades de la peça. Quan no es "
"reprodueix, la miniaplicació mostra informació de la col·lecció i de les "
"<emphasis>Peces reproduïdes recentment</emphasis>, que us permet veure les "
"peces i afegir-les a la llista de reproducció."

#. Tag: guilabel
#: index.docbook:1769
#, no-c-format
msgid "Similar Artists"
msgstr "Artistes semblants"

#. Tag: para
#: index.docbook:1786
#, no-c-format
msgid ""
"Fetches artists similar to the currently playing one, with a short "
"description and options to find them in your collection, or on "
"<emphasis>Last.fm</emphasis>, and add to your current playlist."
msgstr ""
"Recupera artistes similars al que s'està reproduint actualment, amb una "
"descripció breu i opcions per a trobar-los a la vostra col·lecció, o a "
"<emphasis>Last.fm</emphasis>, i afegir a la vostra llista de reproducció "
"actual."

#. Tag: guilabel
#: index.docbook:1791
#, no-c-format
msgid "Upcoming Events"
msgstr "Esdeveniments pròxims"

# skip-rule: kct-locale
#. Tag: para
#: index.docbook:1808
#, no-c-format
msgid ""
"Displays upcoming events that involve the current artist or group. You can "
"set a venue locale to be watched by entering the applet settings and "
"narrowing it down under the Favorites section."
msgstr ""
"Mostra esdeveniments pròxims que impliquen l'artista o grup actual. Podeu "
"establir una ubicació de la seu que es veurà introduint la configuració de "
"la miniaplicació i reduint-la en la secció Preferits."

#. Tag: guilabel
#: index.docbook:1813
#, no-c-format
msgid "Wikipedia"
msgstr "Viquipèdia"

#. Tag: para
#: index.docbook:1819
#, no-c-format
msgid ""
"<emphasis>Wikipedia</emphasis> page for the track or artist. Also browse "
"other <emphasis>Wikipedia</emphasis> links, and use the back button to go "
"back to the starting page."
msgstr ""
"La pàgina de la <emphasis>Viquipèdia</emphasis> de la peça o l'artista. "
"També navegueu per altres enllaços de la <emphasis>Viquipèdia</emphasis>, i "
"utilitzeu el botó enrere per a tornar a la pàgina d'inici."

#. Tag: guilabel
#: index.docbook:1824
#, no-c-format
msgid "Labels"
msgstr "Etiquetes"

#. Tag: para
#: index.docbook:1841
#, no-c-format
msgid ""
"View, add and edit Labels for the current song. To add a Label just type it "
"in the text box and press &Enter;. Suggested Labels are user-contributed "
"tags from <emphasis>Last.fm</emphasis>."
msgstr ""
"Veure, afegir i editar etiquetes per a la cançó actual. Per a afegir una "
"etiqueta simplement escriviu-la en el quadre de text i premeu &Intro;. Les "
"etiquetes suggerides són les etiquetes introduïdes pels usuaris de "
"<emphasis>Last.fm</emphasis>."

#. Tag: guilabel
#: index.docbook:1846
#, no-c-format
msgid "Tabs"
msgstr "Tabulatures"

#. Tag: para
#: index.docbook:1863
#, no-c-format
msgid "Fetches and displays guitar and bass tabs (if available). Not editable."
msgstr ""
"Fetches i mostra les tabulatures de guitarra i baix (si estan disponibles). "
"No editable."

#. Tag: guilabel
#: index.docbook:1868
#, no-c-format
msgid "Lyrics"
msgstr "Lletres"

#. Tag: para
#: index.docbook:1885
#, no-c-format
msgid ""
"Displays the lyrics of the song that is currently playing. Add or change "
"lyrics scripts in the <link linkend=\"scripts\">Script Manager</link>."
msgstr ""
"Mostra la lletra de la cançó que s'està reproduint actualment. Afegeix o "
"canvia scripts de lletra en el <link linkend=\"scripts\">Gestor de scripts</"
"link>."

#. Tag: guilabel
#: index.docbook:1890 index.docbook:5278
#, no-c-format
msgid "Albums"
msgstr "Àlbums"

#. Tag: para
#: index.docbook:1907
#, no-c-format
msgid ""
"View albums from the current artist or band that are available in your local "
"Collection."
msgstr ""
"Veure els àlbums de l'artista o banda actual que estan disponibles a la "
"col·lecció local."

#. Tag: guilabel
#: index.docbook:1912
#, no-c-format
msgid "Photos"
msgstr "Fotos"

#. Tag: para
#: index.docbook:1929
#, no-c-format
msgid ""
"This applet queries <emphasis>Flickr.com</emphasis> for pictures of the band "
"you're listening to. Open the settings to add more keywords to your query "
"(&eg;: live in tokyo).&gt;"
msgstr ""
"Aquesta miniaplicació consulta a <emphasis>Flickr.com</emphasis> les imatges "
"de la banda que esteu escoltant. Obriu la configuració per a afegir més "
"paraules clau a la vostra consulta (&pex;: directe a tokyo).&gt;"

#. Tag: guilabel
#: index.docbook:1934
#, no-c-format
msgid "Analyzer"
msgstr "Analitzador"

#. Tag: para
#: index.docbook:1951
#, no-c-format
msgid ""
"This is a new applet in version 2.8. It provides basic audio visualizations. "
"A right click on it allows to configure the applet settings."
msgstr ""
"Aquesta és una miniaplicació nova a la versió 2.8. Proporciona "
"visualitzacions bàsiques d'àudio. Fent-hi un clic dret permet configurar els "
"paràmetres de la miniaplicació."

#. Tag: guilabel
#: index.docbook:1956
#, no-c-format
msgid "Info"
msgstr "Informació"

#. Tag: para
#: index.docbook:1973
#, no-c-format
msgid ""
"Information about the current media source. Allows you to navigate through "
"internet services such as <emphasis>Librivox.org</emphasis>."
msgstr ""
"Informació sobre l'origen actual de suports. Permet navegar a través de "
"serveis d'Internet com ara <emphasis>Librivox.org</emphasis>."

#. Tag: para
#: index.docbook:1982
#, no-c-format
msgid ""
"&amarok; offers excellent playlist management for all of your songs and "
"other audio files. Here you see a short playlist, sorted by album."
msgstr ""
"L'&amarok; ofereix una gestió excel·lent de la llista de reproducció per a "
"totes les vostres cançons i altres fitxers d'àudio. Aquí veieu una llista de "
"reproducció curta, ordenada per àlbum."

#. Tag: phrase
#: index.docbook:1992
#, no-c-format
msgid "<phrase>&amarok; Playlist pane</phrase>"
msgstr "<phrase>Subfinestra de la llista de reproducció de l'&amarok;</phrase>"

#. Tag: para
#: index.docbook:1995
#, no-c-format
msgid "<para>&amarok; Playlist pane</para>"
msgstr "<para>Subfinestra de la llista de reproducció de l'&amarok;</para>"

#. Tag: title
#: index.docbook:2000
#, no-c-format
msgid "Basic Playlist Manipulation"
msgstr "Manipulació bàsica de la llista de reproducció"

#. Tag: phrase
#: index.docbook:2009
#, no-c-format
msgid "<phrase>Playlist Pop Up Dropper menu</phrase>"
msgstr ""
"<phrase>Menú del comptagotes emergent de la llista de reproducció</phrase>"

#. Tag: para
#: index.docbook:2012
#, no-c-format
msgid "<para>Playlist Pop Up Dropper menu</para>"
msgstr "<para>Menú del comptagotes emergent de la llista de reproducció</para>"

#. Tag: para
#: index.docbook:2017
#, no-c-format
msgid ""
"Adding music to your playlist is a simple drag-and-drop, right-click or "
"double-click operation."
msgstr ""
"Afegir música a la vostra llista de reproducció és una simple operació "
"d'arrossegar i deixar anar, fer clic dret o fer doble clic."

#. Tag: para
#: index.docbook:2019
#, no-c-format
msgid ""
"Two playlist-related options will be shown in the <emphasis>Context</"
"emphasis> pane in the center (the <emphasis>Pop-Up Dropper</emphasis>, or "
"<emphasis>PUD</emphasis>) when performing a drag-and-drop operation to add "
"music to your current playlist. You can either use <guilabel>Add to "
"Playlist</guilabel>, which will append the songs you have selected, or "
"<guilabel>Replace Playlist</guilabel>, which will replace all the contents "
"of the playlist with your selection."
msgstr ""
"Dues opcions relacionades amb la llista de reproducció es mostraran a la "
"subfinestra <emphasis>Context</emphasis> al centre (el <emphasis>Comptagotes "
"emergent</emphasis>, o <emphasis>PUD</emphasis>) en realitzar una operació "
"d'arrossegar i deixar anar per a afegir música a la vostra llista de "
"reproducció actual. Podeu utilitzar <guilabel>Afegeix a la llista de "
"reproducció</guilabel>, que afegirà les cançons que heu seleccionat, o "
"<guilabel>Substitueix la llista de reproducció</guilabel>, que substituirà "
"tot el contingut de la llista de reproducció per la vostra selecció."

#. Tag: para
#: index.docbook:2021
#, no-c-format
msgid ""
"Alternatively, dragging-and-dropping your selection into a position in the "
"<emphasis>Playlist</emphasis> pane also works."
msgstr ""
"Alternativament, arrossegar i deixar anar la vostra selecció en una posició "
"a la subfinestra <emphasis>Llista de reproducció</emphasis> també funciona."

#. Tag: para
#: index.docbook:2023
#, no-c-format
msgid ""
"Right-clicking on a track, album, or selected group will bring up a context "
"menu from which you can <guilabel>Add to Playlist</guilabel>, or "
"<guilabel>Replace Playlist</guilabel>."
msgstr ""
"En fer clic dret en una peça, àlbum o grup seleccionat s'obrirà un menú "
"contextual des del qual podreu <guilabel>Afegeix a la llista de reproducció</"
"guilabel>, o <guilabel>Reemplaça la llista de reproducció</guilabel>."

#. Tag: para
#: index.docbook:2025
#, no-c-format
msgid ""
"Double-clicking a selection or pressing &Enter; while a track is selected in "
"the <emphasis>Media Sources</emphasis> pane will perform the same as "
"<guilabel>Add to Playlist</guilabel>."
msgstr ""
"Fer doble clic en una selecció o prémer &Intro; mentre se selecciona una "
"peça a la subfinestra <emphasis>Orígens de suports</emphasis> realitzarà el "
"mateix que <guilabel>Afegeix a la llista de reproducció</guilabel>."

#. Tag: para
#: index.docbook:2027
#, no-c-format
msgid ""
"Middle-clicking an item will append it to the playlist and begin playing "
"from the start of the playlist."
msgstr ""
"En fer clic amb el botó del mig en un element, s'afegirà a la llista de "
"reproducció i començarà a reproduir des de l'inici de la llista de "
"reproducció."

#. Tag: para
#: index.docbook:2029
#, no-c-format
msgid ""
"If you tell the file browser to open a supported multimedia file, &amarok; "
"will append the selected file to the current playlist. Some multimedia files "
"contain playlists themselves or may have playlist files associated by name "
"(&eg; <emphasis>wav</emphasis> with <emphasis>cue</emphasis>). If &amarok; "
"detects such an association, it may add several items to the playlist."
msgstr ""
"Si li dieu al navegador de fitxers que obri un fitxer multimèdia acceptat, "
"l'&amarok; afegirà el fitxer seleccionat a la llista de reproducció actual. "
"Alguns fitxers multimèdia contenen llistes de reproducció o poden tenir "
"fitxers de llista de reproducció associats pel seu nom (&pex;, "
"<emphasis>wav</emphasis> amb <emphasis>cue</emphasis>). Si l'&amarok; "
"detecta aquesta associació, pot afegir diversos elements a la llista de "
"reproducció."

#. Tag: title
#: index.docbook:2032
#, no-c-format
msgid "Context menu"
msgstr "Menú contextual"

#. Tag: para
#: index.docbook:2033
#, no-c-format
msgid ""
"Right-clicking on any song or album in the playlist will bring up the "
"<emphasis>Playlist</emphasis> context menu."
msgstr ""
"En fer clic dret a qualsevol cançó o àlbum de la llista de reproducció es "
"mostrarà el menú contextual de la <emphasis>Llista de reproducció</emphasis>."

#. Tag: title
#: index.docbook:2048
#, no-c-format
msgid "Queue/Dequeue Track"
msgstr "Posar/treure una peça de la cua"

#. Tag: para
#: index.docbook:2049
#, no-c-format
msgid ""
"Queuing a track will temporarily modify the play order without modifying the "
"actual playlist order by setting the user-selected track as the next track."
msgstr ""
"Posar a la cua una peça modificarà temporalment l'ordre de reproducció sense "
"modificar l'ordre real de la llista de reproducció establint la peça "
"seleccionada per l'usuari com a peça següent."

#. Tag: para
#: index.docbook:2051
#, no-c-format
msgid ""
"As many tracks as required can be queued, and the order of queuing is "
"indicated by a green circle with the determined order. Choose the tracks by "
"<keycombo>&Shift;<keycap>Click</keycap></keycombo> for a block of tracks, or "
"<keycombo>&Ctrl;<keycap>Click</keycap></keycombo> for individual tracks. The "
"order in which the tracks are selected is the determined order."
msgstr ""
"A la cua es poden posar tantes peces com sigui necessari, i l'ordre de la "
"cua s'indica per un cercle verd amb l'ordre determinat. Trieu les peces amb "
"<keycombo> &Maj;<keycap>Clic</keycap></keycombo> per a un bloc de peces, o "
"<keycombo>&Ctrl;<keycap>Clic</keycap></keycombo> per a peces individuals. "
"L'ordre en què se seleccionen les peces és l'ordre determinat."

#. Tag: para
#: index.docbook:2053
#, no-c-format
msgid ""
"Tracks can be dequeued by opening the context menu and selecting the "
"<guilabel>Dequeue Track</guilabel> option."
msgstr ""
"Les peces es poden treure de la cua obrint el menú contextual i seleccionant "
"l'opció <guilabel>Treu la peça de la cua</guilabel>."

#. Tag: para
#: index.docbook:2055
#, no-c-format
msgid "More about the <link linkend=\"queue-manager\">Queue Manager</link>."
msgstr "Més sobre el <link linkend=\"queue-manager\">Gestor de la cua</link>."

#. Tag: title
#: index.docbook:2058
#, no-c-format
msgid "Stop Playing After This Track"
msgstr "Para la reproducció després d'aquesta peça"

#. Tag: para
#: index.docbook:2059
#, no-c-format
msgid ""
"Choosing this option allows a track to finish, after which &amarok; will "
"stop playing . It will be indicated by the stop icon in place of the track "
"number. Selecting this option on a track already marked will unmark it. Only "
"one track in the playlist may be so marked."
msgstr ""
"Si es tria aquesta opció es permet acabar una peça, després de la qual "
"l'&amarok; aturarà la reproducció. S'indicarà amb la icona d'aturada en lloc "
"del número de peça. Seleccionar aquesta opció en una peça ja marcada la "
"desmarcarà. Només una peça de la llista de reproducció pot estar marcada "
"així."

#. Tag: title
#: index.docbook:2062
#, no-c-format
msgid "Remove From Playlist"
msgstr "Elimina de la llista de reproducció"

#. Tag: para
#: index.docbook:2063
#, no-c-format
msgid "This removes the selected track from the current playlist."
msgstr "Això elimina la peça seleccionada de la llista de reproducció actual."

#. Tag: title
#: index.docbook:2066
#, no-c-format
msgid "Add Position Marker"
msgstr "Afegeix un marcador de posició"

#. Tag: para
#: index.docbook:2067
#, no-c-format
msgid ""
"Adding a position marker is only available for the currently playing track. "
"This will add a bookmark in the seek bar at the top of the &amarok; "
"interface."
msgstr ""
"Afegir un marcador de posició només està disponible per a la peça que s'està "
"reproduint. Això afegirà una adreça d'interès a la barra de cerca a la part "
"superior de la interfície de l'&amarok;."

#. Tag: title
#: index.docbook:2070
#, no-c-format
msgid "Show in Media Sources"
msgstr "Mostra en orígens de suports"

#. Tag: para
#: index.docbook:2071
#, no-c-format
msgid ""
"This displays the track selected in the <link linkend=\"the-media-sources-"
"pane\">Media Sources</link> pane, which is on the left by default."
msgstr ""
"Això mostra la peça seleccionada a la subfinestra <link linkend=\"the-media-"
"sources-pane\">Orígens de suports</link>, que està a l'esquerra per defecte."

#. Tag: title
#: index.docbook:2074
#, no-c-format
msgid "<title>Album</title>"
msgstr "<title>Àlbum</title>"

#. Tag: phrase
#: index.docbook:2083
#, no-c-format
msgid "<phrase>Playlist album menu</phrase>"
msgstr "<phrase>Menú d'àlbum de la llista de reproducció</phrase>"

#. Tag: para
#: index.docbook:2086
#, no-c-format
msgid "<para>Playlist album menu</para>"
msgstr "<para>Menú d'àlbum de la llista de reproducció</para>"

#. Tag: para
#: index.docbook:2091
#, no-c-format
msgid ""
"These are per-album options which will affect the entire album the track "
"belongs to, rather than the track itself. The options are largely the same "
"as the album menu in the <link linkend=\"the-media-sources-pane\">Media "
"Sources</link> pane."
msgstr ""
"Aquestes són opcions per àlbum que afectaran a tot l'àlbum al qual pertany "
"la peça, en lloc de la mateixa peça. Les opcions són en gran part les "
"mateixes que el menú de l'àlbum a la subfinestra <link linkend=\"the-media-"
"sources-pane\">Orígens de suports</link>."

#. Tag: title
#: index.docbook:2094
#, no-c-format
msgid "Edit Track Details"
msgstr "Edita els detalls de la peça"

#. Tag: para
#: index.docbook:2095
#, no-c-format
msgid ""
"This option brings up the <link linkend=\"tag-editor\">Edit Track Details</"
"link> dialog for the selected tracks."
msgstr ""
"Aquesta opció obre el diàleg <link linkend=\"tag-editor\">Edita els detalls "
"de la peça</link> per a les peces seleccionades."

#. Tag: title
#: index.docbook:2099
#, no-c-format
msgid "Searching the Playlist"
msgstr "Cercar a la llista de reproducció"

#. Tag: phrase
#: index.docbook:2108
#, no-c-format
msgid "<phrase>Playlist searching options</phrase>"
msgstr "<phrase>Opcions de cerca a la llista de reproducció</phrase>"

#. Tag: para
#: index.docbook:2111
#, no-c-format
msgid "<para>Playlist searching options</para>"
msgstr "<para>Opcions de cerca a la llista de reproducció</para>"

#. Tag: para
#: index.docbook:2116
#, no-c-format
msgid ""
"&amarok; offers powerful searching capabilities for playlists. Simply enter "
"your query for a song into the text box labelled <guilabel>Search playlist</"
"guilabel> and it will match your keywords up against the match criteria you "
"specify in the options menu &mdash; for instance, you can choose to search "
"only by <guilabel>Albums</guilabel> and not <guilabel>Artists</guilabel>, or "
"choose to match both of them."
msgstr ""
"L'&amarok; ofereix capacitats de cerca potents per a les llistes de "
"reproducció. Simplement, introduïu la consulta per a una cançó en el quadre "
"de text etiquetat <guilabel>Cerca a la llista de reproducció</guilabel> i "
"cercarà les vostres paraules clau amb els criteris de coincidència que "
"especifiqueu en el menú d'opcions, per exemple, podeu triar cercar només per "
"<guilabel>àlbums</guilabel> i no per <guilabel>Artistes</guilabel>, o triar "
"que coincideixin els dos."

#. Tag: phrase
#: index.docbook:2126
#, no-c-format
msgid "<phrase>Playlist search bar</phrase>"
msgstr "<phrase>Barra de cerca de la llista de reproducció</phrase>"

#. Tag: para
#: index.docbook:2129
#, no-c-format
msgid "<para>Playlist search bar</para>"
msgstr "<para>Barra de cerca de la llista de reproducció</para>"

#. Tag: para
#: index.docbook:2134
#, no-c-format
msgid ""
"Pressing the <inlinemediaobject> <imageobject> <imagedata fileref=\"Icon-go-"
"up.png\" format=\"PNG\"/> </imageobject> </inlinemediaobject> icon moves the "
"selection to the previous search result, and <inlinemediaobject> "
"<imageobject> <imagedata fileref=\"Icon-go-down.png\" format=\"PNG\"/> </"
"imageobject> </inlinemediaobject> moves to the next result, all without "
"losing focus on the search input box."
msgstr ""
"En prémer la icona <inlinemediaobject> <imageobject> <imagedata fileref="
"\"Icon-go-up.png\" format=\"PNG\"/> </imageobject> </inlinemediaobject> mou "
"la selecció al resultat de la cerca anterior, i <inlinemediaobject> "
"<imageobject> <imagedata fileref=\"Icon-go-down.png\" format=\"PNG\"/> </"
"imageobject> </inlinemediaobject> mou al resultat següent, tot sense perdre "
"el focus en el quadre d'entrada de la cerca."

#. Tag: para
#: index.docbook:2136
#, no-c-format
msgid ""
"The <inlinemediaobject> <imageobject> <imagedata fileref=\"Icon-edit-clear-"
"locationbar-rtl.png\" format=\"PNG\"/> </imageobject> </inlinemediaobject> "
"icon in the search field will clear your query."
msgstr ""
"La icona <inlinemediaobject> <imageobject> <imagedata fileref=\"Icon-edit-"
"clear-locationbar-rtl.png\" format=\"PNG\"/> </imageobject> </"
"inlinemediaobject> al camp de cerca esborrarà la consulta."

#. Tag: para
#: index.docbook:2138
#, no-c-format
msgid ""
"Enabling <guilabel>Show only matches</guilabel> from the menu will cause "
"your playlist to display only the tracks matching the query."
msgstr ""
"Si activeu <guilabel>Mostra únicament les coincidències</guilabel> del menú "
"farà que la llista de reproducció només mostri les peces que coincideixen "
"amb la consulta."

#. Tag: para
#: index.docbook:2140
#, no-c-format
msgid ""
"More about <link linkend=\"playlist-filtering\">Playlist filtering here</"
"link>."
msgstr ""
"Més sobre el <link linkend=\"playlist-filtering\">filtratge de la llista de "
"reproducció aquí</link>."

#. Tag: title
#: index.docbook:2143
#, no-c-format
msgid "Sorting Levels and Bookmarking"
msgstr "Nivells d'ordenació i adreces d'interès"

#. Tag: phrase
#: index.docbook:2152
#, no-c-format
msgid "<phrase>Playlist sorting and bookmarking toolbar</phrase>"
msgstr ""
"<phrase>Ordenació de la llista de reproducció i barra d'eines d'adreces "
"d'interès</phrase>"

#. Tag: para
#: index.docbook:2155
#, no-c-format
msgid "<para>Playlist sorting and bookmarking toolbar</para>"
msgstr ""
"<para>Ordenació de la llista de reproducció i barra d'eines d'adreces "
"d'interès</para>"

#. Tag: title
#: index.docbook:2160
#, no-c-format
msgid "Sorting Levels"
msgstr "Nivells d'ordenació"

#. Tag: phrase
#: index.docbook:2169
#, no-c-format
msgid "<phrase>Menu for adding a sorting level</phrase>"
msgstr "<phrase>Menú per a afegir un nivell d'ordenació</phrase>"

#. Tag: para
#: index.docbook:2172
#, no-c-format
msgid "<para>Menu for adding a sorting level</para>"
msgstr "<para>Menú per a afegir un nivell d'ordenació</para>"

#. Tag: para
#: index.docbook:2177
#, no-c-format
msgid ""
"&amarok;'s robust sorting abilities offer the ability to sort not only by "
"one field of a track, but by many combined in a series of levels."
msgstr ""
"Les capacitats robustes d'ordenació de l'&amarok; ofereixen la capacitat "
"d'ordenar no només per un camp d'una peça, sinó per molts combinats en una "
"sèrie de nivells."

#. Tag: para
#: index.docbook:2179
#, no-c-format
msgid ""
"There are many different modes by which a sorting level can act. For "
"instance, songs can be sorted by their <guilabel>Genre</guilabel> and then "
"their <guilabel>Album</guilabel>."
msgstr ""
"Hi ha molts modes diferents pels quals pot actuar un nivell d'ordenació. Per "
"exemple, les cançons es poden classificar pel seu <guilabel>Gènere</"
"guilabel> i després pel seu <guilabel>Àlbum</guilabel>."

#. Tag: para
#: index.docbook:2181
#, no-c-format
msgid ""
"A sorting level can be added by clicking the right-pointing triangle, which "
"will bring up the menu for adding another sorting level."
msgstr ""
"Es pot afegir un nivell d'ordenació fent clic al triangle que apunta cap a "
"la dreta, que mostrarà el menú per a afegir un altre nivell d'ordenació."

#. Tag: para
#: index.docbook:2183
#, no-c-format
msgid ""
"Clicking the small triangle on the right of the sorting level's name will "
"cause items in the playlist to switch between ascending and descending "
"order, which is indicated by the direction in which the triangle is pointing "
"&mdash; up or down, respectively."
msgstr ""
"Fer clic al petit triangle de la dreta del nom del nivell d'ordenació farà "
"que els elements de la llista de reproducció canviïn entre ordre ascendent i "
"descendent, el qual s'indica per la direcció en la qual el triangle apunta "
"cap amunt o cap avall, respectivament."

#. Tag: para
#: index.docbook:2185
#, no-c-format
msgid ""
"To remove a sorting level, click the name of the sorting level that precedes "
"the one you wish to remove. Multiple sorting levels can be removed &mdash; "
"provided that they are all lower in the hierarchy &mdash; by clicking on the "
"ancestor of all of them. If you wish to clear all sorting levels, you can "
"click the playlist icon to the left of the first right-pointing arrow."
msgstr ""
"Per a eliminar un nivell d'ordenació, feu clic al nom del nivell d'ordenació "
"que precedeix el que voleu eliminar. Es poden eliminar diversos nivells "
"d'ordenació si tots són inferiors a la jerarquia fent clic a l'avantpassat "
"de tots ells. Si voleu netejar tots els nivells d'ordenació, podeu fer clic "
"a la icona de la llista de reproducció a l'esquerra de la primera fletxa que "
"apunta cap a la dreta."

#. Tag: title
#: index.docbook:2188
#, no-c-format
msgid "Bookmarking"
msgstr "Anotar les adreces d'interès"

#. Tag: phrase
#: index.docbook:2197
#, no-c-format
msgid "<phrase>Bookmarking menu</phrase>"
msgstr "<phrase>Menú d'adreces d'interès</phrase>"

#. Tag: para
#: index.docbook:2200
#, no-c-format
msgid "<para>Bookmarking menu</para>"
msgstr "<para>Menú d'adreces d'interès</para>"

#. Tag: para
#: index.docbook:2205
#, no-c-format
msgid ""
"The bookmarking menu provides options to save your <link linkend=\"changing-"
"the-playlist-layout\">current playlist layout</link>. Clicking "
"<guilabel>Bookmark Playlist Setup</guilabel> will add your playlist layout "
"to the layout bookmarks, which can be viewed in <link linkend=\"bookmark-"
"manager\">Bookmark Manager</link>."
msgstr ""
"El menú d'adreces d'interès proporciona opcions per a desar el <link linkend="
"\"changing-the-playlist-layout\">format actual de la llista de reproducció</"
"link>. En fer clic a <guilabel>Arranjament dels punts de la llista de "
"reproducció</guilabel> s'afegirà el format de la llista de reproducció a les "
"adreces d'interès, que es poden veure a <link linkend=\"bookmark-manager"
"\">Gestor d'adreces d'interès</link>."

#. Tag: para
#: index.docbook:2207
#, no-c-format
msgid ""
"<guilabel>Copy Current View Bookmark to Clipboard</guilabel> copies an "
"&amarok; playlist layout URL to the clipboard, which can be used for backing "
"up your playlist layout."
msgstr ""
"<guilabel>Copia les adreces d'interès de la vista actual al porta-retalls</"
"guilabel> copia l'URL del format de la llista de reproducció de l'&amarok; "
"al porta-retalls, que es pot utilitzar per a fer una còpia de seguretat del "
"format de la llista de reproducció."

#. Tag: title
#: index.docbook:2211
#, no-c-format
msgid "Playlist Functions"
msgstr "Funcions de la llista de reproducció"

#. Tag: phrase
#: index.docbook:2220
#, no-c-format
msgid "<phrase>Playlist bottom bar</phrase>"
msgstr "<phrase>Barra inferior de la llista de reproducció</phrase>"

#. Tag: para
#: index.docbook:2223
#, no-c-format
msgid "<para>Playlist bottom bar</para>"
msgstr "<para>Barra inferior de la llista de reproducció</para>"

#. Tag: para
#: index.docbook:2228
#, no-c-format
msgid ""
"The bottom bar of the <emphasis>Playlist</emphasis> pane provides various "
"additional options for manipulation of your playlist."
msgstr ""
"La barra inferior de la subfinestra <emphasis>llista de reproducció</"
"emphasis> proporciona diverses opcions addicionals per a la manipulació de "
"la llista de reproducció."

#. Tag: para
#: index.docbook:2258
#, no-c-format
msgid "Empty playlist of all playlists, albums and tracks."
msgstr ""
"Llista de reproducció buida de totes les llistes de reproducció, àlbums i "
"peces."

#. Tag: para
#: index.docbook:2277
#, no-c-format
msgid ""
"Save your playlist. Right-click to rename it, default is the date as a name. "
"Left-click to bring up the <emphasis>Save Playlist</emphasis> menu, to save "
"your playlist file onto the hard drive instead of the database."
msgstr ""
"Deseu la llista de reproducció. Feu clic amb el botó dret per a canviar el "
"nom, per defecte és la data com a nom. Feu clic amb el botó esquerre per a "
"obrir el menú <emphasis>Desa la llista de reproducció</emphasis>, per a "
"desar el fitxer de la llista de reproducció en el disc dur en lloc de la "
"base de dades."

#. Tag: para
#: index.docbook:2334
#, no-c-format
msgid ""
"Scrolls playlist to the track which is currently playing and highlights it "
"&mdash; useful for a large playlist."
msgstr ""
"Desplaça la llista de reproducció a la peça que s'està reproduint i la "
"destaca; útil per a les llistes de reproducció grans."

#. Tag: para
#: index.docbook:2372
#, no-c-format
msgid ""
"Edit the playlist queue; tracks played first before the playlist resumes. "
"More about the <link linkend=\"queue-manager\">Queue Manager</link>."
msgstr ""
"Edita la cua de la llista de reproducció; les peces es reprodueixen primer "
"abans que es reprengui la llista de reproducció. Més sobre el <link linkend="
"\"queue-manager\">Gestor de la cua</link>."

#. Tag: title
#: index.docbook:2378
#, no-c-format
msgid "Save Playlist menu"
msgstr "Menú de desament de la llista de reproducció"

#. Tag: phrase
#: index.docbook:2387
#, no-c-format
msgid "<phrase>Save playlist menu</phrase>"
msgstr "<phrase>Menú de desament de la llista de reproducció</phrase>"

#. Tag: para
#: index.docbook:2390
#, no-c-format
msgid "<para>Save playlist menu</para>"
msgstr "<para>Menú de desament de la llista de reproducció</para>"

#. Tag: para
#: index.docbook:2395
#, no-c-format
msgid ""
"Left-click <inlinemediaobject> <imageobject> <imagedata fileref=\"Icon-"
"document-save.png\" format=\"PNG\"/> </imageobject> </inlinemediaobject> to "
"bring up the <guilabel>Save Playlist</guilabel> menu, to save your playlist "
"file onto the hard drive instead of the database."
msgstr ""
"Feu clic amb el botó esquerre <inlinemediaobject> <imageobject> <imagedata "
"fileref=\"Icon-document-save.png\" format=\"PNG\"/> </imageobject> </"
"inlinemediaobject> per a fer aparèixer el menú <guilabel>Desa la llista de "
"reproducció</guilabel>, per a desar el fitxer de la llista de reproducció al "
"disc dur en lloc de la base de dades."

#. Tag: title
#: index.docbook:2398
#, no-c-format
msgid "Track Progression"
msgstr "Progrés de la peça"

#. Tag: phrase
#: index.docbook:2407
#, no-c-format
msgid "<phrase>Track progression menu</phrase>"
msgstr "<phrase>Menú de progrés de la peça</phrase>"

#. Tag: para
#: index.docbook:2410
#, no-c-format
msgid "<para>Track progression menu</para>"
msgstr "<para>Menú de progrés de la peça</para>"

#. Tag: para
#: index.docbook:2415
#, no-c-format
msgid ""
"The <guilabel>Track Progression</guilabel> menu enables you to modify the "
"order in which &amarok; progresses through the tracks in your playlist."
msgstr ""
"El menú <guilabel>Progrés de la peça</guilabel> permet modificar l'ordre en "
"què l'&amarok; progressa a través de les peces de la llista de reproducció."

#. Tag: para
#: index.docbook:2417
#, no-c-format
msgid ""
"The top half of the menu specifies repeat options &mdash; whether songs "
"should be repeated by track, by album or by playlist; whereas the bottom "
"half specifies the order in which the tracks play in &mdash; in random order "
"or by favor. Only one type of progression may be selected, &eg; you cannot "
"select both random track and repeat playlist."
msgstr ""
"La meitat superior del menú especifica les opcions de repetició: si les "
"cançons s'han de repetir per peça, per àlbum o per llista de reproducció; "
"mentre que la meitat inferior especifica l'ordre en què es reprodueixen les "
"peces: en ordre aleatori o per afavoriment. Només es pot seleccionar un "
"tipus de progressió, &pex;, no es pot seleccionar una peça aleatòria i "
"repetir la llista de reproducció."

#. Tag: title
#: index.docbook:2419
#, no-c-format
msgid "Favor"
msgstr "Afavoreix"

#. Tag: phrase
#: index.docbook:2428
#, no-c-format
msgid "<phrase>Playlist favor menu</phrase>"
msgstr "<phrase>Menú d'afavoriment de la llista de reproducció</phrase>"

#. Tag: para
#: index.docbook:2431
#, no-c-format
msgid "<para>Playlist favor menu</para>"
msgstr "<para>Menú d'afavoriment de la llista de reproducció</para>"

#. Tag: para
#: index.docbook:2436
#, no-c-format
msgid ""
"Favor is an innovative method to determine the next track to be played when "
"using the random selection mode. The next track to be played can be "
"determined depending on their score (a measure of how often they are "
"played), their user-given rating, or if they have not been recently played."
msgstr ""
"Afavoreix és un mètode innovador per a determinar la peça següent a "
"reproduir quan s'utilitza el mode de selecció aleatòria. La peça següent que "
"es pot reproduir es pot determinar depenent de la seva puntuació (una mesura "
"de la freqüència amb què es reprodueixen), la seva valoració d'usuari, o si "
"no s'han reproduït recentment."

#. Tag: title
#: index.docbook:2443
#, no-c-format
msgid "Configuring Amarok"
msgstr "Configuració de l'Amarok"

#. Tag: para
#: index.docbook:2444
#, no-c-format
msgid ""
"On first start, some basic configuration is done; see also <link linkend="
"\"getting-started\">Quick Start Guide: Getting Started</link>. But there is "
"more under the hood."
msgstr ""
"En el primer inici, es fa una configuració bàsica; vegeu també <link linkend="
"\"getting-started\">Guia ràpida d'inici: Com començar</link>. Però hi ha més "
"sota el capó."

#. Tag: para
#: index.docbook:2446
#, no-c-format
msgid ""
"To access the <emphasis>Configuration Menu</emphasis>, go to "
"<menuchoice><guimenu>Settings</guimenu><guimenuitem>Configure Amarok...</"
"guimenuitem></menuchoice> and see the following dialog:"
msgstr ""
"Per a accedir al <emphasis>menú de configuració</emphasis>, aneu a "
"<menuchoice><guimenu>Arranjament</guimenu><guimenuitem>Configura l'Amarok..."
"</guimenuitem></menuchoice> i vegeu el diàleg següent:"

#. Tag: phrase
#: index.docbook:2456
#, no-c-format
msgid "<phrase>General configuration options</phrase>"
msgstr "<phrase>Opcions generals de configuració</phrase>"

#. Tag: para
#: index.docbook:2459
#, no-c-format
msgid "<para>General configuration options</para>"
msgstr "<para>Opcions generals de configuració</para>"

#. Tag: title
#: index.docbook:2464
#, no-c-format
msgid "General"
msgstr "General"

#. Tag: para
#: index.docbook:2465
#, no-c-format
msgid ""
"In the screenshot above, see some <emphasis>General Options</emphasis> you "
"can set. Depending on the distribution, the default settings can vary. When "
"hovering over the options with the mouse pointer, a tooltip will show to "
"explain the individual settings."
msgstr ""
"A la captura de pantalla anterior, vegeu algunes <emphasis>Opcions generals</"
"emphasis> que podeu establir. Depenent de la distribució, les opcions "
"predeterminades poden variar. En passar per sobre de les opcions amb el "
"punter del ratolí, es mostrarà un consell d'eina per a explicar la "
"configuració individual."

#. Tag: para
#: index.docbook:2467
#, no-c-format
msgid "General options:"
msgstr "Opcions generals:"

#. Tag: entry
#: index.docbook:2474 index.docbook:2559 index.docbook:2641 index.docbook:2683
#: index.docbook:2757 index.docbook:2899 index.docbook:3008
#, no-c-format
msgid "Option"
msgstr "Opció"

#. Tag: entry
#: index.docbook:2475 index.docbook:2560 index.docbook:2642 index.docbook:2684
#: index.docbook:2758 index.docbook:2900 index.docbook:3009
#, no-c-format
msgid "Tooltip"
msgstr "Consell"

#. Tag: guilabel
#: index.docbook:2481
#, no-c-format
msgid "Show tray icon"
msgstr "Mostra una icona a la safata del sistema"

#. Tag: para
#: index.docbook:2484
#, no-c-format
msgid "Check to enable the &amarok; system tray icon."
msgstr ""
"Marqueu-la per a activar la icona de l'&amarok; a la safata del sistema."

#. Tag: guilabel
#: index.docbook:2489
#, no-c-format
msgid "Automatically retrieve cover art"
msgstr "Recupera la caràtula automàticament"

#. Tag: para
#: index.docbook:2492
#, no-c-format
msgid "Check to enable the automatic retrieval of cover art from the internet."
msgstr ""
"Marqueu-la per a activar la recuperació automàtica de les caràtules des "
"d'Internet."

#. Tag: guilabel
#: index.docbook:2497
#, no-c-format
msgid "Enable context applets collapse animations"
msgstr "Activa les animacions en reduir les miniaplicacions contextuals"

#. Tag: para
#: index.docbook:2500
#, no-c-format
msgid "Check to enable animations when context applets collapse."
msgstr ""
"Marqueu-la per a activar les animacions en reduir les miniaplicacions "
"contextuals."

#. Tag: guilabel
#: index.docbook:2505
#, no-c-format
msgid "Automatically scroll playlist to current track"
msgstr "Desplaça automàticament la llista de reproducció a la peça actual"

#. Tag: para
#: index.docbook:2508
#, no-c-format
msgid ""
"Check to make the playlist scroll so the current track is always visible."
msgstr ""
"Marqueu-la per a desplaçar la llista de reproducció de manera que la peça "
"actual sigui sempre visible."

#. Tag: guilabel
#: index.docbook:2513
#, no-c-format
msgid "Show Moodbar in progress slider"
msgstr "Mostra la barra d'ànim en el control lliscant de progrés"

#. Tag: para
#: index.docbook:2516
#, no-c-format
msgid ""
"The <emphasis>Moodbar</emphasis> makes it possible to navigate in your music "
"visually. Please note that this feature requires the <link linkend=\"the-"
"moodbar\">external Moodbar Generator tool</link>, or a script."
msgstr ""
"La <emphasis>Barra d'ànim</emphasis> permet navegar visualment per la "
"música. Tingueu en compte que aquesta característica requereix l'<link "
"linkend=\"the-moodbar\">eina de generació de Barra d'ànim externa</link>, o "
"un script."

#. Tag: guilabel
#: index.docbook:2521
#, no-c-format
msgid "Moodbar style"
msgstr "Estil de la barra d'ànim"

#. Tag: para
#: index.docbook:2524
#, no-c-format
msgid "Choose the mood display style."
msgstr "Selecciona l'estil de visualització de la barra d'ànim."

#. Tag: para
#: index.docbook:2530
#, no-c-format
msgid ""
"When you enable the <emphasis>Moodbar</emphasis>, be aware of the following "
"requirements: the Moodbar will only display if your tracks have been tagged "
"with moods. For more about the Moodbar, refer to: <link linkend=\"the-moodbar"
"\">Moodbar</link>."
msgstr ""
"Quan activeu la <emphasis>Barra d'ànim</emphasis>, tingueu en compte els "
"requisits següents: la Barra d'ànim només es mostrarà si les vostres peces "
"han estat etiquetades amb ànims. Per a més informació sobre la Barra d'ànim, "
"vegeu: <link linkend=\"the-moodbar\">Barra d'ànim</link>."

#. Tag: title
#: index.docbook:2533
#, no-c-format
msgid "Local Collection"
msgstr "Col·lecció local"

#. Tag: phrase
#: index.docbook:2542
#, no-c-format
msgid "<phrase>Local Collection configuration</phrase>"
msgstr "<phrase>Configuració de la col·lecció local</phrase>"

#. Tag: para
#: index.docbook:2545
#, no-c-format
msgid "<para>Local Collection configuration</para>"
msgstr "<para>Configuració de la col·lecció local</para>"

#. Tag: para
#: index.docbook:2550
#, no-c-format
msgid ""
"This dialog shows your file system in a tree structure, called "
"<emphasis>Collection Folders</emphasis>. Selecting a folder always includes "
"its subfolders. These folders will be scanned for media to make up your "
"collection. You can right-click on a folder to individually rescan it, if it "
"was previously selected."
msgstr ""
"Aquest diàleg mostra el vostre sistema de fitxers en una estructura en "
"arbre, anomenada <emphasis>Carpetes de col·leccions</emphasis>. Seleccionar "
"una carpeta sempre inclou les seves subcarpetes. Aquestes carpetes "
"s'exploraran per a obtenir elements multimèdia per a crear la vostra "
"col·lecció. Podeu fer clic amb el botó dret en una carpeta per a tornar a "
"explorar-la individualment, si ha estat seleccionada prèviament."

#. Tag: para
#: index.docbook:2552
#, no-c-format
msgid "Collection options:"
msgstr "Opcions de la col·lecció:"

#. Tag: guilabel
#: index.docbook:2566
#, no-c-format
msgid "Fully Rescan Entire Collection"
msgstr "Torna a explorar tota la col·lecció"

#. Tag: para
#: index.docbook:2569
#, no-c-format
msgid ""
"Rescan your entire collection. This will <emphasis>not</emphasis> delete any "
"statistics."
msgstr ""
"Torna a explorar tota la col·lecció. Això <emphasis>no</emphasis> suprimirà "
"cap estadística."

#. Tag: guilabel
#: index.docbook:2574
#, no-c-format
msgid "Import"
msgstr "Importa"

#. Tag: para
#: index.docbook:2577
#, no-c-format
msgid ""
"Imports ratings and/or statistics from older &amarok; versions, the batch "
"scanner, or media players."
msgstr ""
"Importa valoracions i/o estadístiques de versions antigues de l'&amarok;, "
"l'exploració per lots o reproductors multimèdia."

#. Tag: guilabel
#: index.docbook:2582
#, no-c-format
msgid "Scan folders recursively (requires full rescan if newly checked)"
msgstr ""
"Explora les carpetes recursivament (requereix una exploració completa si "
"s'ha activat de nou)"

#. Tag: para
#: index.docbook:2585
#, no-c-format
msgid "If selected, &amarok; will read all subfolders."
msgstr "Si està seleccionat, &amarok; llegirà totes les subcarpetes."

#. Tag: guilabel
#: index.docbook:2590
#, no-c-format
msgid "Watch folders for changes"
msgstr "Vigila els canvis en les carpetes"

#. Tag: para
#: index.docbook:2593
#, no-c-format
msgid ""
"If selected, the collection folders will be watched for changes. The watcher "
"will not notice changes behind symbolic links."
msgstr ""
"Si està seleccionat, es vigilaran els canvis a les carpetes de la "
"col·lecció. El vigilant no s'adonarà dels canvis darrere els enllaços "
"simbòlics."

#. Tag: guilabel
#: index.docbook:2598
#, no-c-format
msgid "Importing Music: Transcode tracks"
msgstr "Importació de música: transcodificació de peces"

#. Tag: para
#: index.docbook:2601
#, no-c-format
msgid ""
"Whether &amarok; should transcode tracks when they are copied or moved to "
"<emphasis>Local Collection</emphasis>."
msgstr ""
"Si &amarok; hauria de transcodificar les peces quan es mouen o es copien a "
"la <emphasis>col·lecció local</emphasis>."

#. Tag: title
#: index.docbook:2607
#, no-c-format
msgid "Import Statistics"
msgstr "Importació d'estadístiques"

#. Tag: para
#: index.docbook:2608
#, no-c-format
msgid ""
"This option allows you to import statistics, &eg; ratings and scores from "
"either"
msgstr ""
"Aquesta opció permet importar estadístiques, &pex;, valoracions i puntuacions"

#. Tag: para
#: index.docbook:2611
#, no-c-format
msgid ""
"an older &amarok; 1.4.x version (from <guilabel>SQLite</guilabel>, "
"<guilabel>MySQL</guilabel> or <guilabel>PostgreSQL</guilabel> databases)"
msgstr ""
"des d'una versió antiga de l'&amarok; 1.4.x (de bases de dades "
"<guilabel>SQLite</guilabel>, <guilabel>MySQL</guilabel> o "
"<guilabel>PostgreSQL</guilabel>)"

#. Tag: para
#: index.docbook:2612
#, no-c-format
msgid "from <guilabel>iTunes</guilabel>"
msgstr "des d'<guilabel>iTunes</guilabel>"

#. Tag: para
#: index.docbook:2614
#, no-c-format
msgid ""
"It does <emphasis>not</emphasis> import statistics from an &amarok; 2.x "
"database, so if you want to merge an older 2.x database version, you will "
"need to do this by hand."
msgstr ""
"<emphasis>No</emphasis> importa estadístiques d'una base de dades &amarok; 2."
"x, així que si voleu fusionar una versió antiga de la base de dades 2.x "
"haureu de fer-ho a mà."

#. Tag: title
#: index.docbook:2618
#, no-c-format
msgid "Metadata"
msgstr "Metadades"

#. Tag: para
#: index.docbook:2632
#, no-c-format
msgid ""
"This dialog will allow you to configure the settings for metadata handling. "
"This is a separate page starting with Amarok 2.7"
msgstr ""
"Aquest diàleg us permetrà configurar els paràmetres per a la gestió de les "
"metadades. Aquesta és una pàgina separada que comença amb l'Amarok 2.7"

#. Tag: para
#: index.docbook:2634
#, no-c-format
msgid "Metadata options:"
msgstr "Opcions de les metadades:"

#. Tag: guilabel
#: index.docbook:2648
#, no-c-format
msgid "Write statistics to file"
msgstr "Escriu les estadístiques al fitxer"

#. Tag: para
#: index.docbook:2651
#, no-c-format
msgid ""
"Check to write play-changing statistics as tags back to the audio files."
msgstr ""
"Marqueu-ho per a escriure les estadístiques de canvis de reproducció com a "
"etiquetes als fitxers d'àudio."

#. Tag: guilabel
#: index.docbook:2656
#, no-c-format
msgid "Write covers to file, maximum size..."
msgstr "Escriu les caràtules al fitxer, mida màxima..."

#. Tag: para
#: index.docbook:2659
#, no-c-format
msgid ""
"Check to write changed covers back to the audio files. This will replace "
"existing embedded covers. Select a value from the drop-down list to set the "
"maximum size of the cover."
msgstr ""
"Marqueu-ho per a escriure les caràtules canviades als fitxers d'àudio. Això "
"substituirà les caràtules incrustades existents. Seleccioneu un valor de la "
"llista desplegable per a establir la mida màxima de la caràtula."

#. Tag: guilabel
#: index.docbook:2664
#, no-c-format
msgid "Enable character set detection in ID3 tags"
msgstr "Activa la detecció del joc de caràcters a les etiquetes ID3"

#. Tag: para
#: index.docbook:2667
#, no-c-format
msgid ""
"If checked, Amarok will use Mozilla's Character Set Detector to attempt to "
"automatically guess the character sets used in ID3 tags. If your tags are "
"correct, it is more safe to leave this option turned off."
msgstr ""
"Si està marcada, l'Amarok utilitzarà el detector de joc de caràcters de "
"Mozilla per a intentar endevinar automàticament els jocs de caràcters "
"utilitzats en les etiquetes ID3. Si les etiquetes són correctes, és més "
"segur deixar aquesta opció desactivada."

#. Tag: title
#: index.docbook:2673
#, no-c-format
msgid "Statistics Synchronization"
msgstr "Sincronització d'estadístiques"

#. Tag: para
#: index.docbook:2674
#, no-c-format
msgid ""
"This dialog will allow you to <link linkend=\"statistics-synchronization"
"\">keep statistics of your collections synchronized</link>. Make sure to "
"only check collections between which you want to synchronize metadata."
msgstr ""
"Aquest diàleg us permetrà <link linkend=\"statistics-synchronization"
"\">mantenir les estadístiques de les vostres col·leccions sincronitzades</"
"link>. Assegureu-vos de marcar només les col·leccions de les quals voleu "
"sincronitzar les metadades."

#. Tag: para
#: index.docbook:2676
#, no-c-format
msgid "Statistics Synchronization options:"
msgstr "Opcions de sincronització d'estadístiques:"

#. Tag: guilabel
#: index.docbook:2690
#, no-c-format
msgid "Synchronize Rating"
msgstr "Sincronitza la valoració"

#. Tag: para
#: index.docbook:2693
#, no-c-format
msgid "Check to synchronize ratings between collections."
msgstr "Marqueu-ho per a sincronitzar les valoracions entre les col·leccions."

#. Tag: guilabel
#: index.docbook:2698
#, no-c-format
msgid "Synchronize First Played"
msgstr "Sincronitza les primeres reproduccions"

#. Tag: para
#: index.docbook:2701
#, no-c-format
msgid "Check to synchronize first played dates between collections."
msgstr ""
"Marqueu-ho per a sincronitzar les dates de primera reproducció entre les "
"col·leccions."

#. Tag: guilabel
#: index.docbook:2706
#, no-c-format
msgid "Synchronize Last Played"
msgstr "Sincronitza les darreres reproduccions"

#. Tag: para
#: index.docbook:2709
#, no-c-format
msgid "Check to synchronize last played dates between collections."
msgstr ""
"Marqueu-ho per a sincronitzar les dates de darrera reproducció entre les "
"col·leccions."

#. Tag: guilabel
#: index.docbook:2714
#, no-c-format
msgid "Synchronize Playcount"
msgstr "Sincronitza el nombre de reproduccions"

#. Tag: para
#: index.docbook:2717
#, no-c-format
msgid "Check to synchronize playcounts between collections."
msgstr ""
"Marqueu-ho per a sincronitzar el nombre de reproduccions entre les "
"col·leccions."

#. Tag: guilabel
#: index.docbook:2722
#, no-c-format
msgid "Synchronize Labels"
msgstr "Sincronitza les etiquetes"

#. Tag: para
#: index.docbook:2725
#, no-c-format
msgid "Check to synchronize labels between collections."
msgstr "Marqueu-ho per a sincronitzar les etiquetes entre les col·leccions."

#. Tag: title
#: index.docbook:2733
#, no-c-format
msgid "Playback"
msgstr "Reproducció"

#. Tag: phrase
#: index.docbook:2742
#, no-c-format
msgid "<phrase>Playback configuration dialog</phrase>"
msgstr "<phrase>Diàleg de configuració de la reproducció</phrase>"

#. Tag: para
#: index.docbook:2745
#, no-c-format
msgid "<para>Playback configuration dialog</para>"
msgstr "<para>Diàleg de configuració de la reproducció</para>"

#. Tag: para
#: index.docbook:2750
#, no-c-format
msgid ""
"Configure the playback options, as well as the KDE multimedia framework "
"&phonon;."
msgstr ""
"Configura les opcions de reproducció, així com l'entorn de treball "
"multimèdia &phonon; de KDE."

#. Tag: guilabel
#: index.docbook:2764
#, no-c-format
msgid "Fadeout on stop"
msgstr "Esvaeix en aturar"

#. Tag: para
#: index.docbook:2767
#, no-c-format
msgid ""
"If checked, &amarok; will slowly fade the volume of the playing track on "
"stop or at the end of the playlist, or stop playback immediately."
msgstr ""
"Si està marcada, l'&amarok; esvairà lentament el volum de reproducció de la "
"peça en aturar o al final de la llista de reproducció, o aturarà la "
"reproducció immediatament."

#. Tag: guilabel
#: index.docbook:2772
#, no-c-format
msgid "Fadeout on pause"
msgstr "Esvaeix en fer pausa"

#. Tag: para
#: index.docbook:2775
#, no-c-format
msgid ""
"If checked, &amarok; will slowly fade the volume of the playing track on "
"pausing the current track."
msgstr ""
"Si està marcada, l'&amarok; esvairà lentament el volum de reproducció de la "
"peça en fer una pausa a la peça actual."

#. Tag: guilabel
#: index.docbook:2780
#, no-c-format
msgid "Fadeout duration"
msgstr "Durada de l'esvaïment"

#. Tag: para
#: index.docbook:2783
#, no-c-format
msgid "The length of the fadeout, in milliseconds."
msgstr "La durada de l'esvaïment en mil·lisegons."

#. Tag: guilabel
#: index.docbook:2788
#, no-c-format
msgid "Inhibit automatic suspend if playing"
msgstr "Inhibeix la suspensió automàtica si està reproduint"

#. Tag: para
#: index.docbook:2791
#, no-c-format
msgid ""
"If checked, &amarok; will prevent the computer from being suspended will a "
"track is playing."
msgstr ""
"Si està marcada, l'&amarok; impedirà que l'ordinador entri en suspensió "
"mentre es reprodueix una peça."

#. Tag: guilabel
#: index.docbook:2796
#, no-c-format
msgid "Pause playback on suspend"
msgstr "Fa pausa de la reproducció en suspendre"

#. Tag: para
#: index.docbook:2799
#, no-c-format
msgid ""
"If checked, &amarok; will pause playing of the current track when the "
"computer is about to suspend."
msgstr ""
"Si està marcada, l'&amarok; aturarà la reproducció de la peça actual quan "
"l'ordinador estigui a punt de suspendre's."

#. Tag: guilabel
#: index.docbook:2804
#, no-c-format
msgid "Resume playback on start"
msgstr "Reprèn la reproducció a l'inici"

#. Tag: para
#: index.docbook:2807
#, no-c-format
msgid ""
"If checked, &amarok; will resume playback where you left it the last session "
"-- just like a tape-player."
msgstr ""
"Si està marcada, l'&amarok; reprendrà la reproducció on la vau deixar "
"l'última sessió, com un reproductor de cinta."

#. Tag: title
#: index.docbook:2813
#, no-c-format
msgid "Configuring Phonon"
msgstr "Configuració del Phonon"

#. Tag: para
#: index.docbook:2814
#, no-c-format
msgid ""
"&phonon; is the multimedia framework used by &amarok;. It was created to "
"allow KDE 4 to be independent of any single multimedia framework such as "
"<guilabel>GStreamer</guilabel> or <guilabel>VLC</guilabel> and to provide a "
"stable API for KDE 4's lifetime. As an added bonus, it simplifies "
"development by providing a simple API that works across different platforms "
"such as <guilabel>Windows</guilabel> and <guilabel>OS X</guilabel>."
msgstr ""
"El &phonon; és l'entorn multimèdia utilitzat per l'&amarok;. Es va crear per "
"a permetre que el KDE 4 sigui independent de qualsevol entorn multimèdia "
"únic com el <guilabel>GStreamer</guilabel> o el <guilabel>VLC</guilabel> i "
"proporcionar una API estable durant la vida del KDE 4. Com a bonificació "
"addicional, simplifica el desenvolupament proporcionant una API senzilla que "
"funciona a través de plataformes diferents com el <guilabel>Windows</"
"guilabel> i l'<guilabel>OS X</guilabel>."

#. Tag: para
#: index.docbook:2816
#, no-c-format
msgid ""
"The result of all this for you, the user, is that you can choose the "
"multimedia framework that works best for you. This is usually pre-configured "
"by your distribution."
msgstr ""
"El resultat de tot això per a vós, l'usuari, és que podeu triar l'entorn "
"multimèdia que us funcioni millor. Normalment està preconfigurat per la "
"vostra distribució."

#. Tag: para
#: index.docbook:2818
#, no-c-format
msgid ""
"Playback problems in &amarok; are typically not &amarok; issues, but rather "
"&phonon; issues, as &amarok; doesn't handle sound directly anymore."
msgstr ""
"Els problemes de reproducció a l'&amarok; no solen ser problemes de "
"l'&amarok;, sinó més aviat problemes del &phonon;, atès que l'&amarok; ja no "
"gestiona el so directament."

#. Tag: title
#: index.docbook:2820
#, no-c-format
msgid "Device Preference tab"
msgstr "La pestanya Preferències del dispositiu"

#. Tag: para
#: index.docbook:2834
#, no-c-format
msgid ""
"Depending on your OS and distribution, you may need to use <guilabel>ALSA</"
"guilabel>, <guilabel>OSS</guilabel>, <guilabel>PulseAudio</guilabel>, or "
"something else as your default playback device. Find one that works for you "
"with the <guilabel>Test</guilabel> button and apply to all types of output. "
"If you would like different types of output to go with different devices, "
"this is possible as well."
msgstr ""
"Depenent del vostre sistema operatiu i distribució, és possible que hàgiu "
"d'utilitzar <guilabel>ALSA</guilabel>, <guilabel>OSS</guilabel>, "
"<guilabel>PulseAudio</guilabel>, o alguna altra cosa com a dispositiu de "
"reproducció predeterminat. Trobeu-ne un que funcioni amb el botó "
"<guilabel>Prova</guilabel> i s'apliqui a tots els tipus de sortida. Si voleu "
"que els tipus diferents de sortida vagin amb dispositius diferents, això "
"també és possible."

#. Tag: title
#: index.docbook:2837
#, no-c-format
msgid "Speaker Setup tab"
msgstr "La pestanya Configuració de l'altaveu"

#. Tag: para
#: index.docbook:2851
#, no-c-format
msgid ""
"Should you wish to change the standard speaker setup, here is the place to "
"do it."
msgstr ""
"Si desitgeu canviar la configuració estàndard de l'altaveu, aquí és el lloc "
"a on fer-ho."

#. Tag: title
#: index.docbook:2854
#, no-c-format
msgid "Backend tab"
msgstr "Pestanya del dorsal"

# skip-rule: kct-backend
#. Tag: para
#: index.docbook:2868
#, no-c-format
msgid ""
"Depending on your operating system you may see options such as "
"<emphasis>Gstreamer</emphasis>, <emphasis>VLC</emphasis>, or <emphasis>DS9</"
"emphasis> (Windows) here. The recommended phonon-backend for &Linux; users "
"is <emphasis>VLC</emphasis> or <emphasis>Gstreamer</emphasis>."
msgstr ""
"Depenent del sistema operatiu, aquí podreu veure opcions com "
"<emphasis>GStreamer</emphasis>, <emphasis>VLC</emphasis>, o <emphasis>DS9</"
"emphasis> (Windows). El «phonon-backend» recomanat per als usuaris de "
"&Linux; és el <emphasis>VLC</emphasis> o el <emphasis>GStreamer</emphasis>."

# skip-rule: kct-backend
#. Tag: para
#: index.docbook:2870
#, no-c-format
msgid ""
"If you don't see <emphasis>VLC</emphasis> or <emphasis>Gstreamer</emphasis>, "
"install the package for it. For most distributions the package for "
"<emphasis>VLC</emphasis>, for example, would be <guilabel>phonon-backend-"
"vlc</guilabel>."
msgstr ""
"Si no veieu el <emphasis>VLC</emphasis> o el <emphasis>GStreamer</emphasis>, "
"instal·leu el paquet corresponent. Per a la majoria de distribucions, el "
"paquet del <emphasis>VLC</emphasis>, per exemple, seria <guilabel>phonon-"
"backend-vlc</guilabel>."

#. Tag: para
#: index.docbook:2872
#, no-c-format
msgid ""
"Each backend comes with its own codecs, so depending on the backend you "
"choose you will need to also download the codecs, as most distributions "
"don't ship them for legal reasons."
msgstr ""
"Cada dorsal ve amb els seus còdecs propis, de manera que depenent del dorsal "
"que escolliu haureu de descarregar els còdecs, ja que la majoria de "
"distribucions no els envien per motius legals."

#. Tag: title
#: index.docbook:2877
#, no-c-format
msgid "Notifications"
msgstr "Notificacions"

#. Tag: phrase
#: index.docbook:2886
#, no-c-format
msgid "<phrase>Notifications configuration dialog</phrase>"
msgstr "<phrase>Diàleg de configuració de notificacions</phrase>"

#. Tag: para
#: index.docbook:2889
#, no-c-format
msgid "<para>Notifications configuration dialog</para>"
msgstr "<para>Diàleg de configuració de notificacions</para>"

#. Tag: guilabel
#: index.docbook:2906
#, no-c-format
msgid "Use On-Screen Display"
msgstr "Utilitza el visualitzador en pantalla"

#. Tag: para
#: index.docbook:2909
#, no-c-format
msgid ""
"Check to enable the <emphasis>On-Screen Display</emphasis>. The "
"<emphasis>OSD</emphasis> briefly displays track data when a new track is "
"played. Once checked, the OSD will be visible on your screen and you can "
"drag it to the location you prefer."
msgstr ""
"Marqueu-ho per a activar la <emphasis>visualització en pantalla (OSD)</"
"emphasis>. L'<emphasis>OSD</emphasis> mostra breument les dades de la peça "
"quan es reprodueix una peça nova. Una vegada marcat, l'OSD serà visible a la "
"pantalla i el podeu arrossegar fins a la ubicació que preferiu."

#. Tag: guilabel
#: index.docbook:2914
#, no-c-format
msgid "Duration"
msgstr "Durada"

#. Tag: para
#: index.docbook:2917
#, no-c-format
msgid ""
"The time in milliseconds for which to show the OSD. The value must be "
"between 500 ms and 10000 ms."
msgstr ""
"El temps en mil·lisegons que s'ha de mostrar l'OSD. El valor ha d'estar "
"entre 500 ms i 10000 ms."

#. Tag: guilabel
#: index.docbook:2922
#, no-c-format
msgid "Screen"
msgstr "Pantalla"

#. Tag: para
#: index.docbook:2925
#, no-c-format
msgid ""
"Allows you to choose the screen that should display the OSD if you have a "
"multiscreen setup. Default is 0."
msgstr ""
"Us permet triar la pantalla que hauria de mostrar l'OSD si teniu una "
"configuració multipantalla. Per defecte és 0."

#. Tag: guilabel
#: index.docbook:2930
#, no-c-format
msgid "Translucent"
msgstr "Translúcida"

#. Tag: para
#: index.docbook:2933
#, no-c-format
msgid "Check to enable translucency if supported by your desktop system."
msgstr ""
"Marqueu-ho per a activar la translucidesa si el vostre sistema d'escriptori "
"ho permet."

#. Tag: guilabel
#: index.docbook:2938
#, no-c-format
msgid "Font scale"
msgstr "Escala de la lletra"

#. Tag: para
#: index.docbook:2941
#, no-c-format
msgid "(choose the size of the font in the OSD)"
msgstr "(trieu la mida de la lletra de l'OSD)"

#. Tag: guilabel
#: index.docbook:2946
#, no-c-format
msgid "Don't show when a fullscreen application is active"
msgstr "No mostris quan estigui activa una aplicació de pantalla completa"

#. Tag: para
#: index.docbook:2949
#, no-c-format
msgid ""
"Do not show On-Screen Display if another application is focused and running "
"in fullscreen mode."
msgstr ""
"No mostra l'OSD si hi ha una altra aplicació amb el focus i que s'executa en "
"mode de pantalla completa."

#. Tag: guilabel
#: index.docbook:2954
#, no-c-format
msgid "Use custom colors"
msgstr "Usa colors personalitzats"

#. Tag: para
#: index.docbook:2957
#, no-c-format
msgid ""
"Check to enable custom colors for the <emphasis>On-Screen Display</emphasis> "
"text."
msgstr ""
"Marqueu-ho per a activar els colors personalitzats per al text de "
"l'<emphasis>OSD</emphasis>."

#. Tag: guilabel
#: index.docbook:2962
#, no-c-format
msgid "Text color"
msgstr "Color del text"

#. Tag: para
#: index.docbook:2965
#, no-c-format
msgid "Click to select the color of the <emphasis>OSD</emphasis> text."
msgstr ""
"Feu clic per a seleccionar el color del text de l'<emphasis>OSD</emphasis>."

#. Tag: guilabel
#: index.docbook:2970
#, no-c-format
msgid "Use system notifications"
msgstr "Utilitza les notificacions del sistema"

#. Tag: para
#: index.docbook:2973
#, no-c-format
msgid ""
"Check to use the system notification. This can vary depending on your "
"desktop system and/or distribution."
msgstr ""
"Marqueu-ho per a utilitzar la notificació del sistema. Això pot variar "
"depenent del vostre sistema d'escriptori o distribució."

#. Tag: title
#: index.docbook:2980
#, no-c-format
msgid "<title>Database</title>"
msgstr "<title>Base de dades</title>"

#. Tag: phrase
#: index.docbook:2989
#, no-c-format
msgid "<phrase>External Database configuration dialog</phrase>"
msgstr "<phrase>Diàleg de configuració de la base de dades externa</phrase>"

#. Tag: para
#: index.docbook:2992
#, no-c-format
msgid "<para>External Database configuration dialog</para>"
msgstr "<para>Diàleg de configuració de la base de dades externa</para>"

#. Tag: para
#: index.docbook:2997
#, no-c-format
msgid ""
"The default database is already set to use embedded <guilabel>MySQL</"
"guilabel>. For most users there is no need to configure an external "
"database, as there is no change in performance. If you want to share your "
"database or use it remotely, you can configure an external <guilabel>MySQL</"
"guilabel> database."
msgstr ""
"La base de dades predeterminada ja està establerta per a utilitzar el "
"<guilabel>MySQL</guilabel> incrustat. Per a la majoria d'usuaris no hi ha "
"necessitat de configurar una base de dades externa, ja que no hi ha cap "
"canvi en el rendiment. Si voleu compartir la base de dades o utilitzar-la "
"remotament, podeu configurar una base de dades <guilabel>MySQL</guilabel> "
"externa."

#. Tag: para
#: index.docbook:2999
#, no-c-format
msgid ""
"&amarok; expects the external database and user account to already exist. "
"The user also requires full access to the database. You MUST restart "
"&amarok; after changing these settings."
msgstr ""
"L'&amarok; espera que la base de dades externa i el compte d'usuari ja "
"existeixin. L'usuari també necessita accés complet a la base de dades. Heu "
"de reiniciar l'&amarok; després de canviar aquests paràmetres."

#. Tag: para
#: index.docbook:3001
#, no-c-format
msgid ""
"If your database is not already set up, you can use the SQL commands in the "
"field at the bottom to do so, after replacing the password with the correct "
"one."
msgstr ""
"Si la base de dades encara no està configurada, podeu utilitzar les ordres "
"SQL en el camp de la part inferior per a fer-ho, després de substituir la "
"contrasenya per la correcta."

#. Tag: guilabel
#: index.docbook:3015
#, no-c-format
msgid "Use external MySQL Database"
msgstr "Usa una base de dades MySQL externa"

#. Tag: para
#: index.docbook:3018
#, no-c-format
msgid "Check to enable the use of an external database."
msgstr "Marqueu-ho per a activar l'ús d'una base de dades externa."

#. Tag: guilabel
#: index.docbook:3023
#, no-c-format
msgid "<guilabel>Server</guilabel>"
msgstr "<guilabel>Servidor</guilabel>"

#. Tag: para
#: index.docbook:3026
#, no-c-format
msgid "Enter the name of the existing <guilabel>MySQL</guilabel> server."
msgstr "Introduïu el nom del servidor <guilabel>MySQL</guilabel> existent."

#. Tag: guilabel
#: index.docbook:3031
#, no-c-format
msgid "Port"
msgstr "Port"

#. Tag: para
#: index.docbook:3034
#, no-c-format
msgid "Enter the port number to access the server. Default is port 3306."
msgstr ""
"Introduïu el número de port per a accedir al servidor. El port predeterminat "
"és 3306."

#. Tag: guilabel
#: index.docbook:3039
#, no-c-format
msgid "Username"
msgstr "Nom d'usuari"

#. Tag: para
#: index.docbook:3042
#, no-c-format
msgid "Enter the username to access the database with full access privileges."
msgstr ""
"Introduïu el nom d'usuari per a accedir a la base de dades amb privilegis "
"d'accés complet."

#. Tag: guilabel
#: index.docbook:3047
#, no-c-format
msgid "Password"
msgstr "Contrasenya"

#. Tag: para
#: index.docbook:3050
#, no-c-format
msgid "Enter the password for the default user."
msgstr "Introduïu la contrasenya de l'usuari predeterminat."

#. Tag: guilabel
#: index.docbook:3055
#, no-c-format
msgid "<guilabel>Database</guilabel>"
msgstr "<guilabel>Base de dades</guilabel>"

#. Tag: para
#: index.docbook:3058
#, no-c-format
msgid "Enter the name of the database. Default preset is amarokdb."
msgstr ""
"Introduïu el nom de la base de dades. De manera predeterminada, el "
"predefinit és «amarokdb»."

#. Tag: para
#: index.docbook:3064
#, no-c-format
msgid ""
"You can find more information about the External Database <link linkend="
"\"external-database\">here</link>."
msgstr ""
"Podeu trobar més informació sobre la base de dades externa <link linkend="
"\"external-database\">aquí</link>."

#. Tag: title
#: index.docbook:3067
#, no-c-format
msgid "Plugins"
msgstr "Connectors"

#. Tag: phrase
#: index.docbook:3076
#, no-c-format
msgid "<phrase>Plugins configuration dialog</phrase>"
msgstr "<phrase>Diàleg de configuració dels connectors</phrase>"

#. Tag: para
#: index.docbook:3079
#, no-c-format
msgid "<para>Plugins configuration dialog</para>"
msgstr "<para>Diàleg de configuració dels connectors</para>"

#. Tag: para
#: index.docbook:3084
#, no-c-format
msgid ""
"Plugins configuration controls <guilabel>Collections</guilabel>, "
"<guilabel>Internet Services</guilabel>, and <guilabel>Local Collection "
"Backends</guilabel>."
msgstr ""
"La configuració dels connectors controla les <guilabel>Col·leccions</"
"guilabel>, els <guilabel>Serveis d'Internet</guilabel>, i els "
"<guilabel>Dorsals de la col·lecció local</guilabel>."

#. Tag: title
#: index.docbook:3086
#, no-c-format
msgid "Collections"
msgstr "Col·leccions"

#. Tag: para
#: index.docbook:3087
#, no-c-format
msgid ""
"&amarok; offers you access to the following Collections, if they are "
"available:"
msgstr ""
"L'&amarok; us ofereix accés a les col·leccions següents, si estan "
"disponibles:"

#. Tag: entry
#: index.docbook:3094
#, no-c-format
msgid "<entry>Collection</entry>"
msgstr "<entry>Col·lecció</entry>"

#. Tag: guilabel
#: index.docbook:3101
#, no-c-format
msgid "AudioCD Collection"
msgstr "Col·lecció de CD d'àudio"

#. Tag: para
#: index.docbook:3104
#, no-c-format
msgid "AudioCD collection plugin for &amarok;"
msgstr "Connector de col·leccions de CD d'àudio per a l'&amarok;"

#. Tag: guilabel
#: index.docbook:3109
#, no-c-format
msgid "DAAP Collection"
msgstr "Col·lecció DAAP"

#. Tag: para
#: index.docbook:3112
#, no-c-format
msgid "DAAP collection plugin for &amarok;"
msgstr "Connector de col·leccions DAAP per a l'&amarok;"

#. Tag: guilabel
#: index.docbook:3117
#, no-c-format
msgid "iPod, iPad &amp; iPhone Collection"
msgstr "Col·leccions de l'iPod, iPad i iPhone"

#. Tag: para
#: index.docbook:3120
#, no-c-format
msgid "Plugin to use iPod-like devices as collections in &amarok;"
msgstr ""
"Connector per a usar dispositius de tipus iPod com a col·leccions en "
"l'&amarok;"

#. Tag: guilabel
#: index.docbook:3125
#, no-c-format
msgid "MTP Collection"
msgstr "Col·lecció MTP"

#. Tag: para
#: index.docbook:3128
#, no-c-format
msgid "MTP collection plugin for &amarok;"
msgstr "Connector de col·leccions MTP per a l'&amarok;"

#. Tag: guilabel
#: index.docbook:3133
#, no-c-format
msgid "Universal Mass Storage Collection"
msgstr "Col·lecció d'emmagatzematge massiu universal"

#. Tag: para
#: index.docbook:3136
#, no-c-format
msgid "UMS/USB collection plugin for &amarok;"
msgstr "Connector de col·lecció UMS/USB per a l'&amarok;"

#. Tag: guilabel
#: index.docbook:3141
#, no-c-format
msgid "UPnP Collection"
msgstr "Col·lecció UPnP"

#. Tag: para
#: index.docbook:3144
#, no-c-format
msgid "UPnP collection plugin for &amarok;"
msgstr "Connector de col·lecció UPnP per a l'&amarok;"

#. Tag: title
#: index.docbook:3151
#, no-c-format
msgid "Internet Services"
msgstr "Serveis d'Internet"

#. Tag: para
#: index.docbook:3152
#, no-c-format
msgid "&amarok; offers by default the following Internet services:"
msgstr "L'&amarok; ofereix per defecte els serveis d'Internet següents:"

#. Tag: entry
#: index.docbook:3159
#, no-c-format
msgid "Service"
msgstr "Servei"

#. Tag: entry
