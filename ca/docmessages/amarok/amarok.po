#. Tag: title
#: index.docbook:5854
#, no-c-format
msgid "Kubuntu and Ubuntu packages"
msgstr "Paquets de Kubuntu i Ubuntu"

#. Tag: para
#: index.docbook:5857
#, no-c-format
msgid ""
"A package for Moodbar is available in the official package repository; just "
