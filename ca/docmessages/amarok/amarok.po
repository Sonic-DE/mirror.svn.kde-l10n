#: index.docbook:1625 index.docbook:3543 index.docbook:4533 index.docbook:5019
#: index.docbook:5105 index.docbook:6973 index.docbook:7259 index.docbook:7518
#: index.docbook:7595 index.docbook:7720 index.docbook:7821
#, no-c-format
msgid "Menu Item"
msgstr "Elements del menú"

#. Tag: entry
