#, no-c-format
msgid "<guilabel>Previous Track</guilabel>"
msgstr "<guilabel>Peça anterior</guilabel>"

#. Tag: para
#: index.docbook:6995
#, no-c-format
msgid "Skips back to the last track played within your current session."
msgstr "Salta a l'última peça reproduïda a la sessió actual."

#. Tag: guilabel
#: index.docbook:7003
#, no-c-format
msgid "<guilabel>Play/Pause</guilabel>"
msgstr "<guilabel>Reproducció/Pausa</guilabel>"

#. Tag: para
#: index.docbook:7006
#, no-c-format
msgid "Starts or temporarily stops the playing of the current media file."
msgstr ""
