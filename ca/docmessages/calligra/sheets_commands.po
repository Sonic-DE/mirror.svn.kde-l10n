"<action>Insert a mathematical function.</action> See the section <link "
"linkend=\"formulas\">Formulae</link> for more details."
msgstr ""
"<action>Insereix una funció matemàtica.</action> Per a més detalls mireu la "
"secció <link linkend=\"formulas\">Fórmules</link>."

#. Tag: menuchoice
#: commands.docbook:561
#, no-c-format
msgid "<guimenu>Insert</guimenu> <guimenuitem>Series...</guimenuitem>"
msgstr "<guimenu>Insereix</guimenu> <guimenuitem>Sèries...</guimenuitem>"

