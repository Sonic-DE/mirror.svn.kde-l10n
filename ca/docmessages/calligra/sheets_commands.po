"<guimenu>Insert</guimenu> <guimenuitem>Special Character...</guimenuitem>"
msgstr ""
"<guimenu>Insereix</guimenu> <guimenuitem>Caràcter especial...</guimenuitem>"

#. Tag: action
#: commands.docbook:586
#, no-c-format
msgid "Insert a special character into the selected cell."
msgstr "Insereix un caràcter especial dintre de la cel·la seleccionada."

#. Tag: menuchoice
#: commands.docbook:621
#, no-c-format
msgid "<guimenu>Insert</guimenu> <guisubmenu>External Data</guisubmenu>"
msgstr "<guimenu>Insereix</guimenu> <guisubmenu>Dades externes</guisubmenu>"

#. Tag: para
#: commands.docbook:625
#, no-c-format
