"<action>Format selected cell(s).</action> See the <link linkend="
"\"formatspread\">Spreadsheet Formatting</link> section for more details."
msgstr ""
"<action>Dona format a les cel·les seleccionades</action> Per a més detalls "
"mireu la secció <link linkend=\"formatspread\">Dona format a fulls de "
"càlcul</link>."

#. Tag: menuchoice
#: commands.docbook:655
#, no-c-format
msgid "<guimenu>Format</guimenu> <guimenuitem>Style Manager</guimenuitem>"
msgstr "<guimenu>Format</guimenu> <guimenuitem>Gestor d'estils</guimenuitem>"

#. Tag: action
#: commands.docbook:659
#, no-c-format
msgid "Create, Modify or delete cell format styles."
msgstr "Crea, modifica o suprimeix els estils de format de cel·la."

#. Tag: menuchoice
#: commands.docbook:664
#, no-c-format
msgid "<guimenu>Format</guimenu> <guisubmenu>Style</guisubmenu>"
msgstr "<guimenu>Format</guimenu> <guisubmenu>Estil</guisubmenu>"

#. Tag: para
#: commands.docbook:668
#, no-c-format
msgid ""
"<action>Apply a style to selected cell(s).</action> To manage styles use "
"<menuchoice> <guimenu>Format</guimenu><guimenuitem>Style Manager...</"
"guimenuitem> </menuchoice>"
msgstr ""
"<action>Aplica un estil a les cel·les seleccionades.</action> Per a "
"gestionar els estils useu <menuchoice> <guimenu>Format</"
"guimenu><guimenuitem>Gestor d'estils...</guimenuitem> </menuchoice>"

#. Tag: menuchoice
#: commands.docbook:676
#, no-c-format
msgid ""
"<guimenu>Format</guimenu> <guimenuitem>Create Style From Cell...</"
"guimenuitem>"
msgstr ""
"<guimenu>Format</guimenu> <guimenuitem>Crea estil a partir de la cel·la...</"
"guimenuitem>"

#. Tag: para
#: commands.docbook:680
#, no-c-format
msgid ""
"<action>Create a new style from the format of the selected cell.</action> To "
"manage styles use <menuchoice> <guimenu>Format</guimenu><guimenuitem>Style "
"Manager...</guimenuitem> </menuchoice>"
msgstr ""
"<action>Crea un estil nou a partir del format de la cel·la seleccionada.</"
"action> Per a gestionar els estils useu <menuchoice> <guimenu>Format</"
"guimenu><guimenuitem>Gestor d'estils...</guimenuitem> </menuchoice>"

#. Tag: menuchoice
#: commands.docbook:689
#, no-c-format
msgid "<guimenu>Format</guimenu> <guimenuitem>AutoFormat...</guimenuitem>"
msgstr ""
"<guimenu>Format</guimenu> <guimenuitem>Format automàtic...</guimenuitem>"

#. Tag: action
#: commands.docbook:693
#, no-c-format
msgid ""
"Autoformat the selected cells: a dialog let you choose between two proposed "
"formats."
msgstr ""
"Dona format automàticament a les cel·les seleccionades: un diàleg us permet "
"escollir entre els dos formats proposats."

#. Tag: menuchoice
#: commands.docbook:698
#, no-c-format
msgid "<guimenu>Format</guimenu> <guimenuitem>Merge Cells</guimenuitem>"
msgstr ""
"<guimenu>Format</guimenu> <guimenuitem>Fusiona les cel·les</guimenuitem>"

