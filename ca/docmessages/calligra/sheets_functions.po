#: functions.docbook:3021
#, no-c-format
msgid "ACCRINT(issue; first interest; settlement; rate; par; frequency; basis)"
msgstr ""
"ACCRINT(resultat; primer interès; liquidació; proporció; nominal; "
"freqüència; base)"

