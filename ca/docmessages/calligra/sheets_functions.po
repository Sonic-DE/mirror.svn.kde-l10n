msgid "HYPGEOMDIST"
msgstr "HYPGEOMDIST"

#. Tag: para
#: functions.docbook:8145
#, no-c-format
msgid "The HYPGEOMDIST() function returns the hypergeometric distribution."
msgstr "La funció HYPGEOMDIST() retorna la distribució hipergeomètrica."

