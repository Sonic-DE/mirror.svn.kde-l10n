#, no-c-format
msgid "Column number"
msgstr "Número de columna"

#. Tag: seg
#: functions.docbook:5229
#, no-c-format
msgid "Absolute number (optional)"
msgstr "Número absolut (opcional)"

#. Tag: seg
#: functions.docbook:5230 functions.docbook:5434
#, no-c-format
msgid "A1 style (optional)"
msgstr "Estil A1 (opcional)"

#. Tag: seg
#: functions.docbook:5231
#, no-c-format
msgid "Sheet name"
msgstr "Nom del full"

#. Tag: para
#: functions.docbook:5234
#, no-c-format
msgid "ADDRESS(6; 4) returns $D$6"
msgstr "ADDRESS(6; 4) retorna $D$6"

#. Tag: para
#: functions.docbook:5237
#, no-c-format
msgid "ADDRESS(6; 4; 2) returns D$6"
msgstr "ADDRESS(6; 4; 2) retorna D$6"

#. Tag: para
#: functions.docbook:5240
#, no-c-format
msgid "ADDRESS(6; 4; 2; FALSE; \"Sheet1\") returns Sheet1!R6C[4]"
msgstr "ADDRESS(6; 4; 2; FALSE; \"Full1\") retorna Full1!R6C[4]"

#. Tag: para
#: functions.docbook:5243
#, no-c-format
msgid "ADDRESS(6; 4; 1; FALSE; \"Sheet1\") returns Sheet1!R6C4"
msgstr "ADDRESS(6; 4; 1; FALSE; \"Full1\") retorna Full1!R6C4"

#. Tag: para
#: functions.docbook:5246
#, no-c-format
msgid "ADDRESS(6; 4; 4; TRUE; \"Sheet1\") returns Sheet1!D6"
msgstr "ADDRESS(6; 4; 4; TRUE; \"Full1\") retorna Full1!D6"

#. Tag: title
#: functions.docbook:5252
#, no-c-format
msgid "AREAS"
msgstr "AREAS"

#. Tag: para
#: functions.docbook:5253
#, no-c-format
msgid ""
"Returns the number of areas in the reference string. An area can be asingle "
"cell or a set of cells."
msgstr ""
"Retorna el nombre d'àrees a la cadena de referència. Una àrea pot ser una "
"cel·la única o un conjunt de cel·les."

#. Tag: para
#: functions.docbook:5258
#, no-c-format
msgid "AREAS(reference)"
msgstr "AREAS(referència)"

#. Tag: para
#: functions.docbook:5265
#, no-c-format
msgid "AREAS(A1) returns 1"
msgstr "AREAS(A1) retorna 1"

#. Tag: para
#: functions.docbook:5268
#, no-c-format
msgid "AREAS((A1; A2:A4)) returns 2"
msgstr "AREAS((A1; A2:A4)) retorna 2"

#. Tag: title
#: functions.docbook:5274
#, no-c-format
msgid "CELL"
msgstr "CELL"

#. Tag: para
#: functions.docbook:5275
#, no-c-format
msgid ""
"Returns information about position, formatting or contents in a reference."
msgstr ""
"Retorna informació quant a la posició, format o contingut en una referència."

#. Tag: para
#: functions.docbook:5280
#, no-c-format
msgid "CELL(type; reference)"
msgstr "CELL(tipus; referència)"

#. Tag: para
#: functions.docbook:5288
#, no-c-format
msgid "CELL(\"COL\", C7) returns 3"
msgstr "CELL(\"COL\", C7) retorna 3"

#. Tag: para
#: functions.docbook:5291
#, no-c-format
msgid "CELL(\"ROW\", C7) returns 7"
msgstr "CELL(\"ROW\", C7) retorna 7"

#. Tag: para
#: functions.docbook:5294
#, no-c-format
msgid "CELL(\"ADDRESS\", C7) returns $C$7"
msgstr "CELL(\"ADDRESS\", C7) retorna $C$7"

#. Tag: title
#: functions.docbook:5300
#, no-c-format
msgid "CHOOSE"
msgstr "CHOOSE"

#. Tag: para
#: functions.docbook:5301
#, no-c-format
msgid "Returns the parameter specified by the index."
msgstr "Retorna el paràmetre especificat per l'índex."

#. Tag: para
#: functions.docbook:5306
#, no-c-format
msgid "CHOOSE(index; parameter1; parameter2;...)"
msgstr "CHOOSE(índex; paràmetre1; paràmetre2;...)"

#. Tag: seg
#: functions.docbook:5310
#, no-c-format
msgid "Index"
msgstr "Índex"

#. Tag: seg
#: functions.docbook:5311
#, no-c-format
msgid "Arguments"
msgstr "Arguments"

#. Tag: para
#: functions.docbook:5314
#, no-c-format
msgid "CHOOSE(1; \"1st\"; \"2nd\") returns \"1st\""
msgstr "CHOOSE(1; \"1r\"; \"2n\") retorna «1r»"

#. Tag: para
#: functions.docbook:5317
#, no-c-format
msgid "CHOOSE(2; 3; 2; 4) returns 2"
msgstr "CHOOSE(2; 3; 2; 4) retorna 2"

#. Tag: title
#: functions.docbook:5323
#, no-c-format
msgid "COLUMN"
msgstr "COLUMN"

#. Tag: para
#: functions.docbook:5324
#, no-c-format
msgid ""
"The COLUMN function returns the column of given cell reference. If no "
"parameter is specified the column of the current cell gets returned."
msgstr ""
"La funció COLUMN() retorna la columna de la cel·la de referència donada. Si "
"no s'especifica cap paràmetre, es retorna la columna de la cel·la actual."

#. Tag: para
#: functions.docbook:5329
#, no-c-format
msgid "COLUMN(reference)"
msgstr "COLUMN(referència)"

#. Tag: para
#: functions.docbook:5336
#, no-c-format
msgid "COLUMN(A1) returns 1"
msgstr "COLUMN(A1) retorna 1"

#. Tag: para
#: functions.docbook:5339
#, no-c-format
msgid "COLUMN(D2) returns 4"
msgstr "COLUMN(D2) retorna 4"

