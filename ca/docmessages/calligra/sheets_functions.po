#, no-c-format
msgid "PPMT"
msgstr "PPMT"

#. Tag: para
#: functions.docbook:3978
#, no-c-format
msgid ""
"PPMT calculates the amount of a payment of an annuity going towards "
"principal."
msgstr ""
"PPMT calcula la quantitat d'un pagament d'una renda anual cap al capital "
"principal."

#. Tag: para
#: functions.docbook:3989
#, no-c-format
msgid "PPMT(Rate; Period; NPer; PV [; FV = 9 [; Type = 0 ]] )"
msgstr "PPMT(taxa; període; NPer; vp; vf; [; FV = 9 [; Type = 0 ]] )"

