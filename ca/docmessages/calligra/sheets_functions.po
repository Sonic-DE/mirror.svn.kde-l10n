msgid "ISNOTTEXT(12) returns True"
msgstr "ISNOTTEXT(12) retorna Cert"

#. Tag: para
#: functions.docbook:4736
#, no-c-format
msgid "ISNOTTEXT(\"hello\") returns False"
msgstr "ISNOTTEXT(\"hola\") retorna Fals"

#. Tag: member
