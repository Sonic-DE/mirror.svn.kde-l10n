#, no-c-format
msgid "<title>PMT</title>"
msgstr "<title>PMT</title>"

#. Tag: para
#: functions.docbook:3946
#, no-c-format
msgid ""
"PMT returns the amount of payment for a loan based on a constant interest "
"rate and constant payments (each payment is equal amount)."
msgstr ""
"PMT retorna la quantitat de pagaments per a un préstec basat en una taxa "
"d'interès i pagaments constants (cada pagament és de la mateixa quantitat)."

#. Tag: para
#: functions.docbook:3951
#, no-c-format
