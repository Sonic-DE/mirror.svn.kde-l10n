msgstr "<guimenu>Joc</guimenu> <guimenuitem>Repetició</guimenuitem>"

#. Tag: para
#: index.docbook:153
#, no-c-format
msgid "Replay the last game."
msgstr "Torna a jugar l'última partida."

#. Tag: menuchoice
