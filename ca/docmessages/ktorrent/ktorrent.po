#. Tag: para
#: index.docbook:40
#, no-c-format
msgid ""
"&ktorrent; is a bittorrent application by KDE which allows you to download "
"files using the BitTorrent protocol. It enables you to run multiple torrents "
"at the same time and comes with extended features to make it a full-featured "
"client for BitTorrent."
msgstr ""
"El &ktorrent; és una aplicació de bittorrent creada per la comunitat KDE que "
"us permetrà descarregar fitxers utilitzant el protocol BitTorrent. Permet "
"executar múltiples torrents alhora i ve amb característiques esteses per a "
"fer-lo un client complet per a BitTorrent."

#. Tag: title
#: index.docbook:43
#, no-c-format
msgid "Features"
msgstr "Característiques"

#. Tag: para
#: index.docbook:44
#, no-c-format
msgid "Queuing of torrents"
msgstr "Cua dels torrents"

#. Tag: para
#: index.docbook:45
#, no-c-format
msgid "Global and per torrent speed limits"
msgstr "Límits de velocitat global i per torrent"

#. Tag: para
#: index.docbook:46
#, no-c-format
msgid "Previewing of certain file types, build in (video and audio)"
msgstr "Vista prèvia de certs tipus de fitxers, construït en (vídeo i àudio)"

#. Tag: para
#: index.docbook:47
#, no-c-format
msgid "Importing of partially or fully downloaded files"
msgstr "Importació de fitxers descarregats parcialment o del tot"

#. Tag: para
#: index.docbook:48
#, no-c-format
msgid "File prioritization for multi-file torrents"
msgstr "Priorització de fitxers per a torrents amb múltiples fitxers"

#. Tag: para
#: index.docbook:49
#, no-c-format
msgid "Selective downloading for multi-file torrents"
msgstr "Descàrrega selectiva per a torrents amb múltiples fitxers"

#. Tag: para
#: index.docbook:50
#, no-c-format
msgid ""
"Kick/ban peers with an additional IP Filter dialog for list/edit purposes"
msgstr ""
"Expulsa/veta els parells amb un diàleg de filtre d'IP addicional per a "
"finalitats de llista/edició"

#. Tag: para
#: index.docbook:51
#, no-c-format
msgid "UDP tracker support"
msgstr "Suport del seguidor UDP"

#. Tag: para
#: index.docbook:52
#, no-c-format
msgid "Support for private trackers and torrents"
msgstr "Suport per a seguidors i torrents privats"

#. Tag: para
#: index.docbook:53
#, no-c-format
msgid "Support for µTorrent's peer exchange"
msgstr "Suport per a l'intercanvi entre parells de µTorrent"

#. Tag: para
#: index.docbook:54
#, no-c-format
msgid "Support for protocol encryption (compatible with Azureus)"
msgstr "Suport per a encriptatge del protocol (compatible amb Azureus)"

#. Tag: para
#: index.docbook:55
#, no-c-format
msgid "Support for creating trackerless torrents"
msgstr "Suport per a la creació de torrents sense seguidors"

#. Tag: para
#: index.docbook:56
#, no-c-format
msgid "Support for distributed hash tables (DHT, the Mainline version)"
msgstr ""
"Suport per a taules de resum distribuïdes (DHT, la versió de la línia "
"principal)"

#. Tag: para
#: index.docbook:57
#, no-c-format
msgid ""
"Support for UPnP to automatically forward ports on a LAN with dynamic "
"assigned hosts"
msgstr ""
"Suport per a UPnP per a desviar automàticament els ports de la LAN amb "
"assignació dinàmica de màquines"

#. Tag: para
#: index.docbook:58
#, no-c-format
msgid "Support for webseeds"
msgstr "Suport per a sembradors web"

#. Tag: para
#: index.docbook:59
#, no-c-format
msgid "System tray integration"
msgstr "Integració amb la safata del sistema"

#. Tag: para
#: index.docbook:60
#, no-c-format
msgid "Tracker authentication support"
msgstr "Suport d'autenticació del seguidor"

#. Tag: para
#: index.docbook:61
#, no-c-format
msgid "Connection though a proxy"
msgstr "Connexió a través d'un servidor intermediari"

#. Tag: para
#: index.docbook:62
#, no-c-format
msgid "Interprocess control via DBus interface"
msgstr "Control entre processos a través de la interfície de DBus"

