#: index.docbook:1601
#, no-c-format
msgid "<entry>Copy</entry>"
msgstr "<entry>Copia</entry>."

#. Tag: keycombo
#: index.docbook:1605
#, no-c-format
msgid "&Ctrl;<keycap>R</keycap>"
msgstr "&Ctrl;<keycap>R</keycap>"

# skip-rule: punctuation-period-no
