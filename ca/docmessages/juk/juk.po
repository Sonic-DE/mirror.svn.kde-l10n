msgid ""
"&juk; Copyright &copy; 2002-2013 &Scott.Wheeler;, Michael Pyne, and others."
msgstr ""
"&juk; Copyright &copy; 2002-2013 &Scott.Wheeler;, Michael Pyne i altra gent."

#. Tag: para
#: index.docbook:1651
#, no-c-format
