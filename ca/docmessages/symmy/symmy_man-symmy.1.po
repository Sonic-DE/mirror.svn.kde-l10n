"&Elvis.Angelaccio; &Elvis.Angelaccio.mail; <personblurb><para>Autor d'aquest "
"programa i aquesta pàgina man</para></personblurb>"

#. Tag: date
#: man-symmy.1.docbook:17
#, no-c-format
msgid "2017-11-25"
msgstr "25 de novembre de 2017"

#. Tag: releaseinfo
#: man-symmy.1.docbook:18
#, no-c-format
msgid "symmy 0.70"
msgstr "symmy 0.70"

#. Tag: manvolnum
#: man-symmy.1.docbook:23
#, no-c-format
