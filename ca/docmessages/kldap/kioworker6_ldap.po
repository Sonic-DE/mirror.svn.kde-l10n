#. Tag: para
#: index.docbook:17
#, no-c-format
msgid ""
"<acronym>ldap</acronym> is the lightweight directory access protocol. It "
"provides access to an X.500 directory, or to a stand-alone <acronym>LDAP</"
"acronym> server."
msgstr ""
"<acronym>ldap</acronym> és un protocol lleuger per a accedir als directoris. "
"Proporciona accés a un directori X.500 o a un servidor <acronym>LDAP</"
"acronym> autònom."

#. Tag: para
#: index.docbook:21
#, no-c-format
msgid "You can use the ldap KIO worker as follows:"
msgstr "Podeu utilitzar el procés de treball KIO «ldap» del mode següent:"

# skip-rule: punctuation-period-no
#. Tag: para
#: index.docbook:23
#, no-c-format
msgid ""
"<userinput>ldap://host:port/ou=People,o=where,c=de??sub</userinput> for a "
"subtree-query"
msgstr ""
"<userinput>ldap://màquina:port/ou=Gent,o=on,c=de??sub</userinput> per a una "
"petició subarbrada."

#. Tag: para
#: index.docbook:26
#, no-c-format
msgid ""
"or <userinput>ldap://host:port/cn=MM,ou=People,o=where,c=de??base</"
"userinput> for a complete branch."
msgstr ""
"o <userinput>ldap://màquina:port/cn=MM,ou=Gent,o=on,c=de??base</userinput> "
"per a obtenir una branca completa."
