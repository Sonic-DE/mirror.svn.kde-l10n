msgstr "Finestra de configuració del &kget;."

#. Tag: menuchoice
#: index.docbook:160
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Configure &kget;</guimenuitem>"
msgstr ""
"<guimenu>Arranjament</guimenu> <guimenuitem>Configura el &kget;...</"
"guimenuitem>"

# skip-rule: punctuation-period-no
#. Tag: action
#: index.docbook:164
#, no-c-format
msgid "Opens the &kget; configuration window"
msgstr "Obre la finestra de configuració del &kget;."

#. Tag: title
#: index.docbook:169
#, no-c-format
msgid "<title>Appearance</title>"
msgstr "<title>Aparença</title>"

#. Tag: screeninfo
#: index.docbook:172
#, no-c-format
msgid "<screeninfo>Appearance</screeninfo>"
msgstr "<screeninfo>Aparença</screeninfo>"

#. Tag: phrase
