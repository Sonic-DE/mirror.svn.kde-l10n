msgstr ""
"<guimenu>Client LSP</guimenu> <guisubmenu>Inclou la declaració a les "
"referències</guisubmenu>"

#. Tag: para
#: plugins.docbook:2471
#, no-c-format
msgid "Request to include a symbol's declaration when requesting references."
msgstr ""
"Sol·licita incloure la declaració d'un símbol quan se sol·liciten les "
"referències."

#. Tag: menuchoice
#: plugins.docbook:2476
#, no-c-format
msgid ""
"<guimenu>LSP Client</guimenu> <guisubmenu>Add parentheses upon function "
"completion</guisubmenu>"
msgstr ""
"<guimenu>Client LSP</guimenu> <guisubmenu>Afegeix un parèntesi a la "
"finalització de la funció</guisubmenu>"

#. Tag: para
#: plugins.docbook:2481
#, no-c-format
msgid "Automatically add a pair of parentheses after completion of a function."
msgstr ""
"Afegeix automàticament una parella de parèntesis després de completar una "
"funció."

#. Tag: menuchoice
#: plugins.docbook:2486
#, no-c-format
msgid ""
"<guimenu>LSP Client</guimenu> <guisubmenu>Show hover information</guisubmenu>"
msgstr ""
"<guimenu>Client LSP</guimenu> <guisubmenu>Mostra la informació en passar per "
"sobre</guisubmenu>"

#. Tag: para
#: plugins.docbook:2491
#, no-c-format
msgid ""
"Show hover information upon (mouse cursor) hover. Regardless of this "
"setting, the request can always be manually initiated."
msgstr ""
"Mostra informació en passar per sobre (cursor del ratolí). Independentment "
"d'aquesta opció de configuració, la sol·licitud sempre es podrà iniciar "
"manualment."

#. Tag: menuchoice
#: plugins.docbook:2498
#, no-c-format
msgid "<guimenu>LSP Client</guimenu> <guisubmenu>Format on typing</guisubmenu>"
msgstr ""
"<guimenu>Client LSP</guimenu> <guisubmenu>Format per a escriure</guisubmenu>"

#. Tag: para
#: plugins.docbook:2503
#, no-c-format
msgid ""
"[document/onTypeFormatting] Format parts of document when typing certain "
"trigger characters. For example, this might apply indentation upon newline, "
"or as otherwise determined by LSP Server. Note that editor indentation "
"scripts might be trying to do the same (depending on the mode) and so it may "
"not be advisable to have both enabled at the same time."
msgstr ""
"[document/onTypeFormatting] Dona format a parts del document en escriure "
"certs caràcters desencadenants. Per exemple, es podria aplicar sagnat a la "
"línia nova, o segons ho determini el servidor LSP. Recordeu que els scripts "
"de sagnat de l'editor podrien estar intentant fer el mateix (segons el mode) "
"i, per tant, podria no ser recomanable tenir ambdós habilitats alhora."

#. Tag: menuchoice
#: plugins.docbook:2512
#, no-c-format
msgid ""
"<guimenu>LSP Client</guimenu> <guisubmenu>Incremental document "
"synchronization</guisubmenu>"
msgstr ""
"<guimenu>Client LSP</guimenu> <guisubmenu>Sincronització incremental de la "
"documentació</guisubmenu>"

#. Tag: para
#: plugins.docbook:2517
#, no-c-format
msgid ""
"Send partial document edits to update the server rather than whole document "
"text (if supported)."
msgstr ""
"Envia edicions parcials del document per a actualitzar el servidor en lloc "
"de tot el text del document (si està admès)."

#. Tag: menuchoice
#: plugins.docbook:2522
#, no-c-format
msgid ""
"<guimenu>LSP Client</guimenu> <guisubmenu>Highlight goto location</"
"guisubmenu>"
msgstr ""
"<guimenu>Client LSP</guimenu> <guimenuitem>Ressalta la ubicació «goto»</"
"guimenuitem>"

#. Tag: para
#: plugins.docbook:2527
#, no-c-format
msgid ""
"Provide a transient visual cue after performing a goto to a location (of "
"definition, declaration, etc)."
msgstr ""
"Proporciona una indicació visual transitòria després de realitzar un «goto» "
"a una ubicació (de definició, declaració, etc.)."

#. Tag: menuchoice
#: plugins.docbook:2532
#, no-c-format
msgid ""
"<guimenu>LSP Client</guimenu> <guisubmenu>Show diagnostics notifications</"
"guisubmenu>"
msgstr ""
"<guimenu>Client LSP</guimenu> <guisubmenu>Mostra les notificacions de "
"diagnòstic</guisubmenu>"

#. Tag: para
#: plugins.docbook:2537
#, no-c-format
msgid ""
"[textDocument/publishDiagnostics] Process and show diagnostics notifications "
"sent by server."
msgstr ""
"[textDocument/publishDiagnostics] Processa i mostra les notificacions de "
"diagnòstic enviades pel servidor."

#. Tag: menuchoice
#: plugins.docbook:2542
#, no-c-format
msgid ""
"<guimenu>LSP Client</guimenu> <guisubmenu>Show diagnostics highlights</"
"guisubmenu>"
msgstr ""
"<guimenu>Client LSP</guimenu> <guimenuitem>Mostra els ressaltats de "
"diagnòstic</guimenuitem>"

#. Tag: para
#: plugins.docbook:2547
#, no-c-format
msgid "Add text highlights for ranges indicated in diagnostics."
msgstr ""
"Afegeix ressaltat del text per als intervals indicats en el diagnòstic."

#. Tag: menuchoice
#: plugins.docbook:2552
#, no-c-format
msgid ""
"<guimenu>LSP Client</guimenu> <guisubmenu>Show diagnostics marks</guisubmenu>"
msgstr ""
"<guimenu>Client LSP</guimenu> <guimenuitem>Mostra les marques de diagnòstic</"
"guimenuitem>"

#. Tag: para
#: plugins.docbook:2557
#, no-c-format
msgid "Add document marks for lines indicated in diagnostics."
msgstr ""
"Afegeix marques al document per a les línies indicades en el diagnòstic."

#. Tag: menuchoice
#: plugins.docbook:2562
#, no-c-format
msgid ""
"<guimenu>LSP Client</guimenu> <guisubmenu>Switch to diagnostic tab</"
"guisubmenu>"
msgstr ""
"<guimenu>Client LSP</guimenu> <guisubmenu>Canvia a la pestanya diagnòstic</"
"guisubmenu>"

#. Tag: para
#: plugins.docbook:2567
#, no-c-format
msgid "Switch to the diagnostic tab in the plugin toolview."
msgstr "Canvia a la pestanya de diagnòstic en la vista d'eina del connector."

#. Tag: menuchoice
#: plugins.docbook:2572
#, no-c-format
msgid ""
"<guimenu>LSP Client</guimenu> <guisubmenu>Close all non-diagnostics tabs</"
"guisubmenu>"
msgstr ""
"<guimenu>Client LSP</guimenu> <guisubmenu>Tanca totes les pestanyes que no "
"siguin de diagnòstic</guisubmenu>"

# skip-rule: abbreviations-eg
#. Tag: para
#: plugins.docbook:2577
#, no-c-format
msgid "Close all non-diagnostics (&eg; references) tabs in plugin toolview."
msgstr ""
"Tanca totes les pestanyes no siguin de diagnòstic (&pex;, referències) a la "
"vista d'eina del connector."

#. Tag: menuchoice
#: plugins.docbook:2582
#, no-c-format
msgid ""
"<guimenu>LSP Client</guimenu> <guisubmenu>Restart LSP Server</guisubmenu>"
msgstr ""
"<guimenu>Client LSP</guimenu> <guimenuitem>Reinicia el servidor LSP</"
"guimenuitem>"

#. Tag: para
#: plugins.docbook:2587
#, no-c-format
msgid "Restart current document's LSP Server."
msgstr "Torna a iniciar el servidor LSP del document actual."

#. Tag: menuchoice
#: plugins.docbook:2592
#, no-c-format
msgid ""
"<guimenu>LSP Client</guimenu> <guisubmenu>Restart all LSP Servers</"
"guisubmenu>"
msgstr ""
"<guimenu>Client LSP</guimenu> <guimenuitem>Reinicia tots els servidors LSP</"
"guimenuitem>"

#. Tag: para
#: plugins.docbook:2597
#, no-c-format
msgid "Stop all LSP Servers which will then be (re)started as needed."
msgstr ""
"Atura tots els servidors LSP que després es tornaran a iniciar o només "
"iniciar segons calgui."

#. Tag: title
#: plugins.docbook:2606
#, no-c-format
msgid "Goto Symbol support"
msgstr "Implementació del símbol «goto»"

#. Tag: para
#: plugins.docbook:2607
#, no-c-format
msgid ""
"LSP Client can help you jump to any symbol in your project or current file. "
"To jump to any symbol in the file, use the toolview \"LSP Client Symbol "
"Outline\" on the right border of kate. This toolview lists all symbols found "
"by the server in current document."
msgstr ""
"El client LSP pot ajudar-vos a saltar a qualsevol símbol en el vostre "
"projecte o fitxer actual. Per a saltar a qualsevol símbol del fitxer, useu "
"la vista d'eina «Client LSP de símbols d'esquema» a la vora dreta del Kate. "
"Aquesta vista d'eina llista tots els símbols trobats pel servidor en el "
"document actual."

#. Tag: title
#: plugins.docbook:2616
#, no-c-format
msgid "Configuring LSP Client Symbol Outline"
msgstr "Configuració del client LSP de símbols d'esquema"

#. Tag: para
#: plugins.docbook:2618
#, no-c-format
msgid ""
"By default the symbols are sorted by their occurrence in the document but "
"you can change the sort to be alphabetical. To do so, right click in the "
"toolview and check \"Sort Alphabetically\"."
msgstr ""
"De manera predeterminada, els símbols s'ordenen per la seva aparició en el "
"document, però podeu canviar l'ordenació perquè sigui alfabètica. Per a fer-"
"ho, feu clic dret a la vista d'eina i marqueu «Ordena alfabèticament»."

#. Tag: para
#: plugins.docbook:2624
#, no-c-format
msgid ""
"The toolview shows the symbols in tree mode by default, however you can "
"change it to a list using the context menu."
msgstr ""
"La vista d'eina mostra els símbols en mode arbre de manera predeterminada, "
"però podeu canviar-ho a una llista utilitzant el menú contextual."

#. Tag: title
#: plugins.docbook:2631
#, no-c-format
msgid "Global Goto symbol support"
msgstr "Implementació del símbol «goto» global"

#. Tag: para
#: plugins.docbook:2632
#, no-c-format
msgid ""
"To jump to any symbol in your project, you can open the goto symbol dialog "
"using <keycombo action=\"simul\">&Ctrl;&Alt;<keycap>p</keycap></keycombo>. "
"The dialog is empty when it opens but as soon as you type something the "
"dialog will start showing you matching symbols. The quality of matches as "
"well as filtering capabilities depend upon the server that you use. For "
"example, clangd supports fuzzy filtering but some other server may not."
msgstr ""
"Per a saltar a qualsevol símbol del projecte, podeu obrir el diàleg del "
"símbol «goto» utilitzant <keycombo action=\"simul\">&Ctrl;&Alt;<keycap>p</"
"keycap></keycombo>. El diàleg està buit quan s'obre però tan aviat com "
"escriviu alguna cosa el diàleg començarà a mostrar-vos símbols coincidents. "
"La qualitat de les coincidències i les capacitats de filtratge depenen del "
"servidor que utilitzeu. Per exemple, el «clangd» admet un filtratge "
"aproximat, però pot ser que altres servidors no."

#. Tag: title
#: plugins.docbook:2644
#, no-c-format
msgid "Other Features"
msgstr "Altres característiques"

#. Tag: para
#: plugins.docbook:2646
#, no-c-format
msgid ""
"Clangd switch source header command is supported. To switch source header in "
"a C or C++ project either use the \"Switch Source Header\" option from the "
"context menu or the shortcut <keycombo action=\"simul\"><keycap>F12</"
"keycap></keycombo>."
msgstr ""
"S'admet l'ordre de la capçalera del codi font de commutació del «clangd». "
"Per a canviar la capçalera d'origen en un projecte de C o C++ utilitzeu "
"l'opció «Commuta la capçalera del codi font» des del menú contextual o la "
"drecera <keycombo action=\"simul\"><keycap>F12</keycap></keycombo>."

#. Tag: para
#: plugins.docbook:2651
#, no-c-format
msgid ""
"You can jump to a symbol quickly by putting your mouse over the symbol and "
"then pressing <keycombo action=\"simul\">&Ctrl;</keycombo> + left mouse "
"button."
msgstr ""
"Podeu saltar a un símbol ràpidament posant el ratolí sobre el símbol i "
"després prement <keycombo action=\"simul\">&Ctrl;</keycombo> + botó esquerre "
"del ratolí."

#. Tag: para
#: plugins.docbook:2661
#, no-c-format
msgid ""
"The plugin's configuration page mostly allows for persistent configuration "
"of some of the above menu items. However, there is one additional entry to "
"specify the Server Configuration file. This is a &JSON; file that can be "
"used to specify the LSP server to start (and then to communicate with over "
"stdin/stdout). For convenience, some default configuration is included, "
"which can be inspected in the plugin's configuration page. To aid in the "
"explanation below, an excerpt of that configuration is given here:"
msgstr ""
"La pàgina de configuració del connector permet principalment la configuració "
"persistent d'alguns dels elements de menú anteriors. No obstant això, hi ha "
"una entrada addicional per a especificar el fitxer de configuració del "
"servidor. Aquest és un fitxer &JSON; que es pot utilitzar per a especificar "
"el servidor LSP a iniciar (i després s'hi comunica sobre l'entrada/sortida "
"estàndard). Per comoditat, s'inclou alguna configuració predeterminada, el "
"qual es pot inspeccionar en la pàgina de configuració del connector. Per a "
"ajudar en l'explicació a sota, aquí es proporciona un extracte d'aquesta "
"configuració:"

# skip-rule: rst-asterisk1
#. Tag: screen
#: plugins.docbook:2671
#, no-c-format
msgid ""
"{\n"
"    \"servers\": {\n"
"        \"bibtex\": {\n"
"            \"use\": \"latex\",\n"
"            \"highlightingModeRegex\": \"^BibTeX$\"\n"
"        },\n"
"        \"c\": {\n"
"            \"command\": [\"clangd\", \"-log=error\", \"--background-index"
"\"],\n"
"            \"commandDebug\": [\"clangd\", \"-log=verbose\", \"--background-"
"index\"],\n"
"            \"url\": \"https://clang.llvm.org/extra/clangd/\",\n"
"            \"highlightingModeRegex\": \"^(C|ANSI C89|Objective-C)$\"\n"
"        },\n"
"        \"cpp\": {\n"
"            \"use\": \"c\",\n"
"            \"highlightingModeRegex\": \"^(C\\\\+\\\\+|ISO C\\\\+\\\\+|"
"Objective-C\\\\+\\\\+)$\"\n"
"        },\n"
"        \"d\": {\n"
"            \"command\": [\"dls\", \"--stdio\"],\n"
"            \"url\": \"https://github.com/d-language-server/dls\",\n"
"            \"highlightingModeRegex\": \"^D$\"\n"
"        },\n"
"        \"fortran\": {\n"
"            \"command\": [\"fortls\"],\n"
"            \"rootIndicationFileNames\": [\".fortls\"],\n"
"            \"url\": \"https://github.com/hansec/fortran-language-server\",\n"
"            \"highlightingModeRegex\": \"^Fortran.*$\"\n"
"        },\n"
"        \"javascript\": {\n"
"            \"command\": [\"typescript-language-server\", \"--stdio\"],\n"
"            \"rootIndicationFileNames\": [\"package.json\", \"package-lock."
"json\"],\n"
"            \"url\": \"https://github.com/theia-ide/typescript-language-"
"server\",\n"
"            \"highlightingModeRegex\": \"^JavaScript.*$\",\n"
"            \"documentLanguageId\": false\n"
"        },\n"
"        \"latex\": {\n"
"            \"command\": [\"texlab\"],\n"
"            \"url\": \"https://texlab.netlify.com/\",\n"
"            \"highlightingModeRegex\": \"^LaTeX$\"\n"
"        },\n"
"        \"go\": {\n"
"            \"command\": [\"go-langserver\"],\n"
"            \"commandDebug\": [\"go-langserver\", \"-trace\"],\n"
"            \"url\": \"https://github.com/sourcegraph/go-langserver\",\n"
"            \"highlightingModeRegex\": \"^Go$\"\n"
"        },\n"
"        \"python\": {\n"
"            \"command\": [\"python3\", \"-m\", \"pyls\", \"--check-parent-"
"process\"],\n"
"            \"url\": \"https://github.com/palantir/python-language-server"
"\",\n"
"            \"highlightingModeRegex\": \"^Python$\"\n"
"        },\n"
"        \"rust\": {\n"
"            \"command\": [\"rls\"],\n"
"            \"path\": [\"%{ENV:HOME}/.cargo/bin\", \"%{ENV:USERPROFILE}/."
"cargo/bin\"],\n"
"            \"rootIndicationFileNames\": [\"Cargo.lock\", \"Cargo.toml\"],\n"
"            \"url\": \"https://github.com/rust-lang/rls\",\n"
"            \"highlightingModeRegex\": \"^Rust$\"\n"
"        },\n"
"        \"ocaml\": {\n"
"            \"command\": [\"ocamlmerlin-lsp\"],\n"
"            \"url\": \"https://github.com/ocaml/merlin\",\n"
"            \"highlightingModeRegex\": \"^Objective Caml.*$\"\n"
"        }\n"
"    }\n"
"}"
msgstr ""
