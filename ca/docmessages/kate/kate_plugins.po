msgstr ""
"Mostra la documentació per a un element seleccionat a la llista de compleció."

#. Tag: menuchoice
#: plugins.docbook:2456
#, no-c-format
msgid ""
"<guimenu>LSP Client</guimenu> <guisubmenu>Enable signature help with auto "
"completion</guisubmenu>"
msgstr ""
"<guimenu>Client LSP</guimenu> <guimenuitem>Activa l'ajuda de signatures amb "
"la compleció automàtica</guimenuitem>"

#. Tag: para
#: plugins.docbook:2461
#, no-c-format
msgid "Also show signature help in the completion list."
msgstr "També es mostrarà ajuda de la signatura a la llista de compleció."

#. Tag: menuchoice
#: plugins.docbook:2466
#, no-c-format
msgid ""
