#. Tag: para
#: index.docbook:59
#, no-c-format
msgid ""
"GCompris is a multi-activity educational software. This documentation is for "
"the gcompris-teachers administration tool we provide."
msgstr ""
"El GCompris és un programari educatiu multiactivitat. Aquesta documentació "
"és per a l'eina d'administració gcompris-teachers que proporcionem."

#. Tag: keyword
#: index.docbook:65
#, no-c-format
msgid "<keyword>KDE</keyword>"
