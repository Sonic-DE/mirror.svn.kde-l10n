"shortcut> <guimenu>Visualitza</guimenu> <guimenuitem>Amplia</guimenuitem>"

#. Tag: action
#: index.docbook:231
#, no-c-format
msgid "Increase the view of the filemap."
msgstr "Augmenta la vista del mapa de fitxers."

#. Tag: menuchoice
#: index.docbook:236
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>-</keycap></keycombo> </"
"shortcut> <guimenu>View</guimenu> <guimenuitem>Zoom Out</guimenuitem>"
