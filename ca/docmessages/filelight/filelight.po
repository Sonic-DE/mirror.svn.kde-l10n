"keycombo> </shortcut> <guimenu>Ves</guimenu> <guimenuitem>Amunt</guimenuitem>"

#. Tag: action
#: index.docbook:258
#, no-c-format
msgid "Moves you up one step in the filesystem to the parent folder."
msgstr "Mou un pas amunt en el sistema de fitxers a la carpeta pare."

#. Tag: menuchoice
#: index.docbook:262
#, no-c-format
msgid "<guimenu>Go</guimenu> <guimenuitem>Back</guimenuitem>"
msgstr "<guimenu>Ves</guimenu> <guimenuitem>Enrere</guimenuitem>"

#. Tag: action
