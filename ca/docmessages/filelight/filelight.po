"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>-</keycap></keycombo> </"
"shortcut> <guimenu>Visualitza</guimenu> <guimenuitem>Redueix</guimenuitem>"

#. Tag: action
#: index.docbook:243
#, no-c-format
msgid "Decrease the view of the filemap."
msgstr "Redueix la vista del mapa de fitxers."

#. Tag: title
#: index.docbook:249
#, no-c-format
msgid "The Go Menu"
msgstr "El menú Ves"

#. Tag: menuchoice
#: index.docbook:251
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt;<keycap>Up</keycap></keycombo> </"
"shortcut> <guimenu>Go</guimenu> <guimenuitem>Up</guimenuitem>"
