msgid "Glide windows as they appear or disappear"
msgstr "Slidināt logus, tiem parādoties vai pazūdot"

#: src/plugins/hidecursor/metadata.json
msgctxt "Description"
msgid "Hide mouse cursor on inactivity or keyboard input"
msgstr "Slēpt peles kursoru dīkstāves laikā un lietojot tastatūru"

#: src/plugins/highlightwindow/metadata.json
msgctxt "Description"
msgid "Highlight the appropriate window when hovering over taskbar entries"
msgstr "Iekrāso attiecīgo logu, peli liekot pāri uzdevumu joslas vienumiem"

#: src/plugins/invert/metadata.json
msgctxt "Description"
msgid ""
"Inverts the color of the desktop and windows; activated with a keyboard "
"shortcut"
msgstr "Invertē darbvirsmas un logu krāsas; ieslēdz ar tastatūras saīsni"

#: src/plugins/kscreen/metadata.json
msgctxt "Description"
msgid "Helper Effect for KScreen"
msgstr "„KScreen“ palīga efekts"

#: src/plugins/login/package/metadata.json
msgctxt "Description"
msgid "Fade to the desktop when logging in"
msgstr "Izgaist uz darbvirsmu, kad ierakstāties"

#: src/plugins/logout/package/metadata.json
msgctxt "Description"
msgid "Fade to the logout screen"
msgstr "Izgaist uz izrakstīšanās ekrānu"

#: src/plugins/magiclamp/metadata.json
msgctxt "Description"
msgid "Simulate a magic lamp when minimizing windows"
msgstr "Simulē maģisko lampu, minimizējot logus"

#: src/plugins/magnifier/metadata.json
msgctxt "Description"
msgid ""
"Magnify the section of the screen that is near the mouse cursor; activated "
"with a keyboard shortcut"
msgstr ""
"Pietuvina ekrāna daļu, kas atrodas pie peles kursora; ieslēdz ar tastatūras "
"saīsni"

#: src/plugins/maximize/package/metadata.json
msgctxt "Description"
msgid "Stretch windows when they are maximized or restored"
msgstr "Izstiept logus, kad tos maksimizējat vai atjaunojat"

#: src/plugins/minimizeall/package/metadata.json
msgctxt "Description"
msgid "Adds a shortcut to minimize and restore all windows"
msgstr "Pievieno saīsni visu logu minimizēšanai un atjaunošanai"

#: src/plugins/mouseclick/metadata.json
msgctxt "Description"
msgid ""
"Creates an animation whenever a mouse button is clicked. This is useful for "
"screenrecordings/presentations. Activated with a keyboard shortcut"
msgstr ""
"Izveido animāciju, kad noklikšķina peles pogu. Noderīgi ekrāna ierakstiem/"
"prezentācijām. Aktivizē ar tastatūras saīsni"

#: src/plugins/mousemark/metadata.json
msgctxt "Description"
msgid ""
"Allows you to draw lines on the desktop; activated with a keyboard shortcut"
msgstr "Ļauj darbvirsmā zīmēt līnijas; ieslēdz ar tastatūras saīsni"

#: src/plugins/outputlocator/metadata.json
msgctxt "Description"
msgid "Show screen names"
msgstr "Rādīt ekrānu nosaukumus"

#: src/plugins/overview/metadata.json
msgctxt "Description"
msgid ""
"Allows you to overview virtual desktops and windows; activated with a "
"keyboard shortcut"
msgstr ""
"Ļauj pārskatīt virtuālās darbvirsmas un logus; ieslēdz ar tastatūras saīsni"

#: src/plugins/scale/package/metadata.json
msgctxt "Description"
msgid "Make windows scale in and out when they are shown or hidden"
msgstr "Likt logiem samazināties vai palielināties, kad tie parādās vai pazūd"

#: src/plugins/screenedge/metadata.json
msgctxt "Description"
msgid ""
"Highlights screen edges and corners that trigger actions when touched as the "
"cursor approaches them"
msgstr "Tuvinot kursoru, izceļ ekrāna malas un stūrus, kas izsauc darbības."

#: src/plugins/screentransform/metadata.json
msgctxt "Description"
msgid "Animates display transformations"
msgstr "Displeja transformāciju animācija"

#: src/plugins/sessionquit/package/metadata.json
msgctxt "Description"
msgid "Keep the desktop background alive during logout until the end"
msgstr "Izrakstoties darbvirsmas fonu līdz pēdējam brīdim padarīt aktīvu"

#: src/plugins/shakecursor/metadata.json
msgctxt "Description"
msgid ""
"Makes the cursor larger when the pointer is quickly moved back and forth"
msgstr "Padara kursoru lielāku, to ātri kustinot uz priekšu un atpakaļ"

#: src/plugins/sheet/metadata.json
msgctxt "Description"
msgid ""
"Make modal dialogs smoothly fly in and out when they are shown or hidden"
msgstr ""
"Liek modālajiem dialogiem vienmērīgi atlidot un aizlidot, kad tie tiek "
"parādīti vai paslēpti"

#: src/plugins/showcompositing/metadata.json
msgctxt "Description"
msgid "Display if compositing is active"
msgstr "Parādīt, vai kompozitēšanas ir aktīva"

#: src/plugins/showfps/metadata.json
msgctxt "Description"
msgid "Display KWin's performance in the corner of the screen"
msgstr "Ekrāna stūrī parādīt „KWin“ veiktspēju"

#: src/plugins/showpaint/metadata.json
msgctxt "Description"
msgid ""
"Highlight areas of the desktop that have been recently updated; activated "
"with a keyboard shortcut"
msgstr ""
"Iekrāsot darbvirsmas zonas, kas nesen ir mainījušās; ieslēdz ar tastatūras "
"saīsni"

#: src/plugins/slideback/metadata.json
msgctxt "Description"
msgid "Slide back windows when another window is raised"
msgstr "Aizslidināt aizmugurē logu, kad tiek aktivizēts cits logs"

#: src/plugins/slide/metadata.json
msgctxt "Description"
msgid "Slide between virtual desktops when switching"
msgstr "Slīdēt starp virtuālajām darbvirsmām, starp tām pārslēdzoties"

#: src/plugins/slidingpopups/metadata.json
msgctxt "Description"
msgid "Slide Plasma popups in and out"
msgstr "Slidināt „Plasma“ uzlecošos logus"

#: src/plugins/squash/package/metadata.json
msgctxt "Description"
msgid "Squash windows when they are minimized"
msgstr "Saspiest logus, kad tos minimizē"

#: src/plugins/startupfeedback/metadata.json
msgctxt "Description"
msgid "Helper effect for startup feedback"
msgstr "Palaišanas ziņošanas palīgefekts"

#: src/plugins/synchronizeskipswitcher/package/metadata.json
msgctxt "Description"
msgid ""
"Hides all windows marked as Skip Taskbar to be also excluded from window "
"switchers (e.g. Alt+Tab)"
msgstr ""
"Liek visiem logiem, kas ir atzīmēti kā „Izlaist uzdevumu joslu“, "
"neparādīties arī logu pārslēdzējā (proti, Alt+Tab)"

#: src/plugins/systembell/metadata.json
msgctxt "Description"
msgid "Provides the bell"
msgstr "Nodrošina zvanu"

#: src/plugins/thumbnailaside/metadata.json
msgctxt "Description"
msgid ""
"Display window thumbnails on the edge of the screen; activated with a "
"keyboard shortcut"
msgstr "Ekrāna malā parāda logu sīktēlus; ieslēdz ar tastatūras saīsni"

#: src/plugins/tileseditor/metadata.json
msgctxt "Description"
msgid "Editor for the tiling areas"
msgstr "Flīzēšanas zonu redaktors"

#: src/plugins/touchpoints/metadata.json
msgctxt "Description"
msgid "Visualize touch points"
msgstr "Vizualizē kontaktpunktus"

#: src/plugins/trackmouse/metadata.json
msgctxt "Description"
msgid ""
"Display a mouse cursor locating effect; activated with a keyboard shortcut"
msgstr ""
"Aktivizējot parāda peles kursora atrašanas efektu; aktivizē ar tastatūras "
"saīsni"

#: src/plugins/translucency/package/metadata.json
msgctxt "Description"
msgid "Make windows translucent under different conditions"
msgstr "Dažādos apstākļos logus padara caurspīdīgus"

#: src/plugins/videowall/package/metadata.json
msgctxt "Description"
msgid ""
"Spans fullscreen video player over all attached screens to create a Video "
"Wall"
msgstr ""
"Pilnekrāna video atskaņotāju izpleš pāri visiem pievienotajiem ekrāniem, "
"izveidojot video sienu"

#: src/plugins/windowaperture/package/metadata.json
msgctxt "Description"
msgid "Move windows into screen corners"
msgstr "Pārvieto logus ekrāna stūros"

#: src/plugins/windowview/metadata.json
msgctxt "Description"
msgid "Zoom out until all opened windows can be displayed side-by-side"
msgstr "Attālina līdz visus atvērtos logus var parādīt vienu otram blakus"

#: src/plugins/wobblywindows/metadata.json
msgctxt "Description"
msgid "Deform windows while they are moving"
msgstr "Transformē logus, kad tos pārvieto"

#: src/plugins/zoom/metadata.json
msgctxt "Description"
msgid "Magnify the entire desktop; activated with a keyboard shortcut"
msgstr "Tuvina visu darbvirsmu; ieslēdz ar tastatūras saīsni"

#: src/tabbox/switchers/thumbnail_grid/metadata.json
msgctxt "Description"
msgid "A window switcher layout using a small grid of thumbnails"
msgstr "Logu pārslēdzēja izklājums, izmantojot mazu sīktēlu režģi"

