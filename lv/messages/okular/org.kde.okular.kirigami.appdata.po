msgid "Features:"
msgstr "Iespējas:"

#. (itstool) path: ul/li
#: org.kde.okular.kirigami.appdata.xml:18
msgid ""
"Supported Formats: PDF, PS, Tiff, DjVu, Images, DVI, XPS, Fiction Book, "
"Comic Book, Plucker, EPub, Fax"
msgstr ""
"Atbalstītie formāti: PDF, PS, „Tiff“, „DjVu“, attēli, DVI, XPS, „Fiction "
"Book“, „Comic Book“, „Plucker“, „EPub“, fakss"

