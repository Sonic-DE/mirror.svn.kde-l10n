#. (itstool) path: component/name
#: org.kde.kapptemplate.appdata.xml:9
msgid "KAppTemplate"
msgstr "KAppTemplate"

#. (itstool) path: component/summary
#: org.kde.kapptemplate.appdata.xml:10
msgid "App Code Template Generator"
msgstr "Programmu koda sagatavju ģenerators"

#. (itstool) path: description/p
#: org.kde.kapptemplate.appdata.xml:12
msgid ""
"KAppTemplate is an application to start development quickly using existing "
"templates providing basic repeatedly written code and a proper structure."
msgstr ""
"„KAppTemplate“ ir programma, kas palīdz ātri uzsākt attīstību, izmantojot "
"eksistējošās sagataves ar atkārtojošos kodu un atbilstošu struktūru."

#. (itstool) path: description/p
#: org.kde.kapptemplate.appdata.xml:16
msgid "Features:"
msgstr "Iespējas:"

#. (itstool) path: ul/li
#: org.kde.kapptemplate.appdata.xml:18
msgid "Templates for C++, Ruby, Python and PHP"
msgstr "C++, „Ruby“, „Python“ un PHP sagataves"

#. (itstool) path: ul/li
#: org.kde.kapptemplate.appdata.xml:19
msgid "Categories"
msgstr "Kategorijass"

#. (itstool) path: ul/li
#: org.kde.kapptemplate.appdata.xml:20
msgid "Templates for different build-systems and frameworks"
msgstr "Sagataves dažādām būvējumu sistēmām un satvariem"

#. (itstool) path: ul/li
#: org.kde.kapptemplate.appdata.xml:21
msgid ""
"Templates especially for KDE-development (plugins for Plasma, QtQuick, "
"KTextEditor, KRunner, Akonadi)"
msgstr ""
"Sagataves īpaši KDE izstrādei („Plasma“, „QtQuick“, „KTextEditor“, "
"„KRunner“, „Akonadi“ spraudņi)"

#. (itstool) path: ul/li
#: org.kde.kapptemplate.appdata.xml:22
msgid ""
"It is easy to create new templates using space holders and a simple CMake-"
"command"
msgstr ""
"Vienkārša jaunu sagatavju veidošana, izmantojot vietturus un vienkāršu "
"„CMake“ komandu"

#. (itstool) path: ul/li
#: org.kde.kapptemplate.appdata.xml:23
msgid "Integrated into KDevelop"
msgstr "Integrēts „KDevelop“"
