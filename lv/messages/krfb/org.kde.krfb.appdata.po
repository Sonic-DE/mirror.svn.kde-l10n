msgid "Krfb"
msgstr "Krfb"

#. (itstool) path: component/summary
#: org.kde.krfb.appdata.xml:7
msgid "Share your desktop to another computer via VNC"
msgstr "Koplietojiet savas ierīces darbvirsmu ar citu datoru, izmantojot VNC"

#. (itstool) path: description/p
#: org.kde.krfb.appdata.xml:9
msgid ""
"Krfb Desktop Sharing is a server application that allows you to share your "
"current session with a user on another machine, who can use a VNC client to "
"view or even control the desktop."
msgstr ""
"„Krfb“ darbvirsmas koplietošana ir servera tipa programma, kas ļauj "
"koplietot pašreizējo sesiju ar citas ierīces lietotāju, lai, izmantojot VNC "
"klienta programmu, varētu redzēt vai pat kontrolēt darbvirsmu."

#. (itstool) path: screenshot/caption
#: org.kde.krfb.appdata.xml:17
msgid "Sharing desktop with Krfb"
msgstr "Darbvirsmas koplietošana ar „Krfb“"
