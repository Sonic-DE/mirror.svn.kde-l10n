#. (itstool) path: component/name
#: org.kde.dragonplayer.appdata.xml:9
msgid "Dragon Player"
msgstr "Dragon Player"

#. (itstool) path: component/summary
#: org.kde.dragonplayer.appdata.xml:10
msgid "Play video files and streams"
msgstr "Atskaņojiet video datnes un straumes"

#. (itstool) path: description/p
#: org.kde.dragonplayer.appdata.xml:12
msgid ""
"Dragon Player is a video player focusing on simplicity instead of features. "
"Its easy-to-use interface is designed to get out of your way and simply play "
"your video files and streams."
msgstr ""
"„Dragon Player“ ir video atskaņotājs ar uzsvaru uz vienkāršību, bet ne "
"plašām iespējām. Programmai ir viegli lietojama saskarne, lai ļautu bez "
"liekiem traucēkļiem noskatīties video datnes un straumes."

#. (itstool) path: description/p
#: org.kde.dragonplayer.appdata.xml:15
msgid "Features:"
msgstr "Iespējas:"

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:17
msgid ""
"Click to play or pause, and double-click to enter or exit full screen mode."
msgstr ""
"Klikšķiniet, lai atskaņotu vai pauzētu, vai veiciet dubultklikšķi, lai "
"ieslēgtu vai izslēgtu pilnekrāna režīmu."

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:18
msgid ""
"Choose the subtitle language, and automatically load the right one for your "
"language, if possible."
msgstr ""
"Izvēlieties subtitru valodu un automātiski ielādējiet pareizos subtitrus, ja "
"pieejami."

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:19
msgid "Choose the audio track."
msgstr "Izvēlieties skaņas celiņu."

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:20
msgid "Choose the video track."
msgstr "Izvēlieties video celiņu."

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:21
msgid "Adjust the volume by scrolling."
msgstr "Pārvaldiet skaļumu ar ritināšanu."

#~ msgid "Video player with focus on simplicity"
#~ msgstr "Video atskaņotājs ar uzsvaru uz vienkāršību"

#~ msgid "Simple Interface"
#~ msgstr "Vienkārša saskarne"

#~ msgid ""
#~ "Resuming videos: Starts playing a video where you were watching it last "
#~ "time"
#~ msgstr ""
#~ "Video turpināšana: sāk atskaņot no vietas, kurā palikāt iepriekšējo reizi"

#~ msgid ""
#~ "Support for subtitles: Automatically loads subtitles with the matching "
#~ "name"
#~ msgstr ""
#~ "Subtitru atbalsts: automātiski ielādē subtitru datni at atbilstošu "
#~ "nosaukumu"

#~ msgid "Video display settings (brightness, contrast)"
#~ msgstr "Video attēlošanas iestatījumi (gaišums un kontrasts)"

#~ msgid ""
#~ "Due to using Solid and Phonon DragonPlayer is independent of any "
#~ "multimedia framework or hardware abstraction layer"
#~ msgstr ""
#~ "„Dragon Player“ atskaņotājs, pateicoties izmantotajam „Solid“ un "
#~ "„Phonon“, ir neatkarīgs no citiem multivides satvariem vai aparatūras "
#~ "abstrakcijas slāņiem"

#~ msgid "Supports playing CDs and DVDs"
#~ msgstr "Atbalsta CD un DVD atskaņošanu"
