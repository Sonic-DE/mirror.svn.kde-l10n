msgctxt "Name"
msgid "KDE Write Daemon"
msgstr "KDE „Write“ dēmons"

#: kwrited-autostart.desktop:91
msgctxt "Comment"
msgid "Watch for messages from local users sent with write(1) or wall(1)"
msgstr ""
"Novēro ziņojumus no lokālajiem lietotājiem, kas sūtīti, izmantojot "
"„write(1)“ vai „wall(1)“"

#: kwrited.notifyrc:3
