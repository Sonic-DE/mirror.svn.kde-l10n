#. (itstool) path: component/name
#: org.kde.plasma.keyboard.metainfo.xml:8
msgid "Plasma Keyboard"
msgstr "„Plasma“ tastatūra"

#. (itstool) path: component/summary
#: org.kde.plasma.keyboard.metainfo.xml:9
msgid "On-Screen Keyboard for Plasma"
msgstr "Ekrānā redzama tastatūra „Plasma“ darbvirsmai"

#. (itstool) path: description/p
#: org.kde.plasma.keyboard.metainfo.xml:13
msgid ""
"Plasma Keyboard provides a virtual, on-screen keyboard for touchscreens, "
"tablets, convertible devices, phones, and traditional computers without a "
"physical keyboard."
msgstr ""
"„Plasma“ tastatūra ir virtuāla ekrānā redzama tastatūra skārienjutīgiem "
"ekrāniem, planšetdatoriem, pārveidojamām ierīcēm, tālruņiem un "
"tradicionāliem datoriem bez fiziskas tastatūras."

#. (itstool) path: ul/li
#: org.kde.plasma.keyboard.metainfo.xml:18
msgid "Seamless integration with the Plasma workspace and applications"
msgstr "Pilnīga integrācija „Plasma“ darbvirsmā un programmās"

#. (itstool) path: ul/li
#: org.kde.plasma.keyboard.metainfo.xml:19
msgid "Automatic appearance when text input is needed"
msgstr "Automātiski atveras, kad jāieraksta teksts"

#. (itstool) path: ul/li
#: org.kde.plasma.keyboard.metainfo.xml:20
msgid "Support for multiple layouts and languages"
msgstr "Daudzu izkārtojumu un valodu atbalsts"

#. (itstool) path: ul/li
#: org.kde.plasma.keyboard.metainfo.xml:21
msgid "Configurable size and behavior for different form factors"
msgstr "Konfigurējams izmērs un uzvedība dažāda lieluma ekrāniem"
