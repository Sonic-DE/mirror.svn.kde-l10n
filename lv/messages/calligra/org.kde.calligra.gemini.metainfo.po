msgstr ""
"Teksta dokuments tradicionālā darbvirsmas saskarnes stilā (veidošanas režīms)"

#. (itstool) path: screenshot/caption
#: org.kde.calligra.gemini.metainfo.xml:39
msgid "A text document in Create mode with the notes panel shown"
msgstr "Teksta datums izveidošanas režīmā ar redzamu piezīmju paneli"

