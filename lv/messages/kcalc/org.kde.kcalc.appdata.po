#. (itstool) path: component/name
#: org.kde.kcalc.appdata.xml:6
msgid "KCalc"
msgstr "KCalc"

#. (itstool) path: component/summary
#: org.kde.kcalc.appdata.xml:7
msgid "Scientific calculator"
msgstr "Zinātniskais kalkulators"

#. (itstool) path: description/p
#: org.kde.kcalc.appdata.xml:12
msgid ""
"KCalc has everything you would expect from a scientific calculator, plus:"
msgstr "„KCalc“ ir viss, kas nepieciešams zinātniskam kalkulatoram, kā arī:"

#. (itstool) path: ul/li
#: org.kde.kcalc.appdata.xml:14
msgid "Trigonometric functions, logic operations and statistical calculations"
msgstr ""
"Trigonometrijas funkcijas, loģiskie operatori un statistikas aprēķināšana"

#. (itstool) path: ul/li
#: org.kde.kcalc.appdata.xml:15
msgid ""
"A results stack which enables convenient recall of previous calculation "
"results"
msgstr ""
"Rezultātu tabula, kas ļauj ērti atcerēties iepriekšējos aprēķinu rezultātus"

#. (itstool) path: ul/li
#: org.kde.kcalc.appdata.xml:16
msgid "Precision is user-definable"
msgstr "Lietotāja nosakāmā vēlamā precizitāte"

#. (itstool) path: ul/li
#: org.kde.kcalc.appdata.xml:17
msgid "The display allows cut and paste of numbers"
msgstr "Displejs ļauj skaitļus griezt un ielīmēt"

#. (itstool) path: ul/li
#: org.kde.kcalc.appdata.xml:18
msgid "The display colors and font are configurable, aiding usability"
msgstr ""
"Displeja krāsas un fonts ir pielāgojums, veicinot programmas lietojamību"

#. (itstool) path: ul/li
#: org.kde.kcalc.appdata.xml:19
msgid "The use of key-bindings make it easy to use without a pointing device"
msgstr "Taustiņu saīšņu lietojums atvieglo kalkulatora lietojumu bez peles"

