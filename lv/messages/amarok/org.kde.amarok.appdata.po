#: org.kde.amarok.appdata.xml:17
msgid "Amarok"
msgstr "Amarok"

#. (itstool) path: component/summary
#: org.kde.amarok.appdata.xml:18
msgid "Rediscover your music"
msgstr "Atklāj savu mūziku"

#. (itstool) path: description/p
#: org.kde.amarok.appdata.xml:20
msgid ""
"Amarok is a free, cross-platform, versatile, powerful and feature-rich music "
"player and collection manager."
msgstr ""
"„Amarok“ ir brīvs, daudzplatformu, daudzpusējs un jaudīgām iespējām bagāts "
"mūzikas atskaņotājs un mūzikas kolekciju pārvaldnieks."

#. (itstool) path: description/p
#: org.kde.amarok.appdata.xml:21
msgid "Features:"
msgstr "Iespējām:"

#. (itstool) path: ul/li
#: org.kde.amarok.appdata.xml:23
msgid "Dynamic playlists matching different criteria"
msgstr "Dinamiski repertuāri, ievērojot dažādus kritērijus"

#. (itstool) path: ul/li
#: org.kde.amarok.appdata.xml:24
msgid "Collection managing with rating support"
msgstr "Kolekciju pārvaldība ar reitingu atbalstu"

#. (itstool) path: ul/li
#: org.kde.amarok.appdata.xml:25
msgid "Support for basic iPod, MTP and UMS music player devices"
msgstr "Atbalsta pamata „iPod“, MTP un UMS mūzikas atskaņotājus"

#. (itstool) path: ul/li
#: org.kde.amarok.appdata.xml:26
msgid "Integrated Internet services: last.fm, Magnatune, Ampache and more."
msgstr ""
"Integrēti interneta pakalpojumi: „last.fm“, „Magnatune“, „Ampache“ un citi."

#. (itstool) path: ul/li
