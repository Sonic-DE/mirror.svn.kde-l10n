msgstr "Zeroconf"

#: plugins/bwscheduler/ktorrent_bwscheduler.json
msgctxt "Description"
msgid "Schedule upload and download limits over a period of a week"
msgstr ""
"Plānojiet augšupielādes un lejupielādes ātruma ierobežojumus nedēļas dienām"

#: plugins/downloadorder/ktorrent_downloadorder.json
msgctxt "Description"
msgid "Specify the download order of a multi-file torrent"
msgstr "Norādiet datņu lejupielādes kārtību vairāku datņu torentā"

#: plugins/infowidget/ktorrent_infowidget.json
msgctxt "Description"
msgid "Displays general information about a torrent in several tabs"
msgstr "Vairākās cilnēs parāda pamata informāciju par torentu"

#: plugins/ipfilter/ktorrent_ipfilter.json
msgctxt "Description"
msgid "Filter IP addresses through a blocklist"
msgstr "Filtrējiet IP adreses ar bloķēšanas saraksta palīdzību"

#: plugins/logviewer/ktorrent_logviewer.json
msgctxt "Description"
msgid "Displays the logging output"
msgstr "Rāda žurnāla izvadu"

#: plugins/magnetgenerator/ktorrent_magnetgenerator.json
msgctxt "Description"
msgid "Generates magnet links"
msgstr "Ģenerē magnēta saites"

#: plugins/mediaplayer/ktorrent_mediaplayer.json
msgctxt "Description"
msgid "Phonon-based media player"
msgstr "„Phonon“ balstīts multivides atskaņotājs"

#: plugins/scanfolder/ktorrent_scanfolder.json
msgctxt "Description"
msgid "Scan folders for torrent files and load them"
msgstr "Mapēs meklē torentu datnes un tās ielādē"

#: plugins/scanforlostfiles/ktorrent_scanforlostfiles.json
msgctxt "Description"
msgid "Display files in the selected folder that don't belong to any torrent"
msgstr "Parāda datnes atlasītajā mapē, kas nepieder nevienam torentam."

#: plugins/search/ktorrent_search.json
msgctxt "Description"
msgid "Search for torrents"
msgstr "Meklē torentus"

#: plugins/shutdown/ktorrent_shutdown.json
msgctxt "Description"
msgid "Allows you to shutdown your computer when torrents finish"
msgstr "Ļauj izslēgt datoru, kad torentu lejupielāde ir  pabeigta"

#: plugins/stats/ktorrent_stats.json
msgctxt "Description"
msgid "Shows statistics about torrents in several graphs"
msgstr "Rāda vairākus grafikus ar torentu statistiku"

#: plugins/syndication/ktorrent_syndication.json
msgctxt "Description"
msgid "Syndication plugin for KTorrent, supporting RSS and Atom feeds"
msgstr "„KTorrent“ sindikācijas spraudnis, atbalsta RSS un „Atom“ barotnes"

#: plugins/upnp/ktorrent_upnp.json
msgctxt "Description"
msgid "Forward ports using UPnP"
msgstr "Pāradresē portus, izmantojot „UPnP“"

#: plugins/zeroconf/ktorrent_zeroconf.json
msgctxt "Description"
msgid "Discover peers on the local network using the Zeroconf protocol"
msgstr ""
"Atrod lokālajā tīklā esošus dalībniekus, izmantojot „zeroconf“ protokolu"

