#. Tag: para
#: index.docbook:574
#, no-c-format
msgid "The View Properties Dialog."
msgstr "Дијалог својстава приказа."

#. Tag: para
#: index.docbook:576
#, no-c-format
msgid ""
"The <guilabel>View Properties</guilabel> dialog can be used to quickly "
