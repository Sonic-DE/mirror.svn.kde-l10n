#: index.docbook:54
#, no-c-format
msgid ""
"Copy desktop files from <filename class=\"directory\">$HOME/.kde/Autostart</"
"filename> to <filename class=\"directory\">$HOME/.config/autostart</filename>"
msgstr ""
"Копирајте .десктоп фајлове из <filename class=\"directory\">$HOME/.kde/"
"Autostart</filename> у <filename class=\"directory\">$HOME/.config/"
"autostart</filename>."

#. Tag: member
#: index.docbook:55
#, no-c-format
msgid ""
"Copy pre startup script files from <filename class=\"directory\">$HOME/.kde/"
"Autostart</filename> to <filename class=\"directory\">$HOME/.config/plasma-"
"workspace/env</filename>"
msgstr ""
"Копирајте фајлове скрипти пре покретања из <filename class=\"directory\">"
"$HOME/.kde/Autostart</filename> у <filename class=\"directory\">$HOME/."
"config/plasma-workspace/env</filename>."

#. Tag: member
#: index.docbook:56
#, no-c-format
msgid ""
"Copy shutdown script files from <filename class=\"directory\">$HOME/.kde/"
"Autostart</filename> to <filename class=\"directory\">$HOME/.config/plasma-"
"workspace/shutdown</filename>"
msgstr ""
"Копирајте фајлове скрипти при гашењу из <filename class=\"directory\">$HOME/."
"kde/Autostart</filename> у <filename class=\"directory\">$HOME/.config/"
"plasma-workspace/shutdown</filename>."

