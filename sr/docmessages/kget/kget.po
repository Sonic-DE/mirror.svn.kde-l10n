#: index.docbook:226
#, no-c-format
msgid "Groups"
msgstr "Групе"

#. Tag: para
#: index.docbook:227
#, no-c-format
msgid "You can group downloads."
msgstr "Преузимања можете груписати."

#. Tag: screeninfo
#: index.docbook:229
#, no-c-format
msgid "<screeninfo>&kget; Groups</screeninfo>"
msgstr "<screeninfo>Групе у <application>К‑гету</application>.</screeninfo>"

#. Tag: phrase
#: index.docbook:235
#, no-c-format
