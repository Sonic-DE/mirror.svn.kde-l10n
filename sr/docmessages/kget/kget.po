msgstr "Кликните десним на место за спуштање да добијете опције."

# >! ui: Start / Resume All -> ?
#. Tag: menuchoice
#: index.docbook:101
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>R</keycap></keycombo> </"
