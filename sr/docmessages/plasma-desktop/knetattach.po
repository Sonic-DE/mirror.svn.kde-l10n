#. Tag: keyword
#: index.docbook:55
#, no-c-format
msgid "Network Folders"
msgstr "мрежне фасцикле"

#. Tag: keyword
#: index.docbook:56
#, no-c-format
msgid "Network Folder Wizard"
msgstr "чаробњак мрежних фасцикли"

