#, no-c-format
msgid ""
"&knetattach; is a wizard which makes it easier to integrate your network "
"resources with your &kde; Desktop."
msgstr ""
"<application>К‑мрежохват</application> је чаробњак који олакшава интегрисање "
"мрежних ресурса са радном површи КДЕ‑а."

#. Tag: keyword
#: index.docbook:52
#, no-c-format
msgid "<keyword>KDE</keyword>"
msgstr "<keyword>КДЕ</keyword>"

