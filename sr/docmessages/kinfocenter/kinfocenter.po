#~ msgstr ""
#~ "<guilabel>ИСО</guilabel> — попуњено ако чвор подржава изохроне преносе"

#~ msgid "<guilabel>BM</guilabel>: checked if the node is bus manager capable"
#~ msgstr ""
#~ "<guilabel>БМ</guilabel> — попуњено ако чвор може да буде менаџер "
#~ "магистрале"

#~ msgid ""
#~ "<guilabel>PM</guilabel>: checked if the node is power management capable"
#~ msgstr ""
#~ "<guilabel>ПМ</guilabel> — попуњено ако чвор може да управља напајањем"

#~ msgid ""
#~ "<guilabel>Acc</guilabel>: the cycle clock accuracy of the node, valid "
#~ "from 0 to 100"
#~ msgstr ""
#~ "<guilabel>прец.</guilabel> — тачност часовника такта у чвору (од 0 до 100)"

#~ msgid "<guilabel>Speed</guilabel>: the speed of the node"
#~ msgstr "<guilabel>брзина</guilabel> — брзина чвора"

