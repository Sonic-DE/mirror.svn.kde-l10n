#~ "<guibutton>Генериши ресет 1394 магистрале</guibutton>."

#~ msgid "The meaning of the columns in this list:"
#~ msgstr "Значења колона у списку:"

#~ msgid ""
#~ "<guilabel>Name</guilabel>: port or node name, the number can change with "
#~ "each bus reset"
#~ msgstr ""
#~ "<guilabel>име</guilabel> — порт или име чвора (може се изменити по "
#~ "ресетовању магистрале)"

#~ msgid "<guilabel>GUID</guilabel>: the 64 bit GUID of the node"
#~ msgstr "<guilabel>ГУИД</guilabel> — 64‑битни ГУИД чвора"

#~ msgid ""
#~ "<guilabel>Local</guilabel>: checked if the node is an IEEE 1394 port of "
#~ "your computer"
#~ msgstr ""
#~ "<guilabel>локал</guilabel> — попуњено ако је чвор ИЕЕЕ 1394 порт рачунара"

#~ msgid ""
#~ "<guilabel>IRM</guilabel>: checked if the node is isochronous resource "
#~ "manager capable"
#~ msgstr ""
#~ "<guilabel>ИРМ</guilabel> — попуњено ако чвор може да буде менаџер "
#~ "изохроних ресурса"

#~ msgid ""
#~ "<guilabel>CRM</guilabel>: checked if the node is cycle master capable"
#~ msgstr ""
#~ "<guilabel>ЦРМ</guilabel> — попуњено ако чвор може да буде водич циклуса"

#~ msgid ""
#~ "<guilabel>ISO</guilabel>: checked if the node supports isochronous "
