#: data/org.kde.yakuake.desktop:2
msgctxt "Name"
msgid "Yakuake"
msgstr "Јакуаке"

#: data/org.kde.yakuake.desktop:65
msgctxt "GenericName"
msgid "Drop-down Terminal"
