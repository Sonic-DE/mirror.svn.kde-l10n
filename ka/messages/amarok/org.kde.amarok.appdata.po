#. (itstool) path: component/name
#: org.kde.amarok.appdata.xml:17
msgid "Amarok"
msgstr "Amarok"

#. (itstool) path: component/summary
#: org.kde.amarok.appdata.xml:18
msgid "Rediscover your music"
msgstr "თავიდან აღმოაჩინეთ თქვენი მუსიკა"

#. (itstool) path: description/p
#: org.kde.amarok.appdata.xml:20
msgid ""
"Amarok is a free, cross-platform, versatile, powerful and feature-rich music "
"player and collection manager."
msgstr ""
"Amarok-ი უფასო, პლატფორმათაშორისი, მოქნილი, მძლავრი და მრავალი ფუნქციის "
"მქონე მუსიკის დამკვრელი და კოლექციების მმართველია."

#. (itstool) path: description/p
#: org.kde.amarok.appdata.xml:21
msgid "Features:"
msgstr "თვისებები:"

#. (itstool) path: ul/li
#: org.kde.amarok.appdata.xml:23
msgid "Dynamic playlists matching different criteria"
msgstr "დინამიკური დასაკრავი სიები სხვადასხვა პირობებით"

#. (itstool) path: ul/li
#: org.kde.amarok.appdata.xml:24
msgid "Collection managing with rating support"
msgstr "კოლექციის მართვა შეფასების მხარდაჭერით"

#. (itstool) path: ul/li
#: org.kde.amarok.appdata.xml:25
msgid "Support for basic iPod, MTP and UMS music player devices"
msgstr "აქვს iPod, MTP და UMS მუსიკის დამკვრელი მოწყობილობების მხარდაჭერა"

#. (itstool) path: ul/li
#: org.kde.amarok.appdata.xml:26
msgid "Integrated Internet services: last.fm, Magnatune, Ampache and more."
msgstr ""
"ინტეგრირებული ინტერნეტ-სერვისები: last.fm, Magnatune, Jamendo, Amplache და "
"სხვ."

#. (itstool) path: ul/li
#: org.kde.amarok.appdata.xml:27
msgid "Scripting support"
msgstr "სკრიპტების მხარდაჭერა"

#. (itstool) path: ul/li
#: org.kde.amarok.appdata.xml:28
msgid "Cover manager"
msgstr "ყდის მმართველი"

#. (itstool) path: ul/li
#: org.kde.amarok.appdata.xml:29
msgid "Replay gain support"
msgstr "გაძლიერების მხარდაჭერა"

#. (itstool) path: screenshot/caption
#: org.kde.amarok.appdata.xml:37
msgid "Playing music in Amarok 3.0"
msgstr "მუსიკის დაკვრა Amarok 3.0-ში"

#. (itstool) path: screenshot/caption
