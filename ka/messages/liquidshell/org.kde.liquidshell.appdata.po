#. (itstool) path: component/name
#: org.kde.liquidshell.appdata.xml:4
msgid "liquidshell"
msgstr "liquidshell"

#. (itstool) path: component/summary
#. (itstool) path: description/p
#: org.kde.liquidshell.appdata.xml:5 org.kde.liquidshell.appdata.xml:10
msgid "liquidshell is an alternative to plasmashell"
msgstr "liquidshell-ი plasmashell-ის ალტერნატივაა"

#. (itstool) path: description/p
#: org.kde.liquidshell.appdata.xml:11
msgid ""
"It does not use QtQuick but instead relies on QtWidgets, therefore no "
"hardware graphics acceleration is needed."
msgstr ""
"QtQuick -ის მაგიერ ის QtWidgets-ზეა დაწერილი, ამიტომ გრაფიკის აპარატურული "
"აჩქარება საჭირო არაა."

#. (itstool) path: description/p
#: org.kde.liquidshell.appdata.xml:13
msgid "Main Features:"
msgstr "მთავარი ფუნქციები:"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:15
msgid "Wallpaper per virtual desktop"
msgstr "ფონის სურათი თითოეული ვირტუალური სამუშაო მაგიდისთვის"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:16
msgid "No animations, no CPU hogging, low Memory footprint"
msgstr "ანიმაციის გარეშე, არ ჭამს CPU-ს, სჭირდება ცოტა მეხსიერება"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:17
msgid "Instant startup"
msgstr "მყისიერი გაშვება"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:18
msgid "No use of activities"
msgstr "არ იყენებს აქტივობებს"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:19
msgid "QtWidgets based, therefore follows widget style from systemsettings"
msgstr "დაფუძნებულია QtWidgets-ზე, ამიტომ სტილი სისტემის მორგებიდან ეთითება"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:20
msgid ""
"Icons are used from your globally defined icon theme from systemsettings"
msgstr ""
"ხატულები სისტემაში გლობალურად დაყენებული ხატულების თემიდან გამოიყენება "
"(ეთითება სისტემის მორგებიდან)"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:21
msgid ""
"Colors are used from your globally defined color theme from systemsettings"
msgstr ""
"ფერები სისტემაში გლობალურად დაყენებული ფერებს თემიდან გამოიყენება (ეთითება "
"სისტემის მორგებიდან)"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:22
msgid ""
"Can additionally be styled with css by passing the commandline option -"
"stylesheet filename.css (see included example stylesheet.css)"
msgstr ""
"ასევე შეგიძლიათ სტილი CSS-თაც შეცვალოთ ბრძანების სტრიქონის პარამეტრის -"
"stylesheet filename.css -ით შეცვალოთ (იხილეთ მაგალითისთვის მოყოლებული "
"stylesheet.css)"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:23
msgid ""
"uses existing KDE dialogs for most configurations, e.g. StartMenu, Virtual "
"Desktops, Bluetooth, Network"
msgstr ""
"კონფიგურაციისთვის (როგორიცაა მთავარი მენიუ, ვირტუალური სამუშაო მაგიდა, "
"ქსელი) ძირითადად, KDE-ის უკვე არსებულ ფანჯრებს იყენებს"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:24
msgid "One bottom DesktopPanel"
msgstr "ერთი ქვედა DesktopPanel"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:25
msgid "Desktop Applets"
msgstr "სამუშაო მაგიდის აპლეტები"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:43
msgid "Added install options (sleep/shutdown after install)"
msgstr "დაემატა დაყენების პარამეტრები (ძილი/გამორთვა დაყენების შემდეგ)"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:44
msgid "Improved EULA handling on package installation"
msgstr "გასწორდა EULA-ის მართვა პაკეტის დაყენებისას"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:45
msgid "Added long format of time and date display to calendar popup"
msgstr "დაემატა დროისა და თარიღის გრძელი ფორმატის ჩვენება კალენდრის მხტუნარაში"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:46
msgid "Create default folder for storing quicklaunch apps"
msgstr "ნაგულისხმევი საქაღალდის შექმნა სწრაფი გაშვების აპების შესანახად"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:47
msgid "SysLoad widget width depends on CPU count"
msgstr "ვიჯეტი SysLoad, რომელიც დამოკიდებულია CPU-ების რაოდენობაზე"

#. (itstool) path: ul/li
#. (itstool) path: description/p
#: org.kde.liquidshell.appdata.xml:48 org.kde.liquidshell.appdata.xml:54
msgid "Bugfixes and adjustments to newer KDE components"
msgstr "შეცდომების გასწორება და კორექტირება ახალი KDE-ის კომპონენტებისთვის"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:60
msgid "Notifications show how long they remain open (small animation)"
msgstr "გაფრთხილებები აჩვენებენ, რამდენ ხანს რჩებიან ღია (პატარა ანიმაცია)"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:61
msgid "Weather Applet shows moon phase"
msgstr "ამინდის აპლეტი აჩვენებს მთვარის ფაზას"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:62
msgid "Disk Usage Applet watches for mount/unmount to react quicker for update"
msgstr ""
"დისკის გამოყენების აპლეტი ყურადღებას აქცევს მიმაგრება/მოხსნას, რომ "
"განახლებაზე უფრო სწრაფი რეაქცია ჰქონდეს"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:63
msgid "Display improvements in software updates component"
msgstr "გაუმჯობესებების ჩვენება პროგრამის განახლებების კომპონენტში"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:64
msgid ""
"Added DBUS-Menu support (some apps don't provide own menu but only via DBUS, "
"e.g. MS teams)"
msgstr ""
"დაემატა DBUS-Menu-ის მხარდაჭერა (ზოგიერთ აპს საკუთარი მენიუ არ აქვს და, "
"მხოლოდ, DBUS-ს იყენებს. მაგ: MS teams)"
