#. (itstool) path: component/name
#: org.kde.accountwizard.appdata.xml:9
msgid "Account Wizard"
msgstr "ანგარიშის მორგება"

#. (itstool) path: component/summary
#: org.kde.accountwizard.appdata.xml:10
msgid "Configure accounts"
msgstr "ანგარიშების მორგება"

#. (itstool) path: description/p
#: org.kde.accountwizard.appdata.xml:12
msgid ""
"Accountwizard allows to edit, create, delete accounts. Accountwizard "
"supports IMAP/POP3/Kolab account type. Account information can be found by "
"using ispd service."
msgstr ""
"Accountwizard საშუალება გაძლევთ, ჩაასწოროთ, შექმნათ და წაშალოთ ანგარიშები. "
"AccountWizard-ს აქვს IMAP/POP3/Kolab ანგარიშის ტიპების მხარდაჭერა. ანგარიშის "
"ინფორმაცია ispd სერვისის საშუალებით შეგიძლიათ, იპოვოთ."

#~ msgid "Accountwizard allows to edit, create, delete accounts."
#~ msgstr ""
#~ "ანგარიშების მორგების ოსტატი საშუალებას გაძლევთ, ანგარიშები ჩაასწოროთ, "
#~ "შექმნათ ან წაშალოთ."
