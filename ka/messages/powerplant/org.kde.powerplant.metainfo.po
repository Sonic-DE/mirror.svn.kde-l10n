#. (itstool) path: component/name
#: org.kde.powerplant.metainfo.xml:8
msgid "PowerPlant"
msgstr "PowerPlant"

#. (itstool) path: component/summary
#: org.kde.powerplant.metainfo.xml:9
msgid "Keep your plants alive"
msgstr "დაიტოვეთ თქვენი მცენარეები ცოცხალი"

#. (itstool) path: description/p
#: org.kde.powerplant.metainfo.xml:17
msgid ""
"PowerPlant lets you track when your plants have to be watered and how their "
"health develops over time."
msgstr ""
"PowerPlant საშუალებას გაძლევთ, თვალყური ადევნოთ, როდის დაუსხით წყალი თქვენს "
"მცენარეებს და როგორ ვითარდებიან დროის განმავლობაში."

#. (itstool) path: screenshot/caption
#: org.kde.powerplant.metainfo.xml:31
msgid "Main view with the list of plants."
msgstr "ძირითადი ხედი მცენარეთა ჩამონათვალით."

#. (itstool) path: screenshot/caption
#: org.kde.powerplant.metainfo.xml:35
msgid "Details of a plant."
msgstr "მცენარის დეტალები."

#. (itstool) path: screenshot/caption
#: org.kde.powerplant.metainfo.xml:39
msgid "Raw list of tasks."
msgstr "ამოცანების დაუმუშავებელი სია."

