#. (itstool) path: component/name
#: org.kde.smb4k.appdata.xml:10
msgid "Smb4K"
msgstr "Smb4K"

#. (itstool) path: component/summary
#: org.kde.smb4k.appdata.xml:11
msgid "Discover and mount SAMBA and Windows shares over the network"
msgstr "აღმოაჩინეთ და მიამაგრეთ SAMBA-ის და Windows-ის გაზიარებულები ქსელში"

#. (itstool) path: description/p
#: org.kde.smb4k.appdata.xml:13
msgid ""
"Smb4K is an advanced network neighborhood browser and Samba share mounting "
"utility. It is based on the KDE Frameworks, QtKeychain, Samba's client "
"library (libsmbclient) and, optionally, the KDSoap WS-Discovery client. It "
"scans your network neighborhood for all available workgroups, servers and "
"shares and can mount all desired shares to your local file system."
msgstr ""
"Smb4k დამატებითი ქსელის სამეზობლოს დასათვალიერებელი და Samba-ის გაზიარებების "
"მიმაგრების პროგრამაა. ის ეყრდნობა KDE Framework-ს და Samba-ის კლიენტის "
"ბიბლიოთეკას (libsmbclient). ის ასკანირებს თქვენი ქსელის სამეზობლოს ყველა "
"ხელმისაწვდომი სამუშაო ჯგუფების, სერვერებისა და გაზიარებების საპოვნელად და "
"შეუძლია, ყველა სასურველი გაზიარება თქვენს ლოკალურ ფაილურ სისტემაზე მიამაგროს."

#. (itstool) path: description/p
#: org.kde.smb4k.appdata.xml:16
msgid "Features:"
msgstr "თვისებები:"

#. (itstool) path: ul/li
#: org.kde.smb4k.appdata.xml:20
msgid ""
"Scanning for (active) workgroups, hosts, and shares using Samba's client "
"library, DNS Service Discovery (DNS-SD) and, optionally, Web Services "
"Dynamic Discovery (WS-Discovery)"
msgstr ""
"(აქტიური) სამუშაო ჯგუფების, ჰოსტების და გაზიარებების სკანირება Samba-ის "
"კლიენტის ბიბლიოთეკის, DNS სერვისის აღმოჩენით (DNS-SD) და არასავალდებულოდ, "
"ვებსერვისების დინამიკური აღმოჩენით (WS-Discovery)"

#. (itstool) path: ul/li
#: org.kde.smb4k.appdata.xml:21
msgid ""
"Support of the CIFS and SMB3 file system under Linux as well as the SMBFS "
"file system under BSD"
msgstr ""
"CIFS და SMB3 ფაილური სისტემების მხარდაჭერა ლინუქსში და ფაილური სისტემა SMBFS "
"BSD-ში"

#. (itstool) path: ul/li
#: org.kde.smb4k.appdata.xml:22
msgid "Mounting and unmounting of shares"
msgstr "გაზიარებების მიმაგრება და მოხსნა"

#. (itstool) path: ul/li
#: org.kde.smb4k.appdata.xml:23
msgid "Access to the files of a mounted share using a file manager or terminal"
msgstr ""
"წვდომა მიმაგრებული გაზიარების ფაილებთან ფაილების მმართველის, ან ტერმინალის "
"დახმარებით"

#. (itstool) path: ul/li
#: org.kde.smb4k.appdata.xml:24
msgid "Auto-detection of external mounts and unmounts"
msgstr "გარე მიმაგრებებისა და მოხსნების ავტომატური აღმოჩენა"

#. (itstool) path: ul/li
#: org.kde.smb4k.appdata.xml:25
msgid "Remounting of previously used shares on program start"
msgstr "პროგრამის გაშვებისას ადრე მიმაგრებული გაზიარებულების თავიდან მიმაგრება"

#. (itstool) path: ul/li
#: org.kde.smb4k.appdata.xml:26
msgid "Miscellaneous information about remote network items and mounted shares"
msgstr ""
"სხვადასხვა ინფორმაცია დაშორებული ქსელური ელემენტებისა და მიმაგრებული "
"გაზიარებების შესახებ"

#. (itstool) path: ul/li
#: org.kde.smb4k.appdata.xml:27
msgid "Network search"
msgstr "ქსელში ძებნა"

#. (itstool) path: ul/li
#: org.kde.smb4k.appdata.xml:28
msgid "Preview of the contents of a remote share"
msgstr "დაშორებული გაზიარებულის შემცველობის მინიატურები"

#. (itstool) path: ul/li
#: org.kde.smb4k.appdata.xml:29
msgid "Default login"
msgstr "ნაგულისხმევი მომხმარებელი"

#. (itstool) path: ul/li
#: org.kde.smb4k.appdata.xml:30
msgid "Special handling of home shares"
msgstr "საწყისი გაზიარებულების სპეციალური დამუშავება"

#. (itstool) path: ul/li
#: org.kde.smb4k.appdata.xml:31
msgid "Ability to bookmark favorite shares"
msgstr "რჩეული გაზიარებულების ჩანიშვნა"

#. (itstool) path: ul/li
#: org.kde.smb4k.appdata.xml:32
msgid "System tray widget"
msgstr "სისტემის კუთხეში ხატულის ჩართვა"

#. (itstool) path: ul/li
#: org.kde.smb4k.appdata.xml:33
msgid "Support of advanced mount options"
msgstr "მიმაგრების დამატებითი პარამეტრების მხარდაჭერა"

#. (itstool) path: ul/li
#: org.kde.smb4k.appdata.xml:34
msgid "Support of printer shares"
msgstr "პრინტერის გაზიარების მხარდაჭერა"

#. (itstool) path: ul/li
#: org.kde.smb4k.appdata.xml:35
msgid ""
"Support of several secure storage solutions for the login credentials via "
"QtKeychain"
msgstr ""
"რამდენიმე დაცული საცავის გადაწყვეტილების მხარდაჭერა ავტორიზაციის "
"დეტალებისთვის QtKeychain-ით"

#. (itstool) path: ul/li
#: org.kde.smb4k.appdata.xml:36
msgid "Synchronization of a remote share with a local copy and vice versa"
msgstr "დაშორებული გაზიარებულის ლოკალურთან სინქრონიზაცია და პირიქით"

#. (itstool) path: ul/li
#: org.kde.smb4k.appdata.xml:37
msgid "Ability to define custom settings for individual servers and shares"
msgstr ""
"საშუალება, აღწეროთ მორგებული პარამეტრები ინდივიდუალური სერვერებისა და "
"გაზიარებებისათვის"

#. (itstool) path: ul/li
#: org.kde.smb4k.appdata.xml:38
msgid ""
"Hardware support through the Solid device integration framework, the "
"KDBusAddons convenience classes and the Qt Network module"
msgstr ""
"აპარატურის მხარდაჭერა Solid device integration framework-ით, KDBusAddons-ის "
"შესაბამისი კლასებით და Qt-ის ქსელური მოდულით"

#. (itstool) path: ul/li
#: org.kde.smb4k.appdata.xml:39
msgid "Wake-On-LAN capabilities"
msgstr "ქსელით-გაღვიძების შესაძლებლობა"

#. (itstool) path: ul/li
#: org.kde.smb4k.appdata.xml:40
msgid "Plasmoid for desktop integration"
msgstr "პლაზმოიდი სამუშაო მაგიდასთან ინტეგრაციისთვის"

#. (itstool) path: ul/li
#: org.kde.smb4k.appdata.xml:41
msgid "Profiles for different network neighborhood setups"
msgstr "პროფილები სხვადასხვა ქსელური სამეზობლოს მოსარგებად"

#. (itstool) path: description/p
#: org.kde.smb4k.appdata.xml:43
msgid ""
"If you are working in a Windows dominated network environment, you may want "
"to install this application to be able to easily access the provided Windows "
"shares."
msgstr ""
"თუ მუშაობთ ქსელურ გარემოში, სადაც Windows-ის კომპიუტერები უმრავლესობაა, "
"თქვენ ალბათ გნებავთ, ეს აპლიკაცია დააყენოთ, რომ მოწოდებულ Windows-ის "
"გაზიარებებთან იოლი წვდომა გქონდეთ."

