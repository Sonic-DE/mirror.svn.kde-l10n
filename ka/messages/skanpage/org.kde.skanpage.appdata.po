#. (itstool) path: component/name
#: org.kde.skanpage.appdata.xml:14
msgid "Skanpage"
msgstr "Skanpage"

#. (itstool) path: component/summary
#: org.kde.skanpage.appdata.xml:15
msgid "Scan multi-page documents and images"
msgstr "დაასკანერეთ მრავალგვერდიანი დოკუმენტები და გამოსახულებები"

#. (itstool) path: description/p
#: org.kde.skanpage.appdata.xml:17
msgid ""
"Skanpage is a simple scanning application optimized for multi-page document "
"scanning. It can also scan and save single-page documents and images."
msgstr ""
"Skanpage არის მარტივი სკანირების აპლიკაცია, რომელიც შექმნილია როგორც "
"მრავალგვერდიანი, ისე ერთგვერდიანი დოკუმენტებისა და სურათების სკანირებისთვის "
"და შესანახად."

#. (itstool) path: description/p
#: org.kde.skanpage.appdata.xml:18
msgid "Features:"
msgstr "თვისებები:"

#. (itstool) path: ul/li
#: org.kde.skanpage.appdata.xml:20
msgid "Scanning from flatbed and ADF scanners"
msgstr "Flatbed და ADF სკანერებიდან სკანრება"

#. (itstool) path: ul/li
#: org.kde.skanpage.appdata.xml:21
msgid "Configurable options for scanning device"
msgstr "სკანერის პარამეტრების მორგება"

#. (itstool) path: ul/li
#: org.kde.skanpage.appdata.xml:22
msgid "Reordering, rotation, and deletion of scanned pages"
msgstr "სკანირებული გვერდების გადალაგება, მობრუნება და წაშლა"

#. (itstool) path: ul/li
#: org.kde.skanpage.appdata.xml:23
msgid "Saving to multi-page PDF documents and image files"
msgstr "მრავალგვერდიან PDF დოკუმენტებში და გამოსახულებებში შენახვა"

#. (itstool) path: screenshot/caption
