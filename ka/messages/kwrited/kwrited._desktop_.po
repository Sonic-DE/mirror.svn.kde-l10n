#: kwrited-autostart.desktop:2
msgctxt "Name"
msgid "KDE Write Daemon"
msgstr "KDE Write დემონი"

#: kwrited-autostart.desktop:91
msgctxt "Comment"
msgid "Watch for messages from local users sent with write(1) or wall(1)"
msgstr ""
"ლოკალური მომხმარებლების მიერ write(1) და wall(1)-ით გაგზავნილი "
"შეტყობინებების ნახვა"

#: kwrited.notifyrc:3
msgctxt "Name"
msgid "Local System Message Service"
msgstr "ლოკალური სისტემური შეტყობინებების სერვისი"

#: kwrited.notifyrc:48
msgctxt "Comment"
msgid "Local system message service"
msgstr "ლოკალური სისტემური შეტყობინებების სერვისი"

#: kwrited.notifyrc:117
msgctxt "Name"
msgid "New message received"
msgstr "მიღებულია ახალი შეტყობინება"

#: kwrited.notifyrc:192
msgctxt "Comment"
msgid "The daemon received a new message sent with wall(1) or write(1)"
msgstr "დემონმა wall(1)-ით ან write(1)-ით ახალი შეტყობინება მიიღო"
