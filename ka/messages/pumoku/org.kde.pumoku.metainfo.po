#. (itstool) path: component/name
#: org.kde.pumoku.metainfo.xml:11
msgid "PuMoKu"
msgstr "PuMoKu"

#. (itstool) path: component/summary
#: org.kde.pumoku.metainfo.xml:12
msgid "A classic 9 × 9 sudoku game"
msgstr "კლასიკური 9 x 9 სუდოკუ"

#. (itstool) path: description/p
#: org.kde.pumoku.metainfo.xml:28
msgid ""
"PuMoKu is a classic, 9 × 9 Sudoku solving game aimed for Plasma Mobile. It "
"comes with flexible highlighting options and (touch) input methods, full "
"undo stack and more."
msgstr ""
"PuMoKu წარმოადგენს კლასიკურ 9x9 სუდოკუს, რომელიც განკუთვნილია Plasma Mobile-"
"ისთვის. მას მოჰყვება მოქნილი გამოკვეთის პარამეტრები და (შეხებით) შეყვანის "
"მეთოდები, გაუქმების სრული სტეკი და სხვ."

#. (itstool) path: ul/li
#: org.kde.pumoku.metainfo.xml:30
msgid "Input methods: Cell first, Number first or Hybrid"
msgstr "შეყვანის მეთოდები: ჯერ უჯრედი, ჯერ რიცხვი, ან ჰიბრიდული"

#. (itstool) path: ul/li
#: org.kde.pumoku.metainfo.xml:31
msgid "Built in sudoku generator"
msgstr "ჩაშენებული სუდოკუს გენერატორი"

#. (itstool) path: ul/li
#: org.kde.pumoku.metainfo.xml:32
msgid "Automatic undo when the same action is repeated"
msgstr "ავტომატური გაუქმება იგივე ქმედების გამეორებისას"

#. (itstool) path: screenshot/caption
#: org.kde.pumoku.metainfo.xml:37
msgid "PuMoKu game"
msgstr "თამაში PuMoKu"

