#. (itstool) path: component/name
#: org.kde.station.appdata.xml:6
msgid "Station"
msgstr "სადგური"

#. (itstool) path: component/summary
#: org.kde.station.appdata.xml:7
msgid "Terminal Emulator"
msgstr "ტერმინალის ემულატორი"

#. (itstool) path: description/p
#: org.kde.station.appdata.xml:13
msgid ""
"Station is a convergent terminal emulator, ready for desktop and mobile "
"devices using GNU/Linux."
msgstr ""
"სადგური კონვერგენტულ ტერმინალის ემულატორს წარმოადგენს, რომელიც მზადაა GNU/"
"Linux-ის ქვეშ მომუშავე სამუშაო კომპიუტერებისა და მობილური "
"მოწყობილობებისათვის."

#. (itstool) path: screenshot/caption
#: org.kde.station.appdata.xml:27
msgid "Station in desktop and phone."
msgstr "სადგური კომპიუტერზე და ტელეფონზე."
