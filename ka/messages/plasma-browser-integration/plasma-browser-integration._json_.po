#: flatpak-integrator/browserintegrationflatpakintegrator.json
msgctxt "Name"
msgid "Plasma Browser Integration Flatpak Integration"
msgstr "Plasma-ის ბრაუზერის ინტეგრაცია Flatpak-ის ინტეგრაცია"

#: reminder/browserintegrationreminder.json
msgctxt "Name"
msgid "Plasma Browser Integration Installation Reminder"
msgstr "Plasma-ის ბრაუზერის ინტეგრაციის დაყენების შეხსენება"

#: flatpak-integrator/browserintegrationflatpakintegrator.json
msgctxt "Description"
msgid "Automatically enables support for Firefox Flatpak"
msgstr "ავტომატურად ჩართავს Firefox Flatpak-ის მხარდაჭერას"

#: reminder/browserintegrationreminder.json
msgctxt "Description"
msgid ""
"Provides a link to the browser extension if the Plasma Browser Integration "
"host is installed"
msgstr ""
"გაწვდით ბმულს ბრაუზერის გაფართოებაზე, თუ Plasma-ის ბრაუზერის ინტეგრაციის "
"ჰოსტი დაყენებულია"

#~ msgctxt "Name"
#~ msgid "Plasma Browser Integration Host"
#~ msgstr "Plasma-ის ბრაუზერის ინტეგრაციის ჰოსტი"

#~ msgctxt "Name|plasma runner"
#~ msgid "Browser History"
#~ msgstr "ბრაუზერის ისტორია"

#~ msgctxt "Comment"
#~ msgid "Search the browser history for visited websites"
#~ msgstr "ბრაუზერის ისტორიაში ძებნა"

#~ msgctxt "X-Plasma-Runner-Syntax-Descriptions"
#~ msgid "Finds websites in the browser history whose title or URL match :q:"
#~ msgstr "ბრაუზერის ისტორიაში მოძებნის საიტებს, რომლებიც ემთხვევა :q:"

#~ msgctxt "Name|plasma runner"
#~ msgid "Browser Tabs"
#~ msgstr "ბაუზერის ჩანართები"

#~ msgctxt "Comment"
#~ msgid "Find and activate browser tabs"
#~ msgstr "ბრაუზერის ჩანართების პოვნა და გააქტიურება"

#~ msgctxt "X-Plasma-Runner-Syntax-Descriptions"
#~ msgid "Finds open browser tabs whose title or URL match :q:"
#~ msgstr "იპოვის ბრაუზერის ჩანართს, რომლის სათაური ან ბმული ემთხვევა :q:"
