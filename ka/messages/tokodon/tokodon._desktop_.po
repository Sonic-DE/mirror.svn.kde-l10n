#: org.kde.tokodon.desktop:4 src/tokodon.notifyrc:5
msgctxt "Name"
msgid "Tokodon"
msgstr "Tokodon"

#: org.kde.tokodon.desktop:44
msgctxt "GenericName"
msgid "Browse the Fediverse"
msgstr "დაათვალიერეთ Fediverse"

#: org.kde.tokodon.desktop:76
msgctxt "Comment"
msgid "Client for the Mastodon"
msgstr "Mastodon-ის კლიენტი"

#: src/tokodon.notifyrc:46
msgctxt "Comment"
msgid "A client for Mastodon, the decentralized social media"
msgstr "Mastodon-ის, დეცენტრალიზებული სოციალური მედიის კლიენტი"

#: src/tokodon.notifyrc:82
msgctxt "Name"
msgid "Favorite"
msgstr "რჩეული"

#: src/tokodon.notifyrc:118
msgctxt "Comment"
msgid "Someone favorited your post"
msgstr "ვიღაცამ თქვენი პოსტი ჩაინიშნა"

#: src/tokodon.notifyrc:154
msgctxt "Name"
msgid "Boost"
msgstr "გაძლიერება"

#: src/tokodon.notifyrc:188
msgctxt "Comment"
msgid "Someone boosted your post"
msgstr "ვიღაცამ თქვენი პოსტი აწია"

#: src/tokodon.notifyrc:225 src/tokodon.notifyrc:364
msgctxt "Name"
msgid "Follow"
msgstr "გამოწერა"

#: src/tokodon.notifyrc:261
msgctxt "Comment"
msgid "Someone followed you"
msgstr "ვიღაც მოგდევთ"

#: src/tokodon.notifyrc:298
msgctxt "Name"
msgid "Follow Request"
msgstr "მიყოლის მოთხოვნა"

#: src/tokodon.notifyrc:330
msgctxt "Comment"
msgid "Someone requested to followed you"
msgstr "ვიღაცამ თქვენთვის მოყოლა მოითხოვა"

#: src/tokodon.notifyrc:400
msgctxt "Comment"
msgid "Someone mentioned you"
msgstr "ვიღაცამ გახსენათ"

#: src/tokodon.notifyrc:437
msgctxt "Name"
msgid "Update"
msgstr "განახლება"

#: src/tokodon.notifyrc:472
msgctxt "Comment"
msgid "Someone edited a post"
msgstr "ვიღაცამ პოსტი ჩაასწორა ჩაინიშნა"

#: src/tokodon.notifyrc:508
msgctxt "Name"
msgid "Poll"
msgstr "გამოკითხვა"

#: src/tokodon.notifyrc:540
msgctxt "Comment"
msgid "Someone's poll ended"
msgstr "ვიღაცის გამოკითხვა დასრულდა"

#: src/tokodon.notifyrc:574
msgctxt "Name"
msgid "Status"
msgstr "სტატუსი"

#: src/tokodon.notifyrc:606
msgctxt "Comment"
msgid "Someone posted a new status"
msgstr "ვიღაცამ ახალი სტატუსი დაპოსტა"

#: src/tokodon.notifyrc:641
msgctxt "Name"
msgid "Quote"
msgstr "ციტატა"

#: src/tokodon.notifyrc:662
msgctxt "Comment"
msgid "Someone quoted you"
msgstr "ვიღაცამ დაგაციტირათ"

#: src/tokodon.notifyrc:687
msgctxt "Name"
msgid "Annual Report"
msgstr "წლიური ანგარიში"

#: src/tokodon.notifyrc:715
msgctxt "Comment"
msgid "Unveil your year's highlights and memorable moments on the Fediverse!"
msgstr ""
"გამოაქვეყნეთ თქვენი წლის მაჩვენებლები და დასამახსოვრებელი მომენტები "
"Fediverse-ზე!"

#: src/tokodon.notifyrc:746
msgctxt "Name"
msgid "Other"
msgstr "სხვა"

#: src/tokodon.notifyrc:775
msgctxt "Comment"
msgid "Notifications that do not fit in other categories"
msgstr "შეტყობინებები, რომლებიც არ ჯდება სხვა კატეგორიებში"

