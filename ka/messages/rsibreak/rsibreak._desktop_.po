#: src/org.kde.rsibreak.desktop:11 src/rsibreak_autostart.desktop:11
msgctxt "Name"
msgid "RSIBreak"
msgstr "RSIBreak"

#: src/org.kde.rsibreak.desktop:62
msgctxt "GenericName"
msgid "Help prevent repetitive strain injury"
msgstr "დახმარება განმეორებითი ტრავმული დაზიანების თავიდან აცილებაში"

#: src/org.kde.rsibreak.desktop:101 src/rsibreak_autostart.desktop:62
msgctxt "Comment"
msgid "Makes sure you rest now and then"
msgstr "დარწმუნდით, რომ ხანდახან ისვენებთ"

#: src/rsibreak.notifyrc:4
msgctxt "Comment"
msgid "RSIBreak"
msgstr "RSIBreak"

#: src/rsibreak.notifyrc:56
msgctxt "Name"
msgid "Breaks"
msgstr "დასვენებები"

#: src/rsibreak.notifyrc:110
msgctxt "Name"
msgid "Start of a short break"
msgstr "მოკლე დასვენების დასაწყისი"

#: src/rsibreak.notifyrc:160
msgctxt "Comment"
msgid "When a short break starts"
msgstr "როდის იწყება მოკლე შესვენება"

#: src/rsibreak.notifyrc:214
msgctxt "Name"
msgid "End of a short break"
msgstr "მოკლე შესვენების დასასრული"

#: src/rsibreak.notifyrc:264
msgctxt "Comment"
msgid "When a short break ends"
msgstr "როდის სრულდება მოკლე შესვენებეა"

#: src/rsibreak.notifyrc:318
msgctxt "Name"
msgid "Start of a long break"
msgstr "გრძელი დასვენების დასაწყისი"

#: src/rsibreak.notifyrc:368
msgctxt "Comment"
msgid "When a long break starts"
msgstr "როდის იწყება გრძელი შესვენება"

#: src/rsibreak.notifyrc:422
msgctxt "Name"
msgid "End of a long break"
msgstr "გრძელი შესვენების დასასრული"

#: src/rsibreak.notifyrc:472
msgctxt "Comment"
msgid "When a long break ends"
msgstr "როდის მთავრდება გრძელი შესვენება"

#: src/rsibreak.notifyrc:524
msgctxt "Name"
msgid "Regarding timers"
msgstr "ტაიმერების შესახებ"

#: src/rsibreak.notifyrc:570
msgctxt "Name"
msgid "When the short timer has been reset"
msgstr "როცა მოხდა მოკლე ტაიმერის ჩამოყრა"

#: src/rsibreak.notifyrc:618
msgctxt "Name"
msgid "When the timers have been reset"
msgstr "როდის მოხდა ტაიმერების ჩამოყრა"
