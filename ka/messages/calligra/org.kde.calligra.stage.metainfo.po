msgstr "ადვილი გადართვა სლაიდებს შორის პრეტენტაციისას"

#. (itstool) path: ul/li
#: org.kde.calligra.stage.metainfo.xml:19
msgid "Add notes for your slide"
msgstr "დაამატეთ შენიშვნები თქვენს სლაიდს"

#. (itstool) path: ul/li
#: org.kde.calligra.stage.metainfo.xml:20
