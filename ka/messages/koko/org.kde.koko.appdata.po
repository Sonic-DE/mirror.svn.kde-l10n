#. (itstool) path: component/name
#: org.kde.koko.appdata.xml:13
msgid "Photos"
msgstr "ფოტოები"

#. (itstool) path: component/summary
#: org.kde.koko.appdata.xml:14
msgid "Image Gallery"
msgstr "სურათების გალერეა"

#. (itstool) path: description/p
#: org.kde.koko.appdata.xml:16
msgid "An Image gallery application"
msgstr "სურათების გალერეის აპლიკაცია"

#. (itstool) path: description/p
#: org.kde.koko.appdata.xml:72
msgid ""
"This release modernizes the settings page, updates the style of the album "
"page and adds a confirmation dialog before discarding image edits. This also "
"fixes the full screen and slideshow mode."
msgstr ""
"ეს გამოშვება მორგების გვერდს ათანამედროვებს, ალბომის გვერდის სტილს ანახლებს "
"და სურათის ჩასწორებების გაუქმებამდე დადასტურების დიალოგს ამატებს; ასევე, "
"გასწორდა სრულეკრანიანი და სლაიდშოუს რეჟიმები."

#. (itstool) path: ul/li
#: org.kde.koko.appdata.xml:85
msgid "Fixes related to window activation"
msgstr "გასწორდა ფანჯრის აქტივაციასთან დაკავშირებული შეცდომები"

#. (itstool) path: ul/li
#: org.kde.koko.appdata.xml:86
msgid "Various code improvements and bugfixes"
msgstr "კოდის სხვადასხვა გაუმჯობესებები"

#. (itstool) path: ul/li
#: org.kde.koko.appdata.xml:97
msgid "Raise window on activation."
msgstr "ფანჯრის ამოწევა აქტივაციისას."

#. (itstool) path: ul/li
#: org.kde.koko.appdata.xml:105
msgid "User interface improvements."
msgstr "მომხმარებლის ინტერფეისის ზოგადი გაუმჯობესება."

#. (itstool) path: ul/li
#: org.kde.koko.appdata.xml:106
msgid "Image resizing and cropping support improvements."
msgstr "გაუმჯობესდა გამოსახულების ზომის შეცვლისა და ამოჭრის მხარდაჭერა."

#. (itstool) path: ul/li
#: org.kde.koko.appdata.xml:107
msgid "Improvements for SVG rendering"
msgstr "გაუმჯობესდა SVG-ის რენდერი"

#. (itstool) path: ul/li
#: org.kde.koko.appdata.xml:108
msgid "Support for color correction on X11"
msgstr "ფერების კორექციის მხარდაჭერა X11-ზე"

#. (itstool) path: description/p
#: org.kde.koko.appdata.xml:120
msgid "This release contains only a small bugfix and updated translations."
msgstr ""
"ეს ვერსია შეიცავს, მხოლოდ, პატარა შეცდომების გასწორებას და განახლებულ "
"თარგმანებს."

#. (itstool) path: description/p
#: org.kde.koko.appdata.xml:127
msgid ""
"Initial release of Koko, an convergent image viewer for Plasma Mobile and "
"desktop"
msgstr ""
"Koko-ის, Plasma Mobile და Plasma Desktop-ის გამოსახულებების დამთვალიერებლის "
"პირველი ვერსია"

#~ msgid "Koko"
#~ msgstr "Koko"
