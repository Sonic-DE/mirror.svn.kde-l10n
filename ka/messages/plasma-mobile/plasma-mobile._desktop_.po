#: components/waydroidintegrationplugin/kauth/waydroidhelper.actions:5
#: quicksettings/flashlight/kauth/flashlighthelper.actions:5
msgctxt "Name"
msgid "Waydroid Management"
msgstr "Waydroid-ის მართვა"

#: components/waydroidintegrationplugin/kauth/waydroidhelper.actions:35
msgctxt "Name"
msgid "Initialize Waydroid"
msgstr "Waydroid-ის ინიციალიზაცია"

#: components/waydroidintegrationplugin/kauth/waydroidhelper.actions:62
msgctxt "Description"
msgid "Allow initialization of Waydroid"
msgstr "Waydroid-ის ინიციალიზაციის დაშვება"

#: components/waydroidintegrationplugin/kauth/waydroidhelper.actions:94
msgctxt "Name"
msgid "Fetch Android ID for Google Services"
msgstr "Android ID-ის მიღება Google-ის სერვისებისთვის"

#: components/waydroidintegrationplugin/kauth/waydroidhelper.actions:121
msgctxt "Description"
msgid "Allow get Android ID of Waydroid container to activate Google services"
msgstr ""
"Android ID-ის ან Waydroid-ის კონტეინერის მიღების დაშვება Google-ის "
"სერვისების გასააქტიურებლად"

#: components/waydroidintegrationplugin/kauth/waydroidhelper.actions:153
msgctxt "Name"
msgid "Reset Waydroid"
msgstr "Waydroid-ის ჩამოყრა"

#: components/waydroidintegrationplugin/kauth/waydroidhelper.actions:180
msgctxt "Description"
msgid "Allow delete waydroid folder"
msgstr "Waydroid-ის საქაღალდის წაშლის დაშვება"

#: kcms/time/clockconfig_actions.actions:6
msgctxt "Name"
msgid "Date and Time Control Module"
msgstr "თარიღისა და დროის კონტროლის მოდული"

#: kcms/time/clockconfig_actions.actions:45
msgctxt "Name"
msgid "Save the date/time settings"
msgstr "თარიღის/დროის პარამეტრების შენახვა"

#: kcms/time/clockconfig_actions.actions:81
msgctxt "Description"
msgid "System policies prevent you from saving the date/time settings."
msgstr "სისტემის წესები გიკრძალავთ დროის/თარიღის პარამეტრების შენახვას."

#: quicksettings/flashlight/kauth/flashlighthelper.actions:35
msgctxt "Name"
msgid "Set flashlight brightness"
msgstr "განათების სიკაშკაშის დაყენება"

#: quicksettings/flashlight/kauth/flashlighthelper.actions:62
msgctxt "Description"
msgid "Allow set brightness on led device"
msgstr "LED მოწყობილობებზე სიკაშკაშის დაყენების დაშვება"

