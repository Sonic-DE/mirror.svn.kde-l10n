msgstr "სამეფო ნეფრიტი"

#: tilesets/traditional.desktop:2
msgctxt "Name"
msgid "Traditional"
msgstr "ტრადიციული"

#: tilesets/traditional.desktop:64
msgctxt "Description"
msgid "Americanized tiles inspired by Japanese Mahjongg tiles"
msgstr "იაპონური მაჰჯონგის ფილების ამერიკანიზებული ვერსია"
