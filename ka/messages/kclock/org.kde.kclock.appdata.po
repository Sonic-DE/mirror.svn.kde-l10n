#. (itstool) path: component/name
#: org.kde.kclock.appdata.xml:12
msgid "Clock"
msgstr "საათი"

#. (itstool) path: component/summary
#: org.kde.kclock.appdata.xml:13
msgid "Keep time and set alarms"
msgstr "ადევნეთ თვალყური დროს და დააყენეთ განგაშები"

#. (itstool) path: description/p
#: org.kde.kclock.appdata.xml:18
msgid ""
"A universal clock application for desktop and mobile. Clock includes a "
"stopwatch and a world clock, and allows you to set multiple alarms and "
"timers."
msgstr ""
"უნივერსალური საათის აპლიკაცია კომპიუტერისა და მობილურისთვის. Clock შეიცავს "
"წამზომს და მსოფლიო საათს და საშუალებას გაძლევთ, ერთზე მეტი განგაში და "
"წამზომი დააყენოთ."

#. (itstool) path: description/p
#: org.kde.kclock.appdata.xml:19
msgid ""
"It contains alarm, timer, stopwatch and timezone functionalities. Alarms and "
"timers are able to wake the device from suspend on Plasma."
msgstr ""
"ის განგაშის, ტაიმერის, წამზომის და დროის სარტყლის ფუნქციებს მოიცავს. "
"მაღვიძარას და ტაიმერებს შეუძლიათ გააღვიძონ მოწყობილობა, თუ Plasma გაშვებულია."

#. (itstool) path: screenshot/caption
#: org.kde.kclock.appdata.xml:33
msgid "Mobile view"
msgstr "მობილური ხედი"

#. (itstool) path: screenshot/caption
#: org.kde.kclock.appdata.xml:37
msgid "Desktop view"
msgstr "სამუსაო მაგიდის ხედი"

#. (itstool) path: screenshot/caption
#: org.kde.kclock.appdata.xml:41
msgid "Timers page"
msgstr "წამმზომების გვერდი"

#. (itstool) path: screenshot/caption
#: org.kde.kclock.appdata.xml:45
msgid "Timer page"
msgstr "წამმზომის გვერდი"

#. (itstool) path: screenshot/caption
#: org.kde.kclock.appdata.xml:49
msgid "Stopwatch page"
msgstr "სხვანაირი წამმზომის გვერდი"

#. (itstool) path: screenshot/caption
#: org.kde.kclock.appdata.xml:53
msgid "Alarms page"
msgstr "მაღვიძარის გვერდი"

#. (itstool) path: description/p
#: org.kde.kclock.appdata.xml:111
msgid "New features and bugfixes in this release:"
msgstr "ახალი ფუნქციები და შეცდომების გასწორება ამ ვერსიაში:"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:113
msgid "Fixed timer add one minute button."
msgstr "გასწორდა ტაიმერისთვის ერთი წუთის დამატების ღილაკი."

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:114
msgid "Switched to tab bar based sidebar (similar to bottom navigation bar)."
msgstr ""
"გადართვა ჩანართებზე ბაზირებულ გვერდით პანელზე (ქვედა ნავიგაციის პანელის "
"მსგავსად)."

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:131
msgid "Support for background daemon when using flatpak"
msgstr "ფონური დემონის მხარდაჭერა flatpak-ის გამოყენებისას"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:132
msgid "Fix excessive log generation on non-Plasma system"
msgstr "გასწორდა ზედმეტი ჟურნალის ჩანაწერების გენერაცია არა-Plasma სისტემებზე"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:140
msgid "Fix \"Clock daemon not found\" popup message"
msgstr "გასწორდა მხტუნარა შეტყობინება 'საათის დემონი აღმოჩენილი არაა'"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:141
msgid "Various bugfixes and user interface improvements"
msgstr "მომხმარებლის ინტერფეისის გაუმჯობესება და შეცდომების გამოსწორება"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:142
msgid "Add a sound picker component for listing alarm sounds"
msgstr "დაემატა ხმის არჩევის კომპონენტი განგაშის ხმების ჩამოსათვლელად"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:143
msgid "Start snooze only after button is pressed"
msgstr "გადადების დაწყება, მხოლოდ, ღილაკზე დაჭერის შემდეგ"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:144
msgid "Fix alarms not working on PinePhone"
msgstr "გასწორდა განგაშების პრობლემა PinePhone-ზე"

#. (itstool) path: description/p
#: org.kde.kclock.appdata.xml:150 org.kde.kclock.appdata.xml:167
msgid "Changes:"
msgstr "ცვლილებები:"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:152
msgid "Kirigami's bottom navigation bar component is now used for mobile"
msgstr "ახლა მობილურისთვის გამოიყენება Kirigami-ის ქვედა ნავიგაციის კომპონენტი"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:153
msgid "A Plasma style sidebar is now used on desktop"
msgstr "სამუშაო მაგიდაზე ახლა Plasma-ის სტილის გვერდითი პანელი გამოიყენება"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:154
msgid "The system tray item now only shows when alarms are pending"
msgstr "ხატულს სისტემურ საათთან ახლა, მხოლოდ, ნაჩვენებია, თუ განგაშები რიგშია"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:155
msgid "The daemon automatically stops if no alarms and timers are pending"
msgstr "დემონი ავტომატურად გაჩერდება, თუ განგაშები და ტაიმერები რიგში არაა"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:156
msgid "Action bars are now used on the timer and alarms forms page"
msgstr ""
"ქმედებების პანელები ახლა გამოიყენება ტაიმერისა და განგაშის ფორმების გვერდზე"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:157
msgid "The settings button has been moved to the top actions bar"
msgstr "მორგების ღილაკი გადატანილია ზედა ქმედებების პანელზე"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:169
msgid ""
"Watch DBus for PowerDevil, so wake from suspend always works if PowerDevil "
"is found"
msgstr ""
"PowerDevil-ის ლოდინი DBus-ზე, ასე რომ, გაღვიძება ყოველთვის მუშაობს, თუ "
"PowerDevil აღმოჩენილია"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:170
msgid "Use consistent dialog style on the settings page"
msgstr "მუდმივი დიალოგის სტილის გამოყენება მორგების გვერდზე"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:171
msgid "After editing an alarm, the alarm now automatically is activated"
msgstr "განგაშის ჩასწორების შემდეგ, ახლა, განგაში ავტომატურად გააქტიურდება"

#. (itstool) path: description/p
#: org.kde.kclock.appdata.xml:178
msgid "New features and bugfixes:"
msgstr "ახალი ფუნქციები და შეცდომების გასწორებები:"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:180
msgid "Added the ability to set timer presets"
msgstr "დაემატა ტაიმერის პრესეტების დაყენების შესაძლებლობა"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:181
msgid "Added ability to increase timer duration by 1m as timer is running"
msgstr ""
"დაემატა ტაიმერის ხანგრძლივობის ერთი წუთით გაზრდის საშუალება, როცა ტაიმერი "
"გაშვებულია"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:182
msgid ""
"Fixed multiple alarm sounds and notifications being played for one alarm"
msgstr ""
"გასწორდა ერთზე მეტი განგაშისა და შეტყობინების ხმის ერთდროული დაკვრა ერთი "
"განგაშისთვის"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:183
msgid "Fixed errors that prevented the application from working in a Flatpak"
msgstr ""
"გასწორდა შეცდომები, რომლებიც აპლიკაციას Flatpak-ში მუშაობის საშუალებას არ "
"აძლევდა"

#~ msgid "Set alarms and timers, use a stopwatch, and manage world clocks"
#~ msgstr "დააყენეთ გაფრთხილებები, წამმზომები და მაღვიძარები, მართეთ საათები"

#~ msgid "A universal clock application for desktop and mobile."
#~ msgstr "უნივერსალური საათის პროგრამა დესკტოპისა და მობილურისთვის."

#~ msgid "KDE Community"
#~ msgstr "KDE Community"
