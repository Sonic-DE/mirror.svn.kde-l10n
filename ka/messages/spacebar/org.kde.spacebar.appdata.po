#. (itstool) path: component/name
#: org.kde.spacebar.appdata.xml:4
msgid "Spacebar"
msgstr "Spacebar"

#. (itstool) path: component/summary
#: org.kde.spacebar.appdata.xml:5
msgid "SMS/MMS messaging client"
msgstr "SMS/MMS შეტყობინებების კლიენტი"

#. (itstool) path: description/p
#: org.kde.spacebar.appdata.xml:12
msgid ""
"Spacebar is a SMS/MMS messaging client. It allows you to send text messages, "
"pictures and other files over a cellular network."
msgstr ""
"Spacebar არის SMS / MMS შეტყობინებების კლიენტი. ის საშუალებას გაძლევთ "
"გაგზავნოთ ტექსტური შეტყობინებები, სურათები და სხვა ფაილები ფიჭური ქსელით."

#~ msgid "KDE Community"
#~ msgstr "KDE-ის საზოგადოება"

#~ msgid ""
#~ "Spacebar is a telepathy client for Plasma Mobile, that is primarily "
#~ "written for sending and receiving SMS/MMS."
#~ msgstr ""
#~ "Spacebar -ი Plasma Mobile-ის ტელეპათიის კლიენტია, რომელიც ძირითადად SMS/"
#~ "MMS-ების გაგზავნა მიღებისთვისაა განკუთვნილი."
