#. (itstool) path: component/name
#: org.kde.ksirk.appdata.xml:10
msgid "KsirK"
msgstr "KsirK"

#. (itstool) path: component/summary
#: org.kde.ksirk.appdata.xml:11
msgid "World Domination Strategy Game"
msgstr "სტრატეგიული თამაში სამყაროს დომინაციისთვის"

#. (itstool) path: description/p
#: org.kde.ksirk.appdata.xml:13
msgid ""
"KsirK is a computerized version of the well known strategic board game Risk. "
"The goal of the game is simply to conquer the world by attacking your "
"neighbors with your armies."
msgstr ""
"KsirK კომპიუტერიზებული ვერსიაა ცნობილი სტრატეგიული სამაგიდო თამაშისთვის "
"Risk. თამაშის აზრია, უბრალოდ მთელი მსოფლიო დაიპყროთ, მეზობლებზე თქვენი "
"არმიების თავდასხმით."

#. (itstool) path: description/p
#: org.kde.ksirk.appdata.xml:17
msgid "Features:"
msgstr "თვისებები:"

#. (itstool) path: ul/li
#: org.kde.ksirk.appdata.xml:19
msgid "Support for 1-6 human or computer (AI) players"
msgstr "1-6 ადამიანის ან კომპიუტერის (AI) მხარდაჭერა"

#. (itstool) path: ul/li
#: org.kde.ksirk.appdata.xml:20
msgid "Multi-player gaming over a network"
msgstr "მრავალმოთამაშიან ქსელთან მიერთება"

#. (itstool) path: ul/li
#: org.kde.ksirk.appdata.xml:21
msgid "You can easily create new skins with SVG graphics and the skin editor"
msgstr "ახალი სკინების შექმნა SVG გრაფიკით და სკინების რედაქტორით შეგიძლიათ"

#. (itstool) path: ul/li
#: org.kde.ksirk.appdata.xml:22
msgid "Hot New Stuff support. You can easily download and install new skins"
msgstr ""
"სიახლეების მხარდაჭერა. ახალი სკინების გადმოწერა და დაყენება ადვილად შეგიძლიათ"
