#. (itstool) path: component/name
#: org.kde.ktorrent.appdata.xml:10
msgid "KTorrent"
msgstr "KTorrent"

#. (itstool) path: component/summary
#: org.kde.ktorrent.appdata.xml:11
msgid "BitTorrent Client"
msgstr "BitTorrent -ის კლიენტი"

#. (itstool) path: description/p
#: org.kde.ktorrent.appdata.xml:13
msgid ""
"KTorrent is a BitTorrent application by KDE which allows you to download "
"files using the BitTorrent protocol. It enables you to run multiple torrents "
"at the same time and comes with extended features to make it a full-featured "
"client for BitTorrent."
msgstr ""
"KTorrent ტორენტის აპლიკაციაა KDE-სგან, რომელიც საშუალებას გაძლევთ, ფაილები "
"BitTorrent პროტოკოლის გამოყენებით გადმოწეროთ. ის საშუალებას გაძლევთ, "
"ერთდროულად ბევრი ტორენტი გაუშვათ და მოჰყვება დამატებითი ფუნქციები, რაც მას "
"სრულად შეიარაღებულ ტორენტის კლიენტად აქცევს."

#. (itstool) path: description/p
#: org.kde.ktorrent.appdata.xml:18
msgid "Features:"
msgstr "თვისებები:"

#. (itstool) path: ul/li
#: org.kde.ktorrent.appdata.xml:20
msgid "Queuing of torrents"
msgstr "ტორენტების რიგი"

#. (itstool) path: ul/li
#: org.kde.ktorrent.appdata.xml:21
msgid "Global and per torrent speed limits"
msgstr "გლობალური და სათითაო ტორენტის სიჩქარის ლიმიტი"

#. (itstool) path: ul/li
#: org.kde.ktorrent.appdata.xml:22
msgid "Previewing of certain file types, build in (video and audio)"
msgstr "მინიატურები ზოგიერთი ფაილის ტიპებისთვის, ჩაშენებული (ვიდეო და აუდიო)"

#. (itstool) path: ul/li
#: org.kde.ktorrent.appdata.xml:23
msgid "Importing of partially or fully downloaded files"
msgstr "ნაწილობრივ ან სრულად გადმოწერილი ფაილების შემოტანა"

#. (itstool) path: ul/li
