#. (itstool) path: component/name
#: org.kde.kdialog.metainfo.xml:6
msgid "KDialog"
msgstr "KDialog"

#. (itstool) path: component/summary
#: org.kde.kdialog.metainfo.xml:7
msgid "Display dialog boxes from shell scripts"
msgstr "სკრიპტებიდან ფანჯრების ჩვენება"

#. (itstool) path: description/p
#: org.kde.kdialog.metainfo.xml:9
msgid ""
"KDialog allows you to display dialog boxes from shell scripts. The syntax is "
"very much inspired from the \"dialog\" command (which shows text mode "
"dialogs)."
msgstr ""
"KDialog საშუალებას გაძლევთ, გრაფიკული ფანჯრები გარსის სკრიპტებიდან "
"გამოიძახოთ. სინტაქსი ძალიან წააგავს \"dialog\" ბრძანებისას (რომელიც იგივეს "
"ტექსტურ რეჟიმში აკეთებს)."
