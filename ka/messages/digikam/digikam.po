#: core/utilities/setup/metadata/setupmetadata_baloo.cpp:63
#, kde-format
msgctxt "@info"
msgid ""
"provides the basis to handle all kinds of metadata on the KDE desktop in a "
"generic fashion. It allows you to tag, rate and comment your files in KDE "
"applications like Dolphin. Please set here if you want to synchronize the "
"metadata stored by digiKam desktop-wide with the Baloo Desktop Search."
msgstr ""

#: core/utilities/setup/metadata/setupmetadata_baloo.cpp:84
#, kde-format
msgctxt "@title:tab"
msgid "Baloo"
msgstr "Baloo"

#: core/utilities/setup/metadata/setupmetadata_behavior.cpp:34
#, kde-kuit-format
msgctxt "@info:whatsthis"
msgid ""
"<para>In addition to the pixel content, image files usually contain a "
"variety of metadata. A lot of the parameters you can use in digiKam to "
"manage files, such as rating or comment, can be written to the files' "
"metadata.</para> <para>Storing in metadata allows one to preserve this "
"information when moving or sending the files to different systems.</para>"
msgstr ""

#: core/utilities/setup/metadata/setupmetadata_behavior.cpp:44
#, kde-format
msgctxt "@label"
msgid "Write This Information to the Metadata"
msgstr "ამ ინფორმაციის ჩაწერა მეტამონაცემებში"

#: core/utilities/setup/metadata/setupmetadata_behavior.cpp:49
#, kde-format
msgctxt "@option:check"
msgid "Image tags"
msgstr "გამოსახულების ჭდეები"

#: core/utilities/setup/metadata/setupmetadata_behavior.cpp:50
#, kde-format
msgctxt "@info:whatsthis"
msgid "Turn on this option to store the item tags in the XMP and IPTC tags."
msgstr "ჩართეთ ეს პარამეტრები ელემენტის ჭდეების XMP და IPTC ჭდეებში შესანახად."

#: core/utilities/setup/metadata/setupmetadata_behavior.cpp:54
#, kde-format
msgctxt "@option:check"
msgid "Captions and title"
msgstr "წარწერა და სათაური"

#: core/utilities/setup/metadata/setupmetadata_behavior.cpp:55
#, kde-format
msgctxt "@info:whatsthis"
msgid ""
"Turn on this option to store item caption and title in the JFIF Comment "
"section, the Exif tag, the XMP tag, and the IPTC tag."
msgstr ""
"ჩართეთ ეს პარამეტრი ელემენტის წარწერისა და სათაურის JFIF-ის კომენტარების "
"სექციაში, Exif-ის ჭდეში, XMP ჭდეში და IPTC ჭდეში შესანახად."

#: core/utilities/setup/metadata/setupmetadata_behavior.cpp:60
#, kde-format
msgctxt "@option:check"
msgid "Rating"
msgstr "შეფასება"

#: core/utilities/setup/metadata/setupmetadata_behavior.cpp:61
#, kde-format
msgctxt "@info:whatsthis"
msgid ""
"Turn on this option to store the item rating in the Exif tag and the XMP "
"tags."
msgstr ""
"ჩართეთ ეს პარამეტრი ელემენტის რეიტინგის Exif ჭდეში და XMP ჭდეებში შესანახად."

#: core/utilities/setup/metadata/setupmetadata_behavior.cpp:65
#, kde-format
msgctxt "@option:check"
msgid "Pick label"
msgstr "აირჩიეთ ჭდე"

#: core/utilities/setup/metadata/setupmetadata_behavior.cpp:66
#, kde-format
msgctxt "@info:whatsthis"
msgid "Turn on this option to store the item pick label in the XMP tags."
msgstr "ჩართეთ ეს პარამეტრი ელემენტის არჩევის ჭდის XMP ჭდეებში შესანახად."

#: core/utilities/setup/metadata/setupmetadata_behavior.cpp:70
#, kde-format
msgctxt "@option:check"
msgid "Color label"
msgstr "ჭდის ფერი"

#: core/utilities/setup/metadata/setupmetadata_behavior.cpp:71
#, kde-format
msgctxt "@info:whatsthis"
msgid "Turn on this option to store the item color label in the XMP tags."
msgstr "ჩართეთ ეს პარამეტრი ელემენტის ფერის ჭდის შესანახად XMP ჭდეებში."

#: core/utilities/setup/metadata/setupmetadata_behavior.cpp:75
#, kde-format
msgctxt "@option:check"
msgid "Timestamps"
msgstr "დროის შტამპები"

#: core/utilities/setup/metadata/setupmetadata_behavior.cpp:76
#, kde-format
msgctxt "@info:whatsthis"
msgid ""
"Turn on this option to store the item date and time in the EXIF, XMP, and "
"IPTC tags."
msgstr ""
"ჩართეთ ეს პარამეტრი ელემენტის დროისა და თარიღის შესანახად EXIF, XMP და IPTC "
"ჭდეებში."

#: core/utilities/setup/metadata/setupmetadata_behavior.cpp:80
#, kde-format
msgctxt "@option:check"
msgid "Metadata templates (Copyright etc.)"
msgstr "მეტამონაცემების შაბლონები (საავტორო უფლებები და ა.შ.)"

#: core/utilities/setup/metadata/setupmetadata_behavior.cpp:81
#, kde-format
msgctxt "@info:whatsthis"
msgid ""
"Turn on this option to store the metadata template in the XMP and the IPTC "
"tags. You can set template values to Template setup page."
msgstr ""
"ჩართეთ ეს პარამეტრი მეტამონაცემების შაბლონის XMP და IPTC ჭდეებში შესანახად. "
"შაბლონის მნიშვნელობის დაყენება 'შაბლონის მორგების' გვერდზე შეგიძლიათ."

#: core/utilities/setup/metadata/setupmetadata_behavior.cpp:85
#, kde-format
msgctxt "@option:check"
msgid "Face Tags (including face areas)"
msgstr "სახის ჭდეები (სახის ადგილების ჩათვლით)"

#: core/utilities/setup/metadata/setupmetadata_behavior.cpp:86
#, kde-format
msgctxt "@info:whatsthis"
msgid ""
"Turn on this option to store face tags with face rectangles in the XMP tags."
msgstr ""
"ჩართეთ ეს პარამეტრი სახის ჭდეების შესანახად მართკუთხედებთან ერთად XMP "
"ჭდეებში."

#: core/utilities/setup/metadata/setupmetadata_behavior.cpp:90
#, kde-format
msgctxt "@option:check"
msgid "Geolocation information (GPS)"
msgstr "გეოლოკაციის ინფორმაცია (GPS)"

#: core/utilities/setup/metadata/setupmetadata_behavior.cpp:91
#, kde-format
msgctxt "@info:whatsthis"
msgid ""
"Turn on this option to store Geolocation information in the Exif tag and the "
"XMP tags."
msgstr "ჩართეთ ეს პარამეტრი გეოლოკაციის შესანახად Exif და XMPჭდეებში."

#: core/utilities/setup/metadata/setupmetadata_behavior.cpp:115
#, kde-format
msgctxt "@label"
msgid "Reading and Writing Metadata"
msgstr "მეტამონაცემების წაკითხვა და ჩაწერა"

#: core/utilities/setup/metadata/setupmetadata_behavior.cpp:120
#, kde-format
msgctxt "@option:check"
msgid "Use ExifTool backend to read metadata from files"
msgstr ""
"ფაილებიდან მეტამონაცემების წასაკითხად ExcifTool-ის უკანაბოლოს გამოყენება"

#: core/utilities/setup/metadata/setupmetadata_behavior.cpp:121
#, kde-format
msgctxt "@info:whatsthis"
msgid ""
"Turn on this option to read metadata from files with ExifTool backend "
"instead Exiv2. This will slowdown a little bit the synchronization of files "
"metadata with database."
msgstr ""
"ჩართეთ ეს პარამეტრი მეტამონაცემების ფაილებიდან ExifTool უკანაბოლოთი "
"წასაკითხად Exiv2-ის მაგიერ. ეს ფაილის მეტამონაცემების მონაცემთა ბაზასთან "
"სინქრონიზაციას ოდნავ შეანელებს."

#: core/utilities/setup/metadata/setupmetadata_behavior.cpp:126
#, kde-format
msgctxt "@option:check"
msgid "Delegate to ExifTool backend all operations to write metadata to files"
msgstr "ExifTool უკანაბოლოზე გადაცემა მეტამონაცემების ფაილებში ჩაწერისას"

#: core/utilities/setup/metadata/setupmetadata_behavior.cpp:127
#, kde-format
msgctxt "@info:whatsthis"
msgid ""
"Turn on this option to write metadata to files with ExifTool backend instead "
"Exiv2. This will slowdown a little bit the synchronization of files metadata "
"with database."
msgstr ""
"ჩართეთ ეს პარამეტრი ფაილებში მეტამონაცემების ExifTool-ით ჩასაწერად Exiv2-ის "
"მაგიერ. ეს ფაილის მეტამონაცემების მონაცემთა ბაასთან სინქრონიზაციას ოდნავ "
"შეანელებს."

#: core/utilities/setup/metadata/setupmetadata_behavior.cpp:132
#, kde-format
msgctxt "@option:check"
msgid "Write metadata to DNG files"
msgstr "DNG ფაილების მეტამონაცემების ჩაწერა"

#: core/utilities/setup/metadata/setupmetadata_behavior.cpp:133
#, kde-format
msgctxt "@info:whatsthis"
msgid "Turn on this option to write metadata into DNG files."
msgstr "ჩართეთ ეს პარამეტრი მეტამონაცემების ჩასაწერად DNG ფაილებში."

#: core/utilities/setup/metadata/setupmetadata_behavior.cpp:136
#, kde-format
msgctxt "@option:check"
msgid "If possible write metadata to RAW files"
msgstr "მეტამონაცემების ჩაწერა RAW ფაილებში, თუ ეს შესაძლებელია"

#: core/utilities/setup/metadata/setupmetadata_behavior.cpp:137
#, kde-format
msgctxt "@info:whatsthis"
msgid ""
"Turn on this option to write metadata into RAW files. This feature is "
"delegate to ExifTool backend and is disabled by default."
msgstr ""
"ჩართეთ ეს პარამეტრი მეტამონაცემების ჩასაწერად RAW ფაილებში. ეს ფუნქცია "
"ExifTool უკანაბოლოზე გადართვაა და ნაგულისხმევად გათიშულია."

#: core/utilities/setup/metadata/setupmetadata_behavior.cpp:146
#, kde-format
msgctxt "@option:check"
msgid "Use lazy synchronization"
msgstr "ზარმაცი სინქრონიზაციის გამოყენება"

#: core/utilities/setup/metadata/setupmetadata_behavior.cpp:148
#, kde-format
msgctxt "@info:whatsthis"
msgid ""
"Instead of synchronizing metadata, just schedule it for synchronization."
"Synchronization can be done later by triggering the apply pending, or at "
"digikam exit"
msgstr ""

#: core/utilities/setup/metadata/setupmetadata_behavior.cpp:152
#, kde-format
msgctxt "@option:check"
msgid "&Update file modification timestamp when files are modified"
msgstr "&ფაილის მოდიფიკაციის დროის შტამპის განახლება ფაილების ცვლილებისას"

#: core/utilities/setup/metadata/setupmetadata_behavior.cpp:154
#, kde-format
msgctxt "@info:whatsthis"
msgid ""
"Turn off this option to not update file timestamps when files are changed as "
"when you update metadata or image data. Note: disabling this option can "
"introduce some dysfunctions with applications which use file timestamps "
"properties to detect file modifications automatically."
msgstr ""

#: core/utilities/setup/metadata/setupmetadata_behavior.cpp:160
#, kde-format
msgctxt "@option:check"
msgid "&Rescan file when files are modified"
msgstr "ფაილის თავიდან სკანი&რება მათი ცვლილებისას"

#: core/utilities/setup/metadata/setupmetadata_behavior.cpp:162
#, kde-format
msgctxt "@info:whatsthis"
msgid ""
"Turning this option on, will force digiKam to rescan files that has been "
"modified outside digiKam. If a file has changed it is file size or if the "
"last modified timestamp has changed, a rescan of that file will be performed "
"when digiKam starts."
msgstr ""

#: core/utilities/setup/metadata/setupmetadata_behavior.cpp:235
#, kde-format
msgctxt "@label"
msgid "Note: see %1 of ExifTool backend."
msgstr "შენიშვნა: იხილეთ ExifTool-ის %1 of ExifTool."

#: core/utilities/setup/metadata/setupmetadata_behavior.cpp:237
#, kde-format
msgctxt "@label"
msgid "write limitations"
msgstr "ჩაწერის ლიმიტები"

#: core/utilities/setup/metadata/setupmetadata_behavior.cpp:245
#, kde-format
msgctxt "@label"
msgid ""
"Note: these options depends of %1 availability. Check in the ExifTool tab "
"for details."
msgstr ""
"შენიშვნა: ეს პარამეტრები ეყრდნობა %1-ის ხელმისაწვდომობას. დეტალებისთვის "
"იხილეთ ExifTool-ის ჩანართი."

#: core/utilities/setup/metadata/setupmetadata_behavior.cpp:248
#, kde-format
msgctxt "@label"
msgid "ExifTool backend"
msgstr "უკანაბოლო ExifTool"

#: core/utilities/setup/metadata/setupmetadata_display.cpp:28
#, kde-format
msgctxt "@label"
msgid "Select Metadata Fields to be Displayed when using Custom Filters"
msgstr ""
"აირჩიეთ, რომელი მეტამონაცემთა ველები იქნება ნაჩვენები მომხმარებლის ფილტრების "
"გამოყენებისას"

#: core/utilities/setup/metadata/setupmetadata_display.cpp:43
#, kde-format
msgctxt "@title:tab"
msgid "Views"
msgstr "ხედები"

#: core/utilities/setup/metadata/setupmetadata_rotation.cpp:31
#, kde-format
msgctxt "@label"
msgid "When rotating a file"
msgstr "ფაილის სემობრუნებისას"

#: core/utilities/setup/metadata/setupmetadata_rotation.cpp:35
#, kde-format
msgctxt "@option:radio"
msgid "Rotate by only setting a flag"
msgstr "მობრუნება მხოლოდ ალმის დაყენებით"

#: core/utilities/setup/metadata/setupmetadata_rotation.cpp:36
#, kde-format
msgctxt "@option:radio"
msgid "Rotate by changing the content if possible"
msgstr "მობრუნება შემცველობის შეცვლით, თუ ეს შესაძლებელია"

#: core/utilities/setup/metadata/setupmetadata_rotation.cpp:37
#, kde-format
msgctxt "@option:check"
msgid "Even allow lossy rotation if necessary"
msgstr "თუ საჭიროა, დაშვებული იქნება კარგვითი ბრუნვაც"

#: core/utilities/setup/metadata/setupmetadata_rotation.cpp:38
#, kde-format
msgctxt "@option:check"
msgid "Write flag to metadata if possible"
msgstr "ალმის ჩაწერა მეტამონაცემებში, თუ ეს შესაძლებელია"

#: core/utilities/setup/metadata/setupmetadata_rotation.cpp:50
#, kde-format
msgctxt "@info:tooltip"
msgid "Rotate files only by changing a flag, not touching the pixel data"
msgstr "ფაილების შებრუნება ალმის ცვლილებით და პიქსელის მონაცემების შეუხებლად"

#: core/utilities/setup/metadata/setupmetadata_rotation.cpp:52
#, kde-kuit-format
msgctxt "@info:whatsthis"
msgid ""
"<para>A file can be rotated in two ways:<nl/> You can change the contents, "
"rearranging the individual pixels of the image data.<nl/> Or you can set a "
"flag that the file is to be rotated before it is shown.</para> <para>Select "
"this option if you always want to set only a flag. This is less obtrusive, "
"but requires support if the file is accessed with another software. Ensure "
"to allow setting the flag in the metadata if you want to share your files "
"outside digiKam.</para>"
msgstr ""

#: core/utilities/setup/metadata/setupmetadata_rotation.cpp:61
#, kde-format
msgctxt "@info:tooltip"
msgid "If possible rotate files by changing the pixel data"
msgstr "თუ შესაძლებელია, ფაილების მობრუნება პიქსელის მონაცემების ცვლილებით"

#: core/utilities/setup/metadata/setupmetadata_rotation.cpp:63
#, kde-kuit-format
msgctxt "@info:whatsthis"
msgid ""
"<para>A file can be rotated in two ways:<nl/> You can change the contents, "
"rearranging the individual pixels of the image data.<nl/> Or you can set a "
"flag that the file is to be rotated before it is shown.</para> <para>Select "
"this option if you want the file to be rotated by changing the content. This "
"is a lossless operation for JPEG files. For other formats it is a lossy "
"operation, which you need to enable explicitly. It is not support for RAW "
"and other read-only formats, which will be rotated by flag only.</para>"
msgstr ""

#: core/utilities/setup/metadata/setupmetadata_rotation.cpp:73
#, kde-format
msgctxt "@info:tooltip"
msgid ""
"Rotate files by changing the pixel data even if the operation will incur "
"quality loss"
msgstr ""
"ფაილების შებრუნება პიქსელის მონაცემების შეცვლით მაშინაც კი, თუ ოპერაცია "
"ხარისხის კარგვას იწვევს"

#: core/utilities/setup/metadata/setupmetadata_rotation.cpp:75
#, kde-format
msgctxt "@info:whatsthis"
msgid ""
"For some file formats which apply lossy compression, data will be lost each "
"time the content is rotated. Check this option to allow lossy rotation. If "
"not enabled, these files will be rotated by flag."
msgstr ""

#: core/utilities/setup/metadata/setupmetadata_rotation.cpp:81
#, kde-format
msgctxt "@info:tooltip"
msgid ""
"When rotating a file by setting a flag, also change this flag in the file's "
"metadata"
msgstr ""
"ფაილის შემობრუნებისას ალმის დაყენებით ეს ალამი ასევე შეიცვლება ფაილის "
"მეტამონაცემებში"

#: core/utilities/setup/metadata/setupmetadata_rotation.cpp:83
#, kde-format
msgctxt "@info:whatsthis"
msgid ""
"File metadata typically contains a flag describing that a file shall be "
"shown rotated. Enable this option to allow editing this field. "
msgstr ""
"ფაილის მეტამონაცემები, ჩვეულებრივ, შეიცავს ალამს, რომ ეს ფაილი უნდა "
"შებრუნდეს. ჩართეთ ეს პარამეტრი ამ ველის რედაქტირების დასაშვებად. "

#: core/utilities/setup/metadata/setupmetadata_rotation.cpp:107
#, kde-format
msgctxt "@option"
msgid "Show images/thumbnails &rotated according to orientation tag."
msgstr ""
"გამოსახულებების/მინიატურების შებ&რუნებული ჩვენება ორიენტაციის ჭდის მიხედვით."

#: core/utilities/setup/metadata/setupmetadata_rotation.cpp:109
#, kde-format
msgctxt "@option"
msgid "Set orientation tag to normal after rotate/flip."
msgstr "ორიენტაციის ჭდის ნორმალურზე დაყენება მობრუნების/გადაბრუნების შემდეგ."

#: core/utilities/setup/metadata/setupmetadata_rotation.cpp:120
#, kde-format
msgctxt "@info"
msgid ""
"Note: These settings affect the album view and not the image editor. The "
"image editor always changes the image data during the rotation."
msgstr ""
"შენიშვნა: ეს პარამეტრები ეხება ალბომის ხედს და არა გამოსახულების რედაქტორს. "
"გამოსახულების რედაქტორი ყოველთვის ცვლის გამოსახულების მონაცემებს მისი "
"შემობრუნებისას."

#: core/utilities/setup/metadata/setupmetadata_rotation.cpp:134
#, kde-format
msgctxt "@title:tab"
msgid "Rotation"
msgstr "შემობრუნება"

#: core/utilities/setup/metadata/setupmetadata_sidecars.cpp:33
#, kde-format
msgctxt "@label"
msgid "Reading and Writing to Sidecars"
msgstr "ჩაწერა და წაკითხვა დამატებითი ფაილებიდან"

#: core/utilities/setup/metadata/setupmetadata_sidecars.cpp:36
#, kde-format
msgctxt "@option:check"
msgid "Read from sidecar files"
msgstr "წაკითხვა დამატებითი ფაილებიდან"

#: core/utilities/setup/metadata/setupmetadata_sidecars.cpp:38
#, kde-format
msgctxt "@info:whatsthis"
msgid ""
"Turn on this option to read metadata from XMP sidecar files when reading "
"metadata."
msgstr ""
