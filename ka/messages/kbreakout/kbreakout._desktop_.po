#: themes/web20.desktop:2
msgctxt "Name"
msgid "WEB 2.0"
msgstr "WEB 2.0"

#: themes/web20.desktop:57
msgctxt "Description"
msgid ""
"Web 2.0 theme showcases graphical elements reminiscent of those used in "
"popular 'WEB 2.0' movement, currently taking the interweb by storm."
msgstr ""
"ვებ 2.0-ის თემა გამოხატავს გრაფიკულ ელემენტს, რომელიც წააგავს მათ, რომლებიც "
"\"WEB 2.0\" მოძრაობაში გამოიყენებოდა და ახლა ვებს შტურმით იღებს."
