#. (itstool) path: component/name
#: org.kde.krusader.appdata.xml:7
msgid "Krusader"
msgstr "Krusader"

#. (itstool) path: component/summary
#: org.kde.krusader.appdata.xml:8
msgid "File Manager"
msgstr "ფაილების მმართველი"

#. (itstool) path: description/p
#: org.kde.krusader.appdata.xml:13
msgid ""
"Krusader is an advanced twin panel (commander style) file manager for KDE "
"Plasma and other desktops in the *nix world"
msgstr ""
"Krusader დამატებითი ფუნქციების მქონე ორპანელიანი (commander-ის სტილი) "
"ფაილების მმართველა KDE Plasma-სთვის და სხვა სამუშაოებისთვის *nix სამყაროში"

#. (itstool) path: description/p
#: org.kde.krusader.appdata.xml:14
msgid "Features:"
msgstr "ფუნქციები:"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:16
msgid "Extensive archive handling"
msgstr "არქივების დამუშავების ფართო შესაძლებლობები"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:17
msgid "Mounted filesystem support"
msgstr "მიმაგრებული ფაილური სისტემების მხარდაჭერა"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:18
msgid "FTP support"
msgstr "FTP -ის მხარდაჭერა"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:19
msgid "Advanced search module"
msgstr "დამატებითი პარამეტრებით ძებნის მოდული"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:20
msgid "Internal viewer/editor"
msgstr "შიდა დამთვალიერებელი/რედაქტორი"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:21
msgid "Folder synchronisation"
msgstr "საქაღალდის სინქრონიზაცია"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:22
msgid "File content comparisons"
msgstr "ფაილების შემცველობის შედარება"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:23
msgid "Powerful batch renaming"
msgstr "მძლავრი მრავალი ფაილის ერთდროულად სახელის გადარქმევის ფუნქციები"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:24
msgid ""
"Support for a wide variety of archive formats and can handle other KIO "
"slaves such as smb or fish."
msgstr ""
"მხარდაჭერა არქივების მრავალი ფორმატისთვის და შეუძლია სხვა KIO-ის დამხმარე "
"პროგრამების გამოყენება. მაგალითად smb ან fish."

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:25
msgid "Completely customizable and very user friendly"
msgstr "სრულად მორგებადი და ძალიან მოსახერხებელი"

#. (itstool) path: screenshot/caption
#: org.kde.krusader.appdata.xml:33
msgid "File management in Krusader"
msgstr "ფაილების მართვა Krusader-ით"
