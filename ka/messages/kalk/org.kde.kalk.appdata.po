#. (itstool) path: component/name
#: org.kde.kalk.appdata.xml:12
msgid "Calculator"
msgstr "კალკულატორი"

#. (itstool) path: component/summary
#: org.kde.kalk.appdata.xml:13
msgid "A feature rich calculator"
msgstr "მრავალფუნქციური კალკულატორი"

#. (itstool) path: description/p
#: org.kde.kalk.appdata.xml:18
msgid "Kalk is a convergent calculator for Plasma."
msgstr "Kalc-ი Plasma-ის კალკულატორია."

#. (itstool) path: screenshot/caption
#: org.kde.kalk.appdata.xml:22
msgid "Calculator Page"
msgstr "კალკულატორის გვერდი"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:95
msgid "Show decimal separator according to locale"
msgstr "წილადის გამყოფის ჩვენება ლოკალის მიხედვით"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:96
msgid "Fix bug preventing input of comma"
msgstr "გასწორდა შეცდომა, რომლის გამოც მძიმეს ვერ შეიყვანდით"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:104
msgid "General bugfixing and code quality improvements"
msgstr "კოდის რეფაქტორინგი და მომხმარებლის ინტერფეისის გაუმჯობესებები"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:112
msgid "Rearrange trigonometric functions to be together"
msgstr "ტრიგონომეტრიული ფუნქციების ერთად დალაგება"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:113
msgid "Various user-interface improvements"
msgstr "ინტერფეისის სხვადასხვა ნაწილის გაუმჯობესება"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:120
msgid "Rework sidebar design"
msgstr "გადამუშავდა გვერდითი პანელის დიზაინი"

#. (itstool) path: description/p
#: org.kde.kalk.appdata.xml:133
msgid "Changes:"
msgstr "ცვლილებები:"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:135
msgid "Updated the application icon"
msgstr "განახლდა აპლიკაციის ხატულა"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:136
msgid "Added support for parentheses keyboard input"
msgstr "დაემატა ფრჩხილების კლავიატურით შეყვანის მხარდაჭერა"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:137
msgid "Fixed the calculator drawer opening when the application opens"
msgstr "გამოსწორდა კალკულატორის უჯრის გახსნა აპლიკაციის გაშვებისას"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:138
msgid ""
"Changed backspace icon to use a proper system icon instead of a font "
"provided one"
msgstr ""
"შეიცვალა backspace-ის ხატულა, რომ გამოიყენოს სწორი სისტემური ხატულა ფონტის "
"მიერ გადმოცემულის მაგიერ"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:139
msgid "Added keyboard support to unit converter"
msgstr "ერთეულების გარდამქმნელს დაემატა კლავიატურის მხარდაჭერა"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:140
msgid "Fixed page change animation for binary calculator"
msgstr "გამოსწორდა გვერდის შეცვლის ანიმაცია ბინარული კალკულატორისთვის"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:141
msgid "Enabled qml debugging when compiled in debug mode"
msgstr "ჩაირთო QML-ის გამართვა გამართვის რეჟიმში აგებისას"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:142
msgid "Added ability to recognize the decimal separator in other locales"
msgstr "დაემატა სხვა ლოკალებში ათწილადის გამყოფის ამოცნობის შესაძლებლობა"

#~ msgid "KDE Community"
#~ msgstr "KDE-ის საზოგადოება"
