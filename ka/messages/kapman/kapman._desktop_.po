#: src/org.kde.kapman.desktop:4
msgctxt "Name"
msgid "Kapman"
msgstr "Kapman"

#: src/org.kde.kapman.desktop:63
msgctxt "GenericName"
msgid "Pac-Man Clone"
msgstr "Pac-Man -ის კლონი"

#: src/org.kde.kapman.desktop:117
msgctxt "Comment"
msgid "Eat pills escaping ghosts"
msgstr "შეჭამეთ ტაბლეტები, გაექეცით აჩრდილებს"

#: themes/invisible.desktop:2
msgctxt "Name"
msgid "Invisible"
msgstr "უხილავი"

#: themes/invisible.desktop:59
msgctxt "Description"
msgid ""
"Getting bored with Kapman? More than 100,000 points over level 20? Next "
"step: the invisible maze!"
msgstr ""
"მოგბეზრდათ Kapman? უკვე 100, 000 ქულა გაქვთ მეოცე დონეზე? შემდეგი ნაბიჯი: "
"უხილავი ლაბირინთი!"

#: themes/matches.desktop:2
msgctxt "Name"
msgid "Matches"
msgstr "მატჩები"

#: themes/matches.desktop:59
msgctxt "Description"
msgid "A matches drawn maze"
msgstr "მატჩის ფრე"

#: themes/mountain.desktop:2
msgctxt "Name"
msgid "Mountain Adventure"
msgstr "მთის თავგადასავალი"

#: themes/mountain.desktop:55
msgctxt "Description"
msgid "Default"
msgstr "ნაგულისხმევი"

#: themes/mummies_crypt.desktop:2
msgctxt "Name"
msgid "Mummies Crypt"
msgstr "მუმიების საფლავი"

#: themes/mummies_crypt.desktop:54
msgctxt "Description"
msgid "Avoid the mummies at all costs!"
msgstr "თავიდან აიცილეთ მუმიები ნებისმიერ ფასად!"

#: themes/retro.desktop:2
