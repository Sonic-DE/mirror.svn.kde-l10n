#. Tag: para
#: menus.docbook:714
#, fuzzy, no-c-format
#| msgid ""
#| "Apply static word wrapping on all the document. That means that a new "
#| "line of text will automatically start when the current line exceeds the "
#| "length specified by the Wrap words at: option in the Editing tab in "
#| "<menuchoice> <guimenu>Settings</guimenu><guimenuitem>Configure Editor...</"
#| "guimenuitem></menuchoice>"
msgid ""
"Apply static word wrapping on all the document. That means that a new line "
"of text will automatically start when the current line exceeds the length "
"specified by the <guilabel>Wrap words at</guilabel> option in the Editing "
"tab in <menuchoice> <guimenu>Settings</guimenu><guimenuitem>Configure "
"Editor...</guimenuitem></menuchoice> menu."
msgstr ""
"бһўбһ“бһ»бһңбһҸбҹ’бһҸвҖӢбһҖбһ¶бһҡвҖӢбһҡбһ»бҹҶбһ–бһ¶бһҖбҹ’бһҷвҖӢбһӢбһ·бһҸбһ·бһңбһ“бҹ’бһҸвҖӢвҖӢбһ“бҹ…бһӣбһҫвҖӢбһҜбһҖбһҹбһ¶бһҡвҖӢбһ‘бһ¶бҹҶбһ„бһўбһҹбҹӢВ бҹ” бһҳбһ¶бһ“бһ“бҹҗбһҷвҖӢбһҗбһ¶ бһ“бһ№бһ„бһ…бһ¶бһ”бҹӢвҖӢбһ•бҹ’бһҠбһҫбһҳвҖӢбһ”бһ“бҹ’бһ‘бһ¶бһҸбҹӢвҖӢбһҗбҹ’бһҳбһёвҖӢбһ“бҹғвҖӢвҖӢбһўбһҸбҹ’бһҗбһ”бһ‘вҖӢвҖӢбһҠбҹ„бһҷвҖӢбһҹбҹ’бһңбҹҗбһҷвҖӢбһ”бҹ’бһҡбһңбһҸбҹ’бһҸбһ·вҖӢ"
"бһ“бҹ…бһ–бҹҒбһӣвҖӢбһҠбҹӮбһӣвҖӢбһ”бһ“бҹ’бһ‘бһ¶бһҸбҹӢвҖӢбһ”бһ…бҹ’бһ…бһ»бһ”бҹ’бһ”бһ“бҹ’бһ“вҖӢбһӣбһҫбһҹвҖӢбһ”бҹ’бһҡбһңбҹӮбһ„вҖӢбһҠбҹӮбһӣвҖӢбһ”бһ¶бһ“вҖӢбһ”бһүбҹ’бһҮбһ¶бһҖбҹӢвҖӢбһҠбҹ„бһҷвҖӢбһҡбһ»бҹҶвҖӢбһ–бһ¶бһҖбҹ’бһҷвҖӢбһҸбҹ’бһҡбһ„бҹӢВ бҹ– бһҠбҹӮбһӣвҖӢбһҮбһ¶вҖӢбһҮбһҳбҹ’бһҡбһҫбһҹвҖӢбһ“бҹ…вҖӢбһҖбҹ’бһ“бһ»бһ„вҖӢвҖӢбһ•бҹ’бһ‘бһ¶бҹҶбһ„вҖӢбһҖбһ¶бһҡвҖӢ"
"бһҖбҹӮбһҹбһҳбҹ’бһҡбһҪбһӣвҖӢбһ“бҹ…вҖӢбһҖбҹ’бһ“бһ»бһ„ <menuchoice> <guimenu>бһҖбһ¶бһҡвҖӢбһҖбҹҶбһҺбһҸбҹӢ</guimenu><guimenuitem>бһҖбҹҶбһҺбһҸбҹӢвҖӢбһҡбһ…бһ“бһ¶вҖӢбһҹбһҳбҹ’бһ–бҹҗбһ“бҹ’бһ’вҖӢ"
"бһҖбһҳбҹ’бһҳбһңбһ·бһ’бһёвҖӢбһ“бһ·бһ–бһ“бҹ’бһ’...</guimenuitem></menuchoice>"

