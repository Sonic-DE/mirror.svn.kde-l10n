msgstr "fromID"

#. Tag: para
#: index.docbook:4456
#, no-c-format
msgid ""
"The &kmail; identity to use as the sender of the email. If empty, the "
"sender's email address will be that configured in &kalarm;'s <link linkend="
"\"preferences-email\">Email preferences</link>."
msgstr ""
"អត្តសញ្ញាណ​ Kmail ប្រើ​ជា​​អ្នក​ផ្ញើ​អ៊ីមែល ។ បើ​វាទទេ អាសយដ្ឋាន​អ៊ីមែល​របស់អ្នកផ្ញើ​នឹង​ត្រូវ​បាន​"
"កំណត់រចនាសម្ព័ន្ធ​ក្នុង​<link linkend=\"preferences-email\">ចំណូល​ចិត្ត​អ៊ីមែល​</link> ​របស់ "
"Kalarm ។​"

#. Tag: parameter
#: index.docbook:4464
#, no-c-format
msgid "addresses"
msgstr "អាសយដ្ឋាន​ "

#. Tag: para
#: index.docbook:4466
#, no-c-format
msgid "A comma separated list of recipients' email addresses."
msgstr "បញ្ជីសញ្ញាក្បៀស​នៃ​អាសយដ្ឋាន​អ៊ីមែល​របស់អ្នកទទួល ។"

#. Tag: parameter
#: index.docbook:4471
#, no-c-format
msgid "subject"
msgstr "ប្រធាន​បទ"

#. Tag: para
#: index.docbook:4473
#, no-c-format
msgid "Specifies the subject line of the email."
msgstr "បញ្ជាក់​ពី​បន្ទាត់ប្រធាន​បទនៃ​អ៊ីមែល ។"

#. Tag: para
#: index.docbook:4480
#, no-c-format
msgid "Specifies the email message body."
msgstr "បញ្ជាក់​តួ​សារអ៊ីមែល ។"

#. Tag: parameter
#: index.docbook:4485
#, no-c-format
msgid "attachments"
msgstr "ឯកសារ​ភ្ជាប់​​"

#. Tag: para
#: index.docbook:4487
#, no-c-format
msgid ""
"A comma-separated list of paths or &URL;s of files to send as email "
"attachments."
msgstr "បញ្ជី​សញ្ញាក្បៀស​នៃ​ផ្លូវ ឬ​ URL របស់​ឯកសារប្រើសម្រាប់​ផ្ញើឯកសារ​ភ្ជាប់តាមអ៊ីមែល ។​"

#. Tag: para
#: index.docbook:4528
#, no-c-format
msgid ""
"Specifies the logical OR of the desired alarm flags. The flag bits are those "
"defined in class <classname>KAlarmIface</classname> in <filename>kalarmiface."
"h</filename>. Note that not all flag bits are applicable to email alarms."
msgstr ""
"បញ្ជាក់​ចំនួន​តក្ត​​ OR នៃ​ទង់​ជូន​ដំណឹង​ដែល​អ្នកចង់​បាន​​ ។ ប៊ីត​ទង់​បាន​កំណត់​ក្នុង​ថ្នាក់ "
"<classname>KAlarmIface</classname> ក្នុង​ <filename>kalarmiface.h</filename> ។ "
"ចំណាំថា​ប៊ីតទង់ទាំងអស់​មិនអាច​រក​បាន​សម្រាប់អ៊ីមែល​ជូន​ដំណឹង ។"

#. Tag: para
