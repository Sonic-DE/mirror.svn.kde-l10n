#. Tag: title
#: index.docbook:1204
#, fuzzy, no-c-format
#| msgid "Alarm templates"
msgid "Alarm Name"
msgstr "ពុម្ព​សំឡេងរោទិ៍ "

#. Tag: para
#: index.docbook:1206
#, no-c-format
msgid ""
"You can give a name to the alarm in the <guilabel>Alarm name</guilabel> "
"field. This is a convenience to help you identify the alarm more easily. You "
"do not have to enter a name, and it need not be unique."
msgstr ""

#. Tag: para
#: index.docbook:1211
#, fuzzy, no-c-format
#| msgid ""
#| "An alarm's individual enabled/disabled status is indicated by its color "
#| "in the alarm list (the color being configurable in the <link linkend="
#| "\"preferences-fontcolour\">Font &amp; Color</link> tab of the Preferences "
#| "dialog)."
msgid ""
"Note that this field is only displayed if the use of alarm names is enabled "
"in the <link linkend=\"preferences-general\">General</link> tab of the "
"Configuration dialog."
msgstr ""
"ស្ថានភាពបិទ ឬបើក​ឯកជន​របស់​ការជូន​ដំណឹង​ចង្អុរបង្ហាញ​ដោយ​ពណ៌​នៅក្នុង​បញ្ជី​ការជូន​ដំណឹង(ពណ៌​ដែលអាច​ចាប់ផ្តើម​"
"កំណត់រចនាសម្ព័ន្ធក្នុង​ផ្ទាំង<link linkend=\"preferences-fontcolour\">ពុម្ពអក្សរ និង ​ពណ៌</"
"link> នៃ​ប្រអប់​ចំណូលចិត្ត​) ។​"

#. Tag: title
#: index.docbook:1219
#, fuzzy, no-c-format
#| msgid "Alarm action"
msgid "Alarm Action"
msgstr "អំពើ​សំឡេងរោទិ៍"

#. Tag: para
#: index.docbook:1221
#, fuzzy, no-c-format
#| msgid ""
#| "In the <guilabel>Action</guilabel> group box, select the type of alarm:"
msgid ""
"The controls in the <guilabel>Action</guilabel> group box vary depending on "
"the type of alarm being edited."
msgstr "នៅ​ក្នុង​ប្រអប់​ក្រុម​<guilabel>អំពើ</guilabel> ជ្រើស​ប្រភេទ​សំឡេងរោទិ៍ ៖"

#. Tag: title
#: index.docbook:1225
#, fuzzy, no-c-format
#| msgid "Disable Alarms"
msgid "Display Alarms"
msgstr "បិទ​ការជូន​ដំណឹង​"

#. Tag: para
#: index.docbook:1227
#, no-c-format
msgid ""
"Display alarms display a window when the alarm triggers. Select the method "
"used to generate the alarm window contents, using the combo box at the top:"
msgstr ""

#. Tag: para
#: index.docbook:1233
#, fuzzy, no-c-format
#| msgid ""
#| "<guilabel>Text</guilabel> in order to enter an alarm message text (which "
#| "may include newlines) in the edit box. Set the following options:"
msgid ""
"<guilabel>Text message</guilabel> in order to enter an alarm message text "
"(which may include newlines) in the edit box."
msgstr ""
"<guilabel>អត្ថបទ​</guilabel> សម្រាប់បញ្ចូល​អត្ថបទសារ​សំឡេងរោទិ៍ (រួម​ទាំង​បន្ទាត់​ថ្មី) ក្នុង​ប្រអប់​"
"កែសម្រួល​ ។ កំណត់​ជម្រើស​ដូចតទៅ​នេះ ៖"

#. Tag: para
#: index.docbook:1238
#, fuzzy, no-c-format
#| msgid ""
#| "<guilabel>File</guilabel> to enter the path or &URL; of a text or image "
#| "file whose contents are to be displayed in the alarm message. Use the "
#| "button beside the edit box to display a file selection dialog. Set "
#| "options as for text alarms above, but note that the <guilabel>Speak</"
#| "guilabel> option is not available."
msgid ""
"<guilabel>File contents</guilabel> to enter the path or &URL; of a text or "
"image file whose contents are to be displayed in the alarm message. Use the "
"button beside the edit box to display a file selection dialog. The "
"<guilabel>Speak</guilabel> option is not available for this type of alarm."
msgstr ""
"<guilabel>ឯកសារ​</guilabel> បញ្ចូល​ផ្លូវ ឬ​URL នៃ​អត្ថបទ​ ឬ​ឯកសារ​រូបភាព​​មាតិកា​ត្រូវ​បាន​បង្ហាញ​"
"ក្នុង​សារ​សំឡេងរោទិ៍ ។ ប្រើ​ប៊ូតុងក្បែរ​ប្រអប់កែសម្រួល​​សម្រាប់បង្ហាញ​​ប្រអប់​ការជ្រើស​​ឯកសារ​ ។ កំណត់​ជម្រើស​​"
"សម្រាប់​សំឡេងរោទិ៍​អត្ថបទ​ខាងលើ​​ ប៉ុន្តែ​ចំណាំ​ថា​ជម្រើស​ <guilabel>និយាយ</guilabel> មិនអាច​រក​បាន​"
"ទេ ។​"

#. Tag: para
#: index.docbook:1246
#, no-c-format
msgid ""
"<guilabel>Command output</guilabel> to specify that the alarm message text "
"will be generated by a command which is executed when the alarm triggers. "
"See <link linkend=\"command-alarm\">Command Alarms</link> below for details "
"of how to enter the command or command script to execute."
msgstr ""

#. Tag: para
#: index.docbook:1254
#, no-c-format
msgid "The controls available for display alarms are:"
msgstr ""

#. Tag: para
#: index.docbook:1258
#, no-c-format
msgid ""
"The <guilabel>Sound</guilabel> option allows you to select whether an "
"audible alarm should sound when the alarm message is displayed. Choose:"
msgstr ""
"ជ្រើស​<guilabel>សំឡេង</guilabel> អាច​ឲ្យ​អ្នក​ស្តាប់​សំឡេងរោទិ៍ ពេល​សារសំឡេងរោទិ៍​ត្រូវ​បាន​បង្ហាញ ៖ "
"ជ្រើស​"

#. Tag: para
#: index.docbook:1264
#, no-c-format
msgid "<guilabel>None</guilabel> to display the alarm silently."
msgstr "<guilabel>គ្មា​ន​</guilabel> សម្រាប់​បង្ហាញសំឡេងរោទិ៍​ដែល​ស្ថាត់ ។​"

#. Tag: para
#: index.docbook:1268
#, no-c-format
msgid "<guilabel>Beep</guilabel> to sound a beep."
msgstr "<guilabel>ប៊ីប​</guilabel> សំឡេង​ប៊ីប​ ។"

#. Tag: para
#: index.docbook:1272
#, fuzzy, no-c-format
#| msgid ""
#| "<guilabel>Speak</guilabel> to have the alarm message spoken as well as "
#| "being displayed. This option is only available if you have "
#| "<application>KTTSD</application> (from the kdeaccessibility package) "
#| "installed and configured, together with a compatible speech synthesizer, "
#| "&eg; <application>Festival</application>."
msgid ""
"<guilabel>Speak</guilabel> to have the alarm message spoken as well as being "
"displayed. This option is only available if &kalarm; was built with speech "
"enabled and you have the &Qt; Speech module installed and working."
msgstr ""
"<guilabel>និយាយ​</guilabel> សារ​សំឡេងរោទិ៍​ដែល​បានបង្ហាញ​ ។ ជម្រើស​នេះ​បាន​តែ​រក​បាន​បើ​ អ្នក​បាន​"
"ដំឡើង​​ <application>KTTSD</application> (ពី​កញ្ចប់​ kdeaccessibility ) និង​កំណត់​"
"រចនាសម្ព័ន្ធ​​ជាមួយឧបករណ៍​សង្គ្រោះ​ការនិយាយ​​ ឧទាហរណ៍​ដូច​ជា​ <application>Festival</"
"application>​ ។"

#. Tag: para
#: index.docbook:1279
#, no-c-format
msgid ""
"<guilabel>Sound file</guilabel> to play an audio file. Use the button on the "
"right to display the Sound File dialog which lets you select a file to play "
"and set volume and repetition options. If you hover the mouse over the "
"selector, a tooltip will display the audio file currently selected."
msgstr ""
"<guilabel>ឯកសារ​សំឡេង</guilabel> សម្រាប់​ចាក់​ឯកសារ​អូឌីយ៉ូ​​ ។ ប្រើ​ប៊ូតុង​ផ្នែក​ខាងស្តាំ​ដើម្បី​បង្ហាញ​"
"ប្រអប់ឯកសារ​សំឡេង ដែល​អនុញ្ញាត​ឲ្យ​អ្នក​ជ្រើស​ឯកសារ​សម្រាប់​ចាក់​ និង​កំណត់​កម្រិតសំឡេង​​ និង​ជម្រើស​ការ​ធ្វើ​"
"ដដែលៗ ។ បើ​អ្នកសំកាំង​លើ​ប៊ូតុង​ព័ត៌មាន​ជំនួយ​​នឹង​បង្ហាញឯកសារ​អូឌីយ៉ូ​បច្ចុប្បន្ន​​ដែល​បានជ្រើស ។"

#. Tag: para
#: index.docbook:1285
#, no-c-format
msgid "In the Sound File dialog:"
msgstr "នៅ​ក្នុង​ប្រអប់ឯកសារ​សំឡេង "

#. Tag: para
#: index.docbook:1289
#, fuzzy, no-c-format
#| msgid ""
#| "Enter the sound file path, or use the button beside the edit box to "
#| "display a file selection dialog. You can listen to the selected file by "
#| "clicking the play button to the left of the edit field."
msgid ""
"Enter the sound file path, or use the button beside the edit box to display "
"a file selection dialog. You can listen to the selected file by clicking the "
"play button to the left of the edit field. That button then changes function "
"to allow you to stop playing when you have heard enough."
msgstr ""
"បញ្ចូល​ផ្លូវ​ឯកសារ​សំឡេង ឬ​ប្រើ​ប៊ូតុង​បន្ទាប់​ប្រអប់​កែ​សម្រួល​ដើម្បី​បង្ហាញ​ប្រអប់​ការ​ជ្រើស​ឯកសារ ។ អ្នក​អាច​ស្ដាប់​"
"ឯកសារ​ដែល​បាន​ជ្រើស​ដោយ​ចុច​ប៊ូតុង​ចាក់​នៅ​ខាង​ឆ្វេង​នៃ​វាល​កែ​សម្រួល ។"

#. Tag: para
#: index.docbook:1297
#, no-c-format
msgid ""
"Check <guilabel>Repeat</guilabel> to continually repeat the audio file for "
"as long as the alarm is displayed. (The alarm message window contains a "
"button to stop playing the sound should you need silence but still want to "
"display the alarm.)"
msgstr ""
"ធីក <guilabel>ធ្វើ​ម្តង​ទៀត</guilabel> ដើម្បី​បន្តឯកសារ​អូឌីយ៉ូ​ម្តង​ទៀត​​ដ៏រាប​ណា​សំឡេងរោទិ៍​ត្រូវ ​"
"បានបង្ហាញ ។ (បង្អួច​សារ​សំឡេងរោទិ៍មាន​ប៊ូតុង​សម្រាប់​បញ្ឈប់​ការចាក់​សំឡេង​ អ្នក​ចង់​បាន​ស្ងាត់​ ប៉ុន្តែ​អ្នក​នៅ​តែ​"
"ចង់​​បង្ហាញ​សំឡេងរោទិ៍ ។)"

#. Tag: para
#: index.docbook:1304 index.docbook:1585
#, no-c-format
msgid ""
"Check <guilabel>Volume</guilabel> and adjust the slider control if you want "
"to adjust the volume at which the audio file is played."
msgstr ""
"ធីក​ <guilabel>កម្រិត​សំឡេង​</guilabel> ហើយ​ពិនិត្យលៃ​តម្រូវ​​គ្រាប់រំកិល​ បើ​អ្នក​ចង់​លៃតម្រូវ​កម្រិត​សំឡេង​"
"ឯកសារ​អូឌីយ៉ូ​ដែល​បាន​ចាក់ ។"

#. Tag: para
#: index.docbook:1310 index.docbook:1591
#, fuzzy, no-c-format
#| msgid ""
#| "If you wish, you can fade the volume. Fading means to start playing the "
#| "audio file at one volume and gradually change to the final volume, over a "
#| "specified time interval. The final volume is that entered in "
#| "<guilabel>Volume</guilabel> above. To enable fade, check <guilabel>Fade</"
#| "guilabel>, and then enter the fade period in seconds in the "
#| "<guilabel>Fade time</guilabel> field, and adjust the <guilabel>Initial "
#| "volume</guilabel> slider."
msgid ""
"If the audio backend currently in use supports it, you can fade the volume. "
"Fading means to start playing the audio file at one volume and gradually "
"change to the final volume, over a specified time interval. The final volume "
"is that entered in <guilabel>Volume</guilabel> above. To enable fade, check "
"<guilabel>Fade</guilabel>, and then enter the fade period in seconds in the "
"<guilabel>Fade time</guilabel> field, and adjust the <guilabel>Initial "
"volume</guilabel> slider."
msgstr ""
"បើ​អ្នក​ចង់​បាន អ្នក​អាចបន្ថយ​​កម្រិត​សំឡេង​ ។ ការបន្ថយ​​​មាន​ន័យ​ថា​ចាប់ផ្តើម​ចាក់​​ឯកសារ​អូឌីយ៉ូ​​កម្រិត​សំឡេង​មួយ "
"ហើយ​ផ្លាស់ប្តូរ​ជាលំដាប់​រហូត​ដល់​កម្រិតសំឡេង​ចុងក្រោយ​  លើស​ចន្លោះពេល​ដែលបញ្ជាក់​បាន​ ។ កម្រិត​សំឡេង​ចុង​ក្រោយ​​"
"បាន​បញ្ចូល​ក្នុង​ <guilabel>កម្រិត​សំឡេង​</guilabel> ខាងលើ​​ ។ ដើម្បី​បន្ថយ​វា​ ធីក​<guilabel>បន្ថយ​"
"</guilabel> បន្ទាប់​មក​បញ្ចូល​​កំឡុង​ពេល​គិត​ជា​វិនាទី​ក្នុង​វាល​ <guilabel>បន្ថយ​ពេល​វេលា​</guilabel> "
"ហើយ​លៃតម្រូវ​គ្រាប់​រំកិល​ <guilabel>កម្រិត​ចាប់ផ្តើម​</guilabel> ។​"

#. Tag: para
#: index.docbook:1321
#, no-c-format
msgid ""
"You can use the <guibutton>Try</guibutton> button to test out the selected "
"sound levels."
msgstr ""
"អ្នក​អាច​ប្រើ​ប៊ូតុង​​ <guibutton>សាកល្បង</guibutton> ដើម្បី​សាកល្បង​​កម្រិត​សំឡេង​ដែល​បាន​ជ្រើស ។"

#. Tag: para
#: index.docbook:1328
#, fuzzy, no-c-format
#| msgid ""
#| "Use the <guibutton>Font &amp; Color...</guibutton> button to select a "
#| "font, or foreground or background color, for the alarm message. In the "
#| "<guilabel>Choose Alarm Font &amp; Color</guilabel> dialog, check "
#| "<guilabel>Use default font</guilabel> to display the message in whatever "
#| "font is configured as the default at the time the message is displayed. "
#| "(The default font can be set in the <link linkend=\"preferences-fontcolour"
#| "\">Preferences dialog</link>.) To choose a specific font for the message, "
#| "uncheck <guilabel>Use default font</guilabel>."
msgid ""
"Use the <guibutton>Font &amp; Color...</guibutton> button to select a font, "
"and foreground and background colors, for the alarm message. In the "
"<guilabel>Choose Alarm Font &amp; Color</guilabel> dialog, check "
"<guilabel>Use default font</guilabel> to display the message in whatever "
"font is configured as the default at the time the message is displayed. To "
"choose a specific font for the message, uncheck <guilabel>Use default font</"
"guilabel>. (The default font and colors can be set in the <link linkend="
"\"preferences-edit\">Configuration dialog</link>.)"
msgstr ""
"ប្រើ​ប៊ូតុង​ <guibutton>ពុម្ពអក្សរ និង​ពណ៌...</guibutton> ដើម្បី​​ជ្រើស​ពុម្ពអក្សរ​ ឬ​ពណ៌​ផ្ទៃ​ខាង​មុខ ​ឬ​ពណ៌​"
"ផ្ទៃខាងក្រោយ​សម្រាប់​សារ​សំឡេងរោទិ៍ ។ នៅ​ក្នុង​ប្រអប់​ <guilabel>ជ្រើស​​ពុម្ពអក្សរ និង​ពណ៌​សំឡេងរោទិ៍</"
"guilabel> ធីក​ <guilabel>ប្រើ​ពុម្ពអក្សរ​លំនាំដើម​</guilabel> ដើម្បី​បង្ហាញ​សារ​​តាម​ពុម្ពអក្សរ​​ដែល​"
"បាន​កំណត់រចនាសម្ព័ន្ធ​ជា​លំនាំដើម​​នៅ​ពេល​ដែល​សារ​ត្រូវ​បាន​បង្ហាញ ។ (លំនាំដើម​ពុម្ពអក្សរ​អាច​កំណត់​ក្នុង​ "
"<link linkend=\"preferences-fontcolour\">ប្រអប់​ចំណូល​ចិត្ត​</link> ។) ដើម្បី​ជ្រើស​​ពុម្ពអក្សរ​"
"ជាក់លាក់​សម្រាប់​សារ ដោះធីក <guilabel>ប្រើ​ពុម្ពអក្សរ​លំនាំដើម​</guilabel> ។​"

#. Tag: para
#: index.docbook:1338
#, no-c-format
msgid "The selected colors are shown in the alarm message text entry field."
msgstr ""

#. Tag: para
#: index.docbook:1343
#, fuzzy, no-c-format
#| msgid ""
#| "The <guilabel>Sound</guilabel> option allows you to select whether an "
#| "audible alarm should sound when the alarm message is displayed. Choose:"
msgid ""
"The <guilabel>Display method</guilabel> option lets you select how to "
"display the alarm. Choose:"
msgstr ""
"ជ្រើស​<guilabel>សំឡេង</guilabel> អាច​ឲ្យ​អ្នក​ស្តាប់​សំឡេងរោទិ៍ ពេល​សារសំឡេងរោទិ៍​ត្រូវ​បាន​បង្ហាញ ៖ "
"ជ្រើស​"

#. Tag: para
#: index.docbook:1348
#, no-c-format
msgid ""
"<guilabel>Window</guilabel> to display the alarm in a window. This option "
"allows the full range of options to be used when configuring the alarm."
msgstr ""

#. Tag: para
#: index.docbook:1354
#, no-c-format
msgid ""
"<guilabel>Notification</guilabel> to use the standard notification system to "
"display the alarm message. Due to the limitations of the notification "
"system, the following alarm configuration options cannot be used with "
"notifications: setting font and color; setting an audio file to play when "
"the alarm is displayed; confirmation of alarm acknowledgement; automatic "
"closing of the display on expiry of the late-cancellation time."
msgstr ""

#. Tag: para
#: index.docbook:1364
#, fuzzy, no-c-format
#| msgid ""
#| "See <link linkend=\"message-window\">Alarm message window</link> for how "
#| "to acknowledge alarms."
msgid ""
"See the <link linkend=\"message-display\">Alarm Message Display</link> "
"section for further details about how alarm messages are displayed."
msgstr ""
"មើល​ <link linkend=\"message-window\"> បង្អួច​សារ​សំឡេងរោទិ៍ </link> ពី​របៀប​ទទួលស្គាល់​"
"សំឡេងរោទិ៍ ។"

#. Tag: para
#: index.docbook:1370
#, no-c-format
msgid ""
"Use the <guibutton>Special Actions...</guibutton> button to specify shell "
"commands to execute before or after displaying the alarm. In the "
"<guilabel>Special Alarm Actions</guilabel> dialog:"
msgstr ""
"ប្រើ​ប៊ូតុង​ <guibutton>អំពើ​ពិសេស​...</guibutton> ដើម្បី​បញ្ជាក់​ពាក្យ​បញ្ជា​សែល​សម្រាប់​ប្រតិបត្តិ​​មុន ឬ​"
"បន្ទាប់​ពីការបង្ហាញ​សំឡេងរោទិ៍ ។ នៅ​ក្នុង​ប្រអប់​ <guilabel>អំពើសំឡេងរោទិ៍​ពិសេស​</guilabel> ៖"

#. Tag: para
#: index.docbook:1377
#, no-c-format
msgid ""
"In the <guilabel>Pre-alarm action</guilabel> field, enter a shell command to "
"execute before the alarm is displayed. Note that &kalarm; will wait for the "
"command to complete before displaying the alarm."
msgstr ""
"នៅ​ក្នុង​វាល​ <guilabel>អំពើមុន​ពេល​ជូនដំណឹង​</guilabel> សម្រាប់​បញ្ចូល​ពាក្យ​សម្ងាត់​បញ្ជា​សែល​ដើម្បី​"
"ប្រតិបត្តិ​​មុន​សំឡេងរោទិ៍ ត្រូវ​បាន​បង្ហា​ ។ ចំណាំ​ថា​ Kalarm ​​រង់ចាំបញ្ចាប់​ពាក្យ​បញ្ជា​ទាំងស្រុង​មុន​នឹង​បង្ហាញ​"
"សំឡេងរោទិ៍ ។​"

#. Tag: para
#: index.docbook:1382
#, no-c-format
msgid ""
"A pre-alarm action is only executed once when the alarm message is initially "
"displayed, including when a reminder message is replaced by the actual alarm "
"message. It is <emphasis>not</emphasis> executed in any of the following "
"circumstances:"
msgstr ""
"សកម្មភាព​ជូន​ដំណឹង​ត្រូវ​បាន​ប្រតិបត្តិ​ម្ដង​ពេល​សារ​ជូន​ដំណឹង​ត្រូវ​បាន​បង្ហាញ​ជា​ចាប់​ផ្ដើម រួម​បញ្ចូល​ពេល​សារ​រំលឹក​ត្រូវ​"
"បាន​ជំនួស​ដោយ​សារ​ជូន​ដំណឹង​ពិត ។ វា <emphasis>មិន</emphasis> ត្រូវ​បាន​ប្រតិបត្តិ​ក្នុង​កាលៈទេសៈ​ខាង​"
"ក្រោម​ណា​មួយ​ទេ ៖"

#. Tag: para
#: index.docbook:1388
#, no-c-format
msgid "When a reminder message is displayed."
msgstr "ពេល​សារ​រំឮក​ត្រូវ​បាន​បង្ហាញ ។"

#. Tag: para
#: index.docbook:1389
#, fuzzy, no-c-format
#| msgid "When the message is redisplayed after deferring the alarm."
msgid ""
"When the message is redisplayed after deferring the alarm, unless "
"<guilabel>Execute for deferred alarms</guilabel> is checked."
msgstr "ពេល​សារ​ត្រូវ​បាន​បង្ហាញ​ឡើង​វិញ​បន្ទាប់​ពី​ពន្យា​ពេល​ជូន​ដំណឹង ។"

#. Tag: para
#: index.docbook:1392
#, no-c-format
msgid ""
"When the message was displaying at the time you logged off and is then "
"restored when you log back in."
msgstr "ពេល​សារ​កំពុង​បង្ហាញ​នៅ​ពេល​អ្នក​ចេញ និង​បន្ទាប់​ត្រូវ​បាន​ស្ដារ ពេល​អ្នក​ចូល​វិញ ។"

#. Tag: para
#: index.docbook:1394
#, no-c-format
msgid ""
"When a recurring alarm triggers but the alarm message (or a deferred alarm "
"message) from a previous occurrence of the alarm is still visible; in other "
"words, when the previous occurrence of the alarm has not yet been "
"acknowledged."
msgstr ""
"ពេល​ការ​ជូន​ដំណឹង​ដែល​កើត​ឡើង​ផ្ទួនៗ​ចុច ប៉ុន្តែ​សារ​ជូន​ដំណឹង (ឬ​ការ​ជូន​ដំណឹង​ដែល​បាន​ពន្យា) ពី​ការ​កើត​ឡើង​មុន​នៃ​"
"ការ​ជូន​ដំណឹង​នៅ​តែ​មើល​ឃើញ ម្យ៉ាង​វិញ​ទៀត ពេល​ការ​កើត​ឡើង​មុន​នៃ​ការ​ជូន​ដំណឹង​មិន​ត្រូវ​បាន​ទទួល​ស្គាល់​នៅ​ឡើយ ។"

#. Tag: para
#: index.docbook:1400
#, fuzzy, no-c-format
#| msgid "Command alarms: the command line or command script is searched."
msgid ""
"The pre-alarm action can be used to control whether to display the alarm "
"message:"
msgstr "សេចក្តីជូនដំណឹង​​ពាក្យ​បញ្ជា ៖ បន្ទាប់​ពាក្យ​បញ្ជា ឬ​ស្គ្រីប​ពាក្យ​បញ្ជា​ត្រូវ​បាន​ស្វែងរក​ ។​"

#. Tag: para
#: index.docbook:1404
#, no-c-format
msgid ""
"Check <guilabel>Cancel alarm on error</guilabel> to cancel the alarm if the "
"pre-alarm command returns an error status. This will prevent the alarm "
"message from being displayed, and any post-alarm action from being executed."
msgstr ""

#. Tag: para
#: index.docbook:1409
#, no-c-format
msgid ""
"Normally, if the pre-alarm command returns an error, an error message is "
"displayed and an error indication is shown in the alarm list. These error "
"notifications can be prevented by checking <guilabel>Do not notify errors</"
"guilabel>."
msgstr ""

#. Tag: para
#: index.docbook:1417
#, no-c-format
msgid ""
"In the <guilabel>Post-alarm action</guilabel> field, enter a shell command "
"to execute when the alarm is acknowledged (whether by clicking "
"<guibutton>Close</guibutton> or by using the close button in the window's "
"titlebar). It is <emphasis>not</emphasis> executed in any of the following "
"circumstances:"
msgstr ""
"នៅ​ក្នុង​វាល <guilabel>សកម្មភាព​ពន្យា​ចុងក្រោយ</guilabel> បញ្ចូល​ពាក្យ​បញ្ជា​សែល​ដើម្បី​ប្រតិបត្តិ ពេល​"
"ការ​ជូន​ដំណឹង​ត្រូវ​បាន​ទទួល​ស្គាល់ (ថា​តើ​ដោយ​ចុច <guibutton>បិទ</guibutton> ឬ​ដោយ​ប្រើ​ប៊ូតុង​បិទ​ក្នុង​"
"របារ​ចំណង​ជើង​របស់​បង្អួច) ។ វា <emphasis>មិន</emphasis> រួម​បញ្ចូល​ក្នុង​កាលៈទេសៈ​ខាង​ក្រោម​មួយ​ចំនួន​"
"ទេ ៖"

#. Tag: para
#: index.docbook:1424
#, no-c-format
msgid "When a reminder message is closed."
msgstr "ពេល​សារ​ជូន​ដំណឹង​ត្រូវ​បាន​បិទ ។"

#. Tag: para
#: index.docbook:1425
#, no-c-format
msgid ""
"When you defer the alarm, except when the deferred alarm is finally "
"acknowledged."
msgstr "ពេល​អ្នក​ពន្យា​ការ​ជូន​ដំណឹង លើកលែង​ពេល​ការ​ជូន​ដំណឹង​ដែល​ពន្យា​ត្រូវ​បាន​ទទួល​ស្គាល់ ។"

#. Tag: para
#: index.docbook:1427
#, no-c-format
msgid "When the alarm message is closed due to logging out."
msgstr "ពេល​សារ​ជូន​ដំណឹង​ត្រូវ​បាន​បិទ​ដោយ​សារ​ចេញ ។"

#. Tag: para
#: index.docbook:1433
#, fuzzy, no-c-format
#| msgid ""
#| "See the description of Command alarms below for details of how shell "
#| "commands are executed."
msgid ""
"See <link linkend=\"command-alarm\">Command Alarms</link> below for details "
"of how shell commands are executed."
msgstr "មើល​សេចក្តីណែនាំពាក្យ​បញ្ជា​សំឡេងរោទិ៍ព័ត៌មាន​លម្អិតខាងក្រោម​​ នៃ​របៀប​ប្រតិបត្តិ​ពាក្យបញ្ជា​សែល​​ ។​"

#. Tag: title
#: index.docbook:1441
#, fuzzy, no-c-format
#| msgid "For command alarms:"
msgid "Command Alarms"
msgstr "ការជូនដំណឹង​នៃពាក្យបញ្ជា"

#. Tag: para
#: index.docbook:1443
#, fuzzy, no-c-format
#| msgid "Command alarms: the command line or command script is searched."
msgid "Command alarms execute a command without displaying any alarm message."
msgstr "សេចក្តីជូនដំណឹង​​ពាក្យ​បញ្ជា ៖ បន្ទាប់​ពាក្យ​បញ្ជា ឬ​ស្គ្រីប​ពាក្យ​បញ្ជា​ត្រូវ​បាន​ស្វែងរក​ ។​"

#. Tag: para
#: index.docbook:1446
#, fuzzy, no-c-format
#| msgid "This option is not available if &kde; is running in kiosk mode."
msgid "This alarm type is not available if &kde; is running in kiosk mode."
msgstr "ជម្រើស​នេះ​មិនអាច​រក​បាន​ បើ Kde កំពុង​រត់​ជា​របៀប​​ kiosk ។"

#. Tag: para
#: index.docbook:1449
#, no-c-format
msgid ""
"When the command is executed, the environment variable <envar>KALARM_UID</"
"envar> contains the event UID for the alarm. Note that when the command is "
"executed from the Alarm Edit dialog's <guibutton>Try</guibutton> button, "
"<envar>KALARM_UID</envar> will be blank if it is a new alarm, or if the "
"alarm has been modified in the dialog, because the alarm only acquires a UID "
"when it is saved in the alarm calendar."
msgstr ""

#. Tag: para
#: index.docbook:1457
#, no-c-format
msgid "The controls available for command alarms are:"
msgstr ""

#. Tag: para
#: index.docbook:1461
#, fuzzy, no-c-format
#| msgid ""
#| "The <guilabel>Enter a script</guilabel> checkbox lets you choose whether "
#| "to enter a shell command line or a script."
msgid ""
"The <guilabel>Enter a script</guilabel> check box lets you choose whether to "
"enter a shell command line or a script."
msgstr ""
"ប្រអប់ធីក​​ <guilabel>បញ្ចូល​ស្គ្រីប​</guilabel> អនុញ្ញាត​ឲ្យ​អ្នក​​បញ្ជូល​បន្ទាត់​ពាក្យ​បញ្ជា​សែល​ ឬ​ស្គ្រីប ។​"

#. Tag: para
#: index.docbook:1464
#, fuzzy, no-c-format
#| msgid ""
#| "If this option is unchecked, you can enter a shell command line to "
#| "execute. The command is passed straight to the default shell (defined by "
#| "the <envar>SHELL</envar> environment variable), and may include whatever "
#| "options, parameters, piped commands, etc. are permitted by the shell in a "
#| "single line command."
msgid ""
"If this option is unchecked, you can enter a shell command line to execute. "
"The command is passed straight to the default shell (defined by the "
"<envar>SHELL</envar> environment variable), and may include whatever "
"options, parameters, piped commands, &etc; are permitted by the shell in a "
"single line command."
msgstr ""
"បើជម្រើស​នេះ​ពុំ​បានធីក​​ អ្នកអាច​បញ្ចូល​បន្ទាត់​ពាក្យ​បញ្ជាដើម្បី​ឲ្យ​សែល​ប្រតិបត្តិ​ ។ ពាក្យ​បញ្ជាបាន​ឆ្លងកាត់​"
"ភ្លាមៗ​ទៅ​សែល​លំនាំដើម​ (កំណត់ដោយ​អថេរ​បរិស្ថាន​របស់​ <envar>SHELL</envar> ) រួមបញ្ចូល​ទាំង ជម្រើស "
"ប៉ារ៉ាម៉ែត្រ​ បំពុង​ពាក្យ​បញ្ជា​ ។ល។ ត្រូវ​បានអនុញ្ញាតដោយ​សែល​​នៅក្នុង​បន្ទាត់​ពាក្យ​បញ្ជា​តែ​មួយ ។ "

#. Tag: para
#: index.docbook:1470
#, no-c-format
msgid ""
"If this option is checked, you can enter the text of a script to execute. "
"Remember to include a first line such as <literal>#!/bin/bash</literal> to "
"ensure that the correct command interpreter is invoked."
msgstr ""
"បើ​ជម្រើស​នេះ​បានធីក អ្នកអាច​បញ្ចូល​អត្ថបទ​របស់​ស្គ្រីប​ដើម្បី​ប្រតិបត្តិ​ ។ ចងចាំ​ថា​​ដើម្បីរួម​បញ្ចូល​បន្ទាត់​ដំបូង​"
"ដូចជា  <literal>#!/bin/bash</literal> ដើម្បីធានា​ថា​បាន​ហៅកម្មវិធីបក​ប្រែ​​ពាក្យ​បញ្ជា​ដែល​"
"ត្រឹមត្រូវ​ ។ "

#. Tag: para
#: index.docbook:1476
#, no-c-format
msgid ""
"If the command returns an error, an error message is normally displayed, and "
"an error indication is shown in the alarm list. The error notification "
"message can be prevented by checking <guilabel>Do not notify errors</"
"guilabel>."
msgstr ""

#. Tag: para
#: index.docbook:1482
#, no-c-format
msgid ""
"Use the <guilabel>Command Output</guilabel> group box to specify what you "
"want to be done with any terminal output which the command produces when it "
"executes."
msgstr ""
"ប្រើប្រអប់ក្រុម​ <guilabel>លទ្ធផល​ពាក្យ​បញ្ជា​</guilabel> ដើម្បី​បញ្ជាក់​អ្វី​ដែលអ្នកបាន​ធ្វើ​រួច​ជាមួយ​"
"ស្ថានីយ​លទ្ធផល​​ដែល​ប្រតិបត្តិ​ផលិតផល​ពេល​វា​ប្រតិបត្តិ​ ។"

#. Tag: para
#: index.docbook:1488
#, fuzzy, no-c-format
#| msgid ""
#| "Check <guilabel>Execute in terminal window</guilabel> to cause the "
#| "command to be executed in a terminal window. You can choose which type of "
#| "terminal window should be used in the <link linkend=\"preferences-general"
#| "\">Preferences dialog</link>."
msgid ""
"Check <guilabel>Execute in terminal window</guilabel> to cause the command "
"to be executed in a terminal window. You can choose which type of terminal "
"window should be used in the <link linkend=\"preferences-general"
"\">Configuration dialog</link>."
msgstr ""
"ធីក​ <guilabel>ប្រតិបត្តិ​ក្នុង​បង្អួច​ស្ថានីយ</guilabel> ធ្វើ​ឲ្យ​ពាក្យ​បញ្ជា​ប្រតិបត្តិ​ក្នុង​បង្អួច​ស្ថានីយ ។ "
"អ្នក​អាច​ជ្រើស​​ប្រភេទ​បង្អួច​ស្ថានីយ​មួយ​ណា​​ដែល​ត្រូវ​ប្រើ​ក្នុង <link linkend=\"preferences-general"
"\">ប្រអប់​ចំណូល​ចិត្ត</link>​ ។"

#. Tag: para
#: index.docbook:1495
#, no-c-format
msgid ""
"Check <guilabel>Log to file</guilabel> to save the command's output in a "
"file. The output, prefixed by a heading showing the time at which the "
"command was scheduled to run, will be appended to any existing contents of "
"the file. Enter the file name in the edit box, or use the button beside the "
"edit box to display a file selection dialog."
msgstr ""
"ធីក​ <guilabel>ចុះ​កំណត់ហេតុ​ទៅ​ឯកសារ​</guilabel> ដើម្បីរក្សា​លទ្ធផល​របស់​ពាក្យ​ទុក​ក្នុង​ឯកសារ​ ។ "
"ទិន្នផល​ដែ​ល​បានដាក់បុព្វបទ​ដោយ​បង្ហាញ​ក្បាល​ពេលវេលា​ពេលពាក្យ​បញ្ជា​ដែលបាន កំណត់​ពេល​​រត់​ វា​នឹង​បង្ហាញ​"
"មាតិកា​របស់​ឯកសារ​ដែលមាន​រួច​ហើយ​ ។ បញ្ចូល​ឈ្មោះ​ឯកសារ​នៅ​ក្នុង​ប្រអប់​កែសម្រួល​  ឬប្រើ​ប៊ូតុង​​ក្បែរ​"
"ប្រអប់កែសម្រួល​ដើម្បី​បង្ហាញ​ប្រអប់​ជ្រើសឯកសារ ។ "

#. Tag: para
#: index.docbook:1504
#, no-c-format
msgid "Check <guilabel>Discard</guilabel> to throw away the command's output."
