#. Tag: para
#: index.docbook:26
#, fuzzy, no-c-format
#| msgid ""
#| "In this module, you can configure various aspects of &konqueror;'s file "
#| "manager functionality."
msgid ""
"In these modules, you can configure various aspects of &konqueror;’s file "
"manager functionality."
msgstr ""
"ក្នុង​ម៉ូឌុល​នេះ អ្នក​អាច​កំណត់​រចនា​សម្ព័ន្ធ​ទិដ្ឋភាព​ផ្សេងៗ​នៃ​មុខងារជា​កម្មវិធី​គ្រប់គ្រង​ឯកសារ​​របស់ "
"Konqueror ។"

#. Tag: para
#: index.docbook:29
#, fuzzy, no-c-format
#| msgid ""
#| "&konqueror;'s web browser functionality has its <ulink url=\"help:/"
#| "kcontrol/khtml/index.html\">own configuration modules</ulink>."
msgid ""
"&konqueror;’s web browser functionality has its <ulink url=\"help:/kcontrol/"
"khtml-behavior/index.html\">own configuration modules</ulink>."
msgstr ""
"មុខងារ​ជា​កម្មវិធី​រុករក​តំបន់​បណ្ដាញ​របស់ Konqueror មាន<ulink url=\"help:/kcontrol/khtml/"
"index.html\">ម៉ូឌុល​កំណត់​រចនា​សម្ព័ន្ធ​ផ្ទាល់ខ្លួន​របស់​វា</ulink> ។"

