#. Tag: para
#: menus.docbook:824
#, fuzzy, no-c-format
#| msgid ""
#| "Opens up the composer window, inserts the quoted text of the currently "
#| "selected message and presets the <guilabel>To:</guilabel> field with the "
#| "mailing-list address. If you did not specify a mailing-list address for "
#| "the currently selected folder and &kmail; cannot determine the posting "
#| "address from the currently selected message then the <guilabel>To:</"
#| "guilabel> field will be empty. Your identity will automatically be set to "
#| "the one which this message was sent to."
msgid ""
"Opens the composer window, inserts the quoted text of the currently selected "
"message, and sets the <guilabel>To:</guilabel> field to the mailing-list "
"address. If you did not specify a mailing-list address for the currently "
"selected folder and &kmail; cannot determine the posting address from the "
"currently selected message, the <guilabel>To:</guilabel> field will be "
"empty. The sending identity will automatically be set to the identity to "
"which this message was addressed."
msgstr ""
"бһ”бһҫбһҖвҖӢбһ”бһ„бҹ’бһўбһҪбһ…вҖӢбһҖбһҳбҹ’бһҳбһңбһ·бһ’бһёвҖӢбһҸбҹӮбһ„ бһ”бһүбҹ’бһ…бһјбһӣвҖӢбһўбһҸбҹ’бһҗбһ”бһ‘вҖӢбһҠбҹӮбһӣвҖӢбһ”бһ¶бһ“вҖӢбһҹбҹ’бһҡбһ„бҹӢвҖӢбһ“бҹғвҖӢбһҹбһ¶бһҡвҖӢбһҠбҹӮбһӣвҖӢбһ”бһ¶бһ“вҖӢбһҮбҹ’бһҡбһҫбһҹвҖӢбһ”бһ…бҹ’бһ…бһ»бһ”бҹ’бһ”бһ“бҹ’бһ“ бһ“бһ·бһ„вҖӢбһҖбҹҶбһҺбһҸбҹӢвҖӢбһҮбһ¶бһҳбһ»бһ“вҖӢбһңбһ¶бһӣ "
"<guilabel>бһ‘бҹ…В бҹ–</guilabel> бһҮбһ¶бһҳбһҪбһҷвҖӢбһҹбһ¶бһҡвҖӢбһ”бһүбҹ’бһҮбһёвҖӢбһҹбҹҶбһ”бһ»бһҸбҹ’бһҡвҖӢбһҡбһҪбһҳВ бҹ” бһ”бһҫвҖӢбһўбҹ’бһ“бһҖвҖӢбһҳбһ·бһ“вҖӢбһ”бһүбҹ’бһҮбһ¶бһҖбҹӢвҖӢбһўбһ¶бһҹбһҷбһҠбҹ’бһӢбһ¶бһ“вҖӢбһ”бһүбҹ’бһҮбһёвҖӢбһҹбҹҶбһ”бһ»бһҸбҹ’бһҡвҖӢбһҡбһҪбһҳвҖӢ"
"бһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢвҖӢбһҗбһҸвҖӢбһҠбҹӮбһӣвҖӢбһ”бһ¶бһ“вҖӢбһҮбҹ’бһҡбһҫбһҹвҖӢбһ”бһ…бҹ’бһ…бһ»бһ”бҹ’бһ”бһ“бҹ’бһ“ бһ бһҫбһҷ Kmail бһҳбһ·бһ“вҖӢбһўбһ¶бһ…вҖӢбһҖбҹҶбһҺбһҸбҹӢвҖӢбһўбһ¶бһҹбһҷбһҠбҹ’бһӢбһ¶бһ“вҖӢбһ”бҹ’бһҡбһҖбһ¶бһҹвҖӢбһ–бһёвҖӢбһҹбһ¶бһҡвҖӢбһҠбҹӮбһӣвҖӢбһ”бһ¶бһ“вҖӢбһҮбҹ’бһҡбһҫбһҹвҖӢ"
"бһ”бһ…бҹ’бһ…бһ»бһ”бҹ’бһ”бһ“бҹ’бһ“ бһҠбһјбһ…бҹ’бһ“бҹҒбҹҮвҖӢбһңбһ¶бһӣ <guilabel>бһ‘бҹ…В бҹ–</guilabel> бһ“бһ№бһ„вҖӢбһҸбҹ’бһҡбһјбһңвҖӢбһ”бһ¶бһ“вҖӢбһ’бҹ’бһңбһҫвҖӢбһІбҹ’бһҷвҖӢбһ‘бһ‘бҹҒВ бҹ” бһўбһҸбҹ’бһҸвҖӢбһҹбһүбҹ’бһүбһ¶бһҺвҖӢбһҡбһ”бһҹбҹӢвҖӢбһўбҹ’бһ“бһҖвҖӢ"
"бһ“бһ№бһ„вҖӢбһҸбҹ’бһҡбһјбһңвҖӢбһ”бһ¶бһ“вҖӢбһҖбҹҶбһҺбһҸбҹӢвҖӢбһҷбҹүбһ¶бһ„вҖӢбһҹбҹ’бһңбҹҗбһҷвҖӢбһ”бҹ’бһҡбһңбһҸбҹ’бһҸбһ·вҖӢбһ‘бҹ…вҖӢбһҳбһҪбһҷвҖӢбһҠбҹӮбһӣвҖӢбһҹбһ¶бһҡвҖӢбһ“бҹҒбҹҮвҖӢбһҸбҹ’бһҡбһјбһңвҖӢбһ”бһ¶бһ“вҖӢбһ•бҹ’бһүбһҫвҖӢбһ‘бҹ…В бҹ”"

