#, no-c-format
msgid "<para>The Options Menu</para>"
msgstr ""

#. Tag: para
#: menus.docbook:1715
#, fuzzy, no-c-format
#| msgid "Attaches one or more files to the current message."
msgid ""
"This menu lets you toggle various options for the current message. Selected "
"items will be marked (check box colored in) in the menu."
msgstr "бһ—бҹ’бһҮбһ¶бһ”бҹӢбһҮбһ¶бһҳбһҪбһҷвҖӢбһҜбһҖбһҹбһ¶бһҡвҖӢбһҳбһҪбһҷ бһ¬вҖӢбһ…бҹ’бһҡбһҫбһ“вҖӢбһ‘бҹ…бһҹбһ¶бһҡвҖӢбһ”бһ…бҹ’бһ…бһ»бһ”бҹ’бһ”бһ“бҹ’бһ“ бҹ”вҖӢ"

#. Tag: menuchoice
#: menus.docbook:1721
#, fuzzy, no-c-format
#| msgid "<guimenu>Options</guimenu> <guimenuitem>Urgent</guimenuitem>"
msgid "<guimenu>Options</guimenu><guimenuitem>Urgent</guimenuitem>"
msgstr "<guimenu>бһҮбҹ’бһҡбһҫбһҹвҖӢ</guimenu> <guimenuitem>бһ”бҹ’бһҡбһүбһ¶бһ”бҹӢвҖӢ</guimenuitem>"

#. Tag: para
#: menus.docbook:1722
#, fuzzy, no-c-format
#| msgid ""
#| "Sets the priority of the message to Urgent. The receiver's email client "
#| "has to support this or it will have no effect. &kmail; itself does not "
#| "support priorities for incoming messages."
msgid ""
"Sets the priority of the message to Urgent by inserting two header lines: "
"\"X-PRIORITY: 2 (High)\" and \"Priority: urgent\". The receiver's email "
"client must provide support for these headers; otherwise they will have no "
"effect. &kmail; itself does not support priorities for incoming messages "
"(although you can <link linkend=\"reader-mark-messages\">mark messages</"
"link> as Important)."
msgstr ""
"бһҖбҹҶбһҺбһҸбҹӢвҖӢбһўбһ¶бһ‘бһ·бһ—бһ¶бһ–вҖӢбһ“бҹғвҖӢбһҹбһ¶бһҡвҖӢбһ‘бҹ…вҖӢбһҮбһ¶вҖӢбһ”бһ“бҹ’бһ‘бһ¶бһ“бҹӢВ бҹ” бһҳбҹүбһ¶бһҹбҹҠбһёбһ“вҖӢбһ—бҹ’бһүбҹҖбһңвҖӢбһўбҹҠбһёбһҳбҹӮбһӣвҖӢбһҡбһ”бһҹбҹӢвҖӢбһўбҹ’бһ“бһҖвҖӢбһ‘бһ‘бһҪбһӣвҖӢбһҸбҹ’бһҡбһјбһңвҖӢбһҸбҹӮвҖӢбһӮбһ¶бҹҶбһ‘бҹ’бһҡвҖӢбһ“бҹҒбҹҮ бһ¬вҖӢбһңбһ¶вҖӢбһ“бһ№бһ„вҖӢбһӮбҹ’бһҳбһ¶бһ“вҖӢ"
"бһ”бҹ’бһҡбһҹбһ·бһ‘бҹ’бһ’бһ·бһ—бһ¶бһ–В бҹ” Kmail бһҒбҹ’бһӣбһҪбһ“вҖӢбһңбһ¶вҖӢбһҳбһ·бһ“вҖӢбһӮбһ¶бҹҶбһ‘бҹ’бһҡвҖӢбһӣбһҖбҹ’бһҒбһҺбҹҲвҖӢбһҹбһҳбҹ’бһ”бһҸбҹ’бһҸбһ·вҖӢбһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢвҖӢбһҹбһ¶бһҡвҖӢбһ…бһјбһӣвҖӢбһ‘бҹҒВ бҹ”"

#. Tag: menuchoice
#: menus.docbook:1730
#, fuzzy, no-c-format
#| msgid ""
#| "<guimenu>Options</guimenu> <guimenuitem>Request Disposition Notification</"
#| "guimenuitem>"
msgid ""
"<guimenu>Options</guimenu><guimenuitem>Request Disposition Notification</"
"guimenuitem>"
msgstr "<guimenu>бһҮбҹ’бһҡбһҫбһҹвҖӢ</guimenu> <guimenuitem>бһҹбҹ’бһ“бһҫбһҖбһ¶бһҡбһҡбҹҖбһ”бһ…бҹҶвҖӢбһҖбһ¶бһҡбһҮбһјбһ“вҖӢбһҠбҹҶбһҺбһ№бһ„вҖӢ </guimenuitem>"

#. Tag: para
#: menus.docbook:1732
#, fuzzy, no-c-format
#| msgid ""
#| "If you choose this option, you request a confirmation email once your "
#| "message is downloaded and read by its recipient. This has to be supported "
#| "and enabled by the receiver's email client in order to work."
msgid ""
"If you choose this option, &kmail; will insert a Disposition-Notification-"
"To: header line in the message, which is a request to receive an email "
"notification once your message has been downloaded and read by the "
"recipient. This function must be supported, and enabled by the receiver's "
"email client; otherwise, it will not work."
msgstr ""
"бһ”бһҫвҖӢбһўбҹ’бһ“бһҖвҖӢбһҮбҹ’бһҡбһҫбһҹвҖӢбһҮбһҳбҹ’бһҡбһҫбһҹвҖӢбһ“бҹҒбҹҮ бһўбҹ’бһ“бһҖвҖӢбһҹбҹ’бһ“бһҫвҖӢбһўбҹҠбһёбһҳбҹӮбһӣвҖӢбһўбҹҮбһўбһ¶бһ„ бһ–бҹҒбһӣвҖӢбһҹбһ¶бһҡвҖӢбһҡбһ”бһҹбҹӢвҖӢбһўбҹ’бһ“бһҖвҖӢбһҸбҹ’бһҡбһјбһңвҖӢбһ”бһ¶бһ“вҖӢбһ‘бһ¶бһүбһҷбһҖ бһ“бһ·бһ„вҖӢбһҸбҹ’бһҡбһјбһңвҖӢбһ”бһ¶бһ“вҖӢбһўбһ¶бһ“вҖӢбһҠбҹ„бһҷвҖӢбһўбҹ’бһ“бһҖвҖӢ"
"бһ‘бһ‘бһҪбһӣвҖӢбһҡбһ”бһҹбҹӢвҖӢбһңбһ¶В бҹ” бһ“бҹҒбҹҮвҖӢбһҸбҹ’бһҡбһјбһңвҖӢбһҸбҹӮвҖӢбһ”бһ¶бһ“вҖӢбһӮбһ¶бҹҶбһ‘бҹ’бһҡ бһ“бһ·бһ„вҖӢбһўбһ“бһ»бһүбҹ’бһүбһ¶бһҸвҖӢбһҠбҹ„бһҷвҖӢбһҳбҹүбһ¶бһҹбҹҠбһёбһ“вҖӢбһ—бҹ’бһүбҹҖбһңвҖӢбһўбҹҠбһёбһҳбҹӮбһӣвҖӢбһҡбһ”бһҹбҹӢвҖӢбһўбҹ’бһ“бһҖвҖӢбһ‘бһ‘бһҪбһӣвҖӢбһҠбһҫбһҳбҹ’бһ”бһёвҖӢбһ’бҹ’бһңбһҫбһҖбһ¶бһҡВ бҹ”"

#. Tag: para
#: menus.docbook:1738
#, fuzzy, no-c-format
#| msgid ""
#| "See <xref linkend=\"configure-security-reading-mdns\"/> for background "
#| "information and ways to customize the read receipts that &kmail; itself "
#| "sends."
msgid ""
"See <xref linkend=\"configure-security-reading-mdns\"/> for background "
"information and several ways to customize the read receipts that &kmail; "
"itself sends in response to a received Disposition-Notification-To: header "
"line."
msgstr ""
"бһҹбһјбһҳвҖӢбһҳбһҫбһӣ <xref linkend=\"configure-security-reading-mdns\"/> бһҹбһҳбҹ’бһҡбһ¶бһ”бҹӢвҖӢбһ–бҹҗбһҸбҹҢбһҳбһ¶бһ“вҖӢбһ•бҹ’бһ‘бҹғвҖӢ"
"бһҒбһ¶бһ„бһҖбҹ’бһҡбҹ„бһҷ бһ“бһ·бһ„вҖӢбһңбһ·бһ’бһёвҖӢбһҠбһҫбһҳбҹ’бһ”бһёвҖӢбһ”бҹ’бһҠбһјбһҡвҖӢбһҸбһ¶бһҳвҖӢбһ”бҹҶбһҺбһ„вҖӢбһҖбһ¶бһҡвҖӢбһ‘бһ‘бһҪбһӣвҖӢбһҖбһ¶бһҡвҖӢбһўбһ¶бһ“вҖӢбһҠбҹӮбһӣ Kmail бһҒбҹ’бһӣбһҪбһ“вҖӢбһңбһ¶вҖӢбһ•бҹ’бһүбһҫВ бҹ”"

#. Tag: menuchoice
#: menus.docbook:1745
#, fuzzy, no-c-format
#| msgid ""
#| "<guimenu>Options</guimenu> <guimenuitem>Request Disposition Notification</"
#| "guimenuitem>"
msgid ""
"<guimenu>Options</guimenu><guimenuitem>Request Delivery Confirmation</"
"guimenuitem>"
msgstr "<guimenu>бһҮбҹ’бһҡбһҫбһҹвҖӢ</guimenu> <guimenuitem>бһҹбҹ’бһ“бһҫбһҖбһ¶бһҡбһҡбҹҖбһ”бһ…бҹҶвҖӢбһҖбһ¶бһҡбһҮбһјбһ“вҖӢбһҠбҹҶбһҺбһ№бһ„вҖӢ </guimenuitem>"

#. Tag: para
#: menus.docbook:1747
#, no-c-format
msgid ""
"If you choose this option, &kmail; will insert a Return-Receipt-To: header "
"line in the message, which is a request to receive an email notification "
"once your message has been uploaded by your email server and delivered to "
"the recipient. This function must be supported by your outgoing email "
"server; otherwise, it will not work."
msgstr ""

#. Tag: menuchoice
#: menus.docbook:1756
#, fuzzy, no-c-format
#| msgid "<guimenu>Options</guimenu> <guisubmenu>Sign Message</guisubmenu>"
msgid "<guimenu>Options</guimenu><guisubmenu>Sign Message</guisubmenu>"
msgstr "<guimenu>бһҮбһҳбҹ’бһҡбһҫбһҹвҖӢ</guimenu> <guisubmenu>бһҹбһ¶бһҡвҖӢбһ…бһ»бҹҮбһ бһҸбҹ’бһҗбһӣбҹҒбһҒбһ¶</guisubmenu>"

#. Tag: para
#: menus.docbook:1757
#, fuzzy, no-c-format
#| msgid ""
#| "Digitally sign the message using <application>OpenPGP</application>. You "
#| "can learn more about this in the <link linkend=\"pgp\">chapter on "
#| "OpenPGP</link>."
msgid ""
"Digitally signs the message using <application>OpenPGP</application> or an "
"X.509 certificate. You can learn more about this option in the <link linkend="
"\"pgp\">chapter on OpenPGP</link>."
msgstr ""
"бһҸбһҪбһӣбҹҒбһҒвҖӢбһҹбһ¶бһҡвҖӢбһ…бһ»бҹҮбһ бһҸбҹ’бһҗбһӣбҹҒбһҒбһ¶вҖӢбһ”бҹ’бһҡбһҫвҖӢ <application>OpenPGP</application>бҹ” бһўбҹ’бһ“бһҖбһўбһ¶бһ…вҖӢбһҹбһ·бһҖбҹ’бһҹбһ¶вҖӢбһ”бһ“бҹ’бһҗбҹӮбһҳвҖӢбһ–бһёвҖӢ"
"бһ“бҹҒбҹҮбһ“бҹ…бһҖбҹ’бһ“бһ»бһ„вҖӢбһҮбҹҶбһ–бһјбһҖвҖӢбһҳбҹҒбһҡбҹҖбһ“вҖӢ <link linkend=\"pgp\">OpenPGP</link> бҹ”"

#. Tag: menuchoice
#: menus.docbook:1762
#, fuzzy, no-c-format
#| msgid "<guimenu>Options</guimenu> <guisubmenu>Encrypt Message</guisubmenu>"
msgid "<guimenu>Options</guimenu><guisubmenu>Encrypt Message</guisubmenu>"
msgstr "<guimenu>бһҮбһҳбҹ’бһҡбһҫбһҹвҖӢ</guimenu> <guisubmenu>бһўбҹҠбһ·бһ“бһӮбҹ’бһҡбһёбһ”бһҹбһ¶бһҡвҖӢ</guisubmenu>"

#. Tag: para
#: menus.docbook:1763
#, fuzzy, no-c-format
#| msgid ""
#| "Encrypt the message using <application>OpenPGP</application>. You can "
#| "learn more about this in the <link linkend=\"pgp\">chapter on OpenPGP</"
#| "link>."
msgid ""
"Encrypts the message using <application>OpenPGP</application> or an X.509 "
"certificate. You can learn more about encryption in the <link linkend=\"pgp"
"\">chapter on OpenPGP</link>."
msgstr ""
"бһўбҹҠбһ·бһ“бһӮбҹ’бһҡбһёбһ”бһҹбһ¶бһҡвҖӢбһҠбҹ„бһҷвҖӢбһ”бҹ’бһҡбһҫвҖӢ  <application>OpenPGP</application>бҹ” бһўбҹ’бһ“бһҖбһўбһ¶бһ…вҖӢбһҹбһ·бһҖбҹ’бһҹбһ¶бһ”бһ“бҹ’бһҗбҹӮбһҳвҖӢбһўбҹҶбһ–бһёвҖӢбһңбһ¶вҖӢ"
"бһ“бҹ…бһҖбҹ’бһ“бһ»бһ„бһҮбҹҶбһ–бһҪбһҖ <link linkend=\"pgp\">OpenPGP</link> бҹ”"

#. Tag: menuchoice
#: menus.docbook:1768
#, fuzzy, no-c-format
#| msgid ""
#| "<guimenu>Options</guimenu> <guisubmenu>Select Cryptographic Message "
#| "Format</guisubmenu>"
msgid ""
"<guimenu>Options</guimenu><guisubmenu>Cryptographic Message Format &gt;</"
"guisubmenu>"
msgstr ""
"<guimenu>бһҮбһҳбҹ’бһҡбһҫбһҹвҖӢ</guimenu> <guisubmenu>бһҮбҹ’бһҡбһҫбһҹвҖӢбһ‘бҹ’бһҡбһ„бҹӢбһ‘бҹ’бһҡбһ¶бһҷвҖӢбһҹбһ¶бһҡвҖӢбһҖбһјбһҠбһҹбһ¶бһҹбҹ’бһҸбҹ’бһҡвҖӢ</guisubmenu>"

#. Tag: para
#: menus.docbook:1769
#, fuzzy, no-c-format
#| msgid ""
#| "Choose the cryptographic message format to use to digitally sign and/or "
#| "encrypt the message in. See <link linkend=\"cryptographic-message-formats"
