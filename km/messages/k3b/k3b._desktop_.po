msgid "Busy"
msgstr "រវល់"

#: src/k3b.notifyrc:521
msgctxt "Comment"
msgid "K3b is currently busy and cannot start any other operations"
msgstr "បច្ចុប្បន្ន​ K3b ​កំពុង​ជាប់រវល់​មិន​អាច​ចាប់ផ្ដើម​​ប្រតិបត្តិ​ការណ៍​ផ្សេង​ៗ​ទៀត​បាន​ទេ​"

#: src/k3b.notifyrc:577
msgctxt "Name"
msgid "No problems found"
msgstr "រក​មិន​ឃើញ​បញ្ហា​ឡើយ"

#: src/k3b.notifyrc:630
msgctxt "Comment"
msgid "No problems found in system configuration"
msgstr "រក​មិន​ឃើញ​បញ្ហា​នៅ​ក្នុង​ការ​កំណត់​រចនាសម្ព័ន្ធ​ប្រព័ន្ធ​ឡើយ​ ។"

#: src/k3b.notifyrc:686
msgctxt "Name"
msgid "Mount/unmount failed"
msgstr "បាន​បរាជ័យ​ ម៉ោន​/អាន់ម៉ោន​​"

#: src/k3b.notifyrc:739
msgctxt "Comment"
msgid "Medium cannot be mount or unmounted"
msgstr "មិន​អាច​ម៉ោន ឬ​អាន់ម៉ោន​ឧបករណ៍​ផ្ទុក​បាន​ឡើយ​"

#: src/k3b.notifyrc:795
msgctxt "Name"
msgid "Track data not found"
msgstr "រក​មិន​ឃើញ​ទិន្នន័យ​បទ​ឡើយ​"

#: src/k3b.notifyrc:848
msgctxt "Comment"
msgid "Track information has not been found in the online database"
msgstr "ព័ត៌មាន​អំពី​បទ​មិន​ត្រូវ​បាន​រក​ឃើញ​នៅ​ក្នុង​មូលដ្ឋាន​ទិន្នន័យ​លើ​បណ្ដាញ​ឡើយ​"

