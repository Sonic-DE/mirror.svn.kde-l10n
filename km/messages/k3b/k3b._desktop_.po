#: kioworkers/videodvd/videodvd.desktop:5
msgctxt "Name"
msgid "Video DVD Browser"
msgstr "កម្មវិធី​រុករក​ឌីវីឌី​វីដេអូ"

#: src/helper/k3b.actions:2
msgctxt "Name"
msgid "Update device and programs permissions"
msgstr "ធ្វើ​បច្ចុប្បន្នភាព​​សិទ្ធិ​ឧបករណ៍ និង​​កម្មវិធី"

#: src/helper/k3b.actions:58
msgctxt "Description"
msgid ""
"Authentication is required to update permissions of devices and programs"
msgstr "តម្រូវ​ឲ្យ​​ធ្វើការ​ផ្ទៀងផ្ទាត់​ភាព​ត្រឹមត្រូវ ដើម្បី​ធ្វើ​បច្ចុប្បន្នភាព​​សិទ្ធិ​​ឧបករណ៍ និង​កម្មវិធី​"

#: src/helper/k3b.actions:116
msgctxt "Name"
msgid "Adds current user to a specified group"
msgstr "បន្ថែម​អ្នកប្រើ​បច្ចុប្បន្ន​ទៅ​ក្រុម​ដែល​បានបញ្ជាក់"

#: src/helper/k3b.actions:168
msgctxt "Description"
msgid "Authentication is required to add current user to a group"
msgstr "តម្រូវ​ឲ្យ​​ធ្វើការ​ផ្ទៀងផ្ទាត់​ ដើម្បី​ធ្វើ​បច្ចុប្បន្នភាព​​សិទ្ធិ​​ឧបករណ៍ និង​កម្មវិធី​"

