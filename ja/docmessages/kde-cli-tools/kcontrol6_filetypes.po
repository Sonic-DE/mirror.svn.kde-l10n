#. Tag: para
#: index.docbook:79
#, no-c-format
msgid "Application"
msgstr "Applications(アプリケーション)"

#. Tag: para
#: index.docbook:80
#, no-c-format
msgid "Audio"
msgstr "Audio(オーディオ)"

#. Tag: para
#: index.docbook:81
#, no-c-format
msgid "Image"
msgstr "Image(イメージ)"

#. Tag: para
#: index.docbook:82
#, no-c-format
msgid "Inode"
msgstr "Inode(i-nodeオブジェクト)"

#. Tag: para
#: index.docbook:83
#, no-c-format
msgid "Message"
msgstr "Messages(メッセージ)"

#. Tag: para
#: index.docbook:84
#, no-c-format
msgid "Multipart"
msgstr "Multipart(マルチパート)"

#. Tag: para
#: index.docbook:85
#, no-c-format
msgid "Text"
