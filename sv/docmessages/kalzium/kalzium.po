msgstr "<phrase>Gradient för kovalent radie</phrase>"

#. Tag: para
#: index.docbook:446
#, no-c-format
msgid ""
"Implemented are the following gradients (some listed items are clickable):"
msgstr ""
"Följande gradienter har implementerats (några objekt i listan går att klicka "
"på):"

#. Tag: para
#: index.docbook:448
#, no-c-format
msgid "<guimenuitem>None</guimenuitem>: do not use gradients."
msgstr "<guimenuitem>Ingen</guimenuitem>: Använd inte gradienter."

