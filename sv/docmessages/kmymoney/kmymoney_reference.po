"<guimenu>Visa</guimenu> <guimenuitem>Dölj avstämda transaktioner</"
"guimenuitem>"

#. Tag: para
#: reference.docbook:276
#, no-c-format
msgid "Hides reconciled transactions in the ledger."
msgstr "Döljer avstämda transaktioner i huvudboken."

#. Tag: menuchoice
#: reference.docbook:281
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>U</keycap></keycombo> </shortcut> "
"<guimenu>View</guimenu> <guimenuitem>Hide unused categories</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>U</keycap></keycombo> </shortcut> "
"<guimenu>Visa</guimenu> <guimenuitem>Dölj oanvända kategorier</guimenuitem>"

#. Tag: para
#: reference.docbook:289
#, no-c-format
msgid "Hides unused categories in the views."
msgstr "Döljer oanvända kategorier i vyerna."

#. Tag: menuchoice
#: reference.docbook:294
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;&Shift;<keycap>A</keycap></keycombo> </shortcut> "
"<guimenu>View</guimenu><guimenuitem>Show all accounts</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;&Shift;<keycap>A</keycap></keycombo> </shortcut> "
"<guimenu>Visa</guimenu> <guimenuitem>Visa alla konton</guimenuitem>"

#. Tag: para
#: reference.docbook:301
#, no-c-format
msgid ""
"Shows all accounts in the views, including closed accounts and accounts with "
"zero balance."
msgstr ""
"Visar alla konton i vyerna, inklusive stängda konton och konton med ingen "
"behållning."

