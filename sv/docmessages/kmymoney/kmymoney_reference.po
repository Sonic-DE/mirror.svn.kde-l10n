#. Tag: menuchoice
#: reference.docbook:152
#, no-c-format
msgid "<guimenu>File</guimenu><guimenuitem>Personal Data...</guimenuitem>"
msgstr ""
"<guimenu>Arkiv</guimenu> <guimenuitem>Personlig information...</guimenuitem>"

#. Tag: para
#: reference.docbook:156
#, no-c-format
msgid "Allows to edit personal data."
msgstr "Gör det möjligt att redigera personlig information."

#. Tag: menuchoice
#: reference.docbook:161
#, no-c-format
