#. Tag: para
#: index.docbook:34
#, no-c-format
msgid ""
"&ktimer; is an application that lets you start an application after a "
"certain amount of time has passed."
msgstr ""
"&ktimer; är ett program som låter dig starta ett program efter en viss "
"tidsrymd har passerat."

#. Tag: keyword
#: index.docbook:41
#, no-c-format
msgid "<keyword>KDE</keyword>"
msgstr "<keyword>KDE</keyword>"

#. Tag: keyword
#: index.docbook:42
#, no-c-format
