#: index.docbook:4464
#, no-c-format
msgid "addresses"
msgstr "adresser"

#. Tag: para
#: index.docbook:4466
#, no-c-format
msgid "A comma separated list of recipients' email addresses."
msgstr "En lista av mottagarnas e-postadresser åtskilda med kommatecken."

#. Tag: parameter
#: index.docbook:4471
#, no-c-format
msgid "subject"
msgstr "rubrik"

#. Tag: para
#: index.docbook:4473
#, no-c-format
msgid "Specifies the subject line of the email."
msgstr "Anger e-postens rubrikrad."

#. Tag: para
