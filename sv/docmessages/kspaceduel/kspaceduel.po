#. Tag: guiicon
#: index.docbook:162
#, no-c-format
msgid "Bullet"
msgstr "Kulor"

#. Tag: para
#: index.docbook:163
#, no-c-format
msgid "The maximum number of bullets is increased."
msgstr "Det maximala antalet kulor ökas."

#. Tag: term
#: index.docbook:166
#, no-c-format
msgid "<guiicon>Energy</guiicon> (yellow or green sphere)"
msgstr "<guiicon>Energi</guiicon> (gult eller grönt klot)"

#. Tag: para
#: index.docbook:167
#, no-c-format
msgid "Player's energy increases."
msgstr "Spelarens energi ökas."

#. Tag: term
#: index.docbook:170
#, no-c-format
msgid "<guiicon>Shield</guiicon> (red or blue sphere)"
msgstr "<guiicon>Sköld</guiicon> (rött eller blått klot)"

#. Tag: para
#: index.docbook:171
#, no-c-format
msgid "Player's hit points increase."
msgstr "Spelarens träffpoäng ökas."

