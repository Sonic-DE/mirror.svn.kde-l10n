#, no-c-format
msgid "List all agents"
msgstr "Lista alla agenter"

#. Tag: option
#: man-akonadiclient.1.docbook:449
#, no-c-format
msgid "-s, --setstate <replaceable>state</replaceable>"
msgstr "-s, --setstate <replaceable>tillstånd</replaceable>"

#. Tag: para
#: man-akonadiclient.1.docbook:450
#, no-c-format
msgid ""
"Set the state for specified agents. Valid states are 'offline' and 'online'."
msgstr ""
"Ställ in tillstånd för angivna agenter. Giltiga tillstånd är 'offline' och "
"'online'."

#. Tag: option
#: man-akonadiclient.1.docbook:454
#, no-c-format
msgid "-g, --getstate"
msgstr "-g, --getstate"

#. Tag: para
#: man-akonadiclient.1.docbook:455
#, no-c-format
msgid "Get the state for specified agents"
msgstr "Hämta tillstånd för angivna agenter"

#. Tag: option
#: man-akonadiclient.1.docbook:459
#, no-c-format
msgid "-i, --info"
msgstr "-i, --info"

#. Tag: para
#: man-akonadiclient.1.docbook:460
#, no-c-format
msgid "Show information about the specified agents"
msgstr "Visa information om de angivna agenterna"

#. Tag: option
#: man-akonadiclient.1.docbook:464
#, no-c-format
msgid "-r, --restart"
msgstr "-r, --restart"

#. Tag: para
#: man-akonadiclient.1.docbook:465
#, no-c-format
msgid "Restarts the specified agents"
msgstr "Startar om de angivna agenterna"

#. Tag: option
#: man-akonadiclient.1.docbook:478
#, no-c-format
msgid "help"
msgstr "help"

#. Tag: para
#: man-akonadiclient.1.docbook:480
#, no-c-format
msgid "akonadiclient help [COMMAND]"
msgstr "akonadiclient help [KOMMANDO]"

#. Tag: para
#: man-akonadiclient.1.docbook:481
#, no-c-format
msgid ""
"Displays help for COMMAND. If COMMAND is not specified then it lists all the "
"available commands"
msgstr ""
"Visar hjälp om KOMMANDO. Om KOMMANDO inte anges listas alla tillgängliga "
"kommandon."

#. Tag: option
#: man-akonadiclient.1.docbook:486
#, no-c-format
msgid "shell"
msgstr "shell"

#. Tag: para
#: man-akonadiclient.1.docbook:488
#, no-c-format
msgid "akonadiclient shell"
msgstr "akonadiclient shell"

#. Tag: para
#: man-akonadiclient.1.docbook:489
#, no-c-format
msgid "Enter commands in an interactive shell"
msgstr "Mata in kommandon i ett interaktivt skal"

#. Tag: title
#: man-akonadiclient.1.docbook:497
#, no-c-format
msgid "Examples"
msgstr "Exempel"

#. Tag: para
#: man-akonadiclient.1.docbook:498
#, no-c-format
msgid ""
"<emphasis role=\"bold\">akonadiclient list /</emphasis> - Lists all the "
"collections under the root collection"
msgstr ""
"<emphasis role=\"bold\">akonadiclient list /</emphasis> - Listar alla "
"samlingar under rotsamlingen"

#. Tag: para
#: man-akonadiclient.1.docbook:499
#, no-c-format
msgid ""
"<emphasis role=\"bold\">akonadiclient export /Notes notes.xml</emphasis> - "
"Exports all the items and sub-collections of the /Notes collection to the "
"file 'notes.xml'"
msgstr ""
"<emphasis role=\"bold\">akonadiclient export /Notes anteckningar.xml</"
"emphasis> - Exporterar alla objekt och delsamlingar i samlingen /Notes till "
"filen 'anteckningar.xml'"

#. Tag: para
#: man-akonadiclient.1.docbook:500
#, no-c-format
msgid ""
"<emphasis role=\"bold\">akonadiclient agents -l</emphasis> - Lists all agents"
msgstr ""
"<emphasis role=\"bold\">akonadiclient agents -l</emphasis> - Listar alla "
"agenter"

#. Tag: para
#: man-akonadiclient.1.docbook:501
#, no-c-format
msgid ""
"<emphasis role=\"bold\">akonadiclient add /Notes note.txt</emphasis> - Adds "
"the contents of the file note.txt as an item in the collection /Notes"
msgstr ""
"<emphasis role=\"bold\">akonadiclient add /Notes anteckning.txt</emphasis> - "
"Lägger till innehållet i filen anteckning.txt som ett objekt i samlingen /"
"Notes"

#. Tag: para
#: man-akonadiclient.1.docbook:502
#, no-c-format
msgid ""
"<emphasis role=\"bold\">akonadiclient add -m application/x-vnd.akonadi."
"calendar.todo /Todos todo.ics</emphasis> - Adds the contents of the file "
"todo.ics as a TODO calendar entry in the collection /Todos"
msgstr ""
"<emphasis role=\"bold\">akonadiclient add -m application/x-vnd.akonadi."
"calendar.todo /Todos uppgift.ics</emphasis> - Lägger till innehållet i filen "
"uppgift.ics som en TODO kalenderpost i samlingen /Todos"
