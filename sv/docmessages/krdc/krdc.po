msgstr ""
"Inställning av Fjärranslutning till skrivbord - Fliken <guilabel>VNC-"
"standard</guilabel>profiler"

#. Tag: screeninfo
#: index.docbook:484
#, no-c-format
msgid "&krdc; preferences - <guilabel>RDP Defaults</guilabel> tab"
msgstr ""
"Inställning av Fjärranslutning till skrivbord - Fliken <guilabel>RDP-"
"standard</guilabel>"

#. Tag: phrase
#: index.docbook:490
#, no-c-format
msgid "&krdc; preferences - <guilabel>RDP Defaults</guilabel> profiles tab"
msgstr ""
"Inställning av Fjärranslutning till skrivbord - Fliken <guilabel>RDP-"
"standard</guilabel>profiler"

#. Tag: title
#: index.docbook:503
#, no-c-format
msgid "Questions and Answers"
msgstr "Vanliga frågor"

#. Tag: para
#: index.docbook:518
#, no-c-format
msgid "Why does <acronym>RDP</acronym> support not work?"
msgstr "Varför fungerar inte stöd för <acronym>RDP</acronym>?"

#. Tag: para
#: index.docbook:521
#, no-c-format
msgid ""
"<acronym>RDP</acronym> support in &krdc; depends on xfreerdp (FreeRDP). Make "
"sure that you have installed this runtime dependency."
msgstr ""
"Stöd för <acronym>RDP</acronym> i Fjärranslutning till skrivbord beror på "
"xfreerdp (FreeRDP). Försäkra dig om att du har installerat det, som är ett "
"beroende när du kör programmet."

