#. Tag: para
#: index.docbook:21
#, no-c-format
msgid ""
"This is the documentation for the &systemsettings; module that configures "
"mice and other pointing devices."
msgstr ""
"Det här är dokumentationen för systeminställningarnas modul som anpassar "
"musen och andra pekdon."

#. Tag: keyword
#: index.docbook:26
#, no-c-format
msgid "<keyword>KDE</keyword>"
msgstr "<keyword>KDE</keyword>"

#. Tag: keyword
#: index.docbook:27
#, no-c-format
msgid "Systemsettings"
msgstr "Systeminställningar"

#. Tag: keyword
#: index.docbook:28
#, no-c-format
msgid "mouse"
msgstr "mus"

#. Tag: para
#: index.docbook:32
#, no-c-format
msgid ""
"This module allows you to configure your pointing device. Your pointing "
"device may be a mouse, a trackball, a touchpad, or another piece of hardware "
"that performs a similar function."
msgstr ""
"Den här modulen låter dig anpassa ditt pekdon. Ditt pekdon kan vara en mus, "
"en snurrboll, en tryckplatta, eller någon annan sorts hårdvara som utför en "
"liknade funktion."

#. Tag: guilabel
#: index.docbook:38
#, no-c-format
msgid "General"
msgstr "Allmänt"

#. Tag: guilabel
#: index.docbook:42
#, no-c-format
msgid "Left handed mouse"
msgstr "Vänsterhänt läge"

#. Tag: para
#: index.docbook:43
#, no-c-format
msgid ""
"If you are left-handed, you may prefer to swap the functions of the "
"<mousebutton>left</mousebutton> and <mousebutton>right</mousebutton> buttons "
"on your pointing device by checking this option. If your pointing device has "
"more than two buttons, only those that function as the <mousebutton>left</"
"mousebutton> and <mousebutton>right</mousebutton> buttons are affected. For "
"example, if you have a three-button mouse, the <mousebutton>middle</"
"mousebutton> button is unaffected."
msgstr ""
"Om du är vänsterhänt kan du föredra att byta funktionerna på "
"<mousebutton>vänster</mousebutton> och <mousebutton>höger</mousebutton> "
"musknapp på ditt pekdon genom att markera alternativet. Om ditt pekdon har "
"mer än två knappar, är det bara de som fungerar som <mousebutton>vänster</"
"mousebutton> och <mousebutton>höger</mousebutton> musknapp som påverkas. Om "
"du till exempel har en mus med tre knappar, är <mousebutton>mitten</"
"mousebutton>knappen opåverkad."

#. Tag: guilabel
#: index.docbook:54
#, no-c-format
msgid "Press left and right buttons for middle-click"
msgstr "Tryck på vänster- och högerknapp för mittenklick"

#. Tag: para
#: index.docbook:55
#, no-c-format
msgid ""
"Check this item if you don't have a &MMB;. You can press the left and right "
"mouse buttons at the same time to emulate middle-click."
msgstr ""
"Markera alternativet om du inte har en mittenknapp. Du kan trycka på vänster "
"och höger musknappar samtidigt för att emulera ett mittenklick."

#. Tag: guilabel
#: index.docbook:66
#, no-c-format
msgid "Pointer speed"
msgstr "Pekarhastighet"

#. Tag: para
#: index.docbook:67
#, no-c-format
msgid ""
"This option allows you to change the relationship between the distance that "
"the mouse pointer moves on the screen and the relative movement of the "
"physical device itself (which may be a mouse, trackball, or some other "
"pointing device.)"
msgstr ""
"Det här alternativet låter dig ändra förhållandet mellan avståndet som "
"muspekaren flyttas på skärmen och den relativa förflyttningen av den fysiska "
"enheten själv (som kan vara en mus, snurrboll, eller något annat pekdon.)"

#. Tag: guilabel
#: index.docbook:77
#, no-c-format
msgid "Pointer acceleration"
msgstr "Acceleration för pekare"

#. Tag: para
#: index.docbook:78
#, no-c-format
msgid ""
"The <guilabel>Standard</guilabel> mode adjusts the amount of pointer "
"acceleration according to how fast you move the mouse. If you set it to "
"<guilabel>None</guilabel>, the acceleration remains constant regardless of "
"speed."
msgstr ""
"Läget <guilabel >Standard</guilabel > justerar pekaraccelerations storlek "
"efter hur snabbt du rör musen. Om du ställer in den på <guilabel >Ingen</"
"guilabel > förblir accelerationen konstant oavsett hastighet."

#. Tag: guilabel
#: index.docbook:85
#, no-c-format
msgid "Scrolling: Invert scroll direction"
msgstr "Rullning: Omvänd rullningsriktning"

#. Tag: para
#: index.docbook:86
#, no-c-format
msgid ""
"With this check box selected, the scroll wheel (if any) will work in the "
"opposite direction (so that if rolling the top of the scroll wheel towards "
"you previously causes a scroll down, then it will now cause a scroll up)."
msgstr ""
"När den här kryssrutan är markerad, fungerar rullhjulet (om det finns) i "
"omvänd riktning (så om rulla mushjulet mot dig tidigare orsakade rullning "
"neråt, orsakar det nu rullning uppåt)."

#. Tag: para
#: index.docbook:93
#, no-c-format
msgid ""
"In &plasma; 5.13 you find the setting to use single or double mouse clicks "
"to open files and folders in the module <ulink url=\"help:/kcontrol/"
"workspaceoptions/index.html\">Workspace</ulink>."
msgstr ""
"I &plasma; 5.13 hittar du inställningen att använda enkla eller dubbla "
"musklick för att öppna filer och kataloger i modulen <ulink url=\"help:/"
"kcontrol/workspaceoptions/index.html\">Arbetsyta</ulink>."

#~ msgid "Acceleration profile"
#~ msgstr "Accelerationsprofil"

#~ msgid ""
#~ "The <guilabel>Adaptive</guilabel> profile is the default profile for all "
#~ "devices and takes the current speed of the device into account when "
#~ "deciding on acceleration. The <guilabel>Flat</guilabel> profile is simply "
#~ "a constant factor applied to all device deltas, regardless of the speed "
#~ "of motion."
#~ msgstr ""
#~ "Profilen <guilabel>Adaptiv</guilabel> är standardprofilen för alla "
#~ "enheter och tar hänsyn till enhetens nuvarande hastighet när "
#~ "accelerationen bestäms. Profilen <guilabel>Enkel</guilabel> är helt "
#~ "enkelt en konstant faktor applicerad på alla delta från enheten, "
#~ "oberoende av rörelsens hastighet."

#~ msgid "2020-10-01"
#~ msgstr "2020-10-01"

#~ msgid ""
#~ "This module is divided into two tabs: <link linkend=\"mouse-general"
#~ "\">General</link> and <link linkend=\"mouse-advanced\">Advanced</link>."
#~ msgstr ""
#~ "Den här modulen är uppdelad i två flikar:  <link linkend=\"mouse-general"
#~ "\">Allmänt</link> and <link linkend=\"mouse-advanced\">Avancerat</link>."

#~ msgid "Button Order"
#~ msgstr "Knappordning"

#~ msgid "Advanced"
#~ msgstr "Avancerat"

#~ msgid ""
#~ "A high value for the acceleration multiplier will lead to large movements "
#~ "of the mouse pointer on the screen, even when you only make a small "
#~ "movement with the physical device."
#~ msgstr ""
#~ "Ett högt värde på accelerationsfaktorn gör att muspekaren flyttar sig "
#~ "långt på skärmen, även om du bara gör en liten rörelse med den fysiska "
#~ "enheten."

#~ msgid ""
#~ "A multiplier between <guilabel>1x</guilabel> and <guilabel>3x</guilabel> "
#~ "will works well for many systems. With a multiplier over <guilabel>3x</"
#~ "guilabel> the mouse pointer may become difficult to control."
#~ msgstr ""
#~ "En multiplikationsfaktor mellan <guilabel>1x</guilabel> och <guilabel>3x</"
#~ "guilabel> fungerar bra för många system. Med en multiplikationsfaktor "
#~ "över <guilabel>3x</guilabel> kan muspekaren bli svår att kontrollera."

#~ msgid ""
#~ "The threshold is the smallest distance that the mouse pointer must move "
#~ "on the screen before acceleration has any effect. If the movement is "
#~ "within the threshold, the mouse pointer moves as if the acceleration were "
#~ "set to <guilabel>1x</guilabel>."
#~ msgstr ""
#~ "Tröskeln är det minsta avstånd som muspekaren måste flyttas på skärmen "
#~ "innan accelerationen har någon effekt. Om förflyttningen är inom "
#~ "tröskeln, flyttas muspekaren som om accelerationen var satt till "
#~ "<guilabel>1x</guilabel>."

#~ msgid ""
#~ "Thus, when you make small movements with the physical device (&eg; "
#~ "mouse), you still have fine control of the mouse pointer on the screen, "
#~ "whereas larger movements of the physical device will move the mouse "
#~ "pointer rapidly to different areas on the screen."
#~ msgstr ""
#~ "På så sätt, om du gör små förflyttningar med den fysiska enheten (t.ex. "
#~ "musen), har du fortfarande finkontroll över muspekaren på skärmen, medan "
#~ "större förflyttningar av den fysiska enheten snabbt flyttar muspekaren "
#~ "till en annan del av skärmen."

#~ msgid ""
#~ "You can set the threshold by entering a value into the edit box or by "
#~ "clicking the up/down arrows to the right of the box."
#~ msgstr ""
#~ "Du kan ställa in tröskelvärdet genom att skriva in ett värde i "
#~ "redigeringsrutan eller genom att klicka på upp/ner-pilarna på knappen "
#~ "till höger om rutan."

#~ msgid ""
#~ "In general, the higher you set the <guilabel>Pointer acceleration</"
#~ "guilabel> value, the higher you will want to set the <guilabel>Pointer "
#~ "threshold</guilabel> value. For example, a <guilabel>Pointer threshold</"
#~ "guilabel> of 4 pixels may be appropriate for a <guilabel>Pointer "
#~ "Acceleration</guilabel> of 2x, but 10 pixels might be better for 3x."
#~ msgstr ""
#~ "I allmänhet, ju högre du sätter <guilabel>Acceleration för pekare</"
#~ "guilabel>, ju högre vill du sätta <guilabel>Tröskelvärde för pekare</"
#~ "guilabel>. Ett <guilabel>Tröskelvärde för pekare</guilabel> som är till "
#~ "exempel 4 bildpunkter kan vara lämpligt för en <guilabel>Acceleration för "
#~ "pekare</guilabel> som är 2x, men 10 bildpunkter kan vara bättre för 3x."

#~ msgid "Double click interval"
#~ msgstr "Intervall för dubbelklick"

#~ msgid ""
#~ "This is the maximum amount of time between clicks to register a double "
#~ "click. If you click twice, and the time between those two clicks is less "
#~ "than this number, that is recognized as a double click. If the time "
#~ "between these two clicks is greater than this number, it is recognized as "
#~ "two <emphasis>separate</emphasis> single clicks."
#~ msgstr ""
#~ "Det här är den maximala tiden mellan klick för att registrera det som ett "
#~ "dubbelklick. Om du klickar två gånger, och tiden mellan de här två "
#~ "klicken är mindre än det här värdet, känns det igen det som ett "
#~ "dubbelklick. Om tiden mellan de två klicken är större än värdet, känns "
#~ "det igen dem som två <emphasis>separata</emphasis> enkelklick."

#~ msgid ""
#~ "<guilabel>Drag start time</guilabel> and <guilabel>Drag start distance</"
#~ "guilabel>"
#~ msgstr ""
#~ "<guilabel>Tid för start av drag och släpp</guilabel> och "
#~ "<guilabel>Avstånd för start av drag och släpp</guilabel>"

#~ msgid ""
#~ "If you <itemizedlist> <listitem><para>click with the mouse</para></"
#~ "listitem> <listitem><para>drag within the time specified in "
#~ "<guilabel>Drag start time</guilabel>, and </para></listitem> "
#~ "<listitem><para>move a distance equal to or greater than the number (of "
#~ "pixels) specified in <guilabel>Drag start distance</guilabel></para> </"
#~ "listitem> </itemizedlist> the selected item will be dragged."
#~ msgstr ""
#~ "Om du <itemizedlist> <listitem><para>Klickar med musen </para></listitem> "
#~ "<listitem><para>drar inom tiden som specificeras i <guilabel>Tid för "
#~ "start av drag och släpp</guilabel>, och </para></listitem> "
#~ "<listitem><para>flyttar ett avstånd som är större en det antal (pixlar) "
#~ "som anges av <guilabel>Avstånd för start av drag och släpp</guilabel></"
#~ "para> </listitem> </itemizedlist> så dras det valda objektet."

#~ msgid "Mouse wheel scrolls by"
#~ msgstr "Mushjulet rullar"

#~ msgid ""
#~ "If you have a wheel mouse, use the spin box to determine how many lines "
#~ "of text one <quote>step</quote> of the mouse wheel will scroll."
#~ msgstr ""
#~ "Om du har en hjulmus, använd nummerrutan för att avgöra hur många rader "
#~ "text ett <quote>steg</quote> med mushjulet rullar."

#~ msgid "2018-05-18"
#~ msgstr "2018-05-18"

#~ msgid "Keyboard Navigation"
#~ msgstr "Tangentbordsnavigering"

#~ msgid ""
#~ "This tab allows you to configure the keyboard number pad keys as a mouse-"
#~ "type device. This may be useful when you are working on a device without "
#~ "another pointing device, or where you have no other use for the number "
#~ "pad."
#~ msgstr ""
#~ "Den här fliken låter dig ställa in det numeriska tangentbordet som en "
#~ "sorts musenhet. Det kan vara användbart om du arbetar med en dator utan "
#~ "något annat pekdon, eller där du inte har någon annan användning för det "
#~ "numeriska tangentbordet."

#~ msgid "Move pointer with keyboard (using the num pad)"
#~ msgstr "Flytta musen med tangentbordet (använd numeriska tangentbordet)"

#~ msgid ""
#~ "To enable keyboard mouse mode, you need to select the check box labeled "
#~ "<guilabel>Move pointer with keyboard (using the num pad)</guilabel>. When "
#~ "you do this, the other settings will become enabled, and you can "
#~ "customize the keyboard pointer behavior further, if required."
#~ msgstr ""
#~ "För att aktivera tangentbordets musläge, måste du markera kryssrutan som "
#~ "heter <guilabel>Flytta musen med tangentbordet (använd numeriska "
#~ "tangentbordet)</guilabel>. När du gör det aktiveras övriga inställningar, "
#~ "och du kan anpassa beteendet hos tangentbordspekaren ytterligare, om det "
#~ "behövs."

#~ msgid ""
#~ "The various keys on the number pad move in the direction you would "
#~ "expect. Note that you can move diagonally as well as up, down, left and "
#~ "right. The <keycap>5</keycap> key emulates a click to a pointer button, "
#~ "typically &LMB;. You change which button is emulated by using the "
#~ "<keycap>/</keycap> key (which makes it &LMB;), <keycap>*</keycap> key "
#~ "(which makes it &MMB;) and <keycap>-</keycap> (which makes it &RMB;). "
#~ "Using the <keycap>+</keycap> emulates a double click to the selected "
#~ "pointer button. You can use the <keycap>0</keycap> key to emulate holding "
#~ "down the selected pointer button (for easy dragging), and then use the "
#~ "<keycap>.</keycap> to emulate releasing the selected pointer button."
#~ msgstr ""
#~ "De olika tangenterna på det numeriska tangentbordet flyttar i "
#~ "riktningarna du kan förvänta dig. Observera att du kan flytta diagonalt "
#~ "förutom uppåt, neråt, åt vänster och åt höger. Tangenten <keycap>5</"
#~ "keycap> motsvarar ett klick på en musknapp, typiskt vänsterknappen. Du "
#~ "kan ändra vilken knapp som den motsvarar genom att använda tangenten "
#~ "<keycap>/</keycap> (som gör den till vänsterknapp), <keycap>*</keycap> "
#~ "(som gör den till mittenknapp) och <keycap>-</keycap> (som gör den till "
#~ "högerknapp). Att trycka på <keycap>+</keycap> motsvarar ett dubbelklick "
#~ "med den valda musknappen. Du kan använda tangenten <keycap>0</keycap> för "
#~ "att hålla nere den valda musknappen (för att lätt kunna dra), och "
#~ "därefter använda <keycap>.</keycap> för att släppa den valda musknappen."

#~ msgid "Acceleration delay"
#~ msgstr "Accelerationsfördröjning"

#~ msgid ""
#~ "This is the time (in milliseconds) between the initial key press and the "
#~ "first repeated motion event for mouse key acceleration."
#~ msgstr ""
#~ "Det här är tiden (i millisekunder) mellan ursprunglig tangentnertryckning "
#~ "och första upprepade rörelsehändelsen för acceleration av mustangenten."

#~ msgid "Repeat interval"
#~ msgstr "Upprepningsintervall"

#~ msgid ""
#~ "This is the time in milliseconds between repeated motion events for mouse "
#~ "key acceleration."
#~ msgstr ""
#~ "Det här är tiden i millisekunder mellan upprepade rörelsehändelsen för "
#~ "acceleration av mustangenten."

#~ msgid "Acceleration time"
#~ msgstr "Accelerationstid"

#~ msgid ""
#~ "This is the time in milliseconds before the pointer reaches a maximum "
#~ "speed for mouse key acceleration."
#~ msgstr ""
#~ "Det här är tiden i millisekunder innan pekaren når en maximal hastighet "
#~ "för acceleration av mustangenten."

#~ msgid "Maximum speed"
#~ msgstr "Maximal hastighet"

#~ msgid ""
#~ "This is the maximum speed in pixels per second the pointer can reach for "
#~ "mouse key acceleration."
#~ msgstr ""
#~ "Det här är maximal hastighet i bildpunkter per sekund som pekaren kan nå "
#~ "för acceleration av mustangenten."

#~ msgid ""
#~ "This is the slope of the acceleration curve for mouse key acceleration."
#~ msgstr ""
#~ "Det här är lutningen på accelerationskurvan för acceleration av "
#~ "mustangenten."

#~ msgid "Double-click to open files and folders (select icons on first click)"
#~ msgstr ""
#~ "Dubbelklicka för att öppna filer och kataloger (välj ikonen vid första "
#~ "klicket)"

#~ msgid ""
#~ "If this option is not checked, icons/files will be opened with a single "
#~ "click of the <mousebutton>left</mousebutton> mouse-button. This default "
#~ "behavior is consistent with what you would expect when you click links in "
#~ "most web browsers. If checked however, icons/files will be opened with a "
#~ "double click, while a single click will only select the icon or file. "
#~ "This is the behavior you may know from other desktops or operating "
#~ "systems."
#~ msgstr ""
#~ "Om det här alternativet inte är markerat, öppnas ikoner/filer med ett "
#~ "enkelt klick av <mousebutton>vänster</mousebutton> musknapp. Det här "
#~ "förvalda beteendet är det samma som du skulle förvänta dig när du klickar "
#~ "på länkar i de flesta webbläsare. Om det är markerat så öppnas ikoner/"
#~ "filer med ett dubbelklick, medan ett enkelklick bara väljer ikonen eller "
#~ "filen. Det här är ett beteende som du kan känna igen från andra skrivbord "
#~ "eller operativsystem."

#~ msgid "Single-click to open files and folders"
#~ msgstr "Enkelklicka för att öppna filer och kataloger"

#~ msgid ""
#~ "This is the default setting. Clicking once on an icon will open it. To "
#~ "select you can drag around the icon(s) or <keycombo action=\"simul"
#~ "\">&Ctrl;<mousebutton>Right</mousebutton></keycombo> click, or simply "
#~ "click and hold to drag it."
#~ msgstr ""
#~ "Det här är förvald inställning. Att klicka en gång på en ikon öppnar den. "
#~ "För att välja kan du dra runt en eller flera ikoner, <keycombo action="
#~ "\"simul\">&Ctrl;<mousebutton>högerklicka</mousebutton></keycombo>, eller "
#~ "helt enkelt klicka och hålla nere för att dra."

#~ msgid "2016-06-01"
#~ msgstr "2016-06-01"

#~ msgid ""
#~ "This option can be changed in the configuration dialogs of &dolphin; and "
#~ "&konqueror; on the <guilabel>Navigation</guilabel> tab as well."
#~ msgstr ""
#~ "Alternativet kan ändras med inställningsdialogrutorna i &dolphin; och "
#~ "&konqueror; och dessutom under fliken <guilabel>Navigering</guilabel>."

#~ msgid "Change pointer shape over icons"
#~ msgstr "Ändra pekarens form över ikoner"

#~ msgid ""
#~ "When this option is checked, the shape of the mouse pointer changes "
#~ "whenever it is over an icon."
#~ msgstr ""
#~ "När det här alternativet är markerat, så ändras muspekarens form när den "
#~ "befinner sig över en ikon."

#~ msgid ""
#~ "This option should be checked in most situations. It gives more visual "
#~ "feedback and says, in essence, if you click here, something will happen."
#~ msgstr ""
#~ "Det här alternativet ska vara markerat i de flesta fall. Det ger mer "
#~ "synligt gensvar och betyder, i allt väsentligt, om du klickar här så "
#~ "kommer något att hända."

#~ msgid "Automatically select icons"
#~ msgstr "Markera ikoner automatiskt"

#~ msgid ""
#~ "As noted above, if you have <guilabel>Single-click to open files and "
#~ "folders</guilabel> selected, you can select icons by dragging around "
#~ "them, or by using <keycombo action=\"simul\">&Ctrl;<mousebutton>Right</"
#~ "mousebutton></keycombo> click. If you routinely need to select icons, you "
#~ "may want to enable this check box, which will allow icons to be selected "
#~ "automatically by pausing over the icon. The <guilabel>Delay:</guilabel> "
#~ "slider determines how long is required before the automatic selection "
#~ "takes effect."
#~ msgstr ""
#~ "Som beskrivs ovan, om du har markerat <guilabel>Enkelklicka för att öppna "
#~ "filer och kataloger</guilabel> kan du markera ikoner genom att dra "
#~ "omkring dem eller genom att använda <keycombo action=\"simul\">&Ctrl;"
#~ "<mousebutton>höger</mousebutton></keycombo>klick. Om du rutinmässigt "
#~ "behöver markera ikoner, kan du markera kryssrutan, vilket gör det möjligt "
#~ "att markera ikoner automatiskt genom att stanna över ikonen. "
#~ "Skjutreglaget <guilabel>Fördröjning:</guilabel> anger hur lång tid det "
#~ "tar innan den automatiska markeringen utförs."

#~ msgid "Logitech Support"
#~ msgstr "Logitech-stöd"

#~ msgid ""
#~ "Some Logitech USB mice support special features, such as switching to a "
#~ "higher resolution, or providing cordless status. If &kde; was built with "
#~ "libusb support, then you will get an additional tab for each supported "
#~ "mouse that is plugged in."
#~ msgstr ""
#~ "Vissa versioner av Logitech USB-mus stöder speciella funktioner, som att "
#~ "byta till en högre upplösning, eller tillhandahålla status för en "
#~ "sladdlös mus. Om &kde; byggdes med stöd för libusb, får du ytterligare en "
#~ "flik för varje ansluten mus som stöds."

#~ msgid "The supported devices are:"
#~ msgstr "Enheterna som stöds är:"

#~ msgid "Wheel Mouse Optical"
#~ msgstr "Optisk hjulmus"

#~ msgid "MouseMan Traveler"
#~ msgstr "MouseMan resemus"

#~ msgid "MouseMan Dual Optical"
#~ msgstr "MouseMan dubbel optisk mus"

#~ msgid "MX310 Optical Mouse"
#~ msgstr "MX310 optisk mus"

#~ msgid "MX510 Optical Mouse"
#~ msgstr "MX510 optisk mus"

#~ msgid "MX300 Optical Mouse"
#~ msgstr "MX300 optisk mus"

#~ msgid "MX500 Optical Mouse"
#~ msgstr "MX500 optisk mus"

#~ msgid "iFeel Mouse"
#~ msgstr "iFeel-mus"

#~ msgid "Mouse Receiver"
#~ msgstr "Musmottagare"

#~ msgid "Dual Receiver"
#~ msgstr "Dubbel mottagare"

#~ msgid "Cordless Freedom Optical"
#~ msgstr "Freedom sladdlös optisk mus"

#~ msgid "Cordless Elite Duo"
#~ msgstr "Sladdlös Elite Duo"

#~ msgid "MX700 Optical Mouse"
#~ msgstr "MX700 optisk mus"

#~ msgid "Cordless Optical Trackman"
#~ msgstr "Trackman sladdlös optisk mus"

#~ msgid "Cordless MX Duo Receiver"
#~ msgstr "MX Duo sladdlös mus för mottagare"

#~ msgid "MX100 Laser Mouse"
#~ msgstr "MX100 lasermus"

#~ msgid "Receiver for Cordless Presenter"
#~ msgstr "Presenter sladdlös mus för mottagare"

#~ msgid ""
#~ "Not all devices support all capabilities (typically cordless devices do "
#~ "not provide resolution switching, and of course only cordless devices "
#~ "support cordless status reporting), so some parts of the tab will not be "
#~ "enabled for some mouse types."
#~ msgstr ""
#~ "Alla enheter stöder inte alla funktioner (oftast tillhandahåller inte "
#~ "sladdlösa enheter byte av upplösning, och naturligtvis stöder bara "
#~ "sladdlösa enheter sladdlös statusrapportering), så vissa delar av fliken "
#~ "är inte aktiverad för vissa mustyper."

#~ msgid ""
#~ "If the mouse supports resolution switching, the <guilabel>Sensor "
#~ "Resolution</guilabel> radio button group will be enabled, and you can "
#~ "switch from <guilabel>400 counts per inch</guilabel> to <guilabel>800 "
#~ "counts per inch</guilabel> and back. If you use <guilabel>800 counts per "
#~ "inch</guilabel>, the same physical movement of the mouse will cause a "
#~ "greater (roughly double) amount of motion of the cursor. This tends to be "
#~ "popular amongst gamers."
#~ msgstr ""
#~ "Om musen stöder byte av upplösning, är gruppen med alternativknappar "
#~ "<guilabel>Sensorupplösning</guilabel> aktiverad, och du kan byta mellan "
#~ "<guilabel>400 värden per tum</guilabel> och <guilabel>800 värden per tum</"
#~ "guilabel>. Om du använder <guilabel>800 värden per tum</guilabel>, "
#~ "orsakar samma fysiska rörelse av musen en större (ungefär dubbel) rörelse "
#~ "hos pekaren. Det brukar vara populärt bland de som spelar datorspel."

#~ msgid ""
#~ "If the mouse supports cordless reporting, the <guilabel>Battery Level</"
#~ "guilabel> and <guilabel>RF Channel</guilabel> widgets will be enabled. "
#~ "You can only change the <guilabel>RF Channel</guilabel> if your mouse has "
#~ "two channel support."
#~ msgstr ""
#~ "Om musen stöder sladdlös statusrapportering, är de grafiska komponenterna "
#~ "<guilabel>Batterinivå</guilabel> och <guilabel>RF-kanal</guilabel> "
#~ "aktiverade. Du kan bara byta <guilabel>RF-kanal</guilabel> om musen har "
#~ "stöd för två kanaler."

#~ msgid "2013-12-05"
#~ msgstr "2013-12-05"

#~ msgid "&kde; 4.12"
#~ msgstr "&kde; 4.12"

#~ msgid "Fixing permission problems on Logitech mice"
#~ msgstr "Att korrigera problem med rättigheter för en Logitech-mus"

#~ msgid ""
#~ "Because of the way USB devices work, the code that accesses the current "
#~ "status on Logitech mice needs to be able to write to the mouse. This "
#~ "should be handled by your distribution, but if not, you may need to do "
#~ "some configuration yourself."
#~ msgstr ""
#~ "På grund av sättet som USB-enheter fungerar, måste koden som ska komma åt "
#~ "aktuell status på en Logitech-mus kunna skriva till musen. Det bör "
#~ "hanteras av din distribution, men om det inte gör det, kan du behöva göra "
#~ "vissa inställningar själv."

#~ msgid ""
#~ "On a &Linux; system, you should use the hotplug system to change the "
#~ "ownership and permissions on the mouse entry in <filename>/proc/bus/usb</"
#~ "filename>. One way to do this is to create a short script (<filename>/etc/"
#~ "hotplug/usb/consoleUserPerms</filename>) that changes the ownership and "
#~ "permissions, as shown below:"
#~ msgstr ""
#~ "På &Linux;-system bör du använda systemet med anslutning under körning "
#~ "för att ändra ägare och rättigheter för musen under <filename>/proc/bus/"
#~ "usb </filename>. Ett sätt att göra det är att skapa ett kort skript "
#~ "(<filename>/etc/hotplug/usb/consoleUserPerms</filename>) som ändrar ägare "
#~ "och rättigheter, som visas nedan:"

#~ msgid ""
#~ "<![CDATA[\n"
#~ "#!/bin/bash\n"
#~ "#\n"
#~ "# /etc/hotplug/usb/consoleUserPerms\n"
#~ "#\n"
#~ "# Sets up newly plugged in USB device so that the user who owns\n"
#~ "# the console according to pam_console can access it from user space\n"
#~ "#\n"
#~ "# Note that for this script to work, you'll need all of the following:\n"
#~ "# a) a line in the file /etc/hotplug/usb.usermap or another usermap file\n"
#~ "#    in /etc/hotplug/usb/ that corresponds to the device you are using.\n"
#~ "# b) a setup using pam_console creates the respective lock files\n"
#~ "#    containing the name of the respective user. You can check for that\n"
#~ "#    by executing \"echo `cat /var/{run,lock}/console.lock`\" and\n"
#~ "#    verifying the appropriate user is mentioned somewhere there.\n"
#~ "# c) a Linux kernel supporting hotplug and usbdevfs\n"
#~ "# d) the hotplug package (http://linux-hotplug.sourceforge.net/)\n"
#~ "#\n"
#~ "# In the usermap file, the first field \"usb module\" should be named\n"
#~ "# \"consoleUserPerms\" to invoke this script.\n"
#~ "#\n"
#~ "\n"
#~ "if [ \"${ACTION}\" = \"add\" ] && [ -f \"${DEVICE}\" ]\n"
#~ "then\n"
#~ "# New code, using lock files instead of copying /dev/console permissions\n"
#~ "# This also works with non-kdm logins (e.g. on a virtual terminal)\n"
#~ "# Idea and code from Nalin Dahyabhai <nalin@redhat.com>\n"
#~ "    if [ -f /var/run/console.lock ]\n"
#~ "    then\n"
#~ "        CONSOLEOWNER=`cat /var/run/console.lock`\n"
#~ "    elif [ -f /var/lock/console.lock ]\n"
#~ "    then\n"
#~ "        CONSOLEOWNER=`cat /var/lock/console.lock`\n"
#~ "    else\n"
#~ "        CONSOLEOWNER=\n"
#~ "    fi\n"
#~ "    if [ -n \"$CONSOLEOWNER\" ]\n"
#~ "    then\n"
#~ "        chmod 0000 \"${DEVICE}\"\n"
#~ "        chown \"$CONSOLEOWNER\" \"${DEVICE}\"\n"
#~ "        chmod 0600 \"${DEVICE}\"\n"
#~ "    fi\n"
#~ "fi\n"
#~ "]]>"
#~ msgstr ""
#~ "<![CDATA[\n"
#~ "#!/bin/bash\n"
#~ "#\n"
#~ "# /etc/hotplug/usb/consoleUserPerms\n"
#~ "#\n"
#~ "# Sets up newly plugged in USB device so that the user who owns\n"
#~ "# the console according to pam_console can access it from user space\n"
#~ "#\n"
#~ "# Note that for this script to work, you'll need all of the following:\n"
#~ "# a) a line in the file /etc/hotplug/usb.usermap or another usermap file\n"
#~ "#    in /etc/hotplug/usb/ that corresponds to the device you are using.\n"
#~ "# b) a setup using pam_console creates the respective lock files\n"
#~ "#    containing the name of the respective user. You can check for that\n"
#~ "#    by executing \"echo `cat /var/{run,lock}/console.lock`\" and\n"
#~ "#    verifying the appropriate user is mentioned somewhere there.\n"
#~ "# c) a Linux kernel supporting hotplug and usbdevfs\n"
#~ "# d) the hotplug package (http://linux-hotplug.sourceforge.net/)\n"
#~ "#\n"
#~ "# In the usermap file, the first field \"usb module\" should be named\n"
#~ "# \"consoleUserPerms\" to invoke this script.\n"
#~ "#\n"
#~ "\n"
#~ "if [ \"${ACTION}\" = \"add\" ] && [ -f \"${DEVICE}\" ]\n"
#~ "then\n"
#~ "# New code, using lock files instead of copying /dev/console permissions\n"
#~ "# This also works with non-kdm logins (e.g. on a virtual terminal)\n"
#~ "# Idea and code from Nalin Dahyabhai <nalin@redhat.com>\n"
#~ "    if [ -f /var/run/console.lock ]\n"
#~ "    then\n"
#~ "        CONSOLEOWNER=`cat /var/run/console.lock`\n"
#~ "    elif [ -f /var/lock/console.lock ]\n"
#~ "    then\n"
#~ "        CONSOLEOWNER=`cat /var/lock/console.lock`\n"
#~ "    else\n"
#~ "        CONSOLEOWNER=\n"
#~ "    fi\n"
#~ "    if [ -n \"$CONSOLEOWNER\" ]\n"
#~ "    then\n"
#~ "        chmod 0000 \"${DEVICE}\"\n"
#~ "        chown \"$CONSOLEOWNER\" \"${DEVICE}\"\n"
#~ "        chmod 0600 \"${DEVICE}\"\n"
#~ "    fi\n"
#~ "fi\n"
#~ "]]>"

