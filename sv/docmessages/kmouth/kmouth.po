#. Tag: para
#: index.docbook:35
#, no-c-format
msgid ""
"&kmouth; is an application that enables persons that cannot speak to let "
"their computers speak."
msgstr ""
"&kmouth; är ett program som gör det möjligt för personer som inte kan tala, "
"att låta sina datorer tala."

#. Tag: keyword
#: index.docbook:42
#, no-c-format
msgid "<keyword>KDE</keyword>"
