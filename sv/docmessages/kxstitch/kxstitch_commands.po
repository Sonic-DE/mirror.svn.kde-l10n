#. Tag: action
#: commands.docbook:123
#, no-c-format
msgid "Rotate the selected area anti clockwise 90 degrees"
msgstr "Rotera det markerade området moturs 90 grader"

#. Tag: menuchoice
#: commands.docbook:126
#, no-c-format
msgid ""
"<guisubmenu>Rotate Selection</guisubmenu><guimenuitem>180 degrees</"
"guimenuitem>"
msgstr ""
"<guisubmenu>Rotera markering</guisubmenu><guimenuitem>180 grader</"
"guimenuitem>"

#. Tag: action
#: commands.docbook:127
#, no-c-format
