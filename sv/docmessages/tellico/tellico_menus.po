#. Tag: title
#: menus.docbook:2
#, no-c-format
msgid "Command Reference"
msgstr "Kommandoreferens"

#. Tag: title
#: menus.docbook:13
#, no-c-format
msgid "The Main &tellico; Window"
msgstr "Huvudfönstret i &tellico;"

#. Tag: para
#: menus.docbook:15
#, no-c-format
msgid ""
"Each menu item is discussed below. When there is a keyboard shortcut that "
"performs a menu item function, the default shortcut is listed with the menu "
"item."
msgstr ""
"Varje menyalternativ beskrivs nedan. Om det finns en snabbtangent som utför "
"en menyfunktion, så listas den tillsammans med menyalternativet."

#. Tag: title
#: menus.docbook:20
#, no-c-format
msgid "The File Menu"
msgstr "Menyn Arkiv"

#. Tag: menuchoice
#: menus.docbook:27
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>New</guimenuitem>"
msgstr "<guimenu>Arkiv</guimenu> <guimenuitem>Ny</guimenuitem>"

#. Tag: para
#: menus.docbook:34
#, no-c-format
msgid ""
"This command <action>creates a new collection</action>. &tellico; supports "
"<link linkend=\"collection-types\">12 default collection types</link> along "
"with an empty user-defined custom collection. Any custom-saved collection "
"templates will also be available."
msgstr ""
"Kommandot <action>skapar en ny samling</action>. &tellico; stöder <link "
"linkend=\"collection-types\">12 standardsamlingstyper</link> liksom en tom "
"användardefinierad egen samling. Alla egna sparade samlingsmallar är också "
"tillgängliga."

#. Tag: menuchoice
#: menus.docbook:40
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>O</keycap></keycombo> </shortcut> "
"<guimenu>File</guimenu> <guimenuitem>Open...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>O</keycap></keycombo> </shortcut> "
"<guimenu>Arkiv</guimenu> <guimenuitem>Öppna...</guimenuitem>"

#. Tag: para
#: menus.docbook:50
#, no-c-format
msgid "This command <action>opens a &tellico; file</action>."
msgstr "Kommandot <action>öppnar en &tellico;-fil</action>."

#. Tag: menuchoice
#: menus.docbook:56
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Open Recent</guimenuitem>"
msgstr "<guimenu>Arkiv</guimenu> <guimenuitem>Öppna senaste</guimenuitem>"

#. Tag: para
#: menus.docbook:63
#, no-c-format
msgid ""
"This command <action>opens a file</action> from a submenu that contains a "
"list of recently opened files."
msgstr ""
"Kommandot <action>öppnar en fil</action> från en undermeny som innehåller en "
"lista med senast öppnade filer."

#. Tag: menuchoice
#: menus.docbook:70
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>S</keycap></keycombo> </shortcut> "
"<guimenu>File</guimenu> <guimenuitem>Save...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>S</keycap></keycombo> </shortcut> "
"<guimenu>Arkiv</guimenu> <guimenuitem>Spara...</guimenuitem>"

#. Tag: para
#: menus.docbook:80
#, no-c-format
msgid ""
"This command <action>saves the collection</action>. If the file is "
"<emphasis>Untitled</emphasis> then <guimenuitem>Save...</guimenuitem> is "
"equivalent to <guimenuitem>Save As</guimenuitem>. It is only enabled when "
"the collection has been modified."
msgstr ""
"Kommandot <action>sparar samlingen</action>. Om filen är <emphasis>Namnlös</"
"emphasis> är <guimenuitem>Spara...</guimenuitem> samma sak som "
"<guimenuitem>Spara som</guimenuitem>. Det är bara aktiverat när samlingen "
"har ändrats."

#. Tag: menuchoice
#: menus.docbook:89
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;&Shift;<keycap>S</keycap></keycombo> </shortcut> "
"<guimenu>File</guimenu> <guimenuitem>Save As...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;&Shift;<keycap>S</keycap></keycombo> </shortcut> "
"<guimenu>Arkiv</guimenu> <guimenuitem>Spara som...</guimenuitem>"

#. Tag: para
#: menus.docbook:99
#, no-c-format
msgid "This command <action>saves the collection to a new file</action>."
msgstr "Kommandot <action>sparar samlingen i en ny fil</action>."

#. Tag: menuchoice
#: menus.docbook:105
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Save As Template...</guimenuitem>"
msgstr "<guimenu>Arkiv</guimenu> <guimenuitem>Spara som mall...</guimenuitem>"

#. Tag: para
#: menus.docbook:112
#, no-c-format
msgid ""
"This command <action>saves the collection as a new template</action>. Only "
"the fields are saved, and the custom collection type can be created via the "
"<guimenuitem>New Collection</guimenuitem> command."
msgstr ""
"Kommandot <action>sparar samlingen som en ny mall</action>. Bara fälten "
"sparas, och den egna samlingstypen kan skapas via kommandot <guimenuitem >Ny "
"samling</guimenuitem >."

#. Tag: menuchoice
#: menus.docbook:118
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>P</keycap></keycombo> </shortcut> "
"<guimenu>File</guimenu> <guimenuitem>Print...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>P</keycap></keycombo> </shortcut> "
"<guimenu>Arkiv</guimenu> <guimenuitem>Skriv ut...</guimenuitem>"

#. Tag: para
#: menus.docbook:128
#, no-c-format
msgid ""
"This command <action>prints the collection</action>. Printing options may be "
"set in the <interface>Configuration Dialog</interface>."
msgstr ""
"Kommandot <action>skriver ut samlingen</action>. Utskriftsalternativ kan "
"ställas in i <interface>Inställningsdialogrutan</interface>."

#. Tag: menuchoice
#: menus.docbook:134
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Print Preview</guimenuitem>"
msgstr ""
"<guimenu>Arkiv</guimenu> <guimenuitem>Förhandsgranskning av utskrift</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:141
#, no-c-format
msgid ""
"This command <action>shows a preview of the printed collection</action>."
msgstr ""
"Kommandot <action>visar en förhandsgranskning av den utskrivna samlingen</"
"action>."

#. Tag: menuchoice
#: menus.docbook:147
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Import</guimenuitem>"
msgstr "<guimenu>Arkiv</guimenu> <guimenuitem>Importera</guimenuitem>"

#. Tag: para
#: menus.docbook:154
#, no-c-format
msgid ""
"This command <action>imports data from another file</action>. &tellico; can "
"import data from a number of <link linkend=\"importing\">other formats</"
"link>."
msgstr ""
"Kommandot <action>importerar data från en annan fil</action>. &tellico; kan "
"importera data från ett antal <link linkend=\"importing\">andra format</"
"link>."

#. Tag: menuchoice
#: menus.docbook:160
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Export</guimenuitem>"
msgstr "<guimenu>Arkiv</guimenu> <guimenuitem>Exportera</guimenuitem>"

#. Tag: para
#: menus.docbook:167
#, no-c-format
msgid ""
"This command <action>exports the collection to another format</action>. "
"&tellico; can export data to a number of <link linkend=\"exporting\">other "
"formats</link>."
msgstr ""
"Kommandot <action>exporterar samlingen till ett annat format</action>. "
"&tellico; kan exportera data till ett antal <link linkend=\"exporting"
"\">andra format</link>."

#. Tag: menuchoice
#: menus.docbook:173
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>Q</keycap></keycombo> </shortcut> "
"<guimenu>File</guimenu> <guimenuitem>Quit</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>Q</keycap></keycombo> </shortcut> "
"<guimenu>Arkiv</guimenu> <guimenuitem>Avsluta</guimenuitem>"

#. Tag: para
#: menus.docbook:183
#, no-c-format
msgid ""
"This command <action>closes the &tellico; window</action>. If the collection "
"has unsaved changes, you will be prompted to save them before continuing."
msgstr ""
"Kommandot <action>stänger &tellico;s fönster</action>. Om samlingen har "
"osparade ändringar, blir du tillfrågad om att spara dem innan kommandot "
"utförs."

#. Tag: title
#: menus.docbook:193
#, no-c-format
msgid "The Edit Menu"
msgstr "Menyn Redigera"

#. Tag: menuchoice
#: menus.docbook:201
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>Z</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Undo</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>Z</keycap></keycombo> </shortcut> "
"<guimenu>Redigera</guimenu> <guimenuitem>Ångra</guimenuitem>"

#. Tag: para
#: menus.docbook:211
#, no-c-format
msgid ""
"This command <action>undoes the previous action</action>. Not all actions "
"are supported by Undo."
msgstr ""
"Kommandot <action>ångra den föregående åtgärden</action>. Alla åtgärder "
"stöder inte att ångras."

#. Tag: menuchoice
#: menus.docbook:217
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;&Shift;<keycap>Z</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Redo</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>Z</keycap></keycombo> </shortcut> "
"<guimenu>Redigera</guimenu> <guimenuitem>Ångra</guimenuitem>"

#. Tag: para
#: menus.docbook:227
#, no-c-format
msgid "This command <action>reverts a previous Undo</action>."
msgstr "Kommandot <action>gör om en tidigare ångrad åtgärd</action>."

#. Tag: menuchoice
#: menus.docbook:233
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>X</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Cut</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>X</keycap></keycombo> </shortcut> "
"<guimenu>Redigera</guimenu> <guimenuitem>Klipp ut</guimenuitem>"

#. Tag: para
#: menus.docbook:243
#, no-c-format
msgid ""
"This command <action>removes the selected text</action>, if any, and "
"<action>places a copy of the removed text in the clipboard</action>."
msgstr ""
"Kommandot <action>tar bort markerad text</action>, om det finns någon, och "
"<action>placerar en kopia av den borttagna texten på klippbordet</action>."

#. Tag: menuchoice
#: menus.docbook:249
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>C</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Copy</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>C</keycap></keycombo> </shortcut> "
"<guimenu>Redigera</guimenu> <guimenuitem>Kopiera</guimenuitem>"

#. Tag: para
#: menus.docbook:259
#, no-c-format
msgid ""
"This command <action>copies the selected text</action>, if any, to the "
"clipboard."
msgstr ""
"Kommandot <action>kopierar markerad text</action>, om det finns någon, till "
"klippbordet."

#. Tag: menuchoice
#: menus.docbook:265
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>V</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Paste</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>V</keycap></keycombo> </shortcut> "
"<guimenu>Redigera</guimenu> <guimenuitem>Klistra in</guimenuitem>"

#. Tag: para
#: menus.docbook:275
#, no-c-format
msgid ""
"This command <action>pastes the text in the clipboard</action>, if any, into "
"the editor at the cursor position."
msgstr ""
"Kommandot <action>klistrar in texten på klippbordet</action>, om det finns "
"någon, till editorn på markörens position."

#. Tag: menuchoice
#: menus.docbook:281
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>A</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Select All</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>A</keycap></keycombo> </shortcut> "
"<guimenu>Redigera</guimenu> <guimenuitem>Markera alla</guimenuitem>"

#. Tag: para
#: menus.docbook:291
#, no-c-format
msgid ""
"This command <action>selects all the entries</action> in the collection, in "
"the <interface>Column View</interface>."
msgstr ""
"Kommandot <action>markerar alla poster</action> i samlingen, i "
"<interface>Kolumnvyn</interface>."

#. Tag: menuchoice
#: menus.docbook:297
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;&Shift;<keycap>A</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Deselect</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;&Shift;<keycap>A</keycap></keycombo> </shortcut> "
"<guimenu>Redigera</guimenu> <guimenuitem>Avmarkera</guimenuitem>"

#. Tag: para
#: menus.docbook:307
#, no-c-format
msgid ""
"This command <action>deselects all the entries</action> in the collection."
msgstr "Kommandot <action>avmarkerar alla poster</action> i samlingen."

#. Tag: menuchoice
#: menus.docbook:313
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>I</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Internet Search...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>I</keycap></keycombo> </shortcut> "
"<guimenu>Redigera</guimenu> <guimenuitem>Internetsökning...</guimenuitem>"

#. Tag: para
#: menus.docbook:323
#, no-c-format
msgid ""
"This command <action>opens the <interface>Internet Search Dialog</"
"interface></action> to search for and import entries from various Internet "
"sites, including <ulink url=\"http://amazon.com\">Amazon.com</ulink>."
msgstr ""
"Kommandot <action>visar <interface>dialogrutan Internetsökning</interface></"
"action> för att söka efter och importera poster från diverse platser på "
"Internet, inklusive <ulink url=\"http://amazon.com\">Amazon.com</ulink>."

#. Tag: menuchoice
#: menus.docbook:329
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>J</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Advanced Filter...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>J</keycap></keycombo> </shortcut> "
"<guimenu>Redigera</guimenu> <guimenuitem>Avancerat filter...</guimenuitem>"

#. Tag: para
#: menus.docbook:339
#, no-c-format
msgid ""
"This command <action>opens the <interface>Advanced Filter Dialog</"
"interface></action>."
msgstr ""
"Kommandot <action>visar den avancerade <interface>Filterdialogrutan</"
"interface></action>."

#. Tag: title
#: menus.docbook:350
#, no-c-format
msgid "The Collection Menu"
msgstr "Menyn Samling"

#. Tag: menuchoice
#: menus.docbook:357
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>N</keycap></keycombo> </shortcut> "
"<guimenu>Collection</guimenu> <guimenuitem>New Entry</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>N</keycap></keycombo> </shortcut> "
"<guimenu>Samling</guimenu> <guimenuitem>Ny post</guimenuitem>"

#. Tag: para
#: menus.docbook:367
#, no-c-format
msgid ""
"This command <action>opens the <interface>Entry Editor</interface> to edit a "
"new entry</action>."
msgstr ""
"Kommandot <action>visar <interface>Posteditorn</interface> för att redigera "
"en ny post</action>."

#. Tag: menuchoice
#: menus.docbook:373
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>E</keycap></keycombo> </shortcut> "
"<guimenu>Collection</guimenu> <guimenuitem>Edit Entry</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>E</keycap></keycombo> </shortcut> "
"<guimenu>Samling</guimenu> <guimenuitem>Redigera post</guimenuitem>"

#. Tag: para
#: menus.docbook:383
#, no-c-format
msgid ""
"This command <action>opens the <interface>Entry Editor</interface> to edit "
"the selected entries</action>."
msgstr ""
"Kommandot <action>visar <interface>Posteditorn</interface> för att redigera "
"de markerade posterna</action>."

#. Tag: menuchoice
#: menus.docbook:389
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>Y</keycap></keycombo> </shortcut> "
"<guimenu>Collection</guimenu> <guimenuitem>Duplicate Entry</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>Y</keycap></keycombo> </shortcut> "
"<guimenu>Samling</guimenu> <guimenuitem>Duplicera post</guimenuitem>"

#. Tag: para
#: menus.docbook:399
#, no-c-format
msgid ""
"This command <action>copies, or duplicates, the selected entries</action> as "
"new entries in the collection."
msgstr ""
"Kommandot <action>kopierar, eller duplicerar, de markerade posterna</action> "
"som nya poster i samlingen."

#. Tag: menuchoice
#: menus.docbook:405
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>D</keycap></keycombo> </shortcut> "
"<guimenu>Collection</guimenu> <guimenuitem>Delete Entry</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>D</keycap></keycombo> </shortcut> "
"<guimenu>Samling</guimenu> <guimenuitem>Ta bort post</guimenuitem>"

#. Tag: para
#: menus.docbook:415
#, no-c-format
msgid "This command <action>deletes the selected entries</action>."
msgstr "Kommandot <action>tar bort markerade poster</action>."

#. Tag: menuchoice
#: menus.docbook:421
#, no-c-format
msgid "<guimenu>Collection</guimenu> <guimenuitem>Merge Entries</guimenuitem>"
msgstr ""
"<guimenu>Samling</guimenu> <guimenuitem>Sammanfoga poster</guimenuitem>"

#. Tag: para
#: menus.docbook:433
#, no-c-format
msgid "This command <action>merges the selected entries</action>."
msgstr "Kommandot <action>sammanfogar de markerade posterna</action>."

#. Tag: menuchoice
#: menus.docbook:439
#, no-c-format
msgid "<guimenu>Collection</guimenu> <guimenuitem>Update Entry</guimenuitem>"
msgstr "<guimenu>Samling</guimenu> <guimenuitem>Uppdatera post</guimenuitem>"

#. Tag: para
#: menus.docbook:446
#, no-c-format
msgid ""
"This menu contains a list of all available data sources, and can be used to "
"automatically query the source and <action>update the selected entries</"
"action>."
msgstr ""
"Menyn innehåller en lista av alla tillgängliga datakällor, och kan användas "
"för att automatiskt fråga källan och <action>uppdatera markerade poster</"
"action>."

#. Tag: menuchoice
#: menus.docbook:453
#, no-c-format
msgid "<guimenu>Collection</guimenu> <guimenuitem>Check-out</guimenuitem>"
msgstr "<guimenu>Samling</guimenu> <guimenuitem>Låna ut</guimenuitem>"

#. Tag: para
#: menus.docbook:460
#, no-c-format
msgid ""
"This command <action>opens a dialog box for loaning the selected entries.</"
"action>."
msgstr ""
"Kommandot <action>visar en dialogruta för att låna ut markerade poster</"
"action>."

#. Tag: menuchoice
#: menus.docbook:466
#, no-c-format
msgid "<guimenu>Collection</guimenu> <guimenuitem>Check-in</guimenuitem>"
msgstr "<guimenu>Samling</guimenu> <guimenuitem>Lämna tillbaka</guimenuitem>"

#. Tag: para
#: menus.docbook:473
#, no-c-format
msgid ""
"This command <action>checks-in any of the selected entries which are "
"currently on-loan</action>."
msgstr ""
"Kommandot <action>lämnar tillbaks alla markerade poster som för närvarande "
"är utlånade</action>."

#. Tag: menuchoice
#: menus.docbook:479
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>R</keycap></keycombo> </shortcut> "
"<guimenu>Collection</guimenu> <guimenuitem>Rename Collection</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>R</keycap></keycombo> </shortcut> "
"<guimenu>Samling</guimenu> <guimenuitem>Byt namn på samling</guimenuitem>"

#. Tag: para
#: menus.docbook:489
#, no-c-format
msgid ""
"This command <action>opens a dialog box for renaming the collection</action>."
msgstr ""
"Kommandot <action>visar en dialogruta för att byta namn på samlingen</"
"action>."

#. Tag: menuchoice
#: menus.docbook:495
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>U</keycap></keycombo> </shortcut> "
"<guimenu>Collection</guimenu> <guimenuitem>Collection Fields...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>U</keycap></keycombo> </shortcut> "
"<guimenu>Samling</guimenu> <guimenuitem>Samlingsfält...</guimenuitem>"

#. Tag: para
#: menus.docbook:505
#, no-c-format
msgid ""
"This command <action>opens the <interface>Collection Fields Dialog</"
"interface></action>."
msgstr ""
"Kommandot <action>visar <interface>Samlingsfältdialogrutan</interface></"
"action>."

#. Tag: menuchoice
#: menus.docbook:511
#, no-c-format
msgid ""
"<guimenu>Collection</guimenu> <guimenuitem>Generate Reports...</guimenuitem>"
msgstr ""
"<guimenu>Samling</guimenu> <guimenuitem>Skapa rapporter...</guimenuitem>"

#. Tag: para
#: menus.docbook:518
#, no-c-format
msgid ""
"This command <action>opens the <interface>Report Dialog</interface></action> "
"for generating reports about the collection."
msgstr ""
"Kommandot <action>visar <interface>Rapportdialogrutan</interface></action> "
"för att skapa rapporter om samlingen."

#. Tag: menuchoice
#: menus.docbook:524
#, no-c-format
msgid ""
"<guimenu>Collection</guimenu> <guisubmenu>Bibliography</guisubmenu> "
"<guimenuitem>Convert to Bibliography</guimenuitem>"
msgstr ""
"<guimenu>Samling</guimenu> <guisubmenu>Bibliografi</guisubmenu> "
"<guimenuitem>Konvertera till bibliografi</guimenuitem>"

#. Tag: para
#: menus.docbook:532
#, no-c-format
msgid ""
"This command <action>converts a book collection to a bibliography</action> "
"by adding certain fields necessary for Bibtex export, and it is only enabled "
"when a book collection is open."
msgstr ""
"Kommandot <action>konverterar en boksamling till en bibliografi</action> "
"genom att lägga till vissa fält nödvändiga för export till Bibtex, och är "
"bara aktiverat när en boksamling är öppen."

#. Tag: menuchoice
#: menus.docbook:538
#, no-c-format
msgid ""
"<guimenu>Collection</guimenu> <guisubmenu>Bibliography</guisubmenu> "
"<guimenuitem>String Macros...</guimenuitem>"
msgstr ""
"<guimenu>Samling</guimenu> <guisubmenu>Bibliografi</guisubmenu> "
"<guimenuitem>Strängmakron...</guimenuitem>"

#. Tag: para
#: menus.docbook:546
#, no-c-format
msgid ""
"This command <action>opens a dialog box for editing the Bibtex string "
"macros</action> in the collection. It is only enabled when editing a "
"bibliography."
msgstr ""
"Kommandot <action>visar en dialogruta för att redigera Bibtex strängmakron</"
"action> i samlingen. Det är bara aktiverat när en bibliografi redigeras."

#. Tag: menuchoice
#: menus.docbook:552
#, no-c-format
msgid ""
"<guimenu>Collection</guimenu> <guisubmenu>Bibliography</guisubmenu> "
"<guimenuitem>Check for Duplicate Keys</guimenuitem>"
msgstr ""
"<guimenu>Samling</guimenu> <guisubmenu>Bibliografi</guisubmenu> "
"<guimenuitem>Kontrollera duplicerade nycklar...</guimenuitem>"

#. Tag: para
#: menus.docbook:560
#, no-c-format
msgid ""
"This command <action>checks for duplicate Bibtex keys</action> and can "
"filter the collection to show the entries with duplicated keys."
msgstr ""
"Kommandot <action>kontrollerar om det finns duplicerade Bibtex-nycklar</"
"action> och kan filtrera samlingen för att visa posterna med duplicerade "
"nycklar."

#. Tag: menuchoice
#: menus.docbook:566
#, no-c-format
msgid ""
"<guimenu>Collection</guimenu> <guisubmenu>Bibliography</guisubmenu> "
"<guimenuitem>Copy Bibtex to Clipboard</guimenuitem>"
msgstr ""
"<guimenu>Samling</guimenu> <guisubmenu>Bibliografi</guisubmenu> "
"<guimenuitem>Kopiera Bibtex till klippbord</guimenuitem>"

#. Tag: para
#: menus.docbook:574
#, no-c-format
msgid ""
"This command <action>copies a Bibtex citation</action> to the clipboard so "
"that it can pasted in a LaTeX document."
msgstr ""
"Kommandot <action>kopierar en Bibtex hänvisning</action> till klippbordet så "
"att den kan klistras in i ett Latex-dokument."

#. Tag: menuchoice
#: menus.docbook:580
#, no-c-format
msgid ""
"<guimenu>Collection</guimenu> <guisubmenu>Bibliography</guisubmenu> "
"<guimenuitem>Cite Entry in Lyx</guimenuitem>"
msgstr ""
"<guimenu>Samling</guimenu> <guisubmenu>Bibliografi</guisubmenu> "
"<guimenuitem>Hänvisa till post i Lyx</guimenuitem>"

#. Tag: para
#: menus.docbook:588
#, no-c-format
msgid ""
"This command <action>sends a citation for the selected entries</action> to "
"the so-called <emphasis><link linkend=\"hidden-bibtex-options\">lyxpipe</"
"link></emphasis> for use in <application>LyX</application>, "
"<application>Kile</application>, or other LaTeX applications. It is only "
"enabled when editing a bibliography."
msgstr ""
"Kommandot <action>skickar en hänvisning till markerade poster</action> till "
"en så kallad <emphasis><link linkend=\"hidden-bibtex-options\">lyxpipe</"
"link></emphasis> för användning i <application>Lyx</application>, "
"<application>Kile</application>, eller andra Latex-program. Det är bara "
"aktiverat när en bibliografi redigeras."

#. Tag: title
#: menus.docbook:599
#, no-c-format
msgid "The Settings and Help Menu"
msgstr "Menyerna Inställningar och Hjälp"

#. Tag: para
#: menus.docbook:601
#, no-c-format
msgid ""
"Apart from the common &kde; Settings and Help menus described in the <ulink "
"url=\"help:/fundamentals/menus.html\">Menu</ulink> chapter of the &kde; "
"Fundamentals documentation &tellico; has these application specific menu "
"entries:"
msgstr ""
"Förutom de vanliga inställnings- och hjälpmenyerna i &kde; som beskrivs i "
"kapitlet <ulink url=\"help:/fundamentals/menus.html\">Meny</ulink> i "
"dokumentet &kde;:s grunder, har &tellico; följande programspecifika "
"menyalternativ:"

#. Tag: menuchoice
#: menus.docbook:609
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Show Group View</guimenuitem>"
msgstr ""
"<guimenu>Inställningar</guimenu> <guimenuitem>Visa gruppvy</guimenuitem>"

#. Tag: para
#: menus.docbook:616
#, no-c-format
msgid ""
"This command <action>toggles the display of the <interface>Group View</"
"interface></action>."
msgstr ""
"Kommandot <action>växlar visning av <interface>Gruppvyn</interface></action>."

#. Tag: menuchoice
#: menus.docbook:622
#, no-c-format
msgid ""
"<guimenu>Settings</guimenu> <guimenuitem>Show Entry Editor</guimenuitem>"
msgstr ""
"<guimenu>Inställningar</guimenu> <guimenuitem>Visa posteditor</guimenuitem>"

#. Tag: para
#: menus.docbook:629
#, no-c-format
msgid ""
"This command <action>toggles the display of the <interface>Entry Editor</"
"interface></action>."
msgstr ""
"Kommandot <action>växlar visning av <interface>Posteditorn</interface></"
"action>."

#. Tag: menuchoice
#: menus.docbook:635
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Group Selection</guimenuitem>"
msgstr "<guimenu>Inställningar</guimenu> <guimenuitem>Gruppurval</guimenuitem>"

#. Tag: para
#: menus.docbook:642
#, no-c-format
msgid ""
"This command <action>changes the field used to group the entries</action> in "
"the collection."
msgstr ""
"Kommandot <action>ändrar fältet som används för att gruppera posterna </"
"action> i samlingen."

#. Tag: menuchoice
#: menus.docbook:648
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Lock Layout</guimenuitem>"
msgstr "<guimenu>Inställningar</guimenu> <guimenuitem>Lås layout</guimenuitem>"

#. Tag: para
#: menus.docbook:655
#, no-c-format
msgid ""
"This command <action>locks the layout</action> such that the various "
"collection views cannot be moved. Unlocking the layout allows the user to "
"rearrange them."
msgstr ""
"Kommandot <action>låser layouten</action> så att de olika samlingsvyerna "
"inte kan flyttas. Genom att låsa upp layouten kan användaren ordna om dem."

#. Tag: menuchoice
#: menus.docbook:661
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Reset Layout</guimenuitem>"
msgstr ""
"<guimenu>Inställningar</guimenu> <guimenuitem>Återställ layout</guimenuitem>"

#. Tag: para
#: menus.docbook:668
#, no-c-format
msgid ""
"This command <action>resets the layout</action> to the default view, which "
"may be helpful if the various views become hidden or collapsed."
msgstr ""
"Kommandot <action>återställer layouten</action> till standardvyn, vilket kan "
"vara användbart om de olika vyerna blir dolda eller hopdragna."

#. Tag: menuchoice
#: menus.docbook:674
#, no-c-format
msgid "<guimenu>Help</guimenu> <guimenuitem>Show Log</guimenuitem>"
msgstr "<guimenu>Hjälp</guimenu> <guimenuitem>Visa logg</guimenuitem>"

#. Tag: para
#: menus.docbook:681
#, no-c-format
msgid ""
"When the <userinput>tellico --log</userinput> option is used, this command "
"shows the diagnostic log."
msgstr ""
"När väljaren <userinput>tellico --log</userinput> används, visar kommandot "
"diagnostikloggen."

