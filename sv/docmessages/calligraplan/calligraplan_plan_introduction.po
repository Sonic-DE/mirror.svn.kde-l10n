#. Tag: para
#: introduction.docbook:2
#, no-c-format
msgid "Features include:"
msgstr "Funktioner omfattar:"

#. Tag: para
#: introduction.docbook:5
#, no-c-format
msgid ""
"Task management using the <link linkend=\"task-editor\">Task Editor</"
"link>&nbsp;"
msgstr ""
"Aktivitetshantering genom att använda <link linkend=\"task-editor"
"\">Aktivitetseditorn</link>&nbsp;"

#. Tag: para
#: introduction.docbook:6
#, no-c-format
msgid "Work breakdown structure with configurable WBS codes"
msgstr "Arbetsfördelningsstruktur med inställningsbara koder"

#. Tag: para
#: introduction.docbook:7
#, no-c-format
msgid "Tasks, summary tasks, and milestones"
msgstr "Aktiviteter, sammanfattningsaktiviteter och milstolpar"

#. Tag: para
#: introduction.docbook:8
#, no-c-format
msgid "Different types of time constraints"
msgstr "Olika typer av tidsbegränsningar"

#. Tag: para
#: introduction.docbook:9
#, no-c-format
msgid "Different types of dependencies."
msgstr "Olika typer av beroenden."

#. Tag: para
#: introduction.docbook:12
#, no-c-format
msgid ""
"Resource management using the <link linkend=\"resource-editor\">Resource "
"Editor</link>&nbsp;"
msgstr ""
"Resurshantering genom att använda <link linkend=\"resource-editor"
"\">Resurseditorn</link>&nbsp;"

#. Tag: para
#: introduction.docbook:13
#, no-c-format
msgid "Resource breakdown structure"
msgstr "Resursfördelningsstruktur"

#. Tag: para
#: introduction.docbook:14
#, no-c-format
msgid "Working- and material resource types"
msgstr "Arbets- och materialresurstyper"

#. Tag: para
#: introduction.docbook:15
#, no-c-format
msgid "Resource allocation on group level"
msgstr "Resurstilldelning på gruppnivå"

#. Tag: para
#: introduction.docbook:16
#, no-c-format
msgid "Resource teams"
msgstr "Resurslag"

#. Tag: para
#: introduction.docbook:19
#, no-c-format
msgid ""
"Work time &amp; vacation definition using the <link linkend=\"work-and-"
"vacation-editor\">Work and Vacation Editor</link>&nbsp;"
msgstr ""
"Arbetstids- och semesterdefinitioner genom att använda <link linkend=\"work-"
"and-vacation-editor\">Arbete- och semestereditor</link>&amp;"

#. Tag: para
#: introduction.docbook:20
#, no-c-format
msgid ""
"Cost management using the <link linkend=\"cost-breakdown-structure-editor"
"\">Cost Breakdown Structure Editor</link>&nbsp;"
msgstr ""
"Kostnadshantering genom att använda <link linkend=\"cost-breakdown-structure-"
"editor\">Kostnadsfördelningsstruktureditor</link>&nbsp;"

#. Tag: para
#: introduction.docbook:21
#, no-c-format
msgid "Earned value management"
msgstr "Intjänat värdehantering"

#. Tag: para
#: introduction.docbook:22
#, no-c-format
msgid ""
"Project scheduling using the <link linkend=\"schedules-editor\">Schedules "
"Editor</link>&nbsp;"
msgstr ""
"Projektschemaläggning genom att använda <link linkend=\"schedules-editor"
"\">Tidplaneditorn</link>&nbsp;"

#. Tag: para
#: introduction.docbook:23
#, no-c-format
msgid "Schedule forward from start time or backward from finish time"
msgstr "Schemalägg framåt från starttiden eller bakåt från sluttiden"

#. Tag: para
#: introduction.docbook:24
#, no-c-format
msgid "Allow or avoid resource overbooking"
msgstr "Tillåt eller undvik överbokning"

#. Tag: para
#: introduction.docbook:25
#, no-c-format
msgid ""
"PERT distribution with optimistic-, pessimistic-, and most likely estimates"
msgstr ""
"PERT-fördelning med optimistiska, pessimistiska och troligaste uppskattningar"

#. Tag: para
#: introduction.docbook:26
#, no-c-format
msgid ""
"Multiple schedules with a possibility to schedule from current progress "
"information"
msgstr ""
"Flera scheman med möjlighet att schemalägga från aktuell förloppsinformation"

#. Tag: para
#: introduction.docbook:29
#, no-c-format
msgid ""
"Task tracking using the <link linkend=\"task-execution-view\">Task Execution "
"View</link> or <link linkend=\"task-status-view\">Task Status View</"
"link>&nbsp;"
msgstr ""
"Aktivitetsuppföljning genom att använda <link linkend=\"task-execution-view"
"\">Aktivitetsutförandevyn</link> eller <link linkend=\"task-status-view"
"\">Aktivitetsstatusvyn</link>&nbsp;"
