#. Tag: para
#: taskdependencyeditorlist.docbook:2
#, no-c-format
msgid ""
"This view is not shown by default. For large projects, it can impact "
"performance severely"
msgstr ""
"Vyn visas inte normalt. För stora projekt kan den avsevärt påverka prestanda"

#. Tag: para
#: taskdependencyeditorlist.docbook:4
#, no-c-format
msgid ""
"It can be activated using the <link linkend=\"the-view-selector\">View "
"Selector</link> context menu."
msgstr ""
"Den kan aktiveras med den sammanhangsberoende menyn <link linkend=\"the-view-"
"selector\">Vyväljare</link>."

#~ msgid "Task Dependency Editor (List)"
#~ msgstr "Aktivitetsberoende-editor (lista)"
