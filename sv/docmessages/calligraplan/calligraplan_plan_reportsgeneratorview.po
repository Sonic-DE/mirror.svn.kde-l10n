#, no-c-format
msgid "Add a new report"
msgstr "Lägg till en ny rapport"

#. Tag: para
#: reportsgeneratorview.docbook:98
#, no-c-format
msgid "Remove Report"
msgstr "Ta bort rapport"

#. Tag: keycombo
