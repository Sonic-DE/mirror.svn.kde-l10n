#. Tag: title
#: taskganttview.docbook:23
#, no-c-format
msgid "Editing data"
msgstr "Redigera data"

#. Tag: para
#: taskganttview.docbook:24
#, no-c-format
msgid "Task description and progress can be edited using the context menu."
msgstr ""
"Aktivitetsbeskrivning och förlopp kan redigeras genom att använda den "
"sammanhangsberoende menyn."

