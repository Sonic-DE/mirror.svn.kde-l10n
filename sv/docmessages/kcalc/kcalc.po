#~ msgid "&kcalc; is a scientific calculator for &kde;"
#~ msgstr "Miniräknaren är en vetenskaplig räknare för &kde;"

#~ msgid "This document describes &kcalc; version 2.13."
#~ msgstr "Det här dokumentet beskriver Miniräknare version 2.13."

#~ msgid "How to enable long double precision for &kcalc;"
#~ msgstr "Hur man aktiverar precisionen long double för Miniräknaren"

#~ msgid ""
#~ "If your machine supports the C data type <type>long double</type> and if "
#~ "you have a working libc you can enable <type>long double</type> precision "
#~ "for &kcalc;."
#~ msgstr ""
#~ "Om datorn stöder datatypen <type>long double</type> i C, och om det finns "
#~ "ett fungerande libc kan man aktivera precisionen <type>long double</type> "
#~ "för Miniräknaren."

#~ msgid "Here is what to do:"
#~ msgstr "Här är vad man ska göra:"

#~ msgid ""
#~ "Check <filename>config-kcalc.h</filename> and see whether HAVE&lowbar;"
#~ "LONG&lowbar;DOUBLE is defined, &ie; you should be able to locate a line "
#~ "saying:"
#~ msgstr ""
#~ "Kontrollera <filename>config-kcalc.h</filename> och se om HAVE&lowbar;"
#~ "LONG&lowbar;DOUBLE är definierad, dvs. du bör hitta en rad som lyder:"

#~ msgid "#define HAVE_LONG_DOUBLE 1"
#~ msgstr "#define HAVE_LONG_DOUBLE 1"

#~ msgid ""
#~ "If you cannot find such a line your system doesn't support long double "
#~ "IEEE precision."
#~ msgstr ""
#~ "Om du inte hittar en sådan rad, stöder inte systemet precisionen IEEE "
#~ "long double."

#~ msgid ""
#~ "Edit the files <filename class=\"headerfile\">kcalctype.h</filename>, "
#~ "<filename>configdlg.cpp</filename>, <filename>kcalc.cpp</filename> and "
#~ "<filename>kcalc&lowbar;core.cpp</filename> and remove the lines:"
#~ msgstr ""
#~ "Redigera filerna <filename class=\"headerfile\">kcalctype.h</filename>, "
#~ "<filename>configdlg.cpp</filename>, <filename>kcalc.cpp</filename> och "
#~ "<filename>kcalc&lowbar;core.cpp</filename> och ta bort raderna:"

#~ msgid ""
#~ "#ifdef HAVE_LONG_DOUBLE\n"
#~ "#undef HAVE_LONG_DOUBLE\n"
#~ "#endif"
#~ msgstr ""
#~ "#ifdef HAVE_LONG_DOUBLE\n"
#~ "#undef HAVE_LONG_DOUBLE\n"
#~ "#endif"

