#. Tag: title
#: commands.docbook:3
#, no-c-format
msgid "Command Reference"
msgstr "Kommandoreferens"

#. Tag: title
#: commands.docbook:6
#, no-c-format
msgid "Menu Items"
msgstr "Menyalternativ"

#. Tag: para
#: commands.docbook:8
#, no-c-format
msgid "A brief overview of some special menu items in &kcalc;:"
msgstr ""
"En kortfattad översikt av några speciella menyalternativ i Miniräknare:"

#. Tag: menuchoice
#: commands.docbook:12
#, no-c-format
msgid "<guimenu>Constants</guimenu> <guimenuitem>Mathematics</guimenuitem>"
msgstr "<guimenu>Konstanter</guimenu> <guimenuitem>Matematik</guimenuitem>"

#. Tag: action
#: commands.docbook:16
#, no-c-format
msgid "Display Pi, Euler Number or Golden Ratio."
msgstr "Visa pi, Eulers tal eller gyllene snittet."

#. Tag: menuchoice
#: commands.docbook:21
#, no-c-format
msgid ""
"<guimenu>Constants</guimenu> <guimenuitem>Electromagnetism</guimenuitem>"
msgstr ""
"<guimenu>Konstanter</guimenu> <guimenuitem>Elektromagnetism</guimenuitem>"

#. Tag: action
#: commands.docbook:25
#, no-c-format
msgid ""
"Display Light Speed, Elementary Charge, Impedance of Vacuum, Permeability of "
"Vacuum or Permittivity of Vacuum."
msgstr ""
"Visa ljushastigheten, elementarladdningen, impedansen i vakuum, "
"permeabiliteten i vakuum eller kapacitiviteten i vakuum."

#. Tag: menuchoice
#: commands.docbook:31
#, no-c-format
msgid ""
"<guimenu>Constants</guimenu> <guimenuitem>Atomic &amp; Nuclear</guimenuitem>"
msgstr ""
"<guimenu>Konstanter</guimenu> <guimenuitem>Atomer och kärnfysik</guimenuitem>"

#. Tag: action
#: commands.docbook:35
#, no-c-format
msgid ""
"Display Planck's Constant, Elementary Charge or Fine-Structure Constant."
msgstr ""
"Visa Plancks konstant, elementarladdningen eller finstrukturkonstanten."

#. Tag: menuchoice
#: commands.docbook:41
#, no-c-format
msgid "<guimenu>Constants</guimenu> <guimenuitem>Thermodynamics</guimenuitem>"
msgstr "<guimenu>Konstanter</guimenu> <guimenuitem>Termodynamik</guimenuitem>"

#. Tag: action
#: commands.docbook:45
#, no-c-format
msgid ""
"Display Boltzmann Constant, Atomic Mass Unit, Molar Gas Constant, Stefan-"
"Boltzmann Constant or Avogadro's Number."
msgstr ""
"Visa Boltzmanns konstant, atommassenheten, allmänna gaskonstanten, Stefan-"
"Boltzmanns konstant eller Avogadros tal."

#. Tag: menuchoice
#: commands.docbook:51
#, no-c-format
msgid "<guimenu>Constants</guimenu> <guimenuitem>Gravitation</guimenuitem>"
msgstr "<guimenu>Konstanter</guimenu> <guimenuitem>Gravitation</guimenuitem>"

#. Tag: para
#: commands.docbook:55
#, no-c-format
msgid "Display Constant of Gravitation or Earth Acceleration."
msgstr "Visa gravitationskonstanten eller jordaccelerationen."

#. Tag: menuchoice
#: commands.docbook:60
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Simple Mode</guimenuitem>"
msgstr ""
"<guimenu>Inställningar</guimenu> <guimenuitem>Enkelt läge</guimenuitem>"

#. Tag: action
#: commands.docbook:64
#, no-c-format
msgid "Displays the simple math buttons."
msgstr "Visar de enkla matematikknapparna."

#. Tag: menuchoice
#: commands.docbook:69
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Science Mode</guimenuitem>"
msgstr ""
"<guimenu>Inställningar</guimenu> <guimenuitem>Vetenskapligt läge</"
"guimenuitem>"

#. Tag: action
#: commands.docbook:73
#, no-c-format
msgid "Displays trigonometric and science buttons."
msgstr "Visar trigonometriska och vetenskapliga knappar."

#. Tag: menuchoice
#: commands.docbook:78
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Statistic Mode</guimenuitem>"
msgstr ""
"<guimenu>Inställningar</guimenu> <guimenuitem>Statistiskläge</guimenuitem>"

#. Tag: action
#: commands.docbook:82
#, no-c-format
msgid "Displays <link linkend=\"statistical-mode\">statistic buttons.</link>"
msgstr "Visar <link linkend=\"statistical-mode\">statistikknappar.</link>"

#. Tag: menuchoice
#: commands.docbook:88
#, no-c-format
msgid ""
"<guimenu>Settings</guimenu> <guimenuitem>Numeral System Mode</guimenuitem>"
msgstr ""
"<guimenu>Inställningar</guimenu> <guimenuitem>Nummersystemläge</guimenuitem>"

#. Tag: action
#: commands.docbook:92
#, no-c-format
msgid ""
"Displays <link linkend=\"and-or-xor\">logic buttons</link> and allows "
"changing the numeral system."
msgstr ""
"Visar <link linkend=\"and-or-xor\">logiska knappar</link> och tillåter att "
"nummersystemet ändras."

#. Tag: menuchoice
#: commands.docbook:98
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Show History</guimenuitem>"
msgstr ""
"<guimenu>Inställningar</guimenu> <guimenuitem>Visa historik</guimenuitem>"

#. Tag: action
#: commands.docbook:102
#, no-c-format
msgid "Display the history."
msgstr "Visa historiken."

#. Tag: menuchoice
#: commands.docbook:107
#, no-c-format
msgid ""
"<guimenu>Settings</guimenu> <guimenuitem>Constants Buttons</guimenuitem>"
msgstr ""
"<guimenu>Inställningar</guimenu> <guimenuitem>Konstantknappar</guimenuitem>"

#. Tag: action
#: commands.docbook:111
#, no-c-format
msgid ""
"Display constants buttons. They are available in <link linkend=\"science-mode"
"\">science mode</link> and <link linkend=\"statistical-mode\">statistic "
"mode</link>."
msgstr ""
"Visar konstantknappar. De är tillgängliga i <link linkend=\"science-mode"
"\">Vetenskapligt läge</link> och <link linkend=\"statistical-mode"
"\">Statistiskläge</link>."

#. Tag: menuchoice
#: commands.docbook:117
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Show Bit Edit</guimenuitem>"
msgstr ""
"<guimenu>Inställningar</guimenu> <guimenuitem>Visa bitredigering</"
"guimenuitem>"

#. Tag: action
#: commands.docbook:121
#, no-c-format
msgid ""
"Displays a bit edit field. Click on a bit to toggle it. Only available in "
"<link linkend=\"numeral-system-mode\">numeral system mode</link>."
msgstr ""
"Visar ett bitredigeringsfält. Klicka på en bit för att ändra den. Bara "
"tillgängligt i <link linkend=\"numeral-system-mode\">Nummersystemläge</link>."

#. Tag: para
#: commands.docbook:128
#, no-c-format
msgid ""
"Additionally &kcalc; has the common <guimenu>File</guimenu>, <guimenu>Edit</"
"guimenu>, <guimenu>Settings</guimenu> and <guimenu>Help</guimenu> menu "
"items, for more information read the sections about the <ulink url=\"help:/"
"fundamentals/menus.html\">Menus</ulink> in the &kde; Fundamentals."
msgstr ""
"Dessutom har Miniräknare de vanliga menyalternativen <guimenu>Arkiv</"
"guimenu>, <guimenu>Redigera</guimenu>, <guimenu>Inställningar</guimenu> och "
"<guimenu>Hjälp</guimenu>. För mer information, läs avsnitten om <ulink url="
"\"help:/fundamentals/menus.html\">menyer</ulink> i &kde;:s Grunder."

