#~ msgid "Text Area Background"
#~ msgstr "Textområdets bakgrund"

#~ msgid "Normal text"
#~ msgstr "Normal text"

#~ msgid ""
#~ "This is the default background for the editor area, it will be the "
#~ "dominant color on the editor area."
#~ msgstr ""
#~ "Det här är förvald bakgrund för redigeringsområdet. Det kommer att vara "
#~ "den dominerande färgen i redigeringsområdet."

#~ msgid "Selected text"
#~ msgstr "Markerad text"

#~ msgid ""
#~ "This is the background for selected text. The default is the global "
#~ "selection color, as set in your &kde; color preferences."
#~ msgstr ""
#~ "Det här är bakgrunden för markerad text. Förvalt värde är den globala "
#~ "markeringsfärgen, som är inställd i färginställningarna i &kde;."

#~ msgid "Current line"
