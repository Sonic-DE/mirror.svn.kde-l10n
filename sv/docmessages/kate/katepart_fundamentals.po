#~ "till exempel bokmärkesmarkeringar."

#~ msgid "Show line numbers"
#~ msgstr "Visa radnummer"

#~ msgid "If this is checked, you will see line numbers on the left hand side."
#~ msgstr "Om det här är markerat, ser du radnummer till vänster."

#~ msgid "Show scrollbar marks"
#~ msgstr "Visa rullningslistmarkeringar"

