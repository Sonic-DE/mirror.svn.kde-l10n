msgstr "Verktygsvyn Anropsstack i &gdb;"

#. Tag: phrase
#: plugins.docbook:1873
#, no-c-format
msgid "The Call Stack tool view."
msgstr "Verktygsvyn Anropsstack."

#. Tag: para
#: plugins.docbook:1874
#, no-c-format
msgid "The &gdb; Plugin's <guilabel>Call Stack</guilabel> tool view."
msgstr ""
"Verktygsvyn <guilabel>Anropsstack</guilabel> i insticksprogrammet för &gdb;."

#. Tag: para
