#~ "returnerade intervallet är ogiltigt (se Range.isValid()) om "
#~ "textpositionen är efter ett radslut. Om det inte finns något ord vid den "
#~ "givna markörpositionen returneras ett tomt intervall."

#~ msgid ""
#~ "String document.charAt(<parameter>int <replaceable>line</replaceable></"
