#~ "    // 1,0 and 5,0 belongs to the same syntax highlighting system\n"
#~ "}"
#~ msgstr ""
#~ "if ( document.canComment( document.attribute(1,0), document."
#~ "attribute(5,0) ) ) {\n"
#~ "    // 1,0 och 5,0 hör till samma syntaxfärgläggningssystem\n"
#~ "}"

