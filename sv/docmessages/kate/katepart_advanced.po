#~ "replaceable></parameter>);"
#~ msgstr ""
#~ "Range document.wordRangeAt(<parameter>int <replaceable>rad</replaceable></"
#~ "parameter>, <parameter>int <replaceable>kolumn</replaceable></"
#~ "parameter>);\n"
#~ "Range document.wordRangeAt(<parameter>Cursor <replaceable>markör</"
#~ "replaceable></parameter>);"

#~ msgid ""
#~ "Return the range of the word at the given cursor position. The returned "
