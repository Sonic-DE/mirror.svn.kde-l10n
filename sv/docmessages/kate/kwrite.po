#. Tag: para
#: index.docbook:33
#, no-c-format
msgid ""
"&kwrite; is a text editor by &kde; allowing you to edit one file at the time "
"per window."
msgstr ""
"&kwrite; är en texteditor av &kde; som låter dig redigera en fil åt gången i "
"varje fönster."

#. Tag: keyword
#: index.docbook:37
#, no-c-format
msgid "<keyword>KDE</keyword>"
msgstr "<keyword>KDE</keyword>"

