#~ "\"><keycap>Meta</keycap><keycap>Print Screen</keycap></keycombo> tar en "
#~ "skärmbild av det aktiva fönstret och sparar i den förvalda katalogen att "
#~ "spara i utan att visa det grafiska användargränssnittet, medan att trycka "
#~ "på <keycombo action=\"simul\">&Shift;<keycap>Print Screen</keycap></"
#~ "keycombo> tar en skärmbild av hela skrivbordet och sparar den i den "
#~ "förvalda katalogen att spara i utan att visa det grafiska "
#~ "användargränssnittet."

