#. Tag: para
#: index.docbook:17
#, no-c-format
msgid ""
"The <emphasis>file</emphasis> protocol is used by all &kde; applications to "
"display locally available files."
msgstr ""
"Protokollet <emphasis>file</emphasis> används av alla &kde;-program för att "
"visa filer som är lokalt tillgängliga."

#. Tag: para
#: index.docbook:21
#, no-c-format
msgid ""
"Entering <userinput><command>file:/directoryname</command></userinput> in "
"&konqueror; lists the files of this folder."
msgstr ""
"Att skriva in <userinput><command>file:/katalognamn</command></userinput> i "
"&konqueror; listar filerna i katalogen."
