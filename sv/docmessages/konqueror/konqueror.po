msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>B</keycap></"
"keycombo></shortcut> <guimenu>Fönster</guimenu> <guimenuitem>Koppla loss "
"aktuell flik</guimenuitem>"

#. Tag: para
#: index.docbook:3448
#, no-c-format
msgid "Show the current tab page in a new instance of &konqueror;."
msgstr "Visa den aktuella fliksidan i en ny instans av &konqueror;."

#. Tag: menuchoice
#: index.docbook:3453
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>W</keycap></keycombo></"
