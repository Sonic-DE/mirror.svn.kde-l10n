"shortcut> <guimenu>Fönster</guimenu> <guimenuitem>Duplicera aktuell flik</"
"guimenuitem>"

#. Tag: para
#: index.docbook:3438
#, no-c-format
msgid "Open a duplicate tab page."
msgstr "Öppna en duplicerad fliksida."

#. Tag: menuchoice
#: index.docbook:3442
