#: index.docbook:106
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>N</keycap></keycombo> </"
"shortcut> <guimenu>Game</guimenu> <guimenuitem>Single Game</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>N</keycap></keycombo> </"
"shortcut> <guimenu>Spel</guimenu> <guimenuitem>Ensamt spel</guimenuitem>"

#. Tag: para
#: index.docbook:112
#, no-c-format
msgid "Starts a new single player game."
msgstr "Startar ett nytt spel för en ensam spelare."

#. Tag: menuchoice
#: index.docbook:116
#, no-c-format
msgid "<guimenu>Game</guimenu> <guimenuitem>Human vs AI</guimenuitem>"
msgstr "<guimenu>Spel</guimenu> <guimenuitem>Människa mot dator</guimenuitem>"

#. Tag: para
#: index.docbook:119
#, no-c-format
msgid ""
"Compare your skills with the AI and play against the computer using the same "
"sequence of falling blocks, where you have the first turn."
msgstr ""
"Jämför din skicklighet med datorn och spela mot den med samma följd av "
"fallande block, där du börjar."

#. Tag: menuchoice
#: index.docbook:124
#, no-c-format
msgid ""
"<shortcut> <keycap>P</keycap> </shortcut> <guimenu>Game</guimenu> "
"<guimenuitem>Pause</guimenuitem>"
