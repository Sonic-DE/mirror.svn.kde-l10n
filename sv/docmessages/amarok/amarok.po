#, no-c-format
msgid "Help Menu"
msgstr "Menyn Hjälp"

#. Tag: para
#: index.docbook:7798
#, no-c-format
msgid "Important information about &amarok; and KDE."
msgstr "Viktig information om &amarok; och KDE."

