#, no-c-format
msgid "Shortcuts are divided into two groups:"
msgstr "Genvägar delas in i två grupper:"

#. Tag: title
#: index.docbook:7920
#, no-c-format
msgid "Control from Console"
msgstr "Styr från en terminal"

#. Tag: para
#: index.docbook:7921
#, no-c-format
msgid ""
"To control &amarok; from the console, type <userinput>amarok --help-all</"
"userinput> for a current complete list of available commands."
msgstr ""
"För att styra &amarok; från en terminal, skriv <userinput>amarok --help-all</"
"userinput> för en fullständig lista över kommandon som för närvarande är "
"tillgängliga."

#. Tag: title
#: index.docbook:7923
#, no-c-format
msgid "KDE Global Shortcuts"
msgstr "KDE:s globala genvägar"

#. Tag: para
#: index.docbook:7924
#, no-c-format
