#: index.docbook:110
#, no-c-format
msgid ""
"<guilabel>Chance</guilabel>: Summarized value of all the dice currently on "
"display."
msgstr ""
"<guilabel>Chans</guilabel>: Summerat värde av alla tärningar som för "
"närvarande visas."

