msgstr ""
"<action>Ange eller ändra felkontrollkriterier och felvarningsmeddelanden för "
"markerade celler.</action> Se <link linkend=\"validcheck"
"\">Giltighetskontroll</link> för mer information."

#. Tag: menuchoice
#: commands.docbook:847
#, no-c-format
msgid "<guimenu>Data</guimenu> <guimenuitem>Goal Seek...</guimenuitem>"
msgstr "<guimenu>Data</guimenu> <guimenuitem>Målsök...</guimenuitem>"

