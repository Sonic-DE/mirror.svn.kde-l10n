#~ msgstr "<guimenu>Text</guimenu> <guisubmenu>Stil</guisubmenu>"

#~ msgid ""
#~ "Using this submenu, you can apply a style that you have previously "
#~ "defined to the currently selected text."
#~ msgstr ""
#~ "Med den här undermenyn kan du använda en stil som du tidigare har "
#~ "definierat för texten som för närvarande är markerad."

#~ msgid ""
#~ "<guimenu>Text</guimenu> <guimenuitem>Create Style From Selection</"
#~ "guimenuitem>"
#~ msgstr ""
#~ "<guimenu>Text</guimenu> <guimenuitem>Skapa stil från markering</"
#~ "guimenuitem>"

#~ msgid ""
#~ "Copy the properties of the currently selected text and save them as a "
