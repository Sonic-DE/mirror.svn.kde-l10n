#~ msgid "Template Manager"
#~ msgstr "Mallhantering"

#~ msgid ""
#~ "<action>Allows you to save the current slide as a template.</action> In "
#~ "future the template will be available for you to use to build slides "
#~ "with. Creating a template is further discussed in section <xref linkend="
#~ "\"creating-templates\"/>."
#~ msgstr ""
#~ "<action>Låter dig spara den aktuella bilden som en mall.</action> "
#~ "Hädanefter kommer mallen att vara tillgänglig för att använda att skapa "
#~ "bilder med. Att skapa en mall beskrivs i mer detalj i avsnittet <xref "
#~ "linkend=\"creating-templates\"/>."

#~ msgid ""
#~ "<guimenu>File</guimenu> <guimenuitem>Use Current Slide as Default "
#~ "Template</guimenuitem>"
#~ msgstr ""
#~ "<guimenu>Arkiv</guimenu> <guimenuitem>Använd aktuell stordiabild som "
#~ "förvald mall</guimenuitem>"

#~ msgid ""
#~ "<action>Sets the current slide as your default template</action>. "
#~ "Especially useful if you have created a template of your own to fit into "
#~ "corporate style guidelines, or if you just use a particular layout very "
#~ "often."
#~ msgstr ""
#~ "<action>Väljer den nuvarande bilden som den förvalda mallen</action>. "
#~ "Särskilt användbart om du har skapat en egen mall för att passa "
#~ "företagets stilguide, eller om du bara använder en viss layout särskilt "
#~ "ofta."

#~ msgid "<guimenu>Edit</guimenu> Menu"
#~ msgstr "Menyn <guimenu>Redigera</guimenu>"

#~ msgid "<guimenu>Edit</guimenu> <guimenuitem>Duplicate Slide</guimenuitem>"
#~ msgstr ""
#~ "<guimenu>Redigera</guimenu> <guimenuitem>Duplicera sida</guimenuitem>"

#~ msgid ""
#~ "<guimenu>Edit</guimenu> <guimenuitem>Duplicate Object...</guimenuitem>"
#~ msgstr ""
#~ "<guimenu>Redigera</guimenu> <guimenuitem>Duplicera objekt...</guimenuitem>"

#~ msgid ""
#~ "Create a duplicate of the currently selected object. A dialog will "
#~ "display allowing you to set some options for the duplicate, &eg; if it "
#~ "should be rotated, or scaled, or offset to a new position on the slide."
#~ msgstr ""
#~ "Skapa ett duplikat av objektet som för närvarande är markerat. En "
#~ "dialogruta visas, som låter dig ange några alternativ för duplikatet, t."
#~ "ex. om det ska roteras, skalas eller flyttas till en ny plats på sidan."

#~ msgid "<guimenu>View</guimenu> Menu"
#~ msgstr "Menyn <guimenu>Visa</guimenu>"

#~ msgid ""
#~ "<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>W</keycap></"
#~ "keycombo></shortcut> <guimenu>View</guimenu> <guimenuitem>Close All "
#~ "Views</guimenuitem>"
#~ msgstr ""
#~ "<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>W</keycap></"
#~ "keycombo></shortcut> <guimenu>Visa</guimenu> <guimenuitem>Stäng alla "
#~ "vyer</guimenuitem>"

#~ msgid ""
#~ "<action>Close all views on the presentation.</action> You will be given a "
#~ "chance to save any changes, or to cancel closing."
#~ msgstr ""
#~ "<action>Stänger alla vyer av presentationen.</action> Du får en möjlighet "
#~ "att spara eventuella ändringar, eller avbryta åtgärden."

#~ msgid "<guimenu>View</guimenu> <guimenuitem>Split View</guimenuitem>"
#~ msgstr "<guimenu>Visa</guimenu> <guimenuitem>Dela vy</guimenuitem>"

#~ msgid ""
#~ "<action>Splits the window into two (or more) views on the same "
#~ "presentation.</action> The default split is horizontal."
#~ msgstr ""
#~ "<action>Delar fönstret i två (eller flera) vyer av samma presentation.</"
#~ "action> Normalt delas fönstret horisontellt."

#~ msgid "<guimenu>View</guimenu> <guimenuitem>Remove View</guimenuitem>"
#~ msgstr "<guimenu>Visa</guimenu> <guimenuitem>Ta bort vy</guimenuitem>"

#~ msgid ""
#~ "<action>Close only the currently active view</action>. The presentation, "
#~ "and any other views you have open, remain open, and any changes you have "
#~ "made remain unsaved."
#~ msgstr ""
#~ "<action>Stäng bara vyn som för närvarande är aktiv</action>. "
#~ "Presentationen, och eventuella andra vyer som du har öppnat, förblir "
#~ "öppna, och eventuella ändringar du har gjort förblir osparade."

#~ msgid ""
#~ "<guimenu>View</guimenu> <guisubmenu>Splitter Orientation</guisubmenu>"
#~ msgstr ""
#~ "<guimenu>Visa</guimenu> <guisubmenu>Avdelarens orientering</guisubmenu>"

#~ msgid ""
#~ "<action>Toggle the split view</action> between <guimenuitem>Horizontal</"
#~ "guimenuitem> (the default) and <guimenuitem>Vertical</guimenuitem>."
#~ msgstr ""
#~ "<action>Växla den delade vyn</action> mellan <guimenuitem>Horisontell</"
#~ "guimenuitem> (normalvärdet) och <guimenuitem>Vertikal</guimenuitem>."

#~ msgid ""
#~ "<action>Toggle the display of the sidebar</action> where you can see an "
#~ "overview of all the slides in your presentation."
#~ msgstr ""
#~ "<action>Växla visning av sidopanelen</action> där du kan se en översikt "
#~ "av alla bilder i presentationen."

#~ msgid "<guimenu>View</guimenu> <guimenuitem>Show Notebar</guimenuitem>"
#~ msgstr ""
#~ "<guimenu>Visa</guimenu> <guimenuitem>Visa anteckningsrad</guimenuitem>"

#~ msgid ""
#~ "<action>Toggle the display of the notebar</action> where you can see an "
#~ "overview of all the notes in your presentation."
#~ msgstr ""
#~ "<action>Växla visning av anteckningsraden</action> där du kan se en "
#~ "översikt av alla anteckningar i presentationen."

#~ msgid "<guimenu>View</guimenu> <guimenuitem>Slide Master</guimenuitem>"
#~ msgstr "<guimenu>Visa</guimenu> <guimenuitem>Förlaga</guimenuitem>"

#~ msgid ""
#~ "<guimenu>View</guimenu> <guimenuitem>Formatting Characters</guimenuitem>"
#~ msgstr ""
#~ "<guimenu>Visa</guimenu> <guimenuitem>Formateringstecken</guimenuitem>"

#~ msgid ""
#~ "Show a visual representation of <quote>non-printing characters</quote>, "
#~ "such as tabs and paragraph markers. This can be a useful aid to precisely "
#~ "positioning text."
#~ msgstr ""
#~ "Visa en synlig representation av <quote>osynliga tecken</quote>, som "
#~ "tabulator och styckesmarkering. Det kan vara ett användbart hjälpmedel "
#~ "för att exakt placera text."

#~ msgid ""
#~ "This item can be toggled. If enabled, formatting characters are visible; "
#~ "if disabled, they are not."
#~ msgstr ""
#~ "Alternativet kan växlas. Om det är aktiverat, visas formateringstecken. "
#~ "Om det inte är aktiverat, visas de inte."

#~ msgid "<guimenu>View</guimenu> <guimenuitem>Guide Lines</guimenuitem>"
#~ msgstr "<guimenu>Visa</guimenu> <guimenuitem>Hjälplinjer</guimenuitem>"

#~ msgid "<guimenu>View</guimenu> <guimenuitem>Add Guide Line...</guimenuitem>"
#~ msgstr ""
#~ "<guimenu>Visa</guimenu> <guimenuitem>Lägg till hjälplinje...</guimenuitem>"

#~ msgid ""
#~ "Opens a dialog to select the <guilabel>Orientation</guilabel> "
#~ "(<guilabel>Horizontal</guilabel> or <guilabel>Vertical</guilabel>) and "
#~ "choose a <guilabel>Position:</guilabel>"
#~ msgstr ""
#~ "Öppnar en dialogruta för att välja <guilabel>Orientering</guilabel> "
#~ "(<guilabel>Horisontell</guilabel> eller <guilabel>Vertikal</guilabel>) "
#~ "och välja en <guilabel>Position</guilabel>"

#~ msgid "<guimenu>Insert</guimenu> Menu"
#~ msgstr "Menyn <guimenu>Infoga</guimenu>"

#~ msgid ""
#~ "<shortcut> <keycombo action=\"simul\">&Alt;&Shift;<keycap>C</keycap></"
#~ "keycombo> </shortcut> <guimenu>Insert</guimenu> <guimenuitem>Special "
#~ "Character...</guimenuitem>"
#~ msgstr ""
#~ "<shortcut><keycombo action=\"simul\"> &Alt;&Shift;<keycap>C</keycap></"
#~ "keycombo></shortcut> <guimenu>Infoga</guimenu> "
#~ "<guimenuitem>Specialtecken...</guimenuitem>"

#~ msgid ""
#~ "Insert a special character. This might be a character you don't have a "
#~ "key for on your keyboard layout, for instance &uuml; on a US Keyboard."
#~ msgstr ""
#~ "Infoga ett specialtecken. Det kan vara ett tecken som saknar en tangent i "
#~ "din tangentbordslayout, till exempel &uuml; på ett svenskt tangentbord."

#~ msgid "<guimenu>Insert</guimenu> <guimenuitem>Link...</guimenuitem>"
#~ msgstr "<guimenu>Infoga</guimenu> <guimenuitem>Länk...</guimenuitem>"

#~ msgid ""
#~ "Insert a hyperlink to a file, a website, or an email address. This "
#~ "enables these locations to be linked to directly from within active "
#~ "presentations, with resources being handled as appropriately by other "
#~ "applications installed on your system."
#~ msgstr ""
#~ "Infoga en hyperlänk till en fil, webbplats, eller en e-postadress. Detta "
#~ "möjliggör att platserna länkas direkt inne i en aktiv presentation, med "
#~ "resurser som hanteras på nödvändigt sätt av andra program som är "
#~ "installerade på systemet."

#~ msgid "<guimenu>Insert</guimenu> <guimenuitem>Comment...</guimenuitem>"
#~ msgstr "<guimenu>Infoga</guimenu> <guimenuitem>Kommentar...</guimenuitem>"

#~ msgid ""
#~ "Enter a small note that does not display during the real presentation. "
#~ "You might use this to comment on a colleague's text, or to leave a note "
#~ "for yourself about something to do later."
#~ msgstr ""
#~ "Skriv in en kort anmärkning som inte visas under själva presentationen. "
#~ "Du kan använda det för att kommentera en kollegas text, eller lämna en "
#~ "anmärkning åt dig själv om något du ska göra senare."

#~ msgid ""
#~ "<shortcut><keycap>F2</keycap></shortcut> <guimenu>Insert</guimenu> "
#~ "<guimenuitem>Slide...</guimenuitem>"
#~ msgstr ""
#~ "<shortcut><keycap>F2</keycap></shortcut> <guimenu>Infoga</guimenu> "
#~ "<guimenuitem>Sida...</guimenuitem>"

#~ msgid ""
#~ "<action>Add a new page to your presentation.</action> A dialog will open "
#~ "allowing you to choose a template, and whether to insert the new page "
#~ "before or after the currently selected page."
#~ msgstr ""
#~ "<action>Lägg till en ny sida i presentationen.</action> En dialogruta "
#~ "öppnas som låter dig välja en mall, och om den nya sidan ska infogas före "
#~ "eller efter den nuvarande sidan."

#~ msgid ""
#~ "<shortcut><keycap>F10</keycap></shortcut> <guimenu>Insert</"
#~ "guimenu><guimenuitem>Text</guimenuitem>"
#~ msgstr ""
#~ "<shortcut><keycap>F10</keycap></shortcut> <guimenu>Infoga</guimenu> "
#~ "<guimenuitem>Text</guimenuitem>"

#~ msgid ""
#~ "Add a new text object. Click and drag to create a frame where you wish "
#~ "the text to appear."
#~ msgstr ""
#~ "Lägg till ett nytt textobjekt. Klicka och dra för att skapa en ram där du "
#~ "vill att texten ska synas."

#~ msgid "<guimenu>Insert</guimenu> <guimenuitem>Chart</guimenuitem>"
#~ msgstr "<guimenu>Infoga</guimenu> <guimenuitem>Diagram</guimenuitem>"

#~ msgid ""
#~ "Insert a chart. Click and drag to define the size of the chart. Some "
#~ "default data will be displayed. Double click to edit the data and choose "
#~ "the type of chart to display, using the embedded &kchart; editor."
#~ msgstr ""
#~ "Infoga ett diagram. Klicka och dra för att ange diagrammets storlek. "
