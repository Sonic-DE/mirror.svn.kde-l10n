msgstr "Datum2"

#. Tag: seg
#: functions.docbook:1137
#, no-c-format
msgid "Method"
msgstr "Metod"

#. Tag: para
#: functions.docbook:1140
#, no-c-format
msgid "DAYS360(\"2/22/2002\"; \"4/21/2002\"; FALSE) returns 59"
msgstr "DAYS360(\"2002-02-22\"; \"2002-04-21\"; FALSE) returnerar 59"

