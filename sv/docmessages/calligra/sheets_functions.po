#: functions.docbook:5701
#, no-c-format
msgid "CEILING(x)"
msgstr "CEILING(x)"

#. Tag: seg
#: functions.docbook:5706 functions.docbook:6059
#, no-c-format
msgid "Significance (optional)"
msgstr "Signifikans (valfri)"

#. Tag: seg
#: functions.docbook:5707 functions.docbook:6060
#, no-c-format
msgid "Mode (optional)"
msgstr "Läge (valfritt)"

#. Tag: para
#: functions.docbook:5710
#, no-c-format
msgid "CEILING(12.5) equals 13"
msgstr "CEILING(12,5) är lika med 13"

