#: functions.docbook:4411
#, no-c-format
msgid "Price"
msgstr "Pris"

#. Tag: para
#: functions.docbook:3934
#, no-c-format
msgid ""
"ODDLYIELD(DATE(1990;6;1);DATE(1995;12;31);DATE(1990;1;1);3%;91;100;2) "
"returns 4.997775351"
msgstr ""
"ODDLYIELD(DATE(1990;6;1);DATE(1995;12;31);DATE(1990;1;1);3%;91;100;2) "
"returnerar 4,997775351"

#. Tag: member
#: functions.docbook:3938
#, no-c-format
msgid "<link linkend=\"ODDLPRICE\">ODDLPRICE</link>&nbsp;"
msgstr "<link linkend=\"ODDLPRICE\">ODDLPRICE</link>&nbsp;"

#. Tag: title
#: functions.docbook:3945
#, no-c-format
msgid "<title>PMT</title>"
msgstr "<title>PMT</title>"

#. Tag: para
#: functions.docbook:3946
#, no-c-format
msgid ""
"PMT returns the amount of payment for a loan based on a constant interest "
"rate and constant payments (each payment is equal amount)."
msgstr ""
"PMT returnerar storleken på betalningen för ett lån baserat på en konstant "
"räntesats och konstanta betalningar (varje betalning har samma belopp)."

#. Tag: para
#: functions.docbook:3951
#, no-c-format
msgid "PMT(rate; nper ; pv [; fv = 0 [; type = 0 ]] )"
msgstr "PMT(räntesats; aper ; nv [; fv = 0 [; typ = 0 ]] )"

#. Tag: seg
#: functions.docbook:3956
#, no-c-format
msgid "Number of periods (NPer)"
msgstr "Antal perioder (Aper)"

#. Tag: para
#: functions.docbook:3963
#, no-c-format
msgid "PMT(0.1; 4; 10000) equals -3154.71"
msgstr "PMT(0,1; 4; 10000) är lika med -3154,71"

#. Tag: title
#: functions.docbook:3977
#, no-c-format
msgid "PPMT"
msgstr "PPMT"

#. Tag: para
#: functions.docbook:3978
#, no-c-format
msgid ""
"PPMT calculates the amount of a payment of an annuity going towards "
"principal."
msgstr ""
"PPMT beräknar beloppet för en betalning under en period som gäller "
"amortering."

#. Tag: para
#: functions.docbook:3989
#, no-c-format
msgid "PPMT(Rate; Period; NPer; PV [; FV = 9 [; Type = 0 ]] )"
msgstr "PPMT(Räntesats; Period; APer; NV [; FV = 9 [; Typ = 0 ]] )"

#. Tag: para
#: functions.docbook:4001
#, no-c-format
msgid "PPMT(0.0875;1;36;5000;8000;1) equals -18.48"
msgstr "PPMT(0,0875;1;36;5000;8000;1) är lika med -18,48"

#. Tag: title
#: functions.docbook:4014
#, no-c-format
msgid "PRICEMAT"
msgstr "PRICEMAT"

#. Tag: para
#: functions.docbook:4015
#, no-c-format
msgid ""
"PRICEMAT Calculate the price per 100 currency units of face value of the "
"security that pays interest on the maturity date."
msgstr ""
"PRICEMAT beräkna priset per 100 valutaenheter nominellt värde för "
"värdepappret som betalar ränta vid förfallodatum."

#. Tag: para
#: functions.docbook:4016
#, no-c-format
msgid "Basis Calculation method"
msgstr "Basberäkningsmetod"

#. Tag: para
#: functions.docbook:4017
#, no-c-format
msgid "0 US method, 12 months, each month with 30 days"
msgstr ""
"0 Metod använd i Förenta staterna, 12 månader, varje månad med 30 dagar"

#. Tag: para
#: functions.docbook:4018
#, no-c-format
msgid "1 Actual number of days in year, actual number of days in months"
msgstr "1 Verkligt antal dagar under ett år, verkligt antal dagar i månader"

#. Tag: para
#: functions.docbook:4019
#, no-c-format
msgid "2 360 days in a year, actual number of days in months"
msgstr "2 360 dagar under ett år, verkligt antal dagar i månader"

#. Tag: para
#: functions.docbook:4020
#, no-c-format
msgid "4 365 days in a year, actual number of days in months"
msgstr "4 365 dagar under ett år, verkligt antal dagar i månader"

#. Tag: para
#: functions.docbook:4021
#, no-c-format
msgid "5 European method, 12 months, each month has 30 days"
msgstr "5 Europeisk metod, 12 månader, där varje månad har 30 dagar"

#. Tag: para
#: functions.docbook:4026
#, no-c-format
msgid "PRICEMAT(settlement; maturity; issue; rate; yield [; basis = 0 ] )"
msgstr ""
"PRICEMAT(avräkning; förfaller; utgåva; räntesats; avkastning [; bas = 0 ])"

