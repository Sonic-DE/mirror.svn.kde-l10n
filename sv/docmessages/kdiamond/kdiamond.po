#. Tag: para
#: index.docbook:180
#, no-c-format
msgid "There are five levels of difficulty:"
msgstr "Det finns fem svårighetsnivåer:"

#. Tag: para
#: index.docbook:182
#, no-c-format
msgid ""
"<guimenuitem>Very easy</guimenuitem>: 12 rows, 12 columns, 5 types of "
"diamonds."
msgstr ""
"<guimenuitem>Mycket lätt</guimenuitem>: 12 rader, 12 kolumner, 5 "
"diamanttyper."

#. Tag: para
#: index.docbook:183
#, no-c-format
msgid ""
"<guimenuitem>Easy</guimenuitem>: 10 rows, 10 columns, 5 types of diamonds."
msgstr ""
"<guimenuitem>Lätt</guimenuitem>: 10 rader, 10 kolumner, 5 diamanttyper."

#. Tag: para
#: index.docbook:184
#, no-c-format
msgid ""
"<guimenuitem>Medium</guimenuitem>: 8 rows, 8 columns, 5 types of diamonds."
msgstr ""
"<guimenuitem>Normal</guimenuitem>: 8 rader, 8 kolumner, 5 diamanttyper."

#. Tag: para
#: index.docbook:185
#, no-c-format
msgid ""
"<guimenuitem>Hard</guimenuitem>: 8 rows, 8 columns, 6 types of diamonds."
msgstr "<guimenuitem>Svår</guimenuitem>: 8 rader, 8 kolumner, 6 diamanttyper."

#. Tag: para
#: index.docbook:186
#, no-c-format
msgid ""
"<guimenuitem>Very hard</guimenuitem>: 8 rows, 8 columns, 7 types of diamonds."
msgstr ""
"<guimenuitem>Mycket svår</guimenuitem>: 8 rader, 8 kolumner, 7 diamanttyper."

#. Tag: menuchoice
#: index.docbook:192
#, no-c-format
