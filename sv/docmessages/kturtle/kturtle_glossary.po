msgstr "150,0,0"

#. Tag: userinput
#: glossary.docbook:127
#, no-c-format
msgid "0,255,0"
msgstr "0,255,0"

#. Tag: entry
#: glossary.docbook:127
#, no-c-format
msgid "green"
msgstr "grön"

#. Tag: userinput
#: glossary.docbook:128
#, no-c-format
msgid "0,0,255"
msgstr "0,0,255"

#. Tag: entry
#: glossary.docbook:128
#, no-c-format
msgid "blue"
msgstr "blå"

