"<guimenu>File</guimenu> <guimenuitem>Save As...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;&Shift;<keycap>S</keycap></keycombo> </shortcut> "
"<guimenu>Arkiv</guimenu> <guimenuitem>Spara som...</guimenuitem>"

#. Tag: para
#: using-kturtle.docbook:136
#, no-c-format
msgid "Saves the currently opened &turtlescript; file on a specified location."
msgstr ""
