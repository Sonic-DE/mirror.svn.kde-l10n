#, no-c-format
msgid "Prints the current code in the editor."
msgstr "Skriver ut aktuell kod i kodeditorn."

#. Tag: menuchoice
#: using-kturtle.docbook:165
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>Q</keycap></keycombo> </shortcut> "
"<guimenu>File</guimenu> <guimenuitem>Quit</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>Q</keycap></keycombo> </shortcut> "
"<guimenu>Arkiv</guimenu> <guimenuitem>Avsluta</guimenuitem>"

#. Tag: para
#: using-kturtle.docbook:172
#, no-c-format
msgid "Quits &kturtle;."
msgstr "Avslutar &kturtle;."

