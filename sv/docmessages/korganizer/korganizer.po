#~ msgid ""
#~ "Some to-dos require attachments. You can <guibutton>Add...</guibutton>, "
#~ "<guibutton>Edit...</guibutton>, <guibutton>Remove</guibutton>, and "
#~ "<guibutton>Show</guibutton> attachments. You can refer to the attachment "
