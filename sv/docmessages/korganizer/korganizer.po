msgstr "För mer information om åtgärden, se <xref linkend=\"timeline-view\"/>."

#. Tag: menuchoice
#: index.docbook:3078
#, no-c-format
msgid "<guimenu>View</guimenu> <guimenuitem>To-do List</guimenuitem>"
msgstr "<guimenu>Visa</guimenu> <guimenuitem>Uppgiftslista</guimenuitem>"

#. Tag: action
#: index.docbook:3082
#, no-c-format
msgid "Switch the display to the To-do List view."
msgstr "Byt visning till uppgiftslistan."

