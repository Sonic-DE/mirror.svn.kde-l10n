"For more information about this action, please refer to <xref linkend=\"todo-"
"view\"/>."
msgstr "För mer information om åtgärden, se <xref linkend=\"todo-view\"/>."

#. Tag: menuchoice
#: index.docbook:3090
#, no-c-format
msgid "<guimenu> View</guimenu><guimenuitem>Event List</guimenuitem>"
msgstr "<guimenu>Visa</guimenu> <guimenuitem>Händelselista</guimenuitem>"

#. Tag: action
