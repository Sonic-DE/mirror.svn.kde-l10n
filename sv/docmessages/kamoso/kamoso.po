#: index.docbook:162
#, no-c-format
msgid "&underFDL;"
msgstr "&underFDL;"

#~ msgid "2012-12-05"
#~ msgstr "2012-12-05"

#~ msgid "2.0.2 (&kde; SC 4.10)"
#~ msgstr "2.0.2 (&kde; SC 4.10)"

#~ msgid "Welcome to <application>Kamoso</application>!"
#~ msgstr "Välkommen till <application>Kamoso</application>!"

#~ msgid ""
#~ "On launching <application>Kamoso</application>, you are greeted with two "
#~ "groups of buttons on the left and right, and a button in the center."
#~ msgstr ""
#~ "När <application>Kamoso</application> startas hälsas du med två grupper "
#~ "av knappar till vänster och till höger, samt en knapp i mitten."

#~ msgid ""
#~ "The central button helps you to click a picture! Go ahead and try it now! "
#~ "SMILE!"
#~ msgstr ""
#~ "Knappen i mitten hjälper dig att ta en bild. Sätt i gång och prova den "
#~ "nu. OMELETT!"

#~ msgid ""
#~ "<application>Kamoso</application> will give you a 3 second heads up so "
#~ "you can pose for your picture, and ask you to smile right before clicking!"
#~ msgstr ""
#~ "<application>Kamoso</application> ger dig tre sekunders varning, så att "
#~ "du kan posera för bilden, och ber dig att le precis innan klicket."

#~ msgid ""
#~ "If you click on the second button from the left, <application>Kamoso</"
#~ "application> changes to burst-mode. <application>Kamoso</application> "
#~ "will keep clicking pictures rapidly till you don't click on the center "
#~ "button and tell it to stop. The pictures line up in chronological order "
#~ "on the bottom, and you can view them by double-clicking them. "
#~ "Alternatively, you could right click and choose <guilabel>Open</guilabel> "
#~ "to view the pictures too! If you aren't happy with any of the pictures, "
#~ "just right click and select <guilabel>Trash</guilabel> to delete that "
#~ "particular picture."
#~ msgstr ""
#~ "Om du klickar på den andra knappen från vänster, byter "
#~ "<application>Kamoso</application> till snabbläge. <application>Kamoso</"
#~ "application> fortsätter ta bilder snabbt ända tills du inte klickar på "
#~ "knappen i mitten och talar om att det ska sluta. Bilderna radas upp i "
#~ "tidsordning längst ner, och du kan titta på dem genom att dubbelklicka. "
#~ "Som alternativ kan du också högerklicka och välja <guilabel>Öppna</"
#~ "guilabel> för att titta på bilderna. OM du inte är nöjd med någon av "
#~ "bilderna, högerklicka bara och välj <guilabel>Till papperskorg</guilabel> "
#~ "för att ta bort just den bilden."

#~ msgid "Upload image to Facebook"
#~ msgstr "Ladda upp bild till Facebook"

#~ msgid ""
#~ "If you feel your newly-clicked pictures must be uploaded to your Facebook "
#~ "profile, just right click on the picture and select <guilabel>Facebook "
#~ "Import/Export</guilabel>. A window will open up on your browser asking "
#~ "you to grant permission to <application>Kamoso</application>. Once you do "
#~ "this, upload away!"
#~ msgstr ""
#~ "Om du tycker att den nytagna bilden måste laddas upp till din profil på "
#~ "Facebook, högerklicka bara på bilden och välj <guilabel>Facebook import "
#~ "och export</guilabel>. Ett fönster öppnas i webbläsaren som ber dig att "
#~ "ge rättigheter till <application>Kamoso</application>. När du väl gjort "
#~ "det, kör igång och ladda upp."

#~ msgid ""
#~ "You need to have an account on Facebook to upload the picture you made"
#~ msgstr "Du måste ha ett konto på Facebook för att ladda upp bilden du tog."

#~ msgid ""
#~ "If you want to avoid all the right clicks, click on the second button on "
#~ "the right side and you'll be provided with the same options as when you "
#~ "right click."
#~ msgstr ""
#~ "Om du vill undvika alla högerklick, klicka på den andra knappen på höger "
#~ "sida så får du samma alternativ som när du högerklickar."

#~ msgid "Upload video to YouTube"
#~ msgstr "Ladda upp video till YouTube"

#~ msgid ""
#~ "<application>Kamoso</application> also allows you to capture videos! By "
#~ "clicking on the red button on the left, you change to video mode. Click "
#~ "on the central button to shoot your video! Right click on the video and "
#~ "select <guilabel>YouTube</guilabel> to upload it to YouTube."
#~ msgstr ""
#~ "<application>Kamoso</application> låter dig också spela in video. Genom "
#~ "att klicka på den röda knappen till vänster, byter du till videoläget. "
#~ "Klicka på knappen i mitten för att spela in en video. Högerklicka på "
#~ "videon och välj <guilabel>YouTube</guilabel> för att ladda upp den till "
#~ "YouTube."

#~ msgid ""
#~ "You need to have an account on YouTube and provide <application>Kamoso</"
#~ "application> an access with your username and password – don't worry, "
#~ "it's totally safe!"
#~ msgstr ""
#~ "Du måste ha ett konto på YouTube och tillhandahålla åtkomst med "
#~ "användarnamn och lösenord för <application>Kamoso</application>. Var inte "
#~ "orolig, det är fullständigt säkert."

#~ msgid ""
#~ "If you feel your picture quality isn't optimal, click on the button on "
#~ "the extreme right and select <guilabel>Settings</guilabel>. This is the "
#~ "settings panel."
#~ msgstr ""
#~ "Om du tycker att bildkvaliteten inte är optimal, klicka på knappen längst "
#~ "bort till höger och välj <guilabel>Inställningar</guilabel>. Detta är "
#~ "inställningsrutan."

#~ msgid ""
#~ "If you want to change the time before <application>Kamoso</application> "
#~ "clicks your picture, navigate to <guilabel>Photo settings</guilabel>."
#~ msgstr ""
#~ "Om du vill ändra tiden innan <application>Kamoso</application> tar "
#~ "bilder, gå till <guilabel>Fotoinställningar</guilabel>."

#~ msgid ""
#~ "If you're a really technical user, scroll over to the <guilabel>Video "
#~ "settings</guilabel> and there you can adjust settings like brightness, "
#~ "contrast, &etc;"
#~ msgstr ""
#~ "Om du är en riktigt teknisk användare, gå vidare till "
#~ "<guilabel>Videoinställningar</guilabel>, för att justera inställningar "
#~ "som ljusstyrka, kontrast, etc."

#~ msgid "The End"
#~ msgstr "Slutet"

#~ msgid ""
#~ "Well, we've reached the end of our tutorial. I hope your queries have "
#~ "been adequately answered!"
#~ msgstr ""
#~ "Ja, nu har vi nått slutet på vår handledning. Jag hoppas att dina frågor "
#~ "har besvarats tillfredsställande."

#~ msgid "Enjoy using <application>Kamoso</application>!"
#~ msgstr "Ha det så kul när du använder <application>Kamoso</application>!"
