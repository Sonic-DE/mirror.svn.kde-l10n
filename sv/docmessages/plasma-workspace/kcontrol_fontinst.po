#, no-c-format
msgid "2021-04-09"
msgstr "2021-04-09"

#. Tag: releaseinfo
#: index.docbook:18
#, no-c-format
msgid "Plasma 5.20"
msgstr "Plasma 5.20"

#. Tag: keyword
#: index.docbook:21
#, no-c-format
