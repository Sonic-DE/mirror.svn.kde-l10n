#: index.docbook:1193
#, no-c-format
msgid "&Ctrl;&Alt;<keysym>Right</keysym>"
msgstr "&Ctrl;&Alt;<keysym>Högerpil</keysym>"

#. Tag: entry
#: index.docbook:1194
#, no-c-format
msgid "Move Tab Right"
msgstr "Flytta flik åt höger"

