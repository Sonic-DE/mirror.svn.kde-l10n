#: index.docbook:1831
#, no-c-format
msgid "Further Reading"
msgstr "Ytterligare läsning"

#. Tag: para
#: index.docbook:1832
#, no-c-format
msgid ""
"For more information on escape sequences and control characters, check the "
"following documentation:"
msgstr ""
"För mer information om escape-sekvenser och kontrolltecken, se följande "
"dokumentation:"

#. Tag: ulink
#: index.docbook:1835
#, no-c-format
msgid "The VT100 user guide"
msgstr "VT100 användarguide"

#. Tag: ulink
#: index.docbook:1838
#, no-c-format
msgid "The VT102 user guide"
msgstr "VT102 användarguide"

