#, no-c-format
msgid "<phrase>Menu for importing source code in &umbrello;</phrase>"
msgstr "<phrase>Meny för att importera källkod till &umbrello;</phrase>"

#. Tag: para
#: code_import_and_generation.docbook:164
#, no-c-format
msgid "<para>Menu for importing source code in &umbrello;</para>"
msgstr "<para>Meny för att importera källkod till &umbrello;</para>"
