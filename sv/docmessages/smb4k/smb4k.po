#~ msgid "interfaces = 192.168.1.1/24 127.0.0.1/8"
#~ msgstr "interfaces = 192.168.1.1/24 127.0.0.1/8"

#~ msgid "interfaces = eth0 lo"
#~ msgstr "interfaces = eth0 lo"

#~ msgid ""
