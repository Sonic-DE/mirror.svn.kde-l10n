#, no-c-format
msgid ""
"<guimenu>Settings</guimenu> <guisubmenu>Dock Widgets</guisubmenu> "
"<guimenuitem>Mounted Shares</guimenuitem>"
msgstr ""
"<guimenu>Inställningar</guimenu> <guisubmenu>Dockningskomponenter</"
"guisubmenu> <guimenuitem>Monterade resurser</guimenuitem>"

#. Tag: para
#: index.docbook:4623
