#~ msgid "Generic options:"
#~ msgstr "Allmänna väljare:"

#~ msgid "--help"
#~ msgstr "--help"

#~ msgid "Show help about options"
#~ msgstr "Visa hjälp om väljare"

#~ msgid "--help-qt"
#~ msgstr "--help-qt"

#~ msgid "Show Qt specific options"
#~ msgstr "Visa Qt-specifika väljare"

#~ msgid "--help-kde"
#~ msgstr "--help-kde"

#~ msgid "Show KDE specific options"
#~ msgstr "Visa KDE-specifika väljare"

#~ msgid "--help-all"
#~ msgstr "--help-all"

#~ msgid "Show all options"
#~ msgstr "Visa alla väljare"

#~ msgid "Show author information"
#~ msgstr "Visa information om upphovsman"

#~ msgid "-v, --version"
#~ msgstr "-v, --version"

#~ msgid "Show version information"
#~ msgstr "Visa versionsinformation"

#~ msgid "--license"
#~ msgstr "--license"

#~ msgid "Show license information"
#~ msgstr "Visa licensinformation"

#~ msgid "<option>--</option>"
#~ msgstr "<option>--</option>"

#~ msgid "End of options"
#~ msgstr "Slut på väljare"

#~ msgid "KDE options:"
#~ msgstr "KDE-väljare:"

#~ msgid "--caption &lt;caption&gt;"
#~ msgstr "--caption &lt;titel&gt;"

#~ msgid "Use 'caption' as name in the titlebar"
#~ msgstr "Använd \"titel\" som namn i namnlisten"

#~ msgid "--icon &lt;icon&gt;"
#~ msgstr "--icon &lt;ikon&gt;"

#~ msgid "Use 'icon' as the application icon"
#~ msgstr "Använd \"ikon\" som programmets ikon"

#~ msgid "--config &lt;filename&gt;"
#~ msgstr "--config &lt;filnamn&gt;"

#~ msgid "Use alternative configuration file"
#~ msgstr "Använd alternativ inställningsfil"

#~ msgid "--nocrashhandler"
#~ msgstr "--nocrashhandler"

#~ msgid "Disable crash handler, to get core dumps"
#~ msgstr "Inaktivera kraschhanteraren, för att få minnesdumpar"

#~ msgid "--waitforwm"
#~ msgstr "--waitforwm"

#~ msgid "Waits for a WM_NET compatible windowmanager"
#~ msgstr "Väntar på en WM_NET-kompatibel fönsterhanterare"

#~ msgid "--style &lt;style&gt;"
#~ msgstr "--style &lt;stil&gt;"

#~ msgid "sets the application GUI style"
#~ msgstr "anger programmets grafiska gränssnitt"

#~ msgid "--geometry &lt;geometry&gt;"
#~ msgstr "--geometry &lt;geometri&gt;"

#~ msgid ""
#~ "sets the client geometry of the main widget - see man X for the argument "
#~ "format"
#~ msgstr ""
#~ "ställer in klientgeometrin för den grafiska huvudkomponenten. Se man X "
#~ "för argumentformatet"

#~ msgid "Qt options:"
#~ msgstr "Qt-väljare:"

#~ msgid "--display &lt;displayname&gt;"
#~ msgstr "--display &lt;skärmnamn&gt;"

#~ msgid "Use the X-server display 'displayname'"
#~ msgstr "Använd skärmen \"skärmnamn\" på X-servern"

#~ msgid "--session &lt;sessionId&gt;"
#~ msgstr "--session &lt;sessions-id&gt;"

#~ msgid "Restore the application for the given 'sessionId'"
#~ msgstr "Återställ programmet för givet \"sessionsid\""

#~ msgid "--cmap"
#~ msgstr "--cmap"

#~ msgid ""
#~ "Causes the application to install a private color map on an 8-bit display"
#~ msgstr ""
#~ "Gör att programmet installerar en privat färgavbildning på en 8-"
#~ "bitarsskärm"

#~ msgid "--ncols &lt;count&gt;"
#~ msgstr "--ncols &lt;antal&gt;"

#~ msgid ""
#~ "Limits the number of colors allocated in the color cube on an 8-bit "
#~ "display, if the application is using the QApplication::ManyColor color "
#~ "specification"
#~ msgstr ""
#~ "Begränsar antal färger som används i färgkuben på en 8-bitarsskärm, om "
#~ "programmet använder färgspecifikationen QApplication::ManyColor"

#~ msgid "--nograb"
#~ msgstr "--nograb"

#~ msgid "tells Qt to never grab the mouse or the keyboard"
#~ msgstr "anger att Qt aldrig ska ta över musen eller tangentbordet"

#~ msgid "--dograb"
#~ msgstr "--dograb"

#~ msgid ""
#~ "running under a debugger can cause an implicit -nograb, use -dograb to "
#~ "override"
#~ msgstr ""
#~ "att köra inne i en avlusare kan ge upphov till en underförstådd väljare "
#~ "<option>-nograb</option>, använd <option>-dograb</option> för att "
#~ "överskrida den."

#~ msgid "--sync"
#~ msgstr "--sync"

#~ msgid "switches to synchronous mode for debugging"
#~ msgstr "byter till synkront läge för felsökning"

#~ msgid "--fn, --font &lt;fontname&gt;"
#~ msgstr "--fn, --font &lt;teckensnitt&gt;"

#~ msgid "defines the application font"
#~ msgstr "definierar programmets teckensnitt"

#~ msgid "--bg, --background &lt;color&gt;"
#~ msgstr "--bg, --background &lt;färg&gt;"

#~ msgid ""
#~ "sets the default background color and an application palette (light and "
#~ "dark shades are calculated)"
#~ msgstr ""
#~ "ställer in förvald bakgrundsfärg och en programpalett (ljusa och mörka "
#~ "nyanser beräknas)"

#~ msgid "--fg, --foreground &lt;color&gt;"
#~ msgstr "--fg, --foreground &lt;färg&gt;"

#~ msgid "sets the default foreground color"
#~ msgstr "anger den förvalda förgrundsfärgen"

#~ msgid "--btn, --button &lt;color&gt;"
#~ msgstr "--btn, --button &lt;färg&gt;"

#~ msgid "sets the default button color"
#~ msgstr "anger den förvalda knappfärgen"

#~ msgid "--name &lt;name&gt;"
#~ msgstr "--name &lt;namn&gt;"

#~ msgid "sets the application name"
#~ msgstr "anger programmets namn"

#~ msgid "--title &lt;title&gt;"
#~ msgstr "--title &lt;titel&gt;"

#~ msgid "sets the application title (caption)"
#~ msgstr "anger programmets titel (rubrik)"

#~ msgid "--visual TrueColor"
#~ msgstr "--visual TrueColor"

#~ msgid "forces the application to use a TrueColor visual on an 8-bit display"
#~ msgstr "tvingar programmet att använda TrueColor på en 8-bitarsskärm"

#~ msgid "--inputstyle &lt;inputstyle&gt;"
#~ msgstr "--inputstyle &lt;inmatningsstil&gt;"

#~ msgid ""
#~ "sets XIM (X Input Method) input style. Possible values are onthespot, "
#~ "overthespot, offthespot and root"
#~ msgstr ""
#~ "väljer inmatningsstilen XIM (X-inmatningsmetod). Möjliga värden är "
#~ "onthespot, overthespot, offthespot och root"

#~ msgid "--im &lt;XIM server&gt;"
#~ msgstr "--im &lt;XIM-server&gt;"

#~ msgid "set XIM server"
#~ msgstr "ange XIM-server"

#~ msgid "--noxim"
#~ msgstr "--noxim"

#~ msgid "disable XIM"
#~ msgstr "inaktivera XIM"

#~ msgid "--reverse"
#~ msgstr "--reverse"

#~ msgid "mirrors the whole layout of widgets"
#~ msgstr "speglar hela layouten på komponenter"

#~ msgid "--stylesheet"
#~ msgstr "--stylesheet"

#~ msgid ""
#~ "&lt;file.qss&gt; applies the Qt stylesheet to the application widgets"
#~ msgstr ""
#~ "&lt;fil.qss&gt; använder Qt stilmallen för programmets grafiska "
#~ "komponenter"

