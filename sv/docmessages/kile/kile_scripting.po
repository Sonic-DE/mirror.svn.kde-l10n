#, no-c-format
msgid ""
"int document.nextNonSpaceColumn(<parameter>int <replaceable>line</"
"replaceable></parameter>, <parameter>int <replaceable>column</replaceable></"
"parameter>);\n"
"int document.nextNonSpaceColumn(<parameter>Cursor <replaceable>cursor</"
