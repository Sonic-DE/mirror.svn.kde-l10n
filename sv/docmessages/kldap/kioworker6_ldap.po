#. Tag: para
#: index.docbook:17
#, no-c-format
msgid ""
"<acronym>ldap</acronym> is the lightweight directory access protocol. It "
"provides access to an X.500 directory, or to a stand-alone <acronym>LDAP</"
"acronym> server."
msgstr ""
"<acronym>ldap</acronym> är det lättviktiga katalogåtkomstprotokollet. Det "
"ger möjlighet att komma åt en X.500-katalog, eller en ensam <acronym>LDAP</"
"acronym>-server."

#. Tag: para
#: index.docbook:21
#, no-c-format
msgid "You can use the ldap KIO worker as follows:"
msgstr "Du kan använda I/O-arbetaren ldap som följer:"

#. Tag: para
#: index.docbook:23
#, no-c-format
msgid ""
"<userinput>ldap://host:port/ou=People,o=where,c=de??sub</userinput> for a "
"subtree-query"
msgstr ""
"<userinput>ldap://värddator:port/ou=People,o=where,c=de??sub</userinput> får "
"en delträdsförfrågan"

#. Tag: para
#: index.docbook:26
#, no-c-format
msgid ""
"or <userinput>ldap://host:port/cn=MM,ou=People,o=where,c=de??base</"
"userinput> for a complete branch."
msgstr ""
"eller <userinput>ldap://värddator:port/cn=MM,ou=People,o=where,c=de??bas</"
"userinput> får en fullständig gren."
