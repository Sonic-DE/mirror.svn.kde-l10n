#. Tag: title
#: diskusage.docbook:8
#, no-c-format
msgid "<title>Disk Usage</title>"
msgstr "<title>Diskanvändning</title>"

#. Tag: primary
#: diskusage.docbook:10
#, no-c-format
msgid "<primary>Disk Usage</primary>"
msgstr "<primary>Diskanvändning</primary>"

#. Tag: para
#: diskusage.docbook:12
#, no-c-format
msgid ""
"The Disk Usage is based on the code of &filelight;. The Disk Usage shows you "
"how your disk space is being used by a graphical representation of your file "
"system. The following presentations are possible:"
msgstr ""
"Diskanvändning är baserad på kod från &filelight;. Diskanvändning visar hur "
"diskutrymmet används med en grafisk representation av filsystemet. Följande "
"presentationer är möjliga:"

#. Tag: para
#: diskusage.docbook:18
#, no-c-format
msgid "Line view"
msgstr "Radvy"

#. Tag: para
#: diskusage.docbook:21
#, no-c-format
msgid "Detailed view"
msgstr "Detaljerad vy"

#. Tag: para
#: diskusage.docbook:24
#, no-c-format
msgid ""
"<application>Filelight</application> view: as a set of concentric segmented-"
"rings"
msgstr ""
"<application>Filelight</application>-vy: som en uppsättning koncentriska "
"segmenterade ringar"

#. Tag: para
#: diskusage.docbook:28
#, no-c-format
msgid ""
"Choose <menuchoice> <guimenu>Tools</guimenu> <guimenuitem>Disk Usage...</"
"guimenuitem> </menuchoice> or <keycombo action=\"simul\">&Alt;&Shift; "
"<keycap>S</keycap></keycombo> to start this feature in a separate window, or "
"open it inside the <link linkend=\"sidebar\">Sidebar</link>."
msgstr ""
"Välj <menuchoice> <guimenu>Verktyg</guimenu> <guimenuitem>Diskanvändning...</"
"guimenuitem> </menuchoice> eller <keycombo action=\"simul\">&Alt;&Shift; "
"<keycap>S</keycap></keycombo> för att starta funktionen i ett separat "
"fönster, eller öppna den inne i <link linkend=\"sidebar\">sidoraden</link>."

#. Tag: para
#: diskusage.docbook:38
#, no-c-format
msgid "Disk Usage Keybindings, right click menu."
msgstr "Snabbtangenter för diskanvändning, högerklickmenyn."

#. Tag: para
#: diskusage.docbook:41
#, no-c-format
msgid "<keycap>Del</keycap>: Delete"
msgstr "<keycap>Del</keycap>: Ta bort"

#. Tag: para
#: diskusage.docbook:45
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Ctrl; <keycap>E</keycap></keycombo>: Exclude"
msgstr ""
"<keycombo action=\"simul\">&Ctrl; <keycap>E</keycap></keycombo>: Uteslut"

#. Tag: para
#: diskusage.docbook:50
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Shift; <keycap>Arrow Up</keycap></keycombo>: Up "
"one folder"
msgstr ""
"<keycombo action=\"simul\">&Shift; <keycap>Uppåtpil</keycap></keycombo>: Upp "
"en katalog"

#. Tag: para
#: diskusage.docbook:55
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Ctrl; <keycap>N</keycap></keycombo>: new search"
msgstr ""
"<keycombo action=\"simul\">&Ctrl; <keycap>N</keycap></keycombo>: Ny sökning"

#. Tag: para
#: diskusage.docbook:60
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Ctrl; <keycap>R</keycap></keycombo>: refresh"
msgstr ""
"<keycombo action=\"simul\">&Ctrl; <keycap>R</keycap></keycombo>: Uppdatera"

#. Tag: para
#: diskusage.docbook:65
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Ctrl; <keycap>I</keycap></keycombo>: include all"
msgstr ""
"<keycombo action=\"simul\">&Ctrl; <keycap>I</keycap></keycombo>: Inkludera "
"alla"

#. Tag: para
#: diskusage.docbook:70
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Shift; <keycap>Arrow Down</keycap></keycombo>: "
"step into"
msgstr ""
"<keycombo action=\"simul\">&Shift; <keycap>Neråtpil</keycap></keycombo>: Gå "
"in i"

#. Tag: para
#: diskusage.docbook:75
#, no-c-format
msgid "View menu:"
msgstr "Menyn Visa:"

#. Tag: para
#: diskusage.docbook:78
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Ctrl; <keycap>L</keycap></keycombo>: Line view"
msgstr "<keycombo action=\"simul\">&Ctrl; <keycap>L</keycap></keycombo>: Radvy"

#. Tag: para
#: diskusage.docbook:83
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Ctrl; <keycap>D</keycap></keycombo>: Detailed "
"view"
msgstr ""
"<keycombo action=\"simul\">&Ctrl; <keycap>D</keycap></keycombo>: Detaljerad "
"vy"

#. Tag: para
#: diskusage.docbook:88
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Ctrl; <keycap>F</keycap></keycombo>: Filelight "
"view"
msgstr ""
"<keycombo action=\"simul\">&Ctrl; <keycap>F</keycap></keycombo>: Filelight-vy"

#. Tag: para
#: diskusage.docbook:93
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Shift; <keycap>Arrow Right</keycap></keycombo>: "
"Next view"
msgstr ""
"<keycombo action=\"simul\">&Shift; <keycap>Högerpil</keycap></keycombo>: "
"Nästa vy"

#. Tag: para
#: diskusage.docbook:98
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Shift; <keycap>Arrow Left</keycap></keycombo>: "
"Previous view"
msgstr ""
"<keycombo action=\"simul\">&Shift; <keycap>Vänsterpil</keycap></keycombo>: "
"Föregående vy"
