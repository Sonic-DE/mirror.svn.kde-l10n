#: menu-commands.docbook:540
#, no-c-format
msgid "Restore the selection status of previously unselected items."
msgstr "Återställer markeringsstatus för tidigare avmarkerade objekt."

#. Tag: menuchoice
#: menu-commands.docbook:545
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>F</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Find in folder...</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>F</keycap></keycombo> </"
"shortcut> <guimenu>Redigera</guimenu> <guimenuitem>Sök i katalog...</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:555
#, no-c-format
msgid ""
"Toggles &krusader; <link linkend=\"quicksearch\">quick search</link> "
"function."
msgstr ""
"Sätter på eller stänger av &krusader;s funktion för <link linkend="
"\"quicksearch\">snabbsökning</link>."

#. Tag: menuchoice
#: menu-commands.docbook:561
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift; <keycap>C</keycap></"
"keycombo> </shortcut> <guimenu>Edit</guimenu> <guimenuitem>Compare Folders</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift; <keycap>C</keycap></"
"keycombo> </shortcut> <guimenu>Redigera</guimenu> <guimenuitem>Jämför "
"kataloger</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:571
#, no-c-format
msgid ""
"Toggles &krusader; <link linkend=\"compare-dir\">Compare Folders</link> "
"function."
msgstr ""
"Sätter på eller stänger av funktionen <link linkend=\"compare-dir\">Jämför "
"kataloger</link> i &krusader;."

#. Tag: menuchoice
#: menu-commands.docbook:577
#, no-c-format
msgid "<guimenu>Edit</guimenu> <guimenuitem>Compare Setup</guimenuitem>"
msgstr ""
"<guimenu>Redigera</guimenu> <guimenuitem>Anpassa jämförelse</guimenuitem>"

