msgstr "Returnerar true, om objektet är en omgivning."

#. Tag: term
#: index.docbook:3319
#, no-c-format
msgid "isDataNumeric()"
msgstr "isDataNumeric()"

#. Tag: para
#: index.docbook:3319
#, no-c-format
msgid "Returns true, if the object is a vector of numeric data."
msgstr "Returnerar true, om objektet är en vector med numerisk data."

#. Tag: term
#: index.docbook:3320
#, no-c-format
msgid "isDataFactor()"
msgstr "isDataFactor()"

#. Tag: para
#: index.docbook:3320
#, no-c-format
msgid "Returns true, if the object is a vector of factor data."
msgstr "Returnerar true, om objektet är en vektor med faktordata."

#. Tag: term
#: index.docbook:3321
#, no-c-format
msgid "isDataCharacter()"
msgstr "isDataCharacter()"

#. Tag: para
#: index.docbook:3321
#, no-c-format
