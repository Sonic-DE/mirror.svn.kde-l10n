msgstr "Returnerar true, om objektet är en funktion."

#. Tag: term
#: index.docbook:3318
#, no-c-format
msgid "isEnvironment()"
msgstr "isEnvironment()"

#. Tag: para
#: index.docbook:3318
#, no-c-format
