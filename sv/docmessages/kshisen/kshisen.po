#. Tag: para
#: index.docbook:207
#, no-c-format
msgid ""
"The <guimenu>Game</guimenu> menu lets you control the status of the current "
"game:"
msgstr ""
"Menyn <guimenu>Spel</guimenu> låter dig kontrollera det nuvarande spelets "
"status:"

#. Tag: menuchoice
#: index.docbook:214
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>N</keycap></keycombo></"
"shortcut> <guimenu>Game</guimenu><guimenuitem>New</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>N</keycap></keycombo></"
"shortcut> <guimenu>Spel</guimenu><guimenuitem>Ny</guimenuitem>"

#. Tag: para
#: index.docbook:219
#, no-c-format
msgid ""
"<action>Finishes the current game</action> and starts a new session with new "
"tiles."
msgstr ""
"<action>Avslutar det pågående spelet</action> och startar en ny session med "
"nya brickor."

#. Tag: menuchoice
#: index.docbook:224
#, no-c-format
msgid ""
"<shortcut><keycombo><keycap>F5</keycap></keycombo></shortcut> <guimenu>Game</"
"guimenu><guimenuitem>Restart Game</guimenuitem>"
msgstr ""
"<shortcut><keycombo><keycap>F5</keycap></keycombo></shortcut> <guimenu>Spel</"
"guimenu><guimenuitem>Starta om spel</guimenuitem>"

#. Tag: action
#: index.docbook:229
#, no-c-format
msgid "Restarts the current game with the same tiles."
msgstr "Startar om pågående spel med samma brickor."

#. Tag: menuchoice
#: index.docbook:234
#, no-c-format
msgid ""
"<shortcut><keycombo><keycap>P</keycap></keycombo></shortcut> <guimenu>Game</"
"guimenu><guimenuitem>Pause</guimenuitem>"
msgstr ""
"<shortcut><keycombo><keycap>P</keycap></keycombo></shortcut> <guimenu>Spel</"
"guimenu> <guimenuitem>Pausa</guimenuitem>"

#. Tag: para
#: index.docbook:239
#, no-c-format
msgid ""
"<action>Pauses the game</action>, especially the timer which affects the "
"scoring. The menu entry is also used for resuming the game."
msgstr ""
"<action>Gör paus i hela spelet</action>, i synnerhet tidtagningen som behövs "
"för poängtoppen. Menyalternativet används också för att återuppta spelet."

#. Tag: menuchoice
#: index.docbook:244
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>H</keycap></keycombo></"
