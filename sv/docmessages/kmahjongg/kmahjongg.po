"[KMahjonggLayout]\n"
"Name=<replaceable>name_of_your_layout</replaceable>\n"
"Description=<replaceable>description_of_your_layout</replaceable>\n"
"VersionFormat=1\n"
"Author=<replaceable>your_name</replaceable>\n"
"AuthorEmail=<replaceable>your_email</replaceable>\n"
"FileName=<replaceable>name_of_your_layout</replaceable>.layout"
msgstr ""
"[KMahjonggLayout]\n"
"Name=<replaceable>namn på din layout</replaceable>\n"
"Description=<replaceable>beskrivning av din layout</replaceable>\n"
"VersionFormat=1\n"
"Author=<replaceable>ditt namn</replaceable>\n"
"AuthorEmail=<replaceable>din e-postadress</replaceable>\n"
"FileName=<replaceable>namn_på_din_layout</replaceable>.layout"

#. Tag: para
