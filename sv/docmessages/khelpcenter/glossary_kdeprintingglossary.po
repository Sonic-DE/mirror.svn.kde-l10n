#~ msgid ""
#~ "<glossseealso otherterm=\"gloss-cups\">&CUPS;</glossseealso> "
#~ "<glossseealso otherterm=\"gloss-esp\">ESP</glossseealso> <glossseealso "
#~ "otherterm=\"gloss-gimpprint\">Gimp-Print</glossseealso>"
#~ msgstr ""
#~ "<glossseealso otherterm=\"gloss-cups\">&CUPS;</glossseealso> "
#~ "<glossseealso otherterm=\"gloss-esp\">ESP</glossseealso> <glossseealso "
#~ "otherterm=\"gloss-gimpprint\">Gimp-Print</glossseealso>"

#~ msgid "<acronym>ESP</acronym>"
