#~ "<guimenu>Options</guimenu> <guimenuitem>Auto Shutdown Mode</guimenuitem>"
#~ msgstr ""
#~ "<guimenu>Alternativ</guimenu> <guimenuitem>Automatisk avstängning</"
#~ "guimenuitem>"

#~ msgid ""
#~ "Closes &kget; after all the downloads are completed. The Expert Mode must "
#~ "be turned on."
#~ msgstr ""
#~ "Stänger &kget; efter nerladdningarna är färdiga. Expertläget måste vara "
#~ "aktiverat."

#~ msgid "<guimenu>Options</guimenu><guimenuitem>Auto-Paste Mode</guimenuitem>"
#~ msgstr ""
