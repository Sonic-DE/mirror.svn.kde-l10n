#~ msgid ""
#~ "<action> Imports &URL;'s that are in text files.</action> This is a "
#~ "powerful feature that allows you to parse &URL;'s from text files and "
#~ "emails you may have received. It can discriminate between ordinary text "
#~ "and &URL;'s, provided the &URL; begins at the left margin of the "
#~ "document. &kget; will find these &URL;'s and load them into its main "
#~ "window for you."
#~ msgstr ""
#~ "<action>Importerar webbadresser som finns i textfiler.</action>. Det här "
#~ "är en kraftfull funktion, som låter dig tolka webbadresser i textfiler "
#~ "och e-post som du har tagit emot. Den kan skilja på vanlig text och "
#~ "webbadresser, under förutsättning att webbadresserna börjar vid "
#~ "dokumentets vänstermarginal. &kget; hittar webbadresserna och laddar dem "
#~ "i huvudfönstret åt dig."

#~ msgid ""
#~ "This feature only ignores regular text when you have clicked on the "
#~ "Expert Mode icon. If the Expert Mode is not used then the text file must "
#~ "contain only &URL;'s."
#~ msgstr ""
#~ "Den här funktionen ignorerar bara vanlig text när du har klickat på "
#~ "ikonen för expertläge. Om expertläget inte används, får textfilen bara "
#~ "innehålla webbadresser."

#~ msgid "The <guimenu>View</guimenu> Menu"
#~ msgstr "Menyn <guimenu>Visa</guimenu>"

#~ msgid "<guimenu>View</guimenu> <guimenuitem>Show Log Window</guimenuitem>"
#~ msgstr "<guimenu>Visa</guimenu> <guimenuitem>Visa loggfönster</guimenuitem>"

#~ msgid ""
#~ "Opens a log window that shows the events that have occurred. This is "
#~ "useful for seeing what happened during a lengthy download. Here you can "
#~ "see if any packages were skipped or if a connection timed out."
#~ msgstr ""
#~ "Öppnar ett loggfönster som visar händelserna som har skett. Det är "
#~ "användbart för att se vad som hände under en längre nerladdning. Här kan "
#~ "du se om några paket hoppades över, eller om en anslutning tog för lång "
#~ "tid."

#~ msgid ""
#~ "In order for the entries in this menu to become active (not grayed out), "
#~ "you must highlight a download by clicking on the entry with the &LMB;."
#~ msgstr ""
#~ "För att menyalternativen ska bli aktiva (inte gråa), måste du markera en "
#~ "nerladdning genom att klicka på posten med vänsterknappen."

#~ msgid ""
#~ "<guimenu>Transfer</guimenu> <guimenuitem>Copy &URL; to Clipboard</"
#~ "guimenuitem>"
#~ msgstr ""
#~ "<guimenu>Överföring</guimenu> <guimenuitem>Kopiera webbadress till "
#~ "klippbordet</guimenuitem>"

#~ msgid "This pastes a highlighted line into the &kde; clipboard (&klipper;)."
#~ msgstr "Kopierar en markerad linje till &kde;:s klippbord (&klipper;)."

#~ msgid ""
#~ "<guimenu>Transfer</guimenu> <guimenuitem>Open Individual Window</"
#~ "guimenuitem>"
#~ msgstr ""
#~ "<guimenu>Överföring</guimenu> <guimenuitem>Öppna egna fönster</"
#~ "guimenuitem>"

#~ msgid "Displays the selected download in its own window."
#~ msgstr "Visar markerad nerladdning i ett eget fönster."

#~ msgid ""
#~ "<guimenu>Transfer</guimenu> <guimenuitem>Move To Beginning</guimenuitem>"
#~ msgstr ""
#~ "<guimenu>Överföring</guimenu> <guimenuitem>Gå till början</guimenuitem>"

#~ msgid "Moves a highlighted entry to the top of the download list."
#~ msgstr "Flyttar en markerad post längst upp i nerladdningslistan."

#~ msgid "The topmost &URL; in &kget; is downloaded first."
#~ msgstr "Den översta webbadressen i &kget; laddas ner först."

#~ msgid "<guimenu>Transfer</guimenu> <guimenuitem>Move To End</guimenuitem>"
#~ msgstr ""
#~ "<guimenu>Överföring</guimenu> <guimenuitem>Gå till slutet</guimenuitem>"

#~ msgid "Moves a highlighted entry to the bottom of the download list."
#~ msgstr "Flyttar en markerad post längst ner i nerladdningslistan."

#~ msgid "<guimenu>Transfer</guimenu> <guimenuitem>Resume</guimenuitem>"
#~ msgstr "<guimenu>Överföring</guimenu> <guimenuitem>Återuppta</guimenuitem>"

#~ msgid "Resumes a download that has been paused."
#~ msgstr "Återupptar en nerladdning som stannats."

#~ msgid "<guimenu>Transfer</guimenu> <guimenuitem>Pause</guimenuitem>"
#~ msgstr "<guimenu>Överföring</guimenu> <guimenuitem>Paus</guimenuitem>"

#~ msgid "Pauses a download that is running."
#~ msgstr "Gör paus i en nerladdning som pågår."

#~ msgid "<guimenu>Transfer</guimenu> <guimenuitem>Delete</guimenuitem>"
#~ msgstr "<guimenu>Överföring</guimenu> <guimenuitem>Ta bort</guimenuitem>"

#~ msgid "Deletes a highlighted item from the &kget; main window."
#~ msgstr "Tar bort en markerad post från &kget;s huvudfönster."

#~ msgid "<guimenu>Transfer</guimenu> <guimenuitem>Restart</guimenuitem>"
#~ msgstr "<guimenu>Överföring</guimenu> <guimenuitem>Starta om</guimenuitem>"

#~ msgid "Combines the functions of Resume and Pause in one button."
#~ msgstr "Kombinerar funktionerna Återuppta och Paus i en knapp."

#~ msgid "<guimenu>Transfer</guimenu> <guimenuitem>Queue</guimenuitem>"
#~ msgstr "<guimenu>Överföring</guimenu> <guimenuitem>Köa</guimenuitem>"

#~ msgid "Causes the highlighted entries in &kget; to begin downloading."
#~ msgstr "Gör att de markerade posterna i &kget; börjar laddas ner."

#~ msgid "<guimenu>Transfer</guimenu> <guimenuitem>Timer</guimenuitem>"
#~ msgstr "<guimenu>Överföring</guimenu> <guimenuitem>Tidtagare</guimenuitem>"

#~ msgid ""
#~ "Delays the download of the highlighted items by one minute. This is "
#~ "useful if you need to pause the download to check email or go to a "
#~ "website."
#~ msgstr ""
#~ "Fördröjer nerladdningen av de markerade posterna en minut. Det är "
#~ "användbart om du behöver stanna nerladdningen för att kontrollera e-post "
#~ "eller gå till en webbplats."

#~ msgid "<guimenu>Transfer</guimenu> <guimenuitem>Delay</guimenuitem>"
#~ msgstr "<guimenu>Överföring</guimenu> <guimenuitem>Fördröj</guimenuitem>"

#~ msgid "Delays the download of the highlighted items indefinitely."
#~ msgstr "Fördröjer nerladdningen av markerade poster för alltid."

#~ msgid ""
#~ "<guimenuitem>Queue</guimenuitem>, <guimenuitem>Timer</guimenuitem> and "
#~ "<guimenuitem>Delay</guimenuitem> are mutually exclusive; only one of them "
#~ "may be selected at a time."
#~ msgstr ""
#~ "<guimenuitem>Köa</guimenuitem>, <guimenuitem>Tidtagare</guimenuitem> och "
#~ "<guimenuitem>Fördröj</guimenuitem> är ömsesidigt uteslutande. Bara en av "
#~ "dem kan väljas åt gången."

