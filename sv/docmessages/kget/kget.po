#~ "&kget; ignorerar aktuella kataloginställningar och placerar alla nya "
#~ "överföringar i katalogen där den senaste överföringen placerades."

#~ msgid "<guimenu>Options</guimenu> <guimenuitem>Offline Mode</guimenuitem>"
#~ msgstr ""
#~ "<guimenu>Alternativ</guimenu> <guimenuitem>Nerkopplat läge</guimenuitem>"

#~ msgid ""
#~ "Toggles &kget; from being online (ready to download) to offline. The "
#~ "offline mode is used when you want to copy &URL;'s into &kget; without "
#~ "them being downloaded immediately."
#~ msgstr ""
#~ "Ändrar &kget; från att vara uppkopplad (redo att ladda ner) till "
#~ "nerkopplad. Det nerkopplade läget används när du vill kopiera "
#~ "webbadresser till &kget; utan att de omedelbart laddas ner."

#~ msgid ""
#~ "<guimenu>Options</guimenu> <guimenuitem>Auto-Disconnect Mode</guimenuitem>"
#~ msgstr ""
#~ "<guimenu>Alternativ</guimenu> <guimenuitem>Automatisk nerkoppling</"
#~ "guimenuitem>"

#~ msgid ""
#~ "<action>Causes &kget; to disconnect the modem.</action> Usually this "
#~ "would be &kppp;. Expert Mode must be on to use this feature."
