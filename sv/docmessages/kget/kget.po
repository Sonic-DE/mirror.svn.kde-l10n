#~ msgstr "Menyn <guimenu>Inställningar</guimenu>"

#~ msgid "<guimenu>Options</guimenu> <guimenuitem>Use Animations</guimenuitem>"
#~ msgstr ""
#~ "<guimenu>Alternativ</guimenu> <guimenuitem>Använd animation</guimenuitem>"

#~ msgid "<action>Toggle use of animations</action> to display &kget;'s state."
#~ msgstr ""
#~ "<action>Växlar användning av animation</action> för att visa &kget;s "
#~ "tillstånd."

#~ msgid "<guimenu>Options</guimenu> <guimenuitem>Use Sound</guimenuitem>"
#~ msgstr ""
#~ "<guimenu>Alternativ</guimenu> <guimenuitem>Använd ljud</guimenuitem>"

#~ msgid ""
#~ "<action>Toggle the use of sound</action> to indicate events, &eg; a file "
#~ "being added to the download list, or a download completing."
#~ msgstr ""
#~ "<action>Växlar användning av ljud</action> för att ange händelser, t.ex. "
#~ "att en fil läggs till i nerladdningslistan, eller att en nerladdning är "
#~ "klar."

