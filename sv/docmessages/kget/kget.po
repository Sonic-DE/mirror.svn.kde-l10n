#~ msgstr "<guimenu>Alternativ</guimenu> <guimenuitem>Expertläge</guimenuitem>"

#~ msgid "Turns off prompting."
#~ msgstr "Stänger av frågor."

#~ msgid ""
#~ "<guimenu>Options</guimenu> <guimenuitem>Use-Last-Folder Mode</guimenuitem>"
#~ msgstr ""
#~ "<guimenu>Alternativ</guimenu> <guimenuitem>Använd senaste katalog-läge</"
#~ "guimenuitem>"

#~ msgid ""
#~ "&kget; will ignore the current folder settings and place all new "
#~ "transfers in the folder where the last transfer was placed."
