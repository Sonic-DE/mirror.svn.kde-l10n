"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>Q</keycap></keycombo></"
"shortcut> <guimenu>Spel</guimenu><guimenuitem>Avsluta</guimenuitem>"

#. Tag: para
#: index.docbook:252
#, no-c-format
msgid "<action>Quit</action> &kjumpingcube;."
msgstr "<action>Avsluta</action> Hoppande kuben."

#. Tag: title
#: index.docbook:258
#, no-c-format
msgid "The Move Menu"
msgstr "Menyn Flytta"

