#. Tag: para
#: index.docbook:40
#, no-c-format
msgid ""
"&ktorrent; is a bittorrent application by KDE which allows you to download "
"files using the BitTorrent protocol. It enables you to run multiple torrents "
"at the same time and comes with extended features to make it a full-featured "
"client for BitTorrent."
msgstr ""
"&ktorrent; är ett dataflödesprogram av KDE som låter dig ladda ner filer med "
"protokollet BitTorrent. Det möjliggör att hantera flera dataflöden samtidigt "
"och levereras med utökade funktioner som gör det till en fullfjädrad klient "
"för BitTorrent."

#. Tag: title
#: index.docbook:43
#, no-c-format
msgid "Features"
msgstr "Funktioner"

#. Tag: para
#: index.docbook:44
#, no-c-format
msgid "Queuing of torrents"
msgstr "Köa dataflöden"

#. Tag: para
#: index.docbook:45
#, no-c-format
msgid "Global and per torrent speed limits"
msgstr "Hastighetsbegränsningar, allmänna och per dataflöde"

#. Tag: para
#: index.docbook:46
#, no-c-format
msgid "Previewing of certain file types, build in (video and audio)"
msgstr "Förhandsgranskning av vissa filtyper inbyggd (video och ljud)"

#. Tag: para
#: index.docbook:47
#, no-c-format
msgid "Importing of partially or fully downloaded files"
msgstr "Import av partiellt eller fullständigt nerladdade filer"

#. Tag: para
#: index.docbook:48
#, no-c-format
msgid "File prioritization for multi-file torrents"
msgstr "Filprioritering för dataflöden med flera filer"

#. Tag: para
#: index.docbook:49
#, no-c-format
msgid "Selective downloading for multi-file torrents"
msgstr "Selektiv nerladdning för dataflöden med flera filer"

#. Tag: para
#: index.docbook:50
#, no-c-format
msgid ""
"Kick/ban peers with an additional IP Filter dialog for list/edit purposes"
msgstr ""
"Sparka ut eller förbjud deltagare med en ytterligare IP-"
"filtreringsdialogruta i listnings- och redigeringssyfte."

#. Tag: para
#: index.docbook:51
#, no-c-format
msgid "UDP tracker support"
msgstr "Stöd för UDP-spårare"

#. Tag: para
#: index.docbook:52
#, no-c-format
msgid "Support for private trackers and torrents"
msgstr "Stöd för privata spårare och dataflöden"

#. Tag: para
#: index.docbook:53
#, no-c-format
msgid "Support for µTorrent's peer exchange"
msgstr "Stöd för µTorrents utbyte mellan deltagare"

#. Tag: para
#: index.docbook:54
#, no-c-format
msgid "Support for protocol encryption (compatible with Azureus)"
msgstr "Stöd för protokollkryptering (kompatibel med Azureus)"

#. Tag: para
#: index.docbook:55
#, no-c-format
msgid "Support for creating trackerless torrents"
msgstr "Stöd för att skapa dataflöden utan spårare"

#. Tag: para
#: index.docbook:56
#, no-c-format
msgid "Support for distributed hash tables (DHT, the Mainline version)"
msgstr "Stöd för distribuerade kondensattabeller (DHT, huvudversionen)"

#. Tag: para
#: index.docbook:57
#, no-c-format
msgid ""
"Support for UPnP to automatically forward ports on a LAN with dynamic "
"assigned hosts"
msgstr ""
"Stöd för UPnP för att automatiskt vidarebefordra portar på ett lokalt "
"nätverk med dynamiskt tilldelade värddatorer"

#. Tag: para
#: index.docbook:58
#, no-c-format
msgid "Support for webseeds"
msgstr "Stöd för webberbjudanden"

#. Tag: para
#: index.docbook:59
#, no-c-format
msgid "System tray integration"
msgstr "Integrering med systembricka"

#. Tag: para
#: index.docbook:60
#, no-c-format
msgid "Tracker authentication support"
msgstr "Stöd för behörighetskontroll av spårare"

#. Tag: para
#: index.docbook:61
#, no-c-format
msgid "Connection though a proxy"
msgstr "Anslutning via en proxy"

#. Tag: para
#: index.docbook:62
#, no-c-format
msgid "Interprocess control via DBus interface"
msgstr "Styrning mellan processer via D-Bus gränssnitt"

