msgstr "<guimenu>Spel</guimenu> <guimenuitem>Visa spel</guimenuitem>"

#. Tag: para
#: index.docbook:153
#, no-c-format
msgid "Replay the last game."
msgstr "Spela om senaste spel."

#. Tag: menuchoice
