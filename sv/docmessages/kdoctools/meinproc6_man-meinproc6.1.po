#, no-c-format
msgid "--stdout"
msgstr "--stdout"

#. Tag: para
#: man-meinproc6.1.docbook:146
#, no-c-format
msgid "Output whole document to stdout."
msgstr "Skriv ut hela dokumentet på standardutmatningen."

