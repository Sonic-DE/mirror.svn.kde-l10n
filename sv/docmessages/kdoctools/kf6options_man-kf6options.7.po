msgstr "<refname>kf6options</refname>"

#. Tag: refpurpose
#: man-kf6options.7.docbook:22
#, no-c-format
msgid "Common commandline options for all applications based on &kf6-full;"
msgstr ""
"Gemensamma kommandoradsväljare för alla program som är baserade på &kde; "
"Ramverk 6"

#. Tag: cmdsynopsis
#: man-kf6options.7.docbook:26
#, no-c-format
msgid ""
"<command><replaceable>KDE application</replaceable></command> <arg choice="
"\"opt\"><option>-h, --help</option></arg> <arg choice=\"opt\"><option>-v, --"
"version</option></arg> <arg choice=\"opt\"><option>--author</option></arg> "
"<arg choice=\"opt\"><option>--license</option></arg> <arg choice=\"opt"
"\"><option>--desktopfile</option> <replaceable>file name</replaceable></arg>"
msgstr ""
"<command><replaceable>KDE-program</replaceable></command> <arg choice=\"opt"
"\"><option>-h, --help</option></arg> <arg choice=\"opt\"><option>-v, --"
"version</option></arg> <arg choice=\"opt\"><option>--author</option></arg> "
"<arg choice=\"opt\"><option>--license</option></arg> <arg choice=\"opt"
"\"><option>--desktopfile</option> <replaceable>filnamn</replaceable></arg>"

#. Tag: title
#: man-kf6options.7.docbook:37
#, no-c-format
msgid "Options"
msgstr "Väljare"

#. Tag: para
#: man-kf6options.7.docbook:39
#, no-c-format
msgid "The following options apply to all &kde; applications:"
msgstr "Följande väljare gäller alla program som använder &kde;:"

#. Tag: term
#: man-kf6options.7.docbook:43
#, no-c-format
msgid "<option>-h</option> <option>--help</option>"
msgstr "<option>-h</option> <option>--help</option>"

#. Tag: para
#: man-kf6options.7.docbook:44
#, no-c-format
msgid "This lists the options available at the command line."
msgstr "Listar tillgängliga väljare på kommandoraden."

#. Tag: term
#: man-kf6options.7.docbook:49
#, no-c-format
msgid "<option>-v</option> <option>--version</option>"
msgstr "<option>-v</option> <option>--version</option>"

#. Tag: para
#: man-kf6options.7.docbook:51
#, no-c-format
msgid ""
"Lists version information for <replaceable>KDE application</replaceable>."
msgstr "Listar versionsinformation för <replaceable>KDE-program</replaceable>."

#. Tag: option
#: man-kf6options.7.docbook:55
#, no-c-format
msgid "--author"
msgstr "--author"

#. Tag: para
#: man-kf6options.7.docbook:56
#, no-c-format
msgid ""
"Lists <replaceable>KDE application</replaceable> authors in the terminal "
"window."
msgstr ""
"Listar upphovsmän till <replaceable>KDE-program</replaceable> i "
"terminalfönstret."

#. Tag: option
#: man-kf6options.7.docbook:60
#, no-c-format
msgid "--license"
msgstr "--license"

#. Tag: para
#: man-kf6options.7.docbook:61
#, no-c-format
msgid "Shows license information."
msgstr "Visar licensinformation."

#. Tag: term
#: man-kf6options.7.docbook:65
#, no-c-format
msgid "<option>--desktopfile</option> <replaceable>file name</replaceable>"
msgstr "<option>--desktopfile</option> <replaceable>filnamn</replaceable>"

#. Tag: para
#: man-kf6options.7.docbook:66
#, no-c-format
msgid "The base file name of the desktop entry for this application."
msgstr "Basfilnamnet på skrivbordsposten för programmet."

#. Tag: para
#: man-kf6options.7.docbook:67
#, no-c-format
msgid ""
"This is in particular useful for wrapper applications and applications "
"having in general multiple desktop files. Thus each desktop file can put its "
"own name into the exec command."
msgstr ""
"Det är särskilt användbart för omgivande program och program som i allmänhet "
"har flera skrivbordsfiler. På så sätt kan varje skrivbordsfil lägga till "
"sitt eget namn i exec-kommandot."

#. Tag: title
#: man-kf6options.7.docbook:78
#, no-c-format
msgid "See Also"
msgstr "Se också"

#. Tag: para
#: man-kf6options.7.docbook:79
#, no-c-format
msgid "qt6options(7)"
msgstr "qt6options(7)"

#. Tag: title
#: man-kf6options.7.docbook:84
#, no-c-format
msgid "Authors"
msgstr "Upphovsmän"

#. Tag: para
#: man-kf6options.7.docbook:85
#, no-c-format
msgid ""
"Man page originally written by &Lauri.Watts; &Lauri.Watts.mail; for kdelibs4"
msgstr ""
"Manualsidan ursprungligen skriven av &Lauri.Watts; &Lauri.Watts.mail; för "
"kdelibs4"

#. Tag: para
#: man-kf6options.7.docbook:86
#, no-c-format
msgid "Updated to &frameworks; 5 by &Burkhard.Lueck; &Burkhard.Lueck.mail;"
msgstr "Uppdaterad till Ramverk 5 av &Burkhard.Lueck; &Burkhard.Lueck.mail;"

#~ msgid "kf5options User's Manual"
#~ msgstr "kf5options användarhandbok"

#~ msgid "2014-03-04"
#~ msgstr "2014-03-04"

#~ msgid ""
#~ "<command><replaceable>KDE application</replaceable></command> <arg choice="
#~ "\"opt\">KDE Generic Options</arg>"
#~ msgstr ""
#~ "<command><replaceable>KDE-program</replaceable></command> <arg choice="
#~ "\"opt\">Allmänna KDE-väljare</arg>"

#~ msgid "<option>--caption</option> <parameter>caption</parameter>"
#~ msgstr "<option>--caption</option> <parameter>titel</parameter>"

#~ msgid "Use <parameter>caption</parameter> as name in the titlebar."
#~ msgstr "Använd <parameter>titel</parameter> som titel i namnlisten."

#~ msgid "Use <parameter>icon</parameter> as the application icon."
#~ msgstr "Använd <parameter>ikon</parameter> som programmets ikon."

#~ msgid "<option>--config</option> <parameter>filename</parameter>"
#~ msgstr "<option>--config</option> <parameter>filnamn</parameter>"

#~ msgid "Use the alternative configuration <parameter>filename</parameter>"
#~ msgstr "Använd alternativ inställning <parameter>filnamn</parameter>"

#~ msgid "--nocrashhandler"
#~ msgstr "--nocrashhandler"

#~ msgid "Disable the crash handler, to get core dumps."
#~ msgstr "Inaktivera kraschhantering, för att skapa minnesdumpar."

#~ msgid "--waitforwm"
#~ msgstr "--waitforwm"

#~ msgid "Waits for a WM_NET compatible windowmanager."
#~ msgstr "Väntar på en WM_NET-kompatibel fönsterhanterare."

#~ msgid "<option>--style</option> <parameter>style</parameter>"
#~ msgstr "<option>--style</option> <parameter>stil</parameter>"

#~ msgid "Sets the application &GUI; style."
#~ msgstr "Ställer in stilen för programmets grafiska gränssnitt."

#~ msgid "<option>--geometry</option> <parameter>geometry</parameter>"
#~ msgstr "<option>--geometry</option> <parameter>geometri</parameter>"

#~ msgid "Sets the client geometry of the main widget."
#~ msgstr "Ställer in geometrin för klientens grafiska huvudkomponent."

#~ msgid "<replaceable>qt5options</replaceable>(7)"
#~ msgstr "<replaceable>qt5options</replaceable>(7)"

#~ msgid "2004-02-02"
#~ msgstr "2004-02-02"

#~ msgid "KDE Software"
#~ msgstr "KDE-programvara"

#~ msgid "K Desktop Environment"
#~ msgstr "K-skrivbordsmiljön"

#~ msgid "<option>--display</option> <parameter>displayname</parameter>"
#~ msgstr "<option>--display</option> <parameter>skärmnamn</parameter>"

#~ msgid "<option>--session</option> <parameter>sessionId</parameter>"
#~ msgstr "<option>--session</option> <parameter>sessions-id</parameter>"

#~ msgid ""
#~ "Restore the application for the given <parameter>sessionId</parameter>."
#~ msgstr "Återställ programmet för givet <parameter>sessions-id</parameter>."

#~ msgid "--cmap"
#~ msgstr "--cmap"

#~ msgid ""
#~ "Causes the application to install a private color map on an 8-bit display."
#~ msgstr ""
#~ "Gör att programmet installerar en privat färgkarta på en 8-bitarsskärm."

#~ msgid ""
#~ "Limits the number of colors allocated in the color cube on an 8-bit "
#~ "display, if the application is using the <methodname>QApplication::"
#~ "ManyColor</methodname> color specification."
#~ msgstr ""
#~ "Begränsar antal färger som tilldelas i färgkuben för en 8-bitars skärm, "
#~ "om programmet använder färgspecifikationen <methodname>QApplication::"
#~ "ManyColor</methodname>."

#~ msgid "--nograb"
#~ msgstr "--nograb"

#~ msgid "Tells &Qt; to never grab the mouse or the keyboard."
#~ msgstr "Talar om för &Qt; att aldrig låsa musen eller tangentbordet."

#~ msgid "--dograb"
#~ msgstr "--dograb"

#~ msgid ""
#~ "Running under a debugger can cause an implicit <option>--nograb</option>, "
#~ "use <option>--dograb</option> to override."
#~ msgstr ""
#~ "Att köra med en avlusare kan orsaka en implicit <option>--nograb</"
#~ "option>. Använd <option>--dograb</option> för att överskrida det."

#~ msgid "--sync"
#~ msgstr "--sync"

#~ msgid "Switches to synchronous mode for debugging."
#~ msgstr "Byter till synkront läge för avlusning."

#~ msgid ""
#~ "<option>--fn</option>,<option>--font</option> <parameter>fontname</"
#~ "parameter>"
#~ msgstr ""
#~ "<option>--fn</option>,<option>--font</option> <parameter>teckensnitt</"
#~ "parameter>"

#~ msgid "Defines the application font."
#~ msgstr "Definierar programmets teckensnitt."

#~ msgid ""
#~ "<option>--bg</option>,<option>--background</option> <parameter>color</"
#~ "parameter>"
#~ msgstr ""
#~ "<option>--bg</option>,<option>--background</option> <parameter>färg</"
#~ "parameter>"

#~ msgid ""
#~ "Sets the default background color and an application palette (light and "
#~ "dark shades are calculated)."
#~ msgstr ""
#~ "Ställer in förvald bakgrundsfärg och en programpalett (ljusa och mörka "
#~ "nyanser beräknas)."

#~ msgid ""
#~ "<option>--fg</option>,<option>--foreground</option> <parameter>color</"
#~ "parameter>"
#~ msgstr ""
#~ "<option>--fg</option>,<option>--foreground</option> <parameter>färg</"
#~ "parameter>"

#~ msgid "Sets the default foreground color"
#~ msgstr "Ställer in förvald förgrundsfärg"

#~ msgid ""
#~ "<option>--btn</option>,<option>--button</option> <parameter>color</"
#~ "parameter>"
#~ msgstr ""
#~ "<option>--btn</option>,<option>--button</option> <parameter>färg</"
#~ "parameter>"

#~ msgid "Sets the default button color."
#~ msgstr "Ställer in förvald knappfärg."

#~ msgid "Sets the application title (caption)."
#~ msgstr "Ställer in programmets titel (rubrik)."

#~ msgid "<option>--visual</option> <parameter>TrueColor</parameter>"
#~ msgstr "<option>--visual</option> <parameter>TrueColor</parameter>"

#~ msgid ""
#~ "Forces the application to use a <parameter>TrueColor</parameter> visual "
#~ "on an 8-bit display."
#~ msgstr ""
#~ "Tvingar programmet att använda <parameter>TrueColor</parameter> med en 8-"
#~ "bitars skärm."

#~ msgid "<option>--inputstyle</option> <parameter>inputstyle</parameter>"
#~ msgstr "<option>--inputstyle</option> <parameter>inmatningsstil</parameter>"

#~ msgid ""
#~ "Sets XIM (X Input Method) input style. Possible values are "
#~ "<parameter>onthespot</parameter>, <parameter>overthespot</parameter>, "
#~ "<parameter>offthespot</parameter> and <parameter>root</parameter>."
#~ msgstr ""
#~ "Ställer in XIM (X-inmatningsmetod) inmatningsstil. Möjliga värden är "
#~ "<parameter>onthespot</parameter>, <parameter>overthespot</parameter>, "
#~ "<parameter>offthespot</parameter> och <parameter>root</parameter>."

#~ msgid "<option>--im</option> <parameter>XIM server</parameter>"
#~ msgstr "<option>--im</option> <parameter>XIM-server</parameter>"

#~ msgid "Set XIM server."
#~ msgstr "Ange XIM-server."

#~ msgid "--noxim"
#~ msgstr "--noxim"

#~ msgid "Disable XIM"
#~ msgstr "Inaktivera XIM"

#~ msgid "--reverse"
#~ msgstr "--reverse"

#~ msgid "mirrors the whole layout of widgets"
#~ msgstr "spegelvänder hela utläggningen av grafiska komponenter"

#~ msgid ""
#~ "<date>2004-02-02</date> <productname>K Desktop Environment</productname>"
#~ msgstr ""
#~ "<date>2004-02-02</date> <productname>K-skrivbordsmiljön</productname>"
