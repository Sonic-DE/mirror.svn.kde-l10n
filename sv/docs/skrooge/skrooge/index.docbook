            </imageobject>
            </mediaobject>
        </screenshot>
        <para
>De här alternativen hjälper dig att hantera din ändringshistorik bättre.</para>
        </sect1>

        <sect1 id="settings_dashboard">
        <title
>Instrumentpanel</title>
        
        <screenshot>
