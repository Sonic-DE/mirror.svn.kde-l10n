#: src/android_defaults.notifyrc:2
msgctxt "Name"
msgid "Fatal Error"
msgstr "Allvarligt fel"

#: src/android_defaults.notifyrc:61
msgctxt "Comment"
msgid "There was a serious error causing the program to exit"
msgstr "Ett allvarligt fel uppstod vilket fick programmet att avslutas"

#: src/android_defaults.notifyrc:122
msgctxt "Name"
msgid "Notification"
msgstr "Underrättelse"

#: src/android_defaults.notifyrc:180
msgctxt "Comment"
msgid "Something special happened in the program"
msgstr "Någonting speciellt inträffade i programmet"

#: src/android_defaults.notifyrc:240
msgctxt "Name"
msgid "Warning"
msgstr "Varning"

#: src/android_defaults.notifyrc:298
msgctxt "Comment"
msgid "There was an error in the program which may cause problems"
msgstr "Det uppstod ett fel i programmet vilket kan orsaka problem"

#: src/android_defaults.notifyrc:358
msgctxt "Name"
msgid "Catastrophe"
msgstr "Katastrof"

#: src/android_defaults.notifyrc:415
msgctxt "Comment"
msgid "A very serious error occurred, at least causing the program to exit"
msgstr ""
"Ett mycket allvarligt fel uppstod, som åtminstone fick programmet att "
"avslutas"

