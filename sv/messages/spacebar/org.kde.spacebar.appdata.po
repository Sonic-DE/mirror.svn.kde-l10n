#. (itstool) path: component/name
#: org.kde.spacebar.appdata.xml:4
msgid "Spacebar"
msgstr "Spacebar"

#. (itstool) path: component/summary
#: org.kde.spacebar.appdata.xml:5
msgid "SMS/MMS messaging client"
msgstr "SMS/MMS-meddelandeklient"

#. (itstool) path: description/p
#: org.kde.spacebar.appdata.xml:12
msgid ""
"Spacebar is a SMS/MMS messaging client. It allows you to send text messages, "
"pictures and other files over a cellular network."
msgstr ""
"Spacebar är en SMS/MMS-meddelandeklient. Den låter dig skicka "
"textmeddelanden, bilder och andra filer över ett mobilnätverk."

#~ msgid "KDE Community"
#~ msgstr "KDE-gemenskapen"

#~ msgid ""
#~ "Spacebar is a telepathy client for Plasma Mobile, that is primarily "
#~ "written for sending and receiving SMS/MMS."
#~ msgstr ""
#~ "Spacebar är en Telepathy-klient för Plasma Mobil, som i huvudsak är "
#~ "skriven för att skicka och ta emot SMS/MMS."
