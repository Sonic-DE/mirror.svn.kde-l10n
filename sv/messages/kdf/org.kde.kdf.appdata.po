msgid "KDiskFree"
msgstr "Kdiskfree"

#. (itstool) path: component/summary
#: org.kde.kdf.appdata.xml:10
msgid "View Disk Usage"
msgstr "Visa hårddiskanvändning"

#. (itstool) path: description/p
#: org.kde.kdf.appdata.xml:12
msgid ""
"KDiskFree displays the available file devices (hard drive partitions, floppy "
"and CD drives, etc.) along with information on their capacity, free space, "
"type and mount point. It also allows you to mount and unmount drives and "
"view them in a file manager."
msgstr ""
"Kdiskfree visar tillgängliga filenheter (hårddiskpartitioner, diskett- och "
"cd-enheter, etc.) tillsammans med information om deras kapacitet, ledigt "
"utrymme, typ och monteringsplats. Det låter dig också montera och avmontera "
"enheter och visa dem i en filhanterare."

