#. (itstool) path: component/name
#: org.kde.dragonplayer.appdata.xml:9
msgid "Dragon Player"
msgstr "Dragon videospelare"

#. (itstool) path: component/summary
#: org.kde.dragonplayer.appdata.xml:10
msgid "Play video files and streams"
msgstr "Spela videofiler och strömmar"

#. (itstool) path: description/p
#: org.kde.dragonplayer.appdata.xml:12
msgid ""
"Dragon Player is a video player focusing on simplicity instead of features. "
"Its easy-to-use interface is designed to get out of your way and simply play "
"your video files and streams."
msgstr ""
"Dragon videospelare är en videospelare med fokus på enkelhet istället för "
"funktioner. Dess enkla gränssnitt är konstruerat för att inte vara i vägen "
"utan istället ge dig möjlighet att enkelt spela upp videofiler och strömmar."

#. (itstool) path: description/p
#: org.kde.dragonplayer.appdata.xml:15
msgid "Features:"
msgstr "Funktioner:"

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:17
msgid ""
"Click to play or pause, and double-click to enter or exit full screen mode."
msgstr ""
"Klicka för att spela eller pausa, och dubbelklicka för att gå till eller "
"lämna fullskärmsläge."

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:18
msgid ""
"Choose the subtitle language, and automatically load the right one for your "
"language, if possible."
msgstr ""
"Välj språk för textning, och läs automatiskt in rätt språk, om möjligt."

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:19
msgid "Choose the audio track."
msgstr "Välj ljudspåret."

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:20
msgid "Choose the video track."
msgstr "Välj videospåret."

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:21
msgid "Adjust the volume by scrolling."
msgstr "Justera volymen genom att rulla."

#~ msgid "Video player with focus on simplicity"
#~ msgstr "Videospelare med fokus på enkelhet"

#~ msgid "Simple Interface"
#~ msgstr "Enkelt gränssnitt"

#~ msgid ""
#~ "Resuming videos: Starts playing a video where you were watching it last "
#~ "time"
#~ msgstr ""
#~ "Återuppta videor: Börjar spela en video på stället du senast tittade på "
#~ "den"

#~ msgid ""
#~ "Support for subtitles: Automatically loads subtitles with the matching "
#~ "name"
#~ msgstr "Stöd för textning: Laddar automatiskt textning med motsvarande namn"

#~ msgid "Video display settings (brightness, contrast)"
#~ msgstr "Inställningar av videovisning (ljusstyrka, kontrast)"

#~ msgid ""
#~ "Due to using Solid and Phonon DragonPlayer is independent of any "
#~ "multimedia framework or hardware abstraction layer"
#~ msgstr ""
#~ "På grund av att Solid och Phonon används är Dragon videospelare oberoende "
#~ "av alla ramverk för multimedia och hårdvaruabstraktionslager"

#~ msgid "Supports playing CDs and DVDs"
#~ msgstr "Stöder uppspelning av cd- och dvd-skivor"
