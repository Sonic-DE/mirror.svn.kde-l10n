msgstr "En fil kunde inte öppnas"

#: core/smb4k.notifyrc:1611
msgctxt "Name"
msgid "Reading file failed"
msgstr "Misslyckades läsa fil"

#: core/smb4k.notifyrc:1649
msgctxt "Comment"
