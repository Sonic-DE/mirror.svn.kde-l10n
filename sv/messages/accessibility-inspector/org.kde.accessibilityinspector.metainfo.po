msgid "Accessibility Inspector"
msgstr "Tillgänglighetsinspektör"

#. (itstool) path: component/summary
#: org.kde.accessibilityinspector.metainfo.xml:12
msgid "Inspect your application accessibility tree"
msgstr "Inspektera programmets tillgänglighetsträd"

#. (itstool) path: description/p
#: org.kde.accessibilityinspector.metainfo.xml:14
msgid ""
"Accessibility Inspector is as the name suggests an inspector for your "
"application accessibility tree. It lets you check all the items exposed via "
"At-SPI, too."
msgstr ""
"Tillgänglighetsinspektören är som namnet anger en inspektör av ett programs "
"tillgänglighetsträd. Den låter dig också kontrollera alla objekt som "
"exponeras via At-SPI."

