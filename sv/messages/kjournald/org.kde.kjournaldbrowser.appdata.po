msgid "Journald Browser"
msgstr "Journald-bläddrare"

#. (itstool) path: component/summary
#: org.kde.kjournaldbrowser.appdata.xml:15
msgid "Browser for journald databases"
msgstr "Bläddrare för journald-databaser"

#. (itstool) path: description/p
#: org.kde.kjournaldbrowser.appdata.xml:17
msgid ""
"Journald-browser is a reference implementation of the kjournald library and "
"provides a flexible tool to browse in local, remote and offline journald "
"databases."
msgstr ""
"Journald-bläddraren är en referensimplementering av kjournald-biblioteket "
"och tillhandahåller ett flexibelt verktyg för att bläddra i lokala "
"databaser, fjärrdatabaser, och nedkopplade databaser."

