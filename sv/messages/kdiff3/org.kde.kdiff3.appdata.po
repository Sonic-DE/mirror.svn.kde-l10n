#. (itstool) path: component/name
#: org.kde.kdiff3.appdata.xml:13
msgid "KDiff3"
msgstr "Kdiff3"

#. (itstool) path: component/summary
#: org.kde.kdiff3.appdata.xml:14
msgid "A file and folder comparison and merge tool"
msgstr ""
"Ett jämförelse- och sammanfogningsverktyg för fil- och katalogjämförelser"

#. (itstool) path: description/p
#: org.kde.kdiff3.appdata.xml:17
msgid "KDiff3 is a file and folder diff and merge tool which"
msgstr ""
"Kdiff3 är ett verktyg för jämförelser och sammanfogning av filer och "
"kataloger, som"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:19
msgid "compares and merges two or three text input files or folders,"
msgstr "jämför och sammanfogar två eller tre textfiler eller kataloger,"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:20
msgid "shows the differences line by line and character by character(!),"
msgstr "visar skillnaderna rad för rad och tecken för tecken (!),"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:21
msgid "provides an automatic merge-facility,"
msgstr "tillhandahåller en automatisk sammanfogingsfunktion,"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:22
msgid "has an editor for comfortable solving of merge-conflicts,"
msgstr "har en editor för bekväm lösning av sammanfogningskonflikter,"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:23
msgid "provides network transparency via KIO,"
msgstr "tillhandahåller nätverkstransparens via KIO,"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:24
msgid "has options to highlight or hide changes in white-space or comments,"
msgstr ""
"har alternativ för att markera eller dölja ändringar av blanktecken eller "
"kommentarer,"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:25
msgid "supports Unicode, UTF-8 and other file encodings,"
msgstr "stöder Unicode, UTF-8 och andra filkodningar,"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:26
msgid "prints differences,"
msgstr "skriver ut skillnader,"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:27
msgid "supports version control keyword and history merging."
msgstr "stöder nyckelord för versionskontroll och sammanfogning av historik."
