#. (itstool) path: component/name
#: org.kde.accountwizard.appdata.xml:9
msgid "Account Wizard"
msgstr "Kontoguide"

#. (itstool) path: component/summary
#: org.kde.accountwizard.appdata.xml:10
msgid "Configure accounts"
msgstr "Anpassa konton"

#. (itstool) path: description/p
#: org.kde.accountwizard.appdata.xml:12
msgid ""
"Accountwizard allows to edit, create, delete accounts. Accountwizard "
"supports IMAP/POP3/Kolab account type. Account information can be found by "
"using ispd service."
msgstr ""
"Kontoguiden gör det möjligt att redigera, skapa och ta bort konton. "
"Kontoguiden stöder kontotyperna IMAP/POP3/Kolab. Kontoinformation kan "
"lokaliseras genom att använda tjänsten ispd."

#~ msgid "Accountwizard allows to edit, create, delete accounts."
#~ msgstr "Kontoguiden gör det möjligt att redigera, skapa och ta bort konton."
