msgid "KMines"
msgstr "Minröjaren"

#. (itstool) path: component/summary
#: org.kde.kmines.appdata.xml:10
msgid "Minesweeper-like Game"
msgstr "Minröjarliknande spel"

#. (itstool) path: description/p
#: org.kde.kmines.appdata.xml:12
msgid ""
"KMines is a classic Minesweeper game. The idea is to uncover all the squares "
"without blowing up any mines. When a mine is blown up, the game is over."
msgstr ""
"Minröjaren är ett klassiskt minröjarspel. Idén är att frilägga alla rutor "
"utan att detonera några minor. När en mina detonerar är spelet slut."
