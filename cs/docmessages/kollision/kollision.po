#. Tag: menuchoice
#: index.docbook:99
#, no-c-format
msgid "<guimenu>Game</guimenu> <guimenuitem>End game</guimenuitem>"
msgstr "<guimenu>Hra</guimenu> <guimenuitem>Ukončit hru</guimenuitem>"

#. Tag: para
#: index.docbook:102
#, no-c-format
msgid "End a game and return to the welcome screen."
msgstr "Ukončuje hru a vrací se do uvítací obrazovky."

#. Tag: menuchoice
#: index.docbook:107
#, no-c-format
msgid ""
"<shortcut> <keycap>P</keycap></shortcut> <guimenu>Game</guimenu> "
"<guimenuitem>Pause</guimenuitem>"
msgstr ""
"<shortcut> <keycap>P</keycap></shortcut> <guimenu>Hra</guimenu> "
"<guimenuitem>Pozastavit</guimenuitem>"

#. Tag: action
#: index.docbook:113
#, no-c-format
msgid "Pauses or resumes the game."
msgstr "Pozastavuje nebo obnovuje hru."

#. Tag: menuchoice
#: index.docbook:118
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>H</keycap></keycombo> </"
"shortcut> <guimenu>Game</guimenu> <guimenuitem>Show High Scores</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>H</keycap></keycombo></"
"shortcut> <guimenu>Hra</guimenu> <guimenuitem>Zobrazit nejlepší výsledky</"
"guimenuitem>"

#. Tag: para
#: index.docbook:123
#, no-c-format
msgid "This will show the best scores for the current level."
msgstr "Bude zobrazovat nejlepší výsledky současné úrovně."

#. Tag: menuchoice
#: index.docbook:127
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>Q</keycap></keycombo> </"
"shortcut> <guimenu>Game</guimenu> <guimenuitem>Quit</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>Q</keycap></keycombo> </"
"shortcut> <guimenu>Hra</guimenu> <guimenuitem>Ukončit</guimenuitem>"

#. Tag: para
#: index.docbook:132
#, no-c-format
msgid "Selecting this item will end your current game, and exit &kollision;."
msgstr ""
"Zvolení této položky ukončí současnou hru a zavře aplikaci &kollision;."

#. Tag: menuchoice
#: index.docbook:137
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Play Sounds</guimenuitem>"
msgstr "<guimenu>Nastavení</guimenu><guimenuitem>Přehrávat zvuky</guimenuitem>"

#. Tag: para
#: index.docbook:143
#, no-c-format
msgid ""
"<action>Toggle whether sound effects should be played.</action> The default "
"is off."
msgstr ""
"<action>Přepíná, zda by měly být přehrávány zvukové efekty.</action> Výchozí "
"je vypnuto."

#. Tag: menuchoice
#: index.docbook:150
#, no-c-format
msgid ""
"<guimenu>Settings</guimenu> <guimenuitem>Increase Ball Size</guimenuitem>"
msgstr ""

#. Tag: para
#: index.docbook:154
#, no-c-format
msgid "<action>Toggle to make the balls bigger.</action> The default is off."
msgstr ""

#. Tag: menuchoice
#: index.docbook:158
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guisubmenu>Difficulty</guisubmenu>"
msgstr "<guimenu>Nastavení</guimenu><guimenuitem>Obtížnost</guimenuitem>"

#. Tag: para
#: index.docbook:160
#, no-c-format
msgid ""
"Allows you to select a difficulty <guilabel>Easy</guilabel>, "
"<guilabel>Medium</guilabel>, <guilabel>Hard</guilabel> for the game."
msgstr ""
"Umožní zvolit obtížnost hry: <guilabel>Jednoduchá</guilabel>, "
"<guilabel>Střední</guilabel>, <guilabel>Těžká</guilabel>."

#. Tag: para
#: index.docbook:166
#, no-c-format
msgid ""
"Additionally &kollision; has the common &kde; <guimenu>Settings</guimenu> "
"and <guimenu>Help</guimenu> menu items, for more information read the "
"sections about the <ulink url=\"help:/fundamentals/menus.html#menus-settings"
"\">Settings Menu</ulink> and <ulink url=\"help:/fundamentals/menus."
"html#menus-help\">Help Menu</ulink> of the &kde; Fundamentals."
msgstr ""

#. Tag: title
#: index.docbook:176
#, no-c-format
msgid "Frequently asked questions"
msgstr "Často kladené otázky"

#. Tag: para
#: index.docbook:179
#, no-c-format
msgid "I want to change the way this game looks. Can I?"
msgstr "Chci změnit vzhled hry. Mohu?"

#. Tag: para
#: index.docbook:180
#, no-c-format
msgid "<para>No.</para>"
msgstr "<para>Ne.</para>"

#. Tag: para
#: index.docbook:183
#, no-c-format
msgid "Can I use the keyboard to play the game?"
msgstr "Mohu při hraní této hry použít klávesnici?"

#. Tag: para
#: index.docbook:184
#, no-c-format
msgid "No. &kollision; can only be played with a mouse."
msgstr "Ne. &kollision; můžete hrát pouze pomocí myši."

#. Tag: para
#: index.docbook:187
#, no-c-format
msgid "I cannot figure out what to do here! Are there hints?"
msgstr "Nevím jak hrát dál! Jsou zde rady?"

#. Tag: para
#: index.docbook:188
#, no-c-format
msgid "&kollision; does not have a <quote>Hint</quote> feature."
msgstr "&kollision; nemá funkci <quote>Rada</quote>."

#. Tag: para
#: index.docbook:191
#, no-c-format
msgid ""
"I have to quit the game now, but I am not finished yet. Can I save my "
"progress?"
msgstr ""
"Musím ukončit svoji hru ještě před dokončením. Mohu uložit svůj průběh?"

#. Tag: para
#: index.docbook:192
#, no-c-format
msgid "You cannot save games in &kollision;."
msgstr "Ve aplikaci &kollision; nelze uložit hru."

