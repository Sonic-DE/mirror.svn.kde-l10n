"<guimenu>Nastavení</guimenu> <guimenuitem>Nastavit &kget;</guimenuitem>"

#. Tag: action
#: index.docbook:164
#, no-c-format
msgid "Opens the &kget; configuration window"
msgstr "Otevře nastavení okna aplikace &kget;"

