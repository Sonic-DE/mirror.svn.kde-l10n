msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>H</keycap></keycombo> </"
"shortcut> <guimenu>Soubor</guimenu> <guimenuitem>Historie přenosů</"
"guimenuitem>"

