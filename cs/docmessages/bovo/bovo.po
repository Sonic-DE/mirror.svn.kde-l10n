"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>Q</keycap></keycombo></"
"shortcut> <guimenu>Hra</guimenu> <guimenuitem>Ukončit</guimenuitem>"

#. Tag: para
#: index.docbook:162
#, no-c-format
msgid "Selecting this item will end your current game, and exit &bovo;."
msgstr "Výběr této položky ukončí hru a zavře aplikaci &bovo;."

