msgid "Features:"
msgstr "Vlastnosti:"

#. (itstool) path: ul/li
#: org.kde.okular.kirigami.appdata.xml:18
msgid ""
"Supported Formats: PDF, PS, Tiff, DjVu, Images, DVI, XPS, Fiction Book, "
"Comic Book, Plucker, EPub, Fax"
msgstr ""
"Podporované formáty: PDF, PS, Tiff, DjVu, obrázky, DVI, XPS, Fiction Book, "
"Comic Book, Plucker, EPub, Fax"

#. (itstool) path: ul/li
