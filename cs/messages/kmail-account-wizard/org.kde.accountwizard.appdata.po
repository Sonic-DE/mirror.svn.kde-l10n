msgid "Account Wizard"
msgstr "Průvodce nastavením účtu"

#. (itstool) path: component/summary
#: org.kde.accountwizard.appdata.xml:10
msgid "Configure accounts"
msgstr "Nastavit účty"

#. (itstool) path: description/p
#: org.kde.accountwizard.appdata.xml:12
msgid ""
"Accountwizard allows to edit, create, delete accounts. Accountwizard "
"supports IMAP/POP3/Kolab account type. Account information can be found by "
"using ispd service."
msgstr ""
"Průvodce účty umožňuje upravovat, vytvářet a mazat účty. Podporuje typy účtů "
"IMAP/POP3/Kolab. Informace o účtu lze najít pomocí služby ispd."
