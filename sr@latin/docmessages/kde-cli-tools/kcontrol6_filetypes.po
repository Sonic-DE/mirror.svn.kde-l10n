msgstr "<literal>%u</literal> — jedan URL"

#. Tag: para
#: index.docbook:297
#, fuzzy, no-c-format
#| msgid "%U - a list of URLs"
msgid "%U - a list of &URL;s"
msgstr "<literal>%U</literal> — spisak URL‑ova"

#. Tag: para
#: index.docbook:298
#, no-c-format
msgid "%d - the folder of the file to open"
msgstr "<literal>%d</literal> — fascikla fajla koji se otvara"

#. Tag: para
#: index.docbook:299
#, no-c-format
msgid "%D - a list of folders"
msgstr "<literal>%D</literal> — spisak fascikli"

