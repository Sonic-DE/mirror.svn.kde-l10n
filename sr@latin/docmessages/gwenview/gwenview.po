#. Tag: para
#: index.docbook:649
#, no-c-format
msgid "<keycap>F2</keycap>: Rename an image inline."
msgstr "<keycap>F2</keycap>: preimenuje sliku utkano."

#. Tag: para
#: index.docbook:652
#, no-c-format
msgid "<keycap>Del</keycap>: Move an image to the trash."
