#. Tag: para
#: index.docbook:623
#, no-c-format
msgid "<keycap>Del</keycap>: Move the current image to the trash."
msgstr "<keycap>Delete</keycap>: premešta sliku u smeće."

#. Tag: para
#: index.docbook:626
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Shift;<keycap>Del</keycap></keycombo>: "
