#. Tag: para
#: index.docbook:631
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Ctrl;<keycap>P</keycap></keycombo>: Print the "
"current image."
msgstr ""
"<keycombo action=\"simul\"><keycap>Ctrl</keycap><keycap>P</keycap></"
"keycombo>: štampa sliku."

#. Tag: para
#: index.docbook:635
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Ctrl;<keycap>O</keycap></keycombo>: Open an "
"image using the standard file selection dialog."
msgstr ""
"<keycombo action=\"simul\"><keycap>Ctrl</keycap><keycap>O</keycap></"
"keycombo>: otvara sliku putem standardnog dijaloga za izbor fajlova."

#. Tag: para
#: index.docbook:639
#, no-c-format
msgid ""
"<keycap>F</keycap>: Pressing this shortcut toggles zoom-to-fit on and off."
msgstr ""
"<keycap>F</keycap>: ova prečica aktivira i deaktivira uveličanje do "
