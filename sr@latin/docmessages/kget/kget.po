# >! ui: Start / Resume All -> ?
#. Tag: menuchoice
#: index.docbook:101
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>R</keycap></keycombo> </"
"shortcut> <guimenuitem>Start / Resume All</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"><keycap>Ctrl</keycap><keycap>R</"
"keycap></keycombo> </shortcut> <guimenuitem>Započni/nastavi sve</guimenuitem>"

#. Tag: action
#: index.docbook:110
#, no-c-format
msgid ""
"To start a download or resume all the pending downloads. The shortcut for "
"doing this is <keycombo action=\"simul\">&Ctrl;<keycap>R</keycap></keycombo>"
msgstr ""
"Pokrenite preuzimanje ili nastavite sva preuzimanja na čekanju. Prečica za "
"ovo je <keycombo action=\"simul\"><keycap>Ctrl</keycap><keycap>R</keycap></"
"keycombo>."

#. Tag: guimenuitem
#: index.docbook:118
#, no-c-format
msgid "Show/Hide Main Window"
msgstr "Prikaži glavni prozor, Sakrij glavni prozor"

#. Tag: action
#: index.docbook:123
#, no-c-format
msgid "This option shows or minimizes the main window to the system tray."
msgstr "Ova opcija prikazuje ili minimizuje glavni prozor u sistemsku kasetu."

