msgstr ""
"<screeninfo>Opcije priključaka <application>KGeta</application>.</screeninfo>"

#. Tag: phrase
#: index.docbook:520
#, no-c-format
msgid "<phrase>&kget; Plugins Options</phrase>"
msgstr "<phrase>Opcije priključaka <application>KGeta</application>.</phrase>"

#. Tag: para
#: index.docbook:524
#, no-c-format
msgid ""
"On this page you can select the transfer plugins to be used. Use the "
"<inlinemediaobject><imageobject><imagedata fileref=\"pluginsettings.png\" "
"format=\"PNG\"/> </imageobject></inlinemediaobject> button to change the "
"default settings for a plugin."
msgstr ""
"Na ovoj stranici možete da izaberete koji se priključci za prenos koriste. "
"Kliknite na dugme <inlinemediaobject><imageobject><imagedata fileref="
"\"pluginsettings.png\" format=\"PNG\"/> </imageobject></inlinemediaobject> "
"da promenite podrazumevane postavke datog priključka."

#. Tag: title
#: index.docbook:532
#, no-c-format
msgid "Main Window"
msgstr "Glavni prozor"

#. Tag: para
#: index.docbook:533
#, no-c-format
msgid "Overview of &kget;'s Main Window"
msgstr "Pregled glavnog prozora <application>KGeta</application>."

#. Tag: title
#: index.docbook:547
#, no-c-format
msgid "The File Menu"
msgstr "Meni Fajl"

