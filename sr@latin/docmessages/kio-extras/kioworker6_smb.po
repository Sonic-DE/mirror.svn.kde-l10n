#. Tag: para
#: index.docbook:18
#, fuzzy, no-c-format
#| msgid ""
#| "The smb ioslave enables you to browse the shares of a &Windows; (or "
#| "Samba) network."
msgid ""
"The smb worker enables you to browse the shares of a &Windows; (or Samba) "
"network."
msgstr ""
"U/I zahvat SMB‑a omogućava vam da pregledate deljenja na windows (ili Samba) "
"mreži."

#. Tag: para
#: index.docbook:23
#, no-c-format
msgid ""
"To see the workgroups, enter <userinput><command>smb:/</command></userinput>."
msgstr ""
"Unesite <userinput><command>smb:/</command></userinput> za pregled radnih "
"grupa."

#. Tag: para
#: index.docbook:27
#, no-c-format
msgid ""
"<userinput><command>smb://</command><replaceable>a_workgroup</replaceable></"
"userinput> will list the hosts in this workgroup."
msgstr ""
"<userinput><command>smb://</command><replaceable>radnagrupa</replaceable> </"
"userinput> nabrojaće sve domaćine unutar nje."

#. Tag: para
#: index.docbook:31
#, no-c-format
msgid ""
"To see the shares of a host, enter <userinput><command>smb://</"
"command><replaceable>the_host</replaceable></userinput> or "
"<userinput><command>smb:/</command><replaceable>a_workgroup</replaceable>/"
"<replaceable>the_host</replaceable></userinput>."
msgstr ""
"Da biste videli domaćinova deljenja, unesite <userinput><command>smb://</"
"command><replaceable>domacin</replaceable></userinput> ili "
"<userinput><command>smb:/</command><replaceable>radnagrupa</"
"replaceable><replaceable>domacin</replaceable></userinput>."

#. Tag: para
#: index.docbook:37
#, no-c-format
msgid ""
"To access a share directly enter <userinput><command>smb://</"
"command><replaceable>the_host/the_share</replaceable></userinput> or "
"<userinput><command>smb:/</command><replaceable>a_workgroup</replaceable>/"
"<replaceable>the_host</replaceable>/<replaceable>the_share</replaceable></"
"userinput>"
msgstr ""
"Za direktan pristup deljenju, unesite <userinput><command>smb://</"
"command><replaceable>domacin/deljenje</replaceable></userinput> ili "
"<userinput><command>smb:/</command><replaceable>radnagrupa</"
"replaceable><replaceable>domacin</replaceable><replaceable>deljenje</"
"replaceable></userinput>"

#. Tag: para
#: index.docbook:44
#, fuzzy, no-c-format
#| msgid ""
#| "The smb ioslave requires that you have libsmbclient to use this ioslave."
msgid "The smb worker requires that you have libsmbclient to use this worker."
msgstr ""
"Da bi se SMB U/I zahvat koristio, neophodno je da je instalirana "
"<literal>libsmbclient</literal>."

#. Tag: para
#: index.docbook:48
#, fuzzy, no-c-format
#| msgid ""
#| "You can set your default user name and password in the &systemsettings; "
#| "category <guilabel>Network</guilabel> in "
#| "<menuchoice><guisubmenu>Connectivity</guisubmenu><guimenuitem> Windows "
#| "Shares</guimenuitem></menuchoice>. This is especially useful if you are a "
#| "member of a &Windows; <acronym>NT</acronym> domain. There you can also "
#| "set your workgroup name, but in most cases this is not required. The "
#| "kioslave will ask for your username and password if a default is not set."
msgid ""
"You can set your default user name and password in the &systemsettings; "
"category <guilabel>Network</guilabel> in "
"<menuchoice><guisubmenu>Connectivity</guisubmenu><guimenuitem> Windows "
"Shares</guimenuitem></menuchoice>. This is especially useful if you are a "
"member of a &Windows; <acronym>NT</acronym> domain. There you can also set "
"your workgroup name, but in most cases this is not required. The worker will "
"ask for your username and password if a default is not set."
msgstr ""
"Svoje podrazumevano ime i lozinku možete postaviti u Sistemskim postavkama, "
"u kategoriji <guilabel>Mreža</guilabel> pod "
"<menuchoice><guisubmenu>Povezivost</guisubmenu><guimenuitem>Windowsova "
"deljenja</guimenuitem></menuchoice>. Ovo je naročito korisno ako ste član "
"domena pod Windowsom NT. Tamo takođe možete postaviti ime radne grupe, ali "
"ono najčešće nije neophodno. Ako podrazumevano nije postavljeno, U/I zahvat "
"će vam zatražiti korisničko ime i lozinku."
