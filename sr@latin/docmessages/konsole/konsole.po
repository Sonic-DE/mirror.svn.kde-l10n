#, no-c-format
msgid "Help Menu"
msgstr "Meni <guimenu>Pomoć</guimenu>"

#. Tag: para
#: index.docbook:1283
#, fuzzy, no-c-format
#| msgid ""
#| "&konsole; has the some of the common &kde; <guimenu>Help</guimenu> menu "
