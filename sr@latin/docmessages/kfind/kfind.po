"<personname><firstname>Mario</firstname> <surname>Vajlguni</surname></"
"personname> &Mario.Weilguni.mail;"

#. Tag: para
#: index.docbook:350
#, no-c-format
msgid "&Alex.Zepeda; <email>jazepeda@pacbell.net</email>"
msgstr ""
