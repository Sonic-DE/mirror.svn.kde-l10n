#: index.docbook:400
#, no-c-format
msgid "Advanced usage"
msgstr "Napredna upotreba"

#. Tag: title
#: index.docbook:402
#, no-c-format
msgid "Remote controlling and scripting via &DBus;"
msgstr "Daljinsko upravljanje i skriptovanje preko D‑Busa"

#. Tag: para
#: index.docbook:403
#, no-c-format
msgid ""
"You can control &kmix; via &DBus;. This is for advanced users who want to "
"achieve special tasks, like muting the PC every day at 10 pm, or for any "
"other scripting task."
msgstr ""
"<application>K‑miksetom</application> možete upravljati preko D‑Busa. "
"Napredni korisnici ovako mogu izvoditi specijalne zahvate, poput utišavanja "
"računara svaki dan u 22.000, ili bilo kakav drugi skriptovani zadatak."

#. Tag: para
#: index.docbook:407
#, no-c-format
msgid "List all &kmix; related &DBus; methods and properties"
msgstr ""
"Nabrajanje svih D‑Bus metoda i svojstava u vezi sa <application>K‑miksetom</"
"application>:"

#. Tag: programlisting
#: index.docbook:409
#, no-c-format
msgid "qdbus org.kde.kmix"
msgstr "qdbus org.kde.kmix"

#. Tag: para
#: index.docbook:412
#, no-c-format
msgid "Getting volume level (0-100%):"
msgstr "Dobavljanje jačine zvuka (0%–100%):"

#. Tag: programlisting
#: index.docbook:414
#, no-c-format
msgid ""
"qdbus org.kde.kmix /Mixers/0/Master_0 org.freedesktop.DBus.Properties.Get "
"org.kde.KMix.Control volume"
msgstr ""
"qdbus org.kde.kmix /Mixers/0/Master_0 org.freedesktop.DBus.Properties.Get "
"org.kde.KMix.Control volume"

#. Tag: para
#: index.docbook:417
#, no-c-format
msgid "Setting volume level (0-100%):"
msgstr "Postavljanje jačine zvuka (0%–100%):"

#. Tag: programlisting
#: index.docbook:419
#, no-c-format
msgid ""
"qdbus org.kde.kmix /Mixers/0/Master_0 org.freedesktop.DBus.Properties.Set "
"org.kde.KMix.Control volume 70"
msgstr ""
"qdbus org.kde.kmix /Mixers/0/Master_0 org.freedesktop.DBus.Properties.Set "
"org.kde.KMix.Control volume 70"

