#: index.docbook:784
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>B</keycap></keycombo></"
"shortcut> <guimenu>Bookmarks</guimenu> <guimenuitem>Add Bookmark</"
"guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\"><keycap>Ctrl</keycap><keycap>B</"
