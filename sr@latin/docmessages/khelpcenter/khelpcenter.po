"keycap></keycombo></shortcut> <guimenu>Uređivanje</guimenu> "
"<guimenuitem>Nađi...</guimenuitem>"

#. Tag: para
#: index.docbook:659
#, no-c-format
msgid "Find a word or words in the currently visible page."
msgstr "Traži reč na trenutno vidljivoj stranici."

#. Tag: guimenu
#: index.docbook:671
#, no-c-format
msgid "View"
msgstr "Prikaz"

#. Tag: menuchoice
#: index.docbook:676
#, no-c-format
