#. Tag: title
#: index.docbook:9
#, no-c-format
msgid "General &konqueror; Behavior"
msgstr "Opšte ponašanje <application>K‑osvajača</application>"

#. Tag: author
#: index.docbook:13
#, no-c-format
msgid "&Burkhard.Lueck;"
msgstr ""
"<personname><firstname>Burkhard</firstname> <surname>Lik</surname></"
"personname>"

#. Tag: trans_comment
