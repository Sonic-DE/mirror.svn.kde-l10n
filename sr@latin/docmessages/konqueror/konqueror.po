msgstr ""
"Kako postavljam svoju „domaću“ stranicu — onu koja se učitava po pokretanju?"

#. Tag: para
#: index.docbook:3587
#, no-c-format
msgid ""
"&konqueror; has a <guilabel>Home Folder</guilabel> used in file manager mode "
"and a <guilabel>Home Page</guilabel> used in browser mode."
msgstr ""
"<application>K‑osvajač</application> ima „domaću fasciklu“ u režimu "
"menadžera fajlova, a „domaću stranicu“ u režimu pregledača."

#. Tag: para
#: index.docbook:3590
#, fuzzy, no-c-format
#| msgid ""
#| "To change these settings launch <menuchoice><guimenu>Settings</"
#| "guimenu><guimenuitem>Configure Konqueror</guimenuitem><guilabel>General</"
#| "guilabel></menuchoice>."
