#: org.kde.sweeper.desktop:8
msgctxt "Name"
msgid "Sweeper"
msgstr "Čistač"

#: org.kde.sweeper.desktop:75
msgctxt "GenericName"
msgid "System Cleaner"
msgstr "Čistač sistema"

#: org.kde.sweeper.desktop:142
msgctxt "Comment"
msgid ""
"Helps to clean unwanted traces the user leaves on the system and to regain "
"disk space removing unused temporary files"
msgstr ""
"Pomaže u otklanjanju neželjenih tragova koje korisnik ostavi na sistemu i "
"oslobađanju prostora na disku brisanjem privremenih fajlova"
