msgid "Features:"
msgstr "Mogućnosti:"

#. (itstool) path: ul/li
#: org.kde.palapeli.appdata.xml:20
msgid "Create and play puzzles ranging from 4 to 10,000 pieces"
msgstr "stvaranje i igranje slagalica od 4 do 10.000 delova"

#. (itstool) path: ul/li
#: org.kde.palapeli.appdata.xml:21
msgid "Piece-holders for helping solve large puzzles"
msgstr "držači delova kao pomoć u rešavanju velikih slagalica"
