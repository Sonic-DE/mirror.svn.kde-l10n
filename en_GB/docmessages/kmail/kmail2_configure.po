#: configure.docbook:3092
#, no-c-format
msgid ""
"The trash folder is cleared of messages when you quit &kmail; if this option "
"is selected."
msgstr ""
"The wastebin folder is cleared of messages when you quit &kmail; if this "
"option is selected."

#. Tag: guilabel
