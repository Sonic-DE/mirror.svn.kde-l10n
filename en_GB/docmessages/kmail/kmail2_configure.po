msgid "Attempt decryption of encrypted messages when viewing"
msgstr "Automatically encrypt messages whenever possible"

#. Tag: para
#: configure.docbook:2145
#, no-c-format
msgid ""
"By default, &kmail; will automatically attempt to decrypt encrypted messages "
"when you view them. If you prefer to do this manually, unselect this option."
msgstr ""

#. Tag: guilabel
#: configure.docbook:2153
#, fuzzy, no-c-format
#| msgid "Automatically import keys and certificates"
