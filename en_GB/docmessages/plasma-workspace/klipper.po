msgid "Introduction"
msgstr "Introduction"

#. Tag: para
#: index.docbook:50
#, fuzzy, no-c-format
msgid ""
"&klipper; is the &plasma; clipboard utility. It stores clipboard history, "
"and allows you to link clipboard contents to application actions. Please "
"report any problems or feature requests to <ulink url=\"http://bugs.kde.org"
"\">KDEs bugzilla</ulink>."
msgstr ""
"&klipper; is the &kde; clipboard utility. It stores clipboard history, and "
"allows you to link clipboard contents to application actions. Please report "
"any problems or feature requests to Carsten Pfeiffer &Carsten.Pfeiffer.mail;."

