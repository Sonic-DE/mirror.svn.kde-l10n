#: data/org.kde.yakuake.desktop:2
msgctxt "Name"
msgid "Yakuake"
msgstr "याकुआके"

#: data/org.kde.yakuake.desktop:65
msgctxt "GenericName"
msgid "Drop-down Terminal"
msgstr "ड्रॉप-डाउन टर्मिनल्"

#: data/org.kde.yakuake.desktop:128
msgctxt "Comment"
msgid "A drop-down terminal emulator based on KDE Konsole technology."
msgstr "KDE Konsole प्रौद्योगिक्याः आधारेण एकः ड्रॉप्-डाउन टर्मिनल् एमुलेटरः ।"

#: data/yakuake.notifyrc:4
msgctxt "Comment"
msgid "Yakuake"
msgstr "याकुआके"

#: data/yakuake.notifyrc:63
msgctxt "Name"
msgid "Silence detected"
msgstr "मौनं ज्ञातम्"

#: data/yakuake.notifyrc:118
msgctxt "Comment"
msgid "Silence detected in a monitored terminal or session"
msgstr "निरीक्षिते टर्मिनले अथवा सत्रे मौनं ज्ञातम्"

#: data/yakuake.notifyrc:175
msgctxt "Name"
msgid "Activity detected"
msgstr "क्रियाकलापः ज्ञातः"

#: data/yakuake.notifyrc:230
msgctxt "Comment"
msgid "Activity detected in a monitored terminal or session"
msgstr "निरीक्षिते टर्मिनले अथवा सत्रे ज्ञायते क्रियाकलापः"

#: data/yakuake.notifyrc:287
msgctxt "Name"
msgid "Bell in Visible Session"
msgstr "दृश्यसत्रे घण्टा"

#: data/yakuake.notifyrc:344
msgctxt "Comment"
msgid "Bell emitted within a visible session"
msgstr "दृश्यमानसत्रस्य अन्तः बेलः उत्सर्जितवान्"

#: data/yakuake.notifyrc:404
msgctxt "Name"
msgid "Bell in Non-Visible Session"
msgstr "अदृश्यसत्रे घण्टा"

#: data/yakuake.notifyrc:461
msgctxt "Comment"
msgid "Bell emitted within a non-visible session"
msgstr "अदृश्यसत्रस्य अन्तः बेलः उत्सर्जितवान्"
