#: templates/cpp-plasmoid6/cpp-plasmoid6.kdevtemplate:2
msgctxt "Name"
msgid "Plasma QML/C++ Applet (Qt6)"
msgstr "Plasma QML/C++ Applet (Qt6)"

#: templates/cpp-plasmoid6/cpp-plasmoid6.kdevtemplate:44
msgctxt "Comment"
msgid ""
"A Plasma Applet template written in an hybrid mix of QML and C++: a Plasma "
"applet template displaying a SVG picture and a text"
msgstr ""
"QML तथा C++ इत्येतयोः संकरमिश्रणे लिखितः Plasma Applet ढांचा: SVG चित्रं पाठ्यं च "
"प्रदर्शयति इति Plasma applet ढांचा"

#: templates/plasma6-wallpaper/plasma6-wallpaper.kdevtemplate:2
msgctxt "Name"
msgid "Simple Plasma Wallpaper (Qt6)"
msgstr "सरल प्लाज्मा दीवार्पत्तिः (Simple Plasma Wallpaper) (Qt6)"

#: templates/plasma6-wallpaper/plasma6-wallpaper.kdevtemplate:45
msgctxt "Comment"
msgid ""
"Simple Plasma Wallpaper template: a Plasma wallpaper template displaying a "
"text"
msgstr "सरलं प्लाज्मा दीवार्पत्तिः ढांचा: पाठं प्रदर्शयन् एकः प्लाज्मा दीवार्पत्तिः ढांचा"

#: templates/plasma6-wallpaper-with-qml-extension/plasma6-wallpaper-with-qml-extension.kdevtemplate:2
msgctxt "Name"
msgid "Simple Plasma Wallpaper with QML extension (Qt6)"
msgstr "साधारण प्लाज्मा दीवार्पत्तिः च QML प्रसारणः (Qt6)"

#: templates/plasma6-wallpaper-with-qml-extension/plasma6-wallpaper-with-qml-extension.kdevtemplate:44
msgctxt "Comment"
msgid ""
"A Plasma wallpaper which uses custom API provided by an own QML extension "
"plugin"
msgstr ""
"एकः प्लाज्मा दीवार्पत्तिः यः स्वस्य QML विस्तारप्लगिन् द्वारा प्रदत्तस्य अनुकूलनीयः API "
"इत्यस्य उपयोगं करोति"

#: templates/qml-plasmoid6/qml-plasmoid6.kdevtemplate:2
msgctxt "Name"
msgid "Plasma QML Applet (Qt6)"
msgstr "Plasma QML Applet (Qt6)"

#: templates/qml-plasmoid6/qml-plasmoid6.kdevtemplate:45
msgctxt "Comment"
msgid ""
"Plasma QML Applet template: a Plasma applet template displaying a SVG "
"picture and a text"
msgstr ""
"PLasma QML Applet ढांचा : SVG चित्रं पाठ्यम् च प्रदर्शयति इति PLasma Applet ढांचा"

#~ msgctxt "Name"
#~ msgid "Plasma QML Applet with QML extension (Qt6)"
#~ msgstr "QML विस्तारयुक्तः Plasma QML Applet (Qt6)"

#~ msgctxt "Comment"
#~ msgid ""
#~ "A template for a Plasma applet which uses custom API provided by an own "
#~ "QML extension plugin"
#~ msgstr ""
#~ "Plasma applet कृते एकः ढांचा यः स्वस्य QML विस्तारप्लगिन् द्वारा प्रदत्तस्य अनुकूलनीयः "
#~ "API इत्यस्य उपयोगं करोति"
