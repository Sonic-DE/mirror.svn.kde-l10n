#: org.kde.tokodon.desktop:4 src/tokodon.notifyrc:5
msgctxt "Name"
msgid "Tokodon"
msgstr "टोकोडोन्"

#: org.kde.tokodon.desktop:44
msgctxt "GenericName"
msgid "Browse the Fediverse"
msgstr "Fediverse ब्राउज् कुर्वन्तु"

#: org.kde.tokodon.desktop:76
msgctxt "Comment"
msgid "Client for the Mastodon"
msgstr "मस्टोडन् कृते ग्राहकः"

#: src/tokodon.notifyrc:46
msgctxt "Comment"
msgid "A client for Mastodon, the decentralized social media"
