#: src/tokodon.notifyrc:82
msgctxt "Name"
msgid "Favorite"
msgstr "प्रिय"

#: src/tokodon.notifyrc:118
msgctxt "Comment"
msgid "Someone favorited your post"
msgstr "भवतः पोस्ट् कश्चन प्रियं कृतवान्"

#: src/tokodon.notifyrc:154
msgctxt "Name"
msgid "Boost"
msgstr "संवेग"

#: src/tokodon.notifyrc:188
msgctxt "Comment"
msgid "Someone boosted your post"
msgstr "कश्चन भवतः पोस्ट् बूस्ट् कृतवान्"

