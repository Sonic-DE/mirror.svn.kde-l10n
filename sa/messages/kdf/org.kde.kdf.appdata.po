#. (itstool) path: component/name
#: org.kde.kdf.appdata.xml:9
msgid "KDiskFree"
msgstr "KDiskFree इति"

#. (itstool) path: component/summary
#: org.kde.kdf.appdata.xml:10
msgid "View Disk Usage"
msgstr "डिस्कस्य उपयोगं पश्यन्तु"

#. (itstool) path: description/p
#: org.kde.kdf.appdata.xml:12
msgid ""
"KDiskFree displays the available file devices (hard drive partitions, floppy "
"and CD drives, etc.) along with information on their capacity, free space, "
"type and mount point. It also allows you to mount and unmount drives and "
"view them in a file manager."
msgstr ""
"KDiskFree उपलब्धानि सञ्चिकायन्त्राणि (हार्डड्राइवविभाजनं, फ्लॉपी तथा सीडीड्राइव् "
"इत्यादयः) तेषां क्षमता, मुक्तस्थानं, प्रकारः, माउण्ट्-बिन्दुः च इति सूचनाभिः सह प्रदर्शयति । "
"इदं भवन्तं ड्राइव्-माउण्ट्-अनमाउण्ट्-करणं च सञ्चिका-प्रबन्धके द्रष्टुं च शक्नोति ।"

