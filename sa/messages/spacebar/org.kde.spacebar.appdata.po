#. (itstool) path: component/name
#: org.kde.spacebar.appdata.xml:4
msgid "Spacebar"
msgstr "स्पेसबार"

#. (itstool) path: component/summary
#: org.kde.spacebar.appdata.xml:5
msgid "SMS/MMS messaging client"
msgstr "SMS/MMS सन्देशप्रसारणग्राहकः"

#. (itstool) path: description/p
#: org.kde.spacebar.appdata.xml:12
msgid ""
"Spacebar is a SMS/MMS messaging client. It allows you to send text messages, "
"pictures and other files over a cellular network."
msgstr ""
"स्पेसबार एकः SMS/MMS सन्देशप्रसारणग्राहकः अस्ति । एतेन भवन्तः सेलुलरजालद्वारा पाठसन्देशान्, "
"चित्राणि, अन्यसञ्चिकाः च प्रेषयितुं शक्नुवन्ति ।"
