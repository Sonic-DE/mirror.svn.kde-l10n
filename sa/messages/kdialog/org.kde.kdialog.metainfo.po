#. (itstool) path: component/name
#: org.kde.kdialog.metainfo.xml:6
msgid "KDialog"
msgstr "केसंवादः"

#. (itstool) path: component/summary
#: org.kde.kdialog.metainfo.xml:7
msgid "Display dialog boxes from shell scripts"
msgstr "शेल् स्क्रिप्ट् तः संवादपेटिकाः प्रदर्शयन्तु"

#. (itstool) path: description/p
#: org.kde.kdialog.metainfo.xml:9
msgid ""
"KDialog allows you to display dialog boxes from shell scripts. The syntax is "
"very much inspired from the \"dialog\" command (which shows text mode "
"dialogs)."
msgstr ""
"KDialog इत्यनेन शेल् स्क्रिप्ट् तः संवादपेटिकाः प्रदर्शयितुं शक्यन्ते । वाक्यविन्यासः \"dialog"
"\" आदेशात् (यत् पाठविधिसंवादं दर्शयति) अतीव प्रेरितम् अस्ति ।"
