msgid "K3b"
msgstr "K3b"

#: src/k3b.notifyrc:4
msgctxt "Comment"
msgid "K3b"
msgstr "K3b"

#: src/k3b.notifyrc:71
msgctxt "Name"
msgid "Process successful"
msgstr "प्रक्रिया सफला"

#: src/k3b.notifyrc:136
msgctxt "Comment"
msgid "Process successfully finished"
msgstr "प्रक्रिया सफलतया समाप्तवती"

#: src/k3b.notifyrc:202
msgctxt "Name"
msgid "Process error"
msgstr "प्रक्रियादोषः"

#: src/k3b.notifyrc:267
msgctxt "Comment"
msgid "Process finished with errors"
msgstr "प्रक्रिया त्रुटिभिः सह समाप्तवती"

#: src/k3b.notifyrc:336
msgctxt "Name"
msgid "Waiting for medium"
msgstr "मध्यमस्य प्रतीक्षां कुर्वन्"

#: src/k3b.notifyrc:400
msgctxt "Comment"
msgid "The user needs to insert a medium"
msgstr "उपयोक्त्रेण माध्यमं सम्मिलितं कर्तव्यम्"

#: src/k3b.notifyrc:466
msgctxt "Name"
msgid "Busy"
msgstr "व्यस्तः"

#: src/k3b.notifyrc:521
msgctxt "Comment"
msgid "K3b is currently busy and cannot start any other operations"
msgstr "K3b सम्प्रति व्यस्तः अस्ति, अन्यत् किमपि कार्यं आरभुं न शक्नोति"

#: src/k3b.notifyrc:577
msgctxt "Name"
msgid "No problems found"
msgstr "कोऽपि समस्याः न प्राप्ताः"

#: src/k3b.notifyrc:630
msgctxt "Comment"
msgid "No problems found in system configuration"
msgstr "प्रणालीविन्यासे कोऽपि समस्याः न प्राप्यन्ते"

#: src/k3b.notifyrc:686
msgctxt "Name"
msgid "Mount/unmount failed"
msgstr "माउण्ट्/अनमाउण्ट् विफलम् अभवत्"

#: src/k3b.notifyrc:739
msgctxt "Comment"
msgid "Medium cannot be mount or unmounted"
msgstr "मध्यमं माउण्ट् अथवा अनमाउण्ट् कर्तुं न शक्यते"

#: src/k3b.notifyrc:795
msgctxt "Name"
msgid "Track data not found"
msgstr "ट्रैक दत्तांशः न प्राप्तः"

#: src/k3b.notifyrc:848
msgctxt "Comment"
msgid "Track information has not been found in the online database"
msgstr "ऑनलाइन-दत्तांशकोशे ट्रैक-सूचना न प्राप्ता"

