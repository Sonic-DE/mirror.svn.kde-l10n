#: src/org.kde.kapman.desktop:4
msgctxt "Name"
msgid "Kapman"
msgstr "कैपिंग"

#: src/org.kde.kapman.desktop:63
msgctxt "GenericName"
msgid "Pac-Man Clone"
msgstr "पैक-मैन क्लोन"

#: src/org.kde.kapman.desktop:117
msgctxt "Comment"
msgid "Eat pills escaping ghosts"
msgstr "भूतेभ्यः पलायिताः गोलियाः खादन्तु"

#: themes/invisible.desktop:2
msgctxt "Name"
msgid "Invisible"
msgstr "अदृश्यम्"

#: themes/invisible.desktop:59
msgctxt "Description"
msgid ""
"Getting bored with Kapman? More than 100,000 points over level 20? Next "
"step: the invisible maze!"
msgstr ""
"कपमैन इत्यनेन बोरः भवति ? २० स्तरात् एकलक्षाधिकाङ्काः? अग्रिमः सोपानः : अदृश्यः "
"चक्रव्यूहः !"

#: themes/matches.desktop:2
msgctxt "Name"
msgid "Matches"
msgstr "मेलयति"

#: themes/matches.desktop:59
msgctxt "Description"
msgid "A matches drawn maze"
msgstr "एकः मेलः आकृष्टः चक्रव्यूहः"

#: themes/mountain.desktop:2
msgctxt "Name"
msgid "Mountain Adventure"
msgstr "पर्वतसाहसिकम्"

#: themes/mountain.desktop:55
