#. (itstool) path: component/name
#: org.kde.krdc.appdata.xml:4
msgid "KRDC"
msgstr "केआरडीसी"

#. (itstool) path: component/summary
#: org.kde.krdc.appdata.xml:5
msgid "Connect with RDP or VNC to another computer"
msgstr "RDP अथवा VNC इत्यनेन सह अन्यसङ्गणकेन सह सम्बद्धं कुर्वन्तु"

#. (itstool) path: description/p
#: org.kde.krdc.appdata.xml:11
msgid ""
"KRDC is a client application that allows you to view or even control the "
"desktop session on another machine that is running a compatible server. VNC "
"and RDP is supported."
msgstr ""
"KRDC एकः क्लायन्ट् अनुप्रयोगः अस्ति यः भवन्तं अन्यस्मिन् यन्त्रे डेस्कटॉप् सत्रं द्रष्टुं वा "
"नियन्त्रयितुं वा शक्नोति यत् सङ्गतसर्वरं चालयति । VNC तथा RDP समर्थितम् अस्ति।"
