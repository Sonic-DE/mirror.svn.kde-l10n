msgstr "स्क्रीन तालाबद्धा"

#: kscreenlocker.notifyrc:110
msgctxt "Comment"
msgid "The screen has been locked"
msgstr "पटलः ताडितः अस्ति"

#: kscreenlocker.notifyrc:165
msgctxt "Name"
msgid "Screen unlocked"
msgstr "स्क्रीन अनलॉक् अभवत्"

#: kscreenlocker.notifyrc:218
msgctxt "Comment"
msgid "The screen has been unlocked"
msgstr "स्क्रीनः अनलॉक् कृतः अस्ति"
