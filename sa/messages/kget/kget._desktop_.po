#: desktop/kget_download.desktop:13
msgctxt "Name"
msgid "Download with KGet"
msgstr "KGet इत्यनेन सह डाउनलोड् कुर्वन्तु"

#: desktop/org.kde.kget.desktop.cmake:8
msgctxt "Name"
msgid "KGet"
msgstr "केगेट्"

#: desktop/org.kde.kget.desktop.cmake:86
msgctxt "GenericName"
msgid "Download Manager"
msgstr "डाउनलोड प्रबन्धक"

#: desktop/org.kde.kget.desktop.cmake:163
msgctxt "Comment"
msgid "KGet is a versatile and user-friendly download manager"
msgstr "KGet बहुमुखी उपयोक्तृ-अनुकूलः च डाउनलोड्-प्रबन्धकः अस्ति"

#: sounds/kget.notifyrc:4
msgctxt "Comment"
msgid "KGet Download Manager"
msgstr "KGet डाउनलोड प्रबन्धक"

#: sounds/kget.notifyrc:66
msgctxt "Name"
msgid "Transfer Added"
msgstr "स्थानान्तरणम् योजितम्"

#: sounds/kget.notifyrc:127
msgctxt "Comment"
msgid "A new download has been added"
msgstr "नूतनं डाउनलोड् योजितम् अस्ति"

#: sounds/kget.notifyrc:197
msgctxt "Name"
msgid "Download Started"
msgstr "डाउनलोड् आरब्धम्"

#: sounds/kget.notifyrc:260
