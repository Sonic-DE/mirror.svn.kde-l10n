#. (itstool) path: component/name
#: org.kde.knights.appdata.xml:9
msgid "KNights"
msgstr "शूरवीराः"

#. (itstool) path: component/summary
#: org.kde.knights.appdata.xml:10
msgid "Chess game"
msgstr "शतरंजक्रीडा"

#. (itstool) path: description/p
#: org.kde.knights.appdata.xml:12
msgid ""
"KNights is a chess game. As a player, your goal is to defeat your opponent "
"by checkmating their king."
msgstr ""
"नाइट्स् इति शतरंजक्रीडा । क्रीडकत्वेन भवतः लक्ष्यं प्रतिद्वन्द्विनं तेषां राजानं चेकमेट् कृत्वा "
"पराजयितुं भवति ।"

#. (itstool) path: description/p
#: org.kde.knights.appdata.xml:15
msgid "Features:"
msgstr "गुणाः:"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:17
msgid "Local play between two players on the same computer"
msgstr "एकस्मिन् सङ्गणके द्वयोः क्रीडकयोः मध्ये स्थानीयक्रीडा"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:18
msgid "Play against any computer program that supports the XBoard protocol"
msgstr "XBoard प्रोटोकॉल समर्थयति यत्किमपि सङ्गणकप्रोग्रामं तस्य विरुद्धं क्रीडन्तु"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:19
msgid "Play on the Free Internet Chess Server (FICS)"
msgstr "निःशुल्क अन्तर्जालशतरंजसर्वर (FICS) इत्यत्र क्रीडन्तु ।"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:20
msgid "Watching two computer engines play against each other"
msgstr "सङ्गणकयन्त्रद्वयं परस्परं विरुद्धं क्रीडन्तं पश्यन्"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:21
msgid "Support for legal move checking"
msgstr "कानूनी चालपरीक्षणस्य समर्थनम्"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:22
msgid "Markers for possible moves, opponent’s last move and sources of check"
msgstr "सम्भाव्यचरणस्य चिह्नानि, प्रतिद्वन्द्वस्य अन्तिमचरणं, जाँचस्य स्रोतः च"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:23
msgid "Board borders and site notations"
msgstr "बोर्डसीमाः स्थलसंकेताः च"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:24
msgid "Complete time control, with Plasma-styled clocks"
msgstr "सम्पूर्णं समयनियन्त्रणं, प्लाज्मा-शैल्याः घण्टाभिः सह"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:25
msgid ""
"Several themes, with the possibility of downloading new ones from within the "
"program"
msgstr "अनेकाः विषयाः, कार्यक्रमस्य अन्तः नूतनानां अवतरणस्य सम्भावना सह"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:26
msgid "Animated moves (configurable)"
msgstr "एनिमेटेड चालाः (विन्यासयोग्यः)"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:27
msgid ""
"Views for playing on a chess server, including a seek graph, text console, "
"and chat widget"
msgstr ""
"शतरंजसर्वरस्य क्रीडनार्थं दृश्यानि, यत्र seek graph, text console, chat widget च सन्ति"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:28
msgid "Option to undo and redo moves"
msgstr "पूर्ववतीकरणं पुनः कर्तुं च विकल्पः चालयति"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:29
msgid "Graphic interface for making and receiving offers from remote players"
msgstr "दूरस्थक्रीडकानां प्रस्तावान् कर्तुं प्राप्तुं च ग्राफिक् इन्टरफेस्"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:30
msgid ""
"Support for the UCI protocol (used by Stockfish, Chessbase, and many others)"
msgstr "UCI प्रोटोकॉलस्य समर्थनम् (Stockfish, Chessbase, इत्यादिभिः अनेकैः उपयुज्यते)"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:31
msgid "Support for saving and loading Portable game notation (PGN) files"
msgstr "पोर्टेबल गेम नोटेशन (PGN) सञ्चिकानां रक्षणं लोडिंग् च समर्थनम्"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:32
msgid "Speak opponent’s moves"
msgstr "प्रतिद्वन्द्वस्य चालाः वदतु"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:33
msgid "Ability to control the program via a D-Bus interface"
msgstr "D-Bus अन्तरफलकस्य माध्यमेन कार्यक्रमं नियन्त्रयितुं क्षमता"

#. (itstool) path: screenshot/caption
#: org.kde.knights.appdata.xml:38
msgid "Knights, chess game"
msgstr "शूरवीराः, शतरंजक्रीडा"

#. (itstool) path: screenshot/caption
#: org.kde.knights.appdata.xml:42
msgid "Main Window - Human vs. Chess Engine"
msgstr "मुख्य खिडकी - मानव बनाम शतरंज इञ्जिन"

#. (itstool) path: screenshot/caption
#: org.kde.knights.appdata.xml:46
msgid "Main Window - Chess Engine vs. Chess Engine"
msgstr "मुख्य खिडकी - शतरंज इञ्जिन बनाम शतरंज इञ्जिन"

#. (itstool) path: screenshot/caption
#: org.kde.knights.appdata.xml:50
msgid "\"New Game\" Dialog"
msgstr "\"नव खेल\" संवाद"

#. (itstool) path: screenshot/caption
#: org.kde.knights.appdata.xml:54
msgid "Auto-Detection of Chess Engines"
msgstr "शतरंजस्य इञ्जिनस्य स्वतः अन्वेषणम्"

#. (itstool) path: screenshot/caption
#: org.kde.knights.appdata.xml:58
msgid "Playing online - FICS Console"
msgstr "ऑनलाइन क्रीडनम् - FICS Console"

#. (itstool) path: screenshot/caption
#: org.kde.knights.appdata.xml:62
msgid "Playing online - graphical Seek-Graph"
msgstr "ऑनलाइन क्रीडा - चित्रात्मकं Seek-Graph"

