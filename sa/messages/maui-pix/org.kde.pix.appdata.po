#. (itstool) path: component/name
#: org.kde.pix.appdata.xml:7
msgid "Pix"
msgstr "पिक्स्"

#. (itstool) path: component/summary
#: org.kde.pix.appdata.xml:8
msgid "Image Gallery"
msgstr "चित्रसङ्ग्रहालयः"

#. (itstool) path: description/p
#: org.kde.pix.appdata.xml:14
msgid ""
"Pix is an image gallery and image viewer. Pix can be used to open images "
"with other applications like an image editor, add tags to the files, add "
"annotations to pictures, rotate and share them."
msgstr ""
"पिक्स् इति चित्रसङ्ग्रहालयः, चित्रदर्शकः च अस्ति । Pix इत्यस्य उपयोगेन अन्यैः अनुप्रयोगैः सह "
"चित्राणि उद्घाटयितुं, सञ्चिकासु टैग् योजयितुं, चित्रेषु टिप्पणीं योजयितुं, परिभ्रमितुं, साझां कर्तुं "
"च शक्यते ।"

#. (itstool) path: screenshot/caption
#: org.kde.pix.appdata.xml:23
msgid "The Pix music player"
msgstr "पिक्स संगीतवादकः"
