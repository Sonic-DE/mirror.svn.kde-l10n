#: kwrited-autostart.desktop:2
msgctxt "Name"
msgid "KDE Write Daemon"
msgstr "KDE Write Daemon"

#: kwrited-autostart.desktop:91
msgctxt "Comment"
msgid "Watch for messages from local users sent with write(1) or wall(1)"
msgstr "Write(1) अथवा wall(1) इत्यनेन सह प्रेषितानां स्थानीयप्रयोक्तृणां सन्देशान् पश्यन्तु ।"

#: kwrited.notifyrc:3
msgctxt "Name"
msgid "Local System Message Service"
msgstr "स्थानीय प्रणाली सन्देश सेवा"

#: kwrited.notifyrc:48
msgctxt "Comment"
msgid "Local system message service"
msgstr "स्थानीय प्रणाली सन्देश सेवा"

#: kwrited.notifyrc:117
msgctxt "Name"
msgid "New message received"
msgstr "नूतनः सन्देशः प्राप्तः"

#: kwrited.notifyrc:192
msgctxt "Comment"
msgid "The daemon received a new message sent with wall(1) or write(1)"
msgstr "Daemon wall(1) अथवा write(1) इत्यनेन सह प्रेषितः नूतनः सन्देशः प्राप्तवान् ।"
