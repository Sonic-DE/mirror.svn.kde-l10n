#: org.kde.sweeper.desktop:8
msgctxt "Name"
msgid "Sweeper"
msgstr "स्वीपर"

#: org.kde.sweeper.desktop:75
msgctxt "GenericName"
msgid "System Cleaner"
msgstr "सिस्टम क्लीनर"

#: org.kde.sweeper.desktop:142
msgctxt "Comment"
msgid ""
"Helps to clean unwanted traces the user leaves on the system and to regain "
"disk space removing unused temporary files"
msgstr ""
"उपयोक्ता प्रणाल्यां त्यजति अवांछित-लेशान् स्वच्छं कर्तुं तथा च अप्रयुक्तानि अस्थायी-सञ्चिकाः "
"निष्कास्य डिस्क-स्थानं पुनः प्राप्तुं साहाय्यं करोति"
