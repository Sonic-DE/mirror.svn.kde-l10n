#: src/org.kde.kgoldrunner.desktop:2
msgctxt "Name"
msgid "KGoldrunner"
msgstr "केगोल्डरुनर"

#: src/org.kde.kgoldrunner.desktop:73
msgctxt "GenericName"
msgid "Hunt Gold, Dodge Enemies and Solve Puzzles"
msgstr "सुवर्णस्य मृगया, शत्रून् चकमा, पहेलीनां समाधानं च कुर्वन्तु"

#: src/org.kde.kgoldrunner.desktop:127
msgctxt "Comment"
msgid "A game of action and puzzle-solving"
msgstr "क्रियायाः प्रहेलिकासमाधानस्य च क्रीडा"

#: themes/black-on-white.desktop:2
msgctxt "Name"
msgid "Black on White"
msgstr "श्वेतस्य उपरि कृष्णः"

#: themes/black-on-white.desktop:60
msgctxt "Description"
msgid "A monochrome, black on white theme for KGoldrunner"
msgstr "KGoldrunner कृते एकवर्णीयः, श्वेतस्य उपरि कृष्णः विषयः"

#: themes/default.desktop:2
msgctxt "Name"
msgid "KGoldRunner Default"
msgstr "KGoldRunner पूर्वनिर्धारित"

#: themes/default.desktop:59
msgctxt "Description"
msgid "A light and clean theme for KDE4"
msgstr "KDE4 कृते लघुः स्वच्छः च विषयः"

#: themes/egypt.desktop:2
msgctxt "Name"
msgid "The Treasure of Egypt"
msgstr "मिस्रदेशस्य निधिः"

#: themes/egypt.desktop:57
msgctxt "Description"
msgid "Help Matt Goldrunner escape the traps of ancient Egypt."
msgstr "प्राचीनमिस्रस्य जालेभ्यः पलायनार्थं मैट् गोल्डरनर् इत्यस्य सहायतां कुर्वन्तु।"

#: themes/kgr_geek.desktop:2
msgctxt "Name"
msgid "Geek City"
msgstr "गीक सिटी"

#: themes/kgr_geek.desktop:56
msgctxt "Description"
msgid "The hero is trapped inside a computer."
msgstr "नायकः सङ्गणकस्य अन्तः फसति।"

#: themes/nostalgia-blues.desktop:2
msgctxt "Name"
msgid "Nostalgia Blues"
msgstr "नॉस्टेलजिया ब्लूज"

#: themes/nostalgia-blues.desktop:54
msgctxt "Description"
msgid ""
"A theme for KGoldrunner that brings back that 8-bit look... now in blue!"
msgstr "KGoldrunner कृते एकः विषयः यः तत् 8-बिट् रूपं पुनः आनयति... अधुना नीलवर्णे!"

#: themes/nostalgia.desktop:2
msgctxt "Name"
msgid "Nostalgia"
msgstr "विषादः"

#: themes/nostalgia.desktop:58
msgctxt "Description"
msgid "A scalable theme for KGoldrunner that brings back that 8-bit look..."
msgstr "KGoldrunner कृते एकः स्केल-करणीयः विषयः यः तत् 8-बिट्-रूपं पुनः आनयति..."
