#: src/libkleopatrarc.desktop:385 src/libkleopatrarc-win32.desktop:247
msgctxt "Description"
msgid ""
"Certificates that are invalid because they have expired (except disabled "
"ones)"
msgstr "ये प्रमाणपत्राणि अमान्यानि यतः तेषां अवधिः समाप्तः अस्ति (अक्षमान् विहाय)"

