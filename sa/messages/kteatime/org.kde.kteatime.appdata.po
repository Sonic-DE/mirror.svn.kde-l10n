#. (itstool) path: component/name
#: org.kde.kteatime.appdata.xml:9
msgid "KTeaTime"
msgstr "KTeaTime इति"

#. (itstool) path: component/summary
#: org.kde.kteatime.appdata.xml:10
msgid "Tea Cooker"
msgstr "चायपाककम्"

#. (itstool) path: description/p
#: org.kde.kteatime.appdata.xml:12
msgid ""
"KTeaTime is a handy timer for steeping tea. No longer will you have to guess "
"at how long it takes for your tea to be ready. Simply select the type of tea "
"you have, and it will alert you when the tea is ready to drink."
msgstr ""
"KTeaTime चायस्य डुबकी मारयितुं सुलभः समयनिर्धारकः अस्ति । न पुनः भवता अनुमानं कर्तव्यं "
"भविष्यति यत् भवतः चायस्य सज्जतायै कियत्कालं यावत् समयः भवति । केवलं भवतः समीपे चायस्य "
"प्रकारं चिनोतु, तदा चायस्य पेयस्य सज्जता कदा चायः भवन्तं सचेष्टयिष्यति ।"
