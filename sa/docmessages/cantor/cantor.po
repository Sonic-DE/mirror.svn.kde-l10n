#, no-c-format
msgid ""
"<screeninfo>Screenshot of the &cantor; matrix creation dialog</screeninfo>"
msgstr "<screeninfo>&cantor; आकृतिनिर्माणसंवादः</screeninfo>"

#. Tag: phrase
#: index.docbook:384
#, no-c-format
msgid "<phrase>Screenshot of the &cantor; matrix creation dialog</phrase>"
msgstr "<phrase>स्क्रीनशॉट् इत्यस्य &cantor; आकृतिनिर्माणसंवादः</phrase>"

#. Tag: para
#: index.docbook:388
#, no-c-format
msgid ""
"This dialog can be used to input matrices. You can define matrix dimensions "
"and its elements."
msgstr ""
"एतत् संवादं मैट्रिक्स-निवेशनार्थं उपयोक्तुं शक्यते । भवन्तः matrix dimensions तस्य एलिमेण्ट् च "
"परिभाषितुं शक्नुवन्ति ।"

#. Tag: para
#: index.docbook:391
#, no-c-format
msgid ""
"It is possible to navigate between cells quickly during input using the "
"&Tab; key."
msgstr "&Tab; कुंजी।"

#. Tag: title
#: index.docbook:396
#, no-c-format
msgid "Matrix operation dialog"
msgstr "मैट्रिक्स संचालन संवाद"

#. Tag: screeninfo
#: index.docbook:398
#, no-c-format
msgid "<screeninfo>Screenshot of the &cantor; matrix input dialog</screeninfo>"
msgstr "<screeninfo>&cantor; matrix input dialog</screeninfo> इति"

#. Tag: phrase
#: index.docbook:404
#, no-c-format
msgid "<phrase>Screenshot of the &cantor; matrix input dialog</phrase>"
msgstr "<phrase>स्क्रीनशॉट् इत्यस्य &cantor; matrix input dialog</phrase> इति"

#. Tag: para
#: index.docbook:408
#, no-c-format
msgid ""
"This dialog allows entering name of the matrix to compute its eigenvectors, "
"eigenvalues or invert matrix. The default value (<userinput>%</userinput>) "
"is used to refer to the previous result of calculation or input."
msgstr ""
"एषः संवादः तस्य eigenvectors, eigenvalues अथवा invert matrix इत्यस्य गणनां कर्तुं "
"matrix इत्यस्य नाम प्रविष्टुं शक्नोति । पूर्वनिर्धारितं मूल्यं (<userinput>%</userinput>) "
"गणनायाः अथवा निवेशस्य पूर्वफलस्य सन्दर्भार्थं उपयुज्यते ।"

#. Tag: title
#: index.docbook:413
#, no-c-format
msgid "Differentiation dialog"
msgstr "भेदसंवादः"

#. Tag: screeninfo
#: index.docbook:415
#, no-c-format
msgid ""
"<screeninfo>Screenshot of the &cantor; differentiation dialog</screeninfo>"
msgstr "<screeninfo>&cantor; भेदसंवादः</screeninfo> इति"

#. Tag: phrase
#: index.docbook:421
#, no-c-format
msgid "<phrase>Screenshot of the &cantor; differentiation dialog</phrase>"
msgstr "<phrase>स्क्रीनशॉट् इत्यस्य &cantor; भेदसंवाद</phrase> इति"

#. Tag: para
#: index.docbook:425
#, no-c-format
msgid ""
"This dialog allows entering expression of the function to differentiate, the "
"name of the variable and the order of derivative."
msgstr ""
"अयं संवादः भेदं कर्तुं फंक्शन् इत्यस्य अभिव्यक्तिं, चरस्य नाम, व्युत्पन्नस्य क्रमं च प्रविष्टुं शक्नोति ।"

#. Tag: title
#: index.docbook:430
#, no-c-format
msgid "Integration dialog"
msgstr "एकीकरणसंवादः"

#. Tag: screeninfo
#: index.docbook:432
#, no-c-format
msgid "<screeninfo>Screenshot of the &cantor; integration dialog</screeninfo>"
msgstr "<screeninfo>&cantor; एकीकरणसंवादः</screeninfo>"

#. Tag: phrase
#: index.docbook:438
#, no-c-format
msgid "<phrase>Screenshot of the &cantor; integration dialog</phrase>"
msgstr "<phrase>स्क्रीनशॉट् इत्यस्य &cantor; एकीकरणसंवाद</phrase>"

#. Tag: para
#: index.docbook:442
#, no-c-format
msgid ""
"This dialog allows entering expression of the function to integrate, the "
"name of the variable and the limits of integration (for the definite "
"integral)."
msgstr ""
"अयं संवादः एकीकृत्य कार्यस्य अभिव्यक्तिं, चरस्य नाम, एकीकरणस्य सीमाः च (निश्चित अभिन्नस्य "
"कृते) प्रविष्टुं अनुमतिं ददाति ।"

#. Tag: title
#: index.docbook:447
#, no-c-format
msgid "Solve equations dialog"
msgstr "समीकरणसंवादस्य समाधानं कुर्वन्तु"

#. Tag: screeninfo
#: index.docbook:449
#, no-c-format
msgid ""
"<screeninfo>Screenshot of the &cantor; solve equation dialog</screeninfo>"
msgstr "<screeninfo>&cantor; समीकरणसंवादं समाधानं</screeninfo>"

#. Tag: phrase
#: index.docbook:455
#, no-c-format
msgid "<phrase>Screenshot of the &cantor; solve equation dialog</phrase>"
msgstr "<phrase>स्क्रीनशॉट् इत्यस्य &cantor; solve equation dialog</phrase> इति"

#. Tag: para
#: index.docbook:459
#, no-c-format
msgid ""
"This dialog allows entering equations to solve (each equation in a separate "
"line) and the variables to determine (separated by the comma)."
msgstr ""
"अयं संवादः समीकरणानां समाधानार्थं (प्रत्येकं समीकरणं पृथक् रेखायां) तथा च चरानाम् निर्धारणाय "
"(अल्पविरामेन पृथक्कृताः) प्रविष्टुं अनुमतिं ददाति ।"

#. Tag: title
#: index.docbook:464
#, no-c-format
msgid "Package import dialog"
msgstr "संकुल आयातसंवादः"

#. Tag: screeninfo
#: index.docbook:466
#, no-c-format
msgid ""
"<screeninfo>Screenshot of the &cantor; package import dialog</screeninfo>"
msgstr "<screeninfo>&cantor; संकुल आयातसंवादः</screeninfo>"

#. Tag: phrase
#: index.docbook:472
#, no-c-format
msgid "<phrase>Screenshot of the &cantor; package import dialog</phrase>"
msgstr "<phrase>स्क्रीनशॉट् इत्यस्य &cantor; संकुल आयातसंवादः</phrase>"

#. Tag: para
#: index.docbook:476
#, no-c-format
msgid ""
"This dialog allows entering name of the package to import (&eg; "
"<userinput>numpy</userinput> for Python)."
msgstr ""
"एषः संवादः आयातार्थं संकुलस्य नाम प्रविष्टुं शक्नोति (&eg; <userinput>numpy</userinput> "
"पायथन् कृते) ।"

#. Tag: title
#: index.docbook:481
#, no-c-format
msgid "Plot dialog"
msgstr "प्लॉट संवाद"

#. Tag: screeninfo
#: index.docbook:483
#, no-c-format
msgid ""
"<screeninfo>Screenshot of the &cantor; plot dialog (Functions tab)</"
"screeninfo>"
msgstr "<screeninfo>&cantor; plot dialog (Functions tab)</screeninfo> इति"

#. Tag: phrase
#: index.docbook:489
#, no-c-format
msgid "<phrase>Screenshot of the &cantor; plot dialog (Functions tab)</phrase>"
msgstr ""
"<phrase>स्क्रीनशॉट् इत्यस्य &cantor; plot dialog (Functions tab)</phrase> इति"

#. Tag: para
#: index.docbook:493
#, no-c-format
msgid ""
"The options of this dialog are separated into two groups using tabs. The "
"<guilabel>Functions</guilabel> tab allows entering functions to plot."
msgstr ""
"अस्य संवादस्य विकल्पाः ट्याब्स् इत्यस्य उपयोगेन द्वयोः समूहयोः विभक्ताः सन्ति । "
"<guilabel>Functions</guilabel> ट्याब् इत्यनेन फंक्शन्स् प्रविष्टुं प्लॉट् कर्तुं शक्यते ।"

#. Tag: para
#: index.docbook:496
#, no-c-format
msgid ""
"To enter new function click on the <guibutton>Add</guibutton>. Double-click "
"on the <guilabel>Title</guilabel> cell and enter the title, then double-"
"click on the <guilabel>Expression</guilabel> cell and enter the function "
"expression."
msgstr ""
"नूतनं कार्यं प्रविष्टुं <guibutton>Add</guibutton> इत्यत्र नुदन्तु । <guilabel>Title</"
"guilabel> कोष्ठके द्विवारं क्लिक् कृत्वा शीर्षकं प्रविशन्तु, ततः <guilabel>Expression</"
"guilabel> कोष्ठके द्विवारं क्लिक् कृत्वा function expression प्रविशन्तु ।"

#. Tag: screeninfo
#: index.docbook:500
#, no-c-format
msgid ""
"<screeninfo>Screenshot of the &cantor; plot dialog (Options tab)</screeninfo>"
msgstr "<screeninfo>&cantor; plot dialog (Options tab)</screeninfo> इति"

#. Tag: phrase
#: index.docbook:506
#, no-c-format
msgid "<phrase>Screenshot of the &cantor; plot dialog (Options tab)</phrase>"
msgstr "<phrase>स्क्रीनशॉट् इत्यस्य &cantor; plot dialog (Options tab)</phrase> इति"

#. Tag: para
#: index.docbook:510
#, no-c-format
msgid ""
"The <guilabel>Options</guilabel> tab is used to define plot and legend "
"options. You can fine-tune almost every plot option to obtain the pleasant "
"look of your figure."
msgstr ""
"<guilabel>विकल्पाः</guilabel> ट्याब् प्लॉट् तथा लेजेण्ड् विकल्पान् परिभाषितुं उपयुज्यते । "
"भवन्तः स्वस्य आकृतिस्य सुखदरूपं प्राप्तुं प्रायः प्रत्येकं कथानकविकल्पं सूक्ष्मरूपेण स्थापयितुं शक्नुवन्ति "
"।"

#. Tag: title
#: index.docbook:515
#, no-c-format
msgid "Plot 2D dialog"
msgstr "प्लॉट 2D संवाद"

#. Tag: screeninfo
#: index.docbook:517
#, no-c-format
msgid "<screeninfo>Screenshot of the &cantor; plot 2D dialog</screeninfo>"
msgstr "<screeninfo>&cantor; प्लॉट् 2D संवाद</screeninfo>"

#. Tag: phrase
#: index.docbook:523
#, no-c-format
msgid "<phrase>Screenshot of the &cantor; plot 2D dialog</phrase>"
msgstr "<phrase>स्क्रीनशॉट् इत्यस्य &cantor; प्लॉट 2D संवाद</phrase>"

#. Tag: para
#: index.docbook:527
#, no-c-format
msgid ""
"This dialog allows entering expression of the function, its variable and the "
"limits for this variable."
msgstr ""
"अयं संवादः फंक्शन् इत्यस्य अभिव्यक्तिं, तस्य चरस्य, अस्य चरस्य सीमां च प्रविष्टुं शक्नोति ।"

#. Tag: title
#: index.docbook:532
#, no-c-format
msgid "Plot 3D dialog"
msgstr "प्लॉट 3D संवाद"

#. Tag: screeninfo
#: index.docbook:534
#, no-c-format
msgid "<screeninfo>Screenshot of the &cantor; plot 3D dialog</screeninfo>"
msgstr "<screeninfo>&cantor; प्लॉट् 3D संवाद</screeninfo>"

#. Tag: phrase
#: index.docbook:540
#, no-c-format
msgid "<phrase>Screenshot of the &cantor; plot 3D dialog</phrase>"
msgstr "<phrase>स्क्रीनशॉट् इत्यस्य &cantor; प्लॉट् 3D संवाद</phrase>"

#. Tag: para
#: index.docbook:544
#, no-c-format
msgid ""
"This dialog allows entering expression of the function, its variables and "
"the limits for each variable."
msgstr ""
"अयं संवादः फंक्शन् इत्यस्य अभिव्यक्तिं, तस्य चरानाम्, प्रत्येकस्य चरस्य सीमां च प्रविष्टुं शक्नोति ।"

#. Tag: title
#: index.docbook:552
#, no-c-format
msgid "Command Reference"
msgstr "आदेश सन्दर्भ"

#. Tag: title
#: index.docbook:555
#, no-c-format
msgid "The main &cantor; window"
msgstr "मुख्यः &cantor; कोष्ठ"

#. Tag: para
#: index.docbook:557
#, no-c-format
msgid ""
"&cantor; has the common &kde; menu items, for more information read the "
"<ulink url=\"help:/fundamentals/menus.html\">Menu</ulink> chapter of the "
"&kde; Fundamentals."
msgstr "&cantor; सामान्यं &kde; मेनू-वस्तूनाम्, अधिकसूचनार्थं &kde; मौलिकता।"

#. Tag: para
#: index.docbook:561
#, no-c-format
msgid ""
"Below is the list of the additional or special menu items in &cantor;. "
"Please note that some menus are only shown for backends that have "
"corresponding implementation."
msgstr ""
"अधः &cantor;मध्ये अतिरिक्तस्य अथवा विशेषस्य मेनू-वस्तूनाम् सूची अस्ति । कृपया ज्ञातव्यं यत् "
"केचन मेनू केवलं तेषां पृष्ठभागानाम् कृते दर्शिताः सन्ति येषां तत्सम्बद्धं कार्यान्वयनम् अस्ति ।"

#. Tag: title
#: index.docbook:565
#, no-c-format
msgid "The File Menu"
msgstr "सञ्चिकामेनू इति"

#. Tag: menuchoice
#: index.docbook:569
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>N</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>New</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>N</keycap></keycombo> </"
"shortcut> <guimenu>सञ्चिका</guimenu> <guimenuitem>नवीन</guimenuitem>"

#. Tag: action
#: index.docbook:576
#, no-c-format
msgid "Creates a new worksheet with the default backend."
msgstr "पूर्वनिर्धारितपृष्ठभागेन सह नूतनं कार्यपत्रकं निर्माति ।"

#. Tag: menuchoice
#: index.docbook:579
#, no-c-format
msgid ""
"<guimenu>File</guimenu> <guisubmenu>New</guisubmenu> "
"<guimenuitem><replaceable>Backend</replaceable></guimenuitem>"
msgstr ""
"<guimenu>सञ्चिका</guimenu> <guisubmenu>नवीन</guisubmenu> "
"<guimenuitem><replaceable>पृष्ठभूमिः</replaceable></guimenuitem>"

#. Tag: action
#: index.docbook:584
#, no-c-format
msgid "Creates a new worksheet with the chosen backend."
msgstr "चयनितपृष्ठभागेन सह नूतनं कार्यपत्रकं निर्माति ।"

#. Tag: menuchoice
#: index.docbook:587
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>O</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Open...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>O</keycap></keycombo> </"
"shortcut> <guimenu>सञ्चिका</guimenu> <guimenuitem>उद्घाट्य...</guimenuitem>"

#. Tag: action
#: index.docbook:594
#, no-c-format
msgid "Open a supported new worksheet with the file dialog."
msgstr "सञ्चिकासंवादेन सह समर्थितं नूतनं कार्यपत्रकं उद्घाटयन्तु ।"

#. Tag: menuchoice
#: index.docbook:597
#, no-c-format
msgid "<guimenu>File</guimenu> <guisubmenu>Open Recent</guisubmenu>"
msgstr "<menu>सञ्चिका</menu> <menu>अद्यतनं</menu> उद्घाटयन्तु"

#. Tag: action
#: index.docbook:601
#, no-c-format
msgid "Choose a worksheet from a list of recently used files."
msgstr "सद्यः प्रयुक्तानां सञ्चिकानां सूचीतः कार्यपत्रकं चिनोतु ।"

#. Tag: menuchoice
#: index.docbook:604
#, no-c-format
msgid ""
"<guimenu>File</guimenu> <guimenuitem>Download Example Worksheets</"
"guimenuitem>"
msgstr ""
"<guimenu>सञ्चिका</guimenu> <guimenuitem>उदाहरणकार्यपत्राणि डाउनलोड् कुर्वन्तु</"
"guimenuitem>"

#. Tag: action
#: index.docbook:608
#, no-c-format
msgid ""
"Opens the dialog to download examples uploaded by other &cantor; users with "
"<ulink url=\"https://userbase.kde.org/Special:MyLanguage/"
"Glossary#Get_Hot_New_Stuff\">GetHotNewStuff</ulink>."
msgstr ""
"अन्यैः अपलोड् कृतानि उदाहरणानि डाउनलोड् कर्तुं संवादं उद्घाटयति &cantor; <ulink url="
"\"https://userbase.kde.org/Special:MyLanguage/Glossary#Get_Hot_New_Stuff"
"\">GetHotNewStuff</ulink> इत्यनेन सह उपयोक्तारः ।"

#. Tag: menuchoice
#: index.docbook:612
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Open Example</guimenuitem>"
msgstr "<guimenu>सञ्चिका</guimenu> <guimenuitem>उदाहरणं उद्घाटयन्तु</guimenuitem>"

#. Tag: para
#: index.docbook:616
#, no-c-format
msgid ""
"<action>Opens the dialog to choose an example to load.</action> The examples "
"should be downloaded with <menuchoice><guimenu>File</guimenu> "
"<guimenuitem>Download Example Worksheets</guimenuitem></menuchoice> "
"beforehand."
msgstr ""
"<action>लोड् कर्तुं उदाहरणं चिन्वितुं संवादं उद्घाटयति।</action> उदाहरणानि पूर्वं "
"<menuchoice><guimenu>सञ्चिका</guimenu> <guimenuitem>उदाहरणकार्यपत्राणि डाउनलोड् "
"कुर्वन्तु</guimenuitem></menuchoice> इत्यनेन सह अवतरणं कर्तव्यम्"

#. Tag: menuchoice
#: index.docbook:620
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Save Plain Text</guimenuitem>"
msgstr "<guimenu>सञ्चिका</guimenu> <guimenuitem>सादा पाठं रक्षतु</guimenuitem>"

#. Tag: action
#: index.docbook:624
#, no-c-format
msgid "Allows saving the current worksheet as a plain text document."
msgstr "वर्तमानकार्यपत्रकं साधारणपाठदस्तावेजरूपेण रक्षितुं शक्नोति ।"

#. Tag: menuchoice
#: index.docbook:627
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Export to LaTeX</guimenuitem>"
msgstr ""
"<guimenu>सञ्चिका</guimenu> <guimenuitem>LaTeX</guimenuitem> मध्ये निर्यातं कुर्वन्तु"

#. Tag: action
#: index.docbook:631
#, no-c-format
msgid "Allows saving the current worksheet as a &latex; document."
msgstr "वर्तमानकार्यपत्रकं &latex; प्रलेख।"

#. Tag: menuchoice
#: index.docbook:634
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Publish Worksheet</guimenuitem>"
msgstr "<guimenu>सञ्चिका</guimenu> <guimenuitem>कार्यपत्रं प्रकाशयतु</guimenuitem>"

#. Tag: action
#: index.docbook:638
#, no-c-format
msgid ""
"Opens the dialog to publish your current worksheet and make it available to "
"other &cantor; users through <ulink url=\"https://userbase.kde.org/Special:"
"MyLanguage/Glossary#Get_Hot_New_Stuff\">GetHotNewStuff</ulink>."
msgstr ""
"भवतः वर्तमानकार्यपत्रं प्रकाशयितुं अन्येभ्यः &cantor; उपयोक्तृभ्यः <ulink url=\"https://"
"userbase.kde.org/Special:MyLanguage/Glossary#Get_Hot_New_Stuff"
"\">GetHotNewStuff</ulink> इत्यस्य माध्यमेन ।"

#. Tag: menuchoice
#: index.docbook:642
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Run Script</guimenuitem>"
msgstr "<guimenu>सञ्चिका</guimenu> <guimenuitem>स्क्रिप्ट्</guimenuitem> चालयन्तु"

#. Tag: action
