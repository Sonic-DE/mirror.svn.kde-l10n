#. Tag: title
#: index.docbook:348
#, no-c-format
msgid "&Windows; Example"
msgstr "&विण्डोज; उदाहरण"

#. Tag: para
#: index.docbook:349
#, no-c-format
msgid ""
"You can add these switches in the desktop icon properties. Here is an "
"example that runs &gcompris; in kiosk mode in full screen, without "
"Configuration button and cursor:"
msgstr ""
"एतानि स्विच् भवन्तः डेस्कटॉप् चिह्नगुणेषु योजयितुं शक्नुवन्ति । अत्र एकं उदाहरणं यत् &gcompris; "
"पूर्णपर्दे कियोस्क मोड् मध्ये, Configuration बटनं कर्सरं च विना:"

#. Tag: command
#: index.docbook:350
#, no-c-format
msgid ""
"\"C:\\Program Files\\GCompris-Qt\\bin\\GCompris.exe\" --enable-kioskmode -f -"
"C"
msgstr ""
"\"सी: \\ कार्यक्रम सञ्चिकाएँ \\ GCompris-Qt \\ bin \\ GCompris.exe\" --enable-"
"kioskmode -f -C"

#. Tag: title
#: index.docbook:354
#, no-c-format
msgid "&GNU;/&Linux; Example"
msgstr "&GNU;/&लिनक्स; उदाहरण"

#. Tag: para
#: index.docbook:355
#, fuzzy, no-c-format
#| msgid ""
#| "Create an application launcher and configure the command line parameters. "
#| "Here is an example that runs &gcompris; in kiosk mode in full screen, "
#| "without Config button and cursor:"
msgid ""
"Create an application launcher and configure the command line parameters. "
"Here is an example that runs &gcompris; in kiosk mode in fullscreen, without "
"Configuration button and cursor:"
msgstr ""
"एकं अनुप्रयोगं प्रक्षेपकं रचयन्तु तथा च आदेशपङ्क्तिमापदण्डान् विन्यस्यन्तु । अत्र एकं उदाहरणं यत् "
"&gcompris; पूर्णपर्दे कियोस्क मोड् मध्ये, Config बटनं कर्सरं च विना:"

#. Tag: command
#: index.docbook:356
#, no-c-format
msgid "gcompris-qt --enable-kioskmode -f -C"
msgstr "gcompris-qt --सक्षम-कियोस्कमोड -च -सी"

