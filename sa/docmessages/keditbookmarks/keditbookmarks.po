#. Tag: title
#: index.docbook:12
#, no-c-format
msgid "The Bookmark Editor"
msgstr "बुकमार्क सम्पादकः"

#. Tag: author
#: index.docbook:14
#, no-c-format
msgid "&Pamela.Roberts;"
msgstr "&पामेला.रॉबर्ट्स्;"

#. Tag: trans_comment
#: index.docbook:15
#, no-c-format
msgid "ROLES_OF_TRANSLATORS"
msgstr "अनुवादकानां_भूमिका"

