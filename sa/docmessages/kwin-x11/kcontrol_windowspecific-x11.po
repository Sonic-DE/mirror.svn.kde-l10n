#. Tag: para
#: index.docbook:23 index.docbook:37
#, no-c-format
msgid ""
"Here you can customize window settings specifically only for some windows."
msgstr "अत्र भवान् केवलं केषाञ्चन विण्डोजानां कृते विशेषतया विण्डो सेटिङ्ग्स् अनुकूलितुं शक्नोति ।"

#. Tag: keyword
#: index.docbook:27
#, no-c-format
msgid "<keyword>KDE</keyword>"
msgstr "<keyword>WHERE</keyword> इति"

#. Tag: keyword
#: index.docbook:28
#, no-c-format
msgid "KControl"
msgstr "KControl"

#. Tag: keyword
#: index.docbook:29
#, no-c-format
msgid "window settings"
msgstr "विण्डो सेटिंग्स्"

#. Tag: keyword
#: index.docbook:30
