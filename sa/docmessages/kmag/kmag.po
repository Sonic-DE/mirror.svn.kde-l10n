#: index.docbook:303
#, no-c-format
msgid "Select the zoom factor."
msgstr "जूम कारकं चिनोतु।"

#. Tag: menuchoice
#: index.docbook:307
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>-</keycap></keycombo> </"
"shortcut> <guimenu>View</guimenu> <guimenuitem>Zoom Out</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>-</keycap></keycombo> </"
"shortcut> <guimenu>दृश्य</guimenu> <guimenuitem>जूम आउट्</guimenuitem>"

#. Tag: para
#: index.docbook:315
#, no-c-format
msgid "Click on this button to zoom-out on the selected region."
msgstr "चयनितप्रदेशस्य जूम-आउट् कर्तुं एतत् बटन् नुदन्तु ।"

#. Tag: menuchoice
#: index.docbook:319
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>+</keycap></keycombo> </"
"shortcut> <guimenu>View</guimenu> <guimenuitem>Zoom In</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>+</keycap></keycombo> </"
"shortcut> <guimenu>दृश्य</guimenu> <guimenuitem>जूम इन</guimenuitem>"

#. Tag: para
#: index.docbook:327
#, no-c-format
msgid "Click on this button to zoom-in on the selected region."
msgstr "चयनितप्रदेशस्य जूम्-इन् कर्तुं एतत् बटन् नुदन्तु ।"

#. Tag: menuchoice
#: index.docbook:331
#, no-c-format
msgid "<guimenu>View</guimenu> <guimenuitem>Rotation</guimenuitem>"
msgstr "<guimenu>दृश्य</guimenu> <guimenuitem>भ्रमण</guimenuitem>"

#. Tag: para
#: index.docbook:335
#, no-c-format
msgid ""
"Select the rotation degree (<guimenuitem>No Rotation (0 Degrees)</"
"guimenuitem>, <guimenuitem>Left (90 Degrees)</guimenuitem>, "
"<guimenuitem>Upside Down (180 Degrees)</guimenuitem>, <guimenuitem>Right "
"(270 Degrees)</guimenuitem>."
msgstr ""
"परिभ्रमणस्य डिग्री (<guimenuitem>कोऽपि परिभ्रमणं नास्ति (० डिग्री)</guimenuitem>, "
"<guimenuitem>वामम् (९० डिग्री)</guimenuitem>, <guimenuitem>उल्टा (१८० डिग्री)</"
"guimenuitem>, <guimenuitem>दक्षिणं चिनोतु (२७० डिग्री)</guimenuitem>।"

#. Tag: menuchoice
#: index.docbook:341
#, no-c-format
msgid "<guimenu>View</guimenu> <guimenuitem>Refresh</guimenuitem>"
msgstr "<guimenu>दृश्य</guimenu> <guimenuitem>ताजगीकृत्य</guimenuitem>"

#. Tag: para
#: index.docbook:345
#, no-c-format
msgid ""
"Select the refresh rate (<guimenuitem>Very Low</guimenuitem>, "
"<guimenuitem>Low</guimenuitem>, <guimenuitem>Medium</guimenuitem>, "
"<guimenuitem>High</guimenuitem>, <guimenuitem>Very High</guimenuitem>). The "
"higher the rate, the more computing power (CPU) will be needed."
msgstr ""
"ताजगीदरं चिनोतु (<guimenuitem>अति न्यून</guimenuitem>, <guimenuitem>कम</"
"guimenuitem>, <guimenuitem>मध्यम</guimenuitem>, <guimenuitem>उच्च</"
"guimenuitem>, <guimenuitem>अति उच्च</guimenuitem >). यथा यथा अधिकः दरः भवति "
"तथा तथा अधिकगणनाशक्तिः (CPU) आवश्यकी भविष्यति ।"

#. Tag: menuchoice
#: index.docbook:353
#, no-c-format
msgid "<guimenu>View</guimenu> <guisubmenu>Colors</guisubmenu>"
msgstr "<guimenu>दृश्य</guimenu> <guimenu>रङ्गाः</guimenu>"

#. Tag: para
#: index.docbook:357
#, no-c-format
msgid ""
"Select different color vision deficiencies to simulate color blindness. This "
"is not useful for people with color blindness, but good for designing "
"accessible interfaces."
msgstr ""
"वर्ण-अन्धतायाः अनुकरणार्थं भिन्न-भिन्न-वर्णदृष्टि-अभावानाम् चयनं कुर्वन्तु । एतत् वर्णअन्धतां "
"विद्यमानानाम् जनानां कृते उपयोगी नास्ति, परन्तु सुलभ-अन्तरफलकानां परिकल्पनाय उत्तमम् ।"

#. Tag: title
#: index.docbook:366
#, no-c-format
msgid "The Settings Menu"
msgstr "सेटिंग्स् मेन्यू इति"

#. Tag: menuchoice
#: index.docbook:371
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> <keycap>F2</keycap></keycombo> </"
"shortcut> <guimenu>Settings</guimenu> <guimenuitem>Follow Mouse Mode</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> <keycap>F2</keycap></keycombo> </"
"shortcut> <guimenu>सेटिंग्स्</guimenu> <guimenuitem>मूषकविधानस्य अनुसरणं कुर्वन्तु</"
"guimenuitem>"

#. Tag: para
#: index.docbook:379
#, no-c-format
msgid ""
"In this mode the area around the mouse cursor is shown in a normal window."
msgstr "अस्मिन् मोड् मध्ये मूषकस्य कर्सरस्य परितः क्षेत्रं सामान्यविण्डो मध्ये दर्शितं भवति ।"

#. Tag: menuchoice
#: index.docbook:383
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> <keycap>F3</keycap></keycombo> </"
"shortcut> <guimenu>Settings</guimenu> <guimenuitem>Selection Window Mode</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> <keycap>F3</keycap></keycombo> </"
"shortcut> <guimenu>सेटिंग्स्</guimenu> <guimenuitem>चयनविण्डो मोड</guimenuitem>"

#. Tag: para
#: index.docbook:391
#, no-c-format
msgid ""
"In this mode a selection window is opened. The selected area is shown in a "
"normal window."
msgstr ""
"अस्मिन् मोड् मध्ये चयनविण्डो उद्घाट्यते । चयनितं क्षेत्रं सामान्यविण्डो मध्ये दर्शितं भवति ।"

#. Tag: menuchoice
#: index.docbook:395
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> <keycap>F4</keycap></keycombo> </"
"shortcut> <guimenu>Settings</guimenu> <guimenuitem>Whole Screen Mode</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> <keycap>F4</keycap></keycombo> </"
"shortcut> <guimenu>सेटिंग्स्</guimenu> <guimenuitem>समग्रपर्दे मोड</guimenuitem>"

#. Tag: para
#: index.docbook:403
#, no-c-format
msgid "In this mode the whole screen is magnified in the zoom window."
msgstr "अस्मिन् मोड् मध्ये जूम विण्डो मध्ये सम्पूर्णं पटलं वर्धितं भवति ।"

#. Tag: menuchoice
#: index.docbook:407
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> <keycap>F6</keycap></keycombo> </"
"shortcut> <guimenu>Settings</guimenu> <guimenuitem>Hide Mouse Cursor</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> <keycap>F6</keycap></keycombo> </"
"shortcut> <guimenu>सेटिंग्स्</guimenu> <guimenuitem>मूषकस्य कर्सरं गोपयन्तु</"
"guimenuitem>"

#. Tag: para
#: index.docbook:415 index.docbook:482
#, no-c-format
msgid "Show or hide the mouse cursor in the magnified image."
msgstr "वर्धिते चित्रे मूषकस्य कर्सरं दर्शयतु वा गोपयन्तु वा ।"

#. Tag: menuchoice
#: index.docbook:419
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> <keycap>F7</keycap></keycombo> </"
"shortcut> <guimenu>Settings</guimenu> <guimenuitem>Stays On Top</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> <keycap>F7</keycap></keycombo> </"
"shortcut> <guimenu>सेटिंग्स्</guimenu> <guimenuitem>उपरि तिष्ठति</guimenuitem>"

#. Tag: para
#: index.docbook:427 index.docbook:487
#, no-c-format
msgid "The &kmagnifier; window stays on top of other windows."
msgstr "इति &kmagnifier; खिडकी अन्येषां खिडकानाम् उपरि तिष्ठति।"

#. Tag: para
#: index.docbook:431
#, no-c-format
msgid ""
"Additionally &kmagnifier; has the common &kde; <guimenu>Settings</guimenu> "
"and <guimenu>Help</guimenu> menu items, for more information read the "
"sections about the <ulink url=\"help:/fundamentals/menus.html#menus-settings"
"\">Settings Menu</ulink> and <ulink url=\"help:/fundamentals/menus."
"html#menus-help\">Help Menu</ulink> of the &kde; Fundamentals."
msgstr ""
"अतिरिक्तरूपेण &kmagnifier; सामान्यं &kde; <guimenu>सेटिंग्स्</guimenu> तथा "
"<guimenu>सहायता</guimenu> मेनू-वस्तूनाम्, अधिकसूचनार्थं <ulink url=\"help:/"
"fundamentals/menus.html#menus-settings\">सेटिंग्स् मेनु< इत्यस्य विषये विभागान् पठन्तु /"
"ulink> तथा च &kde; मौलिकता।"

#. Tag: title
#: index.docbook:442
#, no-c-format
msgid "Command Reference"
msgstr "आदेश सन्दर्भ"

#. Tag: para
#: index.docbook:444
#, no-c-format
msgid ""
"&kmagnifier; automatically uses all your default shortcuts for saving file, "
"opening new window, printing, starting/stopping refresh (reload button in "
"&konqueror;), zoom-in, zoom-out &etc;"
msgstr ""
"&kmagnifier; स्वयमेव सञ्चिकां रक्षितुं, नूतनं विण्डो उद्घाटयितुं, मुद्रणं कर्तुं, ताजगीं आरभ्य/"
"निरोधं (&konqueror; मध्ये पुनः लोड् बटनं), जूम-इन्, जूम-आउट & इत्यादिषु भवतः सर्वेषां "
"पूर्वनिर्धारितशॉर्टकट्-उपयोगं करोति"

#. Tag: title
#: index.docbook:449
#, no-c-format
msgid "Default Keyboard Shortcuts"
msgstr "पूर्वनिर्धारित कीबोर्ड शॉर्टकट"

#. Tag: keycombo
#: index.docbook:453
#, no-c-format
msgid "&Ctrl;<keycap>S</keycap>"
msgstr "&Ctrl;<keycap>S</keycap> इति"

#. Tag: para
#: index.docbook:454
#, no-c-format
msgid "This will save the contents of the zoom window to a file."
msgstr "एतेन जूम् विण्डो इत्यस्य सामग्रीः सञ्चिकायां रक्षिता भविष्यति ।"

#. Tag: keycap
#: index.docbook:459
#, no-c-format
msgid "<keycap>F2</keycap>"
msgstr "<keycap>F2</keycap> इति"

#. Tag: para
#: index.docbook:460
#, no-c-format
msgid "Switch to \"Follow Mouse Mode\"."
msgstr "\"Follow Mouse Mode\" इत्यत्र स्विच कुर्वन्तु ।"

#. Tag: keycap
#: index.docbook:464
#, no-c-format
msgid "<keycap>F3</keycap>"
msgstr "<keycap>F3</keycap> इति"

#. Tag: para
#: index.docbook:465
#, no-c-format
msgid "Switch to \"Selection Window Mode\"."
msgstr "\"चयनविण्डो मोड\" इत्यत्र स्विच कुर्वन्तु ।"

#. Tag: keycap
#: index.docbook:469
#, no-c-format
msgid "<keycap>F4</keycap>"
msgstr "<keycap>F4</keycap> इति"

#. Tag: para
#: index.docbook:470
#, no-c-format
msgid "Switch to \"Whole Screen Mode\"."
msgstr "\"Whole Screen Mode\" इत्यत्र स्विच कुर्वन्तु ।"

#. Tag: keycap
#: index.docbook:474
#, no-c-format
msgid "<keycap>F5</keycap>"
msgstr "<keycap>F5</keycap> इति"

#. Tag: para
#: index.docbook:475
#, no-c-format
msgid ""
"This will start the refresh of the zoom window if it is stopped, or stops "
"the refresh of the zoom window if the refresh is currently on."
msgstr ""
"एतेन जूम-विण्डो-इत्यस्य ताजगीकरणं आरभ्यते यदि तत् स्थगितम् अस्ति, अथवा जूम-विण्डो-इत्यस्य "
"ताजगीं स्थगयति यदि सम्प्रति ताजगी चालू अस्ति ।"

#. Tag: keycap
#: index.docbook:481
#, no-c-format
msgid "<keycap>F6</keycap>"
msgstr "<keycap>F6</keycap> इति"

#. Tag: keycap
#: index.docbook:486
#, no-c-format
msgid "<keycap>F7</keycap>"
msgstr "<keycap>F7</keycap> इति"

#. Tag: keycombo
#: index.docbook:491
#, no-c-format
msgid "&Ctrl;<keycap>N</keycap>"
msgstr "&Ctrl;<keycap>N</keycap> इति"

#. Tag: para
#: index.docbook:492
#, no-c-format
msgid "This will open a new &kmagnifier; window."
msgstr "एतेन नूतनं &kmagnifier; कोष्ठ।"

#. Tag: keycombo
#: index.docbook:495
#, no-c-format
msgid "&Ctrl;<keycap>P</keycap>"
msgstr "&Ctrl;<keycap>P</keycap> इति"

#. Tag: para
#: index.docbook:496
#, no-c-format
msgid ""
"This will open the print dialog for printing the contents of the zoom window."
msgstr "एतेन जूम् विण्डो इत्यस्य सामग्रीं मुद्रयितुं मुद्रणसंवादः उद्घाटितः भविष्यति ।"

#. Tag: keycombo
#: index.docbook:500
#, no-c-format
msgid "&Ctrl;<keycap>C</keycap>"
msgstr "&Ctrl;<keycap>C</keycap> इति"

#. Tag: para
#: index.docbook:501
#, no-c-format
msgid "This will copy the zoom window contents to the clipboard."
msgstr "एतेन जूम विण्डो सामग्रीः क्लिप्बोर्ड् प्रति प्रतिलिपितः भविष्यति ।"

#. Tag: keycombo
#: index.docbook:506
#, no-c-format
msgid "&Ctrl;<keycap>M</keycap>"
msgstr "&Ctrl;<keycap>M</keycap> इति"

#. Tag: para
#: index.docbook:507
#, no-c-format
msgid "Show/Hide the menubar."
msgstr "मेनूपट्टिकां दर्शयतु/गोपयतु।"

#. Tag: keycombo
#: index.docbook:511
#, no-c-format
msgid "&Ctrl;<keycap>-</keycap>"
msgstr "&Ctrl;<कीकप>-</कीकप>"

#. Tag: para
#: index.docbook:512
#, no-c-format
msgid "Zoom out"
msgstr "जूम आउट् कुर्वन्तु"

#. Tag: keycombo
#: index.docbook:515
#, no-c-format
msgid "&Ctrl;<keycap>+</keycap>"
msgstr "&Ctrl;<कीकप>+</कीकप>"

#. Tag: para
#: index.docbook:516
#, no-c-format
msgid "Zoom in"
msgstr "जूम इन करें"

#. Tag: keycombo
#: index.docbook:519
#, no-c-format
msgid "&Ctrl;<keycap>Q</keycap>"
msgstr "&Ctrl;<keycap>Q</keycap>"

#. Tag: para
#: index.docbook:520
#, no-c-format
msgid "Quits the application."
msgstr "अनुप्रयोगं त्यजति।"

