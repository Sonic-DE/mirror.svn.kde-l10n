msgstr ""
"<shortcut> <keycombo action=\"simul\"> <keycap>F5</keycap></keycombo> </"
"shortcut> <guimenu>दृश्य</guimenu> <guimenuitem>प्रारम्भ/स्थिर</guimenuitem>"

#. Tag: para
#: index.docbook:293
#, no-c-format
msgid ""
"Start/Stop updating of the display. Stopping the update will zero the "
"processing power required (CPU usage)"
msgstr ""
"प्रदर्शनस्य अद्यतनीकरणं आरभत/स्थगयन्तु। अद्यतनं स्थगयित्वा आवश्यकं प्रसंस्करणशक्तिं शून्यं भविष्यति "
"(CPU उपयोगः) ।"

#. Tag: menuchoice
#: index.docbook:299
#, no-c-format
msgid "<guimenu>View</guimenu> <guimenuitem>Zoom</guimenuitem>"
msgstr "<guimenu>दृश्य</guimenu> <guimenuitem>जूम</guimenuitem>"

