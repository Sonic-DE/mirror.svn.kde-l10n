#. Tag: menuchoice
#: index.docbook:738
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>PgDown</keycap></"
"keycombo></shortcut> <guimenu>Go</guimenu> <guimenuitem>Next Page</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>PgDown</keycap></"
"keycombo></shortcut> <guimenu>गच्छ</guimenu> <guimenuitem>अग्रे पृष्ठं</"
"guimenuitem>"

#. Tag: para
#: index.docbook:743
#, no-c-format
msgid "Go to the next page of the current documentation."
msgstr "वर्तमानदस्तावेजस्य अग्रिमपृष्ठं गच्छन्तु ।"

#. Tag: menuchoice
#: index.docbook:750
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt;<keysym>Left</keysym></keycombo></"
"shortcut> <guimenu>Go</guimenu> <guimenuitem>Back</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt;<keysym>वाम</keysym></keycombo></"
