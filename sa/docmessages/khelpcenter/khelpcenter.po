"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>PgUp</keycap></"
"keycombo></shortcut> <guimenu>गच्छ</guimenu> <guimenuitem>पूर्वपृष्ठं</guimenuitem>"

