"<guimenu>Bookmarks</guimenu> <guimenuitem>New Bookmarks Folder</guimenuitem>"
msgstr ""
"<guimenu>पुस्तकचिह्नानि</guimenu> <guimenuitem>नवीनपुस्तकचिह्नपुटम्</guimenuitem>"

