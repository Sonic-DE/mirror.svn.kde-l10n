msgstr "<refname>kf6विकल्पाः</refname> इति"

#. Tag: refpurpose
#: man-kf6options.7.docbook:22
#, no-c-format
msgid "Common commandline options for all applications based on &kf6-full;"
msgstr "&kf6-full;"

#. Tag: cmdsynopsis
#: man-kf6options.7.docbook:26
#, no-c-format
msgid ""
"<command><replaceable>KDE application</replaceable></command> <arg choice="
"\"opt\"><option>-h, --help</option></arg> <arg choice=\"opt\"><option>-v, --"
"version</option></arg> <arg choice=\"opt\"><option>--author</option></arg> "
"<arg choice=\"opt\"><option>--license</option></arg> <arg choice=\"opt"
"\"><option>--desktopfile</option> <replaceable>file name</replaceable></arg>"
msgstr ""
"<command><replaceable>KDE अनुप्रयोग</replaceable></command><arg choice=\"opt"
"\"><option value=\"-h, --help\"> -ह, --सहाय</option></arg><arg choice=\"opt"
"\"><option value=\"-v, --version\"> -व, --संस्करणम्</option></arg><arg choice="
"\"opt\"><option value=--author> --लेखकः</option></arg><arg choice=\"opt"
"\"><option value=--license> --अनुज्ञापत्रम्</option></arg><arg choice=\"opt"
"\"><option value=--desktopfile> --डेस्कटॉपसञ्चिका</option><replaceable> "
"सञ्चिकानाम</replaceable></arg>"

#. Tag: title
#: man-kf6options.7.docbook:37
#, no-c-format
msgid "Options"
msgstr "विकल्पाः"

#. Tag: para
#: man-kf6options.7.docbook:39
#, no-c-format
msgid "The following options apply to all &kde; applications:"
msgstr "निम्नलिखितविकल्पाः सर्वेषु &kde; अनुप्रयोगाः :"

#. Tag: term
#: man-kf6options.7.docbook:43
#, no-c-format
msgid "<option>-h</option> <option>--help</option>"
msgstr "<option value=-h>-ह</option><option value=--help> --साहाय्यम्‌</option>"

#. Tag: para
#: man-kf6options.7.docbook:44
#, no-c-format
msgid "This lists the options available at the command line."
msgstr "एतेन आदेशपङ्क्तौ उपलभ्यमानाः विकल्पाः सूचीबद्धाः सन्ति ।"

#. Tag: term
#: man-kf6options.7.docbook:49
#, no-c-format
msgid "<option>-v</option> <option>--version</option>"
msgstr "<option value=-v>-वि</option><option value=--version> --संस्करण</option>"

#. Tag: para
#: man-kf6options.7.docbook:51
#, no-c-format
msgid ""
"Lists version information for <replaceable>KDE application</replaceable>."
msgstr "<replaceable>KDE अनुप्रयोग</replaceable> कृते संस्करणसूचनाः सूचीबद्धं करोति ।"

#. Tag: option
#: man-kf6options.7.docbook:55
#, no-c-format
msgid "--author"
msgstr "--लेखकः"

#. Tag: para
#: man-kf6options.7.docbook:56
#, no-c-format
msgid ""
"Lists <replaceable>KDE application</replaceable> authors in the terminal "
"window."
msgstr ""
"टर्मिनल् विण्डो मध्ये <replaceable>KDE अनुप्रयोग</replaceable> लेखकान् सूचीबद्धं करोति ।"

#. Tag: option
#: man-kf6options.7.docbook:60
#, no-c-format
msgid "--license"
msgstr "--अनुज्ञापत्रम्"

#. Tag: para
#: man-kf6options.7.docbook:61
#, no-c-format
msgid "Shows license information."
msgstr "अनुज्ञापत्रसूचना दर्शयति।"

#. Tag: term
#: man-kf6options.7.docbook:65
#, no-c-format
msgid "<option>--desktopfile</option> <replaceable>file name</replaceable>"
msgstr ""
"<option value=--desktopfile>--डेस्कटॉपसञ्चिका</option><replaceable> सञ्चिकानाम</"
"replaceable>"

#. Tag: para
#: man-kf6options.7.docbook:66
#, no-c-format
msgid "The base file name of the desktop entry for this application."
msgstr "अस्य अनुप्रयोगस्य कृते डेस्कटॉप् प्रविष्टेः आधारसञ्चिकानाम ।"

#. Tag: para
#: man-kf6options.7.docbook:67
#, no-c-format
msgid ""
"This is in particular useful for wrapper applications and applications "
"having in general multiple desktop files. Thus each desktop file can put its "
"own name into the exec command."
msgstr ""
"इदं विशेषतया रैपर-अनुप्रयोगानाम्, सामान्यतया बहु-डेस्कटॉप्-सञ्चिकानां च अनुप्रयोगानाम् कृते "
"उपयोगी भवति । एवं प्रत्येकं डेस्कटॉप् सञ्चिका स्वस्य नाम exec आदेशे स्थापयितुं शक्नोति ।"

#. Tag: title
#: man-kf6options.7.docbook:78
#, no-c-format
msgid "See Also"
msgstr "इदमपि पश्यन्तु"

#. Tag: para
#: man-kf6options.7.docbook:79
#, no-c-format
msgid "qt6options(7)"
msgstr "qt6विकल्प(7) 1.1."

