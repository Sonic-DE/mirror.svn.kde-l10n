#. Tag: cmdsynopsis
#: man-qt6options.7.docbook:27
#, no-c-format
msgid ""
"<command><replaceable>Qt application</replaceable></command> <arg choice="
"\"opt\"><option>-style=</option> <replaceable>style</replaceable> / <option>-"
"style</option> <replaceable>style</replaceable></arg> <arg choice=\"opt"
"\"><option>-stylesheet=</option> <replaceable>stylesheet</replaceable> / "
"<option>-stylesheet</option> <replaceable>stylesheet</replaceable></arg> "
"<arg choice=\"opt\"><option>-widgetcount</option></arg> <arg choice=\"opt"
"\"><option>-reverse</option></arg> <arg choice=\"opt\"><option>-"
"qmljsdebugger=</option> <replaceable>port</replaceable></arg> <arg choice="
"\"opt\"><option>-platform</option> <replaceable>platformName[:options]</"
"replaceable></arg> <arg choice=\"opt\"><option>-platformpluginpath</option> "
"<replaceable>path</replaceable></arg> <arg choice=\"opt\"><option>-"
"platformtheme</option> <replaceable>platformTheme</replaceable></arg> <arg "
"choice=\"opt\"><option>-plugin</option> <replaceable>plugin</replaceable></"
"arg> <arg choice=\"opt\"><option>-qwindowgeometry</option> "
"<replaceable>geometry</replaceable></arg> <arg choice=\"opt\"><option>-"
"qwindowicon</option> <replaceable>icon</replaceable></arg> <arg choice=\"opt"
"\"><option>-qwindowtitle</option> <replaceable>title</replaceable></arg> "
"<arg choice=\"opt\"><option>-reverse</option></arg> <arg choice=\"opt"
"\"><option>-session</option> <replaceable>session</replaceable></arg> <arg "
"choice=\"opt\"><option>-display</option> <replaceable>hostname:"
"screen_number</replaceable></arg> <arg choice=\"opt\"><option>-geometry</"
"option> <replaceable>geometry</replaceable></arg> <arg choice=\"opt"
"\"><option>-dialogs=</option> <replaceable>[xp|none]</replaceable></arg> "
"<arg choice=\"opt\"><option>-fontengine=</option> <replaceable>freetype</"
"replaceable></arg> <arg choice=\"opt\"><option>-h, --help and -? on &Windows;"
"</option></arg> <arg choice=\"opt\"><option>-v --version</option></arg>"
msgstr ""
"<command><replaceable>Qt अनुप्रयोग</replaceable></command><arg choice=\"opt"
"\"><option value=-style=> -शैली=</option><replaceable> शैली</replaceable> / ."
"<option value=-style> -शैली</option><replaceable> शैली</replaceable></arg><arg "
"choice=\"opt\"><option value=-stylesheet=> -शैलीपत्र=</option><replaceable> "
"stylesheet इति</replaceable> / .<option value=-stylesheet> -शैलीपत्रम्</"
"option><replaceable> stylesheet इति</replaceable></arg><arg choice=\"opt"
"\"><option value=-widgetcount> -विजेटगणना</option></arg><arg choice=\"opt"
"\"><option value=-reverse> -विपरीत</option></arg><arg choice=\"opt\"><option "
"value=-qmljsdebugger=> -qmljsdebugger=</option><replaceable> पोताश्रय</"
"replaceable></arg><arg choice=\"opt\"><option value=-platform> -तमङ्गः</"
"option><replaceable> platformName[:विकल्पाः] ।</replaceable></arg><arg choice="
"\"opt\"><option value=-platformpluginpath> -प्लेटफॉर्मप्लगिन्पथ</"
"option><replaceable> पथं</replaceable></arg><arg choice=\"opt\"><option "
"value=-platformtheme> -मञ्चविषयः</option><replaceable> platformTheme इति</"
"replaceable></arg><arg choice=\"opt\"><option value=-plugin> -प्लगिन्</"
"option><replaceable> प्लगिन्</replaceable></arg><arg choice=\"opt\"><option "
"value=-qwindowgeometry> -qwindowgeometry</option><replaceable> ज्यामिति</"
"replaceable></arg><arg choice=\"opt\"><option value=-qwindowicon> -"
"qwindowicon</option><replaceable> चिह्न</replaceable></arg><arg choice=\"opt"
"\"><option value=-qwindowtitle> -qwindowtitle</option><replaceable> शीर्षक</"
"replaceable></arg><arg choice=\"opt\"><option value=-reverse> -विपरीत</"
"option></arg><arg choice=\"opt\"><option value=-session> -सत्र</"
"option><replaceable> सत्र</replaceable></arg><arg choice=\"opt\"><option "
"value=-display> -प्रदर्शन</option><replaceable> मेजबाननाम:स्क्रीन_संख्या</"
"replaceable></arg><arg choice=\"opt\"><option value=-geometry> -ज्यामिति</"
"option><replaceable> ज्यामिति</replaceable></arg><arg choice=\"opt\"><option "
"value=-dialogs=> -संवादाः=</option><replaceable> [xp|कोऽपि नास्ति] ।</"
"replaceable></arg><arg choice=\"opt\"><option value=-fontengine=> -"
"फॉन्टइञ्जिन=</option><replaceable> मुक्तप्रकारः</replaceable></arg><arg choice="
"\"opt\"><option value=\"-h, --help and -? on &amp;Windows;\"> -ह, --सहायं च "
"-? on &amp;विण्डोज;</option></arg><arg choice=\"opt\"><option value=\"-v --"
"version\"> -v --संस्करणम्</option></arg>"

#. Tag: title
#: man-qt6options.7.docbook:57
#, no-c-format
msgid "Options"
msgstr "विकल्पाः"

#. Tag: para
#: man-qt6options.7.docbook:59
#, no-c-format
msgid "The following options apply to all &Qt; applications:"
msgstr "निम्नलिखितविकल्पाः सर्वेषु &Qt; अनुप्रयोगाः :"

#. Tag: term
#: man-qt6options.7.docbook:64
#, no-c-format
msgid ""
"<option>-style=</option> <replaceable>style</replaceable> / <option>-style</"
"option> <replaceable>style</replaceable>"
msgstr ""
"<option value=-style=>-शैली=</option><replaceable> शैली</replaceable> / ."
"<option value=-style> -शैली</option><replaceable> शैली</replaceable>"

#. Tag: para
#: man-qt6options.7.docbook:67
#, no-c-format
msgid ""
"Set the application &GUI; style. Possible values depend on the system "
"configuration. If &Qt; is compiled with additional styles or has additional "
"styles as plugins these will be available to the <option>-style</option> "
"command line option."
msgstr ""
"अनुप्रयोगं सेट् कुर्वन्तु &amp;GUI; शैली। सम्भाव्यमूल्यानि प्रणालीविन्यासस्य उपरि निर्भरं भवति "
"। यदि &amp;Qt; अतिरिक्तशैल्याः सह संकलितं भवति अथवा अतिरिक्तशैल्याः सन्ति यतः प्लगिन्स् "
"एते उपलब्धाः भविष्यन्ति<option value=-style> -शैली</option> आदेशपङ्क्तिविकल्पः ।"

#. Tag: term
#: man-qt6options.7.docbook:74
#, no-c-format
msgid ""
"<option>-stylesheet=</option> <replaceable>stylesheet</replaceable> / "
"<option>-stylesheet</option> <replaceable>stylesheet</replaceable>"
msgstr ""
"<option value=-stylesheet=>-शैलीपत्र=</option><replaceable> stylesheet इति</"
"replaceable> / .<option value=-stylesheet> -शैलीपत्रम्</option><replaceable> "
"stylesheet इति</replaceable>"

#. Tag: para
#: man-qt6options.7.docbook:77
#, no-c-format
msgid ""
"Set the application styleSheet. The value must be a path to a file that "
"contains the Style Sheet."
msgstr ""
"अनुप्रयोग styleSheet सेट् कुर्वन्तु । मूल्यं सञ्चिकायाः मार्गः भवितुमर्हति यस्मिन् Style "
"Sheet भवति ।"

#. Tag: option
#: man-qt6options.7.docbook:84
#, no-c-format
msgid "-widgetcount"
msgstr "-विजेटगणना"

#. Tag: para
#: man-qt6options.7.docbook:86
#, no-c-format
msgid ""
"Print debug message at the end about number of widgets left undestroyed and "
"maximum number of widgets existed at the same time."
msgstr ""
"अविनाशी अवशिष्टानां विजेट्-सङ्ख्यायाः विषये, एकस्मिन् समये विद्यमानानाम् अधिकतम-विजेट्-"
"सङ्ख्यायाः विषये च अन्ते त्रुटि-निवारण-सन्देशं मुद्रयन्तु ।"

#. Tag: option
#: man-qt6options.7.docbook:93
#, no-c-format
msgid "-reverse"
msgstr "-विपरीत"

#. Tag: para
#: man-qt6options.7.docbook:95
#, no-c-format
msgid ""
"Set the application's layout direction to <methodname>Qt::RightToLeft</"
"methodname>. This option is intended to aid debugging and should not be used "
"in production. The default value is automatically detected from the user's "
"locale (see also <methodname>QLocale::textDirection()</methodname>)."
msgstr ""
"अनुप्रयोगस्य विन्यासदिशां <methodname>Qt::RightToLeft</methodname> इति सेट् कुर्वन्तु । "
"एषः विकल्पः त्रुटिनिवारणे सहायकः अस्ति, उत्पादने न उपयोक्तव्यः । पूर्वनिर्धारितं मूल्यं "
"स्वयमेव उपयोक्तुः स्थानात् ज्ञायते (<methodname>QLocale::textDirection()</"
"methodname> इत्यपि पश्यन्तु) ।"

#. Tag: term
#: man-qt6options.7.docbook:104
#, no-c-format
msgid "<option>-qmljsdebugger=</option> <replaceable>port</replaceable>"
msgstr ""
"<option value=-qmljsdebugger=>-qmljsdebugger=</option><replaceable> पोताश्रय</"
"replaceable>"

#. Tag: para
#: man-qt6options.7.docbook:107
#, no-c-format
msgid ""
"Activate the QML/JS debugger with a specified port. The value must be of "
"format port:1234[,block], where block is optional and will make the "
"application wait until a debugger connects to it."
msgstr ""
"निर्दिष्टेन पोर्ट् इत्यनेन सह QML/JS डिबगरं सक्रियं कुर्वन्तु । मूल्यं format port:1234[,"
"block] इत्यस्य भवितुमर्हति, यत्र block वैकल्पिकं भवति तथा च एप्लिकेशनं तावत् प्रतीक्षां "
"करिष्यति यावत् डिबगरः तया सह सम्बद्धः न भवति ।"

#. Tag: term
#: man-qt6options.7.docbook:114
#, no-c-format
msgid ""
"<option>-platform</option> <replaceable>platformName[:options]</replaceable>"
msgstr ""
"<option value=-platform>-तमङ्गः</option><replaceable> platformName[:विकल्पाः] ।"
"</replaceable>"

#. Tag: para
#: man-qt6options.7.docbook:117
#, no-c-format
msgid "Specify the &Qt; Platform Abstraction (QPA) plugin."
msgstr "&Qt; मंच अमूर्तता (QPA) प्लगइन।"

#. Tag: term
#: man-qt6options.7.docbook:123
#, no-c-format
msgid "<option>-platformpluginpath</option> <replaceable>path</replaceable>"
msgstr ""
"<option value=-platformpluginpath>-प्लेटफॉर्मप्लगिन्पथ</option><replaceable> पथं</"
"replaceable>"

#. Tag: para
#: man-qt6options.7.docbook:126
#, no-c-format
msgid "Specify the path to platform plugins."
msgstr "मञ्चप्लगिन्स् मार्गं निर्दिशन्तु ।"

#. Tag: term
#: man-qt6options.7.docbook:132
#, no-c-format
msgid ""
"<option>-platformtheme</option> <replaceable>platformTheme</replaceable>"
msgstr ""
"<option value=-platformtheme>-मञ्चविषयः</option><replaceable> platformTheme "
"इति</replaceable>"

#. Tag: para
#: man-qt6options.7.docbook:135
#, no-c-format
msgid "Specify the platform theme."
msgstr "मञ्चस्य विषयः निर्दिशन्तु ।"

#. Tag: term
#: man-qt6options.7.docbook:141
#, no-c-format
msgid "<option>-plugin</option> <replaceable>plugin</replaceable>"
msgstr "<option value=-plugin>-प्लगिन्</option><replaceable> प्लगिन्</replaceable>"

#. Tag: para
#: man-qt6options.7.docbook:144
#, no-c-format
msgid ""
"Specify additional plugins to load. The argument may appear multiple times."
msgstr "लोड् कर्तुं अतिरिक्तप्लगिन्स् निर्दिशन्तु । तर्कः बहुवारं दृश्यते ।"

#. Tag: term
#: man-qt6options.7.docbook:150
#, no-c-format
msgid "<option>-qwindowgeometry</option> <replaceable>geometry</replaceable>"
msgstr ""
"<option value=-qwindowgeometry>-qwindowgeometry</option><replaceable> "
"ज्यामिति</replaceable>"

#. Tag: para
#: man-qt6options.7.docbook:153
#, no-c-format
msgid ""
"Specify the window geometry for the main window using the &X11;-syntax. For "
"example: -qwindowgeometry 100x100+50+50"
msgstr ""
"&X11;-वाक्यविन्यासस्य उपयोगेन मुख्यविण्डो कृते विण्डो ज्यामितिः निर्दिशन्तु । यथा : -"
"qwindowgeometry 100x100+50+50"

#. Tag: term
#: man-qt6options.7.docbook:159
#, no-c-format
msgid "<option>-qwindowicon</option> <replaceable>icon</replaceable>"
msgstr ""
"<option value=-qwindowicon>-qwindowicon</option><replaceable> चिह्न</"
"replaceable>"

#. Tag: para
#: man-qt6options.7.docbook:162
#, no-c-format
msgid "Set the default window icon."
msgstr "पूर्वनिर्धारितं विण्डो चिह्नं सेट् कुर्वन्तु ।"

#. Tag: term
#: man-qt6options.7.docbook:168
#, no-c-format
msgid "<option>-qwindowtitle</option> <replaceable>title</replaceable>"
msgstr ""
"<option value=-qwindowtitle>-qwindowtitle</option><replaceable> शीर्षक</"
"replaceable>"

#. Tag: para
#: man-qt6options.7.docbook:171
#, no-c-format
msgid "Set the title of the first window."
msgstr "प्रथमस्य विण्डो इत्यस्य शीर्षकं सेट् कुर्वन्तु ।"

#. Tag: term
#: man-qt6options.7.docbook:177
#, no-c-format
msgid "<option>-session</option> <replaceable>session</replaceable>"
msgstr "<option value=-session>-सत्र</option><replaceable> सत्र</replaceable>"

#. Tag: para
#: man-qt6options.7.docbook:180
#, no-c-format
msgid "Restore the application from an earlier session."
msgstr "पूर्वसत्रात् अनुप्रयोगं पुनः स्थापयन्तु ।"

#. Tag: term
#: man-qt6options.7.docbook:186
#, no-c-format
msgid ""
"<option>-display</option> <replaceable>hostname:screen_number</replaceable>"
msgstr ""
"<option value=-display>-प्रदर्शन</option><replaceable> मेजबाननाम:स्क्रीन_संख्या</"
"replaceable>"

#. Tag: para
#: man-qt6options.7.docbook:189
#, no-c-format
msgid ""
"Switch displays on &X11;. Overrides the <envar>DISPLAY</envar> environment "
"variable."
msgstr "प्रदर्शनं स्विच् कुर्वन्तु &X11;. <envar>DISPLAY</envar> वातावरणचरं अधिलिखति ।"

#. Tag: term
#: man-qt6options.7.docbook:195
#, no-c-format
msgid "<option>-geometry</option> <replaceable>geometry</replaceable>"
msgstr ""
"<option value=-geometry>-ज्यामिति</option><replaceable> ज्यामिति</replaceable>"

#. Tag: para
#: man-qt6options.7.docbook:198
#, no-c-format
msgid ""
"Specify the window geometry for the main window on &X11;. For example: -"
"geometry 100x100+50+50"
msgstr ""
"&X11; इत्यत्र मुख्यविण्डो कृते विण्डो ज्यामितिः निर्दिशन्तु । यथा : -ज्यामितिः "
"१००x१००+५०+५०"

#. Tag: term
#: man-qt6options.7.docbook:204
#, no-c-format
msgid "<option>-dialogs=</option> <replaceable>[xp|none]</replaceable>"
msgstr ""
"<option value=-dialogs=>-संवादाः=</option><replaceable> [xp|कोऽपि नास्ति] ।</"
"replaceable>"

#. Tag: para
#: man-qt6options.7.docbook:207
#, no-c-format
msgid ""
"Only available for the &Windows; platform. XP uses native style dialogs and "
"none disables them."
msgstr ""
"केवलं &Windows; तमङ्गः। XP देशीशैलीसंवादानाम् उपयोगं करोति तथा च कोऽपि तान् निष्क्रियं न "
"करोति ।"

#. Tag: term
#: man-qt6options.7.docbook:213
#, no-c-format
msgid "<option>-fontengine=</option> <replaceable>freetype</replaceable>"
msgstr ""
"<option value=-fontengine=>-फॉन्टइञ्जिन=</option><replaceable> मुक्तप्रकारः</"
"replaceable>"

#. Tag: para
#: man-qt6options.7.docbook:216
#, no-c-format
msgid "Use the FreeType font engine."
msgstr "FreeType font engine इत्यस्य उपयोगं कुर्वन्तु ।"

#. Tag: option
#: man-qt6options.7.docbook:224
#, no-c-format
msgid "-h, --help and -? on &Windows;"
msgstr "-ह, --सहायं च -? on &विण्डोज;"

#. Tag: para
#: man-qt6options.7.docbook:226
#, no-c-format
msgid "Print all options and the application description."
msgstr "सर्वे विकल्पाः अनुप्रयोगविवरणं च मुद्रयन्तु ।"

#. Tag: option
#: man-qt6options.7.docbook:233
#, no-c-format
msgid "-v --version"
msgstr "-v --संस्करणम्"

#. Tag: para
#: man-qt6options.7.docbook:235
#, no-c-format
msgid "Display the version string of the application."
msgstr "अनुप्रयोगस्य संस्करणस्ट्रिंग् प्रदर्शयन्तु ।"

#. Tag: title
#: man-qt6options.7.docbook:246
#, no-c-format
msgid "See Also"
msgstr "इदमपि पश्यन्तु"

#. Tag: para
#: man-qt6options.7.docbook:247
#, no-c-format
msgid "<replaceable>kf6options</replaceable>(7)"
msgstr "<प्रतिस्थापनीय>kf6विकल्प</replaceable>(7)"

#. Tag: title
#: man-qt6options.7.docbook:252
#, no-c-format
msgid "Authors"
msgstr "लेखकाः"

#. Tag: para
#: man-qt6options.7.docbook:253
#, no-c-format
msgid "Man page originally written by &Lauri.Watts; &Lauri.Watts.mail;"
msgstr "मनुष्यपृष्ठं मूलतः &Lauri.Watts; &लौरी.वाट्स.मेल;"

#. Tag: para
#: man-qt6options.7.docbook:254
#, no-c-format
msgid "Updated to &frameworks; 5 by &Burkhard.Lueck; &Burkhard.Lueck.mail;"
msgstr "&frameworks; ५ द्वारा &बुर्खार्ड.लुएक्; &बर्खार्ड.लुएक्.मेल;"

#. Tag: para
#: man-qt6options.7.docbook:255
#, no-c-format
msgid ""
"The infos for this man page are from <ulink url=\"https://doc.qt.io/qt-6/"
