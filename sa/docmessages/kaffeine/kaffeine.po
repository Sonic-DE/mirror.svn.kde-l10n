msgstr ""
"<shortcut> <keycombo action=\"simul\"><keycap>F</keycap></keycombo> </"
"shortcut> <guimenu>प्लेबैक</guimenu> <guimenuitem>पूर्णपर्दे मोड/पूर्णपर्दे मोडात् "
"निर्गच्छ</guimenuitem>"

