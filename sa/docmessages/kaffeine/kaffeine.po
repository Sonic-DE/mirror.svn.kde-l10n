"<guimenu>Playback</guimenu> <guisubmenu>Subtitle</guisubmenu> "
"<guimenuitem>off/<replaceable>Name-of-subtitle</replaceable></guimenuitem>"
msgstr ""
"<guimenu>प्लेबैक</guimenu> <guisubmenu>उपशीर्षक</guisubmenu> <guimenuitem>off/"
"<replaceable>उपशीर्षकस्य नाम</replaceable></guimenuitem>"

