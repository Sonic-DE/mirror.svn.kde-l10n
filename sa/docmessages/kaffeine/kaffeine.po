"<guimenu>Playback</guimenu> <guisubmenu>Audio</guisubmenu> "
"<guimenuitem>Increase Volume</guimenuitem>"
msgstr ""
"<guimenu>प्लेबैक</guimenu> <guisubmenu>श्रव्य</guisubmenu> <guimenuitem>मात्रा "
"वर्धयतु</guimenuitem>"

