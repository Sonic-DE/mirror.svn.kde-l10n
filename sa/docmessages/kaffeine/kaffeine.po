"<shortcut> <keycombo action=\"simul\">&Backspace;</keycombo> </shortcut> "
"<guimenu>Playback</guimenu> <guimenuitem>Stop</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&बैकस्पेस;</keycombo> </shortcut> "
"<guimenu>प्लेबैक</guimenu> <guimenuitem>स्थगयतु</guimenuitem>"

