msgstr ""
"<action>अस्मात् पतत्सूचिकातः उपलब्धं उपशीर्षकं</action> चिनोतु । एते उपशीर्षकचैनलाः "
"स्रोतधारायां सामग्रीं स्वीकृत्य भिन्नाः भविष्यन्ति ।"

#. Tag: menuchoice
#: index.docbook:976
#, no-c-format
msgid ""
"<guimenu>Playback</guimenu> <guisubmenu>Subtitle</guisubmenu> "
"<guimenuitem>Add subtitle file</guimenuitem>"
msgstr ""
"<guimenu>प्लेबैक</guimenu> <guisubmenu>उपशीर्षक</guisubmenu> "
"<guimenuitem>उपशीर्षकसञ्चिकां योजयतु</guimenuitem>"

