"shortcut> <guimenu>खेल</guimenu> <guimenuitem>निवृत्तं</guimenuitem>"

#. Tag: para
#: index.docbook:164
#, no-c-format
msgid "<action>Quits</action> &kolorlines;"
msgstr "<action>त्यजति</action> &kolorlines;"

