msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>Z</keycap></keycombo></"
"shortcut> <guimenu>चल</guimenu> <guimenuitem>पूर्ववर्ती</guimenuitem>"

#. Tag: action
#: index.docbook:173
#, no-c-format
msgid "This will undo the last move."
msgstr "एतेन अन्तिमः चालः पूर्ववत् भविष्यति ।"

#. Tag: menuchoice
#: index.docbook:176
#, no-c-format
msgid "<guimenu>Move</guimenu><guimenuitem>End Turn</guimenuitem>"
msgstr "<guimenu>चल</guimenu><guimenuitem>अन्तं भ्रमणं</guimenuitem>"

#. Tag: para
#: index.docbook:179
#, no-c-format
msgid ""
"Skip your move, immediately play the next marbles without you moving any."
msgstr ""
"भवतः चालनं त्यजतु, तत्क्षणमेव अग्रिमाणि संगमरवराणि क्रीडन्तु, भवतः किमपि चालनं विना।"

#. Tag: menuchoice
#: index.docbook:183
#, no-c-format
msgid ""
"<shortcut>&Left;</shortcut> <guimenu>Navigation</guimenu> <guimenuitem>Move "
