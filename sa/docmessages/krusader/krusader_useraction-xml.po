#. Tag: title
#: useraction-xml.docbook:8
#, no-c-format
msgid "useractions.xml"
msgstr "useractions.xml इति"

#. Tag: para
#: useraction-xml.docbook:9
#, no-c-format
msgid ""
"This appendix gives several examples of <filename>useractions.xml</filename> "
"files. With this you can begin to discover the power of the <link linkend="
"\"useractions\">UserActions</link> and start learning how to use them. Once "
"you understand how to write UserActions you will find that &krusader; is an "
"even more powerful, customizable tool."
msgstr ""
"अस्मिन् परिशिष्टे अनेकानि उदाहरणानि दत्तानि सन्ति<filename> useractions.xml इति</"
"filename> सञ्चिकाः । एतेन भवन्तः तस्य शक्तिं आविष्कर्तुं आरभुं शक्नुवन्ति<link linkend="
"\"useractions\"> उपयोक्तृक्रियाः</link> तथा तेषां उपयोगः कथं करणीयः इति शिक्षितुं "
"आरभत। एकदा भवन्तः UserActions कथं लिखितव्यम् इति अवगत्य भवन्तः तत् &amp;krusader; "
"अतः अपि अधिकं शक्तिशाली, अनुकूलनीयं साधनम् अस्ति ।"

#. Tag: para
#: useraction-xml.docbook:15
#, no-c-format
msgid ""
"Please consider uploading your UserActions at <ulink url=\"https://store.kde."
"org\">store.kde.org</ulink> as we are collecting them. If your UserAction is "
"selected by us it will be shipped with &krusader; at the next release."
msgstr ""
"कृपया भवतः UserActions <ulink url=\"https://store.kde.org\">store.kde.org</"
"ulink> इत्यत्र अपलोड् कर्तुं विचारयन्तु यतः वयं तान् संग्रहयामः । यदि भवतः UserAction "
"अस्माभिः चयनितं तर्हि &krusader; अग्रिमे विमोचनसमये।"

#. Tag: para
#: useraction-xml.docbook:20
#, no-c-format
msgid "Runs <command>uptime</command>"
msgstr "<command>uptime</command> इति चालयति"

#. Tag: programlisting
#: useraction-xml.docbook:21
#, no-c-format
msgid ""
"&lt;!DOCTYPE KrusaderUserActions>\n"
" &lt;KrusaderUserActions>\n"
"  &lt;action name=\"uptime\" >\n"
"  &lt;title>Up-time&lt;/title>\n"
"  &lt;tooltip>tells how long since the computer has been booted&lt;/"
"tooltip>\n"
"  &lt;icon>clock&lt;/icon>\n"
"  &lt;category>information&lt;/category>\n"
"  &lt;description same_as=\"tooltip\" />\n"
"  &lt;command executionmode=\"collect_output\" >uptime&lt;/command>\n"
"  &lt;defaultshortcut>Alt+Ctrl+U&lt;/defaultshortcut>\n"
" &lt;/action>\n"
"&lt;/KrusaderUserActions>"
msgstr ""
"&lt;!DOCTYPE क्रूसेडरप्रयोक्तृक्रियाः>\n"
" &lt;क्रूसेडरप्रयोक्तृक्रियाः>\n"
"  &lt;क्रिया नाम=\"अपटाइम\" >\n"
"  &lt;title>अप-समय&lt;/title>\n"
"  &lt;tooltip>सङ्गणकस्य आरम्भः कियत्कालं यावत् अभवत्&lt;/tooltip> इति वदति\n"
"  &lt;चिह्न>घटिका&lt;/चिह्न>\n"
"  &lt;वर्ग>सूचना&lt;/श्रेणी>\n"
"  &lt;वर्णन same_as=\"उपकरणसूची\" />\n"
"  &lt;command executionmode=\"कलेक्ट_आउटपुट\" >अपटाइम&lt;/आदेश>\n"
"  &lt;defaulttshortcut>Alt+Ctrl+U&lt;/डिफ़ॉल्टशर्टकट>\n"
" &lt;/कर्म>\n"
"&lt;/क्रूसाडरप्रयोक्तृक्रियाः>"

#. Tag: para
#: useraction-xml.docbook:24
#, no-c-format
msgid "Runs <command>ls -l</command>"
msgstr "<command>ls -l</command> चालयति"

#. Tag: programlisting
#: useraction-xml.docbook:25
#, no-c-format
msgid ""
"&lt;!DOCTYPE KrusaderUserActions>\n"
" &lt;KrusaderUserActions>\n"
"  &lt;action name=\"ls -l\" >\n"
"  &lt;title>ls -l in current dir&lt;/title>\n"
"  &lt;description same_as=\"tooltip\" />\n"
"  &lt;command executionmode=\"collect_output\" >ls -l %aPath% %oPath%&lt;/"
"command>\n"
" &lt;/action>\n"
"&lt;/KrusaderUserActions>"
msgstr ""
"&lt;!DOCTYPE क्रूसेडरप्रयोक्तृक्रियाः>\n"
" &lt;क्रूसेडरप्रयोक्तृक्रियाः>\n"
"  &lt;क्रिया नाम=\"ls -l\" >\n"
"  &lt;title>ls -l वर्तमान dir&lt;/title> मध्ये\n"
"  &lt;वर्णन same_as=\"उपकरणसूची\" />\n"
"  &lt;command executionmode=\"कलेक्ट_आउटपुट\" >ls -l % aPath% % oPath%&lt;/"
"आदेश>\n"
" &lt;/कर्म>\n"
"&lt;/क्रूसेडरप्रयोक्तृक्रियाः>"

#. Tag: para
#: useraction-xml.docbook:28
#, no-c-format
msgid "Echo Placeholder"
msgstr "प्रतिध्वनि स्थानधारक"

#. Tag: programlisting
#: useraction-xml.docbook:29
#, no-c-format
msgid ""
"&lt;!DOCTYPE KrusaderUserActions>\n"
" &lt;KrusaderUserActions>\n"
"  &lt;action name=\"test_placeholder\" >\n"
"  &lt;title>Echo Placeholder&lt;/title>\n"
"  &lt;tooltip>Echo's the placeholder values&lt;/tooltip>\n"
"  &lt;category>Testing&lt;/category>\n"
"  &lt;description same_as=\"tooltip\" />\n"
"  &lt;command executionmode=\"collect_output\" onmultiplefiles=\"call_each\" "
">echo -e &quot;aPath %aPath()%  \\naCurrent: %aCurrent()%&quot;&lt;/"
"command>\n"
" &lt;/action>\n"
"&lt;/KrusaderUserActions>"
msgstr ""
"&lt;!DOCTYPE क्रूसेडरप्रयोक्तृक्रियाः>\n"
" &lt;क्रूसेडरप्रयोक्तृक्रियाः>\n"
"  &lt;action name=\"परीक्षण_स्थानधारक\" >\n"
"  &lt;title>प्रतिध्वनिस्थानधारक&lt;/title>\n"
"  &lt;tooltip>Echo इत्यस्य स्थानधारकमूल्यानि&lt;/tooltip> सन्ति\n"
"  &lt;वर्ग>परीक्षण&lt;/श्रेणी>\n"
"  &lt;वर्णन same_as=\"उपकरणसूची\" />\n"
"  &lt;command executionmode=\"collect_output\" onmultiplefiles=\"call_each\" "
">echo -e &quot;aPath %aPath()% \\naवर्तमान: %aवर्तमान()%&quot;&lt;/आदेश>\n"
" &lt;/कर्म>\n"
"&lt;/क्रूसेडरप्रयोक्तृक्रियाः>"

#. Tag: para
#: useraction-xml.docbook:32
#, no-c-format
msgid "This useraction copies current path and filename to clipboard:"
msgstr "इदं useraction वर्तमानमार्गं सञ्चिकानाम च क्लिप्बोर्ड् प्रति प्रतिलिखति:"

#. Tag: programlisting
#: useraction-xml.docbook:33
#, no-c-format
msgid ""
"&lt;!DOCTYPE KrusaderUserActions>\n"
"&lt;KrusaderUserActions>\n"
" &lt;action name=\"clipboard current\" >\n"
"  &lt;title>Copy to Clipboard&lt;/title>\n"
"  &lt;tooltip>Copy to clipboard&lt;/tooltip>\n"
"  &lt;icon>klipper&lt;/icon>\n"
"  &lt;category>System&lt;/category>\n"
"  &lt;description>Copy current path and filename to clipboard&lt;/"
"description>\n"
"  &lt;command>%_Clipboard(&quot;%aCurrent%&quot;)%&lt;/command>\n"
"  &lt;defaultshortcut>Win+C&lt;/defaultshortcut>\n"
" &lt;/action>\n"
"&lt;/KrusaderUserActions>"
msgstr ""
"&lt;!DOCTYPE क्रूसेडरप्रयोक्तृक्रियाः>\n"
"&lt;क्रूसेडरप्रयोक्तृक्रियाः>\n"
" &lt;action name=\"क्लिपबोर्ड वर्तमान\" >\n"
"  &lt;title>क्लिप्बोर्ड् प्रति प्रतिलिपिं कुर्वन्तु&lt;/title>\n"
"  &lt;tooltip>क्लिप्बोर्ड् प्रति प्रतिलिख्यताम्&lt;/tooltip>\n"
"  &lt;चिह्न>क्लिपर&lt;/चिह्न>\n"
"  &lt;वर्ग>प्रणाली&lt;/श्रेणी>\n"
"  &lt;description>वर्तमानमार्गं सञ्चिकानाम च क्लिप्बोर्ड् प्रति प्रतिलिख्यताम्&lt;/"
"description>\n"
"  &lt;command>%_Clipboard(&quot;%aवर्तमान%&quot;)%&lt;/आदेश>\n"
"  &lt;defaulttshortcut>विजय+C&lt;/defaulttshortcut>\n"
" &lt;/कर्म>\n"
"&lt;/क्रूसेडरप्रयोक्तृक्रियाः>"

#. Tag: para
#: useraction-xml.docbook:36
#, no-c-format
msgid ""
"Selects <literal role=\"extension\">.diff</literal> and <literal role="
"\"extension\">*.h</literal> in the active panel:"
msgstr ""
"सक्रियपटले <literal role=\"extension\">.diff</literal> तथा <literal role="
"\"extension\">*.h</literal> इति चयनं करोति:"

#. Tag: programlisting
#: useraction-xml.docbook:37
#, no-c-format
msgid ""
"&lt;!DOCTYPE KrusaderUserActions>\n"
"&lt;KrusaderUserActions>\n"
" &lt;action name=\"test_select\" >\n"
"  &lt;title>Add selection *.diff and *.h&lt;/title>\n"
"  &lt;category>Selection&lt;/category>\n"
"  &lt;command>%aSelect(&quot;*.diff&quot;, &quot;add&quot;)% %aSelect(&quot;"
"*.h&quot;, &quot;add&quot;)%&lt;/command>\n"
" &lt;/action>\n"
"&lt;/KrusaderUserActions>"
msgstr ""
"&lt;!DOCTYPE क्रूसेडरप्रयोक्तृक्रियाः>\n"
"&lt;क्रूसेडरप्रयोक्तृक्रियाः>\n"
" &lt;action name=\"परीक्षण_चयन\" >\n"
"  &lt;title>चयनं *.diff तथा *.h&lt;/title> योजयतु\n"
"  &lt;वर्ग>चयन&lt;/श्रेणी>\n"
"  &lt;आदेश>% aSelect(&quot;*.diff&quot;, &quot;जोड&quot;)% %aSelect(&quot;*."
"h&quot;, &quot;जोड़े&quot;)%&lt;/आदेश>\n"
" &lt;/कर्म>\n"
"&lt;/क्रूसेडरप्रयोक्तृक्रियाः>"

#. Tag: para
#: useraction-xml.docbook:40
#, no-c-format
msgid "Active panel changes to <filename>mnt/floppy</filename> (bookmark):"
msgstr "सक्रियपटलः <filename>mnt/floppy</filename> (बुकमार्क) इति परिवर्तते:"

#. Tag: programlisting
#: useraction-xml.docbook:41
#, no-c-format
msgid ""
"&lt;!DOCTYPE KrusaderUserActions>\n"
"&lt;KrusaderUserActions>\n"
"&lt;action name=\"mnt/floppy bookmark\" >\n"
"  &lt;title>Jump to /mnt/floppy&lt;/title>\n"
"  &lt;category>Bookmarks&lt;/category>\n"
"  &lt;command>%aGoto(&quot;/mnt/floppy&quot;, &quot;yes&quot;)%&lt;/"
"command>\n"
" &lt;/action>\n"
"&lt;/KrusaderUserActions>"
msgstr ""
"&lt;!DOCTYPE क्रूसेडरप्रयोक्तृक्रियाः>\n"
"&lt;क्रूसेडरप्रयोक्तृक्रियाः>\n"
"&lt;action name=\"mnt/फ्लॉपी बुकमार्क\" >\n"
"  &lt;title>/mnt/floppy&lt;/title> इत्यत्र कूदन्तु\n"
"  &lt;वर्ग>पुस्तकचिह्न&lt;/श्रेणी>\n"
"  &lt;command>%aGoto(&quot;/mnt/floppy&quot;, &quot;हाँ&quot;)%&lt;/आदेश>\n"
" &lt;/कर्म>\n"
"&lt;/क्रूसेडरप्रयोक्तृक्रियाः>"

#. Tag: para
#: useraction-xml.docbook:44
#, no-c-format
msgid ""
"Select in the non-active panel, all filenames that are highlighted in the "
"active panel:"
msgstr "अ-सक्रिय-पटले, सक्रिय-पटले प्रकाशितानि सर्वाणि सञ्चिकानामानि चिनोतु:"

#. Tag: programlisting
#: useraction-xml.docbook:45
#, no-c-format
msgid ""
"&lt;!DOCTYPE KrusaderUserActions>\n"
"&lt;KrusaderUserActions>\n"
" &lt;action name=\"asdfasdf\" >\n"
"  &lt;title>Select in Other Panel&lt;/title>\n"
"  &lt;category>Selection&lt;/category>\n"
"  &lt;description>Select all filenames that are selected in the active "
"panel, also in the non-active panel&lt;/description>\n"
"  &lt;command>%oSelect(&quot;%aList(&quot;selected&quot;, &quot; &quot;, "
"&quot;Yes&quot;)%&quot;)%&lt;/command>\n"
" &lt;/action>\n"
"&lt;/KrusaderUserActions>"
msgstr ""
"&lt;!DOCTYPE क्रूसेडरप्रयोक्तृक्रियाः>\n"
"&lt;क्रूसेडरप्रयोक्तृक्रियाः>\n"
" &lt;क्रिया नाम=\"asdfasdf\" >\n"
"  &lt;title>अन्यपटलमध्ये चिनोतु&lt;/title>\n"
"  &lt;वर्ग>चयन&lt;/श्रेणी>\n"
"  &lt;description>सक्रियफलके चयनितानि सर्वाणि सञ्चिकानामानि चिनोतु, असक्रियफलके "
"अपि&lt;/description>\n"
"  &lt;command>%oSelect(&quot;%aList(&quot;चयनित&quot;, &quot; &quot;, &quot;"
"हाँ&quot;)%&quot;)%&lt;/आदेश>\n"
" &lt;/कर्म>\n"
"&lt;/क्रूसेडरप्रयोक्तृक्रियाः>"

#. Tag: para
#: useraction-xml.docbook:48
#, no-c-format
msgid ""
"Make a backup of the current file/folder to <filename>foo.bak</filename> "
"into the current folder:"
msgstr ""
"वर्तमानसञ्चिकायाः/पुटस्य <filename>foo.bak</filename> इत्यत्र वर्तमानपुटे बैकअपं कुर्वन्तु:"

#. Tag: programlisting
#: useraction-xml.docbook:49
#, no-c-format
msgid ""
"&lt;!DOCTYPE KrusaderUserActions>\n"
"&lt;KrusaderUserActions>\n"
" &lt;action name=\"backup current\" >\n"
"  &lt;title>Backup in Current Directory&lt;/title>\n"
"  &lt;tooltip>Backup in current folder&lt;/tooltip>\n"
"  &lt;icon>document-save-as&lt;/icon>\n"
"  &lt;category>System&lt;/category>\n"
"  &lt;description same_as=\"tooltip\" />\n"
"  &lt;command>%_Copy(&quot;%aCurrent%&quot;, &quot;%_Ask(&quot;new "
"name&quot;, &quot;%aCurrent%.bak&quot;)%&quot;)%&lt;/command>\n"
"  &lt;defaultshortcut>Shift+F5&lt;/defaultshortcut>\n"
" &lt;/action>\n"
"&lt;/KrusaderUserActions>"
msgstr ""
"&lt;!DOCTYPE क्रूसेडरप्रयोक्तृक्रियाः>\n"
"&lt;क्रूसेडरप्रयोक्तृक्रियाः>\n"
" &lt;action name=\"बैकअप वर्तमान\" >\n"
"  &lt;title>वर्तमाननिर्देशिकायां बैकअप&lt;/title>\n"
"  &lt;tooltip>वर्तमानपुटे बैकअप&lt;/tooltip>\n"
"  &lt;चिह्न>दस्तावेज-रचना-यथा&lt;/चिह्न>\n"
"  &lt;वर्ग>प्रणाली&lt;/श्रेणी>\n"
"  &lt;वर्णन same_as=\"उपकरणसूची\" />\n"
"  &lt;command>%_Copy(&quot;%aवर्तमान%&quot;, &quot;%_Ask(&quot;नवनाम&quot;, "
"&quot;%aवर्तमान%.bak&quot;)%&quot;)%&lt;/command>\n"
"  &lt;defaulttshortcut>शिफ्ट+F5&lt;/defaulttshortcut>\n"
" &lt;/कर्म>\n"
"&lt;/क्रूसेडरप्रयोक्तृक्रियाः>"

#. Tag: para
#: useraction-xml.docbook:52
#, no-c-format
msgid "Opens <link linkend=\"krusearcher\">KruSearcher</link>:"
msgstr "उद्घाट्यते<link linkend=\"krusearcher\"> क्रूसर्चर</link> :"

#. Tag: programlisting
#: useraction-xml.docbook:53
#, no-c-format
msgid ""
"&lt;!DOCTYPE KrusaderUserActions>\n"
"&lt;KrusaderUserActions>\n"
" &lt;action name=\"search\" >\n"
"  &lt;title>Search Test&lt;/title>\n"
"  &lt;command>%_NewSearch(&quot;Search 2&quot;)%&lt;/command>\n"
" &lt;/action>\n"
"&lt;/KrusaderUserActions>"
msgstr ""
"&lt;!DOCTYPE क्रूसेडरप्रयोक्तृक्रियाः>\n"
"&lt;क्रूसेडरप्रयोक्तृक्रियाः>\n"
" &lt;action name=\"अन्वेषणम्\" >\n"
"  &lt;title>अन्वेषणपरीक्षा&lt;/title>\n"
"  &lt;command>%_NewSearch(&quot;अन्वेषण 2&quot;)%&lt;/command>\n"
" &lt;/कर्म>\n"
"&lt;/क्रूसेडरप्रयोक्तृक्रियाः>"

#. Tag: para
#: useraction-xml.docbook:56
#, no-c-format
msgid "Sets the selected picture as wallpaper:"
msgstr "चयनितं चित्रं वॉलपेपररूपेण सेट् करोति:"

#. Tag: programlisting
#: useraction-xml.docbook:57
#, no-c-format
msgid ""
"&lt;!DOCTYPE KrusaderUserActions>\n"
"&lt;KrusaderUserActions>\n"
" &lt;action name=\"set wallpaper\" >\n"
"  &lt;title>Set as Wallpaper&lt;/title>\n"
"  &lt;tooltip>Set as wallpaper&lt;/tooltip>\n"
"  &lt;icon>image&lt;/icon>\n"
"  &lt;category>Service Menu&lt;/category>\n"
"  &lt;description>Set as wallpaper (scaled)&lt;/description>\n"
"  &lt;command>dcop kdesktop KBackgroundIface setWallpaper &quot;%aCurrent"
"%&quot; 6&lt;/command>\n"
"  &lt;defaultshortcut>Win+W&lt;/defaultshortcut>\n"
" &lt;/action>\n"
"&lt;/KrusaderUserActions>"
msgstr ""
"&lt;!DOCTYPE क्रूसेडरप्रयोक्तृक्रियाः>\n"
"&lt;क्रूसेडरप्रयोक्तृक्रियाः>\n"
" &lt;action name=\"वॉलपेपर सेट् कुर्वन्तु\" >\n"
"  &lt;title>वालपेपररूपेण सेट् कुर्वन्तु&lt;/title>\n"
"  &lt;tooltip>वॉलपेपररूपेण सेट् कुर्वन्तु&lt;/tooltip>\n"
"  &lt;चिह्न>प्रतिबिम्ब&lt;/चिह्न>\n"
"  &lt;category>सेवा मेनू&lt;/category>\n"
"  &lt;description>वॉलपेपर (स्केल) इति सेट् कुर्वन्तु&lt;/description>\n"
"  &lt;command>dcop kdesktop KBackgroundIface setWallpaper &quot;%aवर्तमान"
"%&quot; ६&lt;/आदेशः>\n"
"  &lt;defaulttshortcut>विजय+W&lt;/defaulttshortcut>\n"
" &lt;/कर्म>\n"
"&lt;/क्रूसेडरप्रयोक्तृक्रियाः>"

#. Tag: para
#: useraction-xml.docbook:60
#, no-c-format
msgid ""
"This useraction edits a file with root permissions using <command>kdesu</"
"command>:"
msgstr ""
"इदं useraction <command>kdesu</command> इत्यस्य उपयोगेन मूल-अनुमतियुक्तां सञ्चिकां "
"सम्पादयति:"

#. Tag: programlisting
#: useraction-xml.docbook:61
#, no-c-format
msgid ""
"&lt;!DOCTYPE KrusaderUserActions>\n"
"&lt;KrusaderUserActions>\n"
" &lt;action name=\"edit as root\" >\n"
"  &lt;title>Edit as Root&lt;/title>\n"
"  &lt;tooltip>Edit as root&lt;/tooltip>\n"
"  &lt;icon>kwrite&lt;/icon>\n"
"  &lt;category>System&lt;/category>\n"
"  &lt;description>Edit a file with root permissions using kdesu&lt;/"
"description>\n"
"  &lt;command>kdesu kwrite %aCurrent%&lt;/command>\n"
"  &lt;defaultshortcut>Win+F4&lt;/defaultshortcut>\n"
" &lt;/action>\n"
"&lt;/KrusaderUserActions>"
msgstr ""
"&lt;!DOCTYPE क्रूसेडरप्रयोक्तृक्रियाः>\n"
"&lt;क्रूसेडरप्रयोक्तृक्रियाः>\n"
" &lt;action name=\"मूलरूपेण सम्पादयतु\" >\n"
"  &lt;title>मूलरूपेण सम्पादयतु&lt;/title>\n"
"  &lt;tooltip>मूलरूपेण सम्पादयतु&lt;/tooltip>\n"
"  &lt;चिह्न>कलेखन&lt;/चिह्न>\n"
"  &lt;वर्ग>प्रणाली&lt;/श्रेणी>\n"
"  &lt;description>kdesu&lt;/description> इत्यस्य उपयोगेन मूलानुमतियुक्तां सञ्चिकां "
"सम्पादयन्तु\n"
"  &lt;आदेश>kdesu kwrite %aवर्तमान%&lt;/आदेश>\n"
"  &lt;defaulttshortcut>विजय+F4&lt;/defaulttshortcut>\n"
" &lt;/कर्म>\n"
"&lt;/क्रूसेडरप्रयोक्तृक्रियाः>"

#. Tag: para
#: useraction-xml.docbook:64
#, no-c-format
msgid "This useraction Add item(s) to Amarok playlist:"
msgstr "This useraction Amarok प्लेलिस्ट् मध्ये द्रव्यं (वस्तूनि) योजयन्तु:"

#. Tag: programlisting
#: useraction-xml.docbook:65
#, no-c-format
msgid ""
"&lt;!DOCTYPE KrusaderUserActions>\n"
"&lt;KrusaderUserActions>\n"
" &lt;action name=\"amarok enqueue\" >\n"
"  &lt;title>Enqueue in Amarok&lt;/title>\n"
"  &lt;tooltip>Append selected item(s) to Amarok playlist&lt;/tooltip>\n"
"  &lt;icon>amarok&lt;/icon>\n"
"  &lt;category>Multimedia&lt;/category>\n"
"  &lt;description same_as=\"tooltip\" />\n"
"  &lt;command>amarok --append %aList(&quot;Selected&quot;)%&lt;/command>\n"
"  &lt;defaultshortcut>Win+A&lt;/defaultshortcut>\n"
" &lt;/action>\n"
"&lt;/KrusaderUserActions>"
msgstr ""
"&lt;!DOCTYPE क्रूसेडरप्रयोक्तृक्रियाः>\n"
"&lt;क्रूसेडरप्रयोक्तृक्रियाः>\n"
" &lt;action name=\"अमारोक् एनक्यू\" >\n"
"  &lt;title>अमारोक्&lt;/title> इत्यत्र पङ्क्तिं कुर्वन्तु\n"
"  &lt;tooltip>चयनितं द्रव्यं (वस्तूनि) Amarok प्लेलिस्ट् मध्ये योजयन्तु&lt;/tooltip>\n"
"  &lt;चिह्न>अमारोक्&lt;/चिह्न>\n"
"  &lt;वर्ग>बहुमाध्यम&lt;/श्रेणी>\n"
"  &lt;वर्णन same_as=\"उपकरणसूची\" />\n"
"  &lt;command>amarok --append % aList (&quot;चयनित&quot;)%&lt;/आदेश>\n"
"  &lt;defaulttshortcut>विजय+A&lt;/defaulttshortcut>\n"
" &lt;/कर्म>\n"
"&lt;/क्रूसेडरप्रयोक्तृक्रियाः>"

#. Tag: para
#: useraction-xml.docbook:68
#, no-c-format
msgid "Opens <link linkend=\"synchronizer\">Synchronizer</link>:"
msgstr "उद्घाट्यते<link linkend=\"synchronizer\"> समन्वयक</link> :"

#. Tag: programlisting
#: useraction-xml.docbook:69
#, no-c-format
msgid ""
"&lt;!DOCTYPE KrusaderUserActions>\n"
"&lt;KrusaderUserActions>\n"
" &lt;action name=\"synchronizer\" >\n"
"  &lt;title>Synchronizer&lt;/title>\n"
"  &lt;command>%_Sync(&quot;Sync 2&quot;)%&lt;/command>\n"
" &lt;/action>\n"
"&lt;/KrusaderUserActions>"
msgstr ""
"&lt;!DOCTYPE क्रूसेडरप्रयोक्तृक्रियाः>\n"
"&lt;क्रूसेडरप्रयोक्तृक्रियाः>\n"
" &lt;action name=\"समन्वयक\" >\n"
"  &lt;title>समन्वयक&lt;/title>\n"
"  &lt;command>%_Sync(&quot;सिंक 2&quot;)%&lt;/आदेश>\n"
" &lt;/कर्म>\n"
"&lt;/क्रूसेडरप्रयोक्तृक्रियाः>"
