#. Tag: title
#: features.docbook:8
#, no-c-format
msgid "<title>Features</title>"
msgstr "<title>गुणाः</title>"

#. Tag: primary
#: features.docbook:10
#, no-c-format
msgid "<primary>Features</primary>"
msgstr "<primary>विशेषताः</primary>"

#. Tag: para
#: features.docbook:13
#, no-c-format
msgid ""
"The most important features and improvements are highlighted here, it would "
"make this list too long if we were to include <emphasis>all</emphasis> the "
"features and improvements. You will discover even more features in this "
"documentation and in the <ulink url=\"https://commits.kde.org/krusader?"
"path=ChangeLog\"><filename>ChangeLog</filename></ulink> and <ulink url="
"\"https://commits.kde.org/krusader?path=NEWS\"><filename>NEWS</filename></"
"ulink> files."
msgstr ""
"अत्र महत्त्वपूर्णाः विशेषताः सुधाराः च प्रकाशिताः सन्ति, यदि वयं <emphasis>all</"
"emphasis> विशेषताः सुधाराः च समाविष्टाः भवेयुः तर्हि एषा सूची अतीव दीर्घा भविष्यति "
"अस्मिन् दस्तावेजे अपि च <ulink url=\"https://commits.kde.org/krusader?"
"path=ChangeLog\"><filename>ChangeLog</filename></ulink> <ulink url इत्यत्र च "
"अधिकानि विशेषतानि आविष्करिष्यन्ति =\"https://commits.kde.org/krusader?path=NEWS"
"\"><सञ्चिकानाम>समाचार</filename></ulink> सञ्चिकाः ।"

#. Tag: title
#: features.docbook:27
#, no-c-format
msgid ""
"<ulink url=\"http://www.softpanorama.org/OFM/index.shtml\">Orthodox File "
"Manager (OFM)</ulink> features"
msgstr ""
"<ulink url=\"http://www.softpanorama.org/OFM/index.shtml\">रूढिवादी "
"सञ्चिकाप्रबन्धकः (OFM)</ulink> इति विशेषताः"

#. Tag: para
#: features.docbook:29
#, no-c-format
msgid ""
"Two powerful and easy to use <link linkend=\"panels\">OFM panels</link>."
msgstr "द्वौ शक्तिशालिनौ सुलभौ च<link linkend=\"panels\"> ओएफएम पटल</link> ."

#. Tag: para
#: features.docbook:33
#, no-c-format
msgid ""
"<link linkend=\"cmdline\">Command Line</link> and optional <link linkend="
"\"termemu\">Terminal emulator</link> below."
msgstr ""
"<link linkend=\"cmdline\">आदेशपङ्क्तिः</link> वैकल्पिकं च<link linkend=\"termemu"
"\"> टर्मिनल एमुलेटर</link> अधः।"

#. Tag: para
#: features.docbook:37
#, no-c-format
msgid ""
"Strong <link linkend=\"keyboard-commands\">keyboard</link> orientation and "
"the ability to perform all functions without the mouse."
msgstr ""
"समर्थः<link linkend=\"keyboard-commands\"> कीबोर्ड</link> अभिमुखीकरणं मूषकं विना "
"सर्वाणि कार्याणि कर्तुं क्षमता च।"

#. Tag: para
#: features.docbook:42
#, no-c-format
msgid ""
"Context-dependent invocation of scripts and programs &eg; mouse click/"
"&Enter; (execute or open with the associated application), <keycap>F3</"
"keycap> (view) and <keycap>F4</keycap> (edit)."
msgstr ""
"स्क्रिप्ट्-प्रोग्राम्-योः सन्दर्भ-निर्भर-आह्वानं &eg; मूषकस्य क्लिक्/&Enter; (सम्बद्धेन "
"अनुप्रयोगेन सह निष्पादयन्तु अथवा उद्घाटयन्तु), <keycap>F3</keycap> (दृश्यम्) तथा "
"<keycap>F4</keycap> (सम्पादयन्तु) ।"

#. Tag: para
#: features.docbook:48
#, no-c-format
msgid ""
"<link linkend=\"useractions\">User Menu</link>, create your own customized "
"menu."
msgstr ""
"<link linkend=\"useractions\">उपयोक्ता मेनू</link> , स्वकीयं अनुकूलितं मेनू रचयन्तु ।"

#. Tag: para
#: features.docbook:52
#, no-c-format
msgid ""
"History &eg; <link linkend=\"folderhistory\">Folder History</link>, <link "
"linkend=\"popular-urls\">Popular &URL;s</link>, &etc;"
msgstr ""
"इतिहास ⪚<link linkend=\"folderhistory\"> फोल्डर इतिहास</link> , ९.<link "
"linkend=\"popular-urls\"> लोकप्रिय &amp;URL;s</link> , &amp;इत्यादि;"

#. Tag: para
#: features.docbook:58
#, no-c-format
msgid ""
"<link linkend=\"vfs\">Virtual file systems (VFS)</link> &eg; for <link "
"linkend=\"remote-connections\">Remote Connections</link>, <link linkend="
"\"archives\">archives</link>, search results, synchronizer."
msgstr ""
"<link linkend=\"vfs\">आभासी सञ्चिकातन्त्राणि (VFS) २.</link> ⪚ हि<link linkend="
"\"remote-connections\"> दूरस्थसंयोजनानि</link> , ९.<link linkend=\"archives\"> "
"अभिलेखागाराः</link> , अन्वेषणपरिणामः, समन्वयकः।"

#. Tag: para
#: features.docbook:64
#, no-c-format
msgid ""
"Powerful internal <link linkend=\"krviewer\">viewer and editor</link> via "
"kparts supporting almost every file format."
msgstr ""
"शक्तिशाली आन्तरिक<link linkend=\"krviewer\"> दर्शकः सम्पादकः च</link> प्रायः "
"प्रत्येकं सञ्चिकास्वरूपं समर्थयन् kparts मार्गेण ।"

#. Tag: para
#: features.docbook:69
#, no-c-format
msgid ""
"<link linkend=\"krusearcher\">Advanced Search module</link>: searching in "
"archives and search content on remote file systems."
msgstr ""
"<link linkend=\"krusearcher\">उन्नत अन्वेषण मॉड्यूल</link> : अभिलेखागारेषु अन्वेषणं "
"दूरस्थसञ्चिकातन्त्रेषु सामग्रीं अन्वेष्टुं च।"

#. Tag: para
#: features.docbook:74
#, no-c-format
msgid ""
"Several Panel view modes via the <link linkend=\"sidebar\">Sidebar</link>."
msgstr ""
"मार्गेण अनेकाः Panel view modes<link linkend=\"sidebar\"> पार्श्वपट्टिका</link> ."

#. Tag: title
#: features.docbook:83
#, no-c-format
msgid "&krusader; tools"
msgstr "&क्रूसेडर; उपकरणाः"

#. Tag: para
#: features.docbook:85
#, no-c-format
msgid ""
"<link linkend=\"remote-connections\">Remote Connections</link>: &FTP;/SAMBA "
"with SFTP/SCP support via KIO Slaves"
msgstr ""
"<link linkend=\"remote-connections\">दूरस्थसंयोजनानि</link> : &amp;FTP;/SAMBA "
"KIO Slaves मार्गेण SFTP/SCP समर्थनेन सह"

#. Tag: para
#: features.docbook:90
#, no-c-format
msgid "<link linkend=\"locate\">Locate</link> &GUI; frontend"
msgstr "<link linkend=\"locate\">स्थानं ज्ञातव्यम्</link> &amp;GUI; अग्रभागः"

#. Tag: link
#: features.docbook:93
#, no-c-format
msgid "Synchronize Folders"
msgstr "Folders समन्वयनम्"

#. Tag: link
#: features.docbook:97
#, no-c-format
msgid "Mount-Manager"
msgstr "पर्वत-प्रबन्धकः"

#. Tag: link
#: features.docbook:101
#, no-c-format
msgid "Disk Usage"
msgstr "डिस्कस्य उपयोगः"

#. Tag: link
#: features.docbook:104
#, no-c-format
msgid "Root mode"
msgstr "मूलविधिः"

#. Tag: title
#: features.docbook:112
#, no-c-format
msgid "&krusader; features"
msgstr "&क्रूसेडर; गुणाः"

#. Tag: para
#: features.docbook:114
#, no-c-format
msgid ""
"Archive Handling: browsing, unpack, pack, testing. Supported <link linkend="
"\"archives\">archives</link>: ace, arj, bzip2, deb, gzip, iso, lha, rar, "
"rpm, tar, zip and 7-zip."
msgstr ""
"संग्रह निबन्धनम् : ब्राउजिंग्, अनपैक्, पैक्, परीक्षणम्। समर्थितम्<link linkend=\"archives"
"\"> अभिलेखागाराः</link> : ace, arj, bzip2, deb, gzip, iso, lha, rar, rpm, "
"tar, zip and 7-zip."

#. Tag: para
#: features.docbook:120
#, no-c-format
msgid ""
"<link linkend=\"checksum\">Checksum Creation and Verification</link> "
"mechanism that supports md5, sha1, sha256, sha224, sha256, sha384, sha512, "
"tiger, whirlpool, cfv, and crc."
msgstr ""
"<link linkend=\"checksum\">चेकसम निर्माण तथा सत्यापन</link> तन्त्रं यत् md5, sha1, "
"sha256, sha224, sha256, sha384, sha512, व्याघ्रः, भंवरः, cfv, तथा crc समर्थयति।"

#. Tag: para
#: features.docbook:127
#, no-c-format
msgid ""
"<link linkend=\"calculate\">Calculate occupied space</link> of files and "
"folders, archives and remote filesystems."
msgstr ""
"<link linkend=\"calculate\">कब्जाकृतस्थानस्य गणनां कुरुत</link> सञ्चिकानां पुटकानां च, "
"अभिलेखानां दूरस्थसञ्चिकातन्त्राणां च ।"

#. Tag: para
#: features.docbook:133
#, no-c-format
msgid ""
"<link linkend=\"compare-dir\">Directory comparison</link> and <link linkend="
"\"view-menu\">filtering</link>."
msgstr ""
"<link linkend=\"compare-dir\">निर्देशिकातुलना</link> तथा<link linkend=\"view-"
"menu\"> छाननम्</link> ."

#. Tag: para
#: features.docbook:139
#, no-c-format
msgid ""
"<link linkend=\"compare-content\">Compare files by content</link> via "
"external diff programs like &kompare;, <ulink url=\"https://www.kde.org/"
"applications/development/kdiff3/\"><application>KDiff3</application></ulink> "
"or <ulink url=\"http://furius.ca/xxdiff/\"><application>xxdiff</"
"application></ulink>."
msgstr ""
"<link linkend=\"compare-content\">सामग्रीद्वारा सञ्चिकानां तुलनां कुर्वन्तु</link> "
"&amp;kompare;, इत्यादीनां बाह्य diff कार्यक्रमानां माध्यमेन ।<ulink url=\"https://"
"www.kde.org/applications/development/kdiff3/\"><application> KDiff3</"
"application></ulink> वा<ulink url=\"http://furius.ca/xxdiff/\"><application> "
"xxdiff</application></ulink> ."

#. Tag: para
#: features.docbook:146
#, no-c-format
msgid ""
"<link linkend=\"multi_rename\">Rename</link> files and folders via <ulink "
"url=\"https://www.kde.org/applications/utilities/krename/"
"\"><application>KRename</application></ulink>"
msgstr ""
"<link linkend=\"multi_rename\">पुनर्नाम</link> सञ्चिकाः पुटं च मार्गेण<ulink url="
"\"https://www.kde.org/applications/utilities/krename/\"><application> "
"KRename</application></ulink>"

#. Tag: para
#: features.docbook:151
#, no-c-format
msgid ""
"Completely supports drag'n'drop: drag from &konqueror; straight into a "
"<literal role=\"extension\">.tar.gz</literal> file, from &krusader;'s panel "
"into the trash bin, the desktop or into &konqueror;"
msgstr ""
"drag'n'drop इत्यस्य पूर्णतया समर्थनं करोति: &konqueror; सीधा <literal role="
"\"extension\">.tar.gz</literal> सञ्चिकायां, &krusader;इत्यस्य पटलात् कचराबन्दं, "
"डेस्कटॉप् अथवा &konqueror;"

#. Tag: para
#: features.docbook:157
#, no-c-format
msgid ""
"<link linkend=\"konfig-advanced\">Preserve date</link> for local targets at "
"copy/move operations."
msgstr ""
"<link linkend=\"konfig-advanced\">तिथि संरक्षित करें</link> प्रतिलिपि/"
"स्थानांतरणसञ्चालनेषु स्थानीयलक्ष्याणां कृते।"

#. Tag: para
#: features.docbook:162
#, no-c-format
msgid ""
"<keycap>F9</keycap> opens a <link linkend=\"tools-menu\">Terminal Window</"
"link> in the current folder."
msgstr ""
"<keycap>F9</keycap> उद्घाटयति a<link linkend=\"tools-menu\"> टर्मिनल विण्डो</"
"link> वर्तमानपुटे ।"

#. Tag: para
#: features.docbook:167
#, no-c-format
msgid ""
"Easy editing of <link linkend=\"file-menu\">file permissions</link> and "
"ownership and <link linkend=\"konfig-panel-view\">Numeric Permissions</link>."
msgstr ""
"के सुलभ सम्पादनम्<link linkend=\"file-menu\"> सञ्चिकायाः अनुमतिः</link> स्वामित्वं "
"च<link linkend=\"konfig-panel-view\"> संख्यात्मकाः अनुमतिः</link> ."

#. Tag: para
#: features.docbook:174
#, no-c-format
msgid ""
"<link linkend=\"krusearcher\">Selection filters</link> used in &eg; "
"Synchronizer and KruSearcher."
msgstr ""
"<link linkend=\"krusearcher\">चयन-छिद्रकाः</link> ⪚ Synchronizer तथा "
"KruSearcher इत्यत्र प्रयुक्तम् ।"

#. Tag: link
#: features.docbook:181
#, no-c-format
msgid "Jump-Back"
msgstr "कूद-पृष्ठम्"

#. Tag: para
#: features.docbook:185
#, no-c-format
msgid "<link linkend=\"konfig-general\"> &MIME; type-aware</link>."
msgstr "<link linkend=\"konfig-general\">&amp;MIME; प्रकार-जागरूकः</link> ."

#. Tag: para
#: features.docbook:190
#, no-c-format
msgid ""
"<link linkend=\"folder-tabs\">Tabbed panels</link> and <link linkend="
"\"krviewer\">Tabbed Editor/Viewer</link>."
msgstr ""
"<link linkend=\"folder-tabs\">ट्याब्ड् फलकम्</link> तथा<link linkend=\"krviewer"
"\"> ट्याब्ड् सम्पादकः/दर्शकः</link> ."

#. Tag: link
#: features.docbook:196
#, no-c-format
msgid "Quick search, select and filter"
msgstr "शीघ्रं अन्वेषणं, चयनं, छाननं च"

#. Tag: link
#: features.docbook:200
#, no-c-format
msgid "File splitter"
msgstr "सञ्चिकाविभाजकः"

#. Tag: para
#: features.docbook:204
#, no-c-format
msgid "Mouse Gestures"
msgstr "मूषकस्य इशाराः"

#. Tag: para
#: features.docbook:209
#, no-c-format
msgid ""
"<link linkend=\"list_panel\">Quick Navigation</link> in the Location Toolbar."
msgstr ""
"<link linkend=\"list_panel\">त्वरित नेविगेशन</link> Location Toolbar इत्यत्र ।"

#. Tag: para
#: features.docbook:214
#, no-c-format
msgid "WhatsThis Help function in favour of tooltips where reasonable."
msgstr "WhatsThis Help यत्र उचितं तत्र tooltips इत्यस्य पक्षे कार्यं करोति।"

#. Tag: link
#: features.docbook:218
#, no-c-format
msgid "Sync-browsing"
msgstr "समन्वयन-ब्राउजिंग"

#. Tag: title
#: features.docbook:226
#, no-c-format
msgid "Customize &krusader; to your own needs"
msgstr "अनुकूलितं कुरुत &krusader; स्वस्य आवश्यकतानुसारम्"

#. Tag: para
#: features.docbook:229
#, no-c-format
msgid ""
"<link linkend=\"konfig-startup\"> Konfigurator</link> &krusader;'s "
"configuration center."
msgstr ""
"<link linkend=\"konfig-startup\">विन्यासकर्ता</link> &amp;krusader;&#39;s "
"विन्यासकेन्द्रम् ।"

#. Tag: para
#: features.docbook:235
#, no-c-format
msgid ""
"<link linkend=\"mainwindow\">Main Toolbar</link>, <link linkend="
"\"actions_toolbar\">Actions Toolbar</link> for user actions and bookmarks."
msgstr ""
"<link linkend=\"mainwindow\">मुख्य साधनपट्टी</link> , ९.<link linkend="
"\"actions_toolbar\"> क्रियाः साधनपट्टिका</link> उपयोक्तृक्रियाणां पुस्तकचिह्नानां च कृते "
"।"

#. Tag: link
#: features.docbook:241
#, no-c-format
msgid "Key-bindings"
msgstr "कील-बन्धनानि"

#. Tag: link
#: features.docbook:246
#, no-c-format
msgid "Colors"
msgstr "वर्णाः"

#. Tag: link
#: features.docbook:250
#, no-c-format
msgid "Panel profiles"
msgstr "पैनल प्रोफाइल"

#. Tag: link
#: features.docbook:253
#, no-c-format
msgid "Bookmark-Manager"
msgstr "बुकमार्क-प्रबन्धक"

#. Tag: link
#: features.docbook:256
#, no-c-format
msgid "Selection Modes"
msgstr "चयनविधयः"

#. Tag: para
#: features.docbook:259
#, no-c-format
msgid ""
"Many more features can be <link linkend=\"konfig-startup\">configured</link> "
"the way you like."
msgstr ""
"अनेकानि अधिकानि विशेषतानि भवितुम् अर्हन्ति<link linkend=\"konfig-startup\"> "
"विन्यस्तम्</link> यथा भवतः रोचते।"

#. Tag: title
#: features.docbook:269
#, no-c-format
msgid "&krusader; Extensions"
msgstr "&krusader; विस्तारः"

#. Tag: link
#: features.docbook:271
#, no-c-format
msgid "UserActions"
msgstr "उपयोक्तृक्रियाः"

#. Tag: link
#: features.docbook:274
#, no-c-format
msgid "Color Profiles"
msgstr "रङ्ग प्रोफाइल"

#. Tag: link
#: features.docbook:277
#, no-c-format
msgid "Key-binding Profiles"
msgstr "कील-बन्धन प्रोफाइल"

#. Tag: para
#: features.docbook:279
#, no-c-format
msgid ""
"Download and upload your favourite &krusader; extensions at <ulink url="
"\"https://store.kde.org/\">store.kde.org</ulink>."
msgstr ""
"स्वस्य प्रियं &krusader; <ulink url=\"https://store.kde.org/\">store.kde.org</"
"ulink> इत्यत्र विस्ताराः ।"

#. Tag: title
#: features.docbook:288
#, no-c-format
msgid ""
"New features in the &krusader;-1.80.0 <quote>Final 3rd Stone</quote> release"
msgstr ""
"&krusader;-1.80.0 <quote>अन्तिमः तृतीयः पाषाणः</quote> विमोचने नूतनाः विशेषताः"

#. Tag: para
#: features.docbook:291
#, no-c-format
msgid "Archive improvements"
msgstr "अभिलेखागारसुधाराः"

#. Tag: para
#: features.docbook:294
#, no-c-format
msgid ""
"<link linkend=\"archives\">Password support</link> for: arj, ace, rar and "
"zip. Passwords can be stored in <application>Kwallet</application>"
msgstr ""
"<link linkend=\"archives\">गुप्तशब्दसमर्थनम्</link> for: अर्ज्, ऐसे, रर तथा ज़िप। "
"गुप्तशब्दाः अत्र संग्रहीतुं शक्यन्ते<application> क्वालेट्</application>"

#. Tag: para
#: features.docbook:300
#, no-c-format
msgid ""
"<link linkend=\"archives\">7-zip support</link>, by external applications "
"<application>7z</application> and <application>7za</application>."
msgstr ""
"<link linkend=\"archives\">७-जिप् समर्थनम्</link> , बाह्यप्रयोगैः<application> ७ज़्</"
"application> तथा<application> ७जा</application> ."

#. Tag: para
#: features.docbook:306
#, no-c-format
msgid ""
"<link linkend=\"archives\">Auto-detection support</link>, allowing you to "
"open <quote>hidden archives</quote> (&eg; <trademark class=\"registered"
"\">OpenOffice</trademark> documents)."
msgstr ""
