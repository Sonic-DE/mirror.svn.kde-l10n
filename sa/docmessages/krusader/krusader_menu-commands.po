#. Tag: title
#: menu-commands.docbook:8
#, no-c-format
msgid "Menu Commands"
msgstr "मेनू आदेशाः"

#. Tag: primary
#: menu-commands.docbook:10
#, no-c-format
msgid "Commands"
msgstr "आदेशाः"

#. Tag: secondary
#: menu-commands.docbook:11
#, no-c-format
msgid "Menu"
msgstr "मेनू"

#. Tag: title
#: menu-commands.docbook:14
#, no-c-format
msgid "File Menu"
msgstr "सञ्चिका मेनू"

#. Tag: menuchoice
#: menu-commands.docbook:18
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Shift; <keycap>F4</keycap></keycombo> "
"</shortcut> <guimenu>File</guimenu> <guimenuitem>New Text File...</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Shift; <keycap>F4</keycap></keycombo> "
"</shortcut> <guimenu>सञ्चिका</guimenu> <guimenuitem>नवीनपाठसञ्चिका...</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:28
#, no-c-format
msgid ""
"Creates a new text file in the current folder, unless another folder is "
"specified. The new file is opened for editing after it is created."
msgstr ""
"वर्तमानपुटे नूतनं पाठसञ्चिकां निर्माति, यावत् अन्यत् पुटे निर्दिष्टं न भवति । नूतनसञ्चिका "
"निर्मितस्य अनन्तरं सम्पादनार्थं उद्घाटिता भवति ।"

#. Tag: menuchoice
#: menu-commands.docbook:35
#, no-c-format
msgid ""
"<shortcut> <keycap>F7</keycap> </shortcut> <guimenu>File</guimenu> "
"<guimenuitem>New Folder</guimenuitem>"
msgstr ""
"<shortcut> <keycap>F7</keycap> </shortcut> <guimenu>सञ्चिका</guimenu> "
"<guimenuitem>नवीनपुटं</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:44
#, no-c-format
msgid "Creates a new folder in the current folder."
msgstr "वर्तमानपुटे नूतनं पुटं निर्माति ।"

#. Tag: menuchoice
#: menu-commands.docbook:50
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> &Alt;&Ctrl; <keycap>S</keycap></"
"keycombo> </shortcut> <guimenu>File</guimenu> <guimenuitem>New Symlink...</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> &Alt;&Ctrl; <keycap>S</keycap></"
"keycombo> </shortcut> <guimenu>सञ्चिका</guimenu> <guimenuitem>नवीन "
"प्रतीकसम्बद्धता...</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:61
#, no-c-format
msgid "Creates a symbolic link to the currently selected file."
msgstr "वर्तमान चयनितसञ्चिकायाः प्रतीकात्मकं लिङ्कं निर्माति ।"

#. Tag: menuchoice
#: menu-commands.docbook:67
#, no-c-format
msgid ""
"<shortcut> <keycap>F3</keycap> </shortcut> <guimenu>File</guimenu> "
"<guimenuitem>View File</guimenuitem>"
msgstr ""
"<shortcut> <keycap>F3</keycap> </shortcut> <guimenu>सञ्चिका</guimenu> "
"<guimenuitem>सञ्चिकां पश्यन्तु</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:76
#, no-c-format
msgid ""
"Opens the currently selected file for <link linkend=\"kredit\">viewing</"
"link>."
msgstr "कृते वर्तमान चयनितसञ्चिकां उद्घाटयति<link linkend=\"kredit\"> दर्शनम्</link> ."

#. Tag: menuchoice
#: menu-commands.docbook:82
#, no-c-format
msgid ""
"<shortcut> <keycap>F4</keycap> </shortcut> <guimenu>File</guimenu> "
"<guimenuitem>Edit File</guimenuitem>"
msgstr ""
"<shortcut> <keycap>F4</keycap> </shortcut> <guimenu>सञ्चिका</guimenu> "
"<guimenuitem>सञ्चिका सम्पादयतु</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:91
#, no-c-format
msgid ""
"Opens the currently selected file for <link linkend=\"kredit\">editing</"
"link>."
msgstr ""
"कृते वर्तमान चयनितसञ्चिकां उद्घाटयति<link linkend=\"kredit\"> सम्पादनम्</link> ."

#. Tag: menuchoice
#: menu-commands.docbook:97
#, no-c-format
msgid ""
"<shortcut> <keycap>F5</keycap> </shortcut> <guimenu>File</guimenu> "
"<guimenuitem>Copy to other panel</guimenuitem>"
msgstr ""
"<shortcut> <keycap>F5</keycap> </shortcut> <guimenu>सञ्चिका</guimenu> "
"<guimenuitem>अन्यपटलं प्रति प्रतिलिपिं कुर्वन्तु</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:106
#, no-c-format
msgid "Copy the currently selected files or folders to the other panel."
msgstr "सम्प्रति चयनितसञ्चिकाः अथवा पुटं अन्यपटलं प्रति प्रतिलिख्यताम् ।"

#. Tag: menuchoice
#: menu-commands.docbook:112
#, no-c-format
msgid ""
"<shortcut> <keycap>F6</keycap> </shortcut> <guimenu>File</guimenu> "
"<guimenuitem>Move</guimenuitem>"
msgstr ""
"<shortcut> <keycap>F6</keycap> </shortcut> <guimenu>सञ्चिका</guimenu> "
"<guimenuitem>चल</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:121
#, no-c-format
msgid ""
"Opens a dialog to <link linkend=\"copying\">move</link> the currently "
"selected files or folders to a specified location."
msgstr ""
"एकं संवादं उद्घाटयति<link linkend=\"copying\"> चलनम्</link> वर्तमान चयनितसञ्चिकाः "
"अथवा पुटं निर्दिष्टस्थानं प्रति ।"

#. Tag: menuchoice
#: menu-commands.docbook:128
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift; <keycap>P</keycap></"
"keycombo> </shortcut> <guimenu>File</guimenu> <guimenuitem>Pack...</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&अल्ट;&Shift; <keycap>P</keycap></"
"keycombo> </shortcut> <guimenu>सञ्चिका</guimenu> <guimenuitem>पैक...</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:138
#, no-c-format
msgid ""
"Creates a <link linkend=\"pack-archive\">new archive</link> of all the "
"selected files and folders in the active panel."
msgstr ""
"सृजति क<link linkend=\"pack-archive\"> new आर्काइव</link> सक्रियपटलस्य सर्वेषां "
"चयनितसञ्चिकानां पुटस्य च ।"

#. Tag: menuchoice
#: menu-commands.docbook:146
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift; <keycap>U</keycap></"
"keycombo> </shortcut> <guimenu>File</guimenu> <guimenuitem>Unpack...</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&अल्ट;&Shift; <keycap>U</keycap></"
"keycombo> </shortcut> <guimenu>सञ्चिका</guimenu> <guimenuitem>अनपैक्...</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:156
#, no-c-format
msgid ""
"<link linkend=\"unpacking-archives\">Unpacks</link> all the selected files "
"in the active panel."
msgstr ""
"<link linkend=\"unpacking-archives\">अनपैक करोति</link> सक्रियपटले सर्वाणि "
"चयनितसञ्चिकाः ।"

#. Tag: menuchoice
#: menu-commands.docbook:163
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift; <keycap>E</keycap></"
"keycombo> </shortcut> <guimenu>File</guimenu> <guimenuitem>Test Archive</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&अल्ट;&Shift; <keycap>E</keycap></"
"keycombo> </shortcut> <guimenu>सञ्चिका</guimenu> <guimenuitem>परीक्षणसंग्रहालयः</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:173
#, no-c-format
msgid "<link linkend=\"test-archive\">Tests archive</link> for corruption."
msgstr "<link linkend=\"test-archive\">संग्रहं परीक्षते</link> भ्रष्टाचाराय ।"

#. Tag: menuchoice
#: menu-commands.docbook:180
#, no-c-format
msgid ""
"<guimenu>File</guimenu> <guimenuitem>Compare by Content...</guimenuitem>"
msgstr ""
"<guimenu>सञ्चिका</guimenu> <guimenuitem>सामग्रीद्वारा तुलनां कुरुत...</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:186
#, fuzzy, no-c-format
#| msgid ""
#| "Compares two current files by content - one from each panel via an "
#| "external graphical diff utility. By default &kompare; is used, but you "
#| "can also use &eg; <ulink url=\"http://furius.ca/xxdiff/"
#| "\"><application>xxdiff</application></ulink> or <ulink url=\"https://www."
#| "kde.org/applications/development/kdiff3/\"><application>KDiff3</"
#| "application></ulink> , change it in the <link linkend=\"konfig-"
#| "dependencies\">Konfigurator Dependencies page</link>."
msgid ""
"Compares two current files by content - one from each panel via an external "
"graphical diff utility. By default &kompare; is used, but you can also use "
"&eg; <ulink url=\"http://furius.ca/xxdiff/\"><application>xxdiff</"
"application></ulink> or <ulink url=\"https://apps.kde.org/"
"kdiff3\"><application>KDiff3</application></ulink> , change it in the <link "
"linkend=\"konfig-dependencies\">Konfigurator Dependencies page</link>."
msgstr ""
"सामग्रीद्वारा वर्तमानसञ्चिकाद्वयस्य तुलनां करोति - बाह्यचित्रात्मकविभेदस्य उपयोगितायाः "
"माध्यमेन प्रत्येकं पटलात् एकः । पूर्वनिर्धारितरूपेण &amp;kompare; उपयुज्यते, परन्तु भवन्तः ⪚ "
"इत्यस्य उपयोगं अपि कर्तुं शक्नुवन्ति<ulink url=\"http://furius.ca/xxdiff/"
"\"><application> xxdiff</application></ulink> वा<ulink url=\"https://www.kde."
"org/applications/development/kdiff3/\"><application> KDiff3</application></"
"ulink> , परिवर्तनं कृत्वा<link linkend=\"konfig-dependencies\"> विन्यासकर्ता "
"निर्भरता पृष्ठ</link> ."

#. Tag: menuchoice
#: menu-commands.docbook:196
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Shift; <keycap>F2</keycap></keycombo> "
"</shortcut> <guimenu>File</guimenu> <guimenuitem>Multi Rename...</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Shift; <keycap>F2</keycap></keycombo> "
"</shortcut> <guimenu>सञ्चिका</guimenu> <guimenuitem>बहुनामकरणं...</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:206
#, fuzzy, no-c-format
#| msgid ""
#| "This menu option starts <ulink url=\"https://www.kde.org/applications/"
#| "utilities/krename/\"><application>Krename</application></ulink>, a very "
#| "powerful external batch renamer."
msgid ""
"This menu option starts <ulink url=\"hhttps://apps.kde.org/krename"
"\"><application>Krename</application></ulink>, a very powerful external "
"batch renamer."
msgstr ""
"एषः मेन्यू विकल्पः <ulink url=\"https://www.kde.org/applications/utilities/"
"krename/\"><application>Krename</application></ulink> इति अत्यन्तं शक्तिशाली "
"बाह्यसमूहस्य पुनर्नामकरणं आरभ्यते ।"

#. Tag: title
#: menu-commands.docbook:209
#, no-c-format
msgid "Krename Features"
msgstr "क्रेनेमे विशेषताएँ"

#. Tag: para
#: menu-commands.docbook:211
#, no-c-format
msgid "Renaming a list of files based on a set of expressions"
msgstr "अभिव्यक्तिसमूहस्य आधारेण सञ्चिकासूचिकायाः पुनर्नामकरणम्"

#. Tag: para
#: menu-commands.docbook:215
#, no-c-format
msgid "Copying/moving a list of files to another folder"
msgstr "सञ्चिकानां सूचीं अन्यस्मिन् पुटे प्रतिलिपिं/स्थापनम्"

#. Tag: para
#: menu-commands.docbook:219
#, no-c-format
msgid "Convert filenames to upper/lower case"
msgstr "सञ्चिकानामानि बृहत्/लघुवर्णेषु परिवर्तयन्तु"

#. Tag: para
#: menu-commands.docbook:222
#, no-c-format
msgid "Adding numbers to filenames"
msgstr "सञ्चिकानामसु सङ्ख्याः योजयित्वा"

#. Tag: para
#: menu-commands.docbook:225
#, no-c-format
msgid "Finding and replacing parts of the filename"
msgstr "सञ्चिकानामस्य भागानां अन्वेषणं प्रतिस्थापनं च"

#. Tag: para
#: menu-commands.docbook:229
#, no-c-format
msgid "Renaming MP3/OGG Vorbis files based on their ID3 tags"
msgstr "MP3/OGG Vorbis सञ्चिकानां नामकरणं तेषां ID3 टैग् इत्यस्य आधारेण"

#. Tag: para
#: menu-commands.docbook:233
#, no-c-format
msgid "Setting access and modification dates"
msgstr "अभिगमनस्य परिवर्तनस्य च तिथयः सेट् करणम्"

#. Tag: para
#: menu-commands.docbook:236
#, no-c-format
msgid "Changing permissions and file ownership"
msgstr "अनुमतिः परिवर्तयन् सञ्चिकास्वामित्वं च"

#. Tag: para
#: menu-commands.docbook:239
#, no-c-format
msgid "A plugin API which allows you to extend KRename's features"
msgstr "एकं प्लगिन् एपिआइ यत् भवन्तं KRename इत्यस्य विशेषतां विस्तारयितुं शक्नोति"

#. Tag: para
#: menu-commands.docbook:243
#, no-c-format
msgid "Renaming folders recursively"
msgstr "पुनरावर्तनीयरूपेण पुटस्य पुनर्नामकरणम्"

#. Tag: para
#: menu-commands.docbook:246
#, no-c-format
msgid "Support for KFilePlugins"
msgstr "KFilePlugins इत्यस्य समर्थनम्"

#. Tag: para
#: menu-commands.docbook:249
#, no-c-format
msgid "Undo renaming"
msgstr "नामकरणं पूर्ववत करें"

#. Tag: para
#: menu-commands.docbook:252
#, no-c-format
msgid "And many more...."
msgstr "अपि च बहवः...."

#. Tag: menuchoice
#: menu-commands.docbook:259
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Create Checksum...</guimenuitem>"
msgstr "<guimenu>सञ्चिका</guimenu> <guimenuitem>चेकसम रचयन्तु...</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:265
#, no-c-format
msgid ""
"<link linkend=\"checksum\">Checksum creation</link> on file(s) and/or "
"folder(s)."
msgstr ""
"<link linkend=\"checksum\">चेकसम निर्माण</link> सञ्चिका(सञ्चिकासु) तथा/वा पुटे "
"(पुटेषु) इत्यत्र ।"

#. Tag: menuchoice
#: menu-commands.docbook:272
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Verify Checksum...</guimenuitem>"
msgstr "<guimenu>सञ्चिका</guimenu> <guimenuitem>चेकसम सत्यापयन्तु...</guimenuitem>"

#. Tag: link
#: menu-commands.docbook:279
#, no-c-format
msgid "Verify Checksum"
msgstr "चेकसम सत्यापित करें"

#. Tag: menuchoice
#: menu-commands.docbook:286
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>P</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Split File...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>P</keycap></keycombo> </"
"shortcut> <guimenu>सञ्चिका</guimenu> <guimenuitem>सञ्चिकां विभक्तं...</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:296
#, no-c-format
msgid ""
"The <link linkend=\"splitter\">Split file</link> function splits a file up "
"into multiple smaller files so that it can be stored on several smaller "
"media (like <hardware>diskettes, zip-drives, ...</hardware>) or sent by e-"
"mail."
msgstr ""
"द<link linkend=\"splitter\"> सञ्चिकां विभज्यताम्</link> function सञ्चिकां बहुषु "
"लघुसञ्चिकासु विभजति येन सा अनेकेषु लघुमाध्यमेषु (यथा<hardware> डिस्केट्, जिप्-ड्राइव्, ...</"
"hardware> ) अथवा ई-मेलद्वारा प्रेषितम्।"

#. Tag: menuchoice
#: menu-commands.docbook:305
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>B</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Combine Files...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>B</keycap></keycombo> </"
"shortcut> <guimenu>सञ्चिका</guimenu> <guimenuitem>सञ्चिकाः संयोजयन्तु...</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:315
#, no-c-format
msgid ""
"The <link linkend=\"splitter\">Combine files</link> function combines "
"multiple files into one file after the <link linkend=\"splitter\">Split "
"file</link> function was used."
msgstr ""
"द<link linkend=\"splitter\"> सञ्चिकाः संयोजयन्तु</link> function इत्यस्य अनन्तरं "
"बहुविधसञ्चिकाः एकस्मिन् सञ्चिकायां संयोजयति<link linkend=\"splitter\"> सञ्चिकां "
"विभज्यताम्</link> function इत्यस्य उपयोगः कृतः आसीत् ।"

#. Tag: menuchoice
#: menu-commands.docbook:323
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>Q</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Quit</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simultaneous\">&Ctrl; <keycap>प्रश्न</keycap></"
"keycombo> </shortcut> <guimenu>सञ्चिका</guimenu> <guimenuitem>निर्गम</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:333
#, no-c-format
msgid ""
"Closes &krusader; and cleans up the temporary folder, the same as pressing "
"<keycap>F10</keycap> key."
msgstr ""
"बन्दं करोति &krusader; तथा अस्थायीपुटं स्वच्छं करोति, यथा <keycap>F10</keycap> कीलं "
"नुदति ।"

#. Tag: title
#: menu-commands.docbook:341
#, no-c-format
msgid "Edit Menu"
msgstr "मेनू सम्पादयतु"

#. Tag: menuchoice
#: menu-commands.docbook:345
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>X</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Cut</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>X</keycap></keycombo> </"
"shortcut> <guimenu>सम्पादयतु</guimenu> <guimenuitem>कटयतु</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:355
#, no-c-format
msgid ""
"<link linkend=\"copying\">Cuts</link> the selected file(s) to the clipboard "
"to be moved to another location."
msgstr ""
"<link linkend=\"copying\">कटयति</link> चयनितसञ्चिका(सञ्चिकाः) अन्यस्थाने "
"स्थानान्तरितुं क्लिप्बोर्डं प्रति ।"

#. Tag: menuchoice
#: menu-commands.docbook:362
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>C</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Copy</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>C</keycap></keycombo> </"
"shortcut> <guimenu>सम्पादनं</guimenu> <guimenuitem>प्रतिलिपि</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:372
#, no-c-format
msgid ""
"<link linkend=\"copying\">Copies</link> the selected file(s) to the "
"clipboard to be moved to another location."
msgstr ""
"<link linkend=\"copying\">प्रतिलिपानि</link> चयनितसञ्चिका(सञ्चिकाः) अन्यस्थाने "
"स्थानान्तरितुं क्लिप्बोर्डं प्रति ।"

#. Tag: menuchoice
#: menu-commands.docbook:379
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>V</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Paste</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>V</keycap></keycombo> </"
"shortcut> <guimenu>सम्पादनं</guimenu> <guimenuitem>चिपकतु</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:389
#, no-c-format
msgid ""
"<link linkend=\"copying\">Pastes</link> previously cut or copied items from "
"the clipboard to the current folder."
msgstr ""
"<link linkend=\"copying\">पेस्ट् करोति</link> पूर्वं क्लिप्बोर्डतः वर्तमानपुटं प्रति "
"कटितानि वा प्रतिलिपितानि वा वस्तूनि ।"

#. Tag: menuchoice
#: menu-commands.docbook:414
#, no-c-format
msgid ""
"<shortcut> <keycap>F8</keycap> </shortcut> <guimenu>Edit</guimenu> "
"<guimenuitem>Delete</guimenuitem>"
msgstr ""
"<shortcut> <keycap>F8</keycap> </shortcut> <guimenu>सम्पादन</guimenu> "
"<guimenuitem>विलोपन</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:423
#, no-c-format
msgid ""
"<link linkend=\"deleting\">Deletes</link> the currently selected file(s)."
msgstr ""
"<link linkend=\"deleting\">विलोपयति</link> वर्तमान चयनितसञ्चिका(सञ्चिकाः) ।"

#. Tag: menuchoice
#: menu-commands.docbook:430
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>+</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Select Group...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>+</keycap></keycombo> </"
"shortcut> <guimenu>सम्पादनं</guimenu> <guimenuitem>समूहं चिनोतु...</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:440
#, no-c-format
msgid ""
"Opens a dialog which allows you to select files in the active panel. In the "
"<guilabel>Search for</guilabel> dialog place the main search criteria. Enter "
"a filename, a wildcard ( <literal role=\"extension\">*.o.*</literal>, "
"<literal role=\"extension\">*.c</literal> &etc;) or both - separated by a "
"space. When using <literal>'text'</literal>, the results are the same as "
"<literal>'*text*'</literal>. You can exclude files from the search with "
"'|' (&eg; <literal role=\"extension\">'*.cpp *.h | *.moc.cpp'</literal>). "
"With the <link linkend=\"profiles\">profile handler</link> you can manage "
"your selections for future usage. A double-click on a profile is the same as "
"entering the selection and pressing the <guibutton>OK</guibutton> button. "
"More options for <guilabel>Select Group</guilabel> dialog are explained in "
"the <link linkend=\"krusearcher\">Search dialog</link>, which are basically "
"almost the same dialogs."
msgstr ""
"एकं संवादं उद्घाटयति यत् सक्रियपटले सञ्चिकाः चयनं कर्तुं शक्नोति । इति<guilabel> अन्वेषणं "
"कुर्वन्तु</guilabel> संवाद मुख्य अन्वेषणमापदण्डं स्थापयति। एकं सञ्चिकानाम, एकं वाइल्डकार्डं "
"(<literal role=\"extension\"> *.ओ.*</literal> , ९.<literal role=\"extension"
"\"> *.ग</literal> &amp;etc;) उभयथा वा - अन्तरिक्षेण विभक्तम्। उपयोगं कुर्वन्<literal> "
"&#39;पाठ&#39;</literal> , परिणामाः समानाः सन्ति<literal> &#39;*पाठ*&#39;</"
"literal> . भवन्तः &#39;|&#39; इत्यनेन अन्वेषणात् सञ्चिकाः बहिष्कृतुं शक्नुवन्ति । "
"(⪚<literal role=\"extension\"> &#39;*.cpp *.ह | *.moc.cpp&#39; इति ।</"
"literal> ). सह<link linkend=\"profiles\"> profile handler इति</link> भविष्ये "
"उपयोगाय स्वचयनं प्रबन्धयितुं शक्नुवन्ति । प्रोफाइल् इत्यत्र द्विवारं क्लिक् करणं चयनं प्रविश्य..."
"<guibutton> अस्तु</guibutton> कड्मल। कृते अधिकविकल्पाः<guilabel> समूहं चिनोतु</"
"guilabel> संवादाः व्याख्याताः सन्ति<link linkend=\"krusearcher\"> अन्वेषणसंवादः</"
"link> , ये मूलतः प्रायः समानाः संवादाः सन्ति ।"

#. Tag: menuchoice
#: menu-commands.docbook:465
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>-</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Unselect Group...</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>-</keycap></keycombo> </"
"shortcut> <guimenu>सम्पादनं</guimenu> <guimenuitem>समूहं अचयनं कुर्वन्तु...</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:475
#, no-c-format
msgid ""
"The opposite of <guimenuitem>Select Group</guimenuitem>. The files that "
"match the pattern in the active panel will be deselected."
msgstr ""
"<guimenuitem>समूहं चिनोतु</guimenuitem> इत्यस्य विपरीतम् । सक्रियपटले प्रतिमानेन सह "
"सङ्गताः सञ्चिकाः अचयनिताः भविष्यन्ति ।"

#. Tag: menuchoice
#: menu-commands.docbook:483
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt; <keycap>+</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Select All</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt; <keycap>+</keycap></keycombo> </"
"shortcut> <guimenu>सम्पादनं</guimenu> <guimenuitem>सर्वं चिनोतु</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:493
#, no-c-format
msgid ""
"Selects all files in the active panel. You can also select all folders by "
"activating the <guilabel>Autoselect folders</guilabel> option in the <link "
"linkend=\"konfig-panel\">Konfigurator Panel page</link>."
msgstr ""
"सक्रियपटले सर्वाणि सञ्चिकाः चिनोति । सक्रियीकरणेन सर्वाणि पुटकानि अपि चिन्वितुं "
"शक्नुवन्ति<guilabel> पुटं स्वयमेव चयनं कुर्वन्तु</guilabel> विकल्पे इति<link linkend="
"\"konfig-panel\"> विन्यासकर्ता फलक पृष्ठ</link> ."

#. Tag: menuchoice
#: menu-commands.docbook:501
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt; <keycap>-</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Unselect All</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt; <keycap>-</keycap></keycombo> </"
"shortcut> <guimenu>सम्पादयन्तु</guimenu> <guimenuitem>सर्वं अचयनं कुर्वन्तु</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:511
#, no-c-format
msgid "Unselects all the files in the active panel."
msgstr "सक्रियपटलस्य सर्वाणि सञ्चिकानि अचयनं करोति ।"

#. Tag: menuchoice
#: menu-commands.docbook:516
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt; <keycap>*</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Invert Selection</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt; <keycap>*</keycap></keycombo> </"
"shortcut> <guimenu>सम्पादनं</guimenu> <guimenuitem>चयनं विपर्यय</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:526
#, no-c-format
msgid ""
"Inverts the selection status of all the files in the active panel (&ie; "
"selected files will become unselected and deselected files will become "
"selected)."
msgstr ""
"सक्रियपटलस्य सर्वेषां सञ्चिकानां चयनस्थितिं विपर्ययति (&अर्थात्; चयनितसञ्चिकाः अचयनिताः "
"भविष्यन्ति, अचयनितसञ्चिकाः च चयनिताः भविष्यन्ति) ।"

#. Tag: menuchoice
#: menu-commands.docbook:534
#, no-c-format
msgid "<guimenu>Edit</guimenu> <guimenuitem>Restore Selection</guimenuitem>"
msgstr "<guimenu>सम्पादनं</guimenu> <guimenuitem>चयनं पुनर्स्थापयतु</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:540
#, no-c-format
msgid "Restore the selection status of previously unselected items."
msgstr "पूर्वं अचयनितवस्तूनाम् चयनस्थितिं पुनः स्थापयन्तु ।"

#. Tag: menuchoice
#: menu-commands.docbook:545
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>F</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Find in folder...</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>F</keycap></keycombo> </"
"shortcut> <guimenu>सम्पादनं</guimenu> <guimenuitem>पुटे अन्वेष्टुम्...</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:555
#, no-c-format
msgid ""
"Toggles &krusader; <link linkend=\"quicksearch\">quick search</link> "
"function."
msgstr ""
"टॉगलं करोति &amp;krusader;<link linkend=\"quicksearch\"> शीघ्रं अन्वेषणम्</link> "
