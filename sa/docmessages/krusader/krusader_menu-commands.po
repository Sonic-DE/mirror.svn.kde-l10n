"shortcut> <guimenu>गच्छ</guimenu> <guimenuitem>मूल</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:725
#, no-c-format
msgid "Navigates to the root folder of the system."
msgstr "प्रणाल्याः मूलपुटं प्रति गच्छति ।"

#. Tag: menuchoice
#: menu-commands.docbook:731
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>Z</keycap></keycombo> </"
