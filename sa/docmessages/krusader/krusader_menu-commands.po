#. Tag: para
#: menu-commands.docbook:676
#, no-c-format
msgid "Navigates to the previously viewed folder in the active panel."
msgstr "सक्रियपटले पूर्वं दृष्टं पुटं प्रति गच्छति ।"

#. Tag: menuchoice
#: menu-commands.docbook:682
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt; &Right;</keycombo> </shortcut> "
"<guimenu>Go</guimenu> <guimenuitem>Forward</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simultaneous\">&Alt; &राइट;</keycombo> </"
"shortcut> <guimenu>गच्छ</guimenu> <guimenuitem>अग्रे</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:692
#, no-c-format
msgid ""
"Navigates to the next viewed folder in the active panel. Becomes available "
"only if <menuchoice><guimenu>Go</guimenu> <guimenuitem>Back</guimenuitem></"
"menuchoice> was used beforehand."
msgstr ""
"सक्रियपटले अग्रिमदृश्यपुटं प्रति गच्छति । केवलं तदा एव उपलब्धं भवति यदा "
"<menuchoice><guimenu>Go</guimenu> <guimenuitem>Back</guimenuitem></"
"menuchoice> इत्यस्य पूर्वं उपयोगः कृतः आसीत् ।"

#. Tag: menuchoice
#: menu-commands.docbook:699
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt; &Home;</keycombo> </shortcut> "
"<guimenu>Go</guimenu> <guimenuitem>Home</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simultaneous\">&Alt; &गृहम्;</keycombo> </"
"shortcut> <guimenu>गच्छ</guimenu> <guimenuitem>गृहं</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:709
#, no-c-format
