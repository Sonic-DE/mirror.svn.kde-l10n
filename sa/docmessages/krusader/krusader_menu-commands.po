msgstr ""
"<shortcut> <keycombo action=\"simul\"> &Ctrl;&Shift; <keycap>J</keycap></"
"keycombo> </shortcut> <guimenu>गच्छ</guimenu> <guimenuitem>जम्प बैक बिन्दु</"
"guimenuitem> सेट् कुर्वन्तु"

#. Tag: para
#: menu-commands.docbook:759
#, no-c-format
msgid ""
"Sets the current folder as a <quote>jump back</quote> point. To navigate to "
"this folder quickly, select the <guimenuitem>Jump Back</guimenuitem> command "
"from the <guimenu>Go</guimenu> menu."
msgstr ""
"वर्तमानपुटं <quote>jump back</quote> बिन्दुरूपेण सेट् करोति । अस्मिन् पुटे शीघ्रं गन्तुं "
"<guimenuitem>Jump Back</guimenuitem> आदेशं <guimenu>Go</guimenu> मेन्यूतः चिनोतु ।"

#. Tag: menuchoice
#: menu-commands.docbook:766
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>J</keycap></keycombo> </"
"shortcut> <guimenu>Go</guimenu> <guimenuitem>Jump Back</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>J</keycap></keycombo> </"
"shortcut> <guimenu>गच्छ</guimenu> <guimenuitem>पृष्ठतः कूदतु</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:776
#, no-c-format
msgid "Returns to a previous <quote>jump back</quote> point."
msgstr "पूर्वस्मिन् <quote>jump back</quote> बिन्दुं प्रति आगच्छति ।"

#. Tag: title
#: menu-commands.docbook:782
#, no-c-format
msgid "View Menu"
msgstr "मेनू देखें"

#. Tag: para
#: menu-commands.docbook:783
#, no-c-format
msgid ""
"The action in this submenu usually affects the current &krusader; session. "
"If you want to make permanent changes use <link linkend=\"konfigurator"
"\">Konfigurator Startup page</link>."
msgstr ""
"अस्मिन् उपमेनूमध्ये क्रिया प्रायः वर्तमानं &amp;krusader; सत्र। यदि भवान् स्थायी परिवर्तनं "
"कर्तुम् इच्छति तर्हि उपयोगं करोतु<link linkend=\"konfigurator\"> Konfigurator "
"प्रारम्भ पृष्ठ</link> ."

#. Tag: menuchoice
#: menu-commands.docbook:789
#, no-c-format
msgid "<guimenu>View</guimenu> <guimenuitem>Zoom In</guimenuitem>"
msgstr "<guimenu>दृश्य</guimenu> <guimenuitem>जूम इन</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:795
#, no-c-format
msgid "Increase the view scale."
msgstr "दृश्यमानं वर्धयन्तु।"

#. Tag: menuchoice
#: menu-commands.docbook:800
#, no-c-format
msgid "<guimenu>View</guimenu> <guimenuitem>Zoom Out</guimenuitem>"
msgstr "<guimenu>दृश्य</guimenu> <guimenuitem>जूम आउट्</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:806
#, no-c-format
msgid "Decrease the view scale."
msgstr "दृश्यमापं न्यूनीकरोतु।"

#. Tag: menuchoice
#: menu-commands.docbook:811
#, no-c-format
msgid "<guimenu>View</guimenu> <guimenuitem>Default Zoom</guimenuitem>"
msgstr "<guimenu>दृश्य</guimenu> <guimenuitem>पूर्वनिर्धारितं जूम</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:817
#, no-c-format
msgid "Reset the view scale."
msgstr "दृश्यमापं पुनः सेट् कुर्वन्तु ।"

#. Tag: menuchoice
#: menu-commands.docbook:822
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> &Alt;&Shift; <keycap>D</keycap></"
"keycombo> </shortcut> <guimenu>View</guimenu> <guimenuitem>Detailed View</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> &अल्ट;&Shift; <keycap>D</keycap></"
"keycombo> </shortcut> <guimenu>दृश्य</guimenu> <guimenuitem>विस्तृतदृश्य</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:833
#, no-c-format
msgid ""
"Shows the file names, file size, creation date and time and their attributes."
msgstr ""
"सञ्चिकानामानि, सञ्चिकायाः आकारः, निर्माणतिथिः समयः च तेषां विशेषताः च दर्शयति ।"

#. Tag: menuchoice
#: menu-commands.docbook:838
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> &Alt;&Shift; <keycap>B</keycap></"
"keycombo> </shortcut> <guimenu>View</guimenu> <guimenuitem>Brief View</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> &अल्ट;&Shift; <keycap>B</keycap></"
"keycombo> </shortcut> <guimenu>दृश्य</guimenu> <guimenuitem>संक्षिप्तदृश्य</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:849
#, no-c-format
msgid "Shows only the file names."
msgstr "केवलं सञ्चिकानामानि दर्शयति ।"

#. Tag: menuchoice
#: menu-commands.docbook:854
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt; <keycap>.</keycap></keycombo> </"
"shortcut> <guimenu>View</guimenu> <guimenuitem>Show Hidden Files</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt; <keycap>.</keycap></keycombo> </"
"shortcut> <guimenu>दृश्य</guimenu> <guimenuitem>गुप्तसञ्चिकाः दर्शयतु</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:864
#, no-c-format
msgid ""
"Toggles the option to display the hidden files in the &krusader; panels."
msgstr "&krusader; फलकम् ।"

#. Tag: menuchoice
#: menu-commands.docbook:870
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Shift; <keycap>F10</keycap></"
"keycombo> </shortcut> <guimenu>View</guimenu> <guimenuitem>All Files</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Shift; <keycap>F10</keycap></"
"keycombo> </shortcut> <guimenu>दृश्य</guimenu> <guimenuitem>सर्वसञ्चिकाः</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:880
#, no-c-format
msgid "Turns off all filters and display all files."
msgstr "सर्वाणि फ़िल्टर्स् निष्क्रियं करोति तथा च सर्वाणि सञ्चिकाः प्रदर्शयति ।"

#. Tag: menuchoice
#: menu-commands.docbook:885
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Shift; <keycap>F12</keycap></"
"keycombo> </shortcut> <guimenu>View</guimenu> <guimenuitem>Custom</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Shift; <keycap>F12</keycap></"
"keycombo> </shortcut> <guimenu>दृश्य</guimenu> <guimenuitem>अनुकूल</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:895
#, no-c-format
msgid ""
"Allows you to install a custom filter on the &krusader; panel. Only files "
"that match the filter pattern(s) and folders will be displayed. Do not "
"forget to deactivate the custom filter after use, or some files may not be "
"visible."
msgstr ""
"&krusader; फलकम् । केवलं ताः सञ्चिकाः प्रदर्शिताः भविष्यन्ति ये फ़िल्टर-प्रतिमान(s) तथा "
"पुटयोः मेलनं कुर्वन्ति । उपयोगानन्तरं कस्टम्-छिद्रकं निष्क्रियं कर्तुं न विस्मरन्तु, अथवा काश्चन "
"सञ्चिकाः न दृश्यन्ते ।"

#. Tag: menuchoice
#: menu-commands.docbook:904
#, no-c-format
msgid "<guimenu>View</guimenu> <guimenuitem>Show Previews</guimenuitem>"
msgstr "<guimenu>दृश्य</guimenu> <guimenuitem>पूर्वावलोकनानि दर्शयतु</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:910
#, no-c-format
msgid ""
"If checked, show the previews for all files and folders on the active panel."
msgstr "यदि चेक् कृतं तर्हि सक्रियपटलस्य सर्वेषां सञ्चिकानां, पुटस्य च पूर्वावलोकनं दर्शयतु ।"

#. Tag: menuchoice
#: menu-commands.docbook:915
#, no-c-format
msgid ""
"<guimenu>View</guimenu> <guimenuitem>Select Remote Charset</guimenuitem>"
msgstr "<guimenu>दृश्यं</guimenu> <guimenuitem>दूरस्थं वर्णसमूहं</guimenuitem> चिनोतु"

#. Tag: para
#: menu-commands.docbook:921
#, no-c-format
msgid ""
"Selects the remote charset for <link linkend=\"remote-connections\">Remote "
"Connections</link>."
msgstr ""
"कृते दूरस्थं चरसेट् चिनोति<link linkend=\"remote-connections\"> दूरस्थसंयोजनानि</"
"link> ."

#. Tag: menuchoice
#: menu-commands.docbook:927
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>R</keycap></keycombo> </"
"shortcut> <guimenu>View</guimenu> <guimenuitem>Reload</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>R</keycap></keycombo> </"
"shortcut> <guimenu>दृश्य</guimenu> <guimenuitem>पुनः लोड्</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:937
#, no-c-format
msgid "Refreshes the contents of the active panel."
msgstr "सक्रियपटलस्य सामग्रीं ताजगीं करोति ।"

#. Tag: menuchoice
#: menu-commands.docbook:942
#, no-c-format
msgid ""
"<guimenu>View</guimenu> <guimenuitem>Save settings as default</guimenuitem>"
msgstr ""
"<guimenu>द्रष्टव्यम्</guimenu> <guimenuitem>सेटिंग्स् पूर्वनिर्धारितरूपेण रक्षन्तु</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:948
#, no-c-format
msgid ""
"Allows you to save the view settings of the current tab for new instances of "
"this view type."
msgstr ""
"अस्य दृश्यप्रकारस्य नूतनानां उदाहरणानां कृते वर्तमानट्याब् इत्यस्य दृश्यसेटिंग्स् रक्षितुं शक्नोति ।"

#. Tag: menuchoice
#: menu-commands.docbook:953
#, no-c-format
msgid ""
"<guimenu>View</guimenu> <guimenuitem>Apply settings to other tabs</"
"guimenuitem>"
msgstr ""
"<guimenu>द्रष्टव्यम्</guimenu> <guimenuitem>अन्यट्याब्षु सेटिङ्ग्स् प्रयोजयन्तु</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:959
#, no-c-format
msgid ""
"Allows you to apply the view settings of the current tab to the other tabs."
msgstr "वर्तमान ट्याब् इत्यस्य दृश्यसेटिंग्स् अन्येषु ट्याब्षु प्रयोक्तुं शक्नोति ।"

#. Tag: title
#: menu-commands.docbook:965
#, no-c-format
msgid "Useractions Menu"
msgstr "उपयोक्तृक्रियाः मेनू"

#. Tag: para
#: menu-commands.docbook:966
#, no-c-format
msgid ""
"You can add your own menu entries here by defining your own <link linkend="
"\"useractions\">UserActions</link>."
msgstr ""
"स्वकीयं परिभाष्य अत्र स्वकीयानि मेनू-प्रविष्टयः योजयितुं शक्नुवन्ति<link linkend="
"\"useractions\"> UserActions इति</link> ."

#. Tag: menuchoice
#: menu-commands.docbook:971
#, no-c-format
msgid ""
"<guimenu>Useractions</guimenu> <guimenuitem>Manage User Actions...</"
"guimenuitem>"
msgstr ""
"<guimenu>उपयोक्तृक्रियाः</guimenu> <guimenuitem>उपयोक्तृक्रियाः प्रबन्धयन्तु...</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:977
#, no-c-format
msgid "Opens the <link linkend=\"useractions\">UserActions</link> manager."
msgstr "उद्घाटयति<link linkend=\"useractions\"> उपयोक्तृक्रियाः</link> प्रबंधकः।"

#. Tag: menuchoice
#: menu-commands.docbook:983
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> &Meta; <keycap>A</keycap> </keycombo> "
"</shortcut> <guimenu>Useractions</guimenu><guisubmenu>Multimedia</"
"guisubmenu> <guimenuitem>Enqueue in Amarok</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> &मेटा; <keycap>A</keycap> </keycombo> "
"</shortcut> <guimenu>उपयोक्तृक्रियाः</guimenu><guisubmenu>बहुमाध्यम</guisubmenu> "
"<guimenuitem>अमारोक्</guimenuitem> मध्ये पङ्क्तिं कुर्वन्तु"

#. Tag: para
#: menu-commands.docbook:995
#, no-c-format
msgid "Appends selected item(s) to &amarok; playlist."
msgstr "चयनितं वस्तु (वस्तूनि) &amarok; playlist इति ।"

#. Tag: menuchoice
#: menu-commands.docbook:1000
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> &Ctrl;&Alt; </keycombo> </shortcut> "
"<guimenu>Useractions</guimenu><guisubmenu>Samples</guisubmenu> "
"<guimenuitem>Equal panel-size</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> &Ctrl;&Alt; </keycombo> </shortcut> "
"<guimenu>उपयोक्तृक्रियाः</guimenu><guisubmenu>नमूनानि</guisubmenu> "
"<guimenuitem>समानपटल-आकारः</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1011
#, no-c-format
msgid "Sets the ratio between the two panels to 50/50."
msgstr "द्वयोः पटलयोः मध्ये अनुपातं 50/50 इति सेट् करोति ।"

#. Tag: menuchoice
#: menu-commands.docbook:1017
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> &Ctrl;<keycap>E</keycap> </keycombo> "
"</shortcut> <guimenu>Useractions</guimenu><guisubmenu>Samples</guisubmenu> "
"<guimenuitem>Edit as root</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> &Ctrl;<keycap>E</keycap> </keycombo> "
"</shortcut> <guimenu>उपयोक्तृक्रियाः</guimenu><guisubmenu>नमूना</guisubmenu> "
"<guimenuitem>यथा सम्पादयतु मूल</guimenuitem> इति"

#. Tag: para
#: menu-commands.docbook:1028
#, no-c-format
msgid ""
"Allows you to edit a file with <application>kwrite</application> using root "
"permissions."
msgstr ""
"मूल-अनुमतीनां उपयोगेन <application>kwrite</application> इत्यनेन सह सञ्चिकां सम्पादयितुं "
"शक्नोति ।"

#. Tag: menuchoice
#: menu-commands.docbook:1034
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> &Ctrl;&Alt;<keycap>M</keycap> </"
"keycombo> </shortcut> <guimenu>Useractions</guimenu><guisubmenu>Samples</"
"guisubmenu> <guimenuitem>Mount</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> &Ctrl;&Alt;<keycap>M</keycap> </"
"keycombo> </shortcut> <guimenu>उपयोक्तृक्रियाः</guimenu><guisubmenu>नमूना</"
"guisubmenu> <guimenuitem> माउण्ट्</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1045
#, no-c-format
msgid "Mounts a new filesystem."
msgstr "नूतनं सञ्चिकातन्त्रं माउण्ट् करोति ।"

#. Tag: menuchoice
#: menu-commands.docbook:1050
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> &Ctrl;&Alt;<keycap>C</keycap> </"
"keycombo> </shortcut> <guimenu>Useractions</guimenu><guisubmenu>Samples</"
"guisubmenu> <guimenuitem>Copy current item to clipboard</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> &Ctrl;&Alt;<keycap>C</keycap> </"
"keycombo> </shortcut> <guimenu>उपयोक्तृक्रियाः</guimenu><guisubmenu>नमूना</"
"guisubmenu> <guimenuitem> वर्तमानं द्रव्यं क्लिप्बोर्ड</guimenuitem> मध्ये प्रतिलिख्यताम्"

#. Tag: para
#: menu-commands.docbook:1062
#, no-c-format
msgid "Copies current item name to the clipboard."
msgstr "वर्तमानवस्तुनाम क्लिप्बोर्ड् प्रति प्रतिलिखति ।"

#. Tag: menuchoice
#: menu-commands.docbook:1067
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> &Meta;<keycap>F5</keycap> </keycombo> "
"</shortcut> <guimenu>Useractions</guimenu><guisubmenu>System</guisubmenu> "
"<guimenuitem>Backup current</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> &Meta;<keycap>F5</keycap> </keycombo> "
"</shortcut> <guimenu>उपयोक्तृक्रियाः</guimenu><guisubmenu>प्रणाली</guisubmenu> "
"<guimenuitem>बैकअप वर्तमान </guimenuitem> इति"

#. Tag: para
#: menu-commands.docbook:1078
#, no-c-format
msgid ""
"Backups current file in current folder and asks the user for a new filename. "
"By default <literal role=\"extension\">.old</literal> is appended to the "
"original filename."
msgstr ""
"वर्तमानपुटस्य वर्तमानपुटस्य बैकअपं करोति तथा च उपयोक्त्रेण नूतनं सञ्चिकानाम पृच्छति । "
"पूर्वनिर्धारितरूपेण <literal role=\"extension\">.old</literal> इति मूलसञ्चिकानाम्ना "
"संलग्नम् अस्ति ।"

#. Tag: menuchoice
#: menu-commands.docbook:1084
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> &Meta; <keycap>1</keycap> </keycombo> "
"</shortcut> <guimenu>Useractions</guimenu><guisubmenu>User Interface</"
"guisubmenu> <guimenuitem>Sort By Name</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> &मेटा; <keycap>1</keycap> </keycombo> "
"</shortcut> <guimenu>उपयोक्तृक्रियाः</guimenu><guisubmenu>उपयोक्तृ-अन्तरफलक</"
"guisubmenu> <guimenuitem>नाम्ना क्रमेण क्रमयन्तु</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1096
#, no-c-format
msgid ""
"When this action is turned on, the main sorting key in the &krusader; panel "
"becomes the file name."
msgstr "यदा एषा क्रिया चालू भवति तदा &krusader; panel इति सञ्चिकानाम भवति ।"

#. Tag: menuchoice
#: menu-commands.docbook:1103
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> &Meta; <keycap>2</keycap> </keycombo> "
"</shortcut> <guimenu>Useractions</guimenu><guisubmenu>User Interface</"
"guisubmenu> <guimenuitem>Sort By Extension</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> &मेटा; <keycap>2</keycap> </keycombo> "
"</shortcut> <guimenu>उपयोक्तृक्रियाः</guimenu><guisubmenu>उपयोक्तृ-अन्तरफलक</"
"guisubmenu> <guimenuitem>विस्तारद्वारा क्रमबद्धाः</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1115
#, no-c-format
msgid ""
"When this action is turned on, the main sorting key in the &krusader; panel "
"becomes the file extension (the part of the filename after the last '.'). "
"This is useful for grouping files of the same type closer together."
msgstr ""
"यदा एषा क्रिया चालू भवति तदा &krusader; panel सञ्चिकाविस्तारः (अन्तिमस्य '.' इत्यस्य "
"अनन्तरं सञ्चिकानामस्य भागः) भवति । समानप्रकारस्य सञ्चिकानां समीपस्थं समूहीकरणाय एतत् "
"उपयोगी भवति ।"

#. Tag: menuchoice
#: menu-commands.docbook:1124
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> &Meta; <keycap>3</keycap> </keycombo> "
"</shortcut> <guimenu>Useractions</guimenu><guisubmenu>User Interface</"
"guisubmenu> <guimenuitem>Sort By Size</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> &मेटा; <keycap>3</keycap> </keycombo> "
"</shortcut> <guimenu>उपयोक्तृक्रियाः</guimenu><guisubmenu>उपयोक्तृ-अन्तरफलक</"
"guisubmenu> <guimenuitem>आकारेन क्रमणं कुर्वन्तु</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1136
#, no-c-format
msgid ""
"When this action is turned on, the main sorting key in the &krusader; panel "
"becomes the file size. This is useful for determining the largest files in a "
"particular folder."
msgstr ""
"यदा एषा क्रिया चालू भवति तदा &krusader; panel सञ्चिकायाः आकारः भवति । एतत् "
"कस्मिन्चित् पुटे बृहत्तमानां सञ्चिकानां निर्धारणाय उपयोगी भवति ।"

#. Tag: menuchoice
#: menu-commands.docbook:1144
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> &Meta; <keycap>4</keycap> </keycombo> "
"</shortcut> <guimenu>Useractions</guimenu><guisubmenu>User Interface</"
"guisubmenu> <guimenuitem>Sort By Modified</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> &मेटा; <keycap>4</keycap> </keycombo> "
"</shortcut> <guimenu>उपयोक्तृक्रियाः</guimenu><guisubmenu>उपयोक्तृ-अन्तरफलक</"
"guisubmenu> <guimenuitem>संशोधितेन क्रमाङ्कयन्तु</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1156
#, no-c-format
msgid ""
"When this action is turned on, the main sorting key in the &krusader; panel "
"becomes the last modified date for each file. This is useful for finding "
"files you recently worked on."
msgstr ""
"यदा एषा क्रिया चालू भवति तदा &krusader; panel प्रत्येकस्य सञ्चिकायाः "
"अन्तिमपरिवर्तिततिथिः भवति । भवता अद्यतनकाले कार्यं कृतानि सञ्चिकानि अन्वेष्टुं एतत् उपयोगी "
"भवति ।"

#. Tag: title
#: menu-commands.docbook:1165
#, no-c-format
msgid "Tools Menu"
msgstr "उपकरण मेनू"

#. Tag: menuchoice
#: menu-commands.docbook:1169
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>S</keycap></keycombo> </"
"shortcut> <guimenu>Tools</guimenu> <guimenuitem>Search...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>S</keycap></keycombo> </"
"shortcut> <guimenu>उपकरणं</guimenu> <guimenuitem>अन्वेषणं...</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1179
#, no-c-format
msgid ""
"Opens <link linkend=\"krusearcher\">KruSearcher</link> - the &krusader; "
"search module."
msgstr ""
"उद्घाट्यते<link linkend=\"krusearcher\"> क्रूसर्चर</link> - the &amp;krusader; "
"अन्वेषण मॉड्यूल।"

#. Tag: menuchoice
#: menu-commands.docbook:1186
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> &Ctrl;&Shift; <keycap>L</keycap></"
"keycombo> </shortcut> <guimenu>Tools</guimenu> <guimenuitem>Locate...</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> &Ctrl;&Shift; <keycap>L</keycap></"
"keycombo> </shortcut> <guimenu>उपकरणं</guimenu> <guimenuitem>स्थानम्...</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1197
#, no-c-format
msgid ""
"Opens the <link linkend=\"locate\">Locate</link> &GUI; frontend for fast "
"file searching."
msgstr ""
"उद्घाटयति<link linkend=\"locate\"> स्थानं ज्ञातव्यम्</link> &amp;GUI; "
"द्रुतसञ्चिकासन्धानार्थं frontend इति ।"

#. Tag: menuchoice
#: menu-commands.docbook:1203
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>Y</keycap></keycombo> </"
"shortcut> <guimenu>Tools</guimenu> <guimenuitem>Synchronize Folders</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>Y</keycap></keycombo> </"
"shortcut> <guimenu>उपकरणं</guimenu> <guimenuitem>पुटं समन्वययन्तु</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1213
#, no-c-format
msgid ""
"The <link linkend=\"synchronizer\">Synchronize Folders</link> function "
"compares the left and right panels and shows the differences between them. "
"After the compare function, you can move files/folders so that they can be "
"synchronized."
msgstr ""
"द<link linkend=\"synchronizer\"> Folders समन्वयनम्</link> function वाम-दक्षिण-"
"पटलयोः तुलनां कृत्वा तयोः भेदं दर्शयति । compare function इत्यस्य अनन्तरं भवान् सञ्चिकाः/"
"पुटं स्थानान्तरयितुं शक्नोति येन तेषां समन्वयः कर्तुं शक्यते ।"

#. Tag: menuchoice
#: menu-commands.docbook:1222
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt; <keycap>/</keycap></keycombo> </"
"shortcut> <guimenu>Tools</guimenu> <guimenuitem>MountMan...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt; <keycap>/</keycap></keycombo> </"
"shortcut> <guimenu>उपकरणं</guimenu> <guimenuitem>पर्वतपुरुषः...</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1232
#, no-c-format
msgid ""
"Opens submenu with items to open <link linkend=\"mount-man\">MountMan</link> "
"or mount/unmount various mounting points."
msgstr ""
"उद्घाटयितुं द्रव्यैः सह उपमेनू उद्घाटयति<link linkend=\"mount-man\"> माउण्टमैन</link> "
"अथवा विविधान् माउण्टिङ्ग् बिन्दून् माउण्ट्/अनमाउण्ट् कुर्वन्तु।"

#. Tag: menuchoice
#: menu-commands.docbook:1239
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift; <keycap>S</keycap></"
"keycombo> </shortcut> <guimenu>Tools</guimenu> <guimenuitem>Disk Usage...</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&अल्ट;&Shift; <keycap>S</keycap></"
"keycombo> </shortcut> <guimenu>उपकरणं</guimenu> <guimenuitem>डिस्कस्य उपयोगः..."
"</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1249
#, no-c-format
msgid "Opens <link linkend=\"diskusage\">Disk Usage</link>."
msgstr "उद्घाट्यते<link linkend=\"diskusage\"> डिस्कस्य उपयोगः</link> ."

#. Tag: menuchoice
#: menu-commands.docbook:1254
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>N</keycap></keycombo> </"
"shortcut> <guimenu>Tools</guimenu> <guimenuitem>New Net Connection</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>N</keycap></keycombo> </"
"shortcut> <guimenu>उपकरणाः</guimenu> <guimenuitem>नवीनजालसम्बद्धता</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1264
#, no-c-format
msgid ""
"Opens the <link linkend=\"remote-connections\">New Network Connection</link> "
"dialog to start a &FTP;, SMB, FISH or SFTP connection to a remote host. If "
"you leave the user name and password fields empty, you will login as "
"anonymous. You can <link linkend=\"bookman\">Bookmark</link> these remote "
"sessions."
msgstr ""
"उद्घाटयति<link linkend=\"remote-connections\"> नवीनं संजालसंयोजनम्</link> "
"दूरस्थहोस्ट् प्रति &amp;FTP;, SMB, FISH अथवा SFTP संयोजनं आरभ्य संवादः । यदि भवान् "
"उपयोक्तृनाम गुप्तशब्दक्षेत्रं च रिक्तं त्यजति तर्हि भवान् अनामरूपेण प्रवेशं करिष्यति । भवान्‌ "
"शक्नोति<link linkend=\"bookman\"> बुकमार्क</link> एते दूरस्थसत्राः।"

#. Tag: menuchoice
#: menu-commands.docbook:1276
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> &Ctrl;&Shift; <keycap>D</keycap></"
"keycombo> </shortcut> <guimenu>Tools</guimenu> <guimenuitem>Disconnect From "
"Net</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> &Ctrl;&Shift; <keycap>D</keycap></"
"keycombo> </shortcut> <guimenu>उपकरणाः</guimenu> <guimenuitem>जालतः विच्छेदं</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1287
#, no-c-format
msgid ""
"Ends the <link linkend=\"remote-connections\">remote connection</link> in "
"the active panel and returns to the start-up path."
msgstr ""
"समाप्तं भवति<link linkend=\"remote-connections\"> दूरस्थसंयोजनम्</link> सक्रियपटले "
"स्थापयित्वा आरम्भमार्गं प्रति आगच्छति ।"

#. Tag: menuchoice
#: menu-commands.docbook:1296
#, no-c-format
msgid "<guimenu>Tools</guimenu> <guimenuitem>Start Terminal</guimenuitem>"
msgstr "<guimenu>उपकरणं</guimenu> <guimenuitem>टर्मिनल् आरभत</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1302
#, no-c-format
msgid ""
"Opens a terminal window in the default folder (usually your home folder). "
"You can choose your favorite terminal application in the <link linkend="
"\"konfig-general\">Konfigurator General page</link>."
msgstr ""
"पूर्वनिर्धारितपुटे (प्रायः भवतः गृहपुटे) टर्मिनल् विण्डो उद्घाटयति । भवन्तः स्वस्य प्रियं "
"टर्मिनल् अनुप्रयोगं चिन्वितुं शक्नुवन्ति<link linkend=\"konfig-general\"> विन्यासकर्ता "
"सामान्य पृष्ठ</link> ."

#. Tag: menuchoice
#: menu-commands.docbook:1310
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift; <keycap>K</keycap></"
"keycombo> </shortcut> <guimenu>Tools</guimenu> <guimenuitem>Start Root Mode "
"Krusader</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&अल्ट;&Shift; <keycap>K</keycap></"
"keycombo> </shortcut> <guimenu>उपकरणं</guimenu> <guimenuitem>मूलविधानं क्रूसेडरं "
"आरभत</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1320
#, no-c-format
msgid ""
"Starts &krusader; in <link linkend=\"root-mode\">Root mode</link> at the "
"same location. Root mode &krusader; requires <command>kdesu</command> by "
"default, if <command>kdesu</command> is not available or if you prefer &eg; "
"<command>gksu</command> when using <ulink url=\"https://www.gnome.org"
"\"><application>GNOME</application></ulink> you can change this behaviour in "
"the <link linkend=\"konfig-dependencies\">Konfigurator Dependencies page</"
"link>."
msgstr ""
"आरभते &amp;krusader; इत्यस्मिन्‌<link linkend=\"root-mode\"> मूलविधिः</link> तस्मिन् "
"एव स्थाने । मूलविधा &amp;krusader; अपेक्षते<command> क्देसु</command> पूर्वनिर्धारितरूपेण, "
"यदि<command> क्देसु</command> न उपलब्धं वा यदि भवान् इच्छति ⪚<command> gksu</"
"command> उपयोगं कुर्वन्<ulink url=\"https://www.gnome.org\"><application> GNOME "
"इति</application></ulink> भवन्तः एतत् व्यवहारं परिवर्तयितुं शक्नुवन्ति<link linkend="
"\"konfig-dependencies\"> विन्यासकर्ता निर्भरता पृष्ठ</link> ."

#. Tag: para
#: menu-commands.docbook:1326
#, no-c-format
msgid "Be careful when using &krusader; with ROOT PRIVILEGES."
msgstr "&krusader; ROOT PRIVILEGES इत्यनेन सह।"

#. Tag: menuchoice
#: menu-commands.docbook:1334
#, no-c-format
msgid "<guimenu>Tools</guimenu> <guimenuitem>Empty Trash</guimenuitem>"
msgstr "<guimenu>उपकरणं</guimenu> <guimenuitem>रिक्तं कचरा</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1340
#, no-c-format
msgid "Empties the <link linkend=\"deleting\">trash bin</link>."
msgstr "रिक्तं करोति<link linkend=\"deleting\"> कचराकोषः</link> ."

#. Tag: title
#: menu-commands.docbook:1346
#, no-c-format
msgid "Window Menu"
msgstr "विण्डो मेनू"

#. Tag: menuchoice
#: menu-commands.docbook:1350
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> &Ctrl;&Shift; <keycap>N</keycap></"
"keycombo> </shortcut> <guimenu>Window</guimenu> <guimenuitem>New Tab</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> &Ctrl;&Shift; <keycap>N</keycap></"
"keycombo> </shortcut> <guimenu>विण्डो</guimenu> <guimenuitem>नवीनट्याब्</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1361
#, no-c-format
msgid "Opens a new tab in the active panel."
msgstr "सक्रियपटले नूतनं ट्याब् उद्घाटयति ।"

#. Tag: menuchoice
#: menu-commands.docbook:1366
#, no-c-format
msgid ""
"<guimenu>Window</guimenu> <guimenuitem>Lock Tab/Unlock Tab</guimenuitem>"
msgstr ""
"<guimenu>विण्डो</guimenu> <guimenuitem>लॉक् ट्याब्/अनलॉक ट्याब्</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1372
#, no-c-format
msgid "Locks then unlocks current tab in the active panel."
msgstr "ततः सक्रियपटले वर्तमानट्याब् अनलॉक् करोति ।"

#. Tag: menuchoice
#: menu-commands.docbook:1377
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> &Ctrl;&Alt;&Shift; <keycap>N</"
"keycap></keycombo> </shortcut> <guimenu>Window</guimenu> "
"<guimenuitem>Duplicate Current Tab</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> &Ctrl;&Alt;&Shift; <keycap>N</"
"keycap></keycombo> </shortcut> <guimenu>विण्डो</guimenu> "
"<guimenuitem>वर्तमानट्याब् द्वितीयकं</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1388
#, no-c-format
msgid ""
"Opens a new tab that is a duplicate of the active tab in the active panel."
msgstr "नूतनं ट्याब् उद्घाटयति यत् सक्रियपटले सक्रियट्याब् इत्यस्य द्वितीयकं भवति ।"

#. Tag: menuchoice
#: menu-commands.docbook:1394
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> &Ctrl;&Shift; <keycap>O</keycap></"
"keycombo> </shortcut> <guimenu>Window</guimenu> <guimenuitem>Move Current "
"Tab to Other Side</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> &Ctrl;&Shift; <keycap>O</keycap></"
"keycombo> </shortcut> <guimenu>विण्डो</guimenu> <guimenuitem>वर्तमानं ट्याब् "
"अन्यपक्षं प्रति स्थानान्तरयन्तु</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1405
#, no-c-format
msgid "Moves current tab to the other side of &krusader; window."
msgstr "वर्तमान ट्याब् &krusader; कोष्ठ।"

#. Tag: menuchoice
#: menu-commands.docbook:1410
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>W</keycap></keycombo> </"
"shortcut> <guimenu>Window</guimenu> <guimenuitem>Close Current Tab</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>W</keycap></keycombo> </"
"shortcut> <guimenu>विण्डो</guimenu> <guimenuitem>वर्तमानट्याब् बन्दं कुर्वन्तु</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1420
#, no-c-format
msgid ""
"Closes the current tab in the active panel. This command is only available "
"if there is more than one tab in the active panel."
msgstr ""
"सक्रियपटले वर्तमानट्याब् पिधायति । सक्रियपटले एकादशाधिकं ट्याब् अस्ति चेत् एव एषः आदेशः "
"उपलब्धः भवति ।"

#. Tag: menuchoice
#: menu-commands.docbook:1427
#, no-c-format
msgid ""
"<guimenu>Window</guimenu> <guimenuitem>Close Inactive Tabs</guimenuitem>"
msgstr ""
"<guimenu>विण्डो</guimenu> <guimenuitem>निष्क्रिय ट्याब्स्</guimenuitem> बन्दं कुर्वन्तु"

#. Tag: para
#: menu-commands.docbook:1433
#, no-c-format
msgid "Closes all the tabs in the active panel except for the active."
msgstr "सक्रियं विहाय सक्रियपटलस्य सर्वाणि ट्याब्स् पिधायति ।"

#. Tag: menuchoice
#: menu-commands.docbook:1438
#, no-c-format
msgid ""
"<guimenu>Window</guimenu> <guimenuitem>Close Duplicated Tabs</guimenuitem>"
msgstr ""
"<guimenu>विण्डो</guimenu> <guimenuitem>द्वितीयकट्याब्स्</guimenuitem> बन्दं कुर्वन्तु"

#. Tag: para
#: menu-commands.docbook:1444
#, no-c-format
msgid "Closes the duplicated tabs in the active panel."
msgstr "सक्रियपटले द्वितीयकट्याब्स् पिधायति ।"

#. Tag: menuchoice
#: menu-commands.docbook:1449
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>.</keycap></keycombo> </"
"shortcut> <guimenu>Window</guimenu> <guimenuitem>Next Tab</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>.</keycap></keycombo> </"
"shortcut> <guimenu>विण्डो</guimenu> <guimenuitem>अनन्तरं ट्याब्</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1459
#, no-c-format
msgid ""
"Navigates to the next tab in the active panel. This command is only "
"available if there is more than one tab in the active panel."
msgstr ""
"सक्रियपटले अग्रिमपटलं प्रति गच्छति । सक्रियपटले एकादशाधिकं ट्याब् अस्ति चेत् एव एषः आदेशः "
"उपलब्धः भवति ।"

#. Tag: menuchoice
#: menu-commands.docbook:1466
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>,</keycap></keycombo> </"
"shortcut> <guimenu>Window</guimenu> <guimenuitem>Previous Tab</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>,</keycap></keycombo> </"
"shortcut> <guimenu>विण्डो</guimenu> <guimenuitem>पूर्वं ट्याब्</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1476
#, no-c-format
msgid ""
"Navigates to the previous tab in the active panel. This command is only "
"available if there is more than one tab in the active panel."
msgstr ""
"सक्रियपटले पूर्ववर्ती ट्याब् प्रति गच्छति । सक्रियपटले एकादशाधिकं ट्याब् अस्ति चेत् एव एषः "
"आदेशः उपलब्धः भवति ।"

#. Tag: menuchoice
#: menu-commands.docbook:1483
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift; <keycap>L</keycap></"
"keycombo> </shortcut> <guimenu>Window</guimenu> <guimenuitem>Profiles</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&अल्ट;&Shift; <keycap>L</keycap></"
"keycombo> </shortcut> <guimenu>विण्डो</guimenu> <guimenuitem>प्रोफाइल</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1493
#, no-c-format
msgid ""
"Opens a menu where <link linkend=\"panel_profiles\">Panel profiles</link> "
"can be saved and restored."
msgstr ""
"एकं मेनू उद्घाटयति यत्र<link linkend=\"panel_profiles\"> पैनल प्रोफाइल</link> रक्षितुं "
"पुनः स्थापयितुं च शक्यते।"

#. Tag: menuchoice
#: menu-commands.docbook:1500
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>U</keycap></keycombo> </"
"shortcut> <guimenu>Window</guimenu> <guimenuitem>Swap Panels</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>U</keycap></keycombo> </"
"shortcut> <guimenu>विण्डो</guimenu> <guimenuitem>पैनल-अदला-बदली</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1510
#, no-c-format
msgid ""
"The left panel will become the right panel and vice versa, only the current "
"tabs will be swapped."
msgstr ""
"वामपटलं दक्षिणपटलं भविष्यति तथा च तद्विपरीतम्, केवलं वर्तमानट्याब्स् स्वैप् भविष्यन्ति ।"

#. Tag: menuchoice
#: menu-commands.docbook:1516
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> &Ctrl;&Shift; <keycap>U</keycap></"
"keycombo> </shortcut> <guimenu>Window</guimenu> <guimenuitem>Swap Sides</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> &Ctrl;&Shift; <keycap>U</keycap></"
"keycombo> </shortcut> <guimenu>विण्डो</guimenu> <guimenuitem>पक्ष अदला-बदली</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1527
#, no-c-format
msgid ""
"The complete left panel will become the right panel and vice versa, and all "
"tabs will be swapped."
msgstr ""
"सम्पूर्णं वामपटलं दक्षिणपटलं भविष्यति तथा च तद्विपरीतम्, सर्वाणि ट्याब्स् स्वैप्स् भविष्यन्ति ।"

#. Tag: menuchoice
#: menu-commands.docbook:1533
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> &Ctrl;&Alt; <keycap>R</keycap></"
"keycombo> </shortcut> <guimenu>Window</guimenu> <guimenuitem>Vertical Mode</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> &Ctrl;&Alt; <keycap>R</keycap></"
"keycombo> </shortcut> <guimenu>विण्डो</guimenu> <guimenuitem>ऊर्ध्वाधरविधिः</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1544
#, no-c-format
msgid ""
"Toggles the <link linkend=\"list_panel\">List Panel</link> between "
"horizontal and vertical mode."
msgstr ""
"Toggles the<link linkend=\"list_panel\"> सूची पटल</link> क्षैतिज-लम्ब-गुणयोः मध्ये ।"

#. Tag: menuchoice
#: menu-commands.docbook:1550
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Alt; <keycap>F</keycap></"
"keycombo> </shortcut> <guimenu>Window</guimenu> <guimenuitem>Toggle "
"Fullscreen Terminal Emulator</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Alt; <keycap>F</keycap></"
"keycombo> </shortcut> <guimenu>विण्डो</guimenu> <guimenuitem>पूर्णपर्दे टर्मिनल् "
"अनुकरणकं टॉगलं कुर्वन्तु</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1561
#, no-c-format
msgid ""
"Toggles full screen mode of the terminal emulator. This option is only "
"available when <guilabel>Show Terminal Emulator</guilabel> is activated."
msgstr ""
"टर्मिनल् एमुलेटर् इत्यस्य पूर्णस्क्रीन् मोड् टॉग्ल् करोति । एषः विकल्पः तदा एव उपलब्धः यदा "
"<guilabel>Show Terminal Emulator</guilabel> सक्रियः भवति ।"

#. Tag: menuchoice
#: menu-commands.docbook:1568
#, no-c-format
msgid "<guimenu>Window</guimenu> <guimenuitem>Save Position</guimenuitem>"
msgstr "<guimenu>विण्डो</guimenu> <guimenuitem>स्थानं रक्षतु</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1574
#, no-c-format
msgid ""
"Saves the current size and position of the &krusader; main window. This "
"action can be automated with <guilabel>Save last position, size and panel "
"settings</guilabel> in <link linkend=\"konfigurator\">Konfigurator Startup "
"page</link>"
msgstr ""
"&amp;krusader; मुख्यविण्डो। एतत् क्रिया स्वचालितं कर्तुं शक्यते<guilabel> अन्तिमस्थानं, "
"आकारः, फलकसेटिंग्स् च रक्षन्तु</guilabel> इत्यस्मिन्‌<link linkend=\"konfigurator\"> "
"Konfigurator प्रारम्भ पृष्ठ</link>"

#. Tag: title
#: menu-commands.docbook:1584
#, no-c-format
msgid "Settings Menu"
msgstr "सेटिंग्स् मेनू"

#. Tag: menuchoice
#: menu-commands.docbook:1588
#, no-c-format
msgid ""
"<guimenu>Settings</guimenu> <guisubmenu>Toolbars</guisubmenu> "
"<guimenuitem>Show Main Toolbar</guimenuitem>"
msgstr ""
"<guimenu>सेटिंग्स्</guimenu> <guisubmenu>उपकरणपट्टिकाः</guisubmenu> "
"<guimenuitem>मुख्यसाधनपट्टिकां दर्शयतु</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1595
#, no-c-format
msgid "Shows the <link linkend=\"mainwindow\">Main Toolbar</link> if checked."
msgstr ""
"दर्शयति<link linkend=\"mainwindow\"> मुख्य साधनपट्टी</link> यदि जाँचितम् अस्ति।"

#. Tag: menuchoice
#: menu-commands.docbook:1601
#, no-c-format
msgid ""
"<guimenu>Settings</guimenu> <guisubmenu>Toolbars</guisubmenu> "
"<guimenuitem>Show Job Toolbar</guimenuitem>"
msgstr ""
"<guimenu>सेटिंग्स्</guimenu> <guisubmenu>उपकरणपट्टिकाः</guisubmenu> "
"<guimenuitem>कार्यसाधनपट्टिकां दर्शयतु</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1608
#, no-c-format
msgid "Shows the <link linkend=\"job_toolbar\">Job Toolbar</link> if checked."
msgstr ""
"दर्शयति<link linkend=\"job_toolbar\"> Job Toolbar</link> यदि जाँचितम् अस्ति।"

#. Tag: menuchoice
#: menu-commands.docbook:1614
#, no-c-format
msgid ""
"<guimenu>Settings</guimenu> <guisubmenu>Toolbars</guisubmenu> "
"<guimenuitem>Show Actions Toolbar</guimenuitem>"
msgstr ""
"<guimenu>सेटिंग्स्</guimenu> <guisubmenu>उपकरणपट्टिकाः</guisubmenu> "
"<guimenuitem>क्रियाः साधनपट्टिकां दर्शयतु</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1621
#, no-c-format
msgid ""
"Shows the <link linkend=\"actions_toolbar\">Actions Toolbar</link> if "
"checked."
msgstr ""
"दर्शयति<link linkend=\"actions_toolbar\"> क्रियाः साधनपट्टिका</link> यदि जाँचितम् "
"अस्ति।"

#. Tag: menuchoice
#: menu-commands.docbook:1627
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Show Statusbar</guimenuitem>"
msgstr "<guimenu>सेटिंग्स्</guimenu> <guimenuitem>स्थितिपट्टिकां दर्शयतु</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1633
#, no-c-format
msgid "Shows the <link linkend=\"mainwindow\">Statusbar</link> if chosen."
msgstr "दर्शयति<link linkend=\"mainwindow\"> स्थितिपट्टिका</link> यदि चयनितम्।"

#. Tag: menuchoice
#: menu-commands.docbook:1640
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Show FN Keys Bar</guimenuitem>"
msgstr ""
"<guimenu>सेटिंग्स्</guimenu> <guimenuitem>FN कुञ्जीपट्टिकां दर्शयतु</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1646
#, no-c-format
msgid "Shows the <link linkend=\"fnkeys\">FN Keys Bar</link> if checked."
msgstr "दर्शयति<link linkend=\"fnkeys\"> FN कीज बार</link> यदि जाँचितम् अस्ति।"

#. Tag: menuchoice
#: menu-commands.docbook:1652
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> &Ctrl;&Alt; <keycap>T</keycap></"
"keycombo> </shortcut> <guimenu>Settings</guimenu> <guimenuitem>Show Terminal "
"Emulator</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> &Ctrl;&Alt; <keycap>T</keycap></"
"keycombo> </shortcut> <guimenu>सेटिंग्स्</guimenu> <guimenuitem>टर्मिनल् एमुलेटर् "
"दर्शयतु</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1663
#, no-c-format
msgid "Show the <link linkend=\"cmdline\">Terminal Emulator</link> if checked."
msgstr "दर्शयतु<link linkend=\"cmdline\"> टर्मिनल एमुलेटर</link> यदि जाँचितम् अस्ति।"

#. Tag: menuchoice
#: menu-commands.docbook:1670
#, no-c-format
msgid ""
"<guimenu>Settings</guimenu> <guimenuitem>Show Command Line</guimenuitem>"
msgstr "<guimenu>सेटिंग्स्</guimenu> <guimenuitem>आदेशपङ्क्तिं दर्शयतु</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1676
#, no-c-format
msgid "Shows the <link linkend=\"cmdline\">Command Line</link> if checked."
msgstr "दर्शयति<link linkend=\"cmdline\"> आदेशपङ्क्तिः</link> यदि जाँचितम् अस्ति।"

#. Tag: menuchoice
#: menu-commands.docbook:1683
#, no-c-format
msgid ""
"<guimenu>Settings</guimenu> <guimenuitem>Command Execution Mode Setup</"
"guimenuitem>"
msgstr ""
"<guimenu>सेटिंग्स्</guimenu> <guimenuitem>आदेशनिष्पादनविधिस्थापन</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1689
#, no-c-format
msgid ""
"Allows you to choose command execution mode. You can choose one of the "
"following options."
msgstr ""
"आदेशनिष्पादनविधिं चिन्वितुं शक्नोति । भवन्तः निम्नलिखितविकल्पेषु एकं विकल्पं चिन्वितुं शक्नुवन्ति "
"।"

#. Tag: para
#: menu-commands.docbook:1693
#, no-c-format
msgid ""
"<guimenuitem>Start and Forget</guimenuitem>: start execution and do not wait "
"for the results."
msgstr ""
"<guimenuitem>प्रारम्भं विस्मरन्तु च</guimenuitem>: निष्पादनं आरभत परिणामान् न "
"प्रतीक्षन्तु ।"

#. Tag: para
#: menu-commands.docbook:1697
#, no-c-format
msgid ""
"<guimenuitem>Display Separated Standard and Error Output</guimenuitem>: show "
"the output to stdout and stderr on the separate panels."
msgstr ""
"<guimenuitem>पृथक् मानकं त्रुटिनिर्गमं च प्रदर्शयतु</guimenuitem>: पृथक् पटलेषु stdout तथा "
"stderr इत्येतयोः कृते आउटपुट् दर्शयतु ।"

#. Tag: para
#: menu-commands.docbook:1702
#, no-c-format
msgid ""
"<guimenuitem>Display Mixed Standard and Error Output</guimenuitem>: show the "
"output to stdout and stderr on the single panel (default)."
msgstr ""
"<guimenuitem>मिश्रितं मानकं त्रुटिनिर्गमं च प्रदर्शयतु</guimenuitem>: एकस्मिन् फलकस्य "
"(पूर्वनिर्धारित) stdout तथा stderr इत्येतयोः कृते आउटपुट् दर्शयतु ।"

#. Tag: para
#: menu-commands.docbook:1707
#, no-c-format
msgid ""
"<guimenuitem>Start in New Terminal</guimenuitem>: execute the command in the "
"new terminal window."
msgstr ""
"<guimenuitem>नवटर्मिनल् मध्ये आरभत</guimenuitem>: नूतनटर्मिनल् विण्डो मध्ये आदेशं "
"निष्पादयन्तु ।"

#. Tag: para
#: menu-commands.docbook:1712
#, no-c-format
msgid ""
"<guimenuitem>Send to Embedded Terminal Emulator</guimenuitem>: send the "
"command to the embedded terminal emulator."
msgstr ""
"<guimenuitem>एम्बेड्ड् टर्मिनल् एमुलेटर् प्रति प्रेषयतु</guimenuitem>: एम्बेडेड् टर्मिनल् एमुलेटर् "
"प्रति आदेशं प्रेषयतु ।"

#. Tag: menuchoice
#: menu-commands.docbook:1721
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Job Queue Mode</guimenuitem>"
msgstr "<guimenu>सेटिंग्स्</guimenu> <guimenuitem>कार्यपङ्क्तिविधिः</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1727
#, no-c-format
msgid ""
"Toggles the <link linkend=\"queue\">Queue Manager</link> mode. If checked "
"then pressing <keycap>F2</keycap> or the corresponding button in the copy/"
"move dialog immediately starts the job even if there are running jobs in "
"queue. If unchecked then the job will be put into the queue if the queue is "
"not empty. Otherwise the job will be started immediately."
msgstr ""
"Toggles the<link linkend=\"queue\"> कतारप्रबन्धकः</link> मोड् । यदि चेक् कृतं तर्हि "
"दबावम्<keycap> F2</keycap> अथवा प्रतिलिपि/चलनसंवादे तत्सम्बद्धं बटनं तत्क्षणमेव कार्यं "
"आरभते यद्यपि पङ्क्तौ चालितकार्यं भवति । यदि अनिरीक्षितं तर्हि कार्यं पङ्क्तौ स्थापितं "
"भविष्यति यदि पङ्क्तिः रिक्तः नास्ति । अन्यथा तत्क्षणमेव कार्यं आरभ्यते।"

#. Tag: menuchoice
#: menu-commands.docbook:1734
#, no-c-format
msgid ""
"<guimenu>Settings</guimenu> <guimenuitem>Configure Shortcuts...</guimenuitem>"
msgstr ""
"<guimenu>सेटिंग्स्</guimenu> <guimenuitem>शॉर्टकट् विन्यस्तं कुर्वन्तु...</guimenuitem>"

#. Tag: primary
#: menu-commands.docbook:1741
#, no-c-format
msgid "Configure"
msgstr "विन्यस्तं कुर्वन्तु"

#. Tag: secondary
#: menu-commands.docbook:1742
#, no-c-format
msgid "Shortcuts"
msgstr "शॉर्टकट"

#. Tag: para
#: menu-commands.docbook:1744
#, no-c-format
msgid ""
"Opens a dialog which allows you to configure the &krusader; key bindings."
msgstr "एकं संवादं उद्घाटयति यत् भवन्तं &krusader; कीलबन्धनानि।"

#. Tag: para
#: menu-commands.docbook:1746
#, no-c-format
msgid ""
"With the <guibutton>Import shortcuts</guibutton> and <guibutton>Export "
"shortcuts</guibutton> buttons you can load and save a Key-binding profile. "
"This allows &krusader; to have the <trademark class=\"copyright\">Total "
"Commander</trademark>, <application>Midnight Commander</application>, foo-"
"commander, or your custom Key-bindings. The only limitation is that global "
"&plasma; key-bindings and some &krusader; key-bindings cannot be changed "
"yet, as well as some features in foo-commander that we either do not have or "
"need. The Key-bindings are stored in <filename>/usr/share/krusader</"
"filename>, <filename>foo.keymap.info</filename> contains a description, "
"<filename>foo.keymap</filename> is an ini file that holds the Key-bindings. "
"Until &krusader;-1.70.1 this was a binary file, &krusader; is backwards "
"compatible for importing this legacy binary format. If a <filename>*.keymap."
"info</filename> text file exists, &krusader; will display it, showing "
"additional information regarding the loaded Key-bindings file. Here you have "
"a chance to exit without importing the proposed Key-bindings file."
msgstr ""
"<guibutton>Import shortcuts</guibutton> तथा <guibutton>Export shortcuts</"
"guibutton> बटन् इत्यनेन सह भवान् Key-binding प्रोफाइलं लोड् कृत्वा रक्षितुं शक्नोति । एतेन "
"&krusader; <trademark class=\"copyright\">Total Commander</trademark>, "
"<application>Midnight Commander</application>, foo-commander, अथवा भवतः कस्टम् "
"Key-bindings इति भवितुं । एकमात्रं सीमा अस्ति यत् वैश्विकं &plasma; कीलबन्धनानि च केचन "
"&krusader; key-bindings इत्येतत् अद्यापि परिवर्तयितुं न शक्यते, तथैव foo-commander "
"इत्यस्मिन् केचन विशेषताः ये अस्माकं नास्ति वा आवश्यकता अस्ति वा । कील-बन्धनानि "
"<filename>/usr/share/krusader</filename> इत्यत्र संगृहीताः सन्ति, <filename>foo."
"keymap.info</filename> इत्यत्र वर्णनं भवति, <filename>foo.keymap</filename> इति "
"ini अस्ति file यत् Key-bindings धारयति । &krusader;-1.70.1 यावत् एषा "
"द्विचक्रीयसञ्चिका आसीत्, &krusader; अस्य विरासतां द्विचक्रीयस्वरूपस्य आयातार्थं "
"पश्चात्तापसङ्गतम् अस्ति । यदि <filename>*.keymap.info</filename> पाठसञ्चिका अस्ति "
"तर्हि &krusader; तत् प्रदर्शयिष्यति, लोड् कृतस्य Key-bindings सञ्चिकायाः विषये "
"अतिरिक्तसूचनाः दर्शयति । अत्र भवतः प्रस्तावितां Key-bindings सञ्चिकां आयातं विना "
"निर्गमनस्य अवसरः अस्ति ।"

#. Tag: para
#: menu-commands.docbook:1770
#, no-c-format
msgid ""
"A <trademark class=\"copyright\">Total Commander</trademark> Key-bindings "
"file is provided. Please <link linkend=\"help_krusader\"> upload your "
"favorite Key-bindings schemes</link> so that they become available for the "
"&krusader; community. Thanks!"
msgstr ""
"एकः<trademark class=\"copyright\"> कुल सेनापति</trademark> कील-बन्धनसञ्चिका "
"प्रदत्ता अस्ति । कृपया<link linkend=\"help_krusader\"> स्वस्य प्रियाः Key-bindings "
"योजनाः अपलोड् कुर्वन्तु</link> यथा ते &amp;krusader; समुदाय। धन्यवादा!"

#. Tag: menuchoice
#: menu-commands.docbook:1781
#, no-c-format
msgid ""
"<guimenu>Settings</guimenu> <guimenuitem>Configure Toolbars...</guimenuitem>"
msgstr ""
"<guimenu>सेटिंग्स्</guimenu> <guimenuitem>उपकरणपट्टिकाः विन्यस्यताम्...</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1787
#, no-c-format
msgid ""
"Opens a dialog which allows you to configure the <link linkend=\"mainwindow"
"\">Main Toolbar</link> or the <link linkend=\"actions_toolbar\">Actions "
"Toolbar</link>. You can add action buttons of your favourite <link linkend="
"\"useractions\">UserActions</link> to the desired toolbar."
msgstr ""
"एकं संवादं उद्घाटयति यत् भवन्तं विन्यस्तुं शक्नोति<link linkend=\"mainwindow\"> मुख्य "
"साधनपट्टी</link> इति वा<link linkend=\"actions_toolbar\"> क्रियाः साधनपट्टिका</"
"link> . भवान् स्वस्य प्रियस्य एक्शन् बटन् योजयितुं शक्नोति<link linkend=\"useractions"
"\"> उपयोक्तृक्रियाः</link> इष्टं साधनपट्टिकां प्रति ।"

#. Tag: menuchoice
#: menu-commands.docbook:1796
#, no-c-format
msgid ""
"<guimenu>Settings</guimenu> <guimenuitem>Configure &krusader;...</"
"guimenuitem>"
msgstr ""
"<guimenu>सेटिंग्स्</guimenu> <guimenuitem>&krusader;...</guimenuitem> विन्यस्यताम्"

#. Tag: para
#: menu-commands.docbook:1803
#, no-c-format
msgid ""
"Opens <link linkend=\"konfigurator\">Konfigurator</link> - the &krusader; "
"configuration center."
msgstr ""
"उद्घाट्यते<link linkend=\"konfigurator\"> विन्यासकर्ता</link> - the &amp;"
"krusader; विन्यास केन्द्र।"

#. Tag: title
#: menu-commands.docbook:1811
#, no-c-format
msgid "Help Menu"
msgstr "सहायता मेनू"

#. Tag: para
#: menu-commands.docbook:1812
#, no-c-format
msgid ""
"Additionally, &krusader; has the common &kde; <guimenu>Help</guimenu> menu "
"items, for more information read the sections about the <ulink url=\"help:/"
"fundamentals/menus.html#menus-help\">Help Menu</ulink> of the &kde; "
"Fundamentals."
msgstr ""
"अतिरिक्तरूपेण &krusader; सामान्यं &kde; <guimenu>सहायता</guimenu> मेनू-वस्तूनाम्, "
"अधिकसूचनार्थं &kde; मौलिकता।"
