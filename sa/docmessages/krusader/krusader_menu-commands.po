msgstr ""
"<shortcut> <keycombo action=\"simultaneous\">&Alt; <keysym>प्रत्यावर्तयतु</"
"keysym></keycombo> </shortcut> <guimenu>सम्पादयतु</guimenu> "
"<guimenuitem>गुणाः...</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:639
#, no-c-format
msgid ""
"Opens the properties dialog for the currently selected file. (KP refers to "
"Key Pad.)"
msgstr "वर्तमान चयनितसञ्चिकायाः गुणसंवादं उद्घाटयति । (केपी कीपैड् इति निर्दिशति।)"

#. Tag: title
#: menu-commands.docbook:646
#, no-c-format
msgid "Go Menu"
msgstr "मेनू गच्छतु"

#. Tag: menuchoice
#: menu-commands.docbook:650
