#. Tag: title
#: diskusage.docbook:8
#, no-c-format
msgid "<title>Disk Usage</title>"
msgstr "<title>डिस्कस्य उपयोगः</title>"

#. Tag: primary
#: diskusage.docbook:10
#, no-c-format
msgid "<primary>Disk Usage</primary>"
msgstr "<primary>डिस्कस्य उपयोगः</primary>"

#. Tag: para
#: diskusage.docbook:12
#, no-c-format
msgid ""
"The Disk Usage is based on the code of &filelight;. The Disk Usage shows you "
"how your disk space is being used by a graphical representation of your file "
"system. The following presentations are possible:"
msgstr ""
"Disk Usage &filelight; इत्यस्य कोडस्य आधारेण भवति । डिस्क-उपयोगः भवन्तं दर्शयति यत् "
"भवतः सञ्चिका-प्रणाल्याः चित्रात्मक-प्रतिपादनेन भवतः डिस्क-स्थानं कथं उपयुज्यते । निम्नलिखित "
"प्रस्तुतिः सम्भवति :"

#. Tag: para
#: diskusage.docbook:18
#, no-c-format
msgid "Line view"
msgstr "रेखादृश्यम्"

#. Tag: para
#: diskusage.docbook:21
#, no-c-format
msgid "Detailed view"
msgstr "विस्तृत दृश्य"

#. Tag: para
#: diskusage.docbook:24
#, no-c-format
msgid ""
"<application>Filelight</application> view: as a set of concentric segmented-"
"rings"
msgstr ""
"<application>Filelight</application> दृश्यम्: समकेन्द्रितखण्डित-वलयस्य समुच्चयरूपेण"

#. Tag: para
#: diskusage.docbook:28
#, no-c-format
msgid ""
"Choose <menuchoice> <guimenu>Tools</guimenu> <guimenuitem>Disk Usage...</"
"guimenuitem> </menuchoice> or <keycombo action=\"simul\">&Alt;&Shift; "
"<keycap>S</keycap></keycombo> to start this feature in a separate window, or "
"open it inside the <link linkend=\"sidebar\">Sidebar</link>."
msgstr ""
"चिनोतु<menuchoice><guimenu> उपकरणाः</guimenu><guimenuitem> डिस्कस्य उपयोगः...</"
"guimenuitem></menuchoice> वा<keycombo action=\"simul\"> &amp;अल्ट;&amp;शिफ्ट;"
"<keycap> स</keycap></keycombo> पृथक् विण्डो मध्ये एतत् विशेषता आरभ्य, अथवा अन्तः "
"उद्घाटयितुं<link linkend=\"sidebar\"> पार्श्वपट्टिका</link> ."

#. Tag: para
#: diskusage.docbook:38
#, no-c-format
msgid "Disk Usage Keybindings, right click menu."
msgstr "Disk Usage Keybindings, मेनू इत्यत्र राइट् क्लिक् कुर्वन्तु ।"

#. Tag: para
#: diskusage.docbook:41
#, no-c-format
msgid "<keycap>Del</keycap>: Delete"
msgstr "<keycap>Del</keycap>: विलोपयतु"

#. Tag: para
#: diskusage.docbook:45
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Ctrl; <keycap>E</keycap></keycombo>: Exclude"
msgstr ""
"<keycombo action=\"simul\">&Ctrl; <keycap>E</keycap></keycombo>: बहिष्कृतम्"

#. Tag: para
#: diskusage.docbook:50
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Shift; <keycap>Arrow Up</keycap></keycombo>: Up "
"one folder"
msgstr ""
"<keycombo action=\"simul\">&शिफ्ट; <keycap>बाणः उपरि</keycap></keycombo>: एकं "
"पुटं उपरि"

#. Tag: para
#: diskusage.docbook:55
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Ctrl; <keycap>N</keycap></keycombo>: new search"
msgstr ""
"<keycombo action=\"simul\">&Ctrl; <keycap>N</keycap></keycombo>: नूतनं अन्वेषणम्"

#. Tag: para
#: diskusage.docbook:60
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Ctrl; <keycap>R</keycap></keycombo>: refresh"
msgstr "<keycombo action=\"simul\">&Ctrl; <keycap>R</keycap></keycombo>: ताजगी"

#. Tag: para
#: diskusage.docbook:65
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Ctrl; <keycap>I</keycap></keycombo>: include all"
msgstr ""
"<keycombo action=\"simul\">&Ctrl; <keycap>अहं</keycap></keycombo>: सर्वाणि "
"समावेशयति"

#. Tag: para
#: diskusage.docbook:70
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Shift; <keycap>Arrow Down</keycap></keycombo>: "
"step into"
msgstr ""
"<keycombo action=\"simul\">&शिफ्ट; <keycap>बाणः अधः</keycap></keycombo>: step "
"in"

#. Tag: para
#: diskusage.docbook:75
#, no-c-format
msgid "View menu:"
msgstr "मेनू दृश्यम् :"

#. Tag: para
#: diskusage.docbook:78
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Ctrl; <keycap>L</keycap></keycombo>: Line view"
msgstr ""
"<keycombo action=\"simul\">&Ctrl; <keycap>L</keycap></keycombo>: रेखादृश्यम्"

#. Tag: para
#: diskusage.docbook:83
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Ctrl; <keycap>D</keycap></keycombo>: Detailed "
"view"
msgstr ""
"<keycombo action=\"simul\">&Ctrl; <keycap>D</keycap></keycombo>: विस्तृतदृश्यम्"

#. Tag: para
#: diskusage.docbook:88
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Ctrl; <keycap>F</keycap></keycombo>: Filelight "
"view"
msgstr ""
"<keycombo action=\"simul\">&Ctrl; <keycap>F</keycap></keycombo>: "
"सञ्चिकाप्रकाशदृश्यम्"

#. Tag: para
#: diskusage.docbook:93
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Shift; <keycap>Arrow Right</keycap></keycombo>: "
"Next view"
msgstr ""
"<keycombo action=\"simul\">&शिफ्ट; <keycap>बाण दक्षिण</keycap></keycombo>: "
"अग्रिमदृश्यम्"

#. Tag: para
#: diskusage.docbook:98
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Shift; <keycap>Arrow Left</keycap></keycombo>: "
"Previous view"
msgstr ""
"<keycombo action=\"simul\">&शिफ्ट; <keycap>बाण वाम</keycap></keycombo>: "
"पूर्वदृश्यम्"
