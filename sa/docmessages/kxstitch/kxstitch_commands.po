#. Tag: title
#: commands.docbook:2
#, no-c-format
msgid "Command Reference"
msgstr "आदेश सन्दर्भ"

#. Tag: title
#: commands.docbook:5
#, no-c-format
msgid "&kxstitch; Menus"
msgstr "&kxstitch; मेनू"

#. Tag: title
#: commands.docbook:7
#, no-c-format
msgid "The File Menu"
msgstr "सञ्चिकामेनू इति"

#. Tag: menuchoice
#: commands.docbook:11
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>N</keycap></keycombo></"
"shortcut><guimenuitem>New</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>N</keycap></keycombo></"
"shortcut><guimenuitem>नव</guimenuitem>"

#. Tag: action
#: commands.docbook:12
#, no-c-format
msgid ""
"Creates a new pattern, using the default values set in the pattern "
"properties dialog."
msgstr "नूतनं प्रतिरूपं निर्माति, प्रतिरूपगुणसंवादे सेट् पूर्वनिर्धारितमूल्यानां उपयोगेन ।"

#. Tag: menuchoice
#: commands.docbook:15
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>O</keycap></keycombo></"
"shortcut><guimenuitem>Open</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>ओ</keycap></keycombo></"
"shortcut><guimenuitem>उद्घाट</guimenuitem>"

#. Tag: action
#: commands.docbook:16
#, no-c-format
msgid "Opens an existing pattern"
msgstr "विद्यमानं प्रतिरूपं उद्घाटयति"

#. Tag: guimenuitem
#: commands.docbook:19
#, no-c-format
msgid "Open Recent"
msgstr "Open Recent इति"

#. Tag: action
#: commands.docbook:20
#, no-c-format
msgid "Open a recently used pattern"
msgstr "सद्यः प्रयुक्तं प्रतिमानं उद्घाटयन्तु"

#. Tag: menuchoice
#: commands.docbook:23
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>S</keycap></keycombo></"
"shortcut><guimenuitem>Save</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>S</keycap></keycombo></"
"shortcut><guimenuitem>रक्षतु</guimenuitem>"

#. Tag: action
#: commands.docbook:24
#, no-c-format
msgid "Saves the pattern"
msgstr "प्रतिमानं रक्षति"

#. Tag: menuchoice
#: commands.docbook:27
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;&Shift;<keycap>S</keycap></"
"keycombo></shortcut><guimenuitem>Save As</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;&Shift;<keycap>S</keycap></"
"keycombo></shortcut><guimenuitem>यथा रक्षतु</guimenuitem>"

#. Tag: action
#: commands.docbook:28
#, no-c-format
msgid "Saves the pattern under a new name"
msgstr "नूतननाम्ना प्रतिमानं रक्षति"

#. Tag: guimenuitem
#: commands.docbook:31
#, no-c-format
msgid "Revert"
msgstr "प्रत्यावर्तयतु"

#. Tag: action
#: commands.docbook:32
#, no-c-format
msgid "Revert the pattern to the last saved state"
msgstr "प्रतिरूपं अन्तिमे रक्षितस्थितौ पुनः स्थापयन्तु"

#. Tag: menuchoice
#: commands.docbook:35
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>P</keycap></keycombo></"
"shortcut><guimenuitem>Print</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>P</keycap></keycombo></"
"shortcut><guimenuitem>मुद्रण</guimenuitem>"

#. Tag: action
#: commands.docbook:36
#, no-c-format
msgid "Print the pattern"
msgstr "प्रतिमानं मुद्रयन्तु"

#. Tag: guimenuitem
#: commands.docbook:39
#, no-c-format
msgid "Print Setup"
msgstr "मुद्रण सेटअप"

#. Tag: action
#: commands.docbook:40
#, no-c-format
msgid "Set up the printing layout"
msgstr "मुद्रणविन्यासं स्थापयन्तु"

#. Tag: guimenuitem
#: commands.docbook:43
#, no-c-format
msgid "Import Image"
msgstr "इमेज आयात करें"

#. Tag: action
#: commands.docbook:44
#, no-c-format
msgid "Import an image file converting it to stitches"
msgstr "एकं चित्रसञ्चिकां सिलेनरूपेण परिवर्त्य आयातयन्तु"

#. Tag: guimenuitem
#: commands.docbook:47
#, no-c-format
msgid "File Properties"
msgstr "सञ्चिकागुणाः"

#. Tag: action
#: commands.docbook:48
#, no-c-format
msgid "Display / Edit the document properties"
msgstr "दस्तावेजस्य गुणाः प्रदर्शयन्तु / सम्पादयन्तु"

#. Tag: guimenuitem
#: commands.docbook:51
#, no-c-format
msgid "Add Background Image"
msgstr "Background Image योजयतु"

#. Tag: action
#: commands.docbook:52
#, no-c-format
msgid "Insert an image as a background for tracing."
msgstr "अनुसन्धानार्थं पृष्ठभूमिरूपेण चित्रं सम्मिलितं कुर्वन्तु ।"

#. Tag: guimenuitem
#: commands.docbook:55
#, no-c-format
msgid "Remove Background Image"
msgstr "पृष्ठभूमिचित्रं निष्कासयन्तु"

#. Tag: action
#: commands.docbook:56
#, no-c-format
msgid ""
"Select a background image to remove. The sub menu for this is populated from "
"the background images previously inserted."
msgstr ""
"निष्कासनार्थं पृष्ठभूमिप्रतिबिम्बं चिनोतु । अस्य कृते उपमेनू पूर्वं प्रविष्टानां पृष्ठभूमिचित्रेभ्यः "
"पूरितं भवति ।"

#. Tag: menuchoice
#: commands.docbook:59
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>W</keycap></keycombo></"
"shortcut><guimenuitem>Close</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>W</keycap></keycombo></"
"shortcut><guimenuitem>बन्द</guimenuitem>"

#. Tag: action
#: commands.docbook:60
#, no-c-format
msgid "Close the pattern"
msgstr "प्रतिमानं पिधाय"

#. Tag: menuchoice
#: commands.docbook:63
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>Q</keycap></keycombo></"
"shortcut><guimenuitem>Quit</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>प्रश्न</keycap></keycombo></"
"shortcut><guimenuitem>निवृत्त</guimenuitem>"

#. Tag: simpara
#: commands.docbook:64
#, no-c-format
msgid "<action>Quits</action> &kxstitch;"
msgstr "<action>त्यजति</action> &kxstitch;"

#. Tag: title
#: commands.docbook:71
#, no-c-format
msgid "The Edit Menu"
msgstr "सम्पादन मेनू इति"

#. Tag: menuchoice
#: commands.docbook:75
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>Z</keycap></keycombo></"
"shortcut><guimenuitem>Undo</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>Z</keycap></keycombo></"
"shortcut><guimenuitem>पूर्ववर्ती</guimenuitem>"

#. Tag: action
#: commands.docbook:76
#, no-c-format
msgid ""
"Undo the last change. The list of changes are shown in the History window."
msgstr ""
"अन्तिमपरिवर्तनं पूर्ववत् कुर्वन्तु। परिवर्तनस्य सूची History विण्डो मध्ये दर्शिता भवति ।"

#. Tag: menuchoice
#: commands.docbook:79
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;&Shift;<keycap>Z</keycap></"
"keycombo></shortcut><guimenuitem>Redo</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;&Shift;<keycap>Z</keycap></"
"keycombo></shortcut><guimenuitem>पुनः करो</guimenuitem>"

#. Tag: action
#: commands.docbook:80
#, no-c-format
msgid ""
"Redo the last change undone. The list of changes are shown in the History "
"window."
msgstr ""
"अन्तिमपरिवर्तनं अकृतं पुनः कुर्वन्तु। परिवर्तनस्य सूची History विण्डो मध्ये दर्शिता भवति ।"

#. Tag: menuchoice
#: commands.docbook:83
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>X</keycap></keycombo></"
"shortcut><guimenuitem>Cut</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>X</keycap></keycombo></"
"shortcut><guimenuitem>कट</guimenuitem>"

#. Tag: action
#: commands.docbook:84
#, no-c-format
msgid "Cut the selected area to the clipboard"
msgstr "चयनितं क्षेत्रं क्लिप्बोर्ड् प्रति कटयन्तु"

#. Tag: menuchoice
#: commands.docbook:87
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>C</keycap></keycombo></"
"shortcut><guimenuitem>Copy</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>C</keycap></keycombo></"
"shortcut><guimenuitem>प्रतिलिपि</guimenuitem>"

#. Tag: action
#: commands.docbook:88
#, no-c-format
msgid "Copy the selected area to the clipboard"
msgstr "चयनितं क्षेत्रं क्लिप्बोर्ड् प्रति प्रतिलिख्यताम्"

#. Tag: menuchoice
#: commands.docbook:91
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>V</keycap></keycombo></"
"shortcut><guimenuitem>Paste</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>V</keycap></keycombo></"
"shortcut><guimenuitem>चिपकतु</guimenuitem>"

#. Tag: action
#: commands.docbook:92
#, no-c-format
msgid "Paste the selected area"
msgstr "चयनितं क्षेत्रं चिनोतु"

#. Tag: menuchoice
#: commands.docbook:95
#, no-c-format
msgid ""
"<guisubmenu>Selection Masks</guisubmenu><guimenuitem>Stitch Mask</"
"guimenuitem>"
msgstr "<guisubmenu>चयनमास्क</guisubmenu><guimenuitem>सिलाईमास्क</guimenuitem>"

#. Tag: action
#: commands.docbook:96
#, no-c-format
msgid "Limit selections to the currently selected stitch type"
msgstr "वर्तमान चयनितसिलाईप्रकारे चयनं सीमितं कुर्वन्तु"

#. Tag: menuchoice
#: commands.docbook:99
#, no-c-format
msgid ""
"<guisubmenu>Selection Masks</guisubmenu><guimenuitem>Color Mask</guimenuitem>"
msgstr "<guisubmenu>चयनमास्क</guisubmenu><guimenuitem>रङ्गमास्क</guimenuitem>"

#. Tag: action
#: commands.docbook:100
#, no-c-format
msgid "Limit selections to the currently selected color"
msgstr "वर्तमान चयनितवर्णपर्यन्तं चयनं सीमितं कुर्वन्तु"

#. Tag: menuchoice
#: commands.docbook:102
#, no-c-format
msgid ""
"<guisubmenu>Selection Masks</guisubmenu><guimenuitem>Exclude Backstitches</"
"guimenuitem>"
msgstr ""
"<guisubmenu>चयनमास्क</guisubmenu><guimenuitem>पृष्ठसिलेखान् बहिष्कृत्य</guimenuitem>"

#. Tag: action
#: commands.docbook:103
#, no-c-format
msgid "Exclude backstitches from the selection"
msgstr "चयनात् पृष्ठसिलेखान् बहिष्कृत्य"

#. Tag: menuchoice
#: commands.docbook:106
#, no-c-format
msgid ""
"<guisubmenu>Selection Masks</guisubmenu><guimenuitem>Exclude Knots</"
"guimenuitem>"
msgstr ""
"<guisubmenu>चयनमास्क</guisubmenu><guimenuitem>ग्रन्थिं बहिष्कृत्य</guimenuitem>"

#. Tag: action
#: commands.docbook:107
#, no-c-format
msgid "Exclude Knots from the selection"
msgstr "चयनात् Knots इत्येतत् बहिष्कृतं कुर्वन्तु"

#. Tag: guimenuitem
#: commands.docbook:110
#, no-c-format
msgid "Mirror / Rotate makes copies"
msgstr "Mirror / Rotate प्रतिलिपानि करोति"

#. Tag: action
#: commands.docbook:111
#, no-c-format
msgid ""
"If set, the mirror and rotate functions will make a copy of the selection, "
"otherwise the selected area is moved"
msgstr ""
"यदि सेट् भवति तर्हि mirror तथा rotate फंक्शन्स् चयनस्य प्रतिलिपिं करिष्यन्ति, अन्यथा "
"चयनितं क्षेत्रं स्थानान्तरितम् अस्ति"

#. Tag: menuchoice
#: commands.docbook:114
#, no-c-format
msgid ""
"<guisubmenu>Mirror Selection</guisubmenu><guimenuitem>Horizontally</"
"guimenuitem>"
msgstr "<guisubmenu>दर्पणचयन</guisubmenu><guimenuitem>क्षैतिजरूपेण</guimenuitem>"

#. Tag: action
#: commands.docbook:115
#, no-c-format
msgid "Mirror the selected area horizontally, &ie; flipped from left to right"
msgstr "चयनितक्षेत्रं क्षैतिजरूपेण प्रतिबिम्बं कुर्वन्तु, &ie; वामतः दक्षिणं प्रति प्लवमानः"

#. Tag: menuchoice
#: commands.docbook:118
#, no-c-format
msgid ""
"<guisubmenu>Mirror Selection</guisubmenu><guimenuitem>Vertically</"
"guimenuitem>"
msgstr "<guisubmenu>दर्पणचयन</guisubmenu><guimenuitem>लम्बरूपेण</guimenuitem>"

#. Tag: action
#: commands.docbook:119
#, no-c-format
msgid "Mirrors the selected area vertically, &ie; flipped from top to bottom"
msgstr "चयनितक्षेत्रं लम्बवत् प्रतिबिम्बयति, &ie; उपरितः अधः यावत् प्लवमानः"

#. Tag: menuchoice
#: commands.docbook:122
#, no-c-format
msgid ""
"<guisubmenu>Rotate Selection</guisubmenu><guimenuitem>90 degrees</"
"guimenuitem>"
msgstr ""
"<guisubmenu>चयनं परिभ्रमन्तु</guisubmenu><guimenuitem>९० डिग्री</guimenuitem>"

#. Tag: action
#: commands.docbook:123
#, no-c-format
msgid "Rotate the selected area anti clockwise 90 degrees"
msgstr "चयनितं क्षेत्रं घड़ीयानस्य विपरीतदिशि ९० डिग्री परिभ्रमन्तु"

#. Tag: menuchoice
#: commands.docbook:126
#, no-c-format
msgid ""
"<guisubmenu>Rotate Selection</guisubmenu><guimenuitem>180 degrees</"
"guimenuitem>"
msgstr ""
"<guisubmenu>चयनं परिभ्रमन्तु</guisubmenu><guimenuitem>१८० डिग्री</guimenuitem>"

#. Tag: action
#: commands.docbook:127
#, no-c-format
msgid "Rotate the selected area anti clockwise 180 degrees"
msgstr "चयनितं क्षेत्रं घड़ीयानस्य विपरीतदिशि १८० डिग्रीपर्यन्तं परिभ्रमन्तु"

#. Tag: menuchoice
#: commands.docbook:130
#, no-c-format
msgid ""
"<guisubmenu>Rotate Selection</guisubmenu><guimenuitem>270 degrees</"
"guimenuitem>"
msgstr ""
"<guisubmenu>चयनं परिभ्रमन्तु</guisubmenu><guimenuitem>270 डिग्री</guimenuitem>"

#. Tag: action
#: commands.docbook:131
#, no-c-format
msgid "Rotate the selected area anti clockwise 270 degrees"
msgstr "चयनितं क्षेत्रं घड़ीयानस्य विपरीतदिशि २७० डिग्री परिभ्रमन्तु"

#. Tag: title
#: commands.docbook:136
#, no-c-format
msgid "Cut, Copy and Paste"
msgstr "Cut, Copy and Paste इति कृत्वा स्थापयन्तु"

#. Tag: para
#: commands.docbook:137
#, no-c-format
msgid ""
"Cutting and copying areas of the pattern can make use of stitch and color "
"masks and the exclusion of backstitches and knots to limit the selection."
msgstr ""
"प्रतिरूपस्य क्षेत्राणि कटयित्वा प्रतिलिपिकरणं कृत्वा सिलाई-रङ्ग-मास्कस्य उपयोगः कर्तुं शक्यते "
"तथा च चयनं सीमितं कर्तुं पृष्ठसिले-ग्रन्थि-बहिष्कारः कर्तुं शक्यते ।"

#. Tag: para
#: commands.docbook:141
#, no-c-format
msgid ""
"The paste operation in &kxstitch; allows you to press and hold the &LMB; "
"down roughly in the position that the paste data is to go which will provide "
"an image of the paste data to allow accurate positioning before releasing "
"the mouse button to finalize the position. This technique is also used for "
"the mirroring and rotate functions. The cursor keys can also be used to move "
"the pasted pattern around and the &Enter; key used to fix the position."
msgstr ""
"&kxstitch; &LMB; down roughly in the position that the paste data is to go "
"यत् पेस्ट् दत्तांशस्य प्रतिबिम्बं प्रदास्यति यत् स्थानं अन्तिमरूपेण निर्धारयितुं मूषकस्य बटनं मुक्तं "
"कर्तुं पूर्वं सटीकं स्थापनं अनुमन्यते एतत् तन्त्रं प्रतिबिम्बीकरणस्य, परिभ्रमणकार्यस्य च कृते अपि "
"उपयुज्यते । कर्सर कीलानां उपयोगेन चिनोति प्रतिमानं परितः चालयितुं अपि च &Enter; स्थितिं "
"निश्चेतुं प्रयुक्ता कीलम् ।"

#. Tag: title
#: commands.docbook:152
#, no-c-format
msgid "The View Menu"
msgstr "दृश्य मेनू इति"

#. Tag: guimenuitem
#: commands.docbook:156
#, no-c-format
msgid "Actual Size"
msgstr "वास्तविक आकार"

#. Tag: action
#: commands.docbook:157
#, no-c-format
msgid "Zoom the view so that the screen size approximates the physical size"
msgstr "दृश्यं जूम् कुर्वन्तु येन स्क्रीन आकारः भौतिक आकारस्य अनुमानं करोति"

#. Tag: guimenuitem
#: commands.docbook:160
#, no-c-format
msgid "Fit To Page"
msgstr "पृष्ठं प्रति फिट्"

#. Tag: action
#: commands.docbook:161
#, no-c-format
msgid "Zoom the view so that the whole pattern fits within the visible area"
msgstr "दृश्यं जूम कुर्वन्तु येन सम्पूर्णं प्रतिरूपं दृश्यक्षेत्रे उपयुज्यते"

#. Tag: guimenuitem
#: commands.docbook:164
#, no-c-format
msgid "Fit To Page Width"
msgstr "पृष्ठस्य चौड़ाई कृते फिट्"

#. Tag: action
#: commands.docbook:165
#, no-c-format
msgid "Zoom the view so that the patterns width fits within the visible area"
msgstr "दृश्यं जूम् कुर्वन्तु येन प्रतिमानस्य विस्तारः दृश्यमानक्षेत्रे उपयुज्यते"

#. Tag: guimenuitem
#: commands.docbook:168
#, no-c-format
msgid "Fit To Page Height"
msgstr "पृष्ठस्य ऊर्ध्वतायां फिट्"

#. Tag: action
#: commands.docbook:169
#, no-c-format
msgid "Zoom the view so that the patterns height fits within the visible area"
msgstr "दृश्यं जूम् कुर्वन्तु येन प्रतिमानस्य ऊर्ध्वता दृश्यमानक्षेत्रे उपयुज्यते"

#. Tag: menuchoice
#: commands.docbook:172
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>+</keycap></keycombo></"
"shortcut><guimenuitem>Zoom In</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>+</keycap></keycombo></"
"shortcut><guimenuitem>जूम इन</guimenuitem>"

#. Tag: action
#: commands.docbook:173
#, no-c-format
msgid "Zoom in on the editor view"
msgstr "सम्पादकदृश्ये जूम इन कुर्वन्तु"

#. Tag: menuchoice
#: commands.docbook:176
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>-</keycap></keycombo></"
"shortcut><guimenuitem>Zoom Out</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>-</keycap></keycombo></"
"shortcut><guimenuitem>जूम आउट</guimenuitem>"

#. Tag: action
#: commands.docbook:177
#, no-c-format
msgid "Zoom out on the editor view"
msgstr "सम्पादकदृश्ये जूम आउट् कुर्वन्तु"

#. Tag: guimenuitem
#: commands.docbook:179
#, no-c-format
msgid "Preview"
msgstr "पूर्वावलोकनम्"

#. Tag: action
#: commands.docbook:180
#, no-c-format
msgid "Show or hide the preview window"
msgstr "पूर्वावलोकनविण्डो दर्शयतु वा गोपयन्तु वा"

#. Tag: guimenuitem
#: commands.docbook:183
#, no-c-format
msgid "Palette"
msgstr "पॅलेट्"

#. Tag: action
#: commands.docbook:184
#, no-c-format
msgid "Show or hide the palette window"
msgstr "पॅलेट् विण्डो दर्शयतु वा गोपयन्तु वा"

#. Tag: guimenuitem
#: commands.docbook:187
#, no-c-format
msgid "History"
msgstr "इतिहास"

#. Tag: action
#: commands.docbook:188
#, no-c-format
msgid "Show or hide the history window"
msgstr "इतिहासविण्डो दर्शयतु वा गोपयन्तु वा"

#. Tag: guimenuitem
#: commands.docbook:191
#, no-c-format
msgid "Imported Image"
msgstr "आयातितप्रतिमा"

#. Tag: action
#: commands.docbook:192
#, no-c-format
msgid "Show or hide the imported image preview window"
msgstr "आयातितं चित्रपूर्वावलोकनविण्डो दर्शयतु वा गोपयन्तु वा"

#. Tag: guimenuitem
#: commands.docbook:195
#, no-c-format
msgid "Show Background Image"
msgstr "पृष्ठभूमिचित्रं दर्शयतु"

#. Tag: action
#: commands.docbook:196
#, no-c-format
msgid ""
"Show or hide a background image. The list is generated dynamically based on "
"the inserted background images"
msgstr ""
"पृष्ठभूमिप्रतिबिम्बं दर्शयतु वा गोपयन्तु वा। सूचीः सम्मिलितपृष्ठभूमिप्रतिमानां आधारेण "
"गतिशीलरूपेण उत्पद्यते"

#. Tag: guimenuitem
#: commands.docbook:199
#, no-c-format
msgid "Fit Background Image to Selection"
msgstr "पृष्ठभूमिप्रतिमा चयनं प्रति फिट् कुर्वन्तु"

#. Tag: action
#: commands.docbook:200
#, no-c-format
msgid "Fit the selected background image to the current selection area"
msgstr "चयनितं पृष्ठभूमिचित्रं वर्तमानचयनक्षेत्रे फिट् कुर्वन्तु"

#. Tag: title
#: commands.docbook:207
#, no-c-format
msgid "The Stitches Menu"
msgstr "The Stitches Menu इति"

#. Tag: guimenuitem
#: commands.docbook:211
#, no-c-format
msgid "Quarter Stitch"
msgstr "क्वार्टर सिलाई"

#. Tag: action
#: commands.docbook:212
#, no-c-format
msgid ""
"Quarter Stitch, the position is determined by the quadrant of the cell "
"selected"
msgstr "Quarter Stitch, स्थानं चयनितस्य कोष्ठकस्य चतुर्भागेन निर्धारितं भवति"

#. Tag: guimenuitem
#: commands.docbook:215
#, no-c-format
msgid "Half Stitch"
msgstr "आधा सिलाई"

#. Tag: action
#: commands.docbook:216
#, no-c-format
msgid ""
"Half Stitch, the direction is determined by the quadrant of the cell selected"
msgstr "Half Stitch, दिशा चयनितस्य कोष्ठकस्य चतुर्भागेन निर्धारिता भवति"

#. Tag: guimenuitem
#: commands.docbook:219
#, no-c-format
msgid "3 Quarter Stitch"
msgstr "३ क्वार्टर् स्टिच्"

#. Tag: action
#: commands.docbook:221
#, no-c-format
msgid ""
"Three Quarter Stitch, the orientation is determined by the quadrant of the "
"cell selected"
msgstr ""
"Three Quarter Stitch, अभिविन्यासः चयनितस्य कोष्ठकस्य चतुर्भागेन निर्धारितः भवति"

#. Tag: guimenuitem
#: commands.docbook:224
#, no-c-format
msgid "<guimenuitem>Full Stitch</guimenuitem>"
msgstr "<guimenuitem>पूर्ण सिलाई</guimenuitem>"

#. Tag: action
#: commands.docbook:225
#, no-c-format
msgid "<action>Full Stitch</action>"
msgstr "<action>पूर्णसिलाई</action> इति"

#. Tag: guimenuitem
#: commands.docbook:228
#, no-c-format
msgid "Small Half Stitch"
msgstr "लघु अर्ध सिलाई"

#. Tag: action
#: commands.docbook:229
#, no-c-format
msgid ""
"A small half stitch, the position is determined by the quadrant of the cell "
"selected"
msgstr "लघु अर्धसिलेखः, स्थानं चयनितस्य कोष्ठस्य चतुर्भागेन निर्धारितं भवति"

#. Tag: guimenuitem
#: commands.docbook:232
#, no-c-format
msgid "Small Full Stitch"
msgstr "लघु पूर्ण सिलाई"

#. Tag: action
#: commands.docbook:233
#, no-c-format
msgid ""
"A small full stitch, the position is determined by the quadrant of the cell "
"selected"
msgstr "एकः लघुः पूर्णः सिलेखः, स्थानं चयनितस्य कोष्ठस्य चतुर्भागेन निर्धारितं भवति"

#. Tag: guimenuitem
#: commands.docbook:236
#, no-c-format
msgid "French Knot"
msgstr "फ्रेंच गाँठ"

#. Tag: action
#: commands.docbook:237
#, no-c-format
msgid "French Knot Stitch"
msgstr "फ्रेंच गाँठ सिलाई"

#. Tag: title
#: commands.docbook:244
#, no-c-format
msgid "The Tools Menu"
msgstr "Tools Menu इति"

#. Tag: guimenuitem
#: commands.docbook:248
#, no-c-format
msgid "Paint"
msgstr "चित्र"

#. Tag: action
#: commands.docbook:249
#, no-c-format
msgid ""
"Paint stitches onto the canvas - Press down the &LMB; and drag around the "
"window. Stitches will be added to each cell passed over. Release the mouse "
"button to stop painting."
msgstr ""
"कैनवासस्य उपरि सिलाईं रङ्गयन्तु - &LMB; तथा खिडकीं परितः कर्षन्तु। प्रत्येकं कोष्ठकं पारितस्य "
"मध्ये सिलेखाः योजिताः भविष्यन्ति। चित्रकला स्थगयितुं मूषकस्य बटनं मुक्तं कुर्वन्तु ।"

#. Tag: guimenuitem
#: commands.docbook:255
#, no-c-format
msgid "Draw"
msgstr "आकर्षयतु"

#. Tag: action
#: commands.docbook:256
#, no-c-format
msgid ""
"Draw a line of stitches onto the canvas - Press down the &LMB; at the start "
"of the line, drag to the required end point of the line and release the "
"mouse button. Stitches will be added to each cell that the line passes "
"through."
msgstr ""
"कैनवासस्य उपरि सिलेखानां रेखां आकर्षयन्तु - &LMB; रेखायाः आरम्भे रेखायाः आवश्यकं अन्त्यबिन्दुं "
"यावत् कर्षयित्वा मूषकस्य बटनं मुञ्चन्तु । रेखा यस्मात् कोष्ठके गच्छति तस्मिन् प्रत्येकस्मिन् कोष्ठके "
"सिलेन्थः योजिताः भविष्यन्ति ।"

#. Tag: guimenuitem
#: commands.docbook:263
#, no-c-format
msgid "Erase"
msgstr "मेटयतु"

#. Tag: action
#: commands.docbook:264
#, no-c-format
msgid ""
"Erase stitches - Press down the &LMB; and drag over the stitches to be "
"deleted. All stitches within the cells passed over will be removed. Release "
"the mouse button to stop erasing. To erase backstitches hold down the &Ctrl; "
"key and left click in the start or end point of the backstitch, if there is "
"more than one backstitch at the digitized point this method will erase the "
"first one found. To delete a specific backstitch, click and drag from one "
"end to the other. To erase french knots hold down the &Shift; key and left "
"click on the knot to delete it."
msgstr ""
"सिलाईं मेटयतु - &LMB; तथा लोपनीयानां सिलेखानां उपरि कर्षन्तु। उपरि गतानां कोष्ठकानां "
"अन्तः सर्वे सिलेखाः निष्कासिताः भविष्यन्ति। मेटनं स्थगयितुं मूषकस्य बटनं मुक्तं कुर्वन्तु । "
"पृष्ठसिलेखान् मेटयितुं &Ctrl; key and left click in the start or end point of the "
"backstitch, यदि डिजिटाइज्ड् बिन्दौ एकादशाधिकं backstitch अस्ति तर्हि एषा पद्धतिः "
"प्रथमं प्राप्तं मेटयिष्यति विशिष्टं पृष्ठसिलेखं विलोपयितुं एकस्मात् अन्तः अन्यतमं यावत् क्लिक् कृत्वा "
"कर्षन्तु । फ्रेंचग्रन्थिं मेटयितुं &Shift; कीलं कृत्वा ग्रन्थिं विलोपयितुं वाम क्लिक् कुर्वन्तु ।"

#. Tag: guimenuitem
#: commands.docbook:273
#, no-c-format
msgid "Draw Rectangle"
msgstr "आयत खींचें"

#. Tag: action
#: commands.docbook:274
#, no-c-format
msgid ""
"Draw a rectangle - Press down the &LMB; at one corner of the rectangle and "
"drag to the opposite corner. Release the mouse button and an unfilled "
"rectangle of stitches will be added to the canvas."
msgstr ""
"आयतं आकर्षयन्तु - &LMB; आयतस्य एकस्मिन् कोणे विपरीतकोणं प्रति कर्षन्तु । मूषकस्य बटनं मुक्तं "
"कुर्वन्तु ततः कैनवासस्य मध्ये अपूरितः सिलेखानां आयतः योजितः भविष्यति ।"

#. Tag: guimenuitem
#: commands.docbook:281
#, no-c-format
msgid "Fill Rectangle"
msgstr "आयत भरना"

#. Tag: action
#: commands.docbook:282
#, no-c-format
msgid ""
"Draw a filled rectangle - Press down the &LMB; at one corner of the "
"rectangle and drag to the opposite corner. Release the mouse button and a "
"filled rectangle of stitches will be added to the canvas."
msgstr ""
"पूरितं आयतं आकर्षयन्तु - &LMB; आयतस्य एकस्मिन् कोणे विपरीतकोणं प्रति कर्षन्तु । मूषकस्य बटनं "
"मुक्तं कुर्वन्तु ततः कैनवासस्य मध्ये सिलेन्थस्य पूरितः आयतः योजितः भविष्यति ।"

#. Tag: guimenuitem
#: commands.docbook:288
#, no-c-format
msgid "Draw Ellipse"
msgstr "दीर्घवृत्तम् आकर्षयतु"

#. Tag: action
#: commands.docbook:289
#, no-c-format
msgid ""
"Draw an ellipse - Press down the &LMB; at one corner of the ellipse and drag "
"to the opposite corner. Release the mouse button and an unfilled ellipse of "
"stitches will be added to the canvas."
msgstr ""
"दीर्घवृत्तं आकर्षयन्तु - &LMB; दीर्घवृत्तस्य एकस्मिन् कोणे विपरीतकोणे कर्षन्तु च। मूषकस्य बटनं "
"मुक्तं कुर्वन्तु ततः सिलेखानां अपूरितं दीर्घवृत्तं कैनवासस्य मध्ये योजितं भविष्यति ।"

#. Tag: guimenuitem
#: commands.docbook:296
#, no-c-format
msgid "Fill Ellipse"
msgstr "दीर्घवृत्तं पूरयतु"

#. Tag: action
#: commands.docbook:297
#, no-c-format
msgid ""
"Draw a filled ellipse - Press down the &LMB; at one corner of the ellipse "
"and drag to the opposite corner. Release the mouse button and a filled "
"ellipse of stitches will be added to the canvas."
msgstr ""
"पूरितं दीर्घवृत्तं आकर्षयन्तु - &LMB; दीर्घवृत्तस्य एकस्मिन् कोणे विपरीतकोणे कर्षन्तु च। मूषकस्य "
"बटनं मुक्तं कुर्वन्तु ततः सिलेखानां पूरितं दीर्घवृत्तं कैनवासस्य मध्ये योजितं भविष्यति ।"

#. Tag: guimenuitem
#: commands.docbook:303
#, no-c-format
msgid "Fill Polygon"
msgstr "बहुभुज भरना"

#. Tag: action
#: commands.docbook:304
#, no-c-format
msgid ""
"Draw a filled polygon - Click on each cell marking the vertexes of the "
"polygon, click and drag to create more complex curves. Each of the vertexes "
"are marked by a circle with a black line joining them. To close the polygon "
"click on the starting cell again. You can use the &Backspace; key to remove "
"the last point, or the &Esc; key to remove all vertexes and cancel the "
"operation."
msgstr ""
"पूरितं बहुभुजं आकर्षयन्तु - बहुभुजस्य शिखरं चिह्नितं प्रत्येकं कोष्ठकं क्लिक् कुर्वन्तु, "
"अधिकजटिलवक्राणि निर्मातुं क्लिक् कृत्वा कर्षयन्तु । प्रत्येकं शिखरं वृत्तेन चिह्नितं भवति यत्र "
"कृष्णरेखा तेषु संयोजयति । बहुभुजं पिधातुं पुनः आरम्भकोष्ठके क्लिक् कुर्वन्तु । भवान् &Backspace; "
"अन्तिमबिन्दुं निष्कासयितुं कुञ्जी, अथवा &Esc; सर्वाणि शीर्षस्थानानि निष्कासयितुं क्रियां रद्दं "
"कर्तुं च कीलम् ।"

#. Tag: guimenuitem
#: commands.docbook:312
#, no-c-format
msgid "Text"
msgstr "पाठ"

#. Tag: action
#: commands.docbook:313
#, no-c-format
msgid ""
"Insert text in stitches. This invokes the text dialog. Select the font "
"required and the size, enter the text and click <guibutton>OK</guibutton>. "
"Press the &LMB; roughly where you would like the text, move the mouse to "
"position the text accurately and then release the mouse button. This is the "
"same as the paste function."
msgstr ""
"सिलाईषु पाठं सम्मिलितं कुर्वन्तु। एतेन पाठसंवादः आह्वयते । आवश्यकं फ़ॉन्ट् आकारं च चित्वा पाठं "
"प्रविश्य <guibutton>OK</guibutton> नुदन्तु । &LMB; मोटेन यत्र भवन्तः पाठं इच्छन्ति तत्र, "
"पाठं समीचीनरूपेण स्थापयितुं मूषकं चालयन्तु ततः मूषकस्य बटनं मुञ्चन्तु । एतत् पेस्ट् फंक्शन् इत्यस्य "
"समानम् अस्ति ।"

#. Tag: guimenuitem
#: commands.docbook:320
#, no-c-format
msgid "Alphabet"
msgstr "वर्णमाला"

#. Tag: action
#: commands.docbook:321
#, no-c-format
msgid ""
"Insert patterns from the currently selected library that match the keys "
"pressed. This allows the creation of pattern alphabets that can have a key "
"assignment. After selecting this tool and clicking a position on the pattern "
"for the insertion point, each key pressed will be searched for in the "
"current library for a matching pattern. If found this will be inserted at "
"the position on the pattern and the insertion position then advanced by the "
"width of the inserted character pattern. The pattern space will be extended "
"right to allow further characters to be entered. Pressing &Enter; will start "
"a new line under the position of the original insertion point, the pattern "
"space will be extended downwards to accommodate the new line if insufficient "
"space is available. &Backspace; will delete the last character entered and "
"the <keycap>Space</keycap> key will advance the insertion point by either "
"the width of a space character in the library or a predetermined amount if "
"no space character exists. The text will wrap onto the next line if the edge "
"of the pattern is reached and the end of a word is detected."
msgstr ""
"वर्तमान चयनितपुस्तकालयात् प्रतिरूपाणि सम्मिलितं कुर्वन्तु ये निपीडितानां कीलानां सङ्गतिं "
"कुर्वन्ति । एतेन प्रतिरूपवर्णमालानिर्माणं भवति यस्य कीलनिर्देशः भवितुम् अर्हति । एतत् साधनं "
"चयनं कृत्वा निवेशबिन्दुस्य कृते प्रतिरूपे एकं स्थानं क्लिक् कृत्वा, निपीडितं प्रत्येकं कीलं "
"वर्तमानपुस्तकालये मेलप्रतिरूपस्य अन्वेषणं भविष्यति यदि लभ्यते तर्हि एतत् प्रतिरूपे स्थाने निवेशितं "
"भविष्यति तथा च निवेशस्थानं ततः प्रविष्टस्य वर्णप्रतिमानस्य विस्तारेण उन्नतं भविष्यति "
"अधिकवर्णानां प्रवेशाय प्रतिरूपस्थानं दक्षिणतः विस्तारितं भविष्यति । &Enter इति दबावन्; "
"मूलप्रवेशबिन्दुस्य स्थानस्य अधः नूतनां रेखां आरभेत, अपर्याप्तस्थानं उपलब्धं चेत् नूतनरेखायाः "
"समायोजनाय प्रतिरूपस्थानं अधः विस्तारितं भविष्यति &पृष्ठस्थान; प्रविष्टं अन्तिमं वर्णं "
"विलोपयिष्यति तथा च <keycap>Space</keycap> कीलं पुस्तकालये रिक्तस्थानवर्णस्य विस्तारेण "
"अथवा पूर्वनिर्धारितराशिना वा यदि अन्तरिक्षवर्णः नास्ति तर्हि सम्मिलनबिन्दुं अग्रे करिष्यति "
"यदि प्रतिमानस्य धारः प्राप्य शब्दस्य अन्तः ज्ञातः भवति तर्हि पाठः अग्रिमपङ्क्तौ "
"वेष्टयिष्यति ।"

#. Tag: guimenuitem
#: commands.docbook:336
#, no-c-format
msgid "Select"
msgstr "विचि"

#. Tag: action
#: commands.docbook:337
#, no-c-format
msgid ""
"Select a rectangular region - Press down the &LMB; at one corner of the "
"rectangle, drag to the opposite corner and release the button. A selection "
"rectangle is shown to indicate the area."
msgstr ""
"आयताकारप्रदेशं चिनोतु - &LMB; आयतस्य एकस्मिन् कोणे विपरीतकोणे कर्षयित्वा बटनं मुञ्चन्तु । "
"क्षेत्रं सूचयितुं चयनआयतं दर्शितं भवति ।"

#. Tag: guimenuitem
#: commands.docbook:343
#, no-c-format
msgid "Color picker"
msgstr "रङ्ग पिकर"

#. Tag: action
#: commands.docbook:344
#, no-c-format
msgid ""
"Allows the selection of a color from the existing stitches. Hovering over "
"stitches will show a tool tip indicating the color under the cursor. "
"Clicking with the &LMB; will select it."
msgstr ""
"विद्यमानसिलेखानां वर्णस्य चयनं अनुमन्यते । सिलेखानां उपरि भ्रमन् कर्सरस्य अधः वर्णं सूचयन् एकं "
"साधनाग्रं दर्शयिष्यति । &LMB; तत् चयनं करिष्यति।"

#. Tag: guimenuitem
#: commands.docbook:350
#, no-c-format
msgid "Backstitch"
msgstr "बैकस्टिच"

#. Tag: action
#: commands.docbook:351
#, no-c-format
msgid ""
"Add backstitching to the canvas - Press down the &LMB; at the start of the "
"backstitch, it will snap to the closest of 9 points in the cell, drag to the "
"end point of the backstitch and release the mouse button, again this will "
"snap to the nearest of 9 points in the cell."
msgstr ""
"कैनवास् मध्ये बैकस्टिचिंग् योजयन्तु - &LMB; backstitch इत्यस्य आरम्भे, इदं कोष्ठके ९ बिन्दुषु "
"समीपस्थं यावत् स्नैप् करिष्यति, backstitch इत्यस्य अन्त्यबिन्दुपर्यन्तं कर्षति तथा च मूषकस्य "
"बटनं मुञ्चति, पुनः एतत् कोष्ठके ९ बिन्दुषु समीपस्थं यावत् स्नैप् करिष्यति"

#. Tag: title
#: commands.docbook:362
#, no-c-format
msgid "The Palette Menu"
msgstr "The Palette Menu इति"

#. Tag: guimenuitem
#: commands.docbook:366
#, no-c-format
msgid "Palette Manager"
msgstr "पैलेट प्रबन्धक"

#. Tag: action
#: commands.docbook:367
#, no-c-format
msgid ""
"Add and remove colors to the current palette. Assign symbols and the number "
"of strands for the stitching and backstitching."
msgstr ""
"वर्तमानपैलेट् मध्ये वर्णाः योजयित्वा निष्कासयन्तु । सिलाईं पृष्ठसिलाईं च कृते चिह्नानि, "
"तारसङ्ख्यां च नियुक्तं कुर्वन्तु ।"

#. Tag: guimenuitem
#: commands.docbook:373
#, no-c-format
msgid "Show Symbols"
msgstr "प्रतीकं दर्शयतु"

#. Tag: action
#: commands.docbook:374
#, no-c-format
msgid "Show the symbols associated with each color"
msgstr "प्रत्येकं वर्णेन सह सम्बद्धानि चिह्नानि दर्शयन्तु"

#. Tag: guimenuitem
#: commands.docbook:376
#, no-c-format
msgid "Clear Unused"
msgstr "स्पष्ट अप्रयुक्त"

#. Tag: action
#: commands.docbook:377
#, no-c-format
msgid "Removes the unused colors from the palette."
msgstr "अप्रयुक्तवर्णान् पॅलेट् तः निष्कासयति ।"

#. Tag: guimenuitem
#: commands.docbook:380
#, no-c-format
msgid "Swap Colors"
msgstr "रङ्ग अदला-बदली"

#. Tag: action
#: commands.docbook:381
#, no-c-format
msgid ""
"The next color selected will be swapped with the currently selected color. "
"If you select the eye dropper tool, you can choose the color to be swapped "
"with directly from the pattern."
msgstr ""
"अग्रिमः वर्णः चयनितः वर्तमानचयनितवर्णेन सह स्वैपः भविष्यति । यदि भवान् नेत्र-बिन्दु-उपकरणं "
"चिनोति तर्हि भवान् प्रत्यक्षतया प्रतिरूपात् स्वैप-करणीयं वर्णं चिन्वितुं शक्नोति ।"

#. Tag: guimenuitem
#: commands.docbook:387
#, no-c-format
msgid "Replace Colors"
msgstr "Replace Colors इति"

#. Tag: action
#: commands.docbook:388
#, no-c-format
msgid ""
"The next color selected will replace the currently selected color. As with "
"swap colors, you can use the eye dropper tool to select the color from the "
"pattern."
msgstr ""
"अग्रिमः वर्णः चयनितः वर्तमानचयनितवर्णस्य स्थाने स्थास्यति । यथा swap colors इत्यस्य "
"विषये, भवन्तः eye dropper tool इत्यस्य उपयोगेन pattern तः color इत्यस्य चयनं कर्तुं "
"शक्नुवन्ति ।"

#. Tag: title
#: commands.docbook:398
#, no-c-format
msgid "The Library Menu"
msgstr "पुस्तकालयस्य मेनू"

#. Tag: guimenuitem
#: commands.docbook:402
#, no-c-format
msgid "Library Manager"
msgstr "पुस्तकालय प्रबन्धक"

#. Tag: action
#: commands.docbook:403
#, no-c-format
msgid ""
"Open the pattern library manager which is a non modal dialog allowing the "
"creation and use of libraries of patterns or alphabets. Drag and drop is "
"available to allow the dragging and dropping of patterns from the library to "
"the pattern. Automatic conversion of flosses to suit the current pattern and "
"scaling of the image to the current pattern scale for accurate positioning."
msgstr ""
"pattern library manager उद्घाटयन्तु यत् एकः non modal संवादः अस्ति यः patterns "
"अथवा alphabets इत्यस्य libraries इत्यस्य निर्माणं उपयोगं च अनुमन्यते । पुस्तकालयात् "
"प्रतिरूपं प्रति प्रतिमानानाम् आकर्षणं, पातनं च अनुमन्यते इति कृते drag and drop उपलभ्यते । "
"वर्तमानप्रतिरूपस्य अनुकूलतायै फ्लॉसस्य स्वचालितरूपान्तरणं तथा च समीचीनस्थापनार्थं "
"वर्तमानप्रतिमानमापने प्रतिबिम्बस्य स्केलिंग् ।"

#. Tag: title
#: commands.docbook:415
#, no-c-format
msgid "The Pattern Menu"
msgstr "The Pattern Menu इति"

#. Tag: guimenuitem
#: commands.docbook:419
#, no-c-format
msgid "Extend Pattern"
msgstr "प्रतिरूपं विस्तारयतु"

#. Tag: action
#: commands.docbook:420
#, no-c-format
msgid "Extend the pattern top, left, right and bottom"
msgstr "प्रतिमानं उपरि, वामं, दक्षिणं, अधः च विस्तारयन्तु"

#. Tag: guimenuitem
#: commands.docbook:423
#, no-c-format
msgid "Center Pattern"
msgstr "केन्द्र प्रतिरूप"

#. Tag: action
#: commands.docbook:424
#, no-c-format
msgid "Center the pattern in the canvas"
msgstr "कैनवासे प्रतिरूपं केन्द्रीकृत्य"

#. Tag: guimenuitem
#: commands.docbook:427
#, no-c-format
msgid "Crop Canvas To Pattern"
msgstr "फसल कैनवास To Pattern"

#. Tag: action
#: commands.docbook:428
#, no-c-format
msgid "Crop the canvas to the extents of the pattern"
msgstr "प्रतिरूपस्य विस्तारं यावत् कैनवासं क्रॉप कुर्वन्तु"

#. Tag: guimenuitem
#: commands.docbook:431
#, no-c-format
msgid "Crop Canvas To Selection"
msgstr "क्रॉप कैनवास To Selection"

#. Tag: action
#: commands.docbook:432
#, no-c-format
msgid "Crop the canvas to the extents of the current selection"
msgstr "वर्तमानचयनस्य विस्तारं यावत् कैनवासं क्रॉप् कुर्वन्तु"

#. Tag: guimenuitem
#: commands.docbook:435
#, no-c-format
msgid "Insert Rows"
msgstr "पङ्क्तयः सम्मिलिताः"

#. Tag: action
#: commands.docbook:436
#, no-c-format
msgid "Insert a number of rows represented by a selection area"
msgstr "चयनक्षेत्रेण प्रतिनिधितानां पङ्क्तीनां संख्यां सम्मिलितं कुर्वन्तु"

#. Tag: guimenuitem
#: commands.docbook:439
#, no-c-format
msgid "Insert Columns"
msgstr "स्तम्भान् सम्मिलितं कुर्वन्तु"

#. Tag: action
#: commands.docbook:440
#, no-c-format
msgid "Insert a number of columns represented by a selection area"
msgstr "चयनक्षेत्रेण प्रतिनिधितानां स्तम्भानां संख्यां सम्मिलितं कुर्वन्तु"

#. Tag: title
#: commands.docbook:447
#, no-c-format
msgid "The Settings Menu"
msgstr "सेटिंग्स् मेन्यू इति"

#. Tag: para
#: commands.docbook:448
#, no-c-format
msgid ""
"Apart from the common &kde; Settings menu entries described in the <ulink "
"url=\"help:/fundamentals/menus.html#menus-settings\"> Settings Menu</ulink> "
"chapter of the &kde; Fundamentals &kxstitch; has these application specific "
"menu entries:"
msgstr ""
"सामान्यं विहाय &kde; सेटिङ्ग्स् मेन्यू प्रविष्टयः &kde; मौलिकता &kxstitch; एतानि "
"अनुप्रयोगविशिष्टानि मेनूप्रविष्टयः सन्ति:"

#. Tag: guimenuitem
#: commands.docbook:454
#, no-c-format
msgid "Format Scales As"
msgstr "प्रारूप स्केल As"

#. Tag: action
#: commands.docbook:455
#, no-c-format
msgid "Change the scale display format to Stitches, CM or Inches."
msgstr "स्केल प्रदर्शनस्वरूपं Stitches, CM अथवा Inches इति परिवर्तयन्तु ।"

#. Tag: guimenuitem
#: commands.docbook:458
#, no-c-format
msgid "Render Stitches As"
msgstr "सिलाईं यथा प्रस्तुतं कुर्वन्तु"

#. Tag: action
#: commands.docbook:459
#, no-c-format
msgid "Change the way stitches are displayed."
msgstr "सिलेखानां प्रदर्शनस्य मार्गं परिवर्तयन्तु ।"

#. Tag: guimenuitem
#: commands.docbook:462
#, no-c-format
msgid "Render Backstitches As"
msgstr "Backstitches As प्रतिपादयन्तु"

#. Tag: action
#: commands.docbook:463
#, no-c-format
msgid "Change the way backstitches are displayed."
msgstr "पृष्ठसिलेखानां प्रदर्शनस्य मार्गं परिवर्तयन्तु ।"

#. Tag: guimenuitem
#: commands.docbook:466
#, no-c-format
msgid "Render Knots As"
msgstr "गांठं यथा"

#. Tag: action
#: commands.docbook:467
#, no-c-format
msgid "Change the way knots are displayed."
msgstr "ग्रन्थिप्रदर्शनस्य मार्गं परिवर्तयतु।"

#. Tag: guimenuitem
#: commands.docbook:470
#, no-c-format
msgid "Color Highlight"
msgstr "रङ्ग हाइलाइट्"

#. Tag: action
#: commands.docbook:471
#, no-c-format
msgid "Enable or disable color highlight mode"
msgstr "वर्णप्रकाशनविधिं सक्षमं वा अक्षमं वा"

#. Tag: guimenuitem
#: commands.docbook:474
#, no-c-format
msgid "Show Stitches"
msgstr "सिलाईं दर्शयतु"

#. Tag: action
#: commands.docbook:475
#, no-c-format
msgid "Show or hide the stitches"
msgstr "सिलेन्थान् दर्शयतु वा गोपयतु वा"

#. Tag: guimenuitem
#: commands.docbook:478
#, no-c-format
msgid "Show Backstitches"
msgstr "Backstiches दर्शयतु"

#. Tag: action
#: commands.docbook:479
#, no-c-format
msgid "Show or hide the backstitches"
msgstr "पृष्ठसिलेखान् दर्शयतु वा गोपयन्तु वा"

#. Tag: guimenuitem
#: commands.docbook:482
#, no-c-format
msgid "Show French Knots"
msgstr "फ्रेंच गांठं दर्शयतु"

#. Tag: action
#: commands.docbook:483
#, no-c-format
msgid "Show or hide the french knots"
msgstr "फ्रेंचग्रन्थिं दर्शयतु वा गोपयतु वा"

#. Tag: guimenuitem
#: commands.docbook:486
#, no-c-format
msgid "Show Grid"
msgstr "ग्रिड् दर्शयतु"

#. Tag: action
#: commands.docbook:487
#, no-c-format
msgid "Show or hide the grid"
msgstr "जालं दर्शयतु वा गोपयतु वा"

#. Tag: guimenuitem
#: commands.docbook:490
#, no-c-format
msgid "Show Background Images"
msgstr "पृष्ठभूमिचित्रं दर्शयतु"

#. Tag: action
#: commands.docbook:491
#, no-c-format
msgid "Show or hide all the background images"
msgstr "सर्वाणि पृष्ठभूमिचित्रं दर्शयतु वा गोपयन्तु वा"

#. Tag: guimenuitem
#: commands.docbook:494
#, no-c-format
msgid "Configure &kxstitch;"
msgstr "विन्यस्तं कुर्वन्तु &kxstitch;"

#. Tag: action
#: commands.docbook:495
#, no-c-format
msgid ""
"Open &kxstitch; <link linkend=\"ConfigurationDialog\">configuration dialog</"
"link>."
msgstr ""
"उद्घाट्य &amp;kxstitch;<link linkend=\"ConfigurationDialog\"> विन्याससंवादः</"
"link> ."

#. Tag: title
#: commands.docbook:503
#, no-c-format
msgid "The Help Menu"
msgstr "सहायता मेनू"

#. Tag: para
#: commands.docbook:504
#, no-c-format
msgid ""
"Additionally &kxstitch; has the common &kde; Help menu items, for more "
"information read the section about the <ulink url=\"help:/fundamentals/menus."
"html#menus-help\">Help Menu</ulink> of the &kde; Fundamentals."
msgstr ""
"अतिरिक्तरूपेण &kxstitch; सामान्यं &kde; सहायता मेनू-वस्तूनाम्, अधिकसूचनार्थं &kde; "
"मौलिकता।"
