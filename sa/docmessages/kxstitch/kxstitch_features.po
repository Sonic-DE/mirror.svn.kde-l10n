#. Tag: title
#: features.docbook:2
#, no-c-format
msgid "Features"
msgstr "गुणाः"

#. Tag: para
#: features.docbook:3
#, no-c-format
msgid "The current feature list and other planned features is shown here."
msgstr "वर्तमानविशेषतासूची अन्ये च योजनाकृतविशेषताः अत्र दर्शिताः सन्ति ।"

#. Tag: para
#: features.docbook:5
#, no-c-format
msgid "Creation of new patterns"
msgstr "नवीनप्रतिमानानाम् निर्माणम्"

#. Tag: para
#: features.docbook:7
#, no-c-format
msgid "User defined size"
msgstr "उपयोक्तृ परिभाषितः आकारः"

#. Tag: para
#: features.docbook:8
#, no-c-format
msgid "Selection of material color"
msgstr "सामग्रीवर्णस्य चयनम्"

#. Tag: para
#: features.docbook:9
#, no-c-format
msgid "Insertion of a background images for tracing"
msgstr "अनुसन्धानार्थं पृष्ठभूमिचित्रस्य सम्मिलनम्"

#. Tag: para
#: features.docbook:10
#, no-c-format
msgid "Importing of various image formats"
msgstr "विभिन्नप्रतिबिम्बस्वरूपानाम् आयातम्"

#. Tag: para
#: features.docbook:11
#, no-c-format
msgid "Importing options allow"
msgstr "आयातविकल्पाः अनुमन्यन्ते"

#. Tag: para
#: features.docbook:13
#, no-c-format
msgid "Limiting the number of colors"
msgstr "वर्णसङ्ख्यां सीमितं कृत्वा"

#. Tag: para
#: features.docbook:14
#, no-c-format
msgid "Limiting colors to a specific palette"
msgstr "वर्णानाम् सीमां विशिष्टपैलेट् यावत्"

#. Tag: para
#: features.docbook:15
#, no-c-format
msgid "Scaling to a finished size"
msgstr "समाप्त आकारं यावत् स्केलिंग्"

#. Tag: para
#: features.docbook:16
#, no-c-format
msgid "Support for transparency in images"
msgstr "चित्रेषु पारदर्शितायाः समर्थनम्"

#. Tag: para
#: features.docbook:17
#, no-c-format
msgid "Allow the use of fractional stitches"
msgstr "भिन्नात्मकसिलेखानां प्रयोगं अनुमन्यताम्"

#. Tag: para
#: features.docbook:22
#, no-c-format
msgid "Editing of existing patterns, Editing tools will include"
msgstr "विद्यमानप्रतिमानानाम् सम्पादनं, सम्पादनसाधनानाम् अन्तर्भवति"

#. Tag: para
#: features.docbook:24
#, no-c-format
msgid "Open and filled rectangles"
msgstr "उद्घाटितानि आयतानि च पूरितानि च"

#. Tag: para
#: features.docbook:25
#, no-c-format
msgid "Open and filled ellipses"
msgstr "उद्घाटितं पूरितं च दीर्घवृत्तम्"

#. Tag: para
#: features.docbook:26
#, no-c-format
msgid "Filled polygons"
msgstr "पूरित बहुभुज"

#. Tag: para
#: features.docbook:27
#, no-c-format
msgid "Painting"
msgstr "चित्रकारी"

#. Tag: para
#: features.docbook:28
#, no-c-format
msgid "Lines"
msgstr "रेखाः"

#. Tag: para
#: features.docbook:29
#, no-c-format
msgid "Erasing stitches, knots and backstitches"
msgstr "सिलेन्थं, ग्रन्थिं, पृष्ठसिलेनं च मेटयन्"

#. Tag: para
#: features.docbook:30
#, no-c-format
msgid "Color selection from existing stitches"
msgstr "विद्यमानसिलाईभ्यः वर्णचयनम्"

#. Tag: para
#: features.docbook:31
#, no-c-format
msgid "Swapping two colors"
msgstr "द्वयोः वर्णयोः अदला-बदली"

#. Tag: para
#: features.docbook:32
#, no-c-format
msgid "Replace one color with another"
msgstr "एकं वर्णं अन्येन वर्णेन प्रतिस्थापयन्तु"

#. Tag: para
#: features.docbook:33
#, no-c-format
msgid "Text with user defined fonts and sizes"
msgstr "उपयोक्तृनिर्धारित-अङ्कैः आकारैः च सह पाठः"

#. Tag: para
#: features.docbook:34
#, no-c-format
msgid "Cut, copy and paste of rectangular areas."
msgstr "आयताकारक्षेत्राणां कटनं, प्रतिलिपिं, पेस्ट् च कुर्वन्तु।"

#. Tag: para
#: features.docbook:35
#, no-c-format
msgid "Unlimited undo and redo"
msgstr "असीमित पूर्ववतीकरणं पुनः करणं च"

#. Tag: para
#: features.docbook:36
#, no-c-format
msgid "Mirroring, horizontally and vertically."
msgstr "दर्पणं, क्षैतिजं लम्बवत् च।"

#. Tag: para
#: features.docbook:37
#, no-c-format
msgid "Rotation, 90, 180 and 270 degrees anti clockwise."
msgstr "परिभ्रमणम्, ९०, १८० तथा २७० डिग्री घण्टायाः विपरीतम् ।"

#. Tag: para
#: features.docbook:38
#, no-c-format
msgid "Resizing of the canvas"
msgstr "कैनवासस्य आकारं परिवर्तयति"

#. Tag: para
#: features.docbook:40
#, no-c-format
msgid "Extend canvas left, top, right, bottom"
msgstr "कैनवासं वाम, उपरि, दक्षिणं, अधः विस्तारयन्तु"

#. Tag: para
#: features.docbook:41
#, no-c-format
msgid "Cropping canvas to pattern"
msgstr "कैनवासं प्रतिरूपं प्रति क्रॉपिंग"

#. Tag: para
#: features.docbook:42
#, no-c-format
msgid "Cropping canvas to selection"
msgstr "चयनं प्रति कैनवासं क्रॉपिंग"

#. Tag: para
#: features.docbook:43
#, no-c-format
msgid "Inserting rows and columns"
msgstr "पङ्क्तयः स्तम्भान् च निवेशयन्"

#. Tag: para
#: features.docbook:44
#, no-c-format
msgid "Center the pattern on the canvas"
msgstr "कैनवासस्य उपरि प्रतिमानं केन्द्रीकृत्य"

#. Tag: para
#: features.docbook:47
#, no-c-format
msgid "Conversion between floss schemes"
msgstr "फ्लॉस योजनानां मध्ये परिवर्तनम्"

#. Tag: para
#: features.docbook:50
#, no-c-format
msgid "Use of standard floss pallets, DMC, Anchor, etc."
msgstr "मानक फ्लॉस पैलेट्, डीएमसी, एंकर इत्यादीनां उपयोगः।"

#. Tag: para
#: features.docbook:51
#, no-c-format
msgid "Create customized floss pallets"
msgstr "अनुकूलितं फ्लॉस् पैलेट् रचयन्तु"

#. Tag: para
#: features.docbook:52
#, no-c-format
msgid "Create new colors for any floss pallet"
msgstr "कस्यापि फ्लॉस्-पैलेट्-कृते नूतनानि वर्णाः रचयन्तु"

#. Tag: para
#: features.docbook:53
#, no-c-format
msgid "Save / Load current palette"
msgstr "वर्तमान पैलेटं रक्षतु / लोडं कुर्वन्तु"

#. Tag: para
#: features.docbook:54
#, no-c-format
msgid "Use of standard stitches"
msgstr "मानकसिलाईनां प्रयोगः"

#. Tag: para
#: features.docbook:55
#, no-c-format
msgid "Pattern library manager"
msgstr "पैटर्न पुस्तकालय प्रबन्धक"

#. Tag: para
#: features.docbook:57
#, no-c-format
msgid "Create new library patterns"
msgstr "नूतनानि पुस्तकालयप्रतिमानं रचयन्तु"

#. Tag: para
#: features.docbook:58
#, no-c-format
msgid "Insert library patterns into a design"
msgstr "पुस्तकालयस्य प्रतिमानं डिजाइनमध्ये सम्मिलितं कुर्वन्तु"

#. Tag: para
#: features.docbook:59
#, no-c-format
msgid "Drag and drop from the library to the pattern"
msgstr "पुस्तकालयात् प्रतिरूपं प्रति कर्षयन्तु, पातयन्तु च"

#. Tag: para
#: features.docbook:60
#, no-c-format
msgid "Drag and drop from one library to another"
msgstr "एकस्मात् पुस्तकालयात् अन्यतमं पुस्तकालयं प्रति कर्षयन्तु, पातयन्तु च"

#. Tag: para
#: features.docbook:61
#, no-c-format
msgid "Assign key press to patterns for use with the Alphabet tool"
msgstr "Alphabet tool इत्यनेन सह उपयोगाय patterns कृते कील-प्रेस् नियुक्तं कुर्वन्तु"

#. Tag: para
#: features.docbook:64
#, no-c-format
msgid "Free use of backstitching"
msgstr "बैकस्टिचिंग् इत्यस्य निःशुल्कः उपयोगः"

#. Tag: para
#: features.docbook:65
#, no-c-format
msgid "Printing of completed patterns and floss keys"
msgstr "सम्पन्नप्रतिमानानाम्, फ्लॉसकीलानां च मुद्रणम्"

#. Tag: para
#: features.docbook:67
#, no-c-format
msgid "Pattern image"
msgstr "पैटर्न इमेज"

#. Tag: para
#: features.docbook:68
#, no-c-format
msgid "Instructions"
msgstr "निर्देशाः"

#. Tag: para
#: features.docbook:69
#, no-c-format
msgid "Floss key and stitch summary"
msgstr "फ्लॉस कुञ्जी तथा सिलाई सारांश"

#. Tag: para
#: features.docbook:70
#, no-c-format
msgid "Pattern chart with page map"
msgstr "पृष्ठस्य मानचित्रेण सह पैटर्न् चार्टः"

#. Tag: para
#: features.docbook:71
#, no-c-format
msgid "Text boxes"
msgstr "पाठपेटिकाः"

#. Tag: para
#: features.docbook:74
#, no-c-format
msgid "Mapping of symbols to flosses"
msgstr "प्रतीकानाम् फ्लोस् प्रति मानचित्रणम्"

#. Tag: para
#: features.docbook:75
#, no-c-format
msgid "Specify the number of threads for stitches and backstitches"
msgstr "सिलेखानां पृष्ठसिलेखानां च सूत्राणां संख्यां निर्दिशन्तु"

#. Tag: para
#: features.docbook:76
#, no-c-format
msgid "Calibration of floss colors"
msgstr "फ्लॉसरङ्गानाम् मापनम्"

#. Tag: para
#: features.docbook:78
#, no-c-format
msgid ""
"Requests for new features can be made to the <ulink url=\"http://bugs.kde.org"
"\">KDE Bugtracking System</ulink>"
msgstr ""
"नूतनविशेषतानां अनुरोधाः <ulink url=\"http://bugs.kde.org\">KDE Bugtracking "
"System</ulink> इत्यत्र कर्तुं शक्यन्ते"
