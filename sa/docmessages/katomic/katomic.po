"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>O</keycap></keycombo> </"
"shortcut> <guimenu>Game</guimenu> <guimenuitem>Load…</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>O</keycap></keycombo> </"
"shortcut> <guimenu>खेल</guimenu> <guimenuitem>भार…</guimenuitem>"

#. Tag: para
#: index.docbook:113
#, no-c-format
msgid "Loads a previously saved game."
msgstr "पूर्वं रक्षितं क्रीडां लोड् करोति ।"

#. Tag: menuchoice
#: index.docbook:116
#, no-c-format
msgid ""
"<shortcut><keycap>F5</keycap></shortcut> <guimenu>Game</guimenu> "
"<guimenuitem>Restart Game</guimenuitem>"
msgstr ""
"<shortcut><keycap>F5</keycap></shortcut> <guimenu>क्रीडा</guimenu> "
"<guimenuitem>खेलं पुनः आरभत</guimenuitem>"

#. Tag: para
#: index.docbook:119
#, no-c-format
msgid "This will restart the current level."
msgstr "एतेन वर्तमानस्तरः पुनः आरभ्यते ।"

#. Tag: menuchoice
#: index.docbook:122
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>S</keycap></keycombo> </"
"shortcut> <guimenu>Game</guimenu> <guimenuitem>Save</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>S</keycap></keycombo> </"
"shortcut> <guimenu>खेल</guimenu> <guimenuitem>रक्षतु</guimenuitem>"

#. Tag: para
#: index.docbook:125
#, no-c-format
msgid "Saves the current state of the game to the disk."
msgstr "क्रीडायाः वर्तमानस्थितिं डिस्कमध्ये रक्षति ।"

#. Tag: menuchoice
#: index.docbook:128
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>P</keycap></keycombo> </"
"shortcut> <guimenu>Game</guimenu> <guimenuitem>Previous Level</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>P</keycap></keycombo> </"
"shortcut> <guimenu>खेल</guimenu> <guimenuitem>पूर्वस्तर</guimenuitem>"

#. Tag: para
#: index.docbook:131
#, no-c-format
msgid "Change to the previous game level."
msgstr "पूर्वक्रीडास्तरं प्रति परिवर्तनं कुर्वन्तु।"

#. Tag: menuchoice
#: index.docbook:134
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>N</keycap></keycombo> </"
"shortcut> <guimenu>Game</guimenu> <guimenuitem>Next Level</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>N</keycap></keycombo> </"
"shortcut> <guimenu>खेल</guimenu> <guimenuitem>अग्रे स्तरः</guimenuitem>"

#. Tag: para
#: index.docbook:137
#, no-c-format
msgid "Change to the next game level."
msgstr "अग्रिमक्रीडास्तरं प्रति परिवर्तनं कुर्वन्तु।"

#. Tag: menuchoice
#: index.docbook:140
#, no-c-format
msgid "<guimenu>Game</guimenu> <guimenuitem>Choose Level Set…</guimenuitem>"
msgstr "<guimenu>क्रीडा</guimenu> <guimenuitem>स्तरसेट्…</guimenuitem> इति चिनोतु"

#. Tag: para
#: index.docbook:142
#, no-c-format
msgid ""
"This will show all available level sets and allows you to download "
"additional sets uploaded by other users from the internet."
msgstr ""
"एतेन सर्वाणि उपलब्धानि स्तरसमूहानि दर्शयिष्यन्ति तथा च अन्यैः उपयोक्तृभिः अपलोड् कृतानि "
"अतिरिक्तसमूहानि अन्तर्जालतः डाउनलोड् कर्तुं शक्नुवन्ति ।"

#. Tag: menuchoice
#: index.docbook:146
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>Q</keycap></keycombo> </"
"shortcut> <guimenu>Game</guimenu> <guimenuitem>Quit</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>प्रश्न</keycap></keycombo> "
"</shortcut> <guimenu>खेल</guimenu> <guimenuitem>निवृत्तं</guimenuitem>"

#. Tag: para
#: index.docbook:149
#, no-c-format
msgid "Selecting this item will end your current game, and exit &katomic;."
msgstr "एतत् द्रव्यं चित्वा भवतः वर्तमानक्रीडा समाप्तं भविष्यति, &katomic;."

#. Tag: menuchoice
#: index.docbook:153
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>Z</keycap></keycombo> </"
"shortcut> <guimenu>Move</guimenu> <guimenuitem>Undo</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>Z</keycap></keycombo> </"
"shortcut> <guimenu>चल</guimenu> <guimenuitem>पूर्ववर्ती</guimenuitem>"

#. Tag: action
#: index.docbook:156
#, no-c-format
msgid "Undo the last move you made."
msgstr "भवता कृतं अन्तिमं चालनं पूर्ववत् कुरुत।"

#. Tag: menuchoice
#: index.docbook:159
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;&Shift;<keycap>Z</keycap></"
"keycombo> </shortcut> <guimenu>Move</guimenu> <guimenuitem>Redo</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;&Shift;<keycap>Z</keycap></"
"keycombo> </shortcut> <guimenu>चल</guimenu> <guimenuitem>पुनः कुरुत</"
"guimenuitem>"

#. Tag: action
#: index.docbook:162
#, no-c-format
msgid "If you have previously undone a move, you can redo it here."
msgstr "यदि भवता पूर्वं चालनं अकृतं तर्हि अत्र पुनः कर्तुं शक्यते ।"

#. Tag: menuchoice
#: index.docbook:165
#, no-c-format
msgid "<guimenu>Move</guimenu> <guimenuitem>Undo All</guimenuitem>"
msgstr "<guimenu>चल</guimenu> <guimenuitem>सर्वं पूर्ववत</guimenuitem>"

#. Tag: para
#: index.docbook:167
#, no-c-format
msgid "<action>Undo</action> all moves you made."
msgstr "<action>Undo</action> भवता कृतानि सर्वाणि चालनानि ।"

#. Tag: menuchoice
#: index.docbook:170
