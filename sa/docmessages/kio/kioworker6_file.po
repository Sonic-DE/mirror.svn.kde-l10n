msgid "ROLES_OF_TRANSLATORS"
msgstr "अनुवादकानां_भूमिका"

#. Tag: para
#: index.docbook:17
#, no-c-format
msgid ""
"The <emphasis>file</emphasis> protocol is used by all &kde; applications to "
"display locally available files."
msgstr ""
"<emphasis>file</emphasis> प्रोटोकॉल सर्वैः &kde; स्थानीयतया उपलब्धानि सञ्चिकानि "
"प्रदर्शयितुं अनुप्रयोगाः ।"

#. Tag: para
#: index.docbook:21
#, no-c-format
msgid ""
"Entering <userinput><command>file:/directoryname</command></userinput> in "
"&konqueror; lists the files of this folder."
msgstr "&konqueror; अस्य पुटस्य सञ्चिकाः सूचीकृत्य स्थापयति ।"
