#, no-c-format
msgid "&Ferdinand.Gassauer; &Ferdinand.Gassauer.mail;"
msgstr "&फर्डिनेण्ड्.गस्साउर; &फर्डिनेण्ड्.गसाउर.मेल;"

#. Tag: trans_comment
#: index.docbook:13
