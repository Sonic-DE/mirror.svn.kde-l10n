#. Tag: title
#: index.docbook:470
#, no-c-format
msgid "<title>Background options</title>"
msgstr "<title>पृष्ठभूमिविकल्पाः</title>"

#. Tag: para
#: index.docbook:471
#, no-c-format
msgid ""
"You can choose a background graphic for the game. There are three kinds of "
"background type you can use."
msgstr ""
"क्रीडायाः कृते पृष्ठभूमिचित्रं चिन्वितुं शक्नुवन्ति । पृष्ठभूमिप्रकारः त्रिविधः अस्ति यस्य उपयोगं "
"भवन्तः कर्तुं शक्नुवन्ति ।"

#. Tag: guilabel
#: index.docbook:475
#, no-c-format
msgid "Theme"
msgstr "विषयवस्तु"

#. Tag: para
#: index.docbook:476
#, no-c-format
msgid "Use the background shipped with the current theme."
msgstr "वर्तमानविषयेण सह निर्यातितस्य पृष्ठभूमिस्य उपयोगं कुर्वन्तु ।"

#. Tag: guilabel
#: index.docbook:479
#, no-c-format
msgid "Color"
msgstr "वर्ण"

#. Tag: para
#: index.docbook:480
#, no-c-format
msgid "Use a custom solid color for the background."
msgstr "पृष्ठभूमि कृते इष्टं ठोसवर्णं उपयुज्यताम् ।"

#. Tag: guilabel
