msgstr "<guimenu>खेलः</guimenu> <guimenuitem>नवीनसंख्यायुक्तः क्रीडा…</guimenuitem>"

#. Tag: action
#: index.docbook:267
#, no-c-format
msgid "Starts a specifically numbered game."
msgstr "विशेषरूपेण संख्यायुक्तं क्रीडां आरभते।"

#. Tag: screeninfo
#: index.docbook:269
#, no-c-format
msgid "<screeninfo>Start a Numbered Game Dialog</screeninfo>"
msgstr "<screeninfo>सङ्ख्यायुक्तं क्रीडासंवादं आरभत</screeninfo>"

#. Tag: phrase
#: index.docbook:272
#, no-c-format
msgid "<phrase>Start a Numbered Game Dialog</phrase>"
msgstr "<phrase>सङ्ख्यायुक्तं क्रीडासंवादं आरभत</phrase>"

#. Tag: term
#: index.docbook:279
#, no-c-format
msgid ""
"<menuchoice> <shortcut><keycombo action=\"simul\">&Ctrl;<keycap>S</keycap></"
"keycombo></shortcut> <guimenu>Game</guimenu> <guimenuitem>Save</guimenuitem> "
"</menuchoice> (not in KSame mode)"
msgstr ""
"<menuchoice> <shortcut><keycombo action=\"simul\">&Ctrl;<keycap>S</keycap></"
"keycombo></shortcut> <guimenu>खेल</guimenu> <guimenuitem>रक्षतु</guimenuitem> "
"</ menuchoice> (KSame मोड् मध्ये न)"

#. Tag: para
#: index.docbook:284
#, no-c-format
msgid "Saves the current state of the game to the disk."
msgstr "क्रीडायाः वर्तमानस्थितिं डिस्कमध्ये रक्षति ।"

#. Tag: menuchoice
#: index.docbook:288
#, no-c-format
msgid ""
"<shortcut><keycap>P</keycap></shortcut> <guimenu>Game</guimenu> "
"<guimenuitem>Pause</guimenuitem>"
msgstr ""
"<shortcut><keycap>P</keycap></shortcut> <guimenu>खेल</guimenu> "
"<guimenuitem>विरामं कुरुत</guimenuitem>"

#. Tag: action
#: index.docbook:293
#, no-c-format
msgid ""
"Pauses or resumes the game. While the game is paused, all tiles are hidden."
msgstr ""
"क्रीडां विरामयति पुनः आरभते वा। क्रीडां विरामं कृत्वा सर्वाणि टाइल्स् निगूढानि सन्ति ।"

#. Tag: menuchoice
#: index.docbook:297
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>H</keycap></keycombo></"
"shortcut> <guimenu>Game</guimenu> <guimenuitem>Show High Scores</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>H</keycap></keycombo></"
"shortcut> <guimenu>खेल</guimenu> <guimenuitem>उच्चाङ्कान् दर्शयतु</guimenuitem>"

#. Tag: action
#: index.docbook:302
#, no-c-format
msgid "Shows the high score list."
msgstr "उच्चाङ्कसूचीं दर्शयति ।"

#. Tag: screeninfo
#: index.docbook:304
#, no-c-format
msgid "<screeninfo>Show High scores</screeninfo>"
msgstr "<screeninfo>उच्चाङ्कान् दर्शयतु</screeninfo>"

#. Tag: phrase
#: index.docbook:307
#, no-c-format
msgid "<phrase>Show High scores</phrase>"
msgstr "<phrase>उच्चाङ्कान् दर्शयतु</phrase>"

#. Tag: para
#: index.docbook:311
#, no-c-format
msgid ""
"When your game scores exceed the top ten scores listed, you are prompted to "
"enter your name."
msgstr ""
"यदा भवतः क्रीडा-अङ्काः सूचीकृतानां शीर्षदश-अङ्कानां अतिक्रमणं कुर्वन्ति तदा भवन्तः स्वनाम "
"प्रविष्टुं प्रेरिताः भवन्ति ।"

#. Tag: menuchoice
#: index.docbook:317
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>Q</keycap></keycombo></"
"shortcut> <guimenu>Game</guimenu> <guimenuitem>Quit</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>प्रश्न</keycap></keycombo></"
"shortcut> <guimenu>खेल</guimenu> <guimenuitem>निवृत्तं</guimenuitem>"

#. Tag: para
#: index.docbook:322
#, no-c-format
msgid "Selecting this item will end your current game, and exit &klickety;."
msgstr "एतत् द्रव्यं चित्वा भवतः वर्तमानक्रीडा समाप्तं भविष्यति, &klickety;."

#. Tag: menuchoice
#: index.docbook:326
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>Z</keycap></keycombo></"
"shortcut> <guimenu>Move</guimenu> <guimenuitem>Undo</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>Z</keycap></keycombo></"
"shortcut> <guimenu>चल</guimenu> <guimenuitem>पूर्ववर्ती</guimenuitem>"

#. Tag: action
#: index.docbook:331
#, no-c-format
msgid "Undo the last move you made."
msgstr "भवता कृतं अन्तिमं चालनं पूर्ववत् कुरुत।"

#. Tag: menuchoice
#: index.docbook:335
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;&Shift;<keycap>Z</keycap></"
"keycombo></shortcut> <guimenu>Move</guimenu> <guimenuitem>Redo</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;&Shift;<keycap>Z</keycap></"
"keycombo></shortcut> <guimenu>चल</guimenu> <guimenuitem>पुनः कुरुत</guimenuitem>"

#. Tag: action
#: index.docbook:340
#, no-c-format
msgid "If you have previously undone a move, you can redo it here."
msgstr "यदि भवता पूर्वं चालनं अकृतं तर्हि अत्र पुनः कर्तुं शक्यते ।"

#. Tag: menuchoice
#: index.docbook:344
#, no-c-format
msgid "<guimenu>Move</guimenu> <guimenuitem>Undo All</guimenuitem>"
msgstr "<guimenu>चल</guimenu> <guimenuitem>सर्वं पूर्ववत</guimenuitem>"

#. Tag: para
#: index.docbook:348
#, no-c-format
msgid "<action>Undo</action> all moves you made."
msgstr "<action>Undo</action> भवता कृतानि सर्वाणि चालनानि ।"

#. Tag: menuchoice
#: index.docbook:352
#, no-c-format
msgid "<guimenu>Move</guimenu> <guimenuitem>Redo All</guimenuitem>"
msgstr "<guimenu>चल</guimenu> <guimenuitem>सर्वं पुनः कुरुत</guimenuitem>"

#. Tag: para
#: index.docbook:356
#, no-c-format
msgid "<action>Redo</action> all undone moves."
msgstr "<action>पुनः कुरुत</action> सर्वाणि अकृतानि चालनानि।"

#. Tag: menuchoice
#: index.docbook:360
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guisubmenu>Difficulty</guisubmenu>"
msgstr "<guimenu>सेटिंग्स्</guimenu> <guisubmenu>कठिनता</guisubmenu>"

#. Tag: para
#: index.docbook:365
#, no-c-format
msgid "Lets you set the difficulty level from a sub-menu."
msgstr "उपमेनूतः कठिनतास्तरं सेट् कर्तुं शक्नोति ।"

#. Tag: para
#: index.docbook:366
#, no-c-format
msgid "There are four levels of difficulty:"
msgstr "कठिनतायाः चत्वारः स्तराः सन्ति-"

#. Tag: para
#: index.docbook:368
#, no-c-format
msgid ""
"<guimenuitem>Very easy</guimenuitem>: 16 rows, 10 columns, 3 types of pieces."
msgstr ""
"<guimenuitem>अतिसुलभम्</guimenuitem>: १६ पङ्क्तयः, १० स्तम्भाः, ३ प्रकाराः खण्डाः ।"

#. Tag: para
#: index.docbook:369
#, no-c-format
msgid ""
"<guimenuitem>Easy</guimenuitem>: 16 rows, 10 columns, 4 types of pieces."
msgstr ""
"<guimenuitem>सुलभ</guimenuitem>: १६ पङ्क्तयः, १० स्तम्भाः, ४ प्रकाराः खण्डाः ।"

#. Tag: para
#: index.docbook:370
#, no-c-format
msgid ""
"<guimenuitem>Medium</guimenuitem>: 16 rows, 10 columns, 5 types of pieces."
msgstr ""
"<guimenuitem>मध्यम</guimenuitem>: १६ पङ्क्तयः, १० स्तम्भाः, ५ प्रकाराः खण्डाः ।"

#. Tag: para
#: index.docbook:371
#, no-c-format
msgid ""
"<guimenuitem>Hard</guimenuitem>: 16 rows, 10 columns, 6 types of pieces."
msgstr ""
"<guimenuitem>कठिन</guimenuitem>: १६ पङ्क्तयः, १० स्तम्भाः, ६ प्रकाराः खण्डाः ।"

#. Tag: para
#: index.docbook:374
#, no-c-format
msgid "There is also a <guimenuitem>Custom</guimenuitem> level settings."
msgstr "<guimenuitem>Custom</guimenuitem> स्तरस्य सेटिङ्ग्स् अपि अस्ति ।"

#. Tag: para
#: index.docbook:375
#, no-c-format
msgid ""
"If you select <guimenuitem>Custom</guimenuitem>, then the settings you have "
"configured in the <guimenuitem>Configure - &klickety;</guimenuitem> dialog "
"will be used."
msgstr ""
"यदि भवान् <guimenuitem>Custom</guimenuitem> इति चिनोति तर्हि "
"<guimenuitem>Configure - &klickety;</guimenuitem> संवादे भवता विन्यस्तानि सेटिङ्ग्स् "
"उपयुज्यन्ते ।"

#. Tag: para
#: index.docbook:382
#, no-c-format
msgid ""
"Additionally &klickety; has the common &kde; <guimenu>Settings</guimenu> and "
"<guimenu>Help</guimenu> menu items, for more information read the sections "
"about the <ulink url=\"help:/fundamentals/menus.html#menus-settings"
"\">Settings Menu</ulink> and <ulink url=\"help:/fundamentals/menus."
"html#menus-help\">Help Menu</ulink> of the &kde; Fundamentals."
msgstr ""
"अतिरिक्तरूपेण &klickety; सामान्यं &kde; <guimenu>सेटिंग्स्</guimenu> तथा "
"<guimenu>सहायता</guimenu> मेनू-वस्तूनाम्, अधिकसूचनार्थं <ulink url=\"help:/"
"fundamentals/menus.html#menus-settings\">सेटिंग्स् मेन्यू< इत्यस्य विषये विभागान् पठन्तु /"
"ulink> तथा च &kde; मौलिकता।"

#. Tag: title
#: index.docbook:393
#, no-c-format
msgid "Frequently asked questions"
msgstr "बहुधा पृष्टाः प्रश्नाः"

#. Tag: para
#: index.docbook:399
#, no-c-format
msgid "I want to change the way this game looks. Can I?"
msgstr "अहम् अस्य क्रीडायाः स्वरूपं परिवर्तयितुम् इच्छामि। अहं शक्नोमि ?"

#. Tag: para
#: index.docbook:400
#, no-c-format
msgid ""
"Yes. To change the way &klickety; looks use the menubar to open the <link "
"linkend=\"configuration\">configuration utility</link>."
msgstr ""
"आम्‌। मार्गं परिवर्तयितुं &amp;klickety; looks इत्यस्य उद्घाटनार्थं मेनूबारस्य उपयोगं "
"करोति<link linkend=\"configuration\"> विन्यास उपयोगिता</link> ."

#. Tag: para
#: index.docbook:403
#, no-c-format
msgid "Can I use the keyboard to play the game?"
msgstr "क्रीडां कर्तुं कीबोर्डस्य उपयोगं कर्तुं शक्नोमि वा?"

#. Tag: para
#: index.docbook:404
#, no-c-format
msgid "No. This game does not feature a keyboard play mode yet."
msgstr "न अस्मिन् क्रीडने अद्यापि कीबोर्डप्ले मोड् नास्ति ।"

#. Tag: para
#: index.docbook:407
#, no-c-format
msgid "How to start the game in KSame mode?"
msgstr "KSame मोड् मध्ये क्रीडां कथं आरभ्यते?"

#. Tag: para
#: index.docbook:408
#, no-c-format
msgid ""
"You can launch &klickety; with command <userinput>klickety --KSameMode</"
"userinput> or &ksame; menu entry in K menu."
msgstr ""
"भवान् &klickety; <userinput>klickety --KSameMode</userinput> इति आदेशेन सह अथवा "
"&ksame; K मेन्यू मध्ये मेनू प्रविष्टिः ।"

#. Tag: title
#: index.docbook:415
#, no-c-format
msgid "Game Configuration"
msgstr "खेल विन्यास"

#. Tag: para
#: index.docbook:417
#, no-c-format
msgid ""
"<menuchoice><guimenu>Settings</guimenu><guimenuitem>Configure &klickety;…</"
"guimenuitem></menuchoice> opens the <guilabel>Configure - &klickety;</"
"guilabel> dialog."
msgstr ""
"<menuchoice><guimenu>सेटिंग्स्</guimenu><guimenuitem>&klickety;… विन्यस्तुं</"
"guimenuitem></menuchoice> <guilabel>विन्यस्तं - &klickety;</guilabel> संवादं "
"उद्घाटयति ।"

#. Tag: title
#: index.docbook:422
#, no-c-format
msgid "<title>General options</title>"
msgstr "<title>सामान्यविकल्पाः</title>"

#. Tag: guilabel
#: index.docbook:425
#, no-c-format
msgid "Show bound lines"
msgstr "बद्धरेखाः दर्शयतु"

#. Tag: para
#: index.docbook:426
#, no-c-format
msgid "This option will show bound lines between pieces with different color."
msgstr "एषः विकल्पः भिन्नवर्णयुक्तानां खण्डानां मध्ये बद्धरेखाः दर्शयिष्यति ।"

#. Tag: guilabel
#: index.docbook:431
#, no-c-format
msgid "Enable animation"
msgstr "एनिमेशनं सक्षमं कुर्वन्तु"

#. Tag: para
#: index.docbook:432
#, no-c-format
msgid ""
"This option will enable the falling and merging animation when pieces are "
"removed."
msgstr ""
"एषः विकल्पः यदा खण्डाः निष्कासिताः भवन्ति तदा पतनं विलयं च एनिमेशनं सक्षमं करिष्यति ।"

#. Tag: guilabel
#: index.docbook:437
#, no-c-format
msgid "Enable highlight"
msgstr "हाइलाइट् सक्षमं कुर्वन्तु"

#. Tag: para
#: index.docbook:438
#, no-c-format
msgid ""
"This option will enable highlighting on pieces hovered if they can be "
"removed."
msgstr ""
"एषः विकल्पः भ्रमितानां खण्डानां उपरि प्रकाशनं सक्षमं करिष्यति यदि ते निष्कासयितुं शक्यन्ते ।"

