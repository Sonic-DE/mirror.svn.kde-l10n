#, no-c-format
msgid "<firstname>Benjamin</firstname><surname>Meyer</surname>"
msgstr "<firstname>बेन्जामिन</firstname><surname>मेयर</surname> इति"

#. Tag: trans_comment
#: index.docbook:14
#, no-c-format
msgid "ROLES_OF_TRANSLATORS"
msgstr "अनुवादकानां_भूमिका"

#. Tag: date
#: index.docbook:17
#, no-c-format
