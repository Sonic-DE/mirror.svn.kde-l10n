msgid "<link linkend=\"image-set-as-image\">Set as Image (Crop)</link>"
msgstr "<link linkend=\"image-set-as-image\">इमेज (Crop) इति सेट् कुर्वन्तु ।</link>"

#. Tag: link
#: index.docbook:1096
#, no-c-format
