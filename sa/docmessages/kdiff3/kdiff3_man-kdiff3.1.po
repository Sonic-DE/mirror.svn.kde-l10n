#. Tag: title
#: man-kdiff3.1.docbook:8
#, no-c-format
msgid "KDiff3 User's Manual"
msgstr "KDiff3 उपयोक्तृपुस्तिका"

#. Tag: author
#: man-kdiff3.1.docbook:9
#, no-c-format
msgid ""
"<firstname>Burkhard</firstname><surname>Lueck</surname> <contrib>KDiff3 man "
"page.</contrib> &Burkhard.Lueck.mail;"
msgstr ""
"<firstname>बुर्खार्ड</firstname><surname>लुएक्</surname> <contrib>KDiff3 man page."
"</contrib> &Burkhard.Lueck.mail;"

#. Tag: date
#: man-kdiff3.1.docbook:13
#, no-c-format
msgid "2019-02-22"
msgstr "२०१९-०२-२२"

#. Tag: releaseinfo
#: man-kdiff3.1.docbook:14
#, no-c-format
msgid "kdiff3 1.8"
msgstr "kdiff3 1.8"

#. Tag: manvolnum
#: man-kdiff3.1.docbook:19
#, no-c-format
msgid "<manvolnum>1</manvolnum>"
msgstr "<मन्वोल्नुम्>१</मन्वोल्नुम्>"

#. Tag: refpurpose
#: man-kdiff3.1.docbook:24
#, no-c-format
msgid "Tool for Comparison and Merge of Files and Folders"
msgstr "सञ्चिकानां पुटकानां च तुलनां विलयनं च कर्तुं साधनम्"

#. Tag: cmdsynopsis
#: man-kdiff3.1.docbook:28
#, no-c-format
msgid ""
"<command>kdiff3</command> <arg choice=\"opt\"><option>-u, --ignore</option></"
"arg> <arg choice=\"opt\"><option>--query</option></arg> <arg choice=\"opt"
"\"><option>--html</option></arg> <arg choice=\"opt\"><option>--abort</"
"option></arg> <arg choice=\"opt\"><option>-m, --merge</option></arg> <arg "
"choice=\"opt\"><option>-b, --base</option> <replaceable>file</replaceable></"
"arg> <arg choice=\"opt\"><option>-o, --output</option> <replaceable>file</"
"replaceable></arg> <arg choice=\"opt\"><option>--out</option> "
"<replaceable>file</replaceable></arg> <arg choice=\"opt\"><option>--noauto</"
"option></arg> <arg choice=\"opt\"><option>--auto</option></arg> <arg choice="
"\"opt\"><option>--L1</option> <replaceable>alias1</replaceable></arg> <arg "
"choice=\"opt\"><option>--L2</option> <replaceable>alias2</replaceable></arg> "
"<arg choice=\"opt\"><option>--L3</option> <replaceable>alias3</replaceable></"
"arg> <arg choice=\"opt\"><option>-L, --fname</option> <replaceable>alias</"
"replaceable></arg> <arg choice=\"opt\"><option>--cs</option> "
"<replaceable>string</replaceable></arg> <arg choice=\"opt\"><option>--"
"confighelp</option></arg> <arg choice=\"opt\"><option>--config</option> "
"<replaceable>file</replaceable></arg> <arg choice=\"opt"
"\"><option><replaceable>File1</replaceable></option></arg> <arg choice=\"opt"
"\"><option><replaceable>File2</replaceable></option></arg> <arg choice=\"opt"
"\"><option><replaceable>File3</replaceable></option></arg>"
msgstr ""
"<command>kdiff3</command><arg choice=\"opt\"><option value=\"-u, --ignore\"> "
"-उ, --उपेक्षया</option></arg><arg choice=\"opt\"><option value=--query> --"
"उत्प्रेक्षा</option></arg><arg choice=\"opt\"><option value=--html> --html</"
"option></arg><arg choice=\"opt\"><option value=--abort> --गर्भपातम्</option></"
"arg><arg choice=\"opt\"><option value=\"-m, --merge\"> -म, --विलय</option></"
"arg><arg choice=\"opt\"><option value=\"-b, --base\"> -ख, --आधारः</"
"option><replaceable> संचिका</replaceable></arg><arg choice=\"opt\"><option "
"value=\"-o, --output\"> -ओ, --निर्गमः</option><replaceable> संचिका</"
"replaceable></arg><arg choice=\"opt\"><option value=--out> --बहिः</"
"option><replaceable> संचिका</replaceable></arg><arg choice=\"opt\"><option "
"value=--noauto> --नोआटो</option></arg><arg choice=\"opt\"><option value=--"
"auto> --स्वयम्</option></arg><arg choice=\"opt\"><option value=--L1> --L1</"
"option><replaceable> उपनाम1</replaceable></arg><arg choice=\"opt\"><option "
"value=--L2> --L2</option><replaceable> उपनाम2</replaceable></arg><arg choice="
"\"opt\"><option value=--L3> --L3</option><replaceable> उपनाम३</replaceable></"
"arg><arg choice=\"opt\"><option value=\"-L, --fname\"> -L, --fname</"
"option><replaceable> उपनाम</replaceable></arg><arg choice=\"opt\"><option "
"value=--cs> --cs</option><replaceable> सूत्र</replaceable></arg><arg choice="
"\"opt\"><option value=--confighelp> --confighelp इति</option></arg><arg "
"choice=\"opt\"><option value=--config> --config</option><replaceable> संचिका</"
"replaceable></arg><arg choice=\"opt\"><option><replaceable> सञ्चिका1</"
"replaceable></option></arg><arg choice=\"opt\"><option><replaceable> "
"सञ्चिका2</replaceable></option></arg><arg choice=\"opt"
"\"><option><replaceable> सञ्चिका३</replaceable></option></arg>"

#. Tag: title
#: man-kdiff3.1.docbook:54
#, no-c-format
msgid "Description"
msgstr "वर्णनम्‌"

#. Tag: para
#: man-kdiff3.1.docbook:55
#, no-c-format
msgid "Compares two or three input files or folders."
msgstr "द्वौ वा त्रीणि वा इनपुट् सञ्चिकाः अथवा समुच्चय तुलनां करोति ।"

#. Tag: title
#: man-kdiff3.1.docbook:60
#, no-c-format
msgid "Options"
msgstr "विकल्पाः"

#. Tag: option
#: man-kdiff3.1.docbook:63
#, no-c-format
msgid "-u, --ignore"
msgstr "-उ, --उपेक्षया"

#. Tag: para
#: man-kdiff3.1.docbook:64 man-kdiff3.1.docbook:70 man-kdiff3.1.docbook:76
#: man-kdiff3.1.docbook:82
#, no-c-format
msgid "Ignored. (User defined.)"
msgstr "उपेक्षितम्। (उपयोक्ता परिभाषितम्।)"

#. Tag: option
#: man-kdiff3.1.docbook:69
#, no-c-format
msgid "--query"
msgstr "--उत्प्रेक्षा"

#. Tag: option
#: man-kdiff3.1.docbook:75
#, no-c-format
msgid "--html"
msgstr "--html"

#. Tag: option
#: man-kdiff3.1.docbook:81
#, no-c-format
msgid "--abort"
msgstr "--गर्भपातम्"

#. Tag: option
#: man-kdiff3.1.docbook:87
#, no-c-format
msgid "-m, --merge"
msgstr "-म, --विलय"

#. Tag: para
#: man-kdiff3.1.docbook:88
#, no-c-format
msgid "Merge the input."
msgstr "निवेशं विलीनं कुर्वन्तु।"

#. Tag: term
#: man-kdiff3.1.docbook:93
#, no-c-format
msgid "<option>-b, --base</option> <replaceable>file</replaceable>"
msgstr ""
"<option value=\"-b, --base\">-ख, --आधारः</option><replaceable> संचिका</"
"replaceable>"

#. Tag: para
#: man-kdiff3.1.docbook:94
#, no-c-format
msgid "Explicit base file. For compatibility with certain tools."
msgstr "स्पष्टा आधारसञ्चिका। कतिपयैः साधनैः सह संगततायै ।"

#. Tag: term
#: man-kdiff3.1.docbook:99
#, no-c-format
msgid "<option>-o, --output</option> <replaceable>file</replaceable>"
msgstr ""
"<option value=\"-o, --output\">-ओ, --निर्गमः</option><replaceable> संचिका</"
"replaceable>"

#. Tag: para
#: man-kdiff3.1.docbook:100
#, no-c-format
msgid "Output file. Implies -m. &eg;: -o newfile.txt"
msgstr "आउटपुट् सञ्चिका । तात्पर्यम् -म. &eg;: -o newfile.txt"

#. Tag: term
#: man-kdiff3.1.docbook:105
#, no-c-format
msgid "<option>--out</option> <replaceable>file</replaceable>"
msgstr "<option value=--out>--बहिः</option><replaceable> संचिका</replaceable>"

#. Tag: para
#: man-kdiff3.1.docbook:106
#, no-c-format
msgid "Output file, again. (For compatibility with certain tools.)"
msgstr "आउटपुट् सञ्चिका, पुनः । (कतिपयैः साधनैः सह संगततायै ।)"

#. Tag: option
#: man-kdiff3.1.docbook:111
#, no-c-format
msgid "--auto"
msgstr "--स्वयम्"

#. Tag: para
#: man-kdiff3.1.docbook:112
#, no-c-format
msgid ""
"No GUI if all conflicts are auto-solvable. (Needs <option>-o</option> "
"<replaceable>file</replaceable>)"
msgstr ""
"यदि सर्वे विग्रहाः स्वयमेव समाधानयोग्याः सन्ति तर्हि GUI नास्ति । (आवश्यकता<option "
"value=-o> -o</option><replaceable> संचिका</replaceable> )"

#. Tag: option
#: man-kdiff3.1.docbook:118
#, no-c-format
msgid "--noauto"
msgstr "--नोआटो"

#. Tag: para
#: man-kdiff3.1.docbook:119
#, no-c-format
msgid "Ignore --auto and always show GUI."
msgstr "--auto इत्यस्य अवहेलनां कृत्वा सर्वदा GUI दर्शयन्तु ।"

#. Tag: term
#: man-kdiff3.1.docbook:124
#, no-c-format
msgid "<option>--L1</option> <replaceable>alias1</replaceable>"
msgstr "<option value=--L1>--L1</option><replaceable> उपनाम1</replaceable>"

#. Tag: para
#: man-kdiff3.1.docbook:125
#, no-c-format
msgid "Visible name replacement for input file 1 (base)."
msgstr "निवेशसञ्चिका 1 (आधारः) कृते दृश्यमाननामप्रतिस्थापनम् ।"

#. Tag: term
#: man-kdiff3.1.docbook:130
#, no-c-format
msgid "<option>--L2</option> <replaceable>alias2</replaceable>"
msgstr "<option value=--L2>--L2</option><replaceable> उपनाम2</replaceable>"

#. Tag: para
#: man-kdiff3.1.docbook:131
#, no-c-format
msgid "Visible name replacement for input file 2."
msgstr "निवेशसञ्चिकायाः कृते दृश्यमाननामप्रतिस्थापनम् 2."

#. Tag: term
#: man-kdiff3.1.docbook:136
#, no-c-format
msgid "<option>--L3</option> <replaceable>alias3</replaceable>"
msgstr "<option value=--L3>--L3</option><replaceable> उपनाम३</replaceable>"

#. Tag: para
#: man-kdiff3.1.docbook:137
#, no-c-format
msgid "Visible name replacement for input file 3."
msgstr "निवेशसञ्चिकायाः कृते दृश्यमाननामप्रतिस्थापनम् 3."

#. Tag: term
#: man-kdiff3.1.docbook:142
#, no-c-format
msgid "<option>-L, --fname</option> <replaceable>alias</replaceable>"
msgstr ""
"<option value=\"-L, --fname\">-L, --fname</option><replaceable> उपनाम</"
"replaceable>"

#. Tag: para
#: man-kdiff3.1.docbook:143
#, no-c-format
msgid "Alternative visible name replacement. Supply this once for every input."
msgstr "वैकल्पिकं दृश्यमानं नामप्रतिस्थापनम्। प्रत्येकं निवेशस्य कृते एकवारं एतत् आपूर्तिं कुर्वन्तु।"

#. Tag: term
#: man-kdiff3.1.docbook:148
#, no-c-format
msgid "<option>--cs</option> <replaceable>string</replaceable>"
msgstr "<option value=--cs>--cs</option><replaceable> सूत्र</replaceable>"

#. Tag: para
#: man-kdiff3.1.docbook:149
#, no-c-format
msgid ""
"Override a config setting. Use once for every setting. &eg;: <option>--cs</"
"option> <replaceable>AutoAdvance=1</replaceable>."
msgstr ""
"एकं विन्याससेटिंग् अधिलिखन्तु । प्रत्येकं सेटिङ्ग् कृते एकवारं उपयोगं कुर्वन्तु। ⪚: १.<option "
"value=--cs> --cs</option><replaceable> स्वतः उन्नति=1</replaceable> ."

#. Tag: option
#: man-kdiff3.1.docbook:155
#, no-c-format
msgid "--confighelp"
msgstr "--confighelp इति"

#. Tag: para
#: man-kdiff3.1.docbook:156
#, no-c-format
msgid "Show list of config settings and current values."
msgstr "विन्याससेटिंग्स् इत्यस्य सूचीं वर्तमानमूल्यानि च दर्शयन्तु ।"

#. Tag: term
#: man-kdiff3.1.docbook:161
#, no-c-format
msgid "<option>--config</option> <replaceable>file</replaceable>"
msgstr ""
"<option value=--config>--config</option><replaceable> संचिका</replaceable>"

#. Tag: para
#: man-kdiff3.1.docbook:162
#, no-c-format
msgid "Use a different config file."
msgstr "भिन्नं विन्याससञ्चिकां उपयुज्यताम् ।"

#. Tag: replaceable
#: man-kdiff3.1.docbook:167
#, no-c-format
msgid "File1"
msgstr "सञ्चिका1"

#. Tag: para
#: man-kdiff3.1.docbook:168
#, no-c-format
msgid "file1 to open (base, if not specified via --<option>base</option>)"
msgstr "file1 उद्घाटयितुं (आधारः, यदि --<option value=base> आधार</option> )"

#. Tag: replaceable
#: man-kdiff3.1.docbook:173
#, no-c-format
msgid "File2"
msgstr "सञ्चिका2"

#. Tag: para
#: man-kdiff3.1.docbook:174
#, no-c-format
msgid "file2 to open"
msgstr "file2 उद्घाटयितुं"

#. Tag: replaceable
#: man-kdiff3.1.docbook:179
#, no-c-format
msgid "File3"
msgstr "सञ्चिका३"

#. Tag: para
#: man-kdiff3.1.docbook:180
#, no-c-format
msgid "file3 to open"
msgstr "file3 उद्घाटयितुं"

#. Tag: title
#: man-kdiff3.1.docbook:189
#, no-c-format
msgid "See Also"
msgstr "इदमपि पश्यन्तु"

#. Tag: member
#: man-kdiff3.1.docbook:191
#, no-c-format
msgid ""
"More detailed user documentation is available from <ulink url=\"help:/"
"kdiff3\">help:/kdiff3</ulink> (either enter this &URL; into &konqueror;, or "
"run <userinput><command>khelpcenter</command> <parameter>help:/kdiff3</"
"parameter></userinput>)."
msgstr ""
"अधिकविस्तृतं उपयोक्तृदस्तावेजं <ulink url=\"help:/kdiff3\">help:/kdiff3</ulink> "
"इत्यस्मात् उपलभ्यते (एतत् &URL; &konqueror; मध्ये प्रविशतु, अथवा "
"<userinput><command>khelpcenter</command> < चालयन्तु पैरामीटर>सहायता:/kdiff3</"
"parameter></userinput>)।"

#. Tag: member
#: man-kdiff3.1.docbook:196
#, no-c-format
msgid "kf6options(7)"
msgstr "kf6विकल्पाः(7) ."

#. Tag: member
#: man-kdiff3.1.docbook:197
#, no-c-format
msgid "qt6options(7)"
msgstr "qt6विकल्प(7) 1.1."

