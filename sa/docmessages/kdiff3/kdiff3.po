msgstr "द्वौ वा त्रीणि वा पाठनिवेशसञ्चिकाः अथवा पुटं तुलनां कृत्वा विलीनं करोति,"

#. Tag: para
#: index.docbook:63
#, no-c-format
msgid "shows the differences line by line and character by character(!),"
msgstr "रेखापङ्क्तिः वर्णवर्णेन च भेदान् दर्शयति(!),"

#. Tag: para
#: index.docbook:64
#, no-c-format
msgid "provides an automatic merge-facility,"
msgstr "स्वचालितं विलय-सुविधां प्रदाति,"

#. Tag: para
#: index.docbook:65
#, no-c-format
msgid "has an editor for comfortable solving of merge-conflicts,"
msgstr "विलय-विग्रहस्य सहजनिराकरणाय सम्पादकः अस्ति,"

#. Tag: para
#: index.docbook:66
#, no-c-format
msgid "provides network transparency via KIO,"
msgstr "KIO मार्गेण संजालपारदर्शिता प्रदाति,"

#. Tag: para
#: index.docbook:67
#, no-c-format
msgid "has options to highlight or hide changes in white-space or comments,"
msgstr "श्वेत-स्थाने अथवा टिप्पण्यां परिवर्तनं प्रकाशयितुं गोपयितुं वा विकल्पाः सन्ति,"

#. Tag: para
#: index.docbook:68
#, no-c-format
msgid "supports Unicode, UTF-8 and other file encodings,"
msgstr "यूनिकोड, UTF-8 इत्यादीनां सञ्चिकासङ्केतानां समर्थनं करोति,"

#. Tag: para
#: index.docbook:69
#, no-c-format
msgid "prints differences,"
msgstr "भेदं मुद्रयति,"

#. Tag: para
#: index.docbook:70
#, no-c-format
msgid "supports version control keyword and history merging."
msgstr "संस्करणनियन्त्रणकीवर्डं इतिहासविलयं च समर्थयति ।"

