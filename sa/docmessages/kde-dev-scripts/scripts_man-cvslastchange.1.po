msgid "Display the last change committed to &CVS; for a file"
msgstr "&CVS; सञ्चिकायाः कृते"

#. Tag: cmdsynopsis
#: man-cvslastchange.1.docbook:26
#, no-c-format
msgid "&cvslastchange; <group><replaceable>file</replaceable></group>"
msgstr "&cvslastchange; <group><replaceable>सञ्चिका</replaceable></group> इति"

#. Tag: title
#: man-cvslastchange.1.docbook:33
#, no-c-format
msgid "Description"
msgstr "वर्णनम्‌"

#. Tag: para
#: man-cvslastchange.1.docbook:35
#, no-c-format
msgid ""
"&cvslastchange; displays the last change committed to &CVS; for a file. It "
"uses <command>cvs diff</command> and <command>cvs log</command> to do this."
msgstr ""
"&cvslastchange; &CVS; सञ्चिकायाः कृते । एतत् कर्तुं <command>cvs diff</command> तथा "
"<command>cvs log</command> इत्येतयोः उपयोगं करोति ।"

#. Tag: para
#: man-cvslastchange.1.docbook:39
#, no-c-format
msgid "&cvslastchange; works on any &CVS; branch, not just HEAD."
msgstr "&cvslastchange; कस्मिन् अपि &CVS; शाखा, न केवलं HEAD इति।"

#. Tag: para
#: man-cvslastchange.1.docbook:41
#, no-c-format
msgid "This utility is part of the &kde; Software Development Kit."
msgstr "एषा उपयोगिता &kde; सॉफ्टवेयर विकास किट।"

