#. Tag: cmdsynopsis
#: man-kpat.6.docbook:25
#, no-c-format
msgid ""
"<command>kpat</command> <group choice=\"opt\"><option>--solvegame</option> "
"<replaceable> file</replaceable></group> <group choice=\"opt\"><option>--"
"solve</option> <replaceable> num</replaceable></group> <group choice=\"opt"
"\"><option>--start</option> <replaceable> num</replaceable></group> <group "
"choice=\"opt\"><option>--end</option> <replaceable> num</replaceable></"
"group> <group choice=\"opt\"><option>--gametype</option> <replaceable> game</"
"replaceable></group> <group choice=\"opt\"><option>--testdir</option> "
"<replaceable> directory</replaceable></group> <group choice=\"opt"
"\"><option>--generate</option></group> <group choice=\"opt"
"\"><option><replaceable>file</replaceable></option></group>"
msgstr ""
"<command>क्पत्</command><group choice=\"opt\"><option value=--solvegame> --"
"समाधानखेलम्</option><replaceable> संचिका</replaceable></group><group choice="
"\"opt\"><option value=--solve> --उत्तरयति</option><replaceable> नुम्</"
"replaceable></group><group choice=\"opt\"><option value=--start> --प्रारंभः</"
"option><replaceable> नुम्</replaceable></group><group choice=\"opt\"><option "
"value=--end> --अंत</option><replaceable> नुम्</replaceable></group><group "
"choice=\"opt\"><option value=--gametype> --खेलप्रकारः</option><replaceable> "
"क्रीडा</replaceable></group><group choice=\"opt\"><option value=--testdir> --"
"testdir</option><replaceable> निर्देशिका</replaceable></group><group choice="
"\"opt\"><option value=--generate> --उद्- पद्</option></group><group choice="
"\"opt\"><option><replaceable> संचिका</replaceable></option></group>"

#. Tag: title
#: man-kpat.6.docbook:39
#, no-c-format
msgid "DESCRIPTION"
msgstr "वर्णनम्‌"

#. Tag: para
#: man-kpat.6.docbook:40
#, no-c-format
msgid ""
"&kpatience; is a compendium of several well known patience card games, "
"ranging from the well known Klondike and Freecell, to lesser known games "
"such as Grandfather's Clock and Mod3. In all there are 12 variations for you "
"to while away time."
msgstr ""
"&कधैर्यम्; इति कतिपयानां सुप्रसिद्धानां धैर्यपत्तेः क्रीडाणां संकलनम् अस्ति, यत्र सुप्रसिद्धाः "
"क्लोण्डाइक्, फ्रीसेल् च आरभ्य, दादाघटिका, मोड्३ इत्यादीनां अल्पप्रसिद्धानां क्रीडाणां यावत् "
"सर्वेषु भवतः कृते दूरसमये 12 विविधताः सन्ति।"

#. Tag: title
#: man-kpat.6.docbook:48
#, no-c-format
msgid "OPTIONS"
msgstr "OPTIONS इति"

#. Tag: para
#: man-kpat.6.docbook:49
#, no-c-format
msgid ""
"This program follows the usual GNU command line syntax, with long options "
"starting with two dashes (`--'). A summary of the options supported by "
"<command>kpat</command> is included below."
msgstr ""
"अयं कार्यक्रमः सामान्यं GNU आदेशपङ्क्तिवाक्यविन्यासम् अनुसरति, दीर्घविकल्पैः सह द्वयोः डैशयोः "
"(`--') आरभ्यते । <command>kpat</command> इत्यनेन समर्थितानां विकल्पानां सारांशः अधः "
"समाविष्टः अस्ति ।"

#. Tag: term
#: man-kpat.6.docbook:58
#, no-c-format
msgid "<option>-h</option> <option>--help</option>"
msgstr "<option value=-h>-ह</option><option value=--help> --साहाय्यम्‌</option>"

#. Tag: para
#: man-kpat.6.docbook:59
#, no-c-format
msgid "This lists the options available at the command line"
msgstr "एतेन आदेशपङ्क्तौ उपलब्धाः विकल्पाः सूचीबद्धाः सन्ति"

#. Tag: term
#: man-kpat.6.docbook:64
#, no-c-format
msgid "<option>-v</option> <option>--version</option>"
msgstr "<option value=-v>-वि</option><option value=--version> --संस्करण</option>"

#. Tag: para
#: man-kpat.6.docbook:66
#, no-c-format
msgid "Lists version information for &kpatience;"
msgstr "&kpatience;"

#. Tag: term
#: man-kpat.6.docbook:70
#, no-c-format
msgid "<option>--solvegame</option> <replaceable> file</replaceable>"
msgstr ""
"<option value=--solvegame>--समाधानखेलम्</option><replaceable> संचिका</"
"replaceable>"

#. Tag: para
#: man-kpat.6.docbook:72
#, no-c-format
msgid "Try to find a solution to the given savegame"
msgstr "दत्तस्य savegame इत्यस्य समाधानं अन्वेष्टुं प्रयतध्वम्"

#. Tag: term
#: man-kpat.6.docbook:77
#, no-c-format
msgid "<option>--solve</option> <replaceable> num</replaceable>"
msgstr ""
"<option value=--solve>--उत्तरयति</option><replaceable> कतरः</replaceable>"

#. Tag: para
#: man-kpat.6.docbook:79
#, no-c-format
msgid "Dealer to solve (debug)"
msgstr "समाधानं कर्तुं विक्रेतारः (दोषनिवारणम्) ."

#. Tag: term
#: man-kpat.6.docbook:84
#, no-c-format
msgid "<option>--start</option> <replaceable> num</replaceable>"
msgstr "<option value=--start>--प्रारंभः</option><replaceable> नुम्</replaceable>"

#. Tag: para
#: man-kpat.6.docbook:86
#, no-c-format
msgid "Game range start (default 0:INT_MAX)"
msgstr "क्रीडायाः परिधिः आरम्भः (पूर्वनिर्धारितः 0:INT_MAX)"

#. Tag: term
#: man-kpat.6.docbook:91
#, no-c-format
msgid "<option>--end</option> <replaceable> num</replaceable>"
msgstr "<option value=--end>--अंत</option><replaceable> नुम्</replaceable>"

#. Tag: para
#: man-kpat.6.docbook:93
#, no-c-format
msgid "Game range end (default start:start if start given)"
msgstr "क्रीडपरिधिः समाप्तः (पूर्वनिर्धारितः आरम्भः:प्रारम्भः यदि आरम्भः दत्तः)"

#. Tag: term
#: man-kpat.6.docbook:98
#, no-c-format
msgid "<option>--gametype</option> <replaceable> game</replaceable>"
msgstr ""
"<option value=--gametype>--खेलप्रकारः</option><replaceable> क्रीडा</replaceable>"

#. Tag: para
#: man-kpat.6.docbook:100
#, fuzzy, no-c-format
#| msgid ""
#| "Skip the selection screen and load a particular game type. Valid values "
#| "are: acesup, fortyeight, freecell, golf, grandfather, grandfathersclock, "
#| "gypsy, klondike, mod3, simplesimon, spider, yukon"
