#~ "classLocalizeMainWindow.html\">&स्थानीयकरण;</ulink> वस्तु एपिआइ सन्दर्भ"

#~ msgid ""
#~ "<ulink url=\"http://api.kde.org/4.14-api/kdesdk-apidocs/lokalize/html/"
