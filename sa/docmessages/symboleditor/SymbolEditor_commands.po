#. Tag: action
#: commands.docbook:99
#, no-c-format
msgid "Select the square cap line end type"
msgstr "वर्ग-टोपी-रेखा-अन्त-प्रकारं चिनोतु"

#. Tag: guimenuitem
#: commands.docbook:102
#, no-c-format
msgid "Round Cap"
msgstr "गोल टोपी"

#. Tag: action
#: commands.docbook:103
#, no-c-format
