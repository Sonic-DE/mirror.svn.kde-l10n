"guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;&Alt;<keycap>S</keycap></"
"keycombo> <keycap>,U</keycap></shortcut> <guimenuitem>TeX समूह (बहिः)</ "
"guimenuitem> इति"

