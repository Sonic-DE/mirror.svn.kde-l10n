#. Tag: title
#: index.docbook:52
#, no-c-format
msgid "Introduction"
msgstr "आमुख"

#. Tag: para
#: index.docbook:56
#, no-c-format
msgid "Start &kget; (you should see a Drop Target)"
msgstr "आरभत &kget; (भवन्तः Drop Target द्रष्टव्याः)"

#. Tag: para
#: index.docbook:57
#, no-c-format
msgid "Drag and drop the required &URL; in the &kget; window/Drop Target."
msgstr "आवश्यकं &URL; इत्यत्र &kget; window/Drop लक्ष्यम्।"

#. Tag: screeninfo
#: index.docbook:60 index.docbook:535
#, no-c-format
msgid "<screeninfo>Screenshot of &kget;</screeninfo>"
msgstr "<screeninfo>&kget;</screeninfo> इत्यस्य स्क्रीनशॉट्"

#. Tag: phrase
#: index.docbook:66 index.docbook:541
#, no-c-format
msgid "<phrase>Screenshot of &kget;</phrase>"
msgstr "<phrase>&kget;</phrase> इत्यस्य स्क्रीनशॉट्"

#. Tag: title
#: index.docbook:74
#, no-c-format
msgid "&kget; Drop Target"
msgstr "&kget; लक्ष्यं पातयन्तु"

#. Tag: para
#: index.docbook:76
#, no-c-format
msgid "The &kget; Drop Target has four options."
msgstr "इति &kget; Drop Target इत्यत्र चत्वारः विकल्पाः सन्ति ।"

#. Tag: screeninfo
#: index.docbook:81
#, no-c-format
msgid "<screeninfo>Screenshot of &kget; drop target</screeninfo>"
msgstr "<screeninfo>&kget इत्यस्य स्क्रीनशॉट्; लक्ष्यं पातयन्तु</screeninfo>"

#. Tag: phrase
#: index.docbook:87
#, no-c-format
msgid "<phrase>Screenshot of &kget; drop target</phrase>"
msgstr "<phrase>&kget इत्यस्य स्क्रीनशॉट्; लक्ष्यं पातयति</phrase>"

#. Tag: title
#: index.docbook:93
#, no-c-format
msgid "&kget; Drop Target options"
msgstr "&kget; Target विकल्पान् पातयन्तु"

#. Tag: para
#: index.docbook:94
#, no-c-format
msgid "Right click on the drop target to see the options."
msgstr "विकल्पान् द्रष्टुं drop target इत्यत्र राइट् क्लिक् कुर्वन्तु ।"

#. Tag: menuchoice
#: index.docbook:101
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>R</keycap></keycombo> </"
"shortcut> <guimenuitem>Start / Resume All</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>R</keycap></keycombo> </"
"shortcut> <guimenuitem>सर्वं आरभत / पुनः आरभत</guimenuitem>"

#. Tag: action
#: index.docbook:110
#, no-c-format
msgid ""
"To start a download or resume all the pending downloads. The shortcut for "
"doing this is <keycombo action=\"simul\">&Ctrl;<keycap>R</keycap></keycombo>"
msgstr ""
"डाउनलोड् आरभ्य सर्वाणि लम्बितानि डाउनलोड्स् पुनः आरभ्यतुं वा। एतत् कर्तुं लघुमार्गः "
"<keycombo action=\"simul\">&Ctrl;<keycap>R</keycap></keycombo> अस्ति"

#. Tag: guimenuitem
#: index.docbook:118
#, no-c-format
msgid "Show/Hide Main Window"
msgstr "मुख्यविण्डो दर्शयतु/गोपयतु"

#. Tag: action
#: index.docbook:123
#, no-c-format
msgid "This option shows or minimizes the main window to the system tray."
msgstr "एषः विकल्पः मुख्यविण्डो सिस्टम् ट्रे प्रति दर्शयति न्यूनीकरोति वा ।"

#. Tag: guimenuitem
#: index.docbook:130
#, no-c-format
msgid "Sticky"
msgstr "चिपचिपा"

#. Tag: action
#: index.docbook:135
#, no-c-format
msgid "Makes the &kget; drop target undraggable."
msgstr "करोति &kget; लक्ष्यं पातयन्तु अकर्ष्यम्।"

#. Tag: guimenuitem
#: index.docbook:143
#, no-c-format
msgid "Quit &kget;"
msgstr "त्यजतु &kget;"

#. Tag: action
#: index.docbook:148 index.docbook:698
#, no-c-format
msgid "Quits &kget;"
msgstr "त्यजति &kget;"

#. Tag: title
#: index.docbook:157
#, no-c-format
msgid "&kget;'s Configuration window"
msgstr "&kget; इत्यस्य विन्यासविण्डो"

#. Tag: menuchoice
#: index.docbook:160
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Configure &kget;</guimenuitem>"
msgstr "<guimenu>सेटिंग्स्</guimenu> <guimenuitem>&kget;</guimenuitem> विन्यस्यताम्"

#. Tag: action
#: index.docbook:164
#, no-c-format
msgid "Opens the &kget; configuration window"
msgstr "&kget इति उद्घाटयति; विन्यासविण्डो"

#. Tag: title
#: index.docbook:169
#, no-c-format
msgid "<title>Appearance</title>"
msgstr "<title>स्वरूपम्‌</title>"

#. Tag: screeninfo
#: index.docbook:172
#, no-c-format
msgid "<screeninfo>Appearance</screeninfo>"
msgstr "<screeninfo>रूपता</screeninfo>"

#. Tag: phrase
#: index.docbook:178
#, no-c-format
msgid "<phrase>Appearance</phrase>"
msgstr "<phrase>रूपता</phrase> इति"

#. Tag: guimenuitem
#: index.docbook:188
#, no-c-format
msgid "<guimenuitem>Appearance</guimenuitem>"
msgstr "<guimenuitem>रूपता</guimenuitem>"

#. Tag: action
#: index.docbook:193
#, no-c-format
msgid "You can modify the various appearance related stuff here."
msgstr "अत्र भवन्तः विविधानि रूपसम्बद्धानि वस्तूनि परिवर्तयितुं शक्नुवन्ति ।"

#. Tag: guimenuitem
#: index.docbook:200
#, no-c-format
msgid "Use Drop Target"
msgstr "Drop Target इत्यस्य उपयोगं कुर्वन्तु"

#. Tag: action
#: index.docbook:205
#, no-c-format
msgid "Uncheck this if you do not want the &kget; Drop Target."
msgstr "यदि भवान् &kget; लक्ष्यं पातयन्तु।"

#. Tag: guimenuitem
#: index.docbook:212
#, no-c-format
msgid "Enable animations"
msgstr "एनिमेशनं सक्षमं कुर्वन्तु"

#. Tag: action
#: index.docbook:217
#, no-c-format
msgid "Enables few fancy animations."
msgstr "अल्पानि आडम्बरपूर्णानि एनिमेशन्स् सक्षमं करोति ।"

#. Tag: title
#: index.docbook:226
#, no-c-format
msgid "Groups"
msgstr "समूहाः"

#. Tag: para
#: index.docbook:227
#, no-c-format
msgid "You can group downloads."
msgstr "भवन्तः डाउनलोड्-समूहं कर्तुं शक्नुवन्ति ।"

#. Tag: screeninfo
#: index.docbook:229
#, no-c-format
msgid "<screeninfo>&kget; Groups</screeninfo>"
msgstr "<स्क्रीन इन्फो>&kget; समूह</screeninfo> इति"

#. Tag: phrase
#: index.docbook:235
#, no-c-format
msgid "<phrase>&kget; Groups</phrase>"
msgstr "<वाक्यांश>&kget; समूह</phrase> इति"

#. Tag: guimenuitem
#: index.docbook:244
#, no-c-format
msgid "Use default folders for groups as suggestion"
msgstr "समूहानां कृते पूर्वनिर्धारितपुटस्य उपयोगं सुझावरूपेण कुर्वन्तु"

#. Tag: action
#: index.docbook:249
#, no-c-format
msgid ""
"Tick this box if you want &kget; to use default folders for your downloads."
msgstr ""
"यदि भवान् इच्छति तर्हि एतत् पेटीम् चिह्नितुम् &kget; भवतः डाउनलोड् कृते पूर्वनिर्धारितपुटस्य "
"उपयोगाय ।"

#. Tag: title
#: index.docbook:258
#, no-c-format
msgid "Network"
msgstr "जालकृति"

#. Tag: para
#: index.docbook:259
#, no-c-format
msgid "You can modify your network related settings here."
msgstr "भवान् अत्र स्वस्य संजालसम्बद्धानि सेटिङ्ग्स् परिवर्तयितुं शक्नोति ।"

#. Tag: screeninfo
#: index.docbook:261
#, no-c-format
msgid "<screeninfo>&kget; Network</screeninfo>"
msgstr "<स्क्रीन इन्फो>&kget; संजाल</screeninfo>"

#. Tag: phrase
#: index.docbook:267
#, no-c-format
msgid "<phrase>&kget; Network</phrase>"
msgstr "<वाक्यांश>&kget; संजाल</phrase> इति"

#. Tag: guimenuitem
#: index.docbook:276
#, no-c-format
msgid "Limit Maximum Downloads Per Group"
msgstr "प्रतिसमूहं अधिकतमं डाउनलोड् सीमितं कुर्वन्तु"

#. Tag: action
#: index.docbook:281
#, no-c-format
msgid "Check this box if you want Download limits to be implemented."
msgstr ""
"यदि भवान् इच्छति यत् Download सीमाः कार्यान्विताः भवेयुः तर्हि एतत् पेटीम् चिनोतु ।"

#. Tag: guimenuitem
#: index.docbook:288
#, no-c-format
msgid "Speed Limit"
msgstr "गतिसीमा"

#. Tag: action
#: index.docbook:293
#, no-c-format
msgid "Check this box if you want the Global speed limits to be used."
msgstr ""
"यदि भवान् इच्छति यत् Global speed limits इत्यस्य उपयोगः करणीयः तर्हि एतत् पेटीम् "
"चिनोतु ।"

#. Tag: guimenuitem
#: index.docbook:301
#, no-c-format
msgid "Global download limit"
msgstr "वैश्विक डाउनलोड सीमा"

#. Tag: action
#: index.docbook:306
#, no-c-format
msgid "Set the maximum global download limit."
msgstr "अधिकतमं वैश्विकं डाउनलोड् सीमां सेट् कुर्वन्तु ।"

#. Tag: guimenuitem
#: index.docbook:314
#, no-c-format
msgid "Global upload limit"
msgstr "वैश्विक अपलोड सीमा"

#. Tag: action
#: index.docbook:319
#, no-c-format
msgid "Set the maximum upload limit."
msgstr "अधिकतमं अपलोड् सीमां सेट् कुर्वन्तु।"

#. Tag: guimenuitem
#: index.docbook:327
#, no-c-format
msgid "Reconnect on Broken Connection"
msgstr "भग्नसंयोजने पुनः संयोजयन्तु"

#. Tag: action
#: index.docbook:332
#, no-c-format
msgid ""
"Check this box if you want &kget; to reconnect after an error or a broken "
"connection."
msgstr ""
"यदि भवान् इच्छति तर्हि एतत् पेटीं चिनोतु &kget; त्रुटिः भग्नसंयोजनस्य वा अनन्तरं पुनः "
"संयोजयितुं।"

#. Tag: guimenuitem
#: index.docbook:340
#, no-c-format
msgid "Number of retries"
msgstr "पुनः प्रयासानां संख्या"

#. Tag: action
#: index.docbook:345
#, no-c-format
msgid "Set the maximum number of time &kget; will try to reconnect."
msgstr "अधिकतमं समयसङ्ख्यां सेट् कुर्वन्तु &kgt; पुनः संयोजयितुं प्रयतते।"

#. Tag: guimenuitem
#: index.docbook:353
#, no-c-format
msgid "Retry after"
msgstr "पश्चात् पुनः प्रयासं कुर्वन्तु"

#. Tag: action
#: index.docbook:358
#, no-c-format
msgid "Set the retrying interval here (in seconds)"
msgstr "अत्र पुनः प्रयासान्तरं सेट् कुर्वन्तु (सेकेण्ड्-मात्रेषु) ।"

#. Tag: title
#: index.docbook:368
#, no-c-format
msgid "Web Interface"
msgstr "जाल-अन्तरफलकम्"

#. Tag: para
#: index.docbook:369
#, no-c-format
msgid ""
"To enable the web interface, check <guilabel>Enable Web Interface</"
"guilabel>; default port is 8080, and you configure any port higher than "
"1024. Then set <guilabel>User</guilabel> and <guilabel>Password</guilabel>. "
"You can access your web interface at http://127.0.0.1:&lt;port&gt;. You will "
"need to enter the username and password to get access."
msgstr ""
"जाल-अन्तरफलकं सक्षमं कर्तुं <guilabel>जाल-अन्तरफलकं सक्षमं कुर्वन्तु</guilabel> इति पश्यन्तु; "
"पूर्वनिर्धारितं पोर्ट् 8080 अस्ति, तथा च भवान् 1024 इत्यस्मात् अधिकं किमपि पोर्ट् विन्यस्यति "
"ततः <guilabel>उपयोक्ता</guilabel> तथा <guilabel>गुप्तशब्द</guilabel> सेट् कुर्वन्तु । "
"भवान् स्वस्य जाल-अन्तरफलकं http://127.0.0.1:&lt;port&gt; इत्यत्र प्राप्तुं शक्नोति । "
"प्रवेशं प्राप्तुं भवद्भिः उपयोक्तृनाम गुप्तशब्दं च प्रविष्टव्यं भविष्यति ।"

#. Tag: screeninfo
#: index.docbook:377
#, no-c-format
msgid "<screeninfo>&kget; Web Interface</screeninfo>"
msgstr "<स्क्रीन इन्फो>&kget; जाल-अन्तरफलक</screeninfo>"

#. Tag: phrase
#: index.docbook:383
#, no-c-format
msgid "<phrase>&kget; Web Interface</phrase>"
msgstr "<वाक्यांश>&kget; जाल-अन्तरफलक</phrase>"

#. Tag: title
#: index.docbook:391
#, no-c-format
msgid "Verification"
msgstr "सत्यापनम्"

#. Tag: para
#: index.docbook:392
#, no-c-format
msgid "Verify your downloads."
msgstr "स्वस्य डाउनलोड् सत्यापयन्तु।"

#. Tag: screeninfo
#: index.docbook:394
#, no-c-format
msgid "<screeninfo>&kget; Verification</screeninfo>"
msgstr "<स्क्रीन इन्फो>&kget; सत्यापन</screeninfo>"

#. Tag: phrase
#: index.docbook:400
#, no-c-format
msgid "<phrase>&kget; Verification</phrase>"
msgstr "<वाक्यांश>&kget; सत्यापन</phrase> इति"

#. Tag: para
#: index.docbook:405
#, no-c-format
msgid ""
"Using the two methods <guilabel>Automatic checksums verification</guilabel> "
"and <guilabel>Signature</guilabel> you can verify your downloads. You just "
"have to tick the <guilabel>Automatic verification</guilabel> check box."
msgstr ""
"<guilabel>स्वचालितं चेकसमसत्यापन</guilabel> तथा <guilabel>हस्ताक्षर</guilabel> इति "
"द्वयोः पद्धतयोः उपयोगेन भवान् स्वस्य अवतरणं सत्यापयितुं शक्नोति । भवद्भिः केवलं "
"<guilabel>स्वचालितसत्यापन</guilabel> इति चेकबॉक्सं चिह्नितव्यम् ।"

#. Tag: title
#: index.docbook:410
#, no-c-format
msgid "Integration"
msgstr "एकीकरणम्"

#. Tag: guimenuitem
#: index.docbook:415
#, no-c-format
msgid "Use as download manager for Konqueror"
msgstr "Konqueror कृते डाउनलोड् प्रबन्धकरूपेण उपयुज्यताम्"

#. Tag: action
#: index.docbook:420
#, no-c-format
msgid "You can set &kget; as your download manager for &konqueror;."
msgstr "भवान् &kget; &konqueror; कृते भवतः डाउनलोड् प्रबन्धकरूपेण ।"

#. Tag: guimenuitem
#: index.docbook:428
#, no-c-format
msgid "Monitor clipboard for files to download"
msgstr "डाउनलोड् कर्तुं सञ्चिकानां कृते क्लिप्बोर्डस्य निरीक्षणं कुर्वन्तु"

#. Tag: para
#: index.docbook:432
#, no-c-format
msgid ""
"You can turn on this feature that asks if you want to download &URL;s copied "
"into the clipboard."
msgstr ""
"भवान् एतत् विशेषतां चालू कर्तुं शक्नोति यत् पृच्छति यत् भवान् &URL;s प्रतिलिपितं क्लिप्बोर्ड् "
"मध्ये डाउनलोड् कर्तुम् इच्छति वा इति ।"

#. Tag: title
#: index.docbook:441
#, no-c-format
msgid "Advanced"
msgstr "उन्नतं"

#. Tag: para
#: index.docbook:442
#, no-c-format
msgid "Modify Advanced Options."
msgstr "उन्नतविकल्पान् परिवर्तयन्तु।"

#. Tag: screeninfo
#: index.docbook:444
#, no-c-format
msgid "<screeninfo>&kget; Advanced Options</screeninfo>"
msgstr "<स्क्रीन इन्फो>&kget; उन्नतविकल्पाः</screeninfo>"

#. Tag: phrase
#: index.docbook:450
#, no-c-format
msgid "<phrase>&kget; Advanced Options</phrase>"
msgstr "<वाक्यांश>&kget; उन्नतविकल्प</phrase> इति"

#. Tag: guimenuitem
#: index.docbook:459
#, no-c-format
msgid "Enable system tray icon"
msgstr "सिस्टम् ट्रे चिह्नं सक्षमं कुर्वन्तु"

#. Tag: action
#: index.docbook:464
#, no-c-format
msgid "This check box enables the &kget; system tray icon."
msgstr "एतत् चेकबॉक्सं &kget; प्रणाली ट्रे चिह्न।"

#. Tag: guimenuitem
#: index.docbook:472
#, no-c-format
msgid "Execute action after all downloads have been finished"
msgstr "सर्वेषां डाउनलोड् समाप्तस्य अनन्तरं कार्यं निष्पादयन्तु"

#. Tag: action
#: index.docbook:477
#, no-c-format
msgid ""
"Check this box to enable Quitting &kget; after all downloads have finished. "
"At startup you can choose to Restore Download state. Such as Stop All "
"downloads/ Start All downloads."
msgstr ""
"Quitting &kget; सर्वेषां डाउनलोड् समाप्तस्य अनन्तरम्। स्टार्टअप इत्यत्र भवान् Restore "
"Download state इति चिन्वतु । यथा Stop All downloads/ Start All downloads इति।"

#. Tag: guimenuitem
#: index.docbook:486
#, no-c-format
msgid "History backend"
msgstr "इतिहासः पृष्ठभागः"

#. Tag: action
#: index.docbook:491
#, no-c-format
msgid "You can choose your history backend as Sqlite or Xml."
msgstr "भवान् स्वस्य इतिहासस्य पृष्ठभागं Sqlite अथवा Xml इति चिन्वतु ।"

#. Tag: guimenuitem
#: index.docbook:499
#, no-c-format
msgid "Enable &kde; global progress tracking"
msgstr "सक्षमं कुर्वन्तु &kde; वैश्विक प्रगतिनिरीक्षणम्"

#. Tag: action
#: index.docbook:504
#, no-c-format
msgid ""
"You can set &kget; to show every single download or show overall progress."
msgstr "भवान् &kget; प्रत्येकं एकं डाउनलोड् दर्शयितुं वा समग्रं प्रगतिम् दर्शयितुं वा।"

#. Tag: title
#: index.docbook:512
#, no-c-format
msgid "Plugins"
msgstr "प्लगिन्स्"

#. Tag: screeninfo
#: index.docbook:514
#, no-c-format
msgid "<screeninfo>&kget; Plugins Options</screeninfo>"
msgstr "<स्क्रीन इन्फो>&kget; प्लगिन्स् विकल्पाः</screeninfo>"

#. Tag: phrase
#: index.docbook:520
#, no-c-format
msgid "<phrase>&kget; Plugins Options</phrase>"
msgstr "<वाक्यांश>&kget; प्लगिन्स् विकल्पाः</phrase>"

#. Tag: para
#: index.docbook:524
#, no-c-format
msgid ""
"On this page you can select the transfer plugins to be used. Use the "
"<inlinemediaobject><imageobject><imagedata fileref=\"pluginsettings.png\" "
"format=\"PNG\"/> </imageobject></inlinemediaobject> button to change the "
"default settings for a plugin."
msgstr ""
"अस्मिन् पृष्ठे भवान् उपयोक्तुं स्थानान्तरप्लगिन्स् चिन्वतु । प्लगिन् कृते पूर्वनिर्धारितसेटिंग्स् "
"परिवर्तयितुं <inlinemediaobject><imageobject><imagedata fileref="
"\"pluginsettings.png\" format=\"PNG\"/> </imageobject></inlinemediaobject> "
"बटनस्य उपयोगं कुर्वन्तु ।"

#. Tag: title
#: index.docbook:532
#, no-c-format
msgid "Main Window"
msgstr "मुख्य खिडकी"

#. Tag: para
#: index.docbook:533
#, no-c-format
msgid "Overview of &kget;'s Main Window"
msgstr "&kget; इत्यस्य मुख्यविण्डो इत्यस्य अवलोकनम्"

#. Tag: title
#: index.docbook:547
#, no-c-format
msgid "The File Menu"
msgstr "सञ्चिकामेनू इति"

#. Tag: menuchoice
#: index.docbook:550
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>N</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>New Download...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>N</keycap></keycombo> </"
"shortcut> <guimenu>सञ्चिका</guimenu> <guimenuitem>नवीन डाउनलोड्...</"
"guimenuitem>"

#. Tag: action
#: index.docbook:557
#, no-c-format
msgid "Add a new file to download"
msgstr "डाउनलोड् कर्तुं नूतनं सञ्चिकां योजयन्तु"

#. Tag: menuchoice
#: index.docbook:561
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>L</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Import Links...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>L</keycap></keycombo> </"
"shortcut> <guimenu>सञ्चिका</guimenu> <guimenuitem>लिङ्कानि आयातयतु...</"
"guimenuitem>"

#. Tag: screeninfo
#: index.docbook:570
#, no-c-format
msgid "<screeninfo>Import Links</screeninfo>"
msgstr "<screeninfo>लिङ्कानि आयातयन्तु</screeninfo>"

#. Tag: phrase
#: index.docbook:576
#, no-c-format
msgid "<phrase>Import Links</phrase>"
msgstr "<phrase>लिङ्कानि आयातयन्तु</phrase>"

#. Tag: action
#: index.docbook:580
#, no-c-format
msgid ""
"This action brings up another window, where you can see and manipulate which "
"file to download. Also you can make a selection based on <guilabel>Videos</"
"guilabel>, <guilabel>Images</guilabel>, <guilabel>Audio</guilabel> and "
"<guilabel>Archives</guilabel>. There is also a text box to filter out "
"results."
msgstr ""
"एषा क्रिया अन्यं विण्डो आनयति, यत्र भवान् कस्याः सञ्चिकायाः अवतरणं कर्तव्यमिति द्रष्टुं, "
"परिवर्तनं च कर्तुं शक्नोति । अपि च भवान् <guilabel>Videos</guilabel>, "
"<guilabel>Images</guilabel>, <guilabel>Audio</guilabel> तथा "
"<guilabel>Archives</guilabel> इत्येतयोः आधारेण चयनं कर्तुं शक्नोति । परिणामान् छानयितुं "
"पाठपेटिका अपि अस्ति ।"

#. Tag: menuchoice
#: index.docbook:585
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>I</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Import Transfers...</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>I</keycap></keycombo> </"
"shortcut> <guimenu>सञ्चिका</guimenu> <guimenuitem>स्थानांतरणं आयातयतु...</"
"guimenuitem>"

#. Tag: action
#: index.docbook:592
#, no-c-format
msgid ""
"Loads a <filename class=\"extension\">*.kgt</filename>, <filename class="
"\"extension\">*.metalink</filename>, <filename class=\"extension\">*.meta4</"
"filename> or <filename class=\"extension\">*.torrent</filename> file."
msgstr ""
"एकं <filename class=\"extension\">*.kgt</filename>, <filename class="
"\"extension\">*.metalink</filename>, <filename class=\"extension\">*.meta4</"
"filename> वा लोड् करोति <filename class=\"extension\">*.torrent</filename> "
"सञ्चिका ।"

#. Tag: menuchoice
#: index.docbook:596
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>E</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Export Transfers List...</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>E</keycap></keycombo> </"
"shortcut> <guimenu>सञ्चिका</guimenu> <guimenuitem>निर्यातस्थानांतरणसूची...</"
"guimenuitem>"

#. Tag: action
#: index.docbook:603
#, no-c-format
msgid ""
"Export the highlighted links to a <filename class=\"extension\">.kgt</"
"filename> file, to be loaded later."
msgstr ""
"प्रकाशितलिङ्कानि <filename class=\"extension\">.kgt</filename> सञ्चिकायां "
"निर्यातयन्तु, पश्चात् लोड् कर्तुं ।"

#. Tag: menuchoice
#: index.docbook:607
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Create a Metalink</guimenuitem>"
msgstr "<guimenu>सञ्चिका</guimenu> <guimenuitem>मेटालिङ्क् रचयन्तु</guimenuitem>"

#. Tag: screeninfo
#: index.docbook:613
#, no-c-format
msgid "Creating a metalink0"
msgstr "मेटालिङ्कस्य निर्माणम्0"

#. Tag: phrase
#: index.docbook:619
#, no-c-format
msgid "Creating a Metalink0"
msgstr "मेटालिङ्कस्य निर्माणम्0"

#. Tag: para
#: index.docbook:623
#, no-c-format
msgid ""
"Select between creating a new Metalink and loading an existing Metalink. "
"Click the <guilabel>Next</guilabel> button to proceed."
msgstr ""
"नूतनं Metalink निर्मातुं विद्यमानं Metalink लोड् कर्तुं च मध्ये चयनं कुर्वन्तु । अग्रे गन्तुं "
"<guilabel>Next</guilabel> इति बटन् नुदन्तु ।"

#. Tag: screeninfo
#: index.docbook:626
#, no-c-format
msgid "Creating a metalink1"
msgstr "मेटालिङ्कस्य निर्माणम्1"

#. Tag: phrase
#: index.docbook:632
#, no-c-format
msgid "Creating a Metalink1"
msgstr "मेटालिङ्कस्य निर्माणम्1"

#. Tag: para
#: index.docbook:636
#, no-c-format
msgid ""
"Here you can choose to enter some general optional information. Such as "
"where can this metalink be obtained from (Enter the &URL; in the text box "
"next to <guilabel>Origin</guilabel>)."
msgstr ""
"अत्र भवान् काश्चन सामान्यवैकल्पिकसूचनाः प्रविष्टुं शक्नोति । यथा एतत् मेटालिङ्क् कुतः प्राप्तुं "
"शक्यते (<guilabel>Origin</guilabel> इत्यस्य पार्श्वे पाठपेटिकायां &URL; प्रविशन्तु) ।"

#. Tag: screeninfo
#: index.docbook:639
#, no-c-format
msgid "Creating a metalink2"
msgstr "मेटालिङ्कस्य निर्माणम्2"

#. Tag: phrase
#: index.docbook:645
#, no-c-format
msgid "Creating a Metalink2"
msgstr "मेटालिङ्कस्य निर्माणम्2"

#. Tag: para
#: index.docbook:649
#, no-c-format
msgid ""
"Here you have to enter the &URL; from where you are trying to download the "
"file. Also you can enter some optional information such as Preference "
"(Priority) for a particular mirror if you are adding more then one mirrors, "
"for the file you want to download."
msgstr ""
"अत्र भवद्भिः &URL; यतः भवन्तः सञ्चिकां डाउनलोड् कर्तुं प्रयतन्ते । अपि च भवान् किञ्चित् "
"वैकल्पिकं सूचनां प्रविष्टुं शक्नोति यथा कस्यचित् विशेषदर्पणस्य कृते Preference (Priority) यदि "
"भवान् एकस्मात् अधिकं दर्पणं योजयति तर्हि, यत् सञ्चिकां भवान् अवतरणं कर्तुम् इच्छति तस्य कृते ।"

#. Tag: screeninfo
#: index.docbook:652
#, no-c-format
msgid "Creating a metalink 3"
msgstr "मेटालिङ्कस्य निर्माणम् 3"

#. Tag: phrase
#: index.docbook:658
#, no-c-format
msgid "Creating a Metalink 3"
msgstr "मेटालिङ्कस्य निर्माणम् 3"

#. Tag: para
#: index.docbook:662
#, no-c-format
msgid ""
"You should be able to see a new window where all your files which will be "
"imported will be shown."
msgstr ""
"भवन्तः नूतनं विण्डो द्रष्टुं शक्नुवन्ति यत्र भवतः सर्वाणि सञ्चिकाः दर्शिताः भविष्यन्ति ये "
"आयाताः भविष्यन्ति ।"

#. Tag: menuchoice
#: index.docbook:667
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>H</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Transfer History</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>H</keycap></keycombo> </"
"shortcut> <guimenu>सञ्चिका</guimenu> <guimenuitem>स्थानांतरण-इतिहासः</"
"guimenuitem>"

#. Tag: screeninfo
#: index.docbook:676
#, no-c-format
msgid "<screeninfo>Transfer History</screeninfo>"
msgstr "<screeninfo>स्थानांतरण-इतिहासः</screeninfo>"

#. Tag: phrase
#: index.docbook:682
#, no-c-format
msgid "<phrase>Transfer History</phrase>"
msgstr "<phrase>स्थानांतरण इतिहास</phrase>"

#. Tag: action
#: index.docbook:686
#, no-c-format
msgid ""
"Opens a new window where you can see all the files downloaded using &kget;. "
"You can manage your history here, including filter and clear the history."
msgstr ""
"नूतनं विण्डो उद्घाटयति यत्र भवान् &kget; इत्यस्य उपयोगेन अवतरणं कृतानि सर्वाणि सञ्चिकाः "
"द्रष्टुं शक्नोति । भवान् अत्र स्वस्य इतिहासं प्रबन्धयितुं शक्नोति, यत्र इतिहासं छानयित्वा स्वच्छं "
"कर्तुं शक्नोति ।"

#. Tag: menuchoice
#: index.docbook:691
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>Q</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Quit</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>प्रश्न</keycap></keycombo> "
"</shortcut> <guimenu>सञ्चिका</guimenu> <guimenuitem>निर्गम</guimenuitem>"

