msgid "<keyword>KDE</keyword>"
msgstr "<keyword>WHERE</keyword> इति"

#. Tag: keyword
#: index.docbook:22
#, no-c-format
msgid "System Settings"
msgstr "सिस्टम् सेटिंग्स्"

#. Tag: keyword
#: index.docbook:23
#, no-c-format
msgid "style"
msgstr "शैली"

#. Tag: keyword
