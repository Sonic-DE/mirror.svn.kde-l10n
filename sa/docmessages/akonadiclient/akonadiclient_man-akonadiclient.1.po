#. Tag: option
#: man-akonadiclient.1.docbook:323
#, no-c-format
msgid "-c, --comment <replaceable>name</replaceable>"
msgstr "-ग, --टिप्पणी <प्रतिस्थापनीय>नाम</प्रतिस्थापनीय>"

#. Tag: para
#: man-akonadiclient.1.docbook:324
#, no-c-format
msgid "Email comment (name) for an added item"
msgstr "योजितस्य द्रव्यस्य कृते टिप्पणीं (नाम) ईमेल कुर्वन्तु"

#. Tag: para
#: man-akonadiclient.1.docbook:329
#, no-c-format
msgid "Brief output (for 'expand', email addresses only)"
msgstr "संक्षिप्तं निर्गमं ('विस्तार' कृते, केवलं ईमेल-सङ्केताः)"

#. Tag: option
#: man-akonadiclient.1.docbook:343
#, no-c-format
msgid "import"
msgstr "आयात"

#. Tag: para
#: man-akonadiclient.1.docbook:345
#, no-c-format
msgid "akonadiclient import [OPTIONS] PARENT FILE"
msgstr "akonadiclient आयात [विकल्पाः] मातापितृसञ्चिका"

#. Tag: para
#: man-akonadiclient.1.docbook:346
#, no-c-format
msgid ""
"Imports an XML file inside the collection specified by PARENT. If the "
"collection already exists, its contents are merged with the contents of the "
"collection in the XML file."
msgstr ""
"PARENT द्वारा निर्दिष्टस्य संग्रहस्य अन्तः XML सञ्चिकां आयातयति । यदि संग्रहः पूर्वमेव अस्ति "
"तर्हि तस्य सामग्रीः XML सञ्चिकायां संग्रहस्य सामग्रीभिः सह विलीनः भवति ।"

#. Tag: option
#: man-akonadiclient.1.docbook:360
#, no-c-format
msgid "info"
msgstr "info"

#. Tag: para
#: man-akonadiclient.1.docbook:362
#, no-c-format
msgid "akonadiclient info [OPTIONS] COLLECTION | ITEM"
msgstr "akonadiclient info [विकल्प] संग्रह | वस्तु"

#. Tag: para
#: man-akonadiclient.1.docbook:363
#, no-c-format
msgid "Show full information about a collection or item"
msgstr "संग्रहस्य वा वस्तुनः विषये पूर्णसूचनाः दर्शयन्तु"

#. Tag: para
#: man-akonadiclient.1.docbook:369
#, no-c-format
msgid "Assume that a collection is specified"
msgstr "संग्रहः निर्दिष्टः इति कल्पयतु"

#. Tag: para
#: man-akonadiclient.1.docbook:374
#, no-c-format
msgid "Assume that an item is specified"
msgstr "कल्पयतु यत् कश्चन द्रव्यः निर्दिष्टः अस्ति"

#. Tag: option
#: man-akonadiclient.1.docbook:382
#, no-c-format
msgid "show"
msgstr "दर्शयतु"

#. Tag: para
#: man-akonadiclient.1.docbook:384
#, no-c-format
msgid "akonadiclient show ITEM"
msgstr "akonadiclient शो ITEM"

#. Tag: para
#: man-akonadiclient.1.docbook:385
#, no-c-format
msgid "Shows the raw payload of an item"
msgstr "कस्यचित् द्रव्यस्य कच्चं पेलोड् दर्शयति"

#. Tag: option
#: man-akonadiclient.1.docbook:390
#, no-c-format
msgid "tags"
msgstr "टैग्स"

#. Tag: para
#: man-akonadiclient.1.docbook:392
#, no-c-format
msgid "akonadiclient tags [OPTIONS]"
msgstr "akonadiclient टैग [विकल्प]।"

#. Tag: para
#: man-akonadiclient.1.docbook:393
#, no-c-format
msgid "List all known tags"
msgstr "सर्वाणि ज्ञातानि टैग्स् सूचीबद्धानि कुर्वन्तु"

#. Tag: para
#: man-akonadiclient.1.docbook:399
#, no-c-format
msgid "Brief output - tag names only"
msgstr "संक्षिप्तं उत्पादनम् - केवलं टैगनामानि"

#. Tag: option
#: man-akonadiclient.1.docbook:403
#, no-c-format
msgid "-u, --urls"
msgstr "-उ, --उर्ल्स"

#. Tag: para
#: man-akonadiclient.1.docbook:404
#, no-c-format
msgid "Brief output - tag URLs only"
msgstr "संक्षिप्तं आउटपुट् - केवलं टैग् URLs"

#. Tag: option
#: man-akonadiclient.1.docbook:412
#, no-c-format
msgid "update"
msgstr "अद्यतन"

#. Tag: para
#: man-akonadiclient.1.docbook:414
#, no-c-format
msgid "akonadiclient update [OPTIONS] ITEM FILE"
msgstr "akonadiclient update [विकल्पाः] ITEM FILE"

#. Tag: para
#: man-akonadiclient.1.docbook:415
#, no-c-format
msgid "Updates the raw payload of ITEM with the contents of FILE"
msgstr "ITEM इत्यस्य कच्चा पेलोड् FILE इत्यस्य सामग्रीभिः सह अद्यतनं करोति"

#. Tag: title
#: man-akonadiclient.1.docbook:432
#, no-c-format
msgid "Miscellaneous Commands"
msgstr "विविधाः आदेशाः"

#. Tag: option
#: man-akonadiclient.1.docbook:436
#, no-c-format
msgid "agents"
msgstr "एजेण्ट्"

#. Tag: para
#: man-akonadiclient.1.docbook:438
#, no-c-format
msgid "akonadiclient agents [OPTIONS] [AGENTS...]"
msgstr "akonadiclient एजेण्ट् [OPTIONS] [AGENTS...]"

#. Tag: para
#: man-akonadiclient.1.docbook:439
#, no-c-format
msgid ""
"Allows managing of Akonadi agents like changing their state, restarting an "
"agent or listing all agents and their state."
msgstr ""
"अकोनाडी एजेण्ट् इत्यस्य प्रबन्धनं यथा तेषां राज्यं परिवर्तयितुं, एजेण्ट् पुनः आरभ्यतुं वा सर्वेषां "
"एजेण्ट्-समूहानां तेषां राज्यस्य च सूचीकरणस्य अनुमतिं ददाति ।"

#. Tag: option
#: man-akonadiclient.1.docbook:444
#, no-c-format
msgid "-l, --list"
msgstr "-l, --सूची"

#. Tag: para
#: man-akonadiclient.1.docbook:445
#, no-c-format
msgid "List all agents"
msgstr "सर्वेषां एजेण्ट्-समूहानां सूचीं कुर्वन्तु"

#. Tag: option
#: man-akonadiclient.1.docbook:449
#, no-c-format
msgid "-s, --setstate <replaceable>state</replaceable>"
msgstr "-s, --setstate <प्रतिस्थापनीय>स्थिति</प्रतिस्थापनीय>"

#. Tag: para
#: man-akonadiclient.1.docbook:450
#, no-c-format
msgid ""
"Set the state for specified agents. Valid states are 'offline' and 'online'."
msgstr ""
"निर्दिष्टानां एजेण्ट्-कृते राज्यं सेट् कुर्वन्तु । वैध अवस्थाः 'अफलाइन' 'अनलाइन' च सन्ति ।"

#. Tag: option
#: man-akonadiclient.1.docbook:454
#, no-c-format
msgid "-g, --getstate"
msgstr "-ग, --गेटस्टेट्"

#. Tag: para
#: man-akonadiclient.1.docbook:455
#, no-c-format
msgid "Get the state for specified agents"
msgstr "निर्दिष्टानां एजेण्टानां कृते राज्यं प्राप्नुवन्तु"

#. Tag: option
#: man-akonadiclient.1.docbook:459
#, no-c-format
msgid "-i, --info"
msgstr "-i, --info"

#. Tag: para
#: man-akonadiclient.1.docbook:460
#, no-c-format
msgid "Show information about the specified agents"
msgstr "निर्दिष्टानां एजेण्ट्-विषये सूचनां दर्शयतु"

#. Tag: option
#: man-akonadiclient.1.docbook:464
#, no-c-format
msgid "-r, --restart"
msgstr "-र, --पुनः आरभत"

#. Tag: para
#: man-akonadiclient.1.docbook:465
#, no-c-format
msgid "Restarts the specified agents"
msgstr "निर्दिष्टान् एजेण्ट् पुनः आरभते"

#. Tag: option
#: man-akonadiclient.1.docbook:478
#, no-c-format
msgid "help"
msgstr "साहाय्यम्‌"

#. Tag: para
#: man-akonadiclient.1.docbook:480
#, no-c-format
msgid "akonadiclient help [COMMAND]"
msgstr "akonadiclient सहायता [आज्ञा]।"

#. Tag: para
#: man-akonadiclient.1.docbook:481
#, no-c-format
msgid ""
"Displays help for COMMAND. If COMMAND is not specified then it lists all the "
"available commands"
msgstr ""
"COMMAND कृते सहायतां प्रदर्शयति । यदि COMMAND निर्दिष्टं नास्ति तर्हि सर्वान् उपलब्धान् "
"आदेशान् सूचीबद्धं करोति"

#. Tag: option
#: man-akonadiclient.1.docbook:486
#, no-c-format
msgid "shell"
msgstr "कोष्ठ"

#. Tag: para
#: man-akonadiclient.1.docbook:488
#, no-c-format
msgid "akonadiclient shell"
msgstr "अकोनाडिक्लिन्ट् शंखम्"

#. Tag: para
#: man-akonadiclient.1.docbook:489
#, no-c-format
msgid "Enter commands in an interactive shell"
msgstr "एकस्मिन् अन्तरक्रियाशील-शेल् मध्ये आदेशान् प्रविशन्तु"

#. Tag: title
#: man-akonadiclient.1.docbook:497
#, no-c-format
msgid "Examples"
msgstr "उदाहरणानि"

#. Tag: para
#: man-akonadiclient.1.docbook:498
#, no-c-format
msgid ""
"<emphasis role=\"bold\">akonadiclient list /</emphasis> - Lists all the "
"collections under the root collection"
msgstr ""
"<emphasis role=\"bold\">akonadiclient list /</emphasis> - मूलसङ्ग्रहस्य अधः "
"सर्वान् संग्रहान् सूचीबद्धं करोति"

#. Tag: para
#: man-akonadiclient.1.docbook:499
#, no-c-format
msgid ""
"<emphasis role=\"bold\">akonadiclient export /Notes notes.xml</emphasis> - "
"Exports all the items and sub-collections of the /Notes collection to the "
"file 'notes.xml'"
msgstr ""
"<emphasis role=\"bold\">akonadiclient export /Notes notes.xml</emphasis> - /"
"Notes संग्रहस्य सर्वाणि वस्तूनि उपसङ्ग्रहाणि च 'notes.xml' इति सञ्चिकायां निर्यातयति ।"

#. Tag: para
#: man-akonadiclient.1.docbook:500
#, no-c-format
msgid ""
"<emphasis role=\"bold\">akonadiclient agents -l</emphasis> - Lists all agents"
msgstr ""
"<emphasis role=\"bold\">akonadiclient एजेण्ट् -l</emphasis> - सर्वान् एजेण्ट् सूचीबद्धं "
"करोति"

#. Tag: para
#: man-akonadiclient.1.docbook:501
#, no-c-format
msgid ""
"<emphasis role=\"bold\">akonadiclient add /Notes note.txt</emphasis> - Adds "
"the contents of the file note.txt as an item in the collection /Notes"
msgstr ""
"<emphasis role=\"bold\">akonadiclient add /Notes note.txt</emphasis> - /"
"Notes इति संग्रहे note.txt इति सञ्चिकायाः सामग्रीं योजयति"

#. Tag: para
#: man-akonadiclient.1.docbook:502
#, no-c-format
msgid ""
"<emphasis role=\"bold\">akonadiclient add -m application/x-vnd.akonadi."
"calendar.todo /Todos todo.ics</emphasis> - Adds the contents of the file "
"todo.ics as a TODO calendar entry in the collection /Todos"
msgstr ""
"<emphasis role=\"bold\">akonadiclient add -m application/x-vnd.akonadi."
"calendar.todo /Todos todo.ics</emphasis> - todo.ics सञ्चिकायाः सामग्रीं संग्रहे "
"TODO पञ्चाङ्गप्रविष्टिरूपेण योजयति /टोडोस्"
