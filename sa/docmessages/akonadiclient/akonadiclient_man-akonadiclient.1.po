#: man-akonadiclient.1.docbook:314
#, no-c-format
msgid "Delete a contact from the group"
msgstr "समूहात् सम्पर्कं विलोपयन्तु"

#. Tag: option
#: man-akonadiclient.1.docbook:318
#, no-c-format
