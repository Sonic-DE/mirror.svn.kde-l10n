#. Tag: option
#: man-akonadiclient.1.docbook:278
#, no-c-format
msgid "export"
msgstr "निर्यात"

#. Tag: para
#: man-akonadiclient.1.docbook:280
#, no-c-format
msgid "akonadiclient export [OPTIONS] COLLECTION FILE"
msgstr "akonadiclient निर्यात [विकल्पाः] संग्रहणसञ्चिका"

#. Tag: para
#: man-akonadiclient.1.docbook:281
#, no-c-format
msgid ""
"Export the collection specified by COLLECTION to an XML file specified by "
"FILE."
msgstr ""
"COLLECTION द्वारा निर्दिष्टं संग्रहं FILE द्वारा निर्दिष्टे XML सञ्चिकायां निर्यातयन्तु ।"

#. Tag: option
#: man-akonadiclient.1.docbook:295
#, no-c-format
msgid "group"
msgstr "समूह"

#. Tag: para
#: man-akonadiclient.1.docbook:297
#, no-c-format
msgid "akonadiclient group [OPTIONS] GROUP ARGS"
msgstr "akonadiclient group [विकल्प] समूह ARGS"

#. Tag: para
#: man-akonadiclient.1.docbook:298
#, no-c-format
