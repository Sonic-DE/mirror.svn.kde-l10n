msgstr "maildir निर्देशिकासंरचने ईमेलसन्देशान् डम्प कुर्वन्तु"

#. Tag: option
#: man-akonadiclient.1.docbook:225
#, no-c-format
msgid "-a, --akonadi-categories"
msgstr "-क, --अकोनादि-वर्गाः"

#. Tag: para
#: man-akonadiclient.1.docbook:226
#, no-c-format
msgid "Dump items with Akonadi categories, otherwise text"
msgstr "अकोनाडी श्रेणीभिः सह वस्तूनि डम्प कुर्वन्तु, अन्यथा पाठः"

#. Tag: option
#: man-akonadiclient.1.docbook:230
#, no-c-format
msgid "-f, --force"
msgstr "-च, --बलम्"

#. Tag: para
#: man-akonadiclient.1.docbook:231
#, no-c-format
msgid "Operate even if destination directory is not empty"
msgstr "गन्तव्यनिर्देशिका रिक्तं नास्ति चेदपि कार्यं कुर्वन्तु"

#. Tag: option
#: man-akonadiclient.1.docbook:244
#, no-c-format
msgid "edit"
msgstr "सम्पादन"

#. Tag: para
#: man-akonadiclient.1.docbook:246
#, no-c-format
