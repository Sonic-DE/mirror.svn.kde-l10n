#. Tag: menuchoice
#: commands.docbook:781
#, no-c-format
msgid "<guimenu>Data</guimenu> <guimenuitem>Sort...</guimenuitem>"
msgstr "<guimenu>दत्तांशः</guimenu> <guimenuitem>क्रमणं...</guimenuitem>"

#. Tag: para
#: commands.docbook:785
#, no-c-format
msgid ""
"<action>Sort data in selected cells.</action> See the section <link linkend="
"\"sort\">Sorting Data</link> for more details."
msgstr ""
"<action>चयनितकोष्ठकेषु दत्तांशं क्रमयन्तु ।</action> खण्डं पश्यन्तु<link linkend=\"sort\"> "
"दत्तांशस्य क्रमणं करणम्</link> अधिकविवरणार्थम्।"

#. Tag: menuchoice
#: commands.docbook:791
#, no-c-format
msgid "<guimenu>Data</guimenu> <guimenuitem>Text to Columns...</guimenuitem>"
msgstr "<guimenu>दत्तांशः</guimenu> <guimenuitem>स्तम्भानां पाठः...</guimenuitem>"

#. Tag: para
#: commands.docbook:795
#, no-c-format
msgid ""
"This option attempts to interpret text in the selected cell(s) as "
"<acronym>CSV</acronym> data, placing each item into a different cell in the "
"row."
msgstr ""
"एषः विकल्पः चयनितकोष्ठके (कोष्ठकेषु) पाठस्य व्याख्यां <acronym>CSV</acronym> दत्तांशरूपेण "
"कर्तुं प्रयतते, प्रत्येकं द्रव्यं पङ्क्तौ भिन्नकोष्ठके स्थापयति ।"

#. Tag: menuchoice
#: commands.docbook:802
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>G</keycap></"
"keycombo> </shortcut> <guimenu>Data</guimenu> <guimenuitem>Named Areas...</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>G</keycap></"
"keycombo> </shortcut> <guimenu>दत्तांश</guimenu> <guimenuitem>नामकृतक्षेत्राणि...</"
"guimenuitem >"

#. Tag: para
#: commands.docbook:809
#, no-c-format
msgid ""
"<action>Open</action> the <guilabel>Named Areas</guilabel> dialog to select, "
"add, edit and remove named areas. See the section <link linkend=\"namedareas"
"\">Named Cells and Areas</link> for further details."
msgstr ""
"<action>उद्घाटित</action> the<guilabel> नामित क्षेत्र</guilabel> नामकृतक्षेत्राणां "
"चयनं, योजयितुं, सम्पादयितुं, निष्कासयितुं च संवादः । खण्डं पश्यन्तु<link linkend="
"\"namedareas\"> कोष्ठकाः क्षेत्राणि च नामकृतानि</link> अधिकविवरणार्थम्।"

#. Tag: menuchoice
#: commands.docbook:816
#, no-c-format
msgid "<guimenu>Data</guimenu> <guimenuitem>Consolidate...</guimenuitem>"
msgstr "<guimenu>दत्तांशः</guimenu> <guimenuitem>एकीकरणं कुर्वन्तु...</guimenuitem>"

#. Tag: para
#: commands.docbook:820
#, no-c-format
msgid ""
"<action>Consolidate data.</action> See the section <link linkend="
"\"consolidate\">Consolidating Data</link> for more details."
msgstr ""
"<action>दत्तांशं समेकयन्तु।</action> खण्डं पश्यन्तु<link linkend=\"consolidate\"> "
"दत्तांशस्य समेकनम्</link> अधिकविवरणार्थम्।"

#. Tag: menuchoice
#: commands.docbook:826
#, no-c-format
msgid "<guimenu>Data</guimenu> <guimenuitem>Subtotals...</guimenuitem>"
msgstr "<guimenu>दत्तांश</guimenu> <guimenuitem>उपसङ्ख्याः...</guimenuitem>"

#. Tag: action
#: commands.docbook:830
#, no-c-format
msgid "Create different kinds of subtotals to a database."
msgstr "दत्तांशकोशे भिन्नप्रकारस्य उपकुलं रचयन्तु ।"

#. Tag: menuchoice
#: commands.docbook:836
#, no-c-format
msgid "<guimenu>Data</guimenu> <guimenuitem>Validity...</guimenuitem>"
msgstr "<guimenu>दत्तांश</guimenu> <guimenuitem>वैधता...</guimenuitem>"

#. Tag: para
#: commands.docbook:840
#, no-c-format
msgid ""
"<action>Set or modify the error checking criteria and error alert message "
"for selected cell(s).</action> See <link linkend=\"validcheck\"> Validity "
"Checking</link> for more details."
msgstr ""
"<action>चयनितकोष्ठकानां (कोष्ठकानां) कृते त्रुटिपरीक्षणमापदण्डं त्रुटिसचेतनासन्देशं च सेट् "
"कुर्वन्तु अथवा परिवर्तयन्तु ।</action> पश्यतु<link linkend=\"validcheck\"> वैधता जाँच</"
"link> अधिकविवरणार्थम्।"

#. Tag: menuchoice
#: commands.docbook:847
#, no-c-format
msgid "<guimenu>Data</guimenu> <guimenuitem>Goal Seek...</guimenuitem>"
msgstr "<guimenu>दत्तांश</guimenu> <guimenuitem>लक्ष्यं अन्वेष्टुम्...</guimenuitem>"

#. Tag: para
#: commands.docbook:851
#, no-c-format
msgid ""
"<action>Open the Goal Seek dialog box</action>. See <link linkend=\"goalseek"
"\">Goal Seeking</link> for details."
msgstr ""
"<action>Goal Seek इति संवादपेटिकां उद्घाटयन्तु</action> . पश्यतु<link linkend="
"\"goalseek\"> लक्ष्यार्थी</link> विस्तरेण कृते।"

#. Tag: menuchoice
#: commands.docbook:857
#, no-c-format
msgid "<guimenu>Data</guimenu> <guimenuitem>Pivot...</guimenuitem>"
msgstr "<guimenu>दत्तांश</guimenu> <guimenuitem>पिवट्...</guimenuitem>"

#. Tag: para
#: commands.docbook:861
#, no-c-format
msgid ""
"<action>Open the Pivot Table configuration dialog</action>. See <link "
"linkend=\"pivottable\">Pivot Table</link> for details."
msgstr ""
"<action>Pivot Table विन्याससंवादं उद्घाटयन्तु</action> . पश्यतु<link linkend="
"\"pivottable\"> धुरी सारणी</link> विस्तरेण कृते।"

#. Tag: title
#: commands.docbook:870
#, no-c-format
msgid "The Tools Menu"
msgstr "Tools Menu इति"

#. Tag: menuchoice
#: commands.docbook:874
#, no-c-format
msgid "<guimenu>Tools</guimenu> <guimenuitem>Spelling...</guimenuitem>"
msgstr "<guimenu>उपकरणं</guimenu> <guimenuitem>वर्तनी...</guimenuitem>"

#. Tag: action
#: commands.docbook:878
#, no-c-format
msgid "Check spelling of words in the worksheet."
msgstr "कार्यपत्रके शब्दानां वर्तनीम् अवलोकयन्तु।"

#. Tag: menuchoice
#: commands.docbook:883
#, no-c-format
msgid "<guimenu>Tools</guimenu> <guimenuitem>Custom Lists...</guimenuitem>"
msgstr "<guimenu>उपकरणं</guimenu> <guimenuitem>अनुकूलसूची...</guimenuitem>"

#. Tag: action
#: commands.docbook:887
#, no-c-format
msgid ""
"View or amend the special series of words recognized by &sheets;. These list "
"can be used to insert special <link linkend=\"series\">series</link> into "
"the worksheet."
msgstr ""
"&amp;sheets;द्वारा ज्ञातानां शब्दानां विशेषश्रृङ्खलां पश्यन्तु अथवा संशोधनं कुर्वन्तु। एताः "
"सूचीः विशेषं सम्मिलितुं उपयोक्तुं शक्यन्ते<link linkend=\"series\"> श्रेणी</link> कार्यपत्रके "
"अन्तः ।"

#. Tag: menuchoice
#: commands.docbook:893
#, no-c-format
msgid "<guimenu>Tools</guimenu> <guimenuitem>Protect Sheet...</guimenuitem>"
msgstr ""
"<guimenu>उपकरणाः</guimenu> <guimenuitem>पत्रस्य रक्षणं कुर्वन्तु...</guimenuitem>"

#. Tag: action
#: commands.docbook:898
#, no-c-format
msgid ""
"Protect the sheet with a password. A dialog pops up prompting you for a "
"password. Unchecking this option will prompt you for the password in order "
"to unprotect the sheet. Protecting a sheet means protecting all cells in the "
"sheet. In a protected sheet, the cells cannot be reformatted or overwritten."
msgstr ""
"गुप्तशब्देन पत्रस्य रक्षणं कुर्वन्तु। एकं संवादं भवन्तं गुप्तशब्दं प्रार्थयति । एतत् विकल्पं अनचेक् कृत्वा "
"पत्रस्य रक्षणार्थं गुप्तशब्दं प्रार्थयिष्यति । पत्रस्य रक्षणस्य अर्थः पत्रे स्थितानां सर्वेषां "
"कोशिकानां रक्षणम् । संरक्षितपत्रे कोष्ठकानां पुनः स्वरूपणं वा अधिलेखनं वा कर्तुं न शक्यते ।"

#. Tag: menuchoice
#: commands.docbook:903
#, no-c-format
msgid "<guimenu>Tools</guimenu> <guimenuitem>Protect Document...</guimenuitem>"
msgstr ""
"<guimenu>उपकरणाः</guimenu> <guimenuitem>दस्तावेजस्य रक्षणं कुर्वन्तु...</guimenuitem>"

#. Tag: action
#: commands.docbook:908
#, no-c-format
msgid ""
"Protect the whole document with a password. A dialog pops up prompting you "
"for a password. Unchecking this option will prompt you for the password in "
"order to unprotect the document. In a protected document you cannot rename "
"or remove a sheet. Document protection does not mean that each individual "
"sheet is protected."
msgstr ""
"गुप्तशब्देन सम्पूर्णं दस्तावेजं रक्षन्तु । एकं संवादं भवन्तं गुप्तशब्दं प्रार्थयति । एतत् विकल्पं अनचेक् "
"कृत्वा दस्तावेजस्य रक्षणार्थं गुप्तशब्दं प्रार्थयिष्यति । संरक्षितदस्तावेजे भवान् पत्रस्य नाम "
"परिवर्तयितुं वा निष्कासयितुं वा न शक्नोति । दस्तावेजसंरक्षणस्य अर्थः न भवति यत् प्रत्येकं "
"व्यक्तिगतपत्रं रक्षितम् अस्ति ।"

#. Tag: menuchoice
#: commands.docbook:917
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Shift;<keysym>F9</keysym></keycombo> "
"</shortcut> <guimenu>Tools</guimenu> <guimenuitem>Recalculate Sheet</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Shift;<keysym>F9</keysym></keycombo> "
"</shortcut> <guimenu>उपकरण</guimenu> <guimenuitem>पत्रस्य पुनः गणना</"
"guimenuitem>"

#. Tag: action
#: commands.docbook:924
#, no-c-format
msgid "Recalculate formulae in the current sheet."
msgstr "वर्तमानपत्रे सूत्राणां पुनः गणनां कुर्वन्तु।"

#. Tag: menuchoice
#: commands.docbook:929
#, no-c-format
msgid ""
"<shortcut> <keysym>F9</keysym> </shortcut> <guimenu>Tools</guimenu> "
"<guimenuitem>Recalculate Document</guimenuitem>"
msgstr ""
"<shortcut> <keysym>F9</keysym> </shortcut> <guimenu>उपकरणं</guimenu> "
"<guimenuitem>दस्तावेजस्य पुनः गणना</guimenuitem>"

#. Tag: action
#: commands.docbook:936
#, no-c-format
msgid "Recalculate all sheets."
msgstr "सर्वाणि पत्राणि पुनः गणयन्तु।"

#. Tag: menuchoice
#: commands.docbook:952
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu> <guimenuitem>Execute Script File...</guimenuitem>"
msgstr ""
"<guimenu>उपकरणाः</guimenu> <guimenuitem>स्क्रिप्टसञ्चिकां निष्पादयन्तु...</"
"guimenuitem>"

#. Tag: para
#: commands.docbook:956
#, no-c-format
msgid ""
"Execute the chosen external script in &sheets;. &sheets; supports scripting "
"in JavaScript, Python and Ruby. Default examples of the scripts can be found "
"in the <menuchoice><guimenu>Tools</guimenu><guisubmenu>Scripts</guisubmenu></"
"menuchoice> submenu."
msgstr ""
"&sheets;मध्ये चयनितं बाह्यलिपिं निष्पादयन्तु । &sheets; जावास्क्रिप्ट्, पायथन्, रुबी च "
"इत्यत्र स्क्रिप्टिङ्ग् समर्थयति । स्क्रिप्ट्-समूहस्य पूर्वनिर्धारित-उदाहरणानि "
"<menuchoice><guimenu>Tools</guimenu><guisubmenu>स्क्रिप्ट्</guisubmenu></"
"menuchoice> उपमेनू मध्ये प्राप्यन्ते ।"

#. Tag: menuchoice
#: commands.docbook:960
#, no-c-format
msgid "<guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu>"
msgstr "<guimenu>उपकरणं</guimenu> <guisubmenu>स्क्रिप्ट्</guisubmenu>"

#. Tag: para
#: commands.docbook:964
#, no-c-format
msgid ""
"Here you can execute the script to export or import data in various formats, "
"save your &sheets; log into file, use <ulink url=\"https://live.gnome.org/"
"Orca\">Orca speech</ulink> for accessibility, debug Python and Ruby scripts "
"or add functions to display stock or weather condition values. You can even "
"use some <ulink url=\"http://www.r-project.org/\">R functions</ulink> "
"(<ulink url=\"http://rpy.sourceforge.net/rpy.html\">RPy module</ulink> "
"should be installed)."
msgstr ""
"अत्र भवान् विभिन्नस्वरूपेषु दत्तांशं निर्यातयितुं आयातयितुं वा स्क्रिप्ट् निष्पादयितुं शक्नोति, "
"स्वस्य &sheets; सञ्चिकायां प्रवेशं कुर्वन्तु, अभिगम्यतायै <ulink url=\"https://live.gnome."
"org/Orca\">Orca speech</ulink> इत्यस्य उपयोगं कुर्वन्तु, Python तथा Ruby स्क्रिप्ट् "
"इत्येतयोः त्रुटिनिवारणं कुर्वन्तु अथवा स्टॉक् अथवा मौसमस्य स्थितिमूल्यानि प्रदर्शयितुं कार्याणि "
"योजयन्तु भवन्तः केचन <ulink url=\"http://www.r-project.org/\">R कार्याणि</ulink> "
"(<ulink url=\"http://rpy.sourceforge.net/rpy.html\" अपि उपयोक्तुं शक्नुवन्ति। >RPy "
"मॉड्यूल</ulink> संस्थापनीयम्)।"

#. Tag: menuchoice
#: commands.docbook:968
#, no-c-format
msgid "<guimenu>Tools</guimenu> <guimenuitem>Script Manager...</guimenuitem>"
msgstr ""
"<guimenu>उपकरणाः</guimenu> <guimenuitem>स्क्रिप्ट् प्रबन्धकः...</guimenuitem>"

#. Tag: para
#: commands.docbook:972
#, no-c-format
msgid ""
"<action>Opens</action> the <guilabel>Scripts Manager</guilabel> dialog to "
"execute, load, unload, install, uninstall and get more scripts."
msgstr ""
"<action>अधिकानि स्क्रिप्ट् निष्पादयितुं, लोड् कर्तुं, अनलोड् कर्तुं, संस्थापनं कर्तुं, विस्थापयितुं, "
"अधिकानि स्क्रिप्ट् प्राप्तुं च <guilabel>Scripts Manager</guilabel> संवादं उद्घाटयति</"
"action> ।"

#. Tag: menuchoice
#: commands.docbook:977
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu> <guimenuitem>Function Optimizer...</guimenuitem>"
msgstr "<guimenu>उपकरणाः</guimenu> <guimenuitem>कार्य अनुकूलकः...</guimenuitem>"

#. Tag: para
#: commands.docbook:981
#, no-c-format
msgid ""
"<action>Opens</action> the <guilabel>Function Optimizer</guilabel> dialog "
"where you can choose an objective function cell, optimization target "
"(<guilabel>Maximize</guilabel>, <guilabel>Minimize</guilabel> or enter the "
"<guilabel>Value</guilabel>) and a set of decision parameter cells."
msgstr ""
"<action> <guilabel>कार्यअनुकूलकः</guilabel> संवादं उद्घाटयति</action> यत्र भवान् "
"उद्देश्यपूर्णं कार्यकोशं, अनुकूलनलक्ष्यं (<guilabel>अधिकतमं</guilabel>, <guilabel>न्यूनतमं</"
"guilabel> अथवा प्रविष्टुं शक्नोति <guilabel>Value</guilabel>) तथा निर्णयपैरामीटर् "
"कोष्ठकानां समुच्चयः ।"

#. Tag: title
#: commands.docbook:988
#, no-c-format
msgid "The Settings Menu"
msgstr "सेटिंग्स् मेन्यू इति"

#. Tag: menuchoice
#: commands.docbook:992
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guisubmenu>Toolbars Shown</guisubmenu>"
msgstr "<guimenu>सेटिंग्स्</guimenu> <guisubmenu>उपकरणपट्टिकाः दर्शिताः</guisubmenu>"

#. Tag: action
#: commands.docbook:996
#, no-c-format
msgid ""
"Show or hide the toolbars: <guilabel>File</guilabel>, <guilabel>Edit</"
"guilabel>, <guilabel>Navigation</guilabel>, <guilabel>Font</guilabel>, "
"<guilabel>Format</guilabel> and <guilabel>Color/Border</guilabel>."
msgstr ""
"साधनपट्टिकाः दर्शयन्तु अथवा गोपयन्तु : <guilabel>सञ्चिका</guilabel>, "
"<guilabel>सम्पादनं</guilabel>, <guilabel>नेविगेशन</guilabel>, <guilabel>फ़ॉन्ट्</"
"guilabel>, <guilabel>स्वरूप</guilabel> तथा <guilabel>वर्ण/सीमा</guilabel>।"

#. Tag: menuchoice
#: commands.docbook:1015
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Status Bar</guimenuitem>"
msgstr "<guimenu>सेटिंग्स्</guimenu> <guimenuitem>स्थितिपट्टिका</guimenuitem>"

#. Tag: para
#: commands.docbook:1019
#, no-c-format
msgid ""
"<action>Show or hide the Status Bar.</action> The Status Bar shows "
"additional information for selected items and instant calculations of the "
"selected cells."
msgstr ""
"<action>स्थितिपट्टिकां दर्शयतु अथवा गोपयतु।</action> स्थितिपट्टिका चयनितवस्तूनाम् "
"अतिरिक्तसूचनाः चयनितकोष्ठकानां तत्क्षणगणनाञ्च दर्शयति ।"

#. Tag: menuchoice
#: commands.docbook:1026
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Tab Bar</guimenuitem>"
msgstr "<guimenu>सेटिंग्स्</guimenu> <guimenuitem>ट्याब्बार</guimenuitem>"

#. Tag: para
#: commands.docbook:1030
#, no-c-format
msgid ""
"<action>Show or hide the Tab Bar.</action> All Sheets of the current "
"Document can be accessed through the Tab Bar."
msgstr ""
"<action>Tab Bar दर्शयतु अथवा गोपयतु।</action> वर्तमान Document इत्यस्य सर्वाणि "
"Sheets Tab Bar मार्गेण प्राप्तुं शक्यन्ते ।"

#. Tag: menuchoice
#: commands.docbook:1036
#, no-c-format
msgid ""
"<guimenu>Settings</guimenu> <guimenuitem>Configure Shortcuts...</guimenuitem>"
msgstr ""
"<guimenu>सेटिंग्स्</guimenu> <guimenuitem>शॉर्टकट् विन्यस्तं कुर्वन्तु...</guimenuitem>"

#. Tag: para
#: commands.docbook:1040
#, no-c-format
msgid ""
"<action>Configure the keyboard shortcuts used by &sheets;. </action> See the "
"section on <link linkend=\"configshort\">configuring shortcuts </link> for "
"more details."
msgstr ""
"<action>&amp;sheets;द्वारा उपयुज्यमानं कीबोर्डशॉर्टकट् विन्यस्यताम् ।</action> विषये "
"खण्डं पश्यन्तु<link linkend=\"configshort\"> शॉर्टकट् विन्यस्तं कुर्वन्</link> "
"अधिकविवरणार्थम्।"

#. Tag: menuchoice
#: commands.docbook:1048
#, no-c-format
msgid ""
"<guimenu>Settings</guimenu> <guimenuitem>Configure Toolbars...</guimenuitem>"
msgstr ""
"<guimenu>सेटिंग्स्</guimenu> <guimenuitem>उपकरणपट्टिकाः विन्यस्यताम्...</guimenuitem>"

#. Tag: para
#: commands.docbook:1052
#, no-c-format
msgid ""
"<action>Configure the toolbars.</action> The section on <link linkend="
"\"configtoolbars\">configuring toolbars</link> has more information."
msgstr ""
"<action>साधनपट्टिकाः विन्यस्यताम् ।</action> इति खण्डः<link linkend="
"\"configtoolbars\"> साधनपट्टिकानां विन्यासः</link> अधिकानि सूचनानि सन्ति।"

#. Tag: menuchoice
#: commands.docbook:1059
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Themes</guimenuitem>"
msgstr "<guimenu>सेटिंग्स्</guimenu> <guimenuitem>विषयाणि</guimenuitem>"

#. Tag: para
#: commands.docbook:1063
#, no-c-format
msgid ""
"<action>Choose the color theme for &sheets; window.</action> You can choose "
"one of the predefined color schemes or select <guimenuitem>Configuration...</"
"guimenuitem> to open <ulink url=\"help:/kcontrol/colors\">&systemsettings; "
"color selection module</ulink>."
msgstr ""
"<action>&sheets; window.</action> भवान् पूर्वनिर्धारितवर्णयोजनासु एकं चिन्वतु अथवा "
"<ulink url=\"help:/kcontrol/colors\">&systemsettings; वर्णचयनमॉड्यूल</ulink> "
"इति ।"

#. Tag: menuchoice
#: commands.docbook:1070
#, no-c-format
msgid ""
"<guimenu>Settings</guimenu> <guimenuitem>Active Author Profile</guimenuitem>"
msgstr "<guimenu>सेटिंग्स्</guimenu> <guimenuitem>सक्रियलेखकप्रोफाइल</guimenuitem>"

#. Tag: para
#: commands.docbook:1074
#, no-c-format
msgid ""
"<action>Configure the author profile for the current document.</action> You "
"can choose one of the profiles defined using <link linkend=\"configauthor"
"\">&sheets; configuration window</link>, <guimenuitem>Default Author "
"Profile</guimenuitem> as defined by &systemsettings; data or blank "
"<guimenuitem>Anonymous</guimenuitem> profile which can ensure your privacy."
msgstr ""
"<action>वर्तमानदस्तावेजस्य कृते लेखकरूपरेखां विन्यस्यताम् ।</action> उपयोगेन "
"परिभाषितप्रोफाइलमध्ये एकं चिन्वतु<link linkend=\"configauthor\"> &amp;sheets; "
"विन्यासविण्डो</link> , ९.<guimenuitem> पूर्वनिर्धारित लेखक प्रोफाइल</guimenuitem> "
"यथा परिभाषितं &amp;systemsettings; दत्तांशः रिक्तः वा<guimenuitem> अनामक</"
"guimenuitem> profile यत् भवतः गोपनीयतां सुनिश्चितं कर्तुं शक्नोति।"

#. Tag: menuchoice
#: commands.docbook:1082
#, no-c-format
msgid ""
"<guimenu>Settings</guimenu> <guimenuitem>Configure Notifications...</"
"guimenuitem>"
msgstr "<guimenu>सेटिंग्स्</guimenu> <guimenuitem>सूचनाः विन्यस्यताम्...</guimenuitem>"

#. Tag: para
#: commands.docbook:1086
#, no-c-format
msgid ""
"<action>Configure &sheets; notification system.</action> There are no "
"actions that you can be notified in the current version of &sheets;."
msgstr ""
"<action>विन्यस्तं कुर्वन्तु &sheets; notification system.</action> &sheets; इत्यस्य "
"वर्तमानसंस्करणे भवन्तः सूचनां दातुं शक्नुवन्ति इति क्रियाः नास्ति ।"

#. Tag: menuchoice
#: commands.docbook:1092
#, no-c-format
msgid ""
"<guimenu>Settings</guimenu> <guimenuitem>Configure &sheets;...</guimenuitem>"
msgstr ""
"<guimenu>सेटिंग्स्</guimenu> <guimenuitem>&sheets;...</guimenuitem> विन्यस्यताम्"

#. Tag: para
#: commands.docbook:1096
#, no-c-format
msgid ""
"<action>General &sheets; configuration.</action> See the section on <link "
"linkend=\"configdialog\">&sheets; configuration</link> for more details."
msgstr ""
"<action>सामान्यम् &amp;sheets; विन्यासः ।</action> विषये खण्डं पश्यन्तु<link linkend="
"\"configdialog\"> &amp;sheets; विन्यासः</link> अधिकविवरणार्थम्।"

#. Tag: title
#: commands.docbook:1106
#, no-c-format
msgid "The Help Menu"
msgstr "सहायता मेनू"

#. Tag: sect1
#: commands.docbook:1106
#, no-c-format
msgid "&help.menu.documentation;"
msgstr "&help.menu.दस्तावेजीकरणम्;"

#. Tag: title
#: commands.docbook:1113
#, no-c-format
msgid "The Right Mouse Button Menu"
msgstr "The Right Mouse Button मेनू इति"

#. Tag: para
#: commands.docbook:1114
#, no-c-format
msgid ""
"This section describes the items in the pop up menu obtained by "
"<mousebutton>right</mousebutton> clicking on a selected cell or cells, "
"row(s) or column(s)."
msgstr ""
"अस्मिन् खण्डे <mousebutton>right</mousebutton> इत्यनेन चयनितकोष्ठकस्य अथवा कोष्ठकानां, "
"पङ्क्ति(पङ्क्तयः) अथवा स्तम्भ(स्तम्भानां) क्लिक् कृत्वा प्राप्तानां पॉप अप मेन्यूमध्ये द्रव्याणां "
"वर्णनं कृतम् अस्ति ।"

#. Tag: menuchoice
#: commands.docbook:1121
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Alt;<keycap>F</keycap></"
"keycombo> </shortcut> <guimenuitem>Cell Format...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Alt;<keycap>F</keycap></"
"keycombo> </shortcut> <guimenuitem>कोशिकास्वरूपं...</guimenuitem>"

#. Tag: menuchoice
#: commands.docbook:1134
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>X</keycap></keycombo> </"
"shortcut> <guimenuitem>Cut</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>X</keycap></keycombo> </"
"shortcut> <guimenuitem>कट</guimenuitem>"

#. Tag: para
#: commands.docbook:1140
#, no-c-format
msgid ""
"<action>Put selected item(s) into the clipboard.</action> If you then do a "
"<guilabel>Paste</guilabel> the item(s) will be moved from the original "
"location to the new one."
msgstr ""
"<action>चयनितं द्रव्यं (वस्तूनि) क्लिप्बोर्ड् मध्ये स्थापयन्तु ।</action> यदि भवान् ततः "
"<guilabel>Paste</guilabel> करोति तर्हि द्रव्यं (वस्तूनि) मूलस्थानात् नूतनस्थानं प्रति "
"स्थानान्तरिता भविष्यति ।"

#. Tag: menuchoice
#: commands.docbook:1147
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>C</keycap></keycombo> </"
"shortcut> <guimenuitem>Copy</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>C</keycap></keycombo> </"
"shortcut> <guimenuitem>प्रतिलिपि</guimenuitem>"

#. Tag: action
#: commands.docbook:1153
#, no-c-format
msgid "Copy selected item(s) into the clipboard."
msgstr "चयनितं द्रव्यं (वस्तूनि) क्लिप्बोर्ड् मध्ये प्रतिलिख्यताम् ।"

#. Tag: menuchoice
#: commands.docbook:1158
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>V</keycap></keycombo> </"
"shortcut> <guimenuitem>Paste</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>V</keycap></keycombo> </"
"shortcut> <guimenuitem>चिपकतु</guimenuitem>"

#. Tag: action
#: commands.docbook:1164
#, no-c-format
msgid "Paste item(s) from the clipboard to the selected cells."
msgstr "क्लिप्बोर्ड् तः चयनितकोष्ठकेषु द्रव्यं (वस्तूनि) चिनोतु ।"

#. Tag: guimenuitem
#: commands.docbook:1171
#, no-c-format
msgid "Special Paste..."
msgstr "विशेष पेस्ट..."

#. Tag: guimenuitem
#: commands.docbook:1182
#, no-c-format
msgid "Paste with Insertion"
msgstr "Insertion इत्यनेन सह चिनोतु"

#. Tag: action
#: commands.docbook:1184
#, no-c-format
msgid ""
"Paste from the clipboard to the selected cell(s), moving the previous "
"cell(s) to make room."
msgstr ""
"क्लिप्बोर्ड् तः चयनितकोष्ठकं (कोष्ठकेषु) चिनोतु, पूर्वकोष्ठकं (कोष्ठकानि) चालयित्वा स्थानं "
"कल्पयन्तु ।"

#. Tag: guimenuitem
#: commands.docbook:1191
#, no-c-format
msgid "<guimenuitem>All</guimenuitem>"
msgstr "<guimenuitem>सर्व</guimenuitem>"

#. Tag: action
#: commands.docbook:1193
#, no-c-format
msgid "Delete contents of selected cell(s)."
msgstr "चयनितकोष्ठकानां (कोष्ठकानां) सामग्रीं विलोपयन्तु ।"

#. Tag: guimenuitem
#: commands.docbook:1199
#, no-c-format
msgid "Adjust Row &amp; Column"
msgstr "समायोजित पङ्क्ति &amp; स्तम्भ"

#. Tag: action
#: commands.docbook:1201
#, no-c-format
msgid "Change size of row and column to display selected cell(s) completely."
msgstr "चयनितं कोष्ठकं (कोष्ठकं) पूर्णतया प्रदर्शयितुं पङ्क्तिस्तम्भयोः आकारं परिवर्तयन्तु ।"

#. Tag: guimenuitem
#: commands.docbook:1208
#, no-c-format
msgid "Default"
msgstr "मूलभूतम्‌"

#. Tag: action
#: commands.docbook:1210
#, no-c-format
msgid "Set default formats for selected cell(s)."
msgstr "चयनितकोष्ठकानां (कोष्ठकानां) कृते पूर्वनिर्धारितस्वरूपाणि सेट् कुर्वन्तु ।"

#. Tag: guimenuitem
#: commands.docbook:1216
#, no-c-format
msgid "Area Name..."
msgstr "क्षेत्रनाम..."

#. Tag: para
#: commands.docbook:1218
#, no-c-format
msgid ""
"<action>Name selected area.</action> See the section <link linkend="
"\"namedareas\">Named Areas</link> for more details."
msgstr ""
"<action>चयनितक्षेत्रस्य नामकरणं कुर्वन्तु।</action> खण्डं पश्यन्तु<link linkend="
"\"namedareas\"> नामित क्षेत्र</link> अधिकविवरणार्थम्।"

#. Tag: guimenuitem
#: commands.docbook:1225
#, no-c-format
msgid "Resize Row..."
msgstr "पङ्क्तिः आकारं परिवर्तयतु..."

#. Tag: action
#: commands.docbook:1227
#, no-c-format
msgid "Change height of selected row."
msgstr "चयनितपङ्क्तौ ऊर्ध्वतां परिवर्तयन्तु ।"

#. Tag: guimenuitem
#: commands.docbook:1233
#, no-c-format
msgid "Adjust Row"
msgstr "Adjust Row इति"

#. Tag: action
#: commands.docbook:1235
#, no-c-format
msgid "Change height of selected row to display cell(s) completely."
msgstr "कोष्ठकं (कोशिकाः) पूर्णतया प्रदर्शयितुं चयनितपङ्क्तिः ऊर्ध्वतां परिवर्तयन्तु ।"

#. Tag: guimenuitem
#: commands.docbook:1242
#, no-c-format
msgid "Resize Column..."
msgstr "स्तम्भस्य आकारं परिवर्तयतु..."

#. Tag: action
#: commands.docbook:1244
#, no-c-format
msgid "Change width of selected column."
msgstr "चयनितस्तम्भस्य विस्तारं परिवर्तयन्तु।"

#. Tag: guimenuitem
#: commands.docbook:1250
#, no-c-format
msgid "Adjust Column"
msgstr "स्तम्भं समायोजयन्तु"

#. Tag: action
#: commands.docbook:1252
#, no-c-format
msgid "Change width of selected column to display cell(s) completely."
msgstr "कोष्ठकं (कोशिकाः) पूर्णतया प्रदर्शयितुं चयनितस्तम्भस्य विस्तारं परिवर्तयन्तु ।"

#. Tag: guimenuitem
#: commands.docbook:1259
#, no-c-format
msgid "Insert Cells..."
msgstr "कोष्ठकाः सम्मिलिताः..."

#. Tag: action
#: commands.docbook:1261
#, no-c-format
msgid ""
"Insert new cell(s) at selected location, moving existing cell(s) to make "
"room."
msgstr ""
"चयनितस्थाने नूतनं कोष्ठकं (कोष्ठकं) सम्मिलितं कुर्वन्तु, विद्यमानं कोष्ठकं (कोष्ठकं) "
"स्थानान्तरयित्वा स्थानं कल्पयन्तु ।"

#. Tag: guimenuitem
#: commands.docbook:1268
#, no-c-format
msgid "Delete Cells..."
msgstr "कोष्ठकाः विलोपयन्तु..."

#. Tag: action
#: commands.docbook:1270
#, no-c-format
msgid ""
"Remove selected cell(s), moving other cell(s) to occupy the space left by "
"the removed cell(s)."
msgstr ""
"चयनितं कोष्ठकं (कोष्ठकं) निष्कासयन्तु, अन्यकोष्ठकं (कोष्ठकं) चालयित्वा निष्कासितेन कोष्ठकेन "
"(कोष्ठकैः) अवशिष्टं स्थानं गृह्णन्तु ।"

#. Tag: guimenuitem
#: commands.docbook:1277
#, no-c-format
msgid "Insert Rows"
msgstr "पङ्क्तयः सम्मिलितं कुर्वन्तु"

#. Tag: action
#: commands.docbook:1279
#, no-c-format
msgid "Insert new row(s) above selected row(s)."
msgstr "चयनितपङ्क्ति(पङ्क्तयः) उपरि नूतनपङ्क्ति(पङ्क्तयः) सम्मिलितं कुर्वन्तु ।"

#. Tag: guimenuitem
#: commands.docbook:1286
#, no-c-format
msgid "Delete Rows"
msgstr "पङ्क्तयः विलोपयन्तु"

#. Tag: action
#: commands.docbook:1288
#, no-c-format
msgid "Delete selected row(s)."
msgstr "चयनितपङ्क्ति(पङ्क्तयः) विलोपयन्तु।"

#. Tag: guimenuitem
#: commands.docbook:1294
#, no-c-format
msgid "Hide Rows"
msgstr "पङ्क्तयः गोपयन्तु"

#. Tag: action
#: commands.docbook:1296
#, no-c-format
msgid "Hides selected row(s)."
msgstr "चयनितपङ्क्ति(पङ्क्तयः) गोपयति ।"

#. Tag: guimenuitem
#: commands.docbook:1302
#, no-c-format
msgid "Show Rows"
msgstr "पङ्क्तयः दर्शयतु"

#. Tag: action
#: commands.docbook:1304
#, no-c-format
msgid ""
"Shows selected row(s). In order to show hidden rows you need to select a "
"range of rows that includes the hidden rows."
msgstr ""
"चयनितपङ्क्ति(पङ्क्तयः) दर्शयति । गुप्तपङ्क्तयः दर्शयितुं भवद्भिः पङ्क्तिपरिधिः चिन्वितव्यः "
"यस्मिन् गुप्तपङ्क्तयः समाविष्टाः सन्ति ।"

#. Tag: guimenuitem
#: commands.docbook:1312
#, no-c-format
msgid "Insert Columns"
msgstr "स्तम्भान् सम्मिलितं कुर्वन्तु"

#. Tag: action
#: commands.docbook:1314
#, no-c-format
msgid "Insert new column(s) at left of selected column(s)."
msgstr "चयनितस्तम्भस्य वामे नूतनस्तम्भ(स्तम्भान्) सम्मिलितं कुर्वन्तु ।"

#. Tag: guimenuitem
#: commands.docbook:1321
#, no-c-format
msgid "Delete Columns"
msgstr "स्तम्भान् विलोपयन्तु"

#. Tag: action
#: commands.docbook:1323
#, no-c-format
msgid "Delete selected column(s)."
msgstr "चयनितं स्तम्भं (स्तम्भान्) विलोपयन्तु।"

#. Tag: guimenuitem
#: commands.docbook:1329
#, no-c-format
msgid "Hide Columns"
msgstr "स्तम्भान् गोपयन्तु"

#. Tag: action
#: commands.docbook:1331
#, no-c-format
msgid "Hides selected column(s)."
msgstr "चयनितं स्तम्भं (स्तम्भान्) गोपयति ।"

#. Tag: guimenuitem
#: commands.docbook:1337
#, no-c-format
msgid "Show Columns"
msgstr "स्तम्भान् दर्शयतु"

#. Tag: action
#: commands.docbook:1339
#, no-c-format
msgid ""
"Shows selected column(s). In order to show hidden columns you need to select "
"a range of columns that includes the hidden columns."
msgstr ""
"चयनितं स्तम्भं (स्तम्भान्) दर्शयति । गुप्तस्तम्भान् दर्शयितुं भवद्भिः स्तम्भानां श्रेणीं चिन्वितव्यं "
"यस्मिन् गुप्तस्तम्भाः समाविष्टाः सन्ति ।"

#. Tag: guimenuitem
#: commands.docbook:1347
#, no-c-format
msgid "Comment..."
msgstr "टिप्पणी..."

#. Tag: action
#: commands.docbook:1349
#, no-c-format
msgid "Add or modify a comment to the selected cell."
msgstr "चयनितकोष्ठके टिप्पणीं योजयन्तु परिवर्तनं वा कुर्वन्तु ।"

#. Tag: guimenuitem
#: commands.docbook:1355
#, no-c-format
msgid "Selection List..."
msgstr "चयनसूची..."

#. Tag: action
#: commands.docbook:1357
#, no-c-format
msgid ""
"Lets you select and paste text from any cell of the current selection of "
"cells into the selected cell."
msgstr "वर्तमान कोष्ठकचयनस्य कस्मात् अपि कोष्ठकात् पाठं चयनितकोष्ठके चिनोति, चिनोति च ।"

#. Tag: title
#: commands.docbook:1374
#, no-c-format
msgid "Other Shortcuts"
msgstr "अन्ये शॉर्टकट्"

#. Tag: para
#: commands.docbook:1375
#, no-c-format
msgid ""
"This section describes those &sheets; shortcut keys used for operations that "
"do not appear in any of the menus."
msgstr ""
"अस्मिन् खण्डे तानि &sheets; कस्मिन् अपि मेन्यू मध्ये न दृश्यमानानां कार्याणां कृते प्रयुक्तानि "
"शॉर्टकट् कीलानि ।"

#. Tag: keycombo
#: commands.docbook:1382
#, no-c-format
msgid "&Ctrl;<keycap>H</keycap>"
msgstr "&Ctrl;<keycap>H</keycap> इति"

#. Tag: para
#: commands.docbook:1384
#, no-c-format
msgid "Toggle the display of the dockers."
msgstr "डॉकर्स् इत्यस्य प्रदर्शनं टॉग्ल् कुर्वन्तु ।"

#. Tag: keycombo
#: commands.docbook:1389
#, no-c-format
msgid "&Ctrl;<keysym>Arrow keys</keysym>"
msgstr "&Ctrl;<keysym>बाणकील</keysym>"

#. Tag: action
#: commands.docbook:1391
#, no-c-format
msgid ""
"If the selected cell is occupied then move the cell cursor to the start or "
"end of the occupied block in the current row or column. If the selected cell "
"is not occupied then move the cell cursor to the start or end of the block "
"of unoccupied cells in the current row or column."
msgstr ""
"यदि चयनितः कोष्ठकः कब्जितः अस्ति तर्हि वर्तमानपङ्क्तौ अथवा स्तम्भे कब्जितस्य खण्डस्य आरम्भे "
"अथवा अन्ते कोष्ठकं कर्सरं चालयन्तु । यदि चयनितः कोष्ठकः कब्जितः नास्ति तर्हि वर्तमानपङ्क्तौ "
"अथवा स्तम्भे अकब्जितकोशिकानां खण्डस्य आरम्भे अथवा अन्ते कोष्ठकं कर्सरं चालयन्तु ।"

#. Tag: keycombo
#: commands.docbook:1401
#, no-c-format
msgid "&Ctrl;&Shift;<keysym>Arrow keys</keysym>"
msgstr "&Ctrl;&Shift;<keysym>बाणकील</keysym>"

#. Tag: action
#: commands.docbook:1403
#, no-c-format
msgid ""
"If the selected cell is occupied then select all occupied cells to the start "
"or end of that block of occupied cells in the current row or column. If the "
"selected cell is not occupied then select all unoccupied cells to the start "
"or end of that block of unoccupied cells in the current row or column."
msgstr ""
"यदि चयनितः कोष्ठकः कब्जाकृतः अस्ति तर्हि वर्तमानपङ्क्तौ अथवा स्तम्भे कब्जाकृतानां कोष्ठकानां "
"तस्य खण्डस्य आरम्भं वा अन्ते वा सर्वाणि कब्जितकोशिकानि चिनोतु । यदि चयनितः कोष्ठकः "
"कब्जितः नास्ति तर्हि वर्तमानपङ्क्तौ अथवा स्तम्भे तस्य रिक्तकोष्ठकानां खण्डस्य आरम्भं वा अन्ते "
"वा सर्वाणि रिक्तकोष्ठकानि चिनोतु ।"

#. Tag: keysym
#: commands.docbook:1414
#, no-c-format
msgid "Page Down"
msgstr "पृष्ठं अधः"

#. Tag: action
#: commands.docbook:1416
#, no-c-format
msgid "Move the cell cursor 10 cells down."
msgstr "सेल कर्सरं 10 कोष्ठकं अधः चालयन्तु ।"

#. Tag: keysym
#: commands.docbook:1422
#, no-c-format
msgid "Page Up"
msgstr "पृष्ठ ऊपर"

#. Tag: action
#: commands.docbook:1424
#, no-c-format
msgid "Move the cell cursor 10 cells up."
msgstr "कोष्ठक कर्सरं १० कोष्ठकानि उपरि चालयन्तु ।"

#. Tag: keycombo
#: commands.docbook:1430
#, no-c-format
msgid "&Ctrl;<keysym>Page Down</keysym>"
msgstr "&Ctrl;<keysym>पृष्ठं अधः</keysym>"

#. Tag: action
#: commands.docbook:1432
#, no-c-format
msgid "Move to the next sheet."
msgstr "अग्रिमपत्रं प्रति गच्छन्तु।"

#. Tag: keycombo
#: commands.docbook:1438
#, no-c-format
msgid "&Ctrl;<keysym>Page Up</keysym>"
msgstr "&Ctrl;<keysym>पृष्ठोपरि</keysym>"

#. Tag: action
#: commands.docbook:1440
#, no-c-format
msgid "Move to the previous sheet."
msgstr "पूर्वपत्रं प्रति गच्छन्तु।"

#. Tag: keycap
#: commands.docbook:1446
#, no-c-format
msgid "<keycap>F4</keycap>"
msgstr "<keycap>F4</keycap> इति"

#. Tag: para
#: commands.docbook:1448
#, no-c-format
msgid ""
"<action>Change cell reference</action> between normal and <link linkend="
"\"absolute\">absolute reference</link> types."
msgstr ""
"<action>कोष्ठसन्दर्भं परिवर्तयन्तु</action> सामान्यस्य च मध्ये<link linkend=\"absolute"
"\"> निरपेक्ष सन्दर्भ</link> प्रकाराः ।"
