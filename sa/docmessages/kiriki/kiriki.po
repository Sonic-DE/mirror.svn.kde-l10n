"योगः - '६'='२'+'२'+'२' इति ।"

#. Tag: para
#: index.docbook:98
#, no-c-format
msgid "<guilabel>3s</guilabel>: Sum of all dice valued ‘3’."
msgstr "<guilabel>3s</guilabel>: ‘3’ मूल्यस्य सर्वेषां पासानां योगः।"

