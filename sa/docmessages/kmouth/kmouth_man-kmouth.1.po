msgid "filename"
msgstr "सञ्चिकानाम"

#. Tag: para
#: man-kmouth.1.docbook:50
#, no-c-format
msgid "The history file to open."
msgstr "उद्घाटयितुं इतिहाससञ्चिका ।"

