msgstr "अनुवादकानां_भूमिका"

#. Tag: holder
#: index.docbook:25
#, no-c-format
msgid "Gunnar Schmi Dt"
msgstr "गुन्नर श्मी Dt"

#. Tag: date
#: index.docbook:31
#, no-c-format
