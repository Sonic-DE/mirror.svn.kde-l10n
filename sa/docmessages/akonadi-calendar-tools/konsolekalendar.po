#. Tag: para
#: index.docbook:55
#, no-c-format
msgid "&konsolekalendar; is a command line interface to &kde; calendars."
msgstr "&konsolekalendar; &kde; पञ्चाङ्गाः ।"

#. Tag: keyword
#: index.docbook:60
#, no-c-format
msgid "<keyword>KDE</keyword>"
msgstr "<keyword>WHERE</keyword> इति"

