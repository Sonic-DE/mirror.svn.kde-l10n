#, no-c-format
msgid "Quits the program."
msgstr "कार्यक्रमं त्यजति।"

#. Tag: menuchoice
#: index.docbook:657
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>F</keycap></"
"keycombo> </shortcut> <guimenu>View</guimenu> <guimenuitem>Full Screen Mode</"
