msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>H</keycap></keycombo> </"
"shortcut> <guimenu>खेल</guimenu> <guimenuitem>उच्चाङ्कान् दर्शयतु</guimenuitem>"

#. Tag: para
#: index.docbook:635
#, no-c-format
msgid "Shows a dialog containing the High Scores."
msgstr "High Scores युक्तं संवादं दर्शयति ।"

#. Tag: menuchoice
