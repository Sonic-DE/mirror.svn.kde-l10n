#. Tag: title
#: index.docbook:12
#, no-c-format
msgid "The &kronometer; Handbook"
msgstr "& क्रोनोमीटर्; हस्तपुस्तिका"

#. Tag: author
#: index.docbook:15
#, no-c-format
msgid "<firstname>Elvis</firstname><surname>Angelaccio</surname>"
msgstr "<firstname>एल्विस</firstname><surname>एन्जेलाक्सिओ</surname>"

#. Tag: email
#: index.docbook:18
#, no-c-format
