msgstr "elvis.angelaccio@kde.org"

#. Tag: trans_comment
#: index.docbook:22
#, no-c-format
msgid "ROLES_OF_TRANSLATORS"
msgstr "अनुवादकानां_भूमिका"

#. Tag: holder
#: index.docbook:27
#, no-c-format
msgid "Elvis Angelaccio"
msgstr "एल्विस एन्जेलाक्सिओ"

#. Tag: date
#: index.docbook:30
#, no-c-format
