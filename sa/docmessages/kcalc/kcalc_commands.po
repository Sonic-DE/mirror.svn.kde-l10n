#. Tag: title
#: commands.docbook:3
#, no-c-format
msgid "Command Reference"
msgstr "आदेश सन्दर्भ"

#. Tag: title
#: commands.docbook:6
#, no-c-format
msgid "Menu Items"
msgstr "मेनू आइटम"

#. Tag: para
#: commands.docbook:8
#, no-c-format
msgid "A brief overview of some special menu items in &kcalc;:"
msgstr "&kcalc;: इत्यस्मिन् केषाञ्चन विशेषमेनूवस्तूनाम् संक्षिप्तं अवलोकनम्:"

#. Tag: menuchoice
#: commands.docbook:12
#, no-c-format
msgid "<guimenu>Constants</guimenu> <guimenuitem>Mathematics</guimenuitem>"
msgstr "<guimenu>नित्य</guimenu> <guimenuitem>गणित</guimenuitem>"

#. Tag: action
#: commands.docbook:16
#, no-c-format
msgid "Display Pi, Euler Number or Golden Ratio."
msgstr "Pi, Euler Number अथवा Golden Ratio प्रदर्शयन्तु।"

#. Tag: menuchoice
#: commands.docbook:21
#, no-c-format
msgid ""
"<guimenu>Constants</guimenu> <guimenuitem>Electromagnetism</guimenuitem>"
msgstr "<guimenu>नित्य</guimenu> <guimenuitem>विद्युत्चुम्बकत्व</guimenuitem>"

#. Tag: action
#: commands.docbook:25
#, no-c-format
msgid ""
"Display Light Speed, Elementary Charge, Impedance of Vacuum, Permeability of "
"Vacuum or Permittivity of Vacuum."
msgstr ""
"प्रकाशस्य गतिः, प्राथमिकप्रभारः, वैक्यूमस्य प्रतिबाधा, वैक्यूमस्य पारगम्यता अथवा वैक्यूमस्य "
"अनुमतता प्रदर्शयन्तु।"

#. Tag: menuchoice
#: commands.docbook:31
#, no-c-format
msgid ""
"<guimenu>Constants</guimenu> <guimenuitem>Atomic &amp; Nuclear</guimenuitem>"
msgstr "<guimenu>नित्य</guimenu> <guimenuitem>परमाणु &amp; परमाणु</guimenuitem>"

#. Tag: action
#: commands.docbook:35
#, no-c-format
msgid ""
"Display Planck's Constant, Elementary Charge or Fine-Structure Constant."
msgstr "प्लैङ्कस्य स्थिरांकं, प्राथमिकं आभारं वा सूक्ष्म-संरचना स्थिरांकं प्रदर्शयन्तु।"

#. Tag: menuchoice
#: commands.docbook:41
#, no-c-format
msgid "<guimenu>Constants</guimenu> <guimenuitem>Thermodynamics</guimenuitem>"
msgstr "<guimenu>स्थिरांक</guimenu> <guimenuitem>उष्मागतिकी</guimenuitem>"

#. Tag: action
#: commands.docbook:45
#, no-c-format
msgid ""
"Display Boltzmann Constant, Atomic Mass Unit, Molar Gas Constant, Stefan-"
"Boltzmann Constant or Avogadro's Number."
msgstr ""
"बोल्ट्जमैन स्थिरांक, परमाणु द्रव्यमान इकाई, मोलर गैस स्थिरांक, स्टीफन-बोल्ट्जमैन स्थिरांक "
"अथवा एवोगाड्रो की संख्या प्रदर्शित करें।"

#. Tag: menuchoice
#: commands.docbook:51
#, no-c-format
msgid "<guimenu>Constants</guimenu> <guimenuitem>Gravitation</guimenuitem>"
msgstr "<guimenu>नित्य</guimenu> <guimenuitem>गुरुत्वाकर्षण</guimenuitem>"

#. Tag: para
#: commands.docbook:55
#, no-c-format
msgid "Display Constant of Gravitation or Earth Acceleration."
msgstr "गुरुत्वाकर्षणस्य स्थिरांकं अथवा पृथिवीत्वरणं प्रदर्शयन्तु।"

#. Tag: menuchoice
#: commands.docbook:60
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Simple Mode</guimenuitem>"
msgstr "<guimenu>सेटिंग्स्</guimenu> <guimenuitem>सरलविधिः</guimenuitem>"

#. Tag: action
#: commands.docbook:64
#, no-c-format
msgid "Displays the simple math buttons."
msgstr "सरलगणितबटन्स् प्रदर्शयति ।"

#. Tag: menuchoice
#: commands.docbook:69
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Science Mode</guimenuitem>"
msgstr "<guimenu>सेटिंग्स्</guimenu> <guimenuitem>विज्ञानविधिः</guimenuitem>"

#. Tag: action
#: commands.docbook:73
#, no-c-format
msgid "Displays trigonometric and science buttons."
msgstr "त्रिकोणमितीयविज्ञानबटनं प्रदर्शयति ।"

#. Tag: menuchoice
#: commands.docbook:78
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Statistic Mode</guimenuitem>"
msgstr "<guimenu>सेटिंग्स्</guimenu> <guimenuitem>सांख्यिकीयविधिः</guimenuitem>"

#. Tag: action
#: commands.docbook:82
#, no-c-format
msgid "Displays <link linkend=\"statistical-mode\">statistic buttons.</link>"
msgstr "प्रदर्शयति<link linkend=\"statistical-mode\"> सांख्यिकी बटन।</link>"

#. Tag: menuchoice
#: commands.docbook:88
#, no-c-format
msgid ""
"<guimenu>Settings</guimenu> <guimenuitem>Numeral System Mode</guimenuitem>"
msgstr "<guimenu>सेटिंग्स्</guimenu> <guimenuitem>संख्याप्रणालीविधिः</guimenuitem>"

#. Tag: action
#: commands.docbook:92
#, no-c-format
msgid ""
"Displays <link linkend=\"and-or-xor\">logic buttons</link> and allows "
"changing the numeral system."
msgstr ""
"प्रदर्शयति<link linkend=\"and-or-xor\"> तर्क बटन</link> तथा संख्यातन्त्रं परिवर्तयितुं "
"अनुमतिं ददाति ।"

#. Tag: menuchoice
#: commands.docbook:98
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Show History</guimenuitem>"
msgstr "<guimenu>सेटिंग्स्</guimenu> <guimenuitem>इतिहासं दर्शयतु</guimenuitem>"

#. Tag: action
#: commands.docbook:102
#, no-c-format
msgid "Display the history."
msgstr "इतिहासं प्रदर्शयतु।"

#. Tag: menuchoice
#: commands.docbook:107
#, no-c-format
msgid ""
"<guimenu>Settings</guimenu> <guimenuitem>Constants Buttons</guimenuitem>"
msgstr "<guimenu>सेटिंग्स्</guimenu> <guimenuitem>नित्यबटन्स्</guimenuitem>"

#. Tag: action
#: commands.docbook:111
#, no-c-format
msgid ""
"Display constants buttons. They are available in <link linkend=\"science-mode"
"\">science mode</link> and <link linkend=\"statistical-mode\">statistic "
"mode</link>."
msgstr ""
"नित्यं बटनं प्रदर्शयन्तु। ते उपलभ्यन्ते<link linkend=\"science-mode\"> विज्ञानविधा</"
"link> तथा<link linkend=\"statistical-mode\"> सांख्यिकीयविधिः</link> ."

#. Tag: menuchoice
#: commands.docbook:117
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Show Bit Edit</guimenuitem>"
msgstr "<guimenu>सेटिंग्स्</guimenu> <guimenuitem>बिट् सम्पादनं दर्शयतु</guimenuitem>"

#. Tag: action
#: commands.docbook:121
#, no-c-format
msgid ""
"Displays a bit edit field. Click on a bit to toggle it. Only available in "
"<link linkend=\"numeral-system-mode\">numeral system mode</link>."
msgstr ""
"किञ्चित् सम्पादनक्षेत्रं प्रदर्शयति । तत् टॉग्ल् कर्तुं किञ्चित् क्लिक् कुर्वन्तु । केवलं 1000 तमे वर्षे "
"उपलब्धम्<link linkend=\"numeral-system-mode\"> संख्या प्रणाली मोड</link> ."

#. Tag: para
#: commands.docbook:128
#, no-c-format
msgid ""
"Additionally &kcalc; has the common <guimenu>File</guimenu>, <guimenu>Edit</"
"guimenu>, <guimenu>Settings</guimenu> and <guimenu>Help</guimenu> menu "
"items, for more information read the sections about the <ulink url=\"help:/"
"fundamentals/menus.html\">Menus</ulink> in the &kde; Fundamentals."
msgstr ""
"अतिरिक्तरूपेण &kcalc; सामान्यानि <guimenu>सञ्चिका</guimenu>, <guimenu>सम्पादयतु</"
"guimenu>, <guimenu>सेटिंग्स्</guimenu> तथा <guimenu>सहायता</guimenu> मेन्यू-वस्तूनि "
"सन्ति, अधिकसूचनार्थं < ulink url=\"help:/fundamentals/menus.html\">मेनू</ulink> "
"इत्यत्र &kde; मौलिकता।"
