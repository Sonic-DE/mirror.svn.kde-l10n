#, no-c-format
msgid "log base e"
msgstr "आधार लॉग तथा"

#. Tag: keycap
#: index.docbook:536
#, no-c-format
msgid "<keycap>L</keycap>"
msgstr "<keycap>L</keycap> इति"

#. Tag: entry
