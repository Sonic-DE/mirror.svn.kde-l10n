#. Tag: para
#: index.docbook:2212
#, no-c-format
msgid "<link linkend=\"agenda-view\">Agenda View</link> options:"
msgstr "<link linkend=\"agenda-view\">एजेण्डा व्यू</link> विकल्पाः :"

#. Tag: guilabel
#: index.docbook:2217
#, no-c-format
msgid "Hour size:"
msgstr "घण्टायाः आकारः :"

#. Tag: para
#: index.docbook:2218
#, no-c-format
msgid ""
"By using this you can control the height of the rows in the Agenda view."
msgstr "एतस्य उपयोगेन भवान् Agenda दृश्ये पङ्क्तयः ऊर्ध्वतां नियन्त्रयितुं शक्नोति ।"

#. Tag: guilabel
#: index.docbook:2223
#, no-c-format
msgid "Show icons in agenda view items"
