msgid "Changes to the users home folder, &eg; /home/Peter/."
msgstr "उपयोक्तृणां गृहपुटे परिवर्तनं, &eg; /गृह/पीटर/।"

#. Tag: menuchoice
#: index.docbook:2110
#, no-c-format
msgid "<guimenu>Go</guimenu> <guisubmenu>Recently Closed Tabs</guisubmenu>"
msgstr "<guimenu>गच्छ</guimenu> <guisubmenu>सद्यः बन्दाः ट्याब्स्</guisubmenu>"

#. Tag: action
#: index.docbook:2114
#, no-c-format
msgid "Shows a list of recently closed tabs which can be reopened."
msgstr "सद्यः पिहितानाम् ट्याब्स् इत्यस्य सूचीं दर्शयति यत् पुनः उद्घाटयितुं शक्यते ।"

