"<shortcut> <keycombo action=\"simul\">&Shift;<keycap>F4</keycap></keycombo> "
"</shortcut> <guimenu>उपकरणाः</guimenu> <guimenuitem>टर्मिनल् उद्घाटयन्तु</"
"guimenuitem>"

#. Tag: action
#: index.docbook:2134
#, no-c-format
msgid "Opens &konsole; within the current folder."
msgstr "उद्घाटयति &konsole; वर्तमानपुटस्य अन्तः ।"

#. Tag: menuchoice
#: index.docbook:2138
