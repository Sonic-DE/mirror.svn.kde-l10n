msgid "Examples"
msgstr "उदाहरणानि"

#. Tag: programlisting
#: man-rkward.1.docbook:129
#, no-c-format
msgid ""
"# Start with the t-test dialog\n"
"rkward --nowarn-external rkward://runplugin/rkward::t_test/\n"
"# Open two script files in a running instance of RKWard (or in a fresh "
"instance, if RKWard is not running)\n"
"rkward --reuse file_a.R file_b.R\n"
"\n"
"# Run the rkward backend through valgrind\n"
"rkward --backend-debugger 'valgrind --log-file=valgrind.log'"
msgstr ""
"# t-test संवादेन आरभत\n"
"rkward --nowarn-बाह्य rkward://runplugin/rkward::t_test/\n"
"# RKWard इत्यस्य चालित-दृष्टान्ते (अथवा ताजा-दृष्टान्ते, यदि RKWard न चाल्यते) स्क्रिप्ट्-"
"सञ्चिकाद्वयं उद्घाटयन्तु\n"
"rkward --पुनः उपयोगं कुर्वन्तु file_a.R file_b.R\n"
"\n"
"# valgrind इत्यस्य माध्यमेन rkward backend चालयन्तु\n"
"rkward --backend-debugger 'valgrind --लॉग-सञ्चिका=valgrind.log'."

