msgid "<para>bmp</para>"
msgstr "<परा>बम्प</para>"

#. Tag: para
#: index.docbook:74
#, no-c-format
msgid "<para>psd</para>"
msgstr "<परा>पसद्</para>"

#. Tag: para
#: index.docbook:76
#, no-c-format
msgid "<para>xpm</para>"
msgstr "<para>xpm</para> इति"

#. Tag: para
#: index.docbook:78
#, no-c-format
msgid "<para>ppm</para>"
msgstr "<परा>प्पम्</para>"

#. Tag: para
#: index.docbook:80
#, no-c-format
msgid "<para>pgm</para>"
msgstr "<परा>पग्म</para>"

#. Tag: para
