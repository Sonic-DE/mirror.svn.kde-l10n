#. Tag: title
#: man-plasmoidviewer.1.docbook:8
#, no-c-format
msgid "plasmoidviewer User's Manual"
msgstr "plasmoidviewer उपयोक्तृपुस्तिका"

#. Tag: date
#: man-plasmoidviewer.1.docbook:9
#, no-c-format
msgid "2017-01-09"
msgstr "२०१७-०१-०९"

#. Tag: releaseinfo
#: man-plasmoidviewer.1.docbook:10
#, no-c-format
msgid "Plasma 5.8"
msgstr "प्लाज्मा ५.८"

#. Tag: productname
#: man-plasmoidviewer.1.docbook:11
#, no-c-format
msgid "KDE Plasma"
msgstr "केडीई प्लाज्मा"

#. Tag: manvolnum
#: man-plasmoidviewer.1.docbook:16
#, no-c-format
msgid "<manvolnum>1</manvolnum>"
msgstr "<मन्वोल्नुम्>१</मन्वोल्नुम्>"

#. Tag: refpurpose
#: man-plasmoidviewer.1.docbook:21
#, no-c-format
msgid "Run Plasma widgets in their own window"
msgstr "स्वस्य विण्डो मध्ये Plasma widgets चालयन्तु"

#. Tag: cmdsynopsis
#: man-plasmoidviewer.1.docbook:25
#, no-c-format
msgid ""
"<command>plasmoidviewer</command> <group choice=\"opt\"><option>-v, --"
"version</option></group> <group choice=\"opt\"><option>-c, --containment</"
"option> <replaceable>name</replaceable></group> <group choice=\"opt"
"\"><option>-a, --applet</option> <replaceable>name</replaceable></group> "
"<group choice=\"opt\"><option>-f, --formfactor</option> <replaceable>name</"
"replaceable></group> <group choice=\"opt\"><option>-l, --location</option> "
"<replaceable>name</replaceable></group> <group choice=\"opt\"><option>-x, --"
"xPosition</option> <replaceable>xPosition</replaceable></group> <group "
"choice=\"opt\"><option>-y, --yPosition</option> <replaceable>yPosition</"
"replaceable></group> <group choice=\"opt\"><option>-s, --size</option> "
"<replaceable>widthXheight</replaceable></group> <group choice=\"opt"
"\"><option>-p, --pixmapcache</option> <replaceable>size</replaceable></"
"group> <group choice=\"opt\"><option>-t, --theme</option> <replaceable>name</"
"replaceable></group> <group choice=\"opt\"><option>-h, --help</option></"
"group> <arg choice=\"opt\">args</arg>"
msgstr ""
"<command>प्लाज्मोइडदर्शकः</command><group choice=\"opt\"><option value=\"-v, --"
"version\"> -व, --संस्करणम्</option></group><group choice=\"opt\"><option value="
"\"-c, --containment\"> -ग, --निरोधः</option><replaceable> नामः</"
"replaceable></group><group choice=\"opt\"><option value=\"-a, --applet\"> -"
"क, --एप्लेट्</option><replaceable> नामः</replaceable></group><group choice=\"opt"
"\"><option value=\"-f, --formfactor\"> -च, --रूपकारक</option><replaceable> "
"नामः</replaceable></group><group choice=\"opt\"><option value=\"-l, --"
"location\"> -l, --स्थानम्</option><replaceable> नामः</replaceable></"
"group><group choice=\"opt\"><option value=\"-x, --xPosition\"> -x, --xस्थानम्</"
"option><replaceable> xपदम्</replaceable></group><group choice=\"opt\"><option "
"value=\"-y, --yPosition\"> -y, --yPosition</option><replaceable> yपदम्</"
"replaceable></group><group choice=\"opt\"><option value=\"-s, --size\"> -स, "
"--आकार</option><replaceable> चौड़ाईXउच्चता</replaceable></group><group choice="
"\"opt\"><option value=\"-p, --pixmapcache\"> -प, --पिक्समापकैश</"
"option><replaceable> आकृति</replaceable></group><group choice=\"opt\"><option "
"value=\"-t, --theme\"> -त, --विषयः</option><replaceable> नामः</replaceable></"
"group><group choice=\"opt\"><option value=\"-h, --help\"> -ह, --सहाय</"
"option></group><arg choice=\"opt\"> अर्ग्स्</arg>"

#. Tag: title
#: man-plasmoidviewer.1.docbook:44
#, no-c-format
msgid "Description"
msgstr "वर्णनम्‌"

#. Tag: para
#: man-plasmoidviewer.1.docbook:45
#, no-c-format
msgid ""
"<command>plasmoidviewer</command> is a graphical tool allowing developers to "
"test Plasma applets."
msgstr ""
"<command>plasmoidviewer</command> इति चित्रात्मकं साधनं यत् विकासकाः प्लाज्मा एप्लेट्-"
"परीक्षणं कर्तुं शक्नुवन्ति ।"

#. Tag: para
#: man-plasmoidviewer.1.docbook:48
#, no-c-format
msgid ""
"Only installed applets will be found. <command>kbuildsycoca5</command> may "
"need to be run for newly-installed applets to be found."
msgstr ""
"केवलं संस्थापितानि एप्लेट्-पत्राणि एव प्राप्यन्ते । नवस्थापितानां एप्लेट्-सन्धानार्थं "
"<command>kbuildsycoca5</command> चालयितुं आवश्यकं भवेत् ।"

#. Tag: title
#: man-plasmoidviewer.1.docbook:54
#, no-c-format
msgid "Options"
msgstr "विकल्पाः"

#. Tag: option
#: man-plasmoidviewer.1.docbook:58
#, no-c-format
msgid "-v, --version"
msgstr "-व, --संस्करणम्"

#. Tag: para
#: man-plasmoidviewer.1.docbook:59
#, no-c-format
msgid "Displays version information."
msgstr "संस्करणसूचनाः प्रदर्शयति ।"

#. Tag: option
#: man-plasmoidviewer.1.docbook:62
#, no-c-format
msgid "-c, --containment <replaceable>name</replaceable>"
msgstr "-ग, --निग्रह <प्रतिस्थापनीय>नाम</प्रतिस्थापनीय>"

#. Tag: para
#: man-plasmoidviewer.1.docbook:63
#, no-c-format
msgid "The name of the containment plugin."
msgstr "निरोधप्लगिन् इत्यस्य नाम ।"

#. Tag: option
#: man-plasmoidviewer.1.docbook:66
#, no-c-format
msgid "-a, --applet <replaceable>name</replaceable>"
msgstr "-क, --एप्लेट् <प्रतिस्थापनीय>नाम</प्रतिस्थापनीय>"

#. Tag: para
#: man-plasmoidviewer.1.docbook:67
#, no-c-format
msgid "The name of the applet plugin."
msgstr "एप्लेट् प्लगिन् इत्यस्य नाम ।"

#. Tag: option
#: man-plasmoidviewer.1.docbook:70
#, no-c-format
msgid "-f, --formfactor <replaceable>name</replaceable>"
msgstr "-च, --रूपकारक <प्रतिस्थापनीय>नाम</प्रतिस्थापनीय>"

#. Tag: para
#: man-plasmoidviewer.1.docbook:71
#, no-c-format
msgid ""
"The formfactor to use (horizontal, vertical, mediacenter, planar or "
"application)."
msgstr "उपयोगाय रूपकारकः (क्षैतिजः, ऊर्ध्वाधरः, मध्यकेन्द्रः, समतलः वा अनुप्रयोगः) ।"

#. Tag: option
#: man-plasmoidviewer.1.docbook:74
#, no-c-format
msgid "-l, --location <replaceable>name</replaceable>"
msgstr "-l, --स्थान <प्रतिस्थापनीय>नाम</प्रतिस्थापनीय>"

#. Tag: para
#: man-plasmoidviewer.1.docbook:75
#, no-c-format
msgid ""
"The location constraint to start the Containment with (floating, desktop, "
"fullscreen, topedge, bottomedge, leftedge, rightedge)."
msgstr ""
"Containment इत्यस्य आरम्भार्थं स्थानस्य बाधा (floating, desktop, fullscreen, "
"topedge, bottomedge, leftedge, rightedge) ।"

#. Tag: option
#: man-plasmoidviewer.1.docbook:79
#, no-c-format
msgid "-x, --xPosition <replaceable>xPosition</replaceable>"
msgstr "-x, --xPosition <प्रतिस्थापनीय>xस्थान</प्रतिस्थापनीय>"

#. Tag: para
#: man-plasmoidviewer.1.docbook:80
#, no-c-format
msgid "Set the x position of the plasmoidviewer on the Plasma desktop."
msgstr "Plasma डेस्कटॉप् मध्ये plasmoidviewer इत्यस्य x स्थानं सेट् कुर्वन्तु ।"

#. Tag: option
#: man-plasmoidviewer.1.docbook:83
#, no-c-format
msgid "-y, --yPosition <replaceable>yPosition</replaceable>"
msgstr "-y, --yPosition <प्रतिस्थापनीय>yPosition</replaceable>"

#. Tag: para
#: man-plasmoidviewer.1.docbook:84
#, no-c-format
msgid "Set the y position of the plasmoidviewer on the Plasma desktop."
msgstr "Plasma डेस्कटॉप् मध्ये plasmoidviewer इत्यस्य y स्थानं सेट् कुर्वन्तु ।"

#. Tag: option
#: man-plasmoidviewer.1.docbook:87
#, no-c-format
msgid "-s, --size <replaceable>widthXheight</replaceable>"
msgstr "-s, --size <replaceable>widthXheight</replaceable> इति"

#. Tag: para
#: man-plasmoidviewer.1.docbook:88
#, no-c-format
msgid "Set the window size of the plasmoidview."
msgstr "प्लाज्मोइड्व्यू इत्यस्य विण्डो आकारं सेट् कुर्वन्तु ।"

#. Tag: option
#: man-plasmoidviewer.1.docbook:91
#, no-c-format
msgid "-p, --pixmapcache <replaceable>size</replaceable>"
msgstr "-p, --pixmapcache <प्रतिस्थापनीय>आकार</प्रतिस्थापनीय>"

#. Tag: para
#: man-plasmoidviewer.1.docbook:92
#, no-c-format
msgid "The size in KB to set the pixmap cache to."
msgstr "pixmap cache सेट् कर्तुं KB मध्ये आकारः ।"

#. Tag: option
#: man-plasmoidviewer.1.docbook:95
#, no-c-format
msgid "-t, --theme <replaceable>name</replaceable>"
msgstr "-त, --विषय <प्रतिस्थापनीय>नाम</प्रतिस्थापनीय>"

#. Tag: para
#: man-plasmoidviewer.1.docbook:96
#, no-c-format
msgid "The name of the theme which the shell will use."
msgstr "यस्य विषयस्य नाम शेल् प्रयोक्ष्यति।"

#. Tag: option
#: man-plasmoidviewer.1.docbook:99
#, no-c-format
msgid "-h, --help"
msgstr "-ह, --सहाय"

#. Tag: para
#: man-plasmoidviewer.1.docbook:100
#, no-c-format
msgid "Displays this help."
msgstr "एतत् साहाय्यं प्रदर्शयति ।"

#. Tag: replaceable
#: man-plasmoidviewer.1.docbook:103
#, no-c-format
msgid "args"
msgstr "अर्ग्स्"

#. Tag: para
#: man-plasmoidviewer.1.docbook:104
#, no-c-format
msgid "Data that should be passed to the applet as 'externalData' event."
msgstr "यत् दत्तांशं 'externalData' इवेण्ट् इति एप्लेट् प्रति पारितव्यम् ।"

#. Tag: title
#: man-plasmoidviewer.1.docbook:113
#, no-c-format
msgid "See Also"
msgstr "इदमपि पश्यन्तु"

#. Tag: para
#: man-plasmoidviewer.1.docbook:115
#, no-c-format
msgid ""
"More detailed user documentation is available from <ulink url=\"help:/plasma-"
"desktop\">help:/plasma-desktop</ulink> (either enter this <acronym>URL</"
"acronym> into &konqueror;, or run <userinput><command>khelpcenter</command> "
"<parameter>help:/plasma-desktop</parameter></userinput>)."
msgstr ""
"अधिकविस्तृतं उपयोक्तृदस्तावेजं <ulink url=\"help:/plasma-desktop\">help:/plasma-"
"desktop</ulink> इत्यस्मात् उपलभ्यते (एतत् <acronym>URL</acronym> इत्येतत् &konqueror; "
"इत्यत्र प्रविशन्तु, अथवा <userinput चालयन्तु ><command>khelpcenter</command> "
"<parameter>सहाय्यम्:/प्लाज्मा-डेस्कटॉप</parameter></userinput>) इति ।"

#. Tag: title
#: man-plasmoidviewer.1.docbook:124
#, no-c-format
msgid "Authors"
msgstr "लेखकाः"

