"\"><option value=--app> --app</option><replaceable> अनुप्रयोगः</replaceable></"
"group>"

#. Tag: cmdsynopsis
#: man-plasmaengineexplorer.1.docbook:41
#, no-c-format
msgid ""
"<command>plasmaengineexplorer</command> <arg choice=\"opt\">KDE Generic "
"Options</arg> <arg choice=\"opt\">Qt Generic Options</arg>"
msgstr ""
"<command>plasmaengineexplorer</command> <arg choice=\"opt\">KDE "
"सामान्यविकल्पाः</arg> <arg choice=\"opt\">Qt सामान्यविकल्पाः</arg>"

#. Tag: title
#: man-plasmaengineexplorer.1.docbook:49
#, no-c-format
msgid "Description"
msgstr "वर्णनम्‌"

#. Tag: para
#: man-plasmaengineexplorer.1.docbook:50
#, no-c-format
msgid ""
"<command>plasmaengineexplorer</command> is a graphical tool allowing "
"developers to test Plasma data engines without writing a Plasma applet."
msgstr ""
"<command>plasmaengineexplorer</command> इति चित्रात्मकं साधनं यत् विकासकाः प्लाज्मा "
"एप्लेट् लिखितुं विना प्लाज्मा-दत्तांश-इञ्जिनस्य परीक्षणं कर्तुं शक्नुवन्ति ।"

#. Tag: para
#: man-plasmaengineexplorer.1.docbook:53
#, no-c-format
msgid ""
"If no options are given, it will start without any data engine selected. The "
"required data engine can be selected from a drop-down list."
msgstr ""
"यदि विकल्पाः न दत्ताः तर्हि एतत् किमपि दत्तांशयन्त्रं चयनं विना आरभ्यते । आवश्यकं "
"दत्तांशयन्त्रं ड्रॉप्-डाउन-सूचिकातः चयनं कर्तुं शक्यते ।"

#. Tag: para
#: man-plasmaengineexplorer.1.docbook:56
#, no-c-format
msgid ""
"Only installed data engines will be found. <command>kbuildsycoca4</command> "
"may need to be run for newly-installed data engines to be found."
msgstr ""
"केवलं संस्थापितानि दत्तांशयन्त्राणि एव प्राप्यन्ते । नवस्थापितानां दत्तांशयन्त्राणां अन्वेषणार्थं "
"<command>kbuildsycoca4</command> चालयितुं आवश्यकं भवेत् ।"

#. Tag: title
#: man-plasmaengineexplorer.1.docbook:62
#, no-c-format
msgid "Options"
msgstr "विकल्पाः"

#. Tag: option
#: man-plasmaengineexplorer.1.docbook:66
#, no-c-format
msgid "-v, --version"
msgstr "-व, --संस्करणम्"

#. Tag: para
#: man-plasmaengineexplorer.1.docbook:67
#, no-c-format
msgid "Displays version information."
msgstr "संस्करणसूचनाः प्रदर्शयति ।"

#. Tag: option
#: man-plasmaengineexplorer.1.docbook:70
#, no-c-format
msgid "-h, --help"
msgstr "-ह, --सहाय"

#. Tag: para
#: man-plasmaengineexplorer.1.docbook:71
#, no-c-format
msgid "Displays this help."
msgstr "एतत् साहाय्यं प्रदर्शयति ।"

#. Tag: option
#: man-plasmaengineexplorer.1.docbook:74
#, no-c-format
msgid "--list <replaceable>pixels</replaceable>"
msgstr "--list <replaceable>पिक्सेल</replaceable> इति"

#. Tag: para
#: man-plasmaengineexplorer.1.docbook:75
#, no-c-format
msgid "Displays a list of known engines and their descriptions."
msgstr "ज्ञातानां इञ्जिनानां सूचीं तेषां वर्णनं च प्रदर्शयति ।"

#. Tag: option
#: man-plasmaengineexplorer.1.docbook:78
#, no-c-format
msgid "--height"
msgstr "--औनत्यम्‌"

#. Tag: para
#: man-plasmaengineexplorer.1.docbook:79
#, no-c-format
msgid "Sets the height of the window, in pixels."
msgstr "विण्डो इत्यस्य ऊर्ध्वतां सेट् करोति, पिक्सेलरूपेण ।"

#. Tag: option
#: man-plasmaengineexplorer.1.docbook:82
#, no-c-format
msgid "--width <replaceable>pixels</replaceable>"
msgstr "--width <replaceable>पिक्सेल</replaceable> इति"

#. Tag: para
#: man-plasmaengineexplorer.1.docbook:83
#, no-c-format
msgid "Sets the width of the window, in pixels."
msgstr "विण्डो इत्यस्य विस्तारं सेट् करोति, पिक्सेलरूपेण ।"

#. Tag: option
#: man-plasmaengineexplorer.1.docbook:86
#, no-c-format
msgid "-x <replaceable>pixels</replaceable>"
msgstr "-x <प्रतिस्थापनीय>पिक्सेल</replaceable>"

#. Tag: para
#: man-plasmaengineexplorer.1.docbook:87
#, no-c-format
msgid ""
"Sets the x (horizontal) co-ordinate of the top left corner of the window, in "
"pixels."
msgstr "विण्डो इत्यस्य उपरि वामकोणस्य x (क्षैतिज) निर्देशांकं, पिक्सेलरूपेण सेट् करोति ।"

#. Tag: option
#: man-plasmaengineexplorer.1.docbook:90
#, no-c-format
msgid "-y <replaceable>pixels</replaceable>"
msgstr "-y <replaceable>पिक्सेल</replaceable> इति"

#. Tag: para
#: man-plasmaengineexplorer.1.docbook:91
#, no-c-format
msgid ""
"Sets the y (vertical) co-ordinate of the top left corner of the window, in "
"pixels."
msgstr "विण्डो इत्यस्य उपरि वामकोणस्य y (ऊर्ध्वाधरः) निर्देशांकं, पिक्सेलरूपेण सेट् करोति ।"

#. Tag: option
#: man-plasmaengineexplorer.1.docbook:94
#, no-c-format
msgid "--engine <replaceable>data engine</replaceable>"
msgstr "--engine <replaceable>दत्तांशइञ्जिन</replaceable>"

#. Tag: para
#: man-plasmaengineexplorer.1.docbook:95
#, no-c-format
msgid ""
"Start <command>plasmaengineexplorer</command> with the given data engine "
"selected. <parameter>data engine</parameter> is the internal name of the "
"data engine given by the X-KDE-PluginInfo-Name key of the desktop file."
msgstr ""
"दत्तं दत्तांशयन्त्रं चयनितं कृत्वा <command>plasmaengineexplorer</command> आरभ्यताम् । "
"<parameter>data engine</parameter> इति डेस्कटॉप् सञ्चिकायाः X-KDE-PluginInfo-"
"Name कीलद्वारा दत्तस्य data engine इत्यस्य आन्तरिकं नाम ।"

#. Tag: option
#: man-plasmaengineexplorer.1.docbook:100
#, no-c-format
msgid "--source <replaceable>data engine</replaceable>"
msgstr "--source <replaceable>दत्तांशइञ्जिन</replaceable>"

#. Tag: para
#: man-plasmaengineexplorer.1.docbook:101
#, no-c-format
msgid ""
"Only valid in conjunction with <option>--engine</option>. Requests a "
"specific source from the data engine when <command>plasmaengineexplorer</"
"command> is started."
msgstr ""
"केवलं सह संयोगे एव मान्यम्<option value=--engine> --यन्त्र</option> . दत्तांशइञ्जिनात् "
"विशिष्टं स्रोतं अनुरोधयति यदा<command> प्लाज्माइञ्जिनएक्सप्लोरर</command> प्रारभ्यते ।"

#. Tag: option
#: man-plasmaengineexplorer.1.docbook:106
#, no-c-format
msgid "--interval <replaceable>time</replaceable>"
msgstr "--अन्तराल <प्रतिस्थापनीय>समय</प्रतिस्थापनीय>"

#. Tag: para
#: man-plasmaengineexplorer.1.docbook:107
#, no-c-format
msgid ""
"Sets the default update interval for requested sources to <parameter>time</"
"parameter> milliseconds. If not set, the source will update on demand (for "
"some sources, this will be when new data is available)."
msgstr ""
"अनुरोधितस्रोतानां कृते पूर्वनिर्धारितं अद्यतनान्तरं <parameter>time</parameter> मिलीसेकेण्ड् "
"इति सेट् करोति । यदि न सेट् भवति तर्हि स्रोतः आग्रहेण अद्यतनं करिष्यति (केषाञ्चन स्रोतां "
"कृते, एतत् तदा भविष्यति यदा नूतनदत्तांशः उपलब्धः भवति) ।"

#. Tag: para
#: man-plasmaengineexplorer.1.docbook:110
#, no-c-format
msgid ""
"If <option>--source</option> is specified, this is the update interval that "
"will be used when requesting that source."
msgstr ""
"यदि<option value=--source> --स्रोतः</option> निर्दिष्टं भवति, एतत् अद्यतनान्तरं यत् "
"तस्य स्रोतस्य अनुरोधं कुर्वन् उपयुज्यते ।"

#. Tag: option
#: man-plasmaengineexplorer.1.docbook:114
#, no-c-format
msgid "--app <replaceable>application</replaceable>"
msgstr "--app <replaceable>अनुप्रयोगः</replaceable>"

#. Tag: para
#: man-plasmaengineexplorer.1.docbook:115
#, no-c-format
msgid ""
"Only show engines associated with the parent application; maps to the X-KDE-"
"ParentApp entry in the DataEngine's .desktop file."
msgstr ""
"केवलं मातापितृ-अनुप्रयोगेन सह सम्बद्धानि इञ्जिनानि दर्शयन्तु; DataEngine इत्यस्य .desktop "
"सञ्चिकायां X-KDE-ParentApp प्रविष्टिं प्रति नक्शाङ्कयति ।"

#. Tag: title
#: man-plasmaengineexplorer.1.docbook:124
#, no-c-format
msgid "See Also"
msgstr "इदमपि पश्यन्तु"

#. Tag: para
#: man-plasmaengineexplorer.1.docbook:126
#, no-c-format
msgid ""
"More detailed user documentation is available from <ulink url=\"help:/plasma-"
"desktop\">help:/plasma-desktop</ulink> (either enter this <acronym>URL</"
"acronym> into &konqueror;, or run <userinput><command>khelpcenter</command> "
"<parameter>help:/plasma-desktop</parameter></userinput>)."
msgstr ""
"अधिकविस्तृतं उपयोक्तृदस्तावेजं <ulink url=\"help:/plasma-desktop\">help:/plasma-"
"desktop</ulink> इत्यस्मात् उपलभ्यते (एतत् <acronym>URL</acronym> इत्येतत् &konqueror; "
"इत्यत्र प्रविशन्तु, अथवा <userinput चालयन्तु ><command>khelpcenter</command> "
"<parameter>सहाय्यम्:/प्लाज्मा-डेस्कटॉप</parameter></userinput>) इति ।"

#. Tag: title
#: man-plasmaengineexplorer.1.docbook:135
#, no-c-format
msgid "Examples"
msgstr "उदाहरणानि"

#. Tag: para
#: man-plasmaengineexplorer.1.docbook:136
#, no-c-format
msgid ""
"Load the time data engine, showing the local time and updating every second:"
msgstr "समयदत्तांशइञ्जिनं लोड् कुर्वन्तु, स्थानीयसमयं दर्शयित्वा प्रत्येकं सेकेण्ड् अद्यतनं कुर्वन्तु:"

#. Tag: screen
#: man-plasmaengineexplorer.1.docbook:138
#, no-c-format
msgid ""
"<userinput><command>plasmaengineexplorer</command> <option>--engine time</"
"option> <option>--source Local</option> <option>--interval 1000</option></"
"userinput>"
msgstr ""
"<userinput><command>प्लाज्माइञ्जिनएक्सप्लोरर</command><option value=\"--engine "
"time\"> --इञ्जिन समय</option><option value=\"--source Local\"> --source "
"स्थानीय</option><option value=\"--interval 1000\"> --अन्तराल 1000</option></"
"userinput>"

#. Tag: title
#: man-plasmaengineexplorer.1.docbook:143
#, no-c-format
msgid "Authors"
msgstr "लेखकाः"

