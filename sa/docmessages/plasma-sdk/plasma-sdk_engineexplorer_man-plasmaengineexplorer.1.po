#. Tag: title
#: man-plasmaengineexplorer.1.docbook:8
#, no-c-format
msgid "plasmaengineexplorer User's Manual"
msgstr "plasmaengineexplorer उपयोक्तृपुस्तिका"

#. Tag: date
#: man-plasmaengineexplorer.1.docbook:9
#, no-c-format
msgid "2017-01-09"
msgstr "२०१७-०१-०९"

#. Tag: releaseinfo
#: man-plasmaengineexplorer.1.docbook:10
#, no-c-format
msgid "Plasma 5.8"
msgstr "प्लाज्मा ५.८"

#. Tag: productname
#: man-plasmaengineexplorer.1.docbook:11
#, no-c-format
msgid "KDE Plasma"
msgstr "केडीई प्लाज्मा"

#. Tag: manvolnum
#: man-plasmaengineexplorer.1.docbook:16
#, no-c-format
msgid "<manvolnum>1</manvolnum>"
msgstr "<मन्वोल्नुम्>१</मन्वोल्नुम्>"

#. Tag: refpurpose
#: man-plasmaengineexplorer.1.docbook:21
#, no-c-format
msgid "Provides direct access to plasma data engines"
msgstr "प्लाज्मा-दत्तांश-इञ्जिनेषु प्रत्यक्षं प्रवेशं प्रदाति"

#. Tag: cmdsynopsis
