msgstr "अश्वसेना"

#. Tag: entry
#: index.docbook:461
#, no-c-format
msgid "Icon representing five armies."
msgstr "पञ्चसेनानां प्रतिनिधित्वं कृत्वा चिह्नम्।"

#. Tag: literal
#: index.docbook:464
#, no-c-format
