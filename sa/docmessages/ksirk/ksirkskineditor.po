msgstr "कुण्डस्य तत्त्वानि"

#. Tag: entry
#: index.docbook:437
#, no-c-format
msgid "Element name"
msgstr "तत्त्व नाम"

#. Tag: entry
#: index.docbook:438
#, no-c-format
