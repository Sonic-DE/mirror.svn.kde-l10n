#, no-c-format
msgid "defendTwo.png"
msgstr "defendTwo.png"

#. Tag: entry
#: index.docbook:575
#, no-c-format
msgid "Chooses to defend an attacked country with two armies."
msgstr "आक्रमितदेशस्य रक्षणं द्वयोः सेनायोः सह चयनं करोति।"

#. Tag: filename
#: index.docbook:579
#, no-c-format
msgid "moveArmies.png"
msgstr "moveArmies.png"

#. Tag: entry
#: index.docbook:580
#, no-c-format
msgid ""
"Chooses to start the moving of armies between two countries (last action in "
"the turn)."
msgstr "द्वयोः देशयोः मध्ये सेनायाः चालनं आरभ्यतुं चयनं करोति (वारे अन्तिमक्रिया)।"

