#: index.docbook:3831 index.docbook:3874 index.docbook:3932 index.docbook:3943
#: index.docbook:4001 index.docbook:4017 index.docbook:4028 index.docbook:4155
#, no-c-format
msgid "Default: not selected"
msgstr "पूर्वनिर्धारितम्: न चयनितम्"

#. Tag: guilabel
#: index.docbook:1778
#, no-c-format
msgid "Minimal SMB protocol version:"
msgstr "न्यूनतमं SMB प्रोटोकॉलसंस्करणम् :"

#. Tag: para
#: index.docbook:1781 index.docbook:1816
#, no-c-format
msgid "The following protocol versions can be set:"
msgstr "निम्नलिखित प्रोटोकॉल संस्करणं सेट् कर्तुं शक्यते:"

#. Tag: guimenuitem
#: index.docbook:1785 index.docbook:1820
#, no-c-format
msgid "NT1 (Classic CIFS/SMBv1 protocol)"
msgstr "NT1 (क्लासिक CIFS/SMBv1 प्रोटोकॉल) 1.1."

#. Tag: para
#: index.docbook:1788 index.docbook:1823
#, no-c-format
msgid ""
"This is the classic version of the protocol. It is used by &Windows; NT and "
"is known as CIFS or SMBv1. It is considered to be unsafe and was disabled in "
"the latest &Samba; and &Windows; versions."
msgstr ""
"एतत् प्रोटोकॉलस्य क्लासिकं संस्करणम् अस्ति । अस्य उपयोगः &Windows; NT तथा CIFS अथवा "
"SMBv1 इति नाम्ना प्रसिद्धः अस्ति । असुरक्षितं मन्यते, नवीनतमे &Samba; तथा &विण्डोज; "
"संस्करणाः ।"

#. Tag: guimenuitem
#: index.docbook:1793 index.docbook:1828
#, no-c-format
msgid "SMB2 (Windows Vista and above)"
msgstr "SMB2 (विण्डोज विस्टा अपि च उपरि)"

#. Tag: para
#: index.docbook:1796 index.docbook:1831
#, no-c-format
msgid ""
"This is the re-implementation of the SMB protocol. It is used by &Windows; "
"Vista and above."
msgstr ""
"एतत् SMB प्रोटोकॉलस्य पुनः कार्यान्वयनम् अस्ति । अस्य उपयोगः &Windows; विस्टा च उपरि ।"

#. Tag: guimenuitem
#: index.docbook:1801 index.docbook:1836
#, no-c-format
msgid "SMB3 (Windows 8 and above)"
msgstr "SMB3 (विण्डोज ८ अपि च उपरि)"

#. Tag: para
#: index.docbook:1804
#, no-c-format
msgid ""
"This is the SMBv3 protocol version. It features several improvements of the "
"functionality and performance of SMBv2 as well as several security "
"enhancements. This protocol version is used by &Windows; 8 and above."
msgstr ""
"एतत् SMBv3 प्रोटोकॉलसंस्करणम् अस्ति । अस्मिन् SMBv2 इत्यस्य कार्यक्षमतायाः कार्यक्षमतायाः "
"च अनेकाः सुधाराः अपि च अनेकाः सुरक्षावर्धनाः सन्ति । एतत् प्रोटोकॉलसंस्करणं &Windows; ८ "
"उपरि च ।"

#. Tag: para
#: index.docbook:1808
#, no-c-format
msgid "Default: <guimenuitem>SMB2 (Windows Vista and above)</guimenuitem>"
msgstr ""
"पूर्वनिर्धारितम्: <guimenuitem>SMB2 (विण्डोज विस्टा अपि च उपरि)</guimenuitem>"

#. Tag: guilabel
#: index.docbook:1813
#, no-c-format
msgid "Maximal SMB protocol version:"
msgstr "अधिकतमं SMB प्रोटोकॉलसंस्करणम् :"

#. Tag: para
#: index.docbook:1839
#, no-c-format
msgid ""
"This is the SMBv3 protocol version. It features serveral improvements of the "
"functionality and performance of SMBv2 as well as serveral security "
"enhancements. This protocol version is used by &Windows; 8 and above."
msgstr ""
"एतत् SMBv3 प्रोटोकॉलसंस्करणम् अस्ति । अस्मिन् SMBv2 इत्यस्य कार्यक्षमतायाः कार्यक्षमतायाः "
"च सर्वरल् सुधारणं तथा च सर्वरल् सुरक्षावर्धनं दृश्यते । एतत् प्रोटोकॉलसंस्करणं &Windows; ८ "
"उपरि च ।"

#. Tag: para
#: index.docbook:1843
#, no-c-format
msgid "Default: <guimenuitem>SMB3 (Windows 8 and above)</guimenuitem>"
msgstr "पूर्वनिर्धारितम्: <guimenuitem>SMB3 (विण्डोज 8 अपि च उपरि)</guimenuitem>"

#. Tag: title
#: index.docbook:1853 index.docbook:2039 index.docbook:3259
#, no-c-format
msgid "Behavior"
msgstr "व्यवहार"

#. Tag: guibutton
#: index.docbook:1858
#, no-c-format
msgid "Detect printer shares"
msgstr "मुद्रकसाझेदारीम् अन्वेष्टुम्"

#. Tag: para
#: index.docbook:1861
#, no-c-format
msgid "Printer shares are detected."
msgstr "मुद्रकस्य भागाः ज्ञायन्ते ।"

#. Tag: guibutton
#: index.docbook:1867
#, no-c-format
msgid "Detect hidden shares"
msgstr "गुप्तभागानाम् अन्वेषणं कुर्वन्तु"

#. Tag: para
#: index.docbook:1870
#, no-c-format
msgid ""
"Hidden shares are detected. Hidden shares are ending with a $ sign, &eg; "
"Musik$ or IPC$."
msgstr "गुप्तभागाः ज्ञायन्ते। गुप्तभागाः $ चिह्नेन समाप्ताः सन्ति, &eg; Musik$ अथवा IPC$।"

#. Tag: guibutton
#: index.docbook:1876
#, no-c-format
msgid "Preview hidden files and directories"
msgstr "गुप्तसञ्चिकानां निर्देशिकानां च पूर्वावलोकनं कुर्वन्तु"

#. Tag: para
#: index.docbook:1879
#, no-c-format
msgid ""
"Show all files and directories including the hidden ones when opening a "
"share's contents in the preview dialog."
msgstr ""
"पूर्वावलोकनसंवादे भागस्य सामग्रीं उद्घाटयन्ते सति गुप्ताः सहितं सर्वाणि सञ्चिकानि "
"निर्देशिकाश्च दर्शयन्तु ।"

#. Tag: title
#: index.docbook:1892
#, no-c-format
msgid "Advanced Settings"
msgstr "उन्नत सेटिंग्स्"

#. Tag: title
#: index.docbook:1895
#, no-c-format
msgid "<title>Samba</title>"
msgstr "<title>साम्बः</title>"

#. Tag: guibutton
#: index.docbook:1900
#, no-c-format
msgid "Set the SMB port to"
msgstr "SMB पोर्ट् इति सेट् कुर्वन्तु"

#. Tag: para
#: index.docbook:1903
#, no-c-format
msgid ""
"Enabling this setting sets the remote SMB port number to communicate with a "
"remote host to the value defined in the spin box. Under BSD, this is also "
"the port that is used for mounting."
msgstr ""
"एतत् सेटिङ्ग् सक्षमं कृत्वा दूरस्थं SMB पोर्ट् सङ्ख्यां दूरस्थेन होस्ट् इत्यनेन सह संवादं कर्तुं स्पिन "
"बॉक्स् मध्ये परिभाषितं मूल्यं प्रति सेट् करोति । BSD इत्यस्य अधः एतत् पोर्ट् अपि अस्ति यत् "
"माउण्टिङ्ग् कृते उपयुज्यते ।"

#. Tag: para
#: index.docbook:1904
#, no-c-format
msgid ""
"Unless you are using a firewall or have a customized network setup, you do "
"not need to change anything here."
msgstr ""
"यावत् भवान् अग्निप्रावरणं न उपयुङ्क्ते अथवा अनुकूलितं जालस्थापनं न करोति तावत् भवता अत्र "
"किमपि परिवर्तनस्य आवश्यकता नास्ति ।"

#. Tag: para
#: index.docbook:1905
#, no-c-format
msgid "Default: 139"
msgstr "पूर्वनिर्धारितम् : १३९"

#. Tag: guibutton
#: index.docbook:1910
#, no-c-format
msgid "Set the encryption level to"
msgstr "एन्क्रिप्शनस्तरं इति सेट् कुर्वन्तु"

#. Tag: para
#: index.docbook:1913
#, no-c-format
msgid ""
"Set the level of encryption that is used to make connections. The following "
"settings can be chosen:"
msgstr ""
"संयोजनानि कर्तुं यत् एन्क्रिप्शनस्य स्तरं उपयुज्यते तत् सेट् कुर्वन्तु । निम्नलिखितसेटिंग्स् चिन्वितुं "
"शक्यन्ते ।"

#. Tag: guimenuitem
#: index.docbook:1917
#, no-c-format
msgid "None"
msgstr "न कश्चित्"

#. Tag: para
#: index.docbook:1920
#, no-c-format
msgid "Encryption is not used."
msgstr "एन्क्रिप्शनस्य उपयोगः न भवति ।"

#. Tag: guimenuitem
#: index.docbook:1925
#, no-c-format
msgid "Request"
msgstr "अनुरोधः"

#. Tag: para
#: index.docbook:1928
#, no-c-format
msgid "Encryption is requested."
msgstr "एन्क्रिप्शनं प्रार्थ्यते।"

#. Tag: guimenuitem
#: index.docbook:1933
#, no-c-format
msgid "Require"
msgstr "आवश्यक"

#. Tag: para
#: index.docbook:1936
#, no-c-format
msgid "Encryption is required."
msgstr "एन्क्रिप्शन आवश्यकम् अस्ति।"

#. Tag: para
#: index.docbook:1940
#, no-c-format
msgid "Default: <guimenuitem>None</guimenuitem>"
msgstr "पूर्वनिर्धारितम्: <guimenuitem>कोऽपि नास्ति</guimenuitem>"

#. Tag: guibutton
#: index.docbook:1945
#, no-c-format
msgid "This computer is on a large network neighborhood"
msgstr "अयं सङ्गणकः विशाले जालपरिसरस्य उपरि अस्ति"

#. Tag: para
#: index.docbook:1948
#, no-c-format
msgid ""
"In the default configuration, all available master browsers are queried when "
"the browse list is compiled. On large network neighborhoods this can be very "
"time consuming. Enabling this setting restricts the query to three master "
"browsers."
msgstr ""
"पूर्वनिर्धारितविन्यासे, ब्राउजसूची संकलितसमये सर्वे उपलब्धाः मुख्यब्राउजराः पृच्छ्यन्ते । बृहत् "
"जालपरिसरेषु एतत् अतीव समयग्राहकं भवितुम् अर्हति । एतत् सेटिङ्ग् सक्षमीकरणेन प्रश्नः त्रयः "
"मुख्यब्राउजर् मध्ये प्रतिबन्धितः भवति ।"

#. Tag: guibutton
#: index.docbook:1954
#, no-c-format
msgid "Master browsers require authentication"
msgstr "मास्टर ब्राउजर् कृते प्रमाणीकरणस्य आवश्यकता भवति"

#. Tag: para
#: index.docbook:1957
#, no-c-format
msgid ""
"If the workgroup master browsers require authentication to return the browse "
"list, you need to check this button. This may be the case for example with "
"some NAS devices. This setting is rarely needed and might even cause a "
"master browser to return an empty browse list."
msgstr ""
"यदि कार्यसमूहस्य मुख्यब्राउजर् ब्राउज् सूचीं प्रत्यागन्तुं प्रमाणीकरणस्य आवश्यकता भवति तर्हि "
"भवद्भिः एतत् बटन् परीक्षितव्यम् । एतत् उदाहरणार्थं केषुचित् NAS उपकरणेषु भवितुम् अर्हति । "
"एतस्य सेटिङ्ग् इत्यस्य आवश्यकता दुर्लभा अस्ति तथा च मुख्यब्राउजर् रिक्तं ब्राउजर् सूचीं प्रत्यागन्तुं "
"अपि शक्नोति ।"

#. Tag: guibutton
#: index.docbook:1963
#, no-c-format
msgid "Use Kerberos for authentication"
msgstr "प्रमाणीकरणार्थं Kerberos इत्यस्य उपयोगं कुर्वन्तु"

#. Tag: para
#: index.docbook:1966
#, no-c-format
msgid "Use Kerberos for authentication in an Active Directory environment."
msgstr "सक्रियनिर्देशिकावातावरणे प्रमाणीकरणाय Kerberos इत्यस्य उपयोगं कुर्वन्तु ।"

#. Tag: guibutton
#: index.docbook:1972
#, no-c-format
msgid "Use Winbind ccache for authentication"
msgstr "प्रमाणीकरणार्थं Winbind ccache इत्यस्य उपयोगं कुर्वन्तु"

#. Tag: para
#: index.docbook:1975
#, no-c-format
msgid "Try to use the credentials cached by Winbind."
msgstr "Winbind द्वारा संग्रहीतं प्रमाणपत्रं उपयोक्तुं प्रयतध्वम् ।"

#. Tag: title
#: index.docbook:1982
#, no-c-format
msgid "Wake-On-LAN"
msgstr "जाग-ऑन-लैन्"

#. Tag: para
#: index.docbook:1984
#, no-c-format
msgid ""
"To be able to use the Wake-On-LAN capability of &smb4k;, you have to enable "
"this setting. The hosts that should to be woken up have to be defined "
"through the <link linkend="
"\"network_neighborhood_browser_defining_custom_settings\">custom settings "
"editor</link>."
msgstr ""
"&amp;smb4k; इत्यस्य Wake-On-LAN क्षमतां उपयोक्तुं शक्नुवन् भवद्भिः एतत् सेटिङ्ग् सक्षमं "
"कर्तव्यम् । ये गणाः जागरितव्याः तेषां माध्यमेन परिभाषितव्याः भवन्ति<link linkend="
"\"network_neighborhood_browser_defining_custom_settings\"> कस्टम सेटिंग्स् "
"सम्पादकः</link> ."

#. Tag: guibutton
#: index.docbook:1989
#, no-c-format
msgid "Enable Wake-On-LAN features"
msgstr "Wake-On-LAN विशेषताः सक्षमाः कुर्वन्तु"

#. Tag: para
#: index.docbook:1992
#, no-c-format
msgid ""
"Enable Wake-on-LAN (WOL) features. Wake-On-LAN is an ethernet computer "
"networking standard that allows a computer to be turned on or woken up by a "
"network message. Smb4K uses a magic packet send via a UDP socket to wake up "
"remote servers. If you want to take advantage of the Wake-On-LAN feature, "
"you need to enable this option."
msgstr ""
"Wake-on-LAN (WOL) इति सुविधाः सक्षमाः कुर्वन्तु । Wake-On-LAN इति ईथरनेट् "
"सङ्गणकसंजालमानकम् अस्ति यत् सङ्गणकं जालसन्देशेन चालू कर्तुं वा जागृतुं वा शक्नोति । Smb4K "
"दूरस्थसर्वरं जागृतुं UDP सॉकेट् मार्गेण प्रेषितं जादुपैकेट् उपयुज्यते । यदि भवान् Wake-On-LAN इति "
"सुविधायाः लाभं ग्रहीतुं इच्छति तर्हि भवान् एतत् विकल्पं सक्षमं कर्तव्यम् ।"

#. Tag: guilabel
#: index.docbook:1997
#, no-c-format
msgid "Waiting time"
msgstr "प्रतीक्षाकालः"

#. Tag: para
#: index.docbook:2000
#, no-c-format
msgid ""
"This is the waiting time in seconds between the sending of the magic Wake-On-"
"LAN packets and the scanning of the network neighborhood or the mounting of "
"a share."
msgstr ""
"एषः जादुई Wake-On-LAN-पैकेट्-प्रेषणस्य च संजाल-परिसरस्य स्कैनिङ्गस्य अथवा भागस्य माउण्टिङ्ग्-"
"योः मध्ये सेकण्ड्-मात्रायां प्रतीक्षासमयः अस्ति"

#. Tag: para
#: index.docbook:2001
#, no-c-format
msgid "Default: 5 s"
msgstr "पूर्वनिर्धारित: 5 s"

#. Tag: title
#: index.docbook:2017
#, no-c-format
msgid "Mounting"
msgstr "माउण्टिङ्ग्"

#. Tag: para
#: index.docbook:2019
#, no-c-format
msgid ""
"This configuration page contains all settings regarding the mounting of "
"shares. The settings appearing here are depending on the operation system "
"you are using."
msgstr ""
"अस्मिन् विन्यासपृष्ठे भागानां माउण्ट्-सम्बद्धानि सर्वाणि सेटिङ्ग्स् सन्ति । अत्र दृश्यमानानि "
"सेटिङ्ग्स् भवता उपयुज्यमानस्य ऑपरेशन सिस्टम् इत्यस्य आधारेण भवन्ति ।"

#. Tag: screeninfo
#: index.docbook:2022
#, no-c-format
msgid "Screenshot of the \"Mounting\" configuration page"
msgstr "\"Mounting\" विन्यासपृष्ठस्य स्क्रीनशॉट्"

#. Tag: phrase
#: index.docbook:2025
#, no-c-format
msgid "The \"Mounting\" configuration page"
msgstr "\"Mounting\" विन्यासपृष्ठम्"

#. Tag: para
#: index.docbook:2036
#, no-c-format
msgid ""
"The settings in this tab are the same for all supported operating systems."
msgstr "अस्मिन् ट्याब् मध्ये सेटिङ्ग्स् सर्वेषां समर्थितानां प्रचालनतन्त्राणां कृते समानाः सन्ति ।"

#. Tag: guibutton
#: index.docbook:2044
#, no-c-format
msgid "Remount shares"
msgstr "शेयर्स् पुनः माउंट करें"

#. Tag: para
#: index.docbook:2047
#, no-c-format
msgid ""
"Remount all your shares that were mounted when you exited the program or "
"changed a profile. If the remounting of a share fails, Smb4K will retry the "
"next time it is started. Shares that were mounted by other users are ignored."
msgstr ""
"भवता कार्यक्रमात् निर्गतस्य अथवा प्रोफाइल परिवर्तनस्य समये माउण्ट् कृतानि सर्वाणि भागानि "
"पुनः माउण्ट् कृतवन्तः । यदि कस्यचित् भागस्य पुनः माउण्टिङ्ग् विफलं भवति तर्हि Smb4K अग्रिमे "
"समये पुनः प्रयासं करिष्यति । अन्यैः उपयोक्तृभिः ये भागाः माउण्ट् कृताः आसन् ते उपेक्षिताः "
"भवन्ति ।"

#. Tag: guilabel
#: index.docbook:2052
#, no-c-format
msgid "Number of remount attempts"
msgstr "पुनः माउण्ट् प्रयत्नानाम् संख्या"

#. Tag: para
#: index.docbook:2055
#, no-c-format
msgid ""
"Set the number of attempts that are made to remount shares before Smb4K "
"gives up."
msgstr ""
"Smb4K इत्यस्य त्यागात् पूर्वं शेयर्स् पुनः माउण्ट् कर्तुं ये प्रयत्नाः क्रियन्ते तेषां संख्यां सेट् कुर्वन्तु "
"।"

#. Tag: para
#: index.docbook:2056
#, no-c-format
msgid "Default: 1"
msgstr "पूर्वनिर्धारितम् : 1"

#. Tag: guilabel
#: index.docbook:2061
#, no-c-format
msgid "Interval between remount attempts"
msgstr "पुनः माउण्ट्-प्रयासानां मध्ये अन्तरम्"

#. Tag: para
#: index.docbook:2064
#, no-c-format
msgid "Set the time that elapses between attempts to remount shares."
msgstr "शेयर्स् पुनः माउण्ट् कर्तुं प्रयत्नानाम् मध्ये यः समयः व्यतीतः सः सेट् कुर्वन्तु ।"

#. Tag: para
#: index.docbook:2065
#, no-c-format
msgid "Default: 5 min"
msgstr "पूर्वनिर्धारित: 5 मि"

#. Tag: guibutton
#: index.docbook:2073
#, no-c-format
msgid "Unmount all personal shares on exit"
msgstr "निर्गमनसमये सर्वाणि व्यक्तिगतभागाः अनमाउण्ट् कुर्वन्तु"

#. Tag: para
#: index.docbook:2076
#, no-c-format
msgid ""
"Unmount all shares that belong to you when the program exits. Shares that "
"are owned by other users are ignored."
msgstr ""
"कार्यक्रमस्य निर्गमनसमये भवतः सर्वान् भागान् अनमाउण्ट् कुर्वन्तु । अन्येषां उपयोक्तृणां स्वामित्वं "
"येषां भागानां भवति ते उपेक्षिताः भवन्ति ।"

#. Tag: guibutton
#: index.docbook:2082
#, no-c-format
msgid "Force unmounting of inaccessible shares"
msgstr "दुर्गमभागानाम् अनमाउण्टिंगं बलात्"

#. Tag: para
#: index.docbook:2085
#, no-c-format
msgid ""
"Force unmounting of inaccessible shares (&Linux; only). In case a share is "
"inaccessible, a lazy unmount is performed. Before the actual unmounting is "
"done, a warning dialog is shown asking to approve the unmount."
msgstr ""
"दुर्गमभागानाम् (&Linux; केवलं) अनमाउण्टिङ्ग् कर्तुं बाध्यताम्। यदि भागः दुर्गमः भवति तर्हि "
"आलस्यपूर्णः अनमाउण्ट् क्रियते । वास्तविकं अनमाउण्ट्-करणात् पूर्वं, अनमाउण्ट्-अनुमोदनं कर्तुं पृच्छन् "
"चेतावनी-संवादः दर्शितः भवति ।"

#. Tag: guibutton
#: index.docbook:2091
#, no-c-format
msgid "Detect all shares that are mounted on the system"
msgstr "प्रणाल्यां माउण्ट् कृताः सर्वे भागाः अन्वेष्टुम्"

#. Tag: para
#: index.docbook:2094
#, no-c-format
msgid ""
"You will not only see the shares that were mounted and are owned by you, but "
"also all other mounts using the SMBFS (BSD) and &CIFS; (&Linux;) file system "
"that are present on the system."
msgstr ""
"भवान् न केवलं तानि भागानि द्रक्ष्यति ये माउण्ट् कृताः आसन्, भवतः स्वामित्वे च सन्ति, अपितु "
"SMBFS (BSD) तथा &CIFS; (&Linux;) सञ्चिकातन्त्रं ये प्रणाल्यां वर्तन्ते ।"

#. Tag: title
#: index.docbook:2107
#, no-c-format
msgid "Common Mount Settings (&Linux; only)"
msgstr "सामान्यं माउण्ट् सेटिंग्स् (&Linux; केवलं)"

#. Tag: para
#: index.docbook:2109
#, no-c-format
msgid ""
"The <guilabel>Common Mount Settings</guilabel> tab is only available under "
"&Linux; and the listed options refer to the <ulink url=\"man:/mount.cifs"
"\"><citerefentry><refentrytitle>mount.cifs</refentrytitle><manvolnum>8</"
"manvolnum></citerefentry></ulink> / <ulink url=\"man:/mount."
"smb3\"><citerefentry><refentrytitle>mount.smb3</refentrytitle><manvolnum>8</"
"manvolnum></citerefentry></ulink> command. The settings present under BSD "
"can be found in the <link linkend="
"\"configuration_page_mounting_mount_settings\">Mount Settings (BSD only)</"
"link> section."
msgstr ""
"द<guilabel> सामान्यं माउण्ट् सेटिंग्स्</guilabel> tab केवलं &amp;Linux; तथा "
"सूचीकृतविकल्पाः सन्दर्भयन्ति<ulink url=\"man:/mount.cifs"
"\"><citerefentry><refentrytitle> mount.cifs इति</refentrytitle><manvolnum> "
"८</manvolnum></citerefentry></ulink> / .<ulink url=\"man:/mount."
"smb3\"><citerefentry><refentrytitle> माउण्ट.smb3</refentrytitle><manvolnum> "
"८</manvolnum></citerefentry></ulink> आदेश। BSD इत्यस्य अन्तर्गतं वर्तमानाः सेटिङ्ग्स् "
"इत्यत्र द्रष्टुं शक्यन्ते<link linkend=\"configuration_page_mounting_mount_settings"
"\"> माउण्ट् सेटिंग्स् (केवलं BSD) .</link> खंड।"

#. Tag: title
#: index.docbook:2112 index.docbook:2686
#, no-c-format
msgid "Common Options"
msgstr "सामान्यविकल्पाः"

#. Tag: guibutton
#: index.docbook:2117
#, no-c-format
msgid "Write access"
msgstr "लेखन अभिगमः"

#. Tag: para
#: index.docbook:2120
#, no-c-format
msgid ""
"The write access to a share can be determined here. This option is "
"independent of the file mask and the folder mask settings above. Available "
"options are:"
msgstr ""
"भागस्य लेखनप्रवेशः अत्र निर्धारयितुं शक्यते । एषः विकल्पः सञ्चिकामास्कतः उपरिष्टात् समुच्चय "
"मास्कसेटिंग्स् च स्वतन्त्रः अस्ति । उपलब्धविकल्पाः सन्ति :"

#. Tag: guimenuitem
#: index.docbook:2124
#, no-c-format
msgid "read-write"
msgstr "पठित-लिख"

#. Tag: para
#: index.docbook:2127
#, no-c-format
msgid "Option: <option>rw</option>"
msgstr "विकल्प:<option value=rw> रव</option>"

#. Tag: para
#: index.docbook:2128
#, no-c-format
msgid "Mount the share read-write."
msgstr "शेयर पठन-लेखनं माउण्ट् कुर्वन्तु।"

#. Tag: guimenuitem
#: index.docbook:2133
#, no-c-format
msgid "read-only"
msgstr "पठनीय एव"

#. Tag: para
#: index.docbook:2136
#, no-c-format
msgid "Option: <option>ro</option>"
msgstr "विकल्प:<option value=ro> रो</option>"

#. Tag: para
#: index.docbook:2137
#, no-c-format
msgid "Mount the share read-only."
msgstr "केवलं पठनीयं भागं माउण्ट् कुर्वन्तु।"

#. Tag: para
#: index.docbook:2141
#, no-c-format
msgid "Default: not selected; <guimenuitem>read-write</guimenuitem>"
msgstr "पूर्वनिर्धारितम्: न चयनितम्; <guimenuitem>पठन-लेखन</guimenuitem>"

#. Tag: guibutton
#: index.docbook:2146 index.docbook:2741
#, no-c-format
msgid "Client character set"
msgstr "क्लायन्ट् वर्णसमूहः"

#. Tag: para
#: index.docbook:2149
#, no-c-format
msgid "Option: <option>iocharset=CHARSET</option>"
msgstr "विकल्प:<option value=iocharset=CHARSET> iocharset=चरसेट</option>"

#. Tag: para
#: index.docbook:2150
#, no-c-format
msgid ""
"Sets the character set used by the client side (&ie; your computer) to one "
"of the following:"
msgstr ""
"क्लायन्ट् पक्षेन (&अर्थात् भवतः सङ्गणकेन) उपयुज्यमानं वर्णसमूहं निम्नलिखितयोः एकस्मिन् सेट् "
"करोति ।"

#. Tag: guimenuitem
#: index.docbook:2154 index.docbook:2748 index.docbook:2943
#, no-c-format
msgid "default"
msgstr "मूलभूतम्‌"

#. Tag: para
#: index.docbook:2157
#, no-c-format
msgid ""
"Default character set used by the client's kernel. In this case the "
"<option>iocharset</option> option is omitted from the command line."
msgstr ""
"क्लायन्ट्-कर्नेल्-द्वारा उपयुज्यमानः पूर्वनिर्धारितः वर्णसमूहः । एवं सति द<option "
"value=iocharset> iocharset इति</option> आदेशपङ्क्तौ विकल्पः लोपितः अस्ति ।"

#. Tag: guimenuitem
#: index.docbook:2162 index.docbook:2756
#, no-c-format
msgid "iso8859-1"
msgstr "iso8859-1"

#. Tag: para
#: index.docbook:2165 index.docbook:2759
#, no-c-format
msgid ""
"ISO/IEC 8859-1:1998. This character-encoding scheme is used throughout the "
"Americas, Western Europe, Oceania, and much of Africa."
msgstr ""
"आईएसओ / आईईसी 8859-1:1998. एषा वर्ण-सङ्केत-योजना सम्पूर्णे अमेरिका-देशे, पश्चिम-यूरोपे, "
"ओशिनिया-देशे, आफ्रिका-देशे च अधिकांशेषु उपयुज्यते ।"

#. Tag: guimenuitem
#: index.docbook:2170 index.docbook:2764
#, no-c-format
msgid "iso8859-2"
msgstr "iso8859-2"

#. Tag: para
#: index.docbook:2173 index.docbook:2767
#, no-c-format
msgid ""
"ISO/IEC 8859-2:1999. It is informally referred to as \"Latin-2\". It is "
"generally intended for Central or \"Eastern European\" languages that are "
"written in the Latin script."
msgstr ""
"आईएसओ / आईईसी 8859-2:1999. अनौपचारिकरूपेण \"लैटिन-२\" इति उच्यते । सामान्यतया एतत् "
"मध्य-अथवा \"पूर्वीय-यूरोपीय\"-भाषायाः कृते अभिप्रेतम् यत् लैटिन-लिपिना लिखितम् अस्ति ।"

#. Tag: guimenuitem
#: index.docbook:2178 index.docbook:2772
#, no-c-format
msgid "iso8859-3"
msgstr "iso8859-3"

#. Tag: para
#: index.docbook:2181 index.docbook:2775
#, no-c-format
msgid ""
"ISO/IEC 8859-3:1999. It is informally referred to as Latin-3 or South "
"European. It was designed to cover Turkish, Maltese and Esperanto, though "
"the introduction of ISO/IEC 8859-9 superseded it for Turkish."
msgstr ""
"आईएसओ / आईईसी 8859-3:1999. अनौपचारिकरूपेण लैटिन-३ अथवा दक्षिण-यूरोपीय इति उच्यते । "
"तुर्की, माल्टीज, एस्पेरान्टो च भाषाः आच्छादयितुं अस्य डिजाइनं कृतम् आसीत्, यद्यपि ISO/IEC "
"8859-9 इत्यस्य प्रवर्तनेन तुर्कीभाषायाः कृते तस्य स्थानान्तरितम् ।"

#. Tag: guimenuitem
#: index.docbook:2186 index.docbook:2780
#, no-c-format
msgid "iso8859-4"
msgstr "iso8859-4"

#. Tag: para
#: index.docbook:2189 index.docbook:2783
#, no-c-format
msgid ""
"ISO/IEC 8859-4:1998. It is informally referred to as Latin-4 or North "
"European. It was designed to cover Estonian, Latvian, Lithuanian, "
"Greenlandic, and Sami. It has been largely superseded by ISO/IEC 8859-10 and "
"Unicode."
msgstr ""
"आईएसओ / आईईसी 8859-4:1998. अनौपचारिकरूपेण लैटिन-४ अथवा उत्तर-यूरोपीय इति उच्यते । "
"एस्टोनिया-लाट्विया-लिथुएनिया-ग्रीनलैण्डिक-सामी-भाषा च आच्छादयितुं अस्य रचना कृता आसीत् । "
"अस्य स्थानान्तरणं बहुधा ISO/IEC 8859-10 तथा Unicode इत्यनेन कृतम् अस्ति ।"

#. Tag: guimenuitem
#: index.docbook:2194 index.docbook:2788
#, no-c-format
msgid "iso8859-5"
msgstr "iso8859-5"

#. Tag: para
#: index.docbook:2197 index.docbook:2791
#, no-c-format
msgid ""
"ISO/IEC 8859-5:1999. It is informally referred to as Latin/Cyrillic. It was "
"designed to cover languages using a Cyrillic alphabet such as Bulgarian, "
"Belarusian, Russian, Serbian and Macedonian but was never widely used."
msgstr ""
"आईएसओ / आईईसी 8859-5:1999. अनौपचारिकरूपेण लैटिन/सिरिलिक इति उच्यते । बल्गेरिया, "
"बेलारूसी, रूसी, सर्बिया, मैसिडोनिया इत्यादीनां सिरिलिकवर्णमालायाः उपयोगेन भाषाः "
"आच्छादयितुं अस्य रचना कृता आसीत् किन्तु कदापि तस्य व्यापकरूपेण उपयोगः न कृतः ।"

#. Tag: guimenuitem
#: index.docbook:2202 index.docbook:2796
#, no-c-format
msgid "iso8859-6"
msgstr "iso8859-6"

#. Tag: para
#: index.docbook:2205 index.docbook:2799
#, no-c-format
msgid ""
"ISO/IEC 8859-6:1999. It is informally referred to as Latin/Arabic. It was "
"designed to cover Arabic."
msgstr ""
"आईएसओ / आईईसी 8859-6:1999. अनौपचारिकरूपेण लैटिन/अरबी इति उच्यते । अरबीभाषां "
"आच्छादयितुं तस्य रचना आसीत् ।"

#. Tag: guimenuitem
#: index.docbook:2210 index.docbook:2804
#, no-c-format
msgid "iso8859-7"
msgstr "iso8859-7"

#. Tag: para
#: index.docbook:2213 index.docbook:2807
#, no-c-format
msgid ""
"ISO/IEC 8859-7:2003. It is informally referred to as Latin/Greek. It was "
"designed to cover the modern Greek language."
msgstr ""
"आईएसओ / आईईसी 8859-7:2003. अनौपचारिकरूपेण लैटिन/ग्रीक इति उच्यते । "
"आधुनिकग्रीकभाषायाः आच्छादनाय अस्य निर्माणं कृतम् आसीत् ।"

#. Tag: guimenuitem
#: index.docbook:2218 index.docbook:2812
#, no-c-format
msgid "iso8859-8"
msgstr "iso8859-8"

#. Tag: para
#: index.docbook:2221 index.docbook:2815
#, no-c-format
msgid ""
"ISO/IEC 8859-8:1999. It is informally referred to as Latin/Hebrew. ISO/IEC "
"8859-8 covers all the Hebrew letters, but no Hebrew vowel signs."
msgstr ""
"आईएसओ / आईईसी 8859-8:1999. अनौपचारिकरूपेण लैटिन/हिब्रू इति उच्यते । ISO/IEC 8859-8 "
"इत्यत्र सर्वाणि हिब्रू-अक्षराणि आच्छादितानि, परन्तु हिब्रू-स्वरचिह्नानि न सन्ति ।"

#. Tag: guimenuitem
#: index.docbook:2226 index.docbook:2820
#, no-c-format
msgid "iso8859-9"
msgstr "iso8859-9"

#. Tag: para
#: index.docbook:2229 index.docbook:2823
#, no-c-format
msgid ""
"ISO/IEC 8859-9:1999. It is informally referred to as Latin-5 or Turkish. It "
"was designed to cover the Turkish language, designed as being of more use "
"than the ISO/IEC 8859-3 encoding."
msgstr ""
"आईएसओ / आईईसी 8859-9:1999. अनौपचारिकरूपेण लैटिन-५ अथवा तुर्की इति उच्यते । इदं "
"तुर्कीभाषां आच्छादयितुं निर्मितम् आसीत्, यत् ISO/IEC 8859-3 एन्कोडिंग् इत्यस्मात् अधिकं "
"उपयोगी इति परिकल्पितम् आसीत् ।"

#. Tag: guimenuitem
#: index.docbook:2234 index.docbook:2828
#, no-c-format
msgid "iso8859-13"
msgstr "iso8859-13 इति"

#. Tag: para
#: index.docbook:2237 index.docbook:2831
#, no-c-format
msgid ""
"ISO/IEC 8859-13:1998. It is informally referred to as Latin-7 or Baltic Rim. "
"It was designed to cover the Baltic languages, and added characters used in "
"the Polish language missing from the earlier encodings ISO 8859-4 and ISO "
"8859-10. Unlike these two, it does not cover the Nordic languages."
msgstr ""
"आईएसओ / आईईसी 8859-13:1998. अनौपचारिकरूपेण लैटिन-७ अथवा बाल्टिक रिम् इति उच्यते । "
"एतत् बाल्टिकभाषाणां आच्छादनाय निर्मितम् आसीत्, तथा च पूर्ववर्तीषु ISO 8859-4 तथा ISO "
"8859-10 इत्येतयोः एन्कोडिंग्-मध्ये अनुपलब्धाः पोलिश-भाषायां प्रयुक्ताः वर्णाः योजिताः "
"एतयोः विपरीतम् अस्मिन् नॉर्डिक् भाषाः न आच्छादिताः ।"

#. Tag: guimenuitem
#: index.docbook:2242 index.docbook:2836
#, no-c-format
msgid "iso8859-14"
msgstr "iso8859-14 इति"

#. Tag: para
#: index.docbook:2245 index.docbook:2839
#, no-c-format
msgid ""
"ISO/IEC 8859-14:1998. It is informally referred to as Latin-8 or Celtic. It "
"was designed to cover the Celtic languages, such as Irish, Manx, Scottish "
"Gaelic, Welsh, Cornish, and Breton."
msgstr ""
"आईएसओ / आईईसी 8859-14:1998. अनौपचारिकरूपेण लैटिन-८ अथवा सेल्टिक इति उच्यते । आयरिश, "
"म्यान्क्स, स्कॉटिश गेलिक्, वेल्स्, कोर्निश्, ब्रेटोन् इत्यादीनां सेल्टिकभाषाणां आच्छादनाय अस्य "
"निर्माणं कृतम् आसीत् ।"

#. Tag: guimenuitem
#: index.docbook:2250 index.docbook:2844
#, no-c-format
msgid "iso8859-15"
msgstr "iso8859-15 इति"

#. Tag: para
#: index.docbook:2253 index.docbook:2847
#, no-c-format
msgid ""
"ISO/IEC 8859-15:1999. It is informally referred to as Latin-9 (and for a "
"while Latin-0). It is similar to ISO 8859-1, and thus also intended for "
"“Western European” languages, but replaces some less common symbols with the "
"euro sign and some letters that were deemed necessary."
msgstr ""
"आईएसओ / आईईसी 8859-15:1999. अनौपचारिकरूपेण लैटिन-९ (किञ्चित्कालं यावत् च लैटिन-०) "
"इति उच्यते । इदं ISO 8859-1 इत्यस्य सदृशम् अस्ति, एवं च “पश्चिमीय-यूरोपीय” भाषाणां कृते "
"अपि अभिप्रेतम्, परन्तु केषाञ्चन अल्पसामान्यचिह्नानां स्थाने यूरो-चिह्नं, केचन अक्षराणि च "
"प्रतिस्थापयति ये आवश्यकाः इति मन्यन्ते स्म"

#. Tag: guimenuitem
#: index.docbook:2258 index.docbook:2852
#, no-c-format
msgid "utf8"
msgstr "utf8"

#. Tag: para
#: index.docbook:2261 index.docbook:2855
#, no-c-format
msgid ""
"Unicode (or Universal Coded Character Set) Transformation Format – 8-bit. "
"UTF-8 is used by many &Linux; distributions as default character set, and "
"is, in addition, by far the most common encoding for the World Wide Web."
msgstr ""
"यूनिकोड (अथवा सार्वभौमिककोडेड् वर्णसमूहः) परिवर्तनस्वरूपम् – ८-बिट् । UTF-8 इत्यस्य "
"उपयोगः बहुभिः &Linux; वितरणं पूर्वनिर्धारितवर्णसमूहरूपेण, अपि च, तदतिरिक्तं, "
"विश्वव्यापीजालस्य कृते दूरतः सर्वाधिकं सामान्यं एन्कोडिंग् अस्ति ।"

#. Tag: guimenuitem
#: index.docbook:2266 index.docbook:2860
#, no-c-format
msgid "koi8-r"
msgstr "कोइ८-र"

#. Tag: para
#: index.docbook:2269 index.docbook:2863
#, no-c-format
msgid ""
"KOI8-R (RFC 1489) is an 8-bit character encoding, derived from the KOI-8 "
"encoding by the programmer Andrei Chernov in 1993 and designed to cover "
"Russian, which uses a Cyrillic alphabet."
msgstr ""
"KOI8-R (RFC 1489) इति ८-बिट् वर्णसङ्केतनम् अस्ति, यत् १९९३ तमे वर्षे प्रोग्रामर आन्द्रेई "
"चेर्नोव् इत्यनेन KOI-8 एन्कोडिंग् इत्यस्मात् प्राप्तम् अस्ति तथा च रूसीभाषां आच्छादयितुं डिजाइनं "
"कृतम् अस्ति, यस्मिन् सिरिलिकवर्णमालायाः उपयोगः भवति"

#. Tag: guimenuitem
#: index.docbook:2274 index.docbook:2868
#, no-c-format
msgid "koi8-u"
msgstr "कोइ८-उ"

#. Tag: para
#: index.docbook:2277 index.docbook:2871
#, no-c-format
msgid ""
"KOI8-U (RFC 2319) is an 8-bit character encoding, designed to cover "
"Ukrainian, which uses a Cyrillic alphabet."
msgstr ""
"KOI8-U (RFC 2319) इति ८-बिट् वर्णसङ्केतनम् अस्ति, यत् युक्रेनभाषां आच्छादयितुं विनिर्मितम् "
"अस्ति, यत् सिरिलिकवर्णमालायाः उपयोगं करोति ।"

#. Tag: guimenuitem
#: index.docbook:2282 index.docbook:2876
#, no-c-format
msgid "koi8-ru"
msgstr "कोइ८-रु"

#. Tag: para
#: index.docbook:2285 index.docbook:2879
#, no-c-format
msgid ""
"KOI8-RU is an 8-bit character encoding, designed to cover Russian, "
"Ukrainian, and Belarusian which use a Cyrillic alphabet."
msgstr ""
"KOI8-RU इति ८-बिट् वर्णसङ्केतनं भवति, यत् रूसी, युक्रेनियन, बेलारूसीभाषा च आच्छादयितुं "
"विनिर्मितम् अस्ति येषु सिरिलिकवर्णमालायाः उपयोगः भवति ।"

#. Tag: guimenuitem
#: index.docbook:2290 index.docbook:2884 index.docbook:3135
#, no-c-format
msgid "cp1251"
msgstr "cp1251"

#. Tag: para
#: index.docbook:2293 index.docbook:2887
#, no-c-format
msgid ""
"Windows-1251 is an 8-bit character encoding, designed to cover languages "
"that use the Cyrillic script such as Russian, Bulgarian, Serbian Cyrillic "
"and other languages. In Linux, the encoding is known as cp1251."
msgstr ""
"विण्डोज-१२५१ इति ८-बिट् वर्णसङ्केतनं भवति, यत् रूसी, बल्गेरिया, सर्बिया सिरिलिक "
"इत्यादीनां भाषाणां सिरिलिक् लिपिप्रयोगं कुर्वन्ति भाषाः आच्छादयितुं विनिर्मितम् अस्ति Linux "
"मध्ये एन्कोडिंग् cp1251 इति नाम्ना प्रसिद्धम् अस्ति ।"

#. Tag: guimenuitem
#: index.docbook:2298 index.docbook:2892
#, no-c-format
msgid "gb2312"
msgstr "gb2312"

#. Tag: para
#: index.docbook:2301 index.docbook:2895
#, no-c-format
msgid ""
"GB/T 2312-1980 is a key official character set of the People's Republic of "
"China, used for Simplified Chinese characters. GB2312 is the registered "
"internet name for EUC-CN, which is its usual encoded form. GB/T 2312-1980 "
"has been superseded by GBK and GB18030, which include additional characters, "
"but GB/T 2312 remains in widespread use as a subset of those encodings."
msgstr ""
"जीबी/टी २३१२-१९८० चीनगणराज्यस्य प्रमुखः आधिकारिकः वर्णसमूहः अस्ति, यस्य उपयोगः "
"सरलीकृतचीनीवर्णानां कृते भवति । GB2312 इति EUC-CN इत्यस्य पञ्जीकृतं अन्तर्जालनाम अस्ति, "
"यत् तस्य सामान्यं एन्कोडेड् रूपम् अस्ति । GB/T 2312-1980 इत्यस्य स्थानं GBK तथा GB18030 "
"इत्यनेन गृहीतम्, येषु अतिरिक्तवर्णाः सन्ति, परन्तु GB/T 2312 तेषां एन्कोडिंग्-समूहस्य उपसमूहरूपेण "
"व्यापकरूपेण उपयुज्यते"

#. Tag: guimenuitem
#: index.docbook:2306 index.docbook:2900
#, no-c-format
msgid "big5"
msgstr "बृहत्५"

#. Tag: para
#: index.docbook:2309 index.docbook:2903
#, no-c-format
msgid ""
"Big-5 or Big5 is a Chinese character encoding method used in Taiwan, Hong "
"Kong, and Macau for traditional Chinese characters. The People's Republic of "
"China (PRC), which uses simplified Chinese characters, uses the GB 18030 "
"character set instead."
msgstr ""
"Big-5 अथवा Big5 इति चीनीयवर्णसङ्केतीकरणपद्धतिः ताइवान, हाङ्गकाङ्ग, मकाऊदेशेषु "
"पारम्परिकचीनीवर्णानां कृते प्रयुक्ता अस्ति । सरलीकृतचीनीवर्णानां उपयोगं कुर्वन् चीनगणराज्यं "
"(PRC) तस्य स्थाने GB 18030 वर्णसमूहस्य उपयोगं करोति ।"

#. Tag: guimenuitem
#: index.docbook:2314 index.docbook:2908
#, no-c-format
msgid "euc-jp"
msgstr "euc-jp"

#. Tag: para
#: index.docbook:2317 index.docbook:2911
#, no-c-format
msgid ""
"EUC-JP is a variable-width encoding used to represent the elements of three "
"Japanese character set standards, namely JIS X 0208, JIS X 0212, and JIS X "
"0201."
msgstr ""
"EUC-JP इति चर-विस्तार-एन्कोडिंग् अस्ति यस्य उपयोगः त्रयाणां जापानी-वर्णसमूह-मानकानां "
"तत्त्वानां प्रतिनिधित्वार्थं भवति, यथा JIS X 0208, JIS X 0212, JIS X 0201 च"

#. Tag: guimenuitem
#: index.docbook:2322 index.docbook:2916
#, no-c-format
msgid "euc-kr"
msgstr "euc-kr"

#. Tag: para
#: index.docbook:2325 index.docbook:2919
#, no-c-format
msgid ""
"EUC-KR is a variable-width encoding to represent Korean text using two coded "
"character sets, KS X 1001 (formerly KS C 5601) and either ISO 646:KR (KS X "
"1003, formerly KS C 5636) or US-ASCII, depending on variant. KS X 2901 "
"(formerly KS C 5861) stipulates the encoding and RFC 1557 dubbed it as EUC-"
"KR."
msgstr ""
"EUC-KR कोरियाईपाठस्य प्रतिनिधित्वार्थं चर-चौड़ाई-एन्कोडिंग् अस्ति, यत् द्वयोः "
"कोडितवर्णसमूहयोः उपयोगेन, KS X 1001 (पूर्वं KS C 5601) तथा च ISO 646:KR (KS X "
"1003, पूर्वं KS C 5636) अथवा US-ASCII, निर्भरं भवति on variant. केएस एक्स २९०१ (पूर्वं "
"केएस सी ५८६१) इत्यनेन एन्कोडिंग् निर्धारितं भवति तथा च आरएफसी १५५७ इत्यनेन तस्य नामकरणं "
"EUC-KR इति कृतम् ।"

#. Tag: guimenuitem
#: index.docbook:2330 index.docbook:2924
#, no-c-format
msgid "tis-620"
msgstr "तिस्-६२०"

#. Tag: para
#: index.docbook:2333 index.docbook:2927
#, no-c-format
msgid ""
"Thai Industrial Standard 620-2533, commonly referred to as TIS-620, is the "
"most common character set and character encoding for the Thai language."
msgstr ""
"थाई औद्योगिकमानकः ६२०-२५३३, यः सामान्यतया TIS-६२० इति उच्यते, थाईभाषायाः कृते "
"सर्वाधिकं सामान्यं वर्णसमूहं वर्णसङ्केतनं च अस्ति ।"

#. Tag: para
#: index.docbook:2337
#, no-c-format
msgid "Default: not selected; CHARSET: <guimenuitem>default</guimenuitem>"
msgstr ""
"पूर्वनिर्धारितम्: न चयनितम्; CHARSET: <guimenuitem>पूर्वनिर्धारितं</guimenuitem>"

#. Tag: title
#: index.docbook:2344
#, no-c-format
msgid "&CIFS; Unix Extensions Support"
msgstr "&CIFS; Unix Extensions समर्थनम्"

#. Tag: guibutton
#: index.docbook:2348
#, no-c-format
msgid "All or most of the servers support the &CIFS; Unix extensions"
msgstr "सर्वे वा अधिकांशः सर्वरः &CIFS; यूनिक्स विस्तार"

#. Tag: para
#: index.docbook:2351
#, no-c-format
msgid "Option: none"
msgstr "विकल्पः - कोऽपि नास्ति"

#. Tag: para
#: index.docbook:2352
#, no-c-format
msgid ""
"Most versions of &Samba; support the &CIFS; Unix or POSIX extensions. For "
"these servers, some options are not needed, because the right values are "
"negotiated during the mount process. For other servers, you might want to "
"uncheck this option, so that predefined values can be passed to the server. "
"Please note that if your computer is located in a &Windows; dominated "
"network neighborhood with only a few &Samba; servers, you can safely uncheck "
"this option and define custom settings for the &Samba; servers."
msgstr ""
"&Samba इत्यस्य अधिकांशसंस्करणम्; समर्थनं करोति &CIFS; Unix अथवा POSIX विस्तारः । एतेषां "
"सर्वराणां कृते केषाञ्चन विकल्पानां आवश्यकता नास्ति, यतः माउण्ट् प्रक्रियायाः समये "
"समीचीनमूल्यानि वार्तालापिताः भवन्ति । अन्येषां सर्वराणां कृते भवान् एतत् विकल्पं अनचेक् कर्तुम् "
"इच्छति, येन पूर्वनिर्धारितमूल्यानि सर्वरं प्रति प्रसारयितुं शक्यन्ते । कृपया ज्ञातव्यं यत् यदि "
"भवतः सङ्गणकं &Windows; केवलं कतिपयैः सह जालपरिसरस्य आधिपत्यं कृतवान् &Samba; सर्वर्स्, "
"भवान् सुरक्षिततया एतत् विकल्पं अनचेक् कृत्वा &Samba; सर्वरः ।"

#. Tag: para
#: index.docbook:2353
#, no-c-format
msgid ""
"In case you uncheck this option, consider to switch on permission checks "
"under <link linkend=\"configuration_page_mounting_advanced_mount_settings"
"\">Advanced Mount Settings</link>."
msgstr ""
"यदि भवान् एतत् विकल्पं अनचेक् करोति तर्हि अन्तर्गतं अनुमतिपरीक्षां चालू कर्तुं विचारयतु<link "
"linkend=\"configuration_page_mounting_advanced_mount_settings\"> उन्नत माउण्ट् "
"सेटिंग्स्</link> ."

#. Tag: guibutton
#: index.docbook:2359 index.docbook:2691
#, no-c-format
msgid "Set the user and group ID"
msgstr ""

#. Tag: para
#: index.docbook:2362
#, fuzzy, no-c-format
#| msgid "Option: <option>setuids</option> or <option>nosetuids</option>"
msgid "Options: <option>uid=UID</option> and <option>gid=GID</option>"
msgstr ""
"विकल्प:<option value=setuids> सेतुइड्स</option> वा<option value=nosetuids> "
"नासिकासूदः</option>"

#. Tag: para
#: index.docbook:2363 index.docbook:2695
#, no-c-format
msgid ""
"&smb4k; uses your user and group ID for mounting if this setting is enabled. "
"They are displayed here for information purposes only and cannot be changed."
msgstr ""

#. Tag: para
#: index.docbook:2364 index.docbook:2375 index.docbook:2386 index.docbook:2696
#, no-c-format
msgid ""
"In case the support for the &CIFS; Unix extensions is selected, this setting "
"is disabled."
msgstr "यस्मिन् सन्दर्भे &CIFS; Unix extensions चयनितम् अस्ति, एतत् सेटिङ्ग् अक्षमम् अस्ति ।"

#. Tag: para
#: index.docbook:2365 index.docbook:2697
#, fuzzy, no-c-format
#| msgid "Default: selected; UID: your UID"
msgid "Default: selected; UID: your UID, GID: your GID"
msgstr "पूर्वनिर्धारितम्: चयनितम्; UID: भवतः UID"

#. Tag: guibutton
#: index.docbook:2370 index.docbook:2705
#, no-c-format
msgid "File mode"
msgstr "सञ्चिकाविधिः"

#. Tag: para
#: index.docbook:2373
#, fuzzy, no-c-format
#| msgid "Option: <option>file_mode=ARG</option>"
msgid "Option: <option>file_mode=MODE</option>"
msgstr "विकल्प:<option value=file_mode=ARG> file_mode=ARG इति</option>"

#. Tag: para
#: index.docbook:2374
#, fuzzy, no-c-format
#| msgid ""
#| "Sets the permissions that are applied to files. The value is given in "
#| "octal and has to have 4 digits. To learn more about the file mode "
#| "(file_mode), you should read the <ulink url=\"man:/"
#| "mount(8)\"><citerefentry><refentrytitle>mount</"
#| "refentrytitle><manvolnum>8</manvolnum></citerefentry></ulink> and <ulink "
#| "url=\"man:/umask(2)\"><citerefentry><refentrytitle>umask</"
#| "refentrytitle><manvolnum>2</manvolnum></citerefentry></ulink> manual "
#| "pages."
msgid ""
"Sets the permissions that are applied to files. The value is given in octal "
"and may have 3 or 4 digits. The SUID, SGID and sticky bit are not allowed. "
"To learn more about the file mode (file_mode), you should read the <ulink "
"url=\"man:/mount(8)\"><citerefentry><refentrytitle>mount</"
"refentrytitle><manvolnum>8</manvolnum></citerefentry></ulink> and <ulink url="
"\"man:/umask(2)\"><citerefentry><refentrytitle>umask</"
"refentrytitle><manvolnum>2</manvolnum></citerefentry></ulink> manual pages."
msgstr ""
"सञ्चिकासु प्रयुक्ताः अनुमतिः सेट् करोति । मूल्यं अष्टकरूपेण दत्तं भवति, तस्य ४ अङ्काः "
"भवितुमर्हन्ति । सञ्चिकाविधानस्य (file_mode) विषये अधिकं ज्ञातुं भवान् <ulink url=\"man:/"
"mount(8)\"><citerefentry><refentrytitle>mount</refentrytitle><manvolnum>8</"
"manvolnum></ इति पठितव्यम् । citerefentry></ulink> तथा <ulink url=\"man:/"
"umask(2)\"><citerefentry><refentrytitle>umask</refentrytitle><manvolnum>2</"
"manvolnum></citerefentry></ulink> मैनुअल पृष्ठ।"

#. Tag: para
#: index.docbook:2376 index.docbook:2387
#, no-c-format
msgid "Default: selected; ARG: 0755"
msgstr "पूर्वनिर्धारितम्: चयनितम्; एआरजी : 0755"

#. Tag: guibutton
#: index.docbook:2381 index.docbook:2715
#, no-c-format
msgid "Directory mode"
msgstr "निर्देशिकाविधिः"

#. Tag: para
#: index.docbook:2384
#, fuzzy, no-c-format
#| msgid "Option: <option>dir_mode=ARG</option>"
msgid "Option: <option>dir_mode=MODE</option>"
msgstr "विकल्प:<option value=dir_mode=ARG> dir_mode=आरजी</option>"

#. Tag: para
#: index.docbook:2385
#, fuzzy, no-c-format
#| msgid ""
#| "Sets the permissions that are applied to directories. The value is given "
#| "in octal and has to have 4 digits. To learn more about the directory mode "
#| "(dir_mode), you should read the <ulink url=\"man:/"
#| "mount(8)\"><citerefentry><refentrytitle>mount</"
#| "refentrytitle><manvolnum>8</manvolnum></citerefentry></ulink> and <ulink "
#| "url=\"man:/umask(2)\"><citerefentry><refentrytitle>umask</"
#| "refentrytitle><manvolnum>2</manvolnum></citerefentry></ulink> manual "
#| "pages."
msgid ""
"Sets the permissions that are applied to directories. The value is given in "
"octal and may have 3 or 4 digits. The SUID, SGID and sticky bit are not "
"allowed. To learn more about the directory mode (dir_mode), you should read "
"the <ulink url=\"man:/mount(8)\"><citerefentry><refentrytitle>mount</"
"refentrytitle><manvolnum>8</manvolnum></citerefentry></ulink> and <ulink url="
"\"man:/umask(2)\"><citerefentry><refentrytitle>umask</"
"refentrytitle><manvolnum>2</manvolnum></citerefentry></ulink> manual pages."
msgstr ""
"निर्देशिकासु प्रयुक्ताः अनुमतिः सेट् करोति । मूल्यं अष्टकरूपेण दत्तं भवति, तस्य ४ अङ्काः "
"भवितुमर्हन्ति । निर्देशिकाविधानस्य (dir_mode) विषये अधिकं ज्ञातुं भवान् <ulink url="
"\"man:/mount(8)\"><citerefentry><refentrytitle>mount</"
"refentrytitle><manvolnum>8</manvolnum></ इति पठितव्यम् । citerefentry></ulink> "
"तथा <ulink url=\"man:/umask(2)\"><citerefentry><refentrytitle>umask</"
"refentrytitle><manvolnum>2</manvolnum></citerefentry></ulink> मैनुअल पृष्ठ।"

#. Tag: title
#: index.docbook:2399
#, no-c-format
msgid "Advanced Mount Settings (&Linux; only)"
msgstr "उन्नत माउण्ट् सेटिंग्स् (&Linux; केवलं)"

#. Tag: para
#: index.docbook:2401
#, no-c-format
msgid ""
"The <guilabel>Advanced Mount Settings</guilabel> tab is only available under "
"&Linux; and the listed options refer to the <ulink url=\"man:/mount.cifs"
"\"><citerefentry><refentrytitle>mount.cifs</refentrytitle><manvolnum>8</"
"manvolnum></citerefentry></ulink> / <ulink url=\"man:/mount."
"smb3\"><citerefentry><refentrytitle>mount.smb3</refentrytitle><manvolnum>8</"
"manvolnum></citerefentry></ulink> command. The settings present under BSD "
"can be found in the <link linkend="
"\"configuration_page_mounting_mount_settings\">Mount Settings (BSD only)</"
"link> section."
msgstr ""
"द<guilabel> उन्नत माउण्ट् सेटिंग्स्</guilabel> tab केवलं &amp;Linux; तथा सूचीकृतविकल्पाः "
"सन्दर्भयन्ति<ulink url=\"man:/mount.cifs\"><citerefentry><refentrytitle> mount."
"cifs इति</refentrytitle><manvolnum> ८</manvolnum></citerefentry></ulink> / ."
"<ulink url=\"man:/mount.smb3\"><citerefentry><refentrytitle> माउण्ट.smb3</"
"refentrytitle><manvolnum> ८</manvolnum></citerefentry></ulink> आदेश। BSD "
"इत्यस्य अन्तर्गतं वर्तमानाः सेटिङ्ग्स् इत्यत्र द्रष्टुं शक्यन्ते<link linkend="
"\"configuration_page_mounting_mount_settings\"> माउण्ट् सेटिंग्स् (केवलं BSD) .</"
"link> खंड।"

#. Tag: guibutton
#: index.docbook:2405
#, no-c-format
msgid "Definitely assign the UID"
msgstr "निश्चितरूपेण UID नियुक्तं कुर्वन्तु"

#. Tag: para
#: index.docbook:2408
#, no-c-format
msgid "Option: <option>forceuid</option>"
msgstr "विकल्प:<option value=forceuid> फोर्सूइड्</option>"

#. Tag: para
#: index.docbook:2409
#, no-c-format
msgid ""
"Instruct the client (i.e. your side) to ignore any user ID (UID) provided by "
"the server for files and directories and to always assign the owner to be "
"the value of the transmitted UID."
msgstr ""
"क्लायन्ट् (अर्थात् भवतः पक्षः) सञ्चिकानां निर्देशिकानां च कृते सर्वरेण प्रदत्तं किमपि उपयोक्तृ-"
"ID (UID) अवहेलितुं तथा च स्वामिनं सर्वदा प्रसारितस्य UID इत्यस्य मूल्यं नियुक्तुं निर्देशयन्तु"

#. Tag: guibutton
#: index.docbook:2415
#, no-c-format
msgid "Definitely assign the GID"
msgstr "निश्चितरूपेण GID नियुक्तं कुर्वन्तु"

#. Tag: para
#: index.docbook:2418
#, no-c-format
msgid "Option: <option>forcegid</option>"
msgstr "विकल्प:<option value=forcegid> बलात्गिड्</option>"

#. Tag: para
#: index.docbook:2419
#, no-c-format
msgid ""
"Instruct the client (i.e. your side) to ignore any group ID (GID) provided "
"by the server for files and directories and to always assign the owner to be "
"the value of the transmitted GID."
msgstr ""
"क्लायन्ट् (अर्थात् भवतः पक्षः) सञ्चिकानां निर्देशिकानां च कृते सर्वरेण प्रदत्तं किमपि समूह-ID "
"(GID) अवहेलितुं तथा च स्वामिनं सर्वदा प्रसारितस्य GID इत्यस्य मूल्यं नियुक्तुं निर्देशयन्तु"

#. Tag: guibutton
#: index.docbook:2425
#, no-c-format
msgid "Do permission checks"
msgstr "अनुमतिपरीक्षां कुर्वन्तु"

#. Tag: para
#: index.docbook:2428
#, no-c-format
msgid "Option: <option>perm</option> or <option>noperm</option>"
msgstr ""
"विकल्प:<option value=perm> perm</option> वा<option value=noperm> नोपरम्</"
"option>"

#. Tag: para
#: index.docbook:2429
#, no-c-format
msgid ""
"The client side checks if you have the correct UID and GID to manipulate "
"files and directories on the share. This is in addition to the normal ACL "
"check on the target machine done by the server software. You most definitely "
"want to switch this feature off, if the server(s) support the &CIFS; Unix "
"extensions and you are, hence, not allowed to fully access the share."
msgstr ""
"क्लायन्ट् पक्षः परीक्षते यत् भवतः समीपे सञ्चिकासु निर्देशिकासु च परिवर्तनार्थं समीचीनः UID "
"तथा GID अस्ति वा । एतत् सर्वर-सॉफ्टवेयर-द्वारा लक्ष्ययन्त्रे सामान्य-ACL-परीक्षायाः "
"अतिरिक्तं भवति । भवान् निश्चयेन एतत् विशेषतां निष्क्रियं कर्तुम् इच्छति, यदि सर्वर(s) &CIFS; "
"Unix विस्ताराः तथा च भवन्तः, अतः, भागं पूर्णतया प्राप्तुं न अनुमताः सन्ति ।"

#. Tag: guibutton
#: index.docbook:2435
#, no-c-format
msgid "Attempt to set UID and GID"
msgstr "UID तथा GID सेट् कर्तुं प्रयतध्वम्"

#. Tag: para
#: index.docbook:2438
#, no-c-format
msgid "Option: <option>setuids</option> or <option>nosetuids</option>"
msgstr ""
"विकल्प:<option value=setuids> सेतुइड्स</option> वा<option value=nosetuids> "
"नासिकासूदः</option>"

#. Tag: para
#: index.docbook:2439
#, no-c-format
msgid ""
"If the &CIFS; Unix extensions are negotiated with the server the client side "
"will attempt to set the effective UID and GID of the local process on newly "
"created files, directories, and devices. If this feature is turned off, the "
"default UID and GID defined for the share will be used. It is recommended "
"that you read the manual page of <ulink url=\"man:/mount.cifs"
"\"><citerefentry><refentrytitle>mount.cifs</refentrytitle><manvolnum>8</"
"manvolnum></citerefentry></ulink> before you change this setting."
msgstr ""
"यदि &CIFS; Unix विस्ताराः सर्वरेण सह वार्तालापं कुर्वन्ति यत् क्लायन्ट् पक्षः "
"नवनिर्मितसञ्चिकासु, निर्देशिकासु, उपकरणेषु च स्थानीयप्रक्रियायाः प्रभावी UID तथा GID सेट् "
"कर्तुं प्रयतते यदि एतत् विशेषता निष्क्रियं भवति तर्हि भागस्य कृते परिभाषितं पूर्वनिर्धारितं UID "
"GID च उपयुज्यते । अनुशंसितं यत् भवान् <ulink url=\"man:/mount.cifs"
"\"><citerefentry><refentrytitle>mount.cifs</refentrytitle><manvolnum>8</"
"manvolnum></citerefentry></ इत्यस्य पुस्तिकापृष्ठं पठतु । ulink> इति सेटिङ्ग् परिवर्तयितुं "
"पूर्वं ।"

#. Tag: guibutton
#: index.docbook:2445
#, no-c-format
msgid "Use server inode numbers"
msgstr "सर्वर inode सङ्ख्यानां उपयोगं कुर्वन्तु"

#. Tag: para
#: index.docbook:2448
#, no-c-format
msgid "Option: <option>serverino</option> or <option>noserverino</option>"
msgstr ""
"विकल्प:<option value=serverino> serverino</option> वा<option "
"value=noserverino> नोसेर्विनो</option>"

#. Tag: para
#: index.docbook:2449
#, no-c-format
msgid ""
"Use inode numbers (unique persistent file identifiers) returned by the "
"server instead of automatically generating temporary inode numbers on the "
"client side. This parameter has no effect if the server does not support "
"returning inode numbers or similar. It is recommended that you read the "
"manual page of <ulink url=\"man:/mount.cifs"
"\"><citerefentry><refentrytitle>mount.cifs</refentrytitle><manvolnum>8</"
"manvolnum></citerefentry></ulink> before you change this setting."
msgstr ""
"क्लायन्ट् पक्षे स्वयमेव अस्थायी inode सङ्ख्याः जनयितुं स्थाने सर्वरेण प्रत्यागतानां inode "
"सङ्ख्यानां (अद्वितीयस्थायिसञ्चिकापरिचयकानां) उपयोगं कुर्वन्तु । यदि सर्वरः inode सङ्ख्याः "
"अथवा तत्सदृशानि प्रत्यागन्तुं समर्थयति तर्हि एतस्य पैरामीटर् इत्यस्य कोऽपि प्रभावः नास्ति । "
"अनुशंसितं यत् भवान् <ulink url=\"man:/mount.cifs"
"\"><citerefentry><refentrytitle>mount.cifs</refentrytitle><manvolnum>8</"
"manvolnum></citerefentry></ इत्यस्य पुस्तिकापृष्ठं पठतु । ulink> इति सेटिङ्ग् परिवर्तयितुं "
"पूर्वं ।"

#. Tag: guibutton
#: index.docbook:2455
#, no-c-format
msgid "Translate reserved characters"
msgstr "आरक्षितवर्णानां अनुवादं कुर्वन्तु"

#. Tag: para
#: index.docbook:2458
#, no-c-format
msgid "Option: <option>mapchars</option> or <option>nomapchars</option>"
msgstr ""
"विकल्प:<option value=mapchars> मपचराः</option> वा<option value=nomapchars> "
"नोमापचार्स्</option>"

#. Tag: para
#: index.docbook:2459
#, no-c-format
msgid ""
"Translate six of the seven reserved characters (not backslash, but including "
"the colon, question mark, pipe, asterisk, greater than, and less than "
"characters) to the remap range (above 0xF000), which also allows the client "
"side to recognize files created with such characters by &Windows;’s POSIX "
"emulation. This can also be useful when mounting to most versions of "
"&Samba;. This has no effect if the server does not support Unicode."
msgstr ""
"सप्तसु आरक्षितवर्णेषु षट् (बैकस्लैशः न, परन्तु कोलन, प्रश्नचिह्न, पाइप्, ताराचिह्नं, वर्णात् "
"अधिकं, न्यूनं च समाविष्टं) पुनः मैप-परिधिं (0xF000 इत्यस्मात् उपरि) अनुवादयन्तु, यत् क्लायन्ट् "
"पक्षं निर्मितसञ्चिकाः अपि ज्ञातुं शक्नोति &Windows; इत्यस्य POSIX अनुकरणेन एतादृशैः वर्णैः "
"सह । &Samba; इत्यस्य अधिकांशसंस्करणेषु माउण्ट् करणसमये अपि एतत् उपयोगी भवितुम् अर्हति । "
"यदि सर्वरः यूनिकोडस्य समर्थनं न करोति तर्हि एतस्य कोऽपि प्रभावः नास्ति ।"

#. Tag: guibutton
#: index.docbook:2465
#, no-c-format
msgid "Do not send byte range lock requests"
msgstr "बाइट्-परिधि-लॉक्-अनुरोधं न प्रेषयन्तु"

#. Tag: para
#: index.docbook:2468
#, no-c-format
msgid "Option: <option>nobrl</option>"
msgstr "विकल्प:<option value=nobrl> नोब्रल्</option>"

#. Tag: para
#: index.docbook:2469
#, no-c-format
msgid ""
"Do not send byte range lock requests to the server. This is necessary for "
"certain applications that break with cifs style mandatory byte range locks "
"(and most cifs servers do not yet support requesting advisory byte range "
"locks)."
msgstr ""
"बाइट् रेन्ज लॉक् अनुरोधं सर्वरं प्रति न प्रेषयन्तु । एतत् कतिपयेभ्यः अनुप्रयोगेभ्यः आवश्यकं यत् "
"cifs शैल्याः अनिवार्यबाइट्-परिधि-तालानां सह भङ्गं कुर्वन्ति (अधिकांशः cifs-सर्वरः अद्यापि "
"सल्लाहकार-बाइट-परिधि-तालानां अनुरोधं समर्थयति न) ।"

#. Tag: guibutton
#: index.docbook:2475
#, no-c-format
msgid "SMB protocol version"
msgstr "SMB प्रोटोकॉल संस्करणम्"

#. Tag: para
#: index.docbook:2478
#, no-c-format
msgid "Option: <option>vers=VERS</option>"
msgstr "विकल्प:<option value=vers=VERS> vers=VERS</option>"

#. Tag: para
#: index.docbook:2479
#, no-c-format
msgid ""
"Define which version of the SMB protocol is to be used. Normally, this "
"option does not need to be enabled because the protocol version is "
"negotiated between the client and the server."
msgstr ""
"SMB प्रोटोकॉलस्य कस्य संस्करणस्य उपयोगः करणीयः इति परिभाषयन्तु । सामान्यतया, अस्य "
"विकल्पस्य सक्षमीकरणस्य आवश्यकता नास्ति यतोहि प्रोटोकॉलसंस्करणं क्लायन्ट्-सर्वरयोः मध्ये "
"वार्तालापः भवति ।"

#. Tag: para
#: index.docbook:2480 index.docbook:2559
#, no-c-format
msgid "The following values are allowed:"
msgstr "निम्नलिखितमूल्यानि अनुमताः सन्ति ।"

#. Tag: guibutton
#: index.docbook:2484
#, no-c-format
msgid "1.0 (Classic &CIFS;/SMBv1 protocol)"
msgstr "१.० (क्लासिक &CIFS;/SMBv1 प्रोटोकॉल)"

#. Tag: para
#: index.docbook:2487
#, no-c-format
msgid ""
"This causes <ulink url=\"man:/mount.cifs"
"\"><citerefentry><refentrytitle>mount.cifs</refentrytitle><manvolnum>8</"
"manvolnum></citerefentry></ulink> to use the classic &CIFS;/SMBv1 protocol."
msgstr ""
"एतेन <ulink url=\"man:/mount.cifs\"><citerefentry><refentrytitle>mount.cifs</"
"refentrytitle><manvolnum>8</manvolnum></citerefentry></ulink> क्लासिक &CIFS; /"
"SMBv1 प्रोटोकॉल।"

#. Tag: guibutton
#: index.docbook:2492
#, no-c-format
msgid "2.0 (Windows Vista SP1/Windows Server 2008)"
msgstr "२.० (विण्डोज विस्टा एसपी१/विण्डोज सर्वर २००८)"

#. Tag: para
#: index.docbook:2495
#, no-c-format
msgid ""
"This causes <ulink url=\"man:/mount.cifs"
"\"><citerefentry><refentrytitle>mount.cifs</refentrytitle><manvolnum>8</"
"manvolnum></citerefentry></ulink> to use the SMBv2.002 protocol. This was "
"initially introduced in &Microsoft; &Windows; Vista Service Pack 1 and "
"&Windows; Server 2008."
msgstr ""
"एतेन <ulink url=\"man:/mount.cifs\"><citerefentry><refentrytitle>mount.cifs</"
"refentrytitle><manvolnum>8</manvolnum></citerefentry></ulink> इत्यनेन "
"SMBv2.002 इत्यस्य उपयोगः भवति प्रोटोकॉल। एतत् प्रारम्भे &Microsoft; &विण्डोज; Vista "
"Service Pack 1 तथा &Windows; सर्वर २००८."

#. Tag: para
#: index.docbook:2496
#, no-c-format
msgid ""
"Please note that the initial release version of &Microsoft; &Windows; Vista "
"spoke a slightly different dialect (2.000) that is not supported."
msgstr ""
