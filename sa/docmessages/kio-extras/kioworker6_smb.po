#. Tag: para
#: index.docbook:18
#, no-c-format
msgid ""
"The smb worker enables you to browse the shares of a &Windows; (or Samba) "
"network."
msgstr "smb कार्यकर्ता भवन्तं &Windows; (वा साम्बा) जालम् ।"

#. Tag: para
#: index.docbook:23
#, no-c-format
msgid ""
"To see the workgroups, enter <userinput><command>smb:/</command></userinput>."
msgstr ""
"कार्यसमूहान् द्रष्टुं <userinput><command>smb:/</command></userinput> इति प्रविशन्तु ।"

#. Tag: para
#: index.docbook:27
#, no-c-format
msgid ""
"<userinput><command>smb://</command><replaceable>a_workgroup</replaceable></"
"userinput> will list the hosts in this workgroup."
msgstr ""
"<userinput><command>smb://</command><replaceable>a_workgroup</replaceable></"
"userinput> अस्मिन् कार्यसमूहे यजमानानाम् सूचीं करिष्यति ।"

#. Tag: para
#: index.docbook:31
#, no-c-format
msgid ""
"To see the shares of a host, enter <userinput><command>smb://</"
"command><replaceable>the_host</replaceable></userinput> or "
"<userinput><command>smb:/</command><replaceable>a_workgroup</replaceable>/"
"<replaceable>the_host</replaceable></userinput>."
msgstr ""
"मेजबानस्य भागं द्रष्टुं <userinput><command>smb://</command><replaceable>the_host</"
"replaceable></userinput> अथवा <userinput><command>smb:/</command>< इति "
"प्रविष्टं कुर्वन्तु replaceable>a_workgroup</replaceable>/<replaceable>होस्ट्</"
"replaceable></userinput> इति ।"

#. Tag: para
#: index.docbook:37
#, no-c-format
msgid ""
"To access a share directly enter <userinput><command>smb://</"
"command><replaceable>the_host/the_share</replaceable></userinput> or "
"<userinput><command>smb:/</command><replaceable>a_workgroup</replaceable>/"
"<replaceable>the_host</replaceable>/<replaceable>the_share</replaceable></"
"userinput>"
msgstr ""
"साक्षात् भागं प्राप्तुं <userinput><command>smb://</command><replaceable>the_host/"
"the_share</replaceable></userinput> अथवा <userinput><command>smb:/</"
"command><replaceable इति प्रविष्टं कुर्वन्तु >a_workgroup</replaceable>/"
"<replaceable>the_host</replaceable>/<replaceable>the_share</replaceable></"
"userinput> इति"

#. Tag: para
#: index.docbook:44
#, no-c-format
msgid "The smb worker requires that you have libsmbclient to use this worker."
msgstr ""
"smb कार्यकर्ता अस्य कार्यकर्तारस्य उपयोगाय भवतः libsmbclient अस्ति इति अपेक्षते ।"

#. Tag: para
#: index.docbook:48
#, no-c-format
msgid ""
"You can set your default user name and password in the &systemsettings; "
"category <guilabel>Network</guilabel> in "
"<menuchoice><guisubmenu>Connectivity</guisubmenu><guimenuitem> Windows "
"Shares</guimenuitem></menuchoice>. This is especially useful if you are a "
"member of a &Windows; <acronym>NT</acronym> domain. There you can also set "
"your workgroup name, but in most cases this is not required. The worker will "
"ask for your username and password if a default is not set."
msgstr ""
"भवान् स्वस्य पूर्वनिर्धारितं उपयोक्तृनाम गुप्तशब्दं च &systemsettings; category "
"<guilabel>जालम्</guilabel> <menuchoice><guisubmenu>संयोजन</"
"guisubmenu><guimenuitem> विण्डोजसाझेदारी</guimenuitem></menuchoice> इत्यत्र । "
"यदि भवान् &Windows; <acronym>NT</acronym> डोमेन् । तत्र भवान् स्वस्य कार्यसमूहस्य नाम "
"अपि सेट् कर्तुं शक्नोति, परन्तु अधिकतया एतत् आवश्यकं नास्ति । यदि पूर्वनिर्धारितं न सेट् भवति "
"तर्हि कार्यकर्ता भवतः उपयोक्तृनाम गुप्तशब्दं च पृच्छति ।"
