#, no-c-format
msgid "Split Horizontal"
msgstr "विभक्त क्षैतिज"

#. Tag: keycombo
#: fundamentals.docbook:344
#, no-c-format
msgid "&Ctrl;&Shift;<keycap>L</keycap>"
msgstr "&Ctrl;&Shift;<keycap>L</keycap> इति"

