#. Tag: guilabel
#: plugins.docbook:3521 plugins.docbook:3569
#, no-c-format
msgid "Name"
msgstr "नामः"

#. Tag: para
#: plugins.docbook:3522
#, no-c-format
msgid ""
"Appears in the list of snippets in the tool view and is also searched when "
"using the code completion feature."
msgstr "साधनदृश्ये स्निपेट्-सूचौ दृश्यते तथा च कोड-समाप्ति-विशेषतायाः उपयोगे अपि अन्वेष्यते ।"

#. Tag: guilabel
#: plugins.docbook:3527
#, no-c-format
msgid "Namespace"
msgstr "नामस्थानम्"

#. Tag: para
#: plugins.docbook:3528
#, no-c-format
msgid "Prefix used while using code completion."
msgstr "कोडसमाप्तिप्रयोगे प्रयुक्तः उपसर्गः ।"

#. Tag: guilabel
#: plugins.docbook:3532
#, no-c-format
msgid "License"
msgstr "अनुज्ञापत्रम्"

#. Tag: para
#: plugins.docbook:3533
#, no-c-format
msgid "Select the license for you snippet repository."
