msgstr "Search and Replace इति साधनदृश्यं प्रारभते ।"

#. Tag: menuchoice
#: plugins.docbook:3384
#, no-c-format
msgid "<guimenu>Edit</guimenu> <guimenuitem>Go to Next Match</guimenuitem>"
msgstr "<guimenu>सम्पादनं</guimenu> <guimenuitem>अग्रे मेलनं</guimenuitem> इति गच्छन्तु"

#. Tag: para
#: plugins.docbook:3389
#, no-c-format
msgid ""
"Go to the next match in a search performed by the Search and Replace plugin."
msgstr "Search and Replace प्लगिन् इत्यनेन कृते अन्वेषणे अग्रिममेलनं गच्छन्तु ।"

#. Tag: menuchoice
#: plugins.docbook:3395
#, no-c-format
msgid "<guimenu>Edit</guimenu> <guimenuitem>Go to Previous Match</guimenuitem>"
msgstr "<guimenu>सम्पादनं</guimenu> <guimenuitem>पूर्वमेलनं</guimenuitem> इति गच्छन्तु"

#. Tag: para
#: plugins.docbook:3400
#, no-c-format
msgid ""
"Go to the previous match in a search performed by the Search and Replace "
