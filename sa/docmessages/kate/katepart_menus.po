#. Tag: title
#: menus.docbook:2
#, no-c-format
msgid "The Menu Entries"
msgstr "मेनू प्रविष्टयः इति"

#. Tag: title
#: menus.docbook:5
#, no-c-format
msgid "The File Menu"
msgstr "सञ्चिकामेनू इति"

#. Tag: menuchoice
#: menus.docbook:10
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>N</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>New</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>N</keycap></keycombo> </"
"shortcut> <guimenu>सञ्चिका</guimenu> <guimenuitem>नवीन</guimenuitem>"

#. Tag: para
#: menus.docbook:18
#, no-c-format
msgid "This starts a new document in a new and independent editor window."
msgstr "एतेन नूतने स्वतन्त्रे च सम्पादकविण्डो मध्ये नूतनं दस्तावेजं आरभ्यते ।"

#. Tag: menuchoice
#: menus.docbook:25
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>New Window</guimenuitem>"
msgstr "<guimenu>सञ्चिका</guimenu> <guimenuitem>नवीनविण्डो</guimenuitem>"

#. Tag: para
#: menus.docbook:30
#, no-c-format
msgid ""
"Create another window containing the current document. All changes to the "
"document in one window are reflected in the other window and vice versa."
msgstr ""
"वर्तमानदस्तावेजं युक्तं अन्यं विण्डो रचयन्तु । एकस्मिन् विण्डो मध्ये दस्तावेजस्य सर्वे परिवर्तनाः "
"अन्यस्मिन् विण्डो मध्ये प्रतिबिम्बिताः भवन्ति तथा च विपरीतम् ।"

#. Tag: menuchoice
#: menus.docbook:36
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>O</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Open...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>O</keycap></keycombo> </"
"shortcut> <guimenu>सञ्चिका</guimenu> <guimenuitem>उद्घाट्य...</guimenuitem>"

#. Tag: para
#: menus.docbook:44
#, no-c-format
msgid ""
"Displays a standard &kde; <guilabel>Open File</guilabel> dialog. Use the "
"file view to select the file you want to open, and click on <guibutton>Open</"
"guibutton> to open it."
msgstr ""
"एकं मानकं प्रदर्शयति &kde; <guilabel>सञ्चिका</guilabel> संवादं उद्घाटयन्तु । भवन्तः यत् "
"सञ्चिकां उद्घाटयितुम् इच्छन्ति तत् चिन्वन्तु इति सञ्चिकादृश्यस्य उपयोगं कुर्वन्तु, तत् उद्घाटयितुं "
"<guibutton>Open</guibutton> इत्यत्र नुदन्तु ।"

#. Tag: menuchoice
#: menus.docbook:51
#, no-c-format
msgid "<guimenu>File</guimenu> <guisubmenu>Open Recent</guisubmenu>"
msgstr "<menu>सञ्चिका</menu> <menu>अद्यतनं</menu> उद्घाटयन्तु"

#. Tag: para
#: menus.docbook:56
#, no-c-format
msgid ""
"This is a shortcut to open recently saved documents. Clicking on this item "
"opens a list to the side of the menu with several of the most recently saved "
"files. Clicking on a specific file will open it in &kappname; - if the file "
"still resides at the same location."
msgstr ""
"सद्यः रक्षितानि दस्तावेजानि उद्घाटयितुं एषः शॉर्टकट् अस्ति । अस्मिन् द्रव्ये क्लिक् करणेन मेन्यू "
"पार्श्वे एकं सूची उद्घाट्यते यत्र अद्यतनतया रक्षितानां कतिपयानां सञ्चिकानां सह । "
"विशिष्टसञ्चिकायां क्लिक् कृत्वा &kappname; - यदि सञ्चिका अद्यापि तस्मिन् एव स्थाने निवसति।"

#. Tag: menuchoice
#: menus.docbook:67
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>S</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Save</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>S</keycap></keycombo> </"
"shortcut> <guimenu>सञ्चिका</guimenu> <guimenuitem>रक्षतु</guimenuitem>"

#. Tag: para
#: menus.docbook:75
#, no-c-format
msgid ""
"This saves the current document. If there has already been a save of the "
"document then this will overwrite the previously saved file without asking "
"for the user's consent. If it is the first save of a new document the save "
"as dialog (described below) will be invoked."
msgstr ""
"एतेन वर्तमानदस्तावेजः रक्षितः भवति । यदि पूर्वमेव दस्तावेजस्य रक्षणं जातम् अस्ति तर्हि एतत् "
"उपयोक्तुः सहमतिम् न याचयित्वा पूर्वं रक्षितां सञ्चिकां अधिलेखयिष्यति । यदि नूतनदस्तावेजस्य "
"प्रथमं रक्षणं भवति तर्हि save as संवादः (अधः वर्णितः) आह्वयते ।"

#. Tag: menuchoice
#: menus.docbook:85
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>S</keycap></"
"keycombo> </shortcut> <guimenu>File</guimenu> <guimenuitem>Save As...</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>S</keycap></"
"keycombo> </shortcut> <guimenu>सञ्चिका</guimenu> <guimenuitem>यथा रक्षतु...</"
"guimenuitem >"

#. Tag: para
#: menus.docbook:93
#, no-c-format
msgid ""
"This allows a document to be saved with a new file name. This is done by "
"means of the file dialog box described above in the <link linkend=\"file-open"
"\">Open</link> section of this help file."
msgstr ""
"एतेन नूतनसञ्चिकानाम्ना सह दस्तावेजं रक्षितुं शक्यते । एतत् उपरि वर्णितस्य "
"सञ्चिकासंवादपेटिकायाः माध्यमेन भवति<link linkend=\"file-open\"> उद्घाटित</link> "
"अस्याः सहायतासञ्चिकायाः विभागः ।"

#. Tag: menuchoice
#: menus.docbook:102
#, no-c-format
msgid ""
"<guimenu>File</guimenu> <guimenuitem>Save As with Encoding</guimenuitem>"
msgstr ""
"<guimenu>सञ्चिका</guimenu> <guimenuitem>एन्कोडिंग् इत्यनेन सह यथा रक्षन्तु</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:107
#, no-c-format
msgid "Save a document with a new file name in a different encoding."
msgstr "नूतनसञ्चिकानाम्ना सह दस्तावेजं भिन्ने एन्कोडिंग् मध्ये रक्षन्तु ।"

#. Tag: menuchoice
#: menus.docbook:113
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Save Copy As</guimenuitem>"
msgstr "<guimenu>सञ्चिका</guimenu> <guimenuitem>प्रतिलिपिं रक्षतु</guimenuitem>"

#. Tag: para
#: menus.docbook:118
#, no-c-format
msgid ""
"Save a copy of the document with a new file name and continue editing the "
"original document."
msgstr ""
"दस्तावेजस्य प्रतिलिपिं नूतनसञ्चिकानाम्ना सह रक्षित्वा मूलदस्तावेजस्य सम्पादनं निरन्तरं कुर्वन्तु ।"

#. Tag: menuchoice
#: menus.docbook:124
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"><keycap>F5</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Reload</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"><keycap>F5</keycap></keycombo> </"
"shortcut> <guimenu>सञ्चिका</guimenu> <guimenuitem>पुनः लोड्</guimenuitem>"

#. Tag: para
#: menus.docbook:132
#, no-c-format
msgid ""
"Reloads the active file from disk. This command is useful if another program "
"or process has changed the file while you have it open in &kappname;."
msgstr ""
"सक्रियसञ्चिकां डिस्कतः पुनः लोड् करोति । यदि भवता &kappname;मध्ये उद्घाटितं भवति तदा "
"अन्यः कार्यक्रमः प्रक्रिया वा सञ्चिकां परिवर्तयति चेत् एषः आदेशः उपयोगी भवति ।"

#. Tag: menuchoice
#: menus.docbook:140
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>P</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Print...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>P</keycap></keycombo> </"
"shortcut> <guimenu>सञ्चिका</guimenu> <guimenuitem>मुद्रणं...</guimenuitem>"

#. Tag: para
#: menus.docbook:148
#, no-c-format
msgid ""
"Opens a simple print dialog allowing the user to specify what, where, and "
"how to print."
msgstr ""
"सरलं मुद्रणसंवादं उद्घाटयति यत् उपयोक्तारं किं, कुत्र, कथं च मुद्रणं कर्तव्यमिति निर्दिष्टुं "
"शक्नोति ।"

#. Tag: menuchoice
#: menus.docbook:158
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Export as HTML</guimenuitem>"
msgstr "<guimenu>सञ्चिका</guimenu> <guimenuitem>HTMLरूपेण निर्यातयतु</guimenuitem>"

#. Tag: para
#: menus.docbook:163
#, no-c-format
msgid ""
"Save the currently open document as an &HTML; file, which will be formatted "
"using the current syntax highlighting and color scheme settings."
msgstr ""
"वर्तमानं उद्घाटितं दस्तावेजं &HTML; file, यत् वर्तमानस्य वाक्यविन्यासस्य प्रकाशनस्य, "
"वर्णयोजनायाः च सेटिंग्स् इत्यस्य उपयोगेन स्वरूपितं भविष्यति ।"

#. Tag: menuchoice
#: menus.docbook:169
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>W</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Close</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>W</keycap></keycombo> </"
"shortcut> <guimenu>सञ्चिका</guimenu> <guimenuitem>निमील्य</guimenuitem>"

#. Tag: para
#: menus.docbook:177
#, no-c-format
msgid ""
"Close the active file with this command. If you have made unsaved changes, "
"you will be prompted to save the file before &kappname; closes it."
msgstr ""
"एतेन आदेशेन सक्रियसञ्चिकां पिधाय । यदि भवान् असरक्षितपरिवर्तनं कृतवान् तर्हि &kappname; "
"पिधाति ।"

#. Tag: menuchoice
#: menus.docbook:185
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>Q</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Quit</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>प्रश्न</keycap></keycombo> "
"</shortcut> <guimenu>सञ्चिका</guimenu> <guimenuitem>निर्गम</guimenuitem>"

#. Tag: para
#: menus.docbook:193
#, no-c-format
msgid ""
"This will close the editor window, if you have more than one instance of "
"&kappname; running, through the <guimenuitem>New</guimenuitem> or "
"<guimenuitem>New Window</guimenuitem> menu items, those instances will not "
"be closed."
msgstr ""
"एतेन सम्पादकविण्डो पिधास्यति, यदि भवतां समीपे &kappname; चालयन्, <guimenuitem>नव</"
"guimenuitem> अथवा <guimenuitem>नवीनविण्डो</guimenuitem> मेन्यू-वस्तूनाम् माध्यमेन, "
"तानि उदाहरणानि न पिहिताः भविष्यन्ति ।"

#. Tag: title
#: menus.docbook:207
#, no-c-format
msgid "The Edit Menu"
msgstr "सम्पादन मेनू इति"

#. Tag: menuchoice
#: menus.docbook:212
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>Z</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Undo</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>Z</keycap></keycombo> </"
"shortcut> <guimenu>सम्पादन</guimenu> <guimenuitem>पूर्ववर्ती</guimenuitem>"

#. Tag: para
#: menus.docbook:220
#, no-c-format
msgid "Undo the last editing command (typing, copying, cutting &etc;)"
msgstr "अन्तिमसम्पादन-आदेशं (टङ्कनं, प्रतिलिपिं, कटनं & इत्यादीनि) पूर्ववत् कुर्वन्तु ।"

#. Tag: para
#: menus.docbook:221
#, no-c-format
msgid ""
"This may undo several editing commands of the same type, like typing in "
"characters."
msgstr ""
"एतेन वर्णानाम् टङ्कनम् इत्यादीनि समानप्रकारस्य अनेकाः सम्पादन-आदेशाः पूर्ववत् कर्तुं शक्यन्ते ।"

#. Tag: menuchoice
#: menus.docbook:227
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>Z</keycap></"
"keycombo> </shortcut> <guimenu>Edit</guimenu> <guimenuitem>Redo</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>Z</keycap></"
"keycombo> </shortcut> <guimenu>सम्पादन</guimenu> <guimenuitem>पुनः करो</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:235
#, no-c-format
msgid "This will reverse the most recent change (if any) made using Undo."
msgstr "एतेन Undo इत्यस्य उपयोगेन कृतं नवीनतमं परिवर्तनं (यदि अस्ति) विपर्यस्तं भविष्यति ।"

#. Tag: menuchoice
#: menus.docbook:240
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>X</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Cut</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>X</keycap></keycombo> </"
"shortcut> <guimenu>सम्पादन</guimenu> <guimenuitem>कट</guimenuitem>"

#. Tag: para
#: menus.docbook:248
#, no-c-format
msgid ""
"This command deletes the current selection and places it on the clipboard. "
"The clipboard works invisibly and provides a way to transfer data between "
"applications."
msgstr ""
"एषः आदेशः वर्तमानचयनं विलोप्य क्लिप्बोर्ड् मध्ये स्थापयति । क्लिप्बोर्ड् अदृश्यरूपेण कार्यं करोति "
"तथा च अनुप्रयोगानाम् मध्ये आँकडानां स्थानान्तरणस्य मार्गं प्रदाति ।"

#. Tag: menuchoice
#: menus.docbook:255
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>C</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Copy</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>C</keycap></keycombo> </"
"shortcut> <guimenu>सम्पादन</guimenu> <guimenuitem>प्रतिलिपि</guimenuitem>"

#. Tag: para
#: menus.docbook:263
#, no-c-format
msgid ""
"This copies the currently selected text to the clipboard so that it may be "
"pasted elsewhere. The clipboard works invisibly and provides a way to "
"transfer data between applications."
msgstr ""
"एतेन सम्प्रति चयनितं पाठं क्लिप्बोर्ड् मध्ये प्रतिलिप्यते यथा अन्यत्र चिनोतु । क्लिप्बोर्ड् "
"अदृश्यरूपेण कार्यं करोति तथा च अनुप्रयोगानाम् मध्ये आँकडानां स्थानान्तरणस्य मार्गं प्रदाति ।"

#. Tag: menuchoice
#: menus.docbook:270
#, no-c-format
msgid "<guimenu>Edit</guimenu> <guimenuitem>Copy as HTML</guimenuitem>"
msgstr ""
"<guimenu>सम्पादनं</guimenu> <guimenuitem>HTML</guimenuitem>रूपेण प्रतिलिपिं कुर्वन्तु"

#. Tag: para
#: menus.docbook:275
#, no-c-format
msgid ""
"Copy the selection as &HTML;, formatted using the current syntax "
"highlighting and color scheme settings."
msgstr "चयनं &HTML;"

#. Tag: menuchoice
#: menus.docbook:281
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>V</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Paste</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>V</keycap></keycombo> </"
"shortcut> <guimenu>सम्पादन</guimenu> <guimenuitem>चिपकतु</guimenuitem>"

#. Tag: para
#: menus.docbook:289
#, no-c-format
msgid ""
"This will insert the first item in the clipboard at the cursor position. The "
"clipboard works invisibly and provides a way to transfer data between "
"applications."
msgstr ""
"एतेन कर्सरस्थाने प्रथमं द्रव्यं क्लिप्बोर्ड् मध्ये सम्मिलितं भविष्यति । क्लिप्बोर्ड् अदृश्यरूपेण कार्यं "
"करोति तथा च अनुप्रयोगानाम् मध्ये आँकडानां स्थानान्तरणस्य मार्गं प्रदाति ।"

#. Tag: para
#: menus.docbook:292
#, no-c-format
msgid ""
"If Overwrite Selection is enabled, the pasted text will overwrite the "
"selection, if any."
msgstr ""
"यदि Overwrite Selection सक्षमम् अस्ति तर्हि चिनोति पाठः चयनं अधिलेखयिष्यति, यदि "
"अस्ति ।"

#. Tag: menuchoice
#: menus.docbook:297
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;&Ins;</keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Paste Selection</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;&Ins;</keycombo> </"
"shortcut> <guimenu>सम्पादनं</guimenu> <guimenuitem>चयनं चिनोतु</guimenuitem>"

#. Tag: para
#: menus.docbook:305
#, no-c-format
msgid ""
"This will paste the <ulink url=\"https://en.wikipedia.org/wiki/"
"Clipboard_(computing)#X_Window_System\">mouse selection</ulink> contents "
"that were chosen previously. Mark some text with the mouse pointer to paste "
"it in the currently open file using this menu item."
msgstr ""
"एतेन पूर्वं चयनितानि <ulink url=\"https://en.wikipedia.org/wiki/"
"Clipboard_(computing)#X_Window_System\">मूषकचयन</ulink> सामग्रीः चिनोति । एतत् "
"मेनू-वस्तु उपयुज्य वर्तमान-उद्घाटित-सञ्चिकायां चिनोतुं मूषक-सूचकेन किञ्चित् पाठं चिह्नितव्यम् ।"

#. Tag: menuchoice
#: menus.docbook:310
#, no-c-format
msgid ""
"<guimenu>Edit</guimenu> <guimenuitem>Swap with clipboard contents</"
"guimenuitem>"
msgstr ""
"<guimenu>सम्पादनं</guimenu> <guimenuitem>क्लिपबोर्डसामग्रीभिः सह अदला-बदली</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:315
#, no-c-format
msgid ""
"This will swap the selected text with the <ulink url=\"https://en.wikipedia."
"org/wiki/Clipboard_(computing)#X_Window_System\">clipboard</ulink> contents."
msgstr ""
"एतेन चयनितपाठः <ulink url=\"https://en.wikipedia.org/wiki/"
"Clipboard_(computing)#X_Window_System\">क्लिप्बोर्ड</ulink> सामग्रीभिः सह स्वैपं "
"करिष्यति ।"

#. Tag: menuchoice
#: menus.docbook:320
#, no-c-format
msgid ""
"<guimenu>Edit</guimenu> <guimenuitem>Clipboard History Paste</guimenuitem>"
msgstr ""
"<guimenu>सम्पादनं</guimenu> <guimenuitem>क्लिपबोर्ड इतिहास चिनोतु</guimenuitem>"

#. Tag: para
#: menus.docbook:325
#, no-c-format
msgid ""
"This will open a dialog to select and paste an entry from the clipboard "
"history."
msgstr "एतेन क्लिप्बोर्ड-इतिहासात् प्रविष्टिं चिन्वितुं चिनोतु च संवादः उद्घाट्यते ।"

#. Tag: menuchoice
#: menus.docbook:330
#, no-c-format
msgid "<guimenu>Edit</guimenu> <guimenuitem>Input Modes</guimenuitem>"
msgstr "<guimenu>सम्पादनं</guimenu> <guimenuitem>निवेशविधानानि</guimenuitem>"

#. Tag: para
#: menus.docbook:335
#, no-c-format
msgid ""
"Switch between a normal and a vi-like, modal editing mode. The vi input mode "
"supports the most used commands and motions from vim's normal and visual "
"mode and has an optional vi mode statusbar. This status bar shows commands "
"while they are being entered, output from commands and the current mode. The "
"behavior of this mode can be configured in the <link linkend=\"pref-edit-vi-"
"input-mode\">Vi Input Mode</link> tab of the <guilabel>Editing</guilabel> "
"page in &kappname;'s settings dialog."
msgstr ""
"सामान्यस्य vi-सदृशस्य च, मोडाल् सम्पादनविधानस्य मध्ये स्विच् कुर्वन्तु । vi इनपुट् मोड् vim "
"इत्यस्य सामान्यतः दृश्यविधानतः च सर्वाधिकं प्रयुक्तान् आदेशान् गतिं च समर्थयति तथा च वैकल्पिकं "
"vi मोड् स्थितिपट्टिका अस्ति । एषा स्थितिपट्टिका आदेशान् प्रविष्टस्य समये, आदेशात् निर्गमं, "
"वर्तमानविधानं च दर्शयति । अस्य मोडस्य व्यवहारः विन्यस्तुं शक्यते<link linkend=\"pref-"
"edit-vi-input-mode\"> Vi इनपुट मोड</link> टब इत्यस्य<guilabel> सम्पादनम्</"
"guilabel> &amp;kappname; इत्यस्य सेटिंग्स् संवादे पृष्ठम् ।"

#. Tag: menuchoice
#: menus.docbook:345
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ins;</keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Overwrite Mode</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ins;</keycombo> </shortcut> "
"<guimenu>सम्पादन</guimenu> <guimenuitem>अतिलेखनविधिः</guimenuitem>"

#. Tag: para
#: menus.docbook:353
#, no-c-format
msgid ""
"Toggles the Insert/Overwrite modes. When the mode is <guilabel>INS</"
"guilabel>, you insert characters where the cursor is. When the mode is "
"<guilabel>OVR</guilabel>, writing characters will replace the current "
"characters if your cursor is positioned before any character. The status bar "
"shows the current state of the Overwrite Mode, either <guilabel>INS</"
"guilabel> or <guilabel>OVR</guilabel>."
msgstr ""
"Insert/Overwrite मोड्स् टॉग्ल् करोति । यदा मोड् <guilabel>INS</guilabel> भवति तदा "
"भवन्तः यत्र कर्सरः अस्ति तत्र वर्णाः निवेशयन्ति । यदा मोड् <guilabel>OVR</guilabel> "
"भवति तदा वर्णलेखनं वर्तमानवर्णानां स्थाने स्थास्यति यदि भवतः कर्सरः कस्यापि वर्णस्य पुरतः "
"स्थितः अस्ति । स्थितिपट्टिका Overwrite Mode इत्यस्य वर्तमानस्थितिं दर्शयति, "
"<guilabel>INS</guilabel> अथवा <guilabel>OVR</guilabel> इति ।"

#. Tag: menuchoice
#: menus.docbook:362
#, no-c-format
msgid "<guimenu>Edit</guimenu> <guimenuitem>Read Only Mode</guimenuitem>"
msgstr "<guimenu>सम्पादनं</guimenu> <guimenuitem>केवलपठनविधिः</guimenuitem>"

#. Tag: para
#: menus.docbook:367
#, no-c-format
msgid ""
"Set the current document to Read Only mode. This prevents any text addition "
"and any changes in the document formatting."
msgstr ""
"वर्तमानदस्तावेजं Read Only मोड् इत्यत्र सेट् कुर्वन्तु । एतेन किमपि पाठसंयोजनं दस्तावेजस्वरूपणे "
"किमपि परिवर्तनं च निवारितं भवति ।"

#. Tag: menuchoice
#: menus.docbook:373
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>F</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Find...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>F</keycap></keycombo> </"
"shortcut> <guimenu>सम्पादनं</guimenu> <guimenuitem>अन्वेषणं...</guimenuitem>"

#. Tag: para
#: menus.docbook:381
#, no-c-format
msgid ""
"This opens the incremental search bar at the bottom of the editor window. On "
"the left side of the bar is a button with an icon to close the bar, followed "
"by a small text box for entering the search pattern."
msgstr ""
"एतेन सम्पादकविण्डो इत्यस्य अधः वृद्धिशीलं अन्वेषणपट्टिका उद्घाटिता भवति । पट्टिकायाः "
"वामभागे पट्टिकां पिधातुं चिह्नयुक्तं बटनं भवति, तदनन्तरं अन्वेषणप्रतिमानं प्रविष्टुं लघुपाठपेटिका "
"अस्ति ।"

#. Tag: para
#: menus.docbook:384
#, no-c-format
msgid ""
"When you start entering characters of your search pattern, the search starts "
"immediately. If there is a match in the text this is highlighted and the "
"background color of the entry field changes to light green. If the search "
"pattern does not match any string in the text, this is indicated by a light "
"red background color of the entry field."
msgstr ""
"यदा भवन्तः स्वस्य अन्वेषणप्रतिमानस्य वर्णाः प्रविष्टुं आरभन्ते तदा अन्वेषणं तत्क्षणमेव आरभ्यते । "
"यदि पाठे मेलनं भवति तर्हि एतत् प्रकाशितं भवति तथा च प्रविष्टिक्षेत्रस्य पृष्ठभूमिवर्णः हल्के "
"हरितवर्णे परिवर्तते । यदि अन्वेषणप्रतिमानं पाठस्य कस्यापि तारस्य सङ्गतिं न करोति तर्हि एतत् "
"प्रविष्टिक्षेत्रस्य हल्केन रक्तेन पृष्ठभूमिवर्णेन सूचितं भवति ।"

#. Tag: para
#: menus.docbook:388 menus.docbook:488
#, no-c-format
msgid ""
"Use the <inlinemediaobject><imageobject><imagedata fileref=\"arrow-up-"
"double-22.png\" format=\"PNG\"/></imageobject></inlinemediaobject> or "
"<inlinemediaobject><imageobject><imagedata fileref=\"arrow-down-double-22.png"
"\" format=\"PNG\"/></imageobject></inlinemediaobject> button to jump to the "
"next or previous match in the document."
msgstr ""
"<inlinemediaobject><imageobject><imagedata fileref=\"arrow-up-double-22.png"
"\" format=\"PNG\"/></imageobject></inlinemediaobject> अथवा "
"<inlinemediaobject><imageobject><imagedata fileref=\"arrow-down-double-22.png"
"\" format=\"PNG\"/></imageobject></inlinemediaobject> बटन दस्तावेजे अग्रिम-पूर्व-"
"मेलनं प्रति कूर्दितुं ।"

#. Tag: para
#: menus.docbook:392
#, no-c-format
msgid ""
"Matches in the document are highlighted even when you close the search bar. "
"To clear this highlighting, press the &Esc; key."
msgstr ""
"अन्वेषणपट्टिकां पिधाय दस्तावेजे मेलनं प्रकाशितं भवति । एतत् हाइलाइटिङ्ग् स्वच्छं कर्तुं &Esc; "
"कुंजी।"

#. Tag: para
#: menus.docbook:394
#, no-c-format
msgid ""
"You can choose whether the search should be case sensitive. Selecting "
"<inlinemediaobject><imageobject><imagedata fileref=\"format-text-"
"superscript-22.png\" format=\"PNG\"/></imageobject></inlinemediaobject> will "
"limit finds to entries that match the case (upper or lower) of each of the "
"characters in the search pattern."
msgstr ""
"अन्वेषणं लघुसंवेदनशीलं भवेत् वा इति भवन्तः चिन्वितुं शक्नुवन्ति । "
"<inlinemediaobject><imageobject><imagedata fileref=\"format-text-"
"superscript-22.png\" format=\"PNG\"/></imageobject></inlinemediaobject> "
"इत्यस्य चयनेन अन्वेषणं केस-सङ्गत-प्रविष्टिषु सीमितं भविष्यति (उच्चं वा अधः वा ) "
"अन्वेषणप्रतिमानस्य प्रत्येकस्य वर्णस्य ।"

#. Tag: para
#: menus.docbook:399
#, no-c-format
msgid ""
"Click on the <inlinemediaobject><imageobject><imagedata fileref=\"configure-"
"shortcuts-22.png\" format=\"PNG\"/></imageobject></inlinemediaobject> button "
"at the right side of the incremental search bar to switch to the power "
"search and replace bar."
msgstr ""
"परिवर्तनार्थं वृद्धिशीलसन्धानपट्टिकायाः दक्षिणभागे "
"<inlinemediaobject><imageobject><imagedata fileref=\"configure-shortcuts-22."
"png\" format=\"PNG\"/></imageobject></inlinemediaobject> बटनं नुदन्तु शक्ति अन्वेषणं "
"प्रतिस्थापनं च पट्टिका।"

#. Tag: menuchoice
#: menus.docbook:407
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"><keycap>F3</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guisubmenu>Find Variants</guisubmenu> "
"<guimenuitem>Find Next</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"><keycap>F3</keycap></keycombo> </"
"shortcut> <guimenu>सम्पादनं</guimenu> <guisubmenu>विविधतां अन्वेष्टुम्</guisubmenu> "
"<guimenuitem>अग्रे अन्वेष्टुम्< /गुइमेनुआइटम>"

#. Tag: para
#: menus.docbook:416
#, no-c-format
msgid ""
"This repeats the last find operation, if any, without calling the "
"incremental search bar, and searching forwards through the document starting "
"from the cursor position."
msgstr ""
"एतेन अन्तिम-अन्वेषण-क्रिया, यदि अस्ति, पुनरावृत्तिः भवति, वृद्धिशील-अन्वेषण-पट्टिकां न "
"आह्वयित्वा, कर्सर-स्थानात् आरभ्य दस्तावेजस्य माध्यमेन अग्रे अन्वेषणं च ।"

#. Tag: menuchoice
#: menus.docbook:423
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Shift;<keycap>F3</keycap></keycombo> "
"</shortcut> <guimenu>Edit</guimenu> <guisubmenu>Find Variants</guisubmenu> "
"<guimenuitem>Find Previous</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Shift;<keycap>F3</keycap></keycombo> "
"</shortcut> <guimenu>सम्पादनं</guimenu> <guisubmenu>रूपान्तरं अन्वेष्टुम्</guisubmenu> "
"<guimenuitem>अन्वेषणम् पूर्व</guimenuitem> इति"

#. Tag: para
#: menus.docbook:432
#, no-c-format
msgid ""
"This repeats the last find operation, if any, without calling the "
"incremental search bar, and searching backwards instead of forwards through "
"the document."
msgstr ""
"एतेन अन्तिम-अन्वेषण-क्रिया, यदि अस्ति, पुनरावृत्तिः भवति, वृद्धिशील-अन्वेषण-पट्टिकां न "
"आह्वयित्वा, दस्तावेजस्य माध्यमेन अग्रे न कृत्वा पश्चात् अन्वेषणं भवति ।"

#. Tag: menuchoice
#: menus.docbook:441
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>H</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guisubmenu>Find Variants</guisubmenu> "
"<guimenuitem>Find Selected</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>H</keycap></keycombo> </"
"shortcut> <guimenu>सम्पादनं</guimenu> <guisubmenu>रूपान्तरं अन्वेष्टुम्</guisubmenu> "
"<guimenuitem>अन्वेषणम् चयनितम्</guimenuitem>"

#. Tag: para
#: menus.docbook:450
#, no-c-format
msgid "Finds next occurrence of selected text."
msgstr "चयनितपाठस्य अग्रिमः आवृत्तिः अन्वेषयति ।"

#. Tag: menuchoice
#: menus.docbook:455
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>H</keycap></"
"keycombo> </shortcut> <guimenu>Edit</guimenu> <guisubmenu>Find Variants</"
"guisubmenu> <guimenuitem>Find Selected Backwards</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>H</keycap></"
"keycombo> </shortcut> <guimenu>सम्पादनं</guimenu> <guisubmenu>रूपान्तरं अन्वेष्टुम्</"
"guisubmenu> <guimenuitem >चयनितं पृष्ठतः अन्वेष्टुम्</guimenuitem>"

#. Tag: para
#: menus.docbook:464
#, no-c-format
msgid "Finds previous occurrence of selected text."
msgstr "चयनितपाठस्य पूर्वानुभवं अन्वेषयति ।"

#. Tag: menuchoice
#: menus.docbook:469
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>R</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Replace...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>R</keycap></keycombo> </"
"shortcut> <guimenu>सम्पादनं</guimenu> <guimenuitem>प्रतिस्थापनं कुर्वन्तु...</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:477
#, no-c-format
msgid ""
"This command opens the power search and replace bar. On the upper left side "
"of the bar is a button with an icon to close the bar, followed by a small "
"text box for entering the search pattern."
msgstr ""
"एषः आदेशः power search and replace इति पट्टिकां उद्घाटयति । पट्टिकायाः उपरि "
"वामभागे पट्टिकां पिधातुं चिह्नयुक्तं बटनं भवति, तदनन्तरं अन्वेषणप्रतिमानं प्रविष्टुं लघुपाठपेटिका "
"अस्ति ।"

#. Tag: para
#: menus.docbook:480
#, no-c-format
msgid ""
"You can control the search mode by selecting <guilabel>Plain text</"
"guilabel>, <guilabel>Whole words</guilabel>, <guilabel>Escape sequences</"
"guilabel> or <guilabel>Regular expression</guilabel> from the drop down box."
msgstr ""
"भवन्तः बून्दतः <guilabel>सादा पाठ</guilabel>, <guilabel>समग्रशब्दाः</guilabel>, "
"<guilabel>पलायनक्रमाः</guilabel> अथवा <guilabel>नियमितव्यञ्जनम्</guilabel> इति "
"चयनं कृत्वा अन्वेषणविधिं नियन्त्रयितुं शक्नुवन्ति down box इति ।"

#. Tag: para
#: menus.docbook:484
#, no-c-format
msgid ""
"If <guilabel>Escape sequences</guilabel> or <guilabel>Regular expression</"
"guilabel> are selected, the <guibutton>Add...</guibutton> menuitem at the "
"bottom of the context menu of the text boxes will be enabled and allows you "
"to add escape sequences or regular expression items to the search or replace "
"pattern from predefined lists."
msgstr ""
"यदि <guilabel>Escape sequences</guilabel> अथवा <guilabel>Regular expression</"
"guilabel> चयनितम् अस्ति तर्हि पाठपेटिकानां सन्दर्भमेनू इत्यस्य अधः <guibutton>Add...</"
"guibutton> menuitem सक्षमं भविष्यति तथा च पूर्वनिर्धारितसूचिकाभ्यः अन्वेषणं प्रति "
"पलायनक्रमं वा नियमितव्यञ्जनवस्तूनि वा योजयितुं वा प्रतिस्थापनं वा अनुमन्यते ।"

#. Tag: para
#: menus.docbook:492
#, no-c-format
msgid ""
"Enter the text to replace with in the text box labeled <guilabel>Replace</"
"guilabel> and click the <guibutton>Replace</guibutton> button to replace "
"only the highlighted text or the <guibutton>Replace All</guibutton> button "
"to replace the search text in the whole document."
msgstr ""
"<guilabel>Replace</guilabel> इति लेबलयुक्ते पाठपेटिकायां प्रतिस्थापनार्थं पाठं प्रविशन्तु "
"तथा च केवलं हाइलाइट् कृतं पाठं प्रतिस्थापयितुं <guibutton>Replace All</guibutton> बटनं "
"नुदन्तु सम्पूर्णे दस्तावेजे अन्वेषणपाठं प्रतिस्थापयन्तु ।"

#. Tag: para
#: menus.docbook:496
#, no-c-format
msgid ""
"You can modify the search and replace behavior by selecting different "
"options at the bottom of the bar. Selecting "
"<inlinemediaobject><imageobject><imagedata fileref=\"format-text-"
"superscript-22.png\" format=\"PNG\"/></imageobject></inlinemediaobject> will "
"limit finds to entries that match the case (upper or lower) of each of the "
"characters in the search pattern. <inlinemediaobject><imageobject><imagedata "
"fileref=\"edit-select-all-22.png\" format=\"PNG\"/></imageobject></"
"inlinemediaobject> will search and replace within the current selection "
"only. The <guilabel>Find All</guilabel> button highlights all matches in the "
"document and shows the number of found matches in a small popup."
msgstr ""
"भवन्तः पट्टिकायाः अधः भिन्नविकल्पान् चित्वा अन्वेषणं प्रतिस्थापनव्यवहारं च परिवर्तयितुं "
"शक्नुवन्ति । <inlinemediaobject><imageobject><imagedata fileref=\"format-text-"
"superscript-22.png\" format=\"PNG\"/></imageobject></inlinemediaobject> "
"इत्यस्य चयनेन अन्वेषणं केस-सङ्गतप्रविष्टिषु सीमितं भविष्यति (उच्चं वा अधः वा ) "
"अन्वेषणप्रतिमानस्य प्रत्येकस्य वर्णस्य । <inlinemediaobject><imageobject><imagedata "
"fileref=\"edit-select-all-22.png\" format=\"PNG\"/></imageobject></"
"inlinemediaobject> केवलं वर्तमानचयनस्य अन्तः अन्वेषणं करिष्यति, प्रतिस्थापयिष्यति च । "
"<guilabel>Find All</guilabel> बटन् दस्तावेजे सर्वाणि मेलनं प्रकाशयति तथा च लघु-पॉपअप-"
"मध्ये प्राप्तमेलनानां संख्यां दर्शयति ।"

#. Tag: para
#: menus.docbook:506
#, no-c-format
msgid ""
"Click on the <inlinemediaobject><imageobject><imagedata fileref=\"configure-"
"shortcuts-22.png\" format=\"PNG\"/></imageobject></inlinemediaobject> button "
"at the right side of the power search and replace bar to switch to the "
"incremental search bar."
msgstr ""
"शक्तिसन्धानस्य दक्षिणभागे <inlinemediaobject><imageobject><imagedata fileref="
"\"configure-shortcuts-22.png\" format=\"PNG\"/></imageobject></"
"inlinemediaobject> बटनं नुदन्तु तथा च पट्टिकां प्रतिस्थापयन्तु वृद्धिशीलसन्धानपट्टिकायां "
"स्विच् कुर्वन्तु ।"

#. Tag: title
#: menus.docbook:519
#, no-c-format
msgid "The Selection Menu"
msgstr "चयनमेनू इति"

#. Tag: menuchoice
#: menus.docbook:523
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>A</keycap></keycombo> </"
"shortcut> <guimenu>Selection</guimenu> <guimenuitem>Select All</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>A</keycap></keycombo> </"
"shortcut> <guimenu>चयन</guimenu> <guimenuitem>सर्वं चिनोतु</guimenuitem>"

#. Tag: para
#: menus.docbook:531
#, no-c-format
msgid ""
"This will select the entire document. This could be very useful for copying "
"the entire file to another application."
msgstr ""
"एतेन सम्पूर्णं दस्तावेजं चिनोति । एतत् सम्पूर्णं सञ्चिकां अन्यस्मिन् अनुप्रयोगे प्रतिलिपिं कर्तुं अतीव "
"उपयोगी भवितुम् अर्हति ।"

#. Tag: menuchoice
#: menus.docbook:537
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>A</keycap></"
"keycombo> </shortcut> <guimenu>Selection</guimenu> <guimenuitem>Deselect</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>A</keycap></"
"keycombo> </shortcut> <guimenu>चयन</guimenu> <guimenuitem>अचयनं</guimenuitem>"

#. Tag: para
#: menus.docbook:545
#, no-c-format
msgid "Deselects the selected text in the editor if any."
msgstr "सम्पादके चयनितं पाठं यदि अस्ति तर्हि अचयनं करोति ।"

#. Tag: menuchoice
#: menus.docbook:550
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>B</keycap></"
"keycombo> </shortcut> <guimenu>Selection</guimenu> <guimenuitem>Block "
"Selection Mode</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>B</keycap></"
"keycombo> </shortcut> <guimenu>चयन</guimenu> <guimenuitem>अवरुद्धचयनविधिः</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:558
#, no-c-format
msgid ""
"Toggles Selection Mode. When the Selection Mode is <guilabel>BLOCK</"
"guilabel>, the status bar contains the string <guilabel>[BLOCK]</guilabel> "
"and you can make vertical selections, &eg; select column 5 to 10 in lines 9 "
"to 15."
msgstr ""
"चयनविधिं टॉगल करोति। यदा चयनविधिः <guilabel>BLOCK</guilabel> भवति तदा "
"स्थितिपट्टिकायां <guilabel>[BLOCK]</guilabel> इति स्ट्रिंग् भवति तथा च भवान् "
"ऊर्ध्वाधरचयनं कर्तुं शक्नोति, &eg; ९ तः १५ पर्यन्तं पङ्क्तौ ५ तः १० पर्यन्तं स्तम्भं चिनोतु ।"

#. Tag: menuchoice
#: menus.docbook:596
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>D</keycap></keycombo> </"
"shortcut> <guimenu>Selection</guimenu> <guimenuitem>Comment</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>D</keycap></keycombo> </"
"shortcut> <guimenu>चयन</guimenu> <guimenuitem>टिप्पणी</guimenuitem>"

#. Tag: para
#: menus.docbook:603
#, no-c-format
msgid ""
"This adds one space to the beginning of the line where the text cursor is "
"located or to the beginning of any selected lines."
msgstr ""
"एतेन रेखायाः आरम्भे यत्र पाठकर्सरः अस्ति तत्र अथवा कस्यापि चयनितपङ्क्तेः आरम्भे एकं स्थानं "
"योजयति ।"

#. Tag: menuchoice
#: menus.docbook:610
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>D</keycap></"
"keycombo> </shortcut> <guimenu>Selection</guimenu> <guimenuitem>Uncomment</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>D</keycap></"
"keycombo> </shortcut> <guimenu>चयन</guimenu> <guimenuitem>अटिप्पणी</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:617
#, no-c-format
msgid ""
"This removes one space (if any exist) from the beginning of the line where "
"the text cursor is located or from the beginning of any selected lines."
msgstr ""
"एतेन यत्र पाठकर्सरः स्थितः तस्य रेखायाः आरम्भात् अथवा कस्यापि चयनितपङ्क्तेः आरम्भात् एकं "
"स्थानं (यदि किमपि अस्ति) अपसारयति ।"

#. Tag: menuchoice
#: menus.docbook:623
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>J</keycap></keycombo> </"
"shortcut> <guimenu>Selection</guimenu> <guimenuitem>Join Lines</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>J</keycap></keycombo> </"
"shortcut> <guimenu>चयन</guimenu> <guimenuitem>पङ्क्तयः सम्मिलितः</guimenuitem>"

#. Tag: para
#: menus.docbook:630
#, no-c-format
msgid ""
"Joins the selected lines, or the current line and the line below with one "
"white space character as a separator. Leading/trailing white space on joined "
"lines is removed in the affected ends."
msgstr ""
"चयनितपङ्क्तयः, अथवा वर्तमानरेखां अधः रेखां च एकेन श्वेतस्थानवर्णेन विभाजकरूपेण संयोजयति । "
"संयोजितरेखासु अग्रणी/पश्चात् श्वेतस्थानं प्रभावितेषु अन्तेषु निष्कासितम् अस्ति।"

#. Tag: menuchoice
#: menus.docbook:636
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Alt;<keycap>U</keycap></"
"keycombo> </shortcut> <guimenu>Selection</guimenu> "
"<guimenuitem>Capitalization</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Alt;<keycap>U</keycap></"
"keycombo> </shortcut> <guimenu>चयन</guimenu> <guimenuitem>राजधानी</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:643
#, no-c-format
msgid "Capitalize the selected text or the current word."
msgstr "चयनितपाठस्य वर्तमानशब्दस्य वा दीर्घवर्णं कुर्वन्तु।"

#. Tag: menuchoice
#: menus.docbook:648
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>U</keycap></keycombo> </"
"shortcut> <guimenu>Selection</guimenu> <guimenuitem>Uppercase</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>U</keycap></keycombo> </"
"shortcut> <guimenu>चयन</guimenu> <guimenuitem>बृहत्</guimenuitem>"

#. Tag: para
#: menus.docbook:655
#, no-c-format
msgid "Put the selected text or the letter after the cursor in uppercase."
msgstr "चयनितं पाठं कर्सरस्य पश्चात् अक्षरं वा बृहत् अक्षरेण स्थापयन्तु ।"

#. Tag: menuchoice
#: menus.docbook:660
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>U</keycap></"
"keycombo> </shortcut> <guimenu>Selection</guimenu> <guimenuitem>Lowercase</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>U</keycap></"
"keycombo> </shortcut> <guimenu>चयन</guimenu> <guimenuitem>लघु अक्षर</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:667
#, no-c-format
msgid "Put the selected text or the letter after the cursor in lowercase."
msgstr "चयनितं पाठं वा कर्सरस्य पश्चात् अक्षरं लघुवर्णेन स्थापयन्तु ।"

#. Tag: menuchoice
#: menus.docbook:672
#, no-c-format
msgid ""
"<guimenu>Selection</guimenu> <guimenuitem>Clean Indentation</guimenuitem>"
msgstr "<guimenu>चयनम्</guimenu> <guimenuitem>इण्डेन्टेशनं स्वच्छं कुरुत</guimenuitem>"

#. Tag: para
#: menus.docbook:677
#, no-c-format
msgid ""
"This cleans the indentation for the current selection or for the line the "
"cursor is currently in. Cleaning the indentation ensures that all your "
"selected text follows the indentation mode you choose."
msgstr ""
"एतेन वर्तमानचयनस्य कृते अथवा कर्सरः वर्तमानकाले यस्मिन् रेखायां वर्तते तस्याः कृते इण्डेन्टेशनं "
"स्वच्छं भवति ।इण्डेन्टेशनं स्वच्छं कृत्वा सुनिश्चितं भवति यत् भवतः सर्वः चयनितः पाठः भवता "
"चयनितस्य इण्डेन्टेशन मोडस्य अनुसरणं करोति"

#. Tag: menuchoice
#: menus.docbook:684
#, no-c-format
msgid "<guimenu>Selection</guimenu> <guimenuitem>Format Indent</guimenuitem>"
msgstr "<guimenu>चयनं</guimenu> <guimenuitem>स्वरूपं इन्डेण्ट्</guimenuitem>"

#. Tag: para
#: menus.docbook:689
#, no-c-format
msgid ""
"Causes a realign of the current line or selected lines using the indentation "
"mode and indentation settings in the document."
msgstr ""
"दस्तावेजे इण्डेन्टेशन मोड् तथा इण्डेन्टेशन सेटिङ्ग्स् इत्येतयोः उपयोगेन वर्तमानरेखायाः अथवा "
"चयनितपङ्क्तयः पुनः संरेखणं जनयति ।"

#. Tag: menuchoice
#: menus.docbook:695
#, no-c-format
msgid "<guimenu>Selection</guimenu> <guimenuitem>Align On...</guimenuitem>"
msgstr "<guimenu>चयनं</guimenu> <guimenuitem>संरेखणं चालू...</guimenuitem>"

#. Tag: para
#: menus.docbook:700
#, no-c-format
msgid ""
"This command aligns lines in the selected block or whole document on the "
"column given by a regular expression that you will be prompted for."
msgstr ""
"एषः आदेशः नियमितव्यञ्जनेन दत्तस्य स्तम्भे चयनितखण्डे अथवा सम्पूर्णदस्तावेजस्य रेखाः संरेखयति यस्य "
"कृते भवान् प्रार्थितः भविष्यति ।"

#. Tag: para
#: menus.docbook:701
#, no-c-format
msgid ""
"If you give an empty pattern it will align on the first non-blank character "
"by default."
msgstr ""
"यदि भवान् रिक्तं प्रतिरूपं ददाति तर्हि पूर्वनिर्धारितरूपेण प्रथमे अरिक्तवर्णे संरेखयिष्यति ।"

#. Tag: para
#: menus.docbook:702
#, no-c-format
msgid "If the pattern has a capture it will indent on the captured match."
msgstr "यदि प्रतिरूपस्य ग्रहणं भवति तर्हि सः गृहीतमेलने इन्डेण्ट् करिष्यति ।"

#. Tag: emphasis
#: menus.docbook:703
#, no-c-format
msgid "Examples:"
msgstr "उदाहरणानि :"

#. Tag: para
#: menus.docbook:704
#, no-c-format
msgid ""
"With '<userinput>-</userinput>' it will insert spaces before the first '-' "
"of each lines to align them all on the same column."
msgstr ""
"'<userinput>-</userinput>' इत्यनेन प्रत्येकस्य पङ्क्तेः प्रथमस्य '-' इत्यस्य पुरतः "
"रिक्तस्थानानि निवेशयिष्यति यत् तान् सर्वान् एकस्मिन् स्तम्भे संरेखयिष्यति ।"

#. Tag: para
#: menus.docbook:705
#, no-c-format
msgid ""
"With '<userinput>alignon :\\\\s+(.)</userinput>' it will insert spaces "
"before the first non-blank character that occurs after a colon to align them "
"all on the same column."
msgstr ""
"'<userinput>alignon :\\\\s+(.)</userinput>' इत्यनेन सह एतत् सर्वान् एकस्मिन् स्तम्भे "
"संरेखयितुं कोलनस्य पश्चात् भवति प्रथमस्य अरिक्तवर्णस्य पूर्वं रिक्तस्थानानि निवेशयिष्यति ।"

#. Tag: menuchoice
#: menus.docbook:710
#, no-c-format
msgid "<guimenu>Selection</guimenu> <guimenuitem>Apply Word Wrap</guimenuitem>"
msgstr "<guimenu>चयन</guimenu> <guimenuitem>शब्दवेष्टनं प्रयोजयन्तु</guimenuitem>"

#. Tag: para
#: menus.docbook:714
#, no-c-format
msgid ""
"Apply static word wrapping on all the document. That means that a new line "
"of text will automatically start when the current line exceeds the length "
"specified by the <guilabel>Wrap words at</guilabel> option in the Editing "
"tab in <menuchoice> <guimenu>Settings</guimenu><guimenuitem>Configure "
"Editor...</guimenuitem></menuchoice> menu."
msgstr ""
"सर्वेषु दस्तावेजेषु स्थिरशब्दवेष्टनं प्रयोजयन्तु । तस्य अर्थः अस्ति यत् यदा वर्तमानपङ्क्तिः "
"<menuchoice> <guimenu>सेटिंग्स्</guimenu><guimenuitem इत्यस्मिन् सम्पादन ट्याब् मध्ये "
"<guilabel>Wrap words at</guilabel> विकल्पेन निर्दिष्टां दीर्घतां अतिक्रमति तदा पाठस्य "
"नूतना पङ्क्तिः स्वयमेव आरभ्यते >सम्पादकं विन्यस्यताम्...</guimenuitem></menuchoice> मेन्यू ।"

#. Tag: menuchoice
#: menus.docbook:723
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Alt;&Up;</keycombo> </shortcut> "
"<guimenu>Selection</guimenu> <guimenuitem>Add Caret above Cursor</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Alt;&Up;</keycombo> </shortcut> "
"<guimenu>चयन</guimenu> <guimenuitem>कर्सर</guimenuitem> इत्यस्य उपरि Caret योजयतु"

#. Tag: para
#: menus.docbook:730
#, no-c-format
msgid ""
"Adds another caret above the current cursor. The caret is placed in the line "
"directly above and in the same column as the current cursor."
msgstr ""
"वर्तमान कर्सरस्य उपरि अन्यं केरेट् योजयति । कैरेट् साक्षात् उपरि रेखायां वर्तमानकर्सरस्य "
"समानस्तम्भे च स्थाप्यते ।"

#. Tag: menuchoice
#: menus.docbook:735
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Alt;&Down;</keycombo> </"
"shortcut> <guimenu>Selection</guimenu> <guimenuitem>Add Caret below Cursor</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Alt;&Down;</keycombo> </"
"shortcut> <guimenu>चयन</guimenu> <guimenuitem>कर्सर</guimenuitem> इत्यस्य अधः "
"Caret योजयतु"

#. Tag: para
#: menus.docbook:742
#, no-c-format
msgid ""
"Adds another caret below the current cursor. The caret is placed in the line "
"directly above and in the same column as the current cursor."
msgstr ""
"वर्तमान कर्सरस्य अधः अन्यं कैरेट् योजयति । कैरेट् साक्षात् उपरि रेखायां वर्तमानकर्सरस्य "
"समानस्तम्भे च स्थाप्यते ।"

#. Tag: menuchoice
#: menus.docbook:747
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift;<keycap>I</keycap></"
"keycombo> </shortcut> <guimenu>Selection</guimenu> <guimenuitem>Add Cursors "
"to Line Ends</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift;<keycap>I</keycap></"
"keycombo> </shortcut> <guimenu>चयन</guimenu> <guimenuitem>रेखासमाप्तिषु कर्सरं "
"योजयतु</guimenuitem >"

#. Tag: para
#: menus.docbook:754
#, no-c-format
msgid "Adds a cursor to every currently selected line."
msgstr "वर्तमान चयनित प्रत्येकस्मिन् पङ्क्तौ कर्सरं योजयति ।"

#. Tag: menuchoice
#: menus.docbook:759
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt;<keycap>J</keycap></keycombo> </"
"shortcut> <guimenu>Selection</guimenu> <guimenuitem>Find and Select Next "
"Occurrence</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt;<keycap>J</keycap></keycombo> </"
"shortcut> <guimenu>चयन</guimenu> <guimenuitem>अनन्तरं घटनां अन्विष्य चिनोतु</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:766
#, no-c-format
msgid ""
"Finds the next occurrence of the word currently under the cursor, selects it "
"and adds a cursor."
msgstr "कर्सरस्य अधः वर्तमानं शब्दस्य अग्रिमम् आवृत्तिम् अन्विष्य तत् चित्वा कर्सरं योजयति ।"

#. Tag: menuchoice
#: menus.docbook:771
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Alt;&Shift;<keycap>J</keycap></"
"keycombo> </shortcut> <guimenu>Selection</guimenu> <guimenuitem>Find and "
"Select All Occurrences</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Alt;&Shift;<keycap>J</keycap></"
"keycombo> </shortcut> <guimenu>चयन</guimenu> <guimenuitem>सर्वघटनानि अन्वेष्टुम् "
"चयनं च< /गुइमेनुआइटम>"

#. Tag: para
#: menus.docbook:778
#, no-c-format
msgid ""
"Finds all occurrences of the word currently under the cursor, selects them "
"and adds a cursor for each of them."
msgstr ""
"कर्सरस्य अधः वर्तमानकाले शब्दस्य सर्वाणि आवृत्तयः अन्विष्य तान् चिनोति, तेषु प्रत्येकस्य कृते "
"कर्सरं योजयति च ।"

#. Tag: title
#: menus.docbook:788
#, no-c-format
msgid "The View Menu"
msgstr "दृश्य मेनू इति"

#. Tag: menuchoice
#: menus.docbook:793
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>+</keycap></keycombo> </"
"shortcut> <guimenu>View</guimenu> <guimenuitem>Enlarge Font</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>+</keycap></keycombo> </"
"shortcut> <guimenu>दृश्य</guimenu> <guimenuitem>फॉन्टं विस्तारयतु</guimenuitem>"

#. Tag: para
#: menus.docbook:800
#, no-c-format
msgid "This increases the display font size."
msgstr "एतेन प्रदर्शनस्य फ़ॉन्ट् आकारः वर्धते ।"

#. Tag: menuchoice
#: menus.docbook:804
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>-</keycap></keycombo> </"
"shortcut> <guimenu>View</guimenu> <guimenuitem>Shrink Font</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>-</keycap></keycombo> </"
"shortcut> <guimenu>दृश्य</guimenu> <guimenuitem>फॉन्टं संकुचितं</guimenuitem>"

#. Tag: para
#: menus.docbook:811
#, no-c-format
msgid "This decreases the display font size."
msgstr "एतेन प्रदर्शनस्य फ़ॉन्ट् आकारः न्यूनीकरोति ।"

#. Tag: menuchoice
#: menus.docbook:815
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"><keycap>F10</keycap></keycombo> </"
"shortcut> <guimenu>View</guimenu> <guisubmenu>Word Wrap</guisubmenu> "
"<guimenuitem>Dynamic Word Wrap</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"><keycap>F10</keycap></keycombo> </"
"shortcut> <guimenu>दृश्य</guimenu> <guisubmenu>शब्दवेष्टनम्</guisubmenu> "
"<guimenuitem>गतिशीलशब्दवेष्टनम् </guimenuitem> इति"

#. Tag: para
#: menus.docbook:823
#, no-c-format
msgid ""
"Toggles dynamic word wrap in the current view. Dynamic word wrap makes all "
"the text in a view visible without the need for horizontal scrolling by "
"rendering one actual line on more visual lines as needed."
msgstr ""
"वर्तमानदृश्ये गतिशीलशब्दवेष्टनं टॉगल करोति । गतिशीलशब्दवेष्टनम् आवश्यकतानुसारं अधिकदृश्यरेखासु "
"एकां वास्तविकपङ्क्तिं प्रतिपादयित्वा क्षैतिजस्क्रॉलस्य आवश्यकतां विना दृश्ये सर्वं पाठं दृश्यमानं "
"करोति ।"

#. Tag: menuchoice
#: menus.docbook:830
#, no-c-format
msgid ""
"<guimenu>View</guimenu> <guisubmenu>Word Wrap</guisubmenu> "
"<guisubmenu>Dynamic Word Wrap Indicators</guisubmenu>"
msgstr ""
"<guimenu>दृश्य</guimenu> <guisubmenu>शब्दवेष्टनम्</guisubmenu> "
"<guisubmenu>गतिशीलशब्दवेष्टनसूचकाः</guisubmenu>"

#. Tag: para
#: menus.docbook:836
#, no-c-format
msgid ""
"Choose when and how the dynamic word wrap indicators should be displayed. "
"This is only available if the <guilabel>Dynamic Word Wrap</guilabel> option "
"is checked."
msgstr ""
"गतिशीलशब्दवेष्टनसूचकाः कदा कथं च प्रदर्शितव्याः इति चिनोतु । एतत् केवलं तदा एव उपलब्धं यदा "
"<guilabel>Dynamic Word Wrap</guilabel> विकल्पः परीक्षितः अस्ति ।"

#. Tag: menuchoice
#: menus.docbook:843
#, no-c-format
msgid ""
"<guimenu>View</guimenu> <guisubmenu>Word Wrap</guisubmenu> <guimenuitem>Show "
"Static Word Wrap Marker</guimenuitem>"
msgstr ""
"<guimenu>दृश्य</guimenu> <guisubmenu>शब्दवेष्टनम्</guisubmenu> "
"<guimenuitem>स्थिरशब्दवेष्टनचिह्नं दर्शयतु</guimenuitem>"

#. Tag: para
#: menus.docbook:849
#, no-c-format
msgid ""
"If this option is checked, a vertical line will be drawn at the word wrap "
"column as defined in the <menuchoice> <guimenu>Settings</guimenu> "
"<guimenuitem>Configure Editor...</guimenuitem></menuchoice> in the Editing "
"tab. Please note that the word wrap marker is only drawn if you use a fixed "
"pitch font."
msgstr ""
"यदि एषः विकल्पः परीक्षितः अस्ति तर्हि <menuchoice> <guimenu>सेटिंग्स्</guimenu> "
"<guimenuitem>सम्पादकं विन्यस्तं कुर्वन्तु...</guimenuitem></menuchoice> इत्यत्र "
"परिभाषितवत् शब्दवेष्टनस्तम्भे लम्बरेखा आकृष्यते सम्पादन ट्याब्। कृपया ज्ञातव्यं यत् word wrap "
"marker केवलं तदा एव आकृष्यते यदा भवान् fixed pitch font इत्यस्य उपयोगं करोति ।"

#. Tag: menuchoice
#: menus.docbook:859
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"><keycap>F6</keycap></keycombo> </"
"shortcut> <guimenu>View</guimenu> <guisubmenu>Borders</guisubmenu> "
"<guimenuitem>Show Icon Border</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"><keycap>F6</keycap></keycombo> </"
"shortcut> <guimenu>दृश्य</guimenu> <guisubmenu>सीमाः</guisubmenu> "
"<guimenuitem>चिह्नसीमा दर्शयतु< /गुइमेनुआइटम>"

#. Tag: para
#: menus.docbook:868
#, no-c-format
msgid ""
"This is a toggle item. Setting it on checked will make the Icon Border "
"visible in the left side of the active editor, and vice versa. The Icon "
"Border indicates the positions of the marked lines in the editor."
msgstr ""
"एतत् टॉगल-वस्तु अस्ति । चेक्ड् इत्यत्र सेट् करणेन सक्रियसम्पादकस्य वामभागे Icon Border "
"दृश्यमानं भविष्यति, तद्विपरीतम् अपि । Icon Border सम्पादके चिह्नितानां रेखानां स्थानानि "
"सूचयति ।"

#. Tag: menuchoice
#: menus.docbook:875
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"><keycap>F11</keycap></keycombo> </"
"shortcut> <guimenu>View</guimenu> <guisubmenu>Borders</guisubmenu> "
"<guimenuitem>Show Line Numbers</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"><keycap>F11</keycap></keycombo> </"
"shortcut> <guimenu>दृश्य</guimenu> <guisubmenu>सीमाः</guisubmenu> "
"<guimenuitem>रेखासङ्ख्याः दर्शयतु< /गुइमेनुआइटम>"

#. Tag: para
#: menus.docbook:884
#, no-c-format
msgid ""
"This is a toggle Item. Setting it on checked will make a pane displaying the "
"line numbers of the document visible in the left border of the active "
"editor, and vice versa."
msgstr ""
"इदं toggle Item अस्ति। चेक्ड् इत्यत्र सेट् करणेन सक्रियसम्पादकस्य वामसीमायां दस्तावेजस्य "
"रेखासङ्ख्याः प्रदर्शयन्तं फलकं दृश्यते, तद्विपरीतम् अपि ।"

#. Tag: menuchoice
#: menus.docbook:891
#, no-c-format
msgid ""
"<guimenu>View</guimenu> <guisubmenu>Borders</guisubmenu> <guimenuitem>Show "
"Scrollbar Marks</guimenuitem>"
msgstr ""
"<guimenu>दृश्य</guimenu> <guisubmenu>सीमाः</guisubmenu> "
"<guimenuitem>स्क्रॉलबारचिह्नानि दर्शयतु</guimenuitem>"

#. Tag: para
#: menus.docbook:897
#, no-c-format
msgid ""
"If this option is checked, the view will show marks on the vertical "
"scrollbar. The marks are equivalent to the marks on the <link linkend=\"view-"
"show-icon-border\">Icon Border</link>."
msgstr ""
"यदि एषः विकल्पः परीक्षितः अस्ति तर्हि दृश्यं ऊर्ध्वाधरस्क्रॉलबारस्य उपरि चिह्नानि "
"दर्शयिष्यति । चिह्नानि तुल्यानि भवन्ति यत्...<link linkend=\"view-show-icon-border"
"\"> चिह्न सीमा</link> ."

#. Tag: menuchoice
#: menus.docbook:904
#, no-c-format
msgid ""
"<guimenu>View</guimenu> <guisubmenu>Borders</guisubmenu> <guimenuitem>Show "
"Scrollbar Mini-Map</guimenuitem>"
msgstr ""
"<guimenu>दृश्य</guimenu> <guisubmenu>सीमा</guisubmenu> <guimenuitem>स्क्रॉलबार "
"लघु-नक्शा दर्शयतु</guimenuitem>"

#. Tag: para
#: menus.docbook:909
#, no-c-format
msgid ""
"This will replace the scrollbar with a visualization of the current "
"document. For more information on the scrollbar minimap, see <xref linkend="
"\"kate-part-scrollbar-minimap\"/>."
msgstr ""
"एतेन स्क्रॉलबारस्य स्थाने वर्तमानदस्तावेजस्य दृश्यीकरणं भविष्यति । स्क्रॉलबार-मिनिमैप् विषये "
"अधिकविवरणार्थं <xref linkend=\"kate-part-scrollbar-minimap\"/> पश्यन्तु ।"

#. Tag: menuchoice
#: menus.docbook:915
#, no-c-format
msgid "<guimenu>View</guimenu> <guimenuitem>Code Folding</guimenuitem>"
msgstr "<guimenu>दृश्य</guimenu> <guimenuitem>सङ्केत तन्तु</guimenuitem>"

#. Tag: para
#: menus.docbook:919
#, no-c-format
msgid ""
"These options pertain to <ulink url=\"help:/katepart/advanced-editing-tools-"
"code-folding.html\">code folding</ulink>:"
msgstr ""
"एते विकल्पाः <ulink url=\"help:/katepart/advanced-editing-tools-code-folding."
"html\">कोड् तन्तु</ulink> इत्यस्य सम्बन्धिनो भवन्ति ।"

#. Tag: menuchoice
#: menus.docbook:925
#, no-c-format
msgid ""
"<guimenu>View</guimenu> <guisubmenu>Borders</guisubmenu> <guisubmenu>Code "
"Folding</guisubmenu> <guimenuitem>Show Folding Markers</guimenuitem>"
msgstr ""
"<guimenu>दृश्य</guimenu> <guisubmenu>सीमाः</guisubmenu> <guisubmenu>कोड् तन्तु</"
"guisubmenu> <guimenuitem>तन्तुचिह्नं दर्शयतु</guimenuitem>"

#. Tag: para
#: menus.docbook:931
#, no-c-format
msgid ""
"Toggles the display of the folding marker pane in the left side of the view."
msgstr "दृश्यस्य वामभागे तन्तुचिह्नफलकस्य प्रदर्शनं टॉगलं करोति ।"

#. Tag: menuchoice
#: menus.docbook:936
#, no-c-format
msgid ""
"<guimenu>View</guimenu> <guisubmenu>Code Folding</guisubmenu> "
"<guimenuitem>Fold Current Node</guimenuitem>"
msgstr ""
"<guimenu>दृश्य</guimenu> <guisubmenu>कोड् तन्तु</guisubmenu> <guimenuitem>वर्तमानं "
"नोडं तन्तु</guimenuitem>"

#. Tag: para
#: menus.docbook:941
#, no-c-format
msgid "Collapse the region that contains the cursor."
msgstr "यस्मिन् प्रदेशे कर्सरः अस्ति तत् संकुचितं कुर्वन्तु ।"

#. Tag: menuchoice
#: menus.docbook:945
#, no-c-format
msgid ""
"<guimenu>View</guimenu> <guisubmenu>Code Folding</guisubmenu> "
"<guimenuitem>Unfold Current Node</guimenuitem>"
msgstr ""
"<guimenu>दृश्य</guimenu> <guisubmenu>कोड् तन्तु</guisubmenu> <guimenuitem>वर्तमानं "
"नोड् अनफोल्ड्</guimenuitem>"

#. Tag: para
#: menus.docbook:950
#, no-c-format
msgid "Expand the region that contains the cursor."
msgstr "यस्मिन् प्रदेशे कर्सरः अस्ति तस्य विस्तारं कुर्वन्तु ।"

#. Tag: menuchoice
#: menus.docbook:954
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>-</keycap></"
"keycombo> </shortcut> <guimenu>View</guimenu> <guisubmenu>Code Folding</"
"guisubmenu> <guimenuitem>Fold Toplevel Nodes</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>-</keycap></"
"keycombo> </shortcut> <guimenu>दृश्य</guimenu> <guisubmenu>कोड तन्तु</"
"guisubmenu> <guimenuitem >शीर्षस्तरस्य नोड्स</guimenuitem>ं गुठयन्तु"

#. Tag: para
#: menus.docbook:962
#, no-c-format
msgid ""
"Collapse all toplevel regions in the document. Click on the right pointing "
"triangle to expand all toplevel regions."
msgstr ""
"दस्तावेजे सर्वाणि शीर्षस्तरीयक्षेत्राणि संकुचयन्तु । सर्वेषां शीर्षस्तरीयक्षेत्राणां विस्तारार्थं "
"दक्षिणसूचकत्रिकोणे नुदन्तु ।"

#. Tag: menuchoice
#: menus.docbook:967
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>+</keycap></"
"keycombo> </shortcut> <guimenu>View</guimenu> <guisubmenu>Code Folding</"
"guisubmenu> <guimenuitem>Unfold Toplevel Nodes</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>+</keycap></"
"keycombo> </shortcut> <guimenu>दृश्य</guimenu> <guisubmenu>कोड तन्तु</"
"guisubmenu> <guimenuitem >शीर्षस्तरीयनोड्स</guimenuitem> अनफोल्ड् कुर्वन्तु"

#. Tag: para
#: menus.docbook:975
#, no-c-format
msgid "Expand all toplevel regions in the document."
msgstr "दस्तावेजे सर्वाणि शीर्षस्तरीयक्षेत्राणि विस्तारयन्तु ।"

#. Tag: guimenuitem
#: menus.docbook:984
#, no-c-format
msgid "Show Non-Printable Spaces"
msgstr "अमुद्रणयोग्यस्थानानि दर्शयतु"

#. Tag: para
#: menus.docbook:986
#, no-c-format
msgid "Show/hide bounding box around non-printable spaces."
msgstr "अमुद्रणयोग्यस्थानानां परितः बाउण्डिंग् पेटी दर्शयतु/गोपयतु।"

#. Tag: title
#: menus.docbook:995
#, no-c-format
msgid "The Go Menu"
msgstr "गो मेनू इति"

#. Tag: menuchoice
#: menus.docbook:999
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>G</keycap></keycombo> </"
"shortcut> <guimenu>Go</guimenu> <guimenuitem>Go to Line...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>G</keycap></keycombo> </"
"shortcut> <guimenu>गच्छ</guimenu> <guimenuitem>पङ्क्तिं गच्छतु...</guimenuitem>"

#. Tag: para
#: menus.docbook:1007
#, no-c-format
msgid ""
"This opens the goto line bar at the bottom of the window which is used to "
"have the cursor jump to a particular line (specified by number) in the "
"document. The line number may be entered directly into the text box or "
"graphically by clicking on the up or down arrow spin controls at the side of "
"the text box. The little up arrow will increase the line number and the down "
"arrow decrease it. Close the bar with a click on the button with an icon on "
"the left side of the bar."
msgstr ""
"एतेन विण्डो इत्यस्य अधः goto line bar उद्घाट्यते यस्य उपयोगः दस्तावेजे कस्मिंश्चित् रेखाविशेषे "
"(सङ्ख्याद्वारा निर्दिष्टे) कर्सरः कूर्दितुं भवति । रेखासङ्ख्या प्रत्यक्षतया पाठपेटिकायां अथवा "
"पाठपेटिकायाः पार्श्वे उपरि अधः वा बाणस्पिननियन्त्रणानि क्लिक् कृत्वा चित्रात्मकरूपेण प्रविष्टुं "
"शक्यते । अल्पः उपरि बाणः रेखासङ्ख्यां वर्धयिष्यति, अधः बाणः तस्याः न्यूनीकरणं करिष्यति । "
"पट्टिकायाः वामभागे चिह्नयुक्ते बटन् क्लिक् कृत्वा पट्टिकां पिधायताम् ।"

#. Tag: menuchoice
#: menus.docbook:1019
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>E</keycap></keycombo> </"
"shortcut> <guimenu>Go</guimenu> <guimenuitem>Go to Previous Editing Line</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>E</keycap></keycombo> </"
"shortcut> <guimenu>गच्छ</guimenu> <guimenuitem>पूर्वसम्पादनपङ्क्तौ गच्छतु</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:1027
#, no-c-format
msgid ""
"This action jumps the previous editing line in the <link linkend="
"\"multicursor-modifier-configure\">multicursor configuration</link>."
msgstr ""
"एषा क्रिया पूर्वसम्पादनपङ्क्तिं कूर्दति<link linkend=\"multicursor-modifier-configure"
"\"> बहुकुर्सर विन्यास</link> ."

#. Tag: menuchoice
#: menus.docbook:1033
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>E</keycap></"
"keycombo> </shortcut> <guimenu>Go</guimenu> <guimenuitem>Go to Next Editing "
"Line</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>E</keycap></"
"keycombo> </shortcut> <guimenu>गच्छ</guimenu> <guimenuitem>अग्रे सम्पादनपङ्क्तौ "
"गच्छतु</guimenuitem >"

#. Tag: para
#: menus.docbook:1041
#, no-c-format
msgid ""
"This action jumps the next editing line in the <link linkend=\"multicursor-"
"modifier-configure\">multicursor configuration</link>."
msgstr ""
"एषा क्रिया अग्रिमसम्पादनपङ्क्तिं कूर्दति<link linkend=\"multicursor-modifier-"
"configure\"> बहुकुर्सर विन्यास</link> ."

#. Tag: menuchoice
#: menus.docbook:1047
#, no-c-format
msgid ""
"<guimenu>Go</guimenu> <guimenuitem>Go to Previous Modified Line</guimenuitem>"
msgstr "<guimenu>गच्छ</guimenu> <guimenuitem>पूर्वसंशोधितपङ्क्तौ गच्छतु</guimenuitem>"

#. Tag: para
#: menus.docbook:1052
#, no-c-format
msgid ""
"Lines that were changed since opening the file are called modified lines. "
"This action jumps the previous modified line."
msgstr ""
"सञ्चिकायाः उद्घाटनात् परं ये पङ्क्तयः परिवर्तिताः आसन् ते परिवर्तिताः रेखाः इति उच्यन्ते । "
"एषा क्रिया पूर्वपरिवर्तितरेखां कूर्दति ।"

#. Tag: menuchoice
#: menus.docbook:1058
#, no-c-format
msgid ""
"<guimenu>Go</guimenu> <guimenuitem>Go to Next Modified Line</guimenuitem>"
msgstr ""
"<guimenu>गच्छ</guimenu> <guimenuitem>अग्रे परिवर्तितपङ्क्तिं गच्छतु</guimenuitem>"

#. Tag: para
#: menus.docbook:1063
#, no-c-format
msgid ""
"Lines that were changed since opening the file are called modified lines. "
"This action jumps the next modified line."
msgstr ""
"सञ्चिकायाः उद्घाटनात् परं ये पङ्क्तयः परिवर्तिताः आसन् ते परिवर्तिताः रेखाः इति उच्यन्ते । "
"एषा क्रिया अग्रिमां परिवर्तितां रेखां कूर्दति ।"

#. Tag: menuchoice
#: menus.docbook:1069
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>6</keycap></keycombo> </"
"shortcut> <guimenu>Go</guimenu> <guimenuitem>Go to Matching Bracket</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>6</keycap></keycombo> </"
"shortcut> <guimenu>गच्छ</guimenu> <guimenuitem>मेलन कोष्ठकं</guimenuitem> गच्छतु"

#. Tag: para
#: menus.docbook:1077
#, no-c-format
msgid "Move the cursor to the associated opening or closing bracket."
msgstr "कर्सरं सम्बद्धं उद्घाटनसमापनकोष्ठकं प्रति चालयन्तु ।"

#. Tag: menuchoice
#: menus.docbook:1082
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>6</keycap></"
"keycombo> </shortcut> <guimenu>Go</guimenu> <guimenuitem>Select to Matching "
"Bracket</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>6</keycap></"
"keycombo> </shortcut> <guimenu>गच्छ</guimenu> <guimenuitem>मेलन कोष्ठकं</"
"guimenuitem> इति चिनोतु"

#. Tag: para
#: menus.docbook:1090
#, no-c-format
msgid "Selects the text between associated opening and closing brackets."
msgstr "सम्बद्धानां उद्घाटनसमापनकोष्ठकानां मध्ये पाठं चिनोति ।"

#. Tag: menuchoice
#: menus.docbook:1095
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>6</keycap></"
"keycombo> </shortcut> <guimenu>Go</guimenu> <guisubmenu>Bookmarks</"
"guisubmenu>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>6</keycap></"
"keycombo> </shortcut> <guimenu>गच्छ</guimenu> <guisubmenu>पुस्तकचिह्नानि</"
"guisubmenu>"

#. Tag: para
#: menus.docbook:1103
#, no-c-format
msgid ""
"Below the entries described here, one entry for each bookmark in the active "
"document will be available. The text will be the first few words of the "
"marked line. Choose an item to move the cursor to the start of that line. "
"The editor will scroll as necessary to make that line visible."
msgstr ""
"अत्र वर्णितप्रविष्टीनां अधः सक्रियदस्तावेजे प्रत्येकं पुस्तकचिह्नस्य कृते एकः प्रविष्टिः उपलभ्यते । "
"पाठः चिह्नितरेखायाः प्रथमाः कतिचन शब्दाः भविष्यन्ति । तस्याः रेखायाः आरम्भे कर्सरं "
"स्थापयितुं एकं द्रव्यं चिनोतु । सम्पादकः तां पङ्क्तिं दृश्यमानं कर्तुं यथावश्यं स्क्रॉल करिष्यति ।"

#. Tag: menuchoice
#: menus.docbook:1112
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>B</keycap></keycombo> </"
"shortcut> <guimenu>Go</guimenu> <guisubmenu>Bookmarks</guisubmenu> "
"<guimenuitem>Set Bookmark</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>B</keycap></keycombo> </"
"shortcut> <guimenu>गच्छ</guimenu> <guisubmenu>पुस्तकचिह्नानि</guisubmenu> "
"<guimenuitem>पुस्तकचिह्नं सेट् कुर्वन्तु </guimenuitem> इति"

#. Tag: para
#: menus.docbook:1121
#, no-c-format
msgid ""
"Sets or removes a bookmark in the current line of the active document. (If "
"it's there, it is removed, otherwise one is set.)"
msgstr ""
"सक्रियदस्तावेजस्य वर्तमानपङ्क्तौ पुस्तकचिह्नं सेट् करोति अथवा निष्कासयति । (यदि तत्र अस्ति "
"तर्हि निष्कासितम् अन्यथा एकः सेट् भवति।)"

#. Tag: menuchoice
#: menus.docbook:1127
#, no-c-format
msgid ""
"<guimenu>Go</guimenu> <guisubmenu>Bookmarks</guisubmenu> <guimenuitem>Clear "
"All Bookmarks</guimenuitem>"
msgstr ""
"<guimenu>गच्छ</guimenu> <guisubmenu>पुस्तकचिह्नानि</guisubmenu> <guimenuitem>सर्वं "
"पुस्तकचिह्नानि स्वच्छं कुर्वन्तु</guimenuitem>"

#. Tag: para
#: menus.docbook:1133
#, no-c-format
msgid ""
"This command will remove all the markers from the document as well as the "
"list of markers which is appended at the bottom of this menu item."
msgstr ""
"एषः आदेशः दस्तावेजात् सर्वाणि चिह्नानि अपि च चिह्नानां सूचीं निष्कासयिष्यति यत् अस्य मेनू-"
"वस्तूनाम् अधः संलग्नम् अस्ति ।"

#. Tag: menuchoice
#: menus.docbook:1141
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt;&PgUp;</keycombo> </shortcut> "
"<guimenu>Go</guimenu> <guisubmenu>Bookmarks</guisubmenu> "
"<guimenuitem>Previous</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt;&PgUp;</keycombo> </shortcut> "
"<guimenu>गच्छ</guimenu> <guisubmenu>पुस्तकचिह्नानि</guisubmenu> "
"<guimenuitem>पूर्वं</guimenuitem>"

#. Tag: para
#: menus.docbook:1149
#, no-c-format
msgid ""
"This will move the cursor to beginning of the first above line with a "
"bookmark. The menuitem text will include the line number and the first piece "
"of text on the line. This item is only available when there is a bookmark in "
"a line above the cursor."
msgstr ""
"एतेन कर्सरः बुकमार्केन सह प्रथमा उपरि रेखायाः आरम्भं प्रति गमिष्यति । menuitem पाठः "
"रेखासङ्ख्यां रेखायां प्रथमपाठखण्डं च समाविष्टं करिष्यति । एतत् द्रव्यं तदा एव उपलभ्यते यदा "
"कर्सरस्य उपरि रेखायां पुस्तकचिह्नं भवति ।"

#. Tag: menuchoice
#: menus.docbook:1156
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt;&PgDn;</keycombo> </shortcut> "
"<guimenu>Go</guimenu> <guisubmenu>Bookmarks</guisubmenu> <guimenuitem>Next</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt;&PgDn;</keycombo> </shortcut> "
"<guimenu>गच्छ</guimenu> <guisubmenu>पुस्तकचिह्नानि</guisubmenu> "
"<guimenuitem>अनन्तरं</guimenuitem>"

#. Tag: para
#: menus.docbook:1164
#, no-c-format
msgid ""
"This will move the cursor to beginning of the next line with a bookmark. The "
"menuitem text will include the line number and the first piece of text on "
"the line. This item is only available when there is a bookmark in a line "
"below the cursor."
msgstr ""
"एतेन कर्सरः पुस्तकचिह्नसहितं अग्रिमपङ्क्तौ आरम्भं प्रति गमिष्यति । menuitem पाठः रेखासङ्ख्यां "
"रेखायां प्रथमपाठखण्डं च समाविष्टं करिष्यति । एतत् द्रव्यं तदा एव उपलभ्यते यदा कर्सरस्य अधः "
"रेखायां पुस्तकचिह्नं भवति ।"

#. Tag: title
#: menus.docbook:1176
#, no-c-format
msgid "The Tools Menu"
msgstr "Tools Menu इति"

#. Tag: menuchoice
#: menus.docbook:1181
#, no-c-format
msgid "<guimenu>Tools</guimenu> <guisubmenu>Mode</guisubmenu>"
msgstr "<guimenu>उपकरणं</guimenu> <highsubmenu>मोड्</highsubmenu>"

#. Tag: para
#: menus.docbook:1186
#, no-c-format
msgid ""
"Choose the filetype scheme you prefer for the active document. This "
"overwrites the global filetype mode set in <menuchoice> <guimenu>Settings</"
"guimenu><guimenuitem>Configure Editor...</guimenuitem></menuchoice> in the "
"Filetypes tab for your current document only."
msgstr ""
"सक्रियदस्तावेजस्य कृते भवता इष्टं सञ्चिकाप्रकारयोजनां चिनोतु । एतेन केवलं भवतः "
"वर्तमानदस्तावेजस्य कृते Filetypes ट्याब् मध्ये <menuchoice> <guimenu>सेटिंग्स्</"
"guimenu><guimenuitem>Configure Editor...</guimenuitem></menuchoice> इत्यस्मिन् "
"सेट् कृतं वैश्विकं सञ्चिकाप्रकारं अधिलिखति ।"

#. Tag: menuchoice
#: menus.docbook:1194
#, no-c-format
msgid "<guimenu>Tools</guimenu> <guisubmenu>Highlighting</guisubmenu>"
msgstr "<guimenu>उपकरणं</guimenu> <guisubmenu>प्रकाशनम्</guisubmenu>"

#. Tag: para
#: menus.docbook:1199
#, no-c-format
msgid ""
"Choose the Highlighting scheme you prefer for the active document. This "
"overwrites the global highlighting mode set in <menuchoice> "
"<guimenu>Settings</guimenu><guimenuitem>Configure Editor...</guimenuitem> </"
"menuchoice> for your current document only."
msgstr ""
"सक्रियदस्तावेजस्य कृते भवन्तः इष्टां Highlighting योजनां चिनोतु । एतेन केवलं भवतः "
"वर्तमानदस्तावेजस्य कृते <menuchoice> <guimenu>सेटिंग्स्</guimenu><guimenuitem>सम्पादकं "
"विन्यस्तं कुर्वन्तु...</guimenuitem> </menuchoice> इत्यत्र सेट् कृतं वैश्विकं हाइलाइटिङ्ग् मोड् "
"अधिलिखति ।"

#. Tag: menuchoice
#: menus.docbook:1207
#, no-c-format
msgid "<guimenu>Tools</guimenu> <guisubmenu>Indentation</guisubmenu>"
msgstr "<guimenu>उपकरणं</guimenu> <guisubmenu>इण्डेन्टेशन</guisubmenu>"

#. Tag: para
#: menus.docbook:1212
#, no-c-format
msgid ""
"Choose the style of indentation you want for your active document. This "
"overwrites the global indentation mode set in <menuchoice> "
"<guimenu>Settings</guimenu><guimenuitem>Configure Editor...</guimenuitem> </"
"menuchoice> for your current document only."
msgstr ""
"स्वस्य सक्रियदस्तावेजस्य कृते इच्छितं इण्डेन्टेशनशैलीं चिनोतु । एतेन केवलं भवतः वर्तमानदस्तावेजस्य "
"कृते <menuchoice> <guimenu>सेटिंग्स्</guimenu><guimenuitem>सम्पादकं विन्यस्तं कुर्वन्तु...</"
"guimenuitem> </menuchoice> इत्यत्र सेट् कृतं वैश्विकं इण्डेन्टेशन मोड् अधिलिखति ।"

#. Tag: menuchoice
#: menus.docbook:1220
#, no-c-format
msgid "<guimenu>Tools</guimenu> <guisubmenu>Encoding</guisubmenu>"
msgstr "<guimenu>उपकरणं</guimenu> <guisubmenu>एन्कोडिंग्</guisubmenu>"

#. Tag: para
#: menus.docbook:1225
#, no-c-format
msgid ""
"You can overwrite the default encoding set in <menuchoice> "
"<guimenu>Settings</guimenu><guimenuitem>Configure Editor...</guimenuitem> </"
"menuchoice> in the <guilabel>Open/Save</guilabel> page to set a different "
"encoding for your current document. The encoding you set here will be only "
"valid for your current document."
msgstr ""
"सेट् कर्तुं <guilabel>उद्घाटन/रक्षतु</guilabel> पृष्ठे <menuchoice> <guimenu>सेटिंग्स्</"
"guimenu><guimenuitem>सम्पादकं विन्यस्तं कुर्वन्तु...</guimenuitem> </menuchoice> "
"इत्यत्र पूर्वनिर्धारितं एन्कोडिंग् सेट् अधिलेखयितुं शक्नुवन्ति भवतः वर्तमानदस्तावेजस्य कृते भिन्नं "
"एन्कोडिंग् । भवता अत्र सेट् कृतं एन्कोडिंग् केवलं भवतः वर्तमानदस्तावेजस्य कृते मान्यं भविष्यति ।"

#. Tag: menuchoice
#: menus.docbook:1234
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu> <guisubmenu>Add Byte Mark Order (BOM)</guisubmenu>"
msgstr ""
"<guimenu>उपकरणं</guimenu> <guisubmenu>बाइट् चिह्नक्रमं (BOM) योजयतु</guisubmenu>"

#. Tag: para
#: menus.docbook:1239
#, no-c-format
msgid ""
"Checking this action you can explicitly add a byte order mark for unicode "
"encoded documents. The byte order mark (BOM) is a Unicode character used to "
"signal the endianness (byte order) of a text file or stream, for more "
"information see <ulink url=\"https://en.wikipedia.org/wiki/Byte_order_mark"
"\">Byte Order Mark</ulink>."
msgstr ""
"एतस्य क्रियायाः जाँचं कृत्वा भवान् यूनिकोड एन्कोडेड् दस्तावेजानां कृते स्पष्टतया बाइट् क्रमचिह्नं "
"योजयितुं शक्नोति । बाइट् क्रमचिह्नम् (BOM) एकः यूनिकोड् वर्णः अस्ति यस्य उपयोगः "
"पाठसञ्चिकायाः अथवा धारायाः एण्डियननेस् (बाइट् क्रमः) संकेतयितुं भवति, अधिकसूचनार्थं "
"<ulink url=\"https://en.wikipedia.org/wiki/Byte_order_mark\" इति पश्यन्तु । "
">बाइटक्रमचिह्न</ulink>।"

#. Tag: menuchoice
#: menus.docbook:1247
#, no-c-format
msgid "<guimenu>Tools</guimenu> <guisubmenu>End of Line</guisubmenu>"
msgstr "<guimenu>उपकरणं</guimenu> <guisubmenu>पङ्क्तिसमाप्तिः</guisubmenu>"

#. Tag: para
#: menus.docbook:1252
#, no-c-format
msgid ""
"Choose your preferred end of line mode for your active document. This "
"overwrites the global end of line mode set in <menuchoice> "
"<guimenu>Settings</guimenu><guimenuitem>Configure Editor...</guimenuitem> </"
"menuchoice> for your current document only."
msgstr ""
"स्वस्य सक्रियदस्तावेजस्य कृते भवतः इष्टं रेखा-अन्तं चिनोतु । एतेन केवलं भवतः वर्तमानदस्तावेजस्य "
"कृते <menuchoice> <guimenu>सेटिंग्स्</guimenu><guimenuitem>सम्पादकं विन्यस्तं कुर्वन्तु...</"
"guimenuitem> </menuchoice> इत्यत्र सेट् कृतं वैश्विकं रेखा मोडं अधिलिखति ।"

#. Tag: menuchoice
#: menus.docbook:1260
#, no-c-format
msgid "<guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu>"
msgstr "<guimenu>उपकरणं</guimenu> <guisubmenu>स्क्रिप्ट्</guisubmenu>"

#. Tag: para
#: menus.docbook:1265
#, no-c-format
msgid ""
"This submenu contains a list of all scripted actions. The list can easily be "
"modified by <link linkend=\"dev-scripting-command-line\">writing your own "
"scripts</link>. This way, &katepart; can be extended with user-defined tools."
msgstr ""
"अस्मिन् उपमेनूमध्ये सर्वेषां स्क्रिप्ट् कृतानां क्रियाणां सूची अस्ति । सूचीं सहजतया परिवर्तयितुं "
"शक्यते<link linkend=\"dev-scripting-command-line\"> स्वकीयानि लिप्याः लेखनम्</"
"link> . एवं &amp;katepart; उपयोक्तृनिर्धारितसाधनेन विस्तारितुं शक्यते ।"

#. Tag: menuchoice
#: menus.docbook:1273
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu> "
"<guisubmenu>Navigation</guisubmenu>"
msgstr ""
"<guimenu>उपकरणं</guimenu> <guisubmenu>स्क्रिप्ट्</guisubmenu> <guisubmenu>नेविगेशन</"
"guisubmenu>"

#. Tag: menuchoice
#: menus.docbook:1281
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift;&Up;</keycombo> </"
"shortcut> <guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu> "
"<guisubmenu>Navigation</guisubmenu> <guimenuitem>Move cursor to previous "
"matching indent</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift;&Up;</keycombo> </"
"shortcut> <guimenu>उपकरणं</guimenu> <guisubmenu>स्क्रिप्ट्</guisubmenu> "
"<guisubmenu>नेविगेशन</guisubmenu> < guimenuitem>कर्सरं पूर्वमेलन-इण्डेण्ट्</"
"guimenuitem> मध्ये स्थानान्तरयन्तु"

#. Tag: para
#: menus.docbook:1290
#, no-c-format
msgid ""
"Moves the cursor to the first line above the current line that is indented "
"at the same level as the current line."
msgstr ""
"वर्तमानरेखायाः उपरि प्रथमपङ्क्तौ कर्सरं चालयति यत् वर्तमानरेखायाः समानस्तरस्य इण्डेण्ट् भवति "
"।"

#. Tag: menuchoice
#: menus.docbook:1297
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift;&Down;</keycombo> </"
"shortcut> <guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu> "
"<guisubmenu>Navigation</guisubmenu> <guimenuitem>Move cursor to next "
"matching indent</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift;&Down;</keycombo> </"
"shortcut> <guimenu>उपकरणं</guimenu> <guisubmenu>स्क्रिप्ट्</guisubmenu> "
"<guisubmenu>नेविगेशन</guisubmenu> < guimenuitem>कर्सरं अग्रिममेलन-इण्डेण्ट्</"
"guimenuitem> मध्ये स्थानान्तरयन्तु"

#. Tag: para
#: menus.docbook:1306
#, no-c-format
msgid ""
"Moves the cursor to the first line below the current line that is indented "
"at the same level as the current line."
msgstr ""
"वर्तमानरेखायाः अधः प्रथमपङ्क्तौ कर्सरं चालयति यत् वर्तमानरेखायाः समानस्तरस्य इण्डेण्ट् भवति ।"

#. Tag: menuchoice
#: menus.docbook:1322
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu> "
"<guisubmenu>Editing</guisubmenu>"
msgstr ""
"<guimenu>उपकरणं</guimenu> <guisubmenu>स्क्रिप्ट्</guisubmenu> <guisubmenu>सम्पादनं</"
"guisubmenu>"

#. Tag: menuchoice
#: menus.docbook:1330
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu> "
"<guisubmenu>Editing</guisubmenu> <guimenuitem>Sort Selected Text</"
"guimenuitem>"
msgstr ""
"<guimenu>उपकरणं</guimenu> <guisubmenu>स्क्रिप्ट्</guisubmenu> "
"<guisubmenu>सम्पादनम्</guisubmenu> <guimenuitem>चयनितपाठं क्रमयन्तु</guimenuitem>"

#. Tag: para
#: menus.docbook:1336
#, no-c-format
msgid "Sorts the selected text or whole document in ascending order."
msgstr "चयनितं पाठं वा सम्पूर्णं दस्तावेजं वा आरोहणक्रमेण क्रमयति ।"

#. Tag: menuchoice
#: menus.docbook:1342
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;&Down;</keycombo> </"
"shortcut> <guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu> "
"<guisubmenu>Editing</guisubmenu> <guimenuitem>Move Lines Down</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;&Down;</keycombo> </"
"shortcut> <guimenu>उपकरणं</guimenu> <guisubmenu>स्क्रिप्ट्</guisubmenu> "
"<guisubmenu>सम्पादनं</guisubmenu> < guimenuitem>रेखाः अधः चालयन्तु</guimenuitem>"

#. Tag: para
#: menus.docbook:1351
#, no-c-format
msgid "Move selected lines down."
msgstr "चयनितपङ्क्तयः अधः स्थापयन्तु।"

#. Tag: menuchoice
#: menus.docbook:1357
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;&Up;</keycombo> </"
"shortcut> <guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu> "
"<guisubmenu>Editing</guisubmenu> <guimenuitem>Move Lines Up</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;&Up;</keycombo> </"
"shortcut> <guimenu>उपकरणं</guimenu> <guisubmenu>स्क्रिप्ट्</guisubmenu> "
"<guisubmenu>सम्पादनं</guisubmenu> < guimenuitem>रेखाः उपरि चालयन्तु</guimenuitem>"

#. Tag: para
#: menus.docbook:1366
#, no-c-format
msgid "Move selected lines up."
msgstr "चयनितपङ्क्तयः उपरि चालयन्तु।"

#. Tag: menuchoice
#: menus.docbook:1372
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Alt;&Down;</keycombo> </"
"shortcut> <guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu> "
"<guisubmenu>Editing</guisubmenu> <guimenuitem>Duplicate Selected Lines Down</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Alt;&Down;</keycombo> </"
"shortcut> <guimenu>उपकरणं</guimenu> <guisubmenu>स्क्रिप्ट्</guisubmenu> "
"<guisubmenu>सम्पादनं</guisubmenu> < guimenuitem>चयनितपङ्क्तयः अधः द्वितीयकं कुर्वन्तु</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:1381
#, no-c-format
msgid "Duplicates the selected lines down."
msgstr "चयनितपङ्क्तयः अधः द्वितीयकं करोति ।"

#. Tag: menuchoice
#: menus.docbook:1387
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Alt;&Up;</keycombo> </shortcut> "
"<guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu> "
"<guisubmenu>Editing</guisubmenu> <guimenuitem>Duplicate Selected Lines Up</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Alt;&Up;</keycombo> </shortcut> "
"<guimenu>उपकरणं</guimenu> <guisubmenu>स्क्रिप्ट्</guisubmenu> <guisubmenu>सम्पादनं</"
"guisubmenu> < guimenuitem>चयनितपङ्क्तयः उपरि द्वितीयकं कुर्वन्तु</guimenuitem>"

#. Tag: para
#: menus.docbook:1396
#, no-c-format
msgid "Duplicates the selected lines up."
msgstr "चयनितपङ्क्तयः अपि द्वितीयकं करोति ।"

#. Tag: menuchoice
#: menus.docbook:1402
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu> "
"<guisubmenu>Editing</guisubmenu> <guimenuitem>URI-encode selected text</"
"guimenuitem>"
msgstr ""
"<guimenu>उपकरणं</guimenu> <guisubmenu>स्क्रिप्ट्</guisubmenu> <guisubmenu>सम्पादनं</"
"guisubmenu> <guimenuitem>चयनितपाठं URI-एन्कोड् कुर्वन्तु</guimenuitem>"

#. Tag: para
#: menus.docbook:1408
#, no-c-format
msgid ""
"Encodes the selected text so that it can be used as part of a query string "
"in a &URL;, replacing the selection with the encoded text."
msgstr ""
"चयनितं पाठं एन्कोड् करोति येन &URL;मध्ये क्वेरी स्ट्रिंग् इत्यस्य भागरूपेण तस्य उपयोगः कर्तुं "
"शक्यते, चयनस्य स्थाने एन्कोडेड् पाठः ।"

#. Tag: menuchoice
#: menus.docbook:1415
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu> "
"<guisubmenu>Editing</guisubmenu> <guimenuitem>URI-decode selected text</"
"guimenuitem>"
msgstr ""
"<guimenu>उपकरणाः</guimenu> <guisubmenu>स्क्रिप्ट्</guisubmenu> "
"<guisubmenu>सम्पादनम्</guisubmenu> <guimenuitem>चयनितपाठं URI-विकोडयन्तु</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:1421
#, no-c-format
msgid ""
"If part of the query string of a &URL; is selected, this will decode it and "
"replace the selection with the original raw text."
msgstr ""
"यदि &URL; चयनितम् अस्ति, एतेन तस्य विकोडीकरणं भविष्यति तथा चयनस्य स्थाने मूलकच्चा पाठः "
"स्थापितः भविष्यति ।"

#. Tag: menuchoice
#: menus.docbook:1431
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu> <guisubmenu>Emmet</"
"guisubmenu>"
msgstr ""
"<guimenu>उपकरणं</guimenu> <guisubmenu>स्क्रिप्ट्</guisubmenu> <guisubmenu>एमेट्</"
"guisubmenu>"

#. Tag: menuchoice
#: menus.docbook:1439
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu> <guisubmenu>Emmet</"
"guisubmenu> <guimenuitem>Expand abbreviation</guimenuitem>"
msgstr ""
"<guimenu>उपकरणं</guimenu> <guisubmenu>स्क्रिप्ट्</guisubmenu> <guisubmenu>Emmet</"
"guisubmenu> <guimenuitem>संक्षेपं विस्तारयतु</guimenuitem>"

#. Tag: para
#: menus.docbook:1445
#, no-c-format
msgid ""
"Converts the selected text to a pair of opening and closing &HTML; or &XML; "
"tags. For example, if <userinput>div</userinput> is selected, this item will "
"replace that with <computeroutput>&lt;div&gt;&lt;/div&gt;</computeroutput>."
msgstr ""
"चयनितं पाठं उद्घाटनस्य समापनस्य च युग्मे परिवर्तयति &HTML; अथवा &XML; टैग्स। यथा, यदि "
"<userinput>div</userinput> चयनितम् अस्ति, तर्हि एतत् द्रव्यं तस्य स्थाने "
"<computeroutput>&lt;div&gt;&lt;/div&gt;</computeroutput> इत्यनेन "
"प्रतिस्थापयिष्यति ।"

#. Tag: menuchoice
#: menus.docbook:1453
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu> <guisubmenu>Emmet</"
"guisubmenu> <guimenuitem>Wrap with tag</guimenuitem>"
msgstr ""
"<guimenu>उपकरणं</guimenu> <guisubmenu>स्क्रिप्ट्</guisubmenu> <guisubmenu>एमेट्</"
"guisubmenu> <guimenuitem>टैग्</guimenuitem> सह लपेटयतु"

#. Tag: para
#: menus.docbook:1459
#, no-c-format
msgid ""
"Wraps the selected text with the tag provided on the <link linkend=\"dev-"
"scripting-command-line\">command line</link>."
msgstr ""
"चयनितं पाठं इत्यत्र प्रदत्तेन टैग् इत्यनेन वेष्टयति<link linkend=\"dev-scripting-command-"
"line\"> आदेशपङ्क्तिः</link> ."

#. Tag: menuchoice
#: menus.docbook:1466
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu> <guisubmenu>Emmet</"
"guisubmenu> <guimenuitem>Move cursor to matching tag</guimenuitem>"
msgstr ""
"<guimenu>उपकरणाः</guimenu> <guisubmenu>स्क्रिप्ट्स्</guisubmenu> "
"<guisubmenu>Emmet</guisubmenu> <guimenuitem>कर्सरं मेलयुक्तटैग्</guimenuitem> प्रति "
"स्थानान्तरयन्तु"

#. Tag: para
#: menus.docbook:1472
#, no-c-format
msgid ""
"If the cursor is inside an opening &HTML;/&XML; tag, this item will move it "
"to the closing tag. If the cursor is inside the closing tag, it will instead "
"move it to the opening tag."
msgstr ""
"यदि कर्सरः कस्यचित् उद्घाटनस्य अन्तः अस्ति &HTML;/&XML; tag, एतत् द्रव्यं तत् समापन टैग् "
"प्रति स्थानान्तरयिष्यति । यदि कर्सरः समापनटैग् इत्यस्य अन्तः अस्ति तर्हि तस्य स्थाने "
"उद्घाटनटैग् प्रति गमिष्यति ।"

#. Tag: menuchoice
#: menus.docbook:1480
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu> <guisubmenu>Emmet</"
"guisubmenu> <guimenuitem>Select &HTML;/&XML; tag contents inwards</"
"guimenuitem>"
msgstr ""
"<guimenu>उपकरणं</guimenu> <guisubmenu>स्क्रिप्ट्स्</guisubmenu> <guisubmenu>एमेट्</"
"guisubmenu> <guimenuitem>&HTML;/&XML; सामग्रीं अन्तः</guimenuitem>ं टैगं कुर्वन्तु"

#. Tag: para
#: menus.docbook:1486
#, no-c-format
msgid ""
"When the cursor is inside a pair of &HTML;/&XML; tags, this option will "
"change the selection to include the contents of those &HTML;/&XML; tags, "
"without selecting the tags themselves."
msgstr ""
"यदा कर्सरः &HTML;/&XML; tags, एषः विकल्पः चयनं परिवर्तयिष्यति यत् तेषां &HTML;/&XML; "
"टैग्, टैग्स् स्वयं चयनं विना।"

#. Tag: menuchoice
#: menus.docbook:1494
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu> <guisubmenu>Emmet</"
"guisubmenu> <guimenuitem>Select &HTML;/&XML; tag contents outwards</"
"guimenuitem>"
msgstr ""
"<guimenu>उपकरणं</guimenu> <guisubmenu>स्क्रिप्ट्स्</guisubmenu> <guisubmenu>एमेट्</"
"guisubmenu> <guimenuitem>&HTML;/&XML; सामग्रीं बहिः</guimenuitem>ं टैगं कुर्वन्तु"

#. Tag: para
#: menus.docbook:1500
#, no-c-format
msgid ""
"When the cursor is inside a pair of &HTML;/&XML; tags, this item will change "
"the selection to include the contents of those &HTML;/&XML; tags, including "
"the tags themselves."
msgstr ""
"यदा कर्सरः &HTML;/&XML; टैग्, एतत् द्रव्यं चयनं परिवर्तयिष्यति यत् तेषां &HTML;/&XML; "
"टैग्स्, टैग्स् एव सहितम्।"

#. Tag: menuchoice
#: menus.docbook:1508
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu> <guisubmenu>Emmet</"
"guisubmenu> <guimenuitem>Toggle Comment</guimenuitem>"
msgstr ""
"<guimenu>उपकरणं</guimenu> <guisubmenu>स्क्रिप्ट्</guisubmenu> <guisubmenu>Emmet</"
"guisubmenu> <guimenuitem>टिप्पणी टॉगल</guimenuitem>"

#. Tag: para
#: menus.docbook:1514
#, no-c-format
msgid ""
"If the selected portion is not a comment, this item will enclose that "
"portion in &HTML;/&XML; comments (&eg; <computeroutput>&lt;!-- selected text "
"--&gt;</computeroutput>). If the selected portion is a comment, the comment "
"tags will be removed instead."
msgstr ""
"यदि चयनितः भागः टिप्पणी नास्ति तर्हि एतत् द्रव्यं तत् भागं &HTML;/&XML; टिप्पणी (&eg; "
"<computeroutput>&lt;!-- चयनितः पाठः --&gt;</computeroutput>)। यदि चयनितः "
"भागः टिप्पणी अस्ति तर्हि तस्य स्थाने टिप्पणीटैग्स् निष्कासिताः भविष्यन्ति ।"

#. Tag: menuchoice
#: menus.docbook:1525
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu><guisubmenu>Scripts</guisubmenu><guisubmenu>Emmet</"
"guisubmenu> <guimenuitem>Delete tag under cursor</guimenuitem>"
msgstr ""
"<guimenu>उपकरणं</guimenu><guisubmenu>स्क्रिप्ट्</guisubmenu><guisubmenu>Emmet</"
"guisubmenu> <guimenuitem>कर्सर</guimenuitem> इत्यस्य अधः टैगं विलोपयतु"

#. Tag: para
#: menus.docbook:1529
#, no-c-format
msgid ""
"If the cursor is presently inside a &HTML;/&XML; tag, this item will delete "
"the entire tag."
msgstr "यदि कर्सरः वर्तमानकाले &HTML;/&XML; tag, एतत् द्रव्यं सम्पूर्णं टैग् विलोपयिष्यति ।"

#. Tag: menuchoice
#: menus.docbook:1536
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu> <guisubmenu>Emmet</"
"guisubmenu> <guimenuitem>Decrement number by 1</guimenuitem>"
msgstr ""
"<guimenu>उपकरणं</guimenu> <guisubmenu>स्क्रिप्ट्</guisubmenu> <guisubmenu>Emmet</"
"guisubmenu> <guimenuitem>सङ्ख्यां 1 द्वारा न्यूनीकरोतु</guimenuitem>"

#. Tag: para
#: menus.docbook:1542
#, no-c-format
msgid ""
"This item will subtract one from the currently selected text, if it is a "
"number. For example, if <userinput>5</userinput> is selected, it will become "
"<computeroutput>4</computeroutput>."
msgstr ""
"एतत् द्रव्यं वर्तमानचयनितपाठात् एकं घटयिष्यति, यदि सा संख्या अस्ति । यथा, यदि "
"<userinput>5</userinput> इति चयनं भवति तर्हि <computeroutput>4</"
"computeroutput> इति भविष्यति ।"

#. Tag: menuchoice
#: menus.docbook:1550
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu> <guisubmenu>Emmet</"
"guisubmenu> <guimenuitem>Decrement number by 10</guimenuitem>"
msgstr ""
"<guimenu>उपकरणाः</guimenu> <guisubmenu>स्क्रिप्ट्स्</guisubmenu> <guisubmenu>एमेट्</"
"guisubmenu> <guimenuitem>सङ्ख्यां १०</guimenuitem> द्वारा न्यूनीकरोतु"

#. Tag: para
#: menus.docbook:1556
#, no-c-format
msgid ""
"This item will subtract 10 from the currently selected text, if it is a "
"number. For example, if <userinput>15</userinput> is selected, it will "
"become <computeroutput>5</computeroutput>."
msgstr ""
"एतत् द्रव्यं वर्तमानचयनितपाठात् १० घटयिष्यति, यदि एषा संख्या अस्ति । यथा, यदि "
"<userinput>15</userinput> इति चयनं भवति तर्हि <computeroutput>5</"
"computeroutput> इति भविष्यति ।"

#. Tag: menuchoice
#: menus.docbook:1564
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu> <guisubmenu>Emmet</"
"guisubmenu> <guimenuitem>Decrement number by 0.1</guimenuitem>"
msgstr ""
"<guimenu>उपकरणाः</guimenu> <guisubmenu>स्क्रिप्ट्स्</guisubmenu> "
"<guisubmenu>Emmet</guisubmenu> <guimenuitem>सङ्ख्यां 0.1 द्वारा न्यूनीकरोतु</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:1570
#, no-c-format
msgid ""
"This item will subtract 0.1 from the currently selected text, if it is a "
"number. For example, if <userinput>4.5</userinput> is selected, it will "
"become <computeroutput>4.4</computeroutput>."
msgstr ""
"एतत् द्रव्यं वर्तमानचयनितपाठात् 0.1 घटयिष्यति, यदि एषा संख्या अस्ति । यथा, यदि "
"<userinput>4.5</userinput> इति चयनं भवति तर्हि <computeroutput>4.4</"
"computeroutput> इति भविष्यति ।"

#. Tag: menuchoice
#: menus.docbook:1578
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu> <guisubmenu>Emmet</"
"guisubmenu> <guimenuitem>Increment number by 1</guimenuitem>"
msgstr ""
"<guimenu>उपकरणाः</guimenu> <guisubmenu>स्क्रिप्ट्स्</guisubmenu> "
"<guisubmenu>Emmet</guisubmenu> <guimenuitem>सङ्ख्यां 1 द्वारा वर्धयन्तु</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:1584
#, no-c-format
msgid ""
"This item will add one to the currently selected text, if it is a number. "
"For example, if <userinput>5</userinput> is selected, it will become "
"<computeroutput>6</computeroutput>."
msgstr ""
"एतत् द्रव्यं सम्प्रति चयनितपाठे एकं योजयिष्यति, यदि सा संख्या अस्ति । यथा, यदि "
"<userinput>5</userinput> इति चयनं भवति तर्हि <computeroutput>6</"
"computeroutput> इति भविष्यति ।"

#. Tag: menuchoice
#: menus.docbook:1592
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu> <guisubmenu>Emmet</"
"guisubmenu> <guimenuitem>Increment number by 10</guimenuitem>"
msgstr ""
"<guimenu>उपकरणाः</guimenu> <guisubmenu>स्क्रिप्ट्स्</guisubmenu> <guisubmenu>एमेट्</"
"guisubmenu> <guimenuitem>सङ्ख्यां १०</guimenuitem> इत्यनेन वर्धयन्तु"

#. Tag: para
#: menus.docbook:1598
#, no-c-format
msgid ""
"This item will add 10 to the currently selected text, if it is a number. For "
"example, if <userinput>5</userinput> is selected, it will become "
"<computeroutput>15</computeroutput>."
msgstr ""
"एतत् द्रव्यं वर्तमानचयनितपाठे १० योजयिष्यति, यदि एषा संख्या अस्ति । यथा, यदि "
"<userinput>5</userinput> इति चयनं भवति तर्हि <computeroutput>15</"
"computeroutput> इति भविष्यति ।"

#. Tag: menuchoice
#: menus.docbook:1606
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu> <guisubmenu>Emmet</"
"guisubmenu> <guimenuitem>Increment number by 0.1</guimenuitem>"
msgstr ""
"<guimenu>उपकरणं</guimenu> <guisubmenu>स्क्रिप्ट्</guisubmenu> <guisubmenu>Emmet</"
"guisubmenu> <guimenuitem>सङ्ख्यां 0.1 द्वारा वर्धयन्तु</guimenuitem>"

#. Tag: para
#: menus.docbook:1612
#, no-c-format
msgid ""
"This item will add 0.1 to the currently selected text, if it is a number. "
"For example, if <userinput>4.5</userinput> is selected, it will become "
"<computeroutput>4.6</computeroutput>."
msgstr ""
"एतत् द्रव्यं वर्तमानचयनितपाठे 0.1 योजयिष्यति, यदि एषा संख्या अस्ति । यथा, यदि "
"<userinput>4.5</userinput> इति चयनं भवति तर्हि <computeroutput>4.6</"
"computeroutput> इति भविष्यति ।"

#. Tag: menuchoice
#: menus.docbook:1628
#, no-c-format
msgid ""
"<shortcut> <keycap>F7</keycap> </shortcut> <guimenu>Tools</guimenu> "
"<guimenuitem>Switch to Command Line</guimenuitem>"
msgstr ""
"<shortcut> <keycap>F7</keycap> </shortcut> <guimenu>उपकरणाः</guimenu> "
"<guimenuitem>आदेशपङ्क्तिं प्रति गच्छन्तु</guimenuitem>"

#. Tag: para
#: menus.docbook:1636
#, no-c-format
msgid ""
"Displays the &katepart; command line at the bottom of the window. In the "
"command line, type <userinput>help</userinput> to get help and "
"<userinput>help list</userinput> to get a list of commands. For more "
"information on the command line, see <link linkend=\"advanced-editing-tools-"
"commandline\">The Editor Component Command Line</link>."
msgstr ""
"प्रदर्शयति &amp;katepart; विण्डो इत्यस्य अधः आदेशपङ्क्तिः । आदेशपङ्क्तौ "
"टङ्कयन्तु<userinput> साहाय्यम्‌</userinput> साहाय्यं प्राप्तुं च<userinput> सहायतासूची</"
"userinput> आदेशानां सूचीं प्राप्तुं । आदेशपङ्क्तौ अधिकविवरणार्थं पश्यन्तु<link linkend="
"\"advanced-editing-tools-commandline\"> सम्पादकघटक आदेशपङ्क्तिः</link> ."

#. Tag: menuchoice
#: menus.docbook:1645
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Space;</keycombo> </shortcut> "
"<guimenu>Tools</guimenu> <guimenuitem>Invoke Code Completion</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Space;</keycombo> </shortcut> "
"<guimenu>उपकरणाः</guimenu> <guimenuitem>सङ्केतसमाप्तिम् आह्वयन्तु</guimenuitem>"

#. Tag: para
#: menus.docbook:1653
#, no-c-format
msgid ""
"Manually invoke command completion, usually by using a shortcut bound to "
"this action."
msgstr ""
"प्रायः अस्य क्रियायाः बाध्यस्य शॉर्टकट् इत्यस्य उपयोगेन आदेशसमाप्तिः मैन्युअल् रूपेण आह्वयन्तु ।"

#. Tag: menuchoice
#: menus.docbook:1658
#, no-c-format
msgid "<guimenu>Tools</guimenu> <guimenuitem>Word Completion</guimenuitem>"
msgstr "<guimenu>उपकरण</guimenu> <guimenuitem>शब्दसमाप्तिः</guimenuitem>"

#. Tag: para
#: menus.docbook:1663
#, no-c-format
msgid ""
"<guimenuitem>Reuse Word Below</guimenuitem> (<keycombo action=\"simul"
"\">&Ctrl; <keycap>9</keycap></keycombo>) and <guimenuitem>Reuse Word Above</"
"guimenuitem> (<keycombo action=\"simul\">&Ctrl; <keycap>8</keycap></"
"keycombo>) complete the currently typed text by searching for similar words "
"backward or forward from the current cursor position. <guimenuitem>Shell "
"Completion</guimenuitem> pops up a completion box with matching entries."
msgstr ""
"<guimenuitem>अधः शब्दस्य पुनः प्रयोगः</guimenuitem> (<keycombo action=\"simul"
"\">&Ctrl; <keycap>9</keycap></keycombo>) तथा <guimenuitem>उपरि शब्दस्य पुनः "
"प्रयोगः</guimenuitem> (<keycombo action= \"simul\">&Ctrl; <keycap>8</keycap></"
"keycombo>) पृष्ठतः अथवा समानशब्दान् अन्वेष्य सम्प्रति टङ्कितं पाठं पूर्णं कुर्वन्तु वर्तमान "
"कर्सरस्थानात् अग्रे । <guimenuitem>Shell Completion</guimenuitem> इत्यनेन मेलप्रविष्टैः "
"सह समाप्तिपेटिकां पोप् अप भवति ।"

#. Tag: menuchoice
#: menus.docbook:1673
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>O</keycap></"
"keycombo> </shortcut> <guimenu>Tools</guimenu> <guisubmenu>Spelling</"
"guisubmenu> <guimenuitem>Automatic Spell Checking</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>O</keycap></"
"keycombo> </shortcut> <guimenu>उपकरण</guimenu> <guisubmenu>वर्तनी</"
"guisubmenu> <guimenuitem> स्वचालितं वर्तनीपरीक्षा</guimenuitem>"

#. Tag: para
#: menus.docbook:1682
#, no-c-format
msgid ""
"When <guimenuitem>Automatic Spell Checking</guimenuitem> is enabled, wrongly "
"spelled text is underlined in the document on-the-fly."
msgstr ""
"यदा <guimenuitem>स्वचालितं वर्तनीपरीक्षा</guimenuitem> सक्षमं भवति तदा दस्तावेजे "
"उड्डयनसमये गलत् वर्तनीयुक्तः पाठः रेखांकितः भवति ।"

#. Tag: menuchoice
#: menus.docbook:1688
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu> <guisubmenu>Spelling</guisubmenu> "
"<guimenuitem>Spelling...</guimenuitem>"
msgstr ""
"<guimenu>उपकरणं</guimenu> <guisubmenu>वर्तनी</guisubmenu> <guimenuitem>वर्तनी..."
"</guimenuitem>"

#. Tag: para
#: menus.docbook:1699
#, no-c-format
msgid ""
"<action>This initiates the spellchecking program - a program designed to "
"help the user catch and correct any spelling errors.</action> Clicking on "
"this entry will start the checker and bring up the speller dialog box "
"through which the user can control the process. There are four settings "
"lined up vertically in the center of the dialog with their corresponding "
"labels just to the left. Starting at the top they are:"
msgstr ""
"<action>एतेन वर्तनीपरीक्षणकार्यक्रमः आरभ्यते - उपयोक्तुः कस्यापि वर्तनीदोषाणां ग्रहणं सम्यक् "
"कर्तुं च सहायार्थं विनिर्मितः कार्यक्रमः ।</action> अस्मिन् प्रविष्टौ क्लिक् कृत्वा परीक्षकं "
"आरभ्य वर्तनीसंवादपेटिकाम् आनयिष्यति यस्य माध्यमेन उपयोक्ता प्रक्रियां नियन्त्रयितुं शक्नोति . "
"संवादस्य केन्द्रे लम्बवत् पङ्क्तिबद्धाः चत्वारि सेटिङ्ग्स् सन्ति, तेषां तत्सम्बद्धानि लेबलानि केवलं "
"वामभागे एव सन्ति । शीर्षतः आरभ्य ते सन्ति :"

#. Tag: guilabel
#: menus.docbook:1709
#, no-c-format
msgid "Unknown word:"
msgstr "अज्ञातशब्दः :"

#. Tag: para
#: menus.docbook:1710
#, no-c-format
msgid ""
"Here, the spellchecker indicates the word currently under consideration. "
"This happens when the checker encounters a word not in its dictionary - a "
"file containing a list of correctly spelled words against which it compares "
"each word in the editor."
msgstr ""
"अत्र वर्तनीपरीक्षकः सम्प्रति विचार्यमाणं शब्दं सूचयति । एतत् तदा भवति यदा परीक्षकः स्वस्य "
"शब्दकोशे नास्ति इति शब्दस्य सम्मुखीभवति - सम्यक् वर्तनीशब्दानां सूचीं युक्ता सञ्चिका यस्य "
"विरुद्धं सम्पादके प्रत्येकं शब्दस्य तुलनां करोति"

#. Tag: guilabel
#: menus.docbook:1717
#, no-c-format
msgid "Replace with:"
msgstr "प्रतिस्थापनं कृत्वा :"

#. Tag: para
#: menus.docbook:1718
#, no-c-format
msgid ""
"If the checker has any similar words in its dictionary the first one will be "
"listed here. The user can accept the suggestion, type in his or her own "
"correction, or choose a different suggestion from the next box."
msgstr ""
"यदि चेकरस्य शब्दकोशे एतादृशाः शब्दाः सन्ति तर्हि प्रथमः अत्र सूचीकृतः भविष्यति । उपयोक्ता "
"सुझावं स्वीकुर्वितुं, स्वस्य सुधारणं टङ्कयितुं, अथवा अग्रिमपेटिकातः भिन्नं सुझावं चिन्वितुं शक्नोति ।"

#. Tag: guilabel
#: menus.docbook:1724
#, no-c-format
msgid "Language:"
msgstr "भाषा:"

#. Tag: para
#: menus.docbook:1725
#, no-c-format
msgid ""
"If you have installed multiple dictionaries, here you can select which "
"dictionary/language should be used."
msgstr ""
"यदि भवान् अनेकाः शब्दकोशाः संस्थापितवान् तर्हि अत्र भवान् कस्य शब्दकोशस्य/भाषायाः उपयोगः "
"कर्तव्यः इति चिन्वितुं शक्नोति ।"

#. Tag: para
#: menus.docbook:1730
#, no-c-format
msgid ""
"On the right side of the dialog box are 6 buttons that allow the user to "
"control the spellcheck process. They are:"
msgstr ""
"संवादपेटिकायाः दक्षिणभागे ६ बटन्स् सन्ति ये उपयोक्तारं वर्तनीपरीक्षाप्रक्रियां नियन्त्रयितुं "
"शक्नुवन्ति । ते सन्ति:"

#. Tag: guibutton
#: menus.docbook:1736
#, no-c-format
msgid "Add to Dictionary"
msgstr "शब्दकोशे योजयतु"

#. Tag: para
#: menus.docbook:1737
#, no-c-format
msgid ""
"Pressing this button adds the <guilabel>Unknown word </guilabel> to the "
"checker's dictionary. This means that in the future the checker will always "
"consider this word to be correctly spelled."
msgstr ""
"एतत् बटन् नुत्वा <guilabel>अज्ञातशब्दः </guilabel> इति परीक्षकस्य शब्दकोशे योजयति । "
"भविष्ये परीक्षकः अस्य शब्दस्य सम्यक् वर्तनी इति सर्वदा मन्यते इति भावः ।"

#. Tag: guilabel
#: menus.docbook:1744
#, no-c-format
msgid "Suggest"
msgstr "निर्दिशतु"

#. Tag: para
#: menus.docbook:1745
#, no-c-format
msgid ""
"The checker may list here a number of possible replacements for the word "
"under consideration. Clicking on any one of the suggestions will cause that "
"word to be entered in the <guilabel>Replace with</guilabel> box, above."
msgstr ""
"परीक्षकः अत्र विचार्यमाणस्य शब्दस्य सम्भाव्यप्रतिस्थापनानाम् एकां संख्यां सूचीतुं शक्नोति । "
"कस्यापि सुझावस्य उपरि क्लिक् करणेन सः शब्दः <guilabel>Replace with</guilabel> इति "
"पेटीयां प्रविष्टः भविष्यति, उपरि ।"

#. Tag: guibutton
#: menus.docbook:1752
#, no-c-format
msgid "Replace"
msgstr "प्रत्याहृ"

#. Tag: para
#: menus.docbook:1753
#, no-c-format
msgid ""
"This button has the checker replace the word under consideration in the "
"document with the word in the <guilabel>Replace with</guilabel> box."
msgstr ""
"अस्मिन् बटन् मध्ये चेकरः दस्तावेजे विचार्यमाणं शब्दं <guilabel>Replace with</guilabel> "
"इति पेटीयां शब्देन प्रतिस्थापयति ।"

#. Tag: guibutton
#: menus.docbook:1759
#, no-c-format
msgid "Replace All"
msgstr "सर्वेषां प्रतिस्थापनम्"

#. Tag: para
#: menus.docbook:1760
#, no-c-format
msgid ""
"This button causes the checker to replace not only the current "
"<guilabel>Unknown word:</guilabel> but to automatically make the same "
"substitution for any other occurrences of this <guilabel>Unknown word</"
"guilabel> in the document."
msgstr ""
"एतेन बटनेन परीक्षकः न केवलं वर्तमानस्य <guilabel>अज्ञातशब्दस्य:</guilabel> इत्यस्य स्थाने "
"अन्यं किमपि प्रतिस्थापनं करोति अपितु दस्तावेजे अस्य <guilabel>अज्ञातशब्दस्य</guilabel> "
"इत्यस्य अन्यस्य कस्यापि घटनायाः समानं प्रतिस्थापनं स्वयमेव करोति"

#. Tag: guibutton
#: menus.docbook:1767
#, no-c-format
msgid "Ignore"
msgstr "उपेक्षा"

#. Tag: para
#: menus.docbook:1768
#, no-c-format
msgid ""
"Activating this button will have the checker move on without making any "
"changes."
msgstr "एतत् बटन् सक्रियीकरणेन चेकरः किमपि परिवर्तनं न कृत्वा अग्रे गमिष्यति ।"

#. Tag: guibutton
#: menus.docbook:1773
#, no-c-format
msgid "Ignore All"
msgstr "सर्वम् अवहेलयतु"

#. Tag: para
#: menus.docbook:1774
#, no-c-format
msgid ""
"This button tells the checker to do nothing with the current "
"<guilabel>Unknown word:</guilabel> and to pass over any other instances of "
"the same word."
msgstr ""
"एतत् बटन् परीक्षकं वर्तमानेन <guilabel>अज्ञातशब्देन:</guilabel> इत्यनेन सह किमपि न कर्तुं "
"वदति तथा च तस्यैव शब्दस्य अन्येषां उदाहरणानां उपरि गन्तुं वदति ।"

#. Tag: para
#: menus.docbook:1776
#, no-c-format
msgid ""
"This only applies to the current spellcheck run. If the checker is run again "
"later it will stop on this same word."
msgstr ""
"एतत् केवलं वर्तमानस्य वर्तनीपरीक्षा-धावनस्य कृते एव प्रवर्तते । यदि पश्चात् पुनः चेकरः चालितः "
"भवति तर्हि अस्मिन् एव शब्दे स्थगयिष्यति ।"

#. Tag: para
#: menus.docbook:1783
#, no-c-format
msgid ""
"Three more buttons are located horizontally along the bottom of the "
"spellcheck dialog. They are:"
msgstr "वर्तनीपरीक्षासंवादस्य अधः क्षैतिजरूपेण त्रीणि अपि बटन्-स्थानानि सन्ति । ते सन्ति:"

#. Tag: guibutton
#: menus.docbook:1789
#, no-c-format
msgid "Help"
msgstr "साहाय्यम्‌"

#. Tag: para
#: menus.docbook:1790
#, no-c-format
msgid "This invokes the &kde; help system with the help page for this dialog."
msgstr "एतेन &kde; अस्य संवादस्य कृते सहायतापृष्ठेन सह help system ।"

#. Tag: guibutton
#: menus.docbook:1795
#, no-c-format
msgid "Finished"
msgstr "सम्पूर्ण"

#. Tag: para
#: menus.docbook:1796
#, no-c-format
msgid "This button ends the spellcheck process, and returns to the document."
msgstr "एतत् बटन् वर्तनीपरीक्षाप्रक्रियाम् समाप्तं करोति, दस्तावेजं प्रति च आगच्छति ।"

#. Tag: guibutton
#: menus.docbook:1801
#, no-c-format
msgid "Cancel"
msgstr "निरसयतु"

#. Tag: para
#: menus.docbook:1802
#, no-c-format
msgid ""
"This button cancels the spellcheck process, all modifications are reverted, "
"and you will return to your document."
msgstr ""
"एतत् बटन् वर्तनीपरीक्षा प्रक्रियां रद्दं करोति, सर्वाणि परिवर्तनानि प्रत्यागच्छन्ति, भवान् "
"स्वदस्तावेजं प्रति आगमिष्यति ।"

#. Tag: menuchoice
#: menus.docbook:1813
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu> <guisubmenu>Spelling</guisubmenu> "
"<guimenuitem>Spelling (from cursor)...</guimenuitem>"
msgstr ""
"<guimenu>उपकरणाः</guimenu> <guisubmenu>वर्तनी</guisubmenu> <guimenuitem>वर्तनी "
"(कर्सरतः)...</guimenuitem>"

#. Tag: para
#: menus.docbook:1819
#, no-c-format
msgid ""
"This initiates the spellchecking program but it starts where your cursor is "
"instead of at the beginning of the document."
msgstr ""
"एतेन वर्तनीपरीक्षाकार्यक्रमः आरभ्यते परन्तु दस्तावेजस्य आरम्भे न अपितु यत्र भवतः कर्सरः अस्ति "
"तत्र आरभ्यते ।"

#. Tag: menuchoice
#: menus.docbook:1825
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu> <guisubmenu>Spelling</guisubmenu> "
"<guimenuitem>Spellcheck Selection...</guimenuitem>"
msgstr ""
"<guimenu>उपकरणाः</guimenu> <guisubmenu>वर्तनी</guisubmenu> "
"<guimenuitem>वर्तनीपरीक्षणचयनम्...</guimenuitem>"

#. Tag: para
#: menus.docbook:1831
#, no-c-format
msgid "Spellchecks the current selection."
msgstr "वर्तमानचयनस्य वर्तनीपरीक्षां करोति ।"

#. Tag: menuchoice
#: menus.docbook:1836
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu> <guisubmenu>Spelling</guisubmenu> "
"<guimenuitem>Change Dictionary</guimenuitem>"
msgstr ""
"<guimenu>उपकरणं</guimenu> <guisubmenu>वर्तनी</guisubmenu> <guimenuitem>शब्दकोशं "
"परिवर्तयतु</guimenuitem>"

#. Tag: para
#: menus.docbook:1842
#, no-c-format
msgid ""
"Displays a drop down box with all available dictionaries for spellchecking "
"at the bottom of the editor window. This allows easy switching of the "
"spellcheck dictionary &eg; for automatic spellcheck of text in different "
"languages."
msgstr ""
"सम्पादकविण्डो इत्यस्य अधः वर्तनीपरीक्षायै सर्वैः उपलब्धैः शब्दकोशैः सह एकं ड्रॉप् डाउन पेटी "
"प्रदर्शयति । एतेन वर्तनीपरीक्षा शब्दकोशस्य सुलभं परिवर्तनं भवति &eg; विभिन्नभाषासु पाठस्य "
"स्वचालितवर्तनीपरीक्षायै।"

#. Tag: title
#: menus.docbook:1852
#, no-c-format
msgid "The Settings and Help Menu"
msgstr "सेटिंग्स् एण्ड् हेल्प् मेन्यू"

#. Tag: menuchoice
#: menus.docbook:1856
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guisubmenu>Editor Color Theme</guisubmenu>"
msgstr "<guimenu>सेटिंग्स्</guimenu> <submenu>रङ्गविषयसम्पादकः</guimenu>"

#. Tag: para
#: menus.docbook:1860
#, no-c-format
msgid ""
"This menu lists the available color schemes. You can change the schema for "
"the current view here, to change the default schema you need to use the "
"<ulink url=\"help:/katepart/config-dialog-editor.html#prefcolors\">Fonts "
"&amp; Colors</ulink> page of the config dialog."
msgstr ""
"अस्मिन् मेन्यू मध्ये उपलब्धानि वर्णयोजनानि सूचीबद्धानि सन्ति । भवान् अत्र वर्तमानदृश्यस्य "
"स्कीमा परिवर्तयितुं शक्नोति, पूर्वनिर्धारितं योजनां परिवर्तयितुं भवान् <ulink url=\"help:/"
"katepart/config-dialog-editor.html#prefcolors\">Fonts &amp; विन्याससंवादस्य "
"वर्णाः</ulink>पृष्ठम् ।"

#. Tag: para
#: menus.docbook:1868
#, no-c-format
msgid ""
"&katepart; has the common &kde; <guimenu>Settings</guimenu> and "
"<guimenu>Help</guimenu> menu items, for more information read the sections "
"about the <ulink url=\"help:/fundamentals/menus.html#menus-settings"
"\">Settings Menu</ulink> and <ulink url=\"help:/fundamentals/menus."
"html#menus-help\">Help Menu</ulink> of the &kde; Fundamentals."
msgstr ""
"&कटेपार्ट; सामान्यं &kde; <guimenu>सेटिंग्स्</guimenu> तथा <guimenu>सहायता</guimenu> "
"मेनू-वस्तूनाम्, अधिकसूचनार्थं <ulink url=\"help:/fundamentals/menus.html#menus-"
"settings\">सेटिंग्स् मेन्यू< इत्यस्य विषये विभागान् पठन्तु /ulink> तथा च &kde; मौलिकता।"
