#. Tag: title
#: man-spectacle.1.docbook:35
#, no-c-format
msgid "Description"
msgstr "वर्णनम्‌"

#. Tag: para
#: man-spectacle.1.docbook:36
#, no-c-format
msgid ""
"<command>spectacle</command> is a simple application for capturing desktop "
"screenshots. It can capture images of the entire desktop, a single monitor, "
"the currently active window, the window currently under the mouse, or a "
"rectangular region of the screen. The images can then be annotated, printed, "
"sent to other applications for manipulation, or quickly be saved as-is."
msgstr ""
"<command>spectacle</command> इति डेस्कटॉप् स्क्रीनशॉट् गृहीतुं सरलं अनुप्रयोगम् अस्ति । "
"एतत् सम्पूर्णस्य डेस्कटॉपस्य, एकस्य निरीक्षकस्य, वर्तमानकाले सक्रियस्य विण्डोस्य, वर्तमानस्य "
"मूषकस्य अधः विद्यमानस्य विण्डोस्य, अथवा पटलस्य आयताकारस्य प्रदेशस्य चित्राणि गृहीतुं शक्नोति "
"। ततः चित्राणि टिप्पणीं कर्तुं, मुद्रयितुं, अन्येषु अनुप्रयोगेषु हेरफेरार्थं प्रेषयितुं, अथवा शीघ्रं "
"यथावत् रक्षितुं शक्यन्ते ।"

#. Tag: title
#: man-spectacle.1.docbook:40
#, no-c-format
msgid "Spectacle options"
msgstr "तमाशा विकल्पाः"

#. Tag: option
#: man-spectacle.1.docbook:44
#, no-c-format
msgid "-h, --help"
msgstr "-ह, --सहाय"

#. Tag: para
#: man-spectacle.1.docbook:46
#, no-c-format
msgid "Displays help on commandline options."
msgstr "आदेशपङ्क्तिविकल्पेषु सहायतां प्रदर्शयति ।"

#. Tag: option
#: man-spectacle.1.docbook:51
#, no-c-format
msgid "--help-all"
msgstr "--सहायता-सर्व"

#. Tag: para
#: man-spectacle.1.docbook:53
#, no-c-format
msgid "Displays help including Qt specific options."
msgstr "Qt विशिष्टविकल्पान् सहितं सहायतां प्रदर्शयति ।"

#. Tag: option
#: man-spectacle.1.docbook:58
#, no-c-format
msgid "-v, --version"
msgstr "-व, --संस्करणम्"

#. Tag: para
#: man-spectacle.1.docbook:60
#, no-c-format
msgid "Displays version information."
msgstr "संस्करणसूचनाः प्रदर्शयति ।"

#. Tag: option
#: man-spectacle.1.docbook:65
#, no-c-format
msgid "-f, --fullscreen"
msgstr "-च, --पूर्णपर्दे"

#. Tag: para
#: man-spectacle.1.docbook:67
#, no-c-format
msgid "Capture the entire desktop (default)."
msgstr "सम्पूर्णं डेस्कटॉप् (पूर्वनिर्धारितं) गृह्यताम् ।"

#. Tag: option
#: man-spectacle.1.docbook:72
#, no-c-format
msgid "--scaled"
msgstr ""

#. Tag: para
#: man-spectacle.1.docbook:74
#, no-c-format
msgid ""
"When used with <option>-f</option>/<option>--fullscreen</option>, capture "
"all screens scaled to the same size. Has no effect without <option>-f</"
"option>."
msgstr ""

#. Tag: option
#: man-spectacle.1.docbook:79
#, no-c-format
msgid "-m, --current"
msgstr "-म, --वर्तमान"

#. Tag: para
#: man-spectacle.1.docbook:81
#, no-c-format
msgid "Capture the current monitor."
msgstr "वर्तमाननिरीक्षकं गृह्यताम्।"

#. Tag: option
#: man-spectacle.1.docbook:86
#, no-c-format
msgid "-a, --activewindow"
msgstr "-क, --सक्रियविण्डो"

#. Tag: para
#: man-spectacle.1.docbook:88
#, no-c-format
msgid "Capture the active window."
msgstr "सक्रियविण्डो गृह्यताम् ।"

#. Tag: option
#: man-spectacle.1.docbook:93
#, no-c-format
msgid "-u, --windowundercursor"
msgstr "-उ, --विण्डोवंडरकर्सर"

#. Tag: para
#: man-spectacle.1.docbook:95
#, no-c-format
msgid ""
"Capture the window currently under the cursor, including parents of pop-up "
"menus."
msgstr "कर्सरस्य अधः वर्तमानं विण्डो गृह्यताम्, यत्र पॉप-अप-मेनू-मातापितरौ अपि सन्ति ।"

#. Tag: option
#: man-spectacle.1.docbook:100
#, no-c-format
msgid "-t, --transientonly"
msgstr "-त, --क्षणिकम्"

#. Tag: para
#: man-spectacle.1.docbook:102
#, no-c-format
msgid ""
"Capture the window currently under the cursor, excluding parents of pop-up "
"menus."
msgstr "कर्सरस्य अधः वर्तमानं विण्डो गृह्यताम्, पॉप-अप-मेनू-मातापितरौ विहाय ।"

#. Tag: option
#: man-spectacle.1.docbook:107
#, no-c-format
msgid "-r, --region"
msgstr "-र, --प्रदेशः"

#. Tag: para
#: man-spectacle.1.docbook:109
#, no-c-format
msgid "Capture a rectangular region of the screen."
msgstr "स्क्रीनस्य आयताकारप्रदेशं गृह्यताम् ।"

#. Tag: option
#: man-spectacle.1.docbook:114
#, no-c-format
msgid "-l, --launchonly"
msgstr "-l, --launchonly"

#. Tag: para
#: man-spectacle.1.docbook:116
#, no-c-format
msgid "Launch Spectacle without taking a screenshot."
msgstr "स्क्रीनशॉट् न गृहीत्वा Spectacle प्रारम्भं कुर्वन्तु।"

#. Tag: option
#: man-spectacle.1.docbook:121
#, no-c-format
msgid "-g, --gui"
msgstr "-ग, --गुइ"

#. Tag: para
#: man-spectacle.1.docbook:123
#, no-c-format
msgid "Start in GUI mode (default)."
msgstr "GUI मोड् (पूर्वनिर्धारितम्) आरभत ।"

#. Tag: option
#: man-spectacle.1.docbook:128
#, no-c-format
msgid "-b, --background"
msgstr "-ख, --पृष्ठभूमि"

#. Tag: para
#: man-spectacle.1.docbook:130
#, no-c-format
msgid "Take a screenshot and exit without showing the GUI."
msgstr "स्क्रीनशॉट् गृहीत्वा GUI न दर्शयित्वा निर्गच्छन्तु ।"

#. Tag: option
#: man-spectacle.1.docbook:135
#, no-c-format
msgid "-s, --dbus"
msgstr "-स, --द्बुस्"

#. Tag: para
#: man-spectacle.1.docbook:137
#, no-c-format
msgid "Start in DBus-Activation mode."
msgstr "DBus-Activation मोड् मध्ये आरभत ।"

#. Tag: option
#: man-spectacle.1.docbook:142
#, no-c-format
msgid "-n, --nonotify"
msgstr "-न, --असूचना"

#. Tag: para
#: man-spectacle.1.docbook:144
#, no-c-format
msgid ""
"In background mode, do not pop up a notification when the screenshot is "
"taken."
msgstr "पृष्ठभूमिविधाने स्क्रीनशॉट् गृहीते सूचनां न पोप् अप कुर्वन्तु ।"

#. Tag: option
#: man-spectacle.1.docbook:149
#, no-c-format
msgid "-o, --output <replaceable>fileName</replaceable>"
msgstr "-o, --output <प्रतिस्थापनीय>सञ्चिकानाम</प्रतिस्थापनीय>"

#. Tag: para
#: man-spectacle.1.docbook:151
#, no-c-format
msgid ""
"In background mode, save image to specified file <replaceable>fileName</"
"replaceable>."
msgstr ""
"पृष्ठभूमिविधाने, चित्रं निर्दिष्टसञ्चिकायां <replaceable>fileName</replaceable> मध्ये "
"रक्षन्तु ।"

#. Tag: option
#: man-spectacle.1.docbook:156
#, no-c-format
msgid "-d, --delay <replaceable>delayMsec</replaceable>"
msgstr "-d, --delay <replaceable>delayMsec</replaceable> इति"

#. Tag: para
#: man-spectacle.1.docbook:158
#, no-c-format
msgid "In background mode, delay before taking the shot (in milliseconds)."
msgstr "पृष्ठभूमिविधाने शॉट् ग्रहीतुं पूर्वं विलम्बं कुर्वन्तु (मिलिसेकेण्ड् मध्ये) ।"

#. Tag: option
#: man-spectacle.1.docbook:163
#, no-c-format
msgid "-c, --copy-image"
msgstr "-ग, --प्रतिलिपि-प्रतिमा"

#. Tag: para
#: man-spectacle.1.docbook:165
#, no-c-format
msgid ""
"In background mode, copy screenshot only to clipboard, unless -o is also "
"used."
msgstr ""
"पृष्ठभूमिविधाने केवलं क्लिप्बोर्ड् मध्ये स्क्रीनशॉट् प्रतिलिख्यताम्, यावत् -o इत्यस्य अपि उपयोगः "
"न भवति ।"

#. Tag: option
#: man-spectacle.1.docbook:170
#, no-c-format
msgid "-C, --copy-path"
msgstr "-सी, --प्रतिलिपि-मार्ग"

#. Tag: para
#: man-spectacle.1.docbook:172
#, no-c-format
msgid "In background mode, copy screenshot file path to clipboard."
msgstr "पृष्ठभूमिविधाने, स्क्रीनशॉट् सञ्चिकामार्गं क्लिप्बोर्ड् प्रति प्रतिलिख्यताम् ।"

#. Tag: option
#: man-spectacle.1.docbook:177
#, no-c-format
msgid "-w, --onclick"
msgstr "-w, --onclick"

#. Tag: para
#: man-spectacle.1.docbook:179
#, no-c-format
msgid "Wait for a click before taking screenshot. Invalidates delay.."
msgstr "स्क्रीनशॉट् ग्रहीतुं पूर्वं क्लिक् प्रतीक्ष्यताम्। विलम्बं अमान्य करोति.."

#. Tag: option
#: man-spectacle.1.docbook:184
#, no-c-format
msgid "-i, --new-instance"
msgstr "-इ, --नव-दृष्टान्त"

#. Tag: para
#: man-spectacle.1.docbook:186
#, no-c-format
msgid "Starts a new GUI instance of spectacle without registering to DBus."
msgstr "DBus मध्ये पञ्जीकरणं विना तमाशायाः नूतनं GUI उदाहरणं आरभते ।"

#. Tag: option
#: man-spectacle.1.docbook:191
#, no-c-format
msgid "-p, --pointer"
msgstr "-प, --सूचक"

#. Tag: para
#: man-spectacle.1.docbook:193
#, no-c-format
msgid "In background mode, include pointer in the screenshot."
msgstr "पृष्ठभूमिविधाने स्क्रीनशॉट् मध्ये सूचकं समावेशयन्तु ।"

#. Tag: option
#: man-spectacle.1.docbook:198
#, no-c-format
msgid "-e, --no-decoration"
msgstr "-ई, --न-अलङ्कारः"

#. Tag: para
#: man-spectacle.1.docbook:200
#, no-c-format
msgid ""
"In background mode, do not include window decorations in the screenshot."
msgstr "पृष्ठभूमिविधाने स्क्रीनशॉट् मध्ये विण्डो अलङ्काराः न समाविष्टाः ।"

#. Tag: option
#: man-spectacle.1.docbook:205
#, no-c-format
msgid "-E, --edit-existing <replaceable>existingFileName</replaceable>"
msgstr "-E, --edit-existing <replaceable>विद्यमानसञ्चिकानाम</replaceable>"

#. Tag: para
#: man-spectacle.1.docbook:207
#, no-c-format
msgid "Open and edit existing screenshot file."
msgstr "विद्यमानं स्क्रीनशॉट् सञ्चिकां उद्घाट्य सम्पादयन्तु।"

#. Tag: title
#: man-spectacle.1.docbook:213
#, no-c-format
msgid "Feedback"
msgstr "स्पर्शावबोध"

