#: index.docbook:109
#, no-c-format
msgid "Main Window"
msgstr "मुख्य खिडकी"

#. Tag: para
#: index.docbook:111
#, no-c-format
msgid "Overview of &kmix; Main Window"
msgstr "&kmix इत्यस्य अवलोकनम्; मुख्य खिडकी"

#. Tag: title
#: index.docbook:125
#, no-c-format
msgid "File Options"
msgstr "सञ्चिकाविकल्पाः"

#. Tag: screeninfo
#: index.docbook:127
#, no-c-format
msgid "<screeninfo>&kmix; File options</screeninfo>"
msgstr "<स्क्रीनसूचना>&kmix; सञ्चिकाविकल्पाः</screeninfo>"

#. Tag: phrase
#: index.docbook:133
#, no-c-format
msgid "<phrase>&kmix; File options</phrase>"
msgstr "<वाक्यांश>&kmix; सञ्चिकाविकल्पाः</phrase>"

#. Tag: menuchoice
#: index.docbook:140
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Esc;</keycombo> </shortcut> "
"<guimenu>File</guimenu> <guimenuitem>Hide Mixer Window</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Esc;</keycombo> </shortcut> "
"<guimenu>सञ्चिका</guimenu> <guimenuitem>मिश्रकविण्डो गोपनं</guimenuitem>"

#. Tag: action
#: index.docbook:147
#, no-c-format
msgid "Hide Mixer Window"
msgstr "मिक्सर विण्डो गोपयन्तु"

#. Tag: title
#: index.docbook:153
#, no-c-format
msgid "Settings"
msgstr "सेटिंग्स्"

#. Tag: screeninfo
#: index.docbook:156
#, no-c-format
msgid "<screeninfo>&kmix; Settings</screeninfo>"
msgstr "<स्क्रीनसूचना>&kmix; सेटिंग्स्</screeninfo> इति"

#. Tag: phrase
#: index.docbook:162
#, no-c-format
msgid "<phrase>&kmix; Settings</phrase>"
msgstr "<वाक्यांश>&kmix; सेटिंग्स्</phrase> इति"

#. Tag: menuchoice
#: index.docbook:169
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Audio Setup</guimenuitem>"
msgstr "<guimenu>सेटिंग्स्</guimenu> <guimenuitem>श्रव्यव्यवस्थापन</guimenuitem>"

#. Tag: para
#: index.docbook:173
#, no-c-format
msgid ""
"<action>Open <ulink url=\"help:/kcontrol/phonon\">&phonon; &systemsettings; "
"module</ulink></action> to configure the sound and video device preference "
"and the backends used by &kde; multimedia API, &phonon;."
msgstr ""
"<action>उद्घाट्य <ulink url=\"help:/kcontrol/phonon\">&phonon; &प्रणालीसेटिंग्स्; "
"module</ulink></action> इत्यनेन ध्वनि-वीडियो-यन्त्र-प्राथमिकताम् अपि च &kde; "
"बहुमाध्यम एपिआइ, &phonon;."

#. Tag: title
#: index.docbook:197
#, no-c-format
msgid "Select Master Channel"
msgstr "Master Channel इति चिनोतु"

#. Tag: screeninfo
#: index.docbook:199
#, no-c-format
msgid "<screeninfo>&kmix; Master Channel</screeninfo>"
msgstr "<स्क्रीनसूचना>&kmix; मास्टर चैनल</screeninfo>"

#. Tag: phrase
#: index.docbook:205
#, no-c-format
msgid "<phrase>&kmix; Master Channel</phrase>"
msgstr "<वाक्यांश>&kmix; मास्टर चैनल</phrase>"

#. Tag: para
#: index.docbook:209
#, no-c-format
msgid "Select your &kmix; master channel."
msgstr "स्वस्य &kmix; master channel."

#. Tag: title
#: index.docbook:213
#, no-c-format
msgid "Configure &kmix;"
msgstr "विन्यस्तं कुर्वन्तु &kmix;"

#. Tag: title
#: index.docbook:215
#, no-c-format
msgid "General configuration"
msgstr "सामान्यविन्यासः"

#. Tag: screeninfo
#: index.docbook:219
#, no-c-format
msgid "<screeninfo>General configuration of &kmix;</screeninfo>"
msgstr "<screeninfo>&kmix;</screeninfo> इत्यस्य सामान्यविन्यासः"

#. Tag: phrase
#: index.docbook:225
#, no-c-format
msgid "<phrase>General configuration of &kmix;</phrase>"
msgstr "<phrase>&kmix;</phrase> इत्यस्य सामान्यविन्यासः"

#. Tag: para
#: index.docbook:229
#, no-c-format
msgid "Configure general &kmix; parameters."
msgstr "सामान्यं विन्यस्य &kmix; पैरामीटर्स्।"

#. Tag: menuchoice
#: index.docbook:233
#, no-c-format
msgid "<guimenu>Behavior</guimenu> <guimenuitem>Volume Overdrive</guimenuitem>"
msgstr "<guimenu>व्यवहारः</guimenu> <guimenuitem>मात्रा अतिड्राइव</guimenuitem>"

#. Tag: para
#: index.docbook:237
#, no-c-format
msgid ""
"Check this box to allow volume to be more than recommended value (sometimes "
"PulseAudio maximal volume exceeds the normal value). &kmix; restart is "
"needed for this setting to take effect."
msgstr ""
"अनुशंसितमूल्यात् अधिकं आयतनं भवितुं अनुमतिं दातुं एतत् पेटी चिनोतु (कदाचित् PulseAudio अधिकतमं "
"आयतनं सामान्यमूल्यं अतिक्रमति) । &kmix; एतस्य सेटिङ्ग् इत्यस्य प्रभावाय पुनः आरम्भस्य "
"आवश्यकता अस्ति ।"

#. Tag: para
#: index.docbook:239
#, no-c-format
msgid ""
"Uncheck this item if there are audible sound distortions at the maximal "
"volume."
msgstr "यदि अधिकतममात्रायां श्रव्यध्वनिविकृतयः सन्ति तर्हि एतत् द्रव्यं अनचेक् कुर्वन्तु ।"

#. Tag: menuchoice
#: index.docbook:247
#, no-c-format
msgid "<guimenu>Behavior</guimenu> <guimenuitem>Volume Feedback</guimenuitem>"
msgstr "<guimenu>व्यवहार</guimenu> <guimenuitem>मात्राप्रतिक्रिया</guimenuitem>"

#. Tag: action
#: index.docbook:251
#, no-c-format
msgid "Check this box to enable audible feedback on volume change."
msgstr "आयतनपरिवर्तनस्य श्रव्यप्रतिक्रिया सक्षमीकरणाय एतत् पेटी चिनोतु ।"

#. Tag: menuchoice
#: index.docbook:255
#, no-c-format
msgid "<guimenu>Behavior</guimenu> <guimenuitem>Volume step</guimenuitem>"
msgstr "<guimenu>व्यवहार</guimenu> <guimenuitem>मात्राचरण</guimenuitem>"

#. Tag: para
#: index.docbook:260
#, no-c-format
msgid "Set the volume step as a percentage of the volume range."
msgstr "आयतनपदं आयतनपरिधिस्य प्रतिशतरूपेण सेट् कुर्वन्तु ।"

#. Tag: para
#: index.docbook:263
#, no-c-format
msgid ""
"This affects changing the volume via hot keys, with the mouse wheel over the "
"system tray icon, or moving sliders by a page step."
msgstr ""
"एतेन हॉट् कीलद्वारा मात्रां परिवर्तयितुं, सिस्टम् ट्रे चिह्नस्य उपरि मूषकचक्रं कृत्वा, अथवा "
"पृष्ठपदेन स्लाइडर् चालयितुं प्रभावितं भवति ।"

#. Tag: para
#: index.docbook:266
#, no-c-format
msgid "&kmix; must be restarted for this change to take effect."
msgstr "&kmix; अस्य परिवर्तनस्य प्रभावाय पुनः आरम्भः करणीयः ।"

#. Tag: menuchoice
#: index.docbook:273
#, no-c-format
msgid ""
"<guimenu>Visual</guimenu> <guimenuitem>Show slider tickmarks</guimenuitem>"
msgstr ""
"<guimenu>दृश्य</guimenu> <guimenuitem>स्लाइडरटिकचिह्नानि दर्शयतु</guimenuitem>"

#. Tag: action
#: index.docbook:277
#, no-c-format
msgid "Check this box to show tickmarks on the sliders."
msgstr "स्लाइडर्-मध्ये टिक-चिह्नानि दर्शयितुं एतत् पेटीम् चिनोतु ।"

#. Tag: menuchoice
#: index.docbook:281
#, no-c-format
msgid ""
"<guimenu>Visual</guimenu> <guimenuitem>Show control labels</guimenuitem>"
msgstr "<guimenu>दृश्य</guimenu> <guimenuitem>नियन्त्रणलेबल् दर्शयतु</guimenuitem>"

#. Tag: action
#: index.docbook:285
#, no-c-format
msgid "Check this box to show labels of controls."
msgstr "नियन्त्रणानां लेबल् दर्शयितुं एतत् पेटी चिनोतु ।"

#. Tag: menuchoice
#: index.docbook:289
#, no-c-format
msgid ""
"<guimenu>Visual</guimenu> <guimenuitem>Show On Screen Display (OSD)</"
"guimenuitem>"
msgstr ""
"<guimenu>दृश्य</guimenu> <guimenuitem>पर्दे प्रदर्शनं (OSD) दर्शयतु</guimenuitem>"

#. Tag: action
#: index.docbook:293
#, no-c-format
msgid "Check this box to enable OSD show on hovering &kmix; tray widget."
msgstr "&kmix; ट्रे विजेट।"

#. Tag: menuchoice
#: index.docbook:297
#, no-c-format
msgid ""
"<guimenu>Slider orientation (main window)</guimenu> <guimenuitem>Horizontal</"
"guimenuitem>"
msgstr ""
"<guimenu>स्लाइडर अभिमुखीकरणं (मुख्यविण्डो)</guimenu> <guimenuitem>क्षैतिज</"
"guimenuitem>"

#. Tag: action
#: index.docbook:301
#, no-c-format
msgid "Check this radio button to orientate the control slider horizontally."
msgstr "नियन्त्रणस्लाइडरं क्षैतिजरूपेण उन्मुखीकर्तुं एतत् रेडियो बटनं पश्यन्तु ।"

#. Tag: menuchoice
#: index.docbook:305
#, no-c-format
msgid ""
"<guimenu>Slider orientation (main window)</guimenu> <guimenuitem>Vertical</"
"guimenuitem>"
msgstr ""
"<guimenu>स्लाइडर अभिविन्यासः (मुख्यविण्डो)</guimenu> <guimenuitem>ऊर्ध्वाधर</"
"guimenuitem>"

#. Tag: action
#: index.docbook:309
#, no-c-format
msgid "Check this radio button to orientate the control slider vertically."
msgstr "नियन्त्रणस्लाइडरं लम्बवत् उन्मुखीकर्तुं एतत् रेडियो बटनं पश्यन्तु ।"

#. Tag: menuchoice
#: index.docbook:313
#, no-c-format
msgid ""
"<guimenu>Slider orientation (system tray popup)</guimenu> "
"<guimenuitem>Horizontal/Vertical</guimenuitem>"
msgstr ""
"<guimenu>स्लाइडर अभिविन्यास (प्रणाली ट्रे पॉपअप)</guimenu> <guimenuitem>क्षैतिज/"
"ऊर्ध्वाधर</guimenuitem>"

#. Tag: para
#: index.docbook:317
#, no-c-format
msgid ""
"Same as the previous two radio buttons but for the system tray volume "
"control (the panel that is shown after &LMB; click on &kmix; tray icon)."
msgstr ""
"पूर्वयोः रेडियो-बटनयोः समानं किन्तु सिस्टम् ट्रे वॉल्यूम् नियन्त्रणस्य कृते (&LMB; &kmix; ट्रे "
"चिह्नस्य उपरि क्लिक् कृत्वा यत् पटलं दर्शितं भवति) ।"

#. Tag: title
#: index.docbook:324
#, no-c-format
msgid "Start configuration"
msgstr "विन्यासः आरभत"

#. Tag: screeninfo
#: index.docbook:328
#, no-c-format
msgid "<screeninfo>Start configuration of &kmix;</screeninfo>"
msgstr "<screeninfo>&kmix;</screeninfo> इत्यस्य विन्यासम् आरभत"

#. Tag: phrase
#: index.docbook:334
#, no-c-format
msgid "<phrase>Start configuration of &kmix;</phrase>"
msgstr "<phrase>&kmix;</phrase> इत्यस्य विन्यासः आरभत"

#. Tag: para
#: index.docbook:338
#, no-c-format
msgid "This page allows you to configure various &kmix; start parameters."
msgstr "एतत् पृष्ठं भवन्तं विविधानि &kmix; start parameters इति ।"

#. Tag: menuchoice
#: index.docbook:342
#, no-c-format
msgid ""
"<guimenu>Startup</guimenu> <guimenuitem>Start KMix on desktop startup</"
"guimenuitem>"
msgstr ""
"<guimenu>प्रारम्भः</guimenu> <guimenuitem>डेस्कटॉप् प्रारम्भे KMix आरभत</guimenuitem>"

#. Tag: action
#: index.docbook:346
#, no-c-format
msgid "Check this box to enable &kmix; autostart with desktop environment."
msgstr "&kmix; डेस्कटॉप वातावरणेन सह autostart कुर्वन्तु।"

#. Tag: menuchoice
#: index.docbook:350
#, no-c-format
msgid ""
"<guimenu>Startup</guimenu> <guimenuitem>Restore previous volume settings on "
"desktop startup</guimenuitem>"
msgstr ""
"<guimenu>प्रारम्भ</guimenu> <guimenuitem>डेस्कटॉप् स्टार्टअप</guimenuitem> इत्यत्र "
"पूर्ववर्ती आयतनसेटिंग्स् पुनः स्थापयन्तु"

#. Tag: action
#: index.docbook:354
#, no-c-format
msgid ""
"Check this box to enable volume levels and switches restoration to their "
"last used settings on desktop start."
msgstr ""
"आयतनस्तरं सक्षमं कर्तुं एतत् पेटी चिनोतु तथा च डेस्कटॉप् आरम्भे पुनर्स्थापनं तेषां "
"अन्तिमप्रयुक्तसेटिंग्स् प्रति स्विच करोति ।"

#. Tag: para
#: index.docbook:356
#, no-c-format
msgid ""
"The volume of PulseAudio or MPRIS2 dynamic controls will not be restored."
msgstr "PulseAudio अथवा MPRIS2 गतिशीलनियन्त्रणानां आयतनं पुनः न स्थापितं भविष्यति ।"

#. Tag: title
#: index.docbook:367
#, no-c-format
msgid "Volume control configuration"
msgstr "मात्रा नियन्त्रण विन्यास"

#. Tag: screeninfo
#: index.docbook:371
#, no-c-format
msgid "<screeninfo>Volume control configuration of &kmix;</screeninfo>"
msgstr "<screeninfo>&kmix;</screeninfo> इत्यस्य आयतननियन्त्रणविन्यासः"

#. Tag: phrase
#: index.docbook:377
#, no-c-format
msgid "<phrase>Volume control configuration of &kmix;</phrase>"
msgstr "<phrase>&kmix;</phrase> इत्यस्य आयतननियन्त्रणविन्यासः"

#. Tag: para
#: index.docbook:381
#, no-c-format
msgid ""
"This page allows you to configure various &kmix; popup volume control "
"parameters."
msgstr "एतत् पृष्ठं भवन्तं विविधानि &kmix; popup मात्रा नियन्त्रण पैरामीटर्स।"

#. Tag: guilabel
#: index.docbook:385
#, no-c-format
msgid "Dock in system tray"
msgstr "सिस्टम् ट्रे मध्ये डॉक"

#. Tag: action
#: index.docbook:387
#, no-c-format
msgid "Check this box to dock &kmix; in system tray."
msgstr "डॉक् कर्तुं एतत् पेटीं चिनोतु &kmix; सिस्टम् ट्रे इत्यत्र ।"

#. Tag: para
#: index.docbook:391
#, no-c-format
msgid ""
"It is possible to select mixers that will be shown in the volume control "
"using the corresponding list on this page."
msgstr ""
"अस्मिन् पृष्ठे तत्सम्बद्धसूचिकायाः उपयोगेन मात्रानियन्त्रणे दर्शयिष्यमाणानां मिश्रणानां चयनं कर्तुं "
"शक्यते ।"

#. Tag: title
#: index.docbook:400
#, no-c-format
msgid "Advanced usage"
msgstr "उन्नतप्रयोगः"

#. Tag: title
#: index.docbook:402
#, no-c-format
msgid "Remote controlling and scripting via &DBus;"
msgstr "&DBus मार्गेण दूरनियन्त्रणं स्क्रिप्टिङ्ग् च;"

#. Tag: para
#: index.docbook:403
#, no-c-format
msgid ""
"You can control &kmix; via &DBus;. This is for advanced users who want to "
"achieve special tasks, like muting the PC every day at 10 pm, or for any "
"other scripting task."
msgstr ""
"भवन्तः &kmix; via &DBus;. एतत् उन्नतप्रयोक्तृणां कृते अस्ति ये विशेषकार्यं प्राप्तुम् इच्छन्ति, "
"यथा प्रतिदिनं रात्रौ १० वादने PC म्यूट् करणं, अन्यस्य वा स्क्रिप्टिङ्ग् कार्यस्य कृते ।"

#. Tag: para
#: index.docbook:407
#, no-c-format
msgid "List all &kmix; related &DBus; methods and properties"
msgstr "सर्वाणि सूचीकृत्य &kmix; सम्बन्धित &DBus; विधयः गुणाः च"

#. Tag: programlisting
#: index.docbook:409
#, no-c-format
msgid "qdbus org.kde.kmix"
msgstr "qdbus org.kde.kmix"

#. Tag: para
#: index.docbook:412
#, no-c-format
msgid "Getting volume level (0-100%):"
msgstr "आयतनस्तरं (०-१००%) प्राप्तुं :"

#. Tag: programlisting
#: index.docbook:414
#, no-c-format
msgid ""
"qdbus org.kde.kmix /Mixers/0/Master_0 org.freedesktop.DBus.Properties.Get "
"org.kde.KMix.Control volume"
msgstr ""
"qdbus org.kde.kmix /Mixers/0/Master_0 org.freedesktop.DBus.Properties.Get "
"org.kde.KMix.Control आयतन"

#. Tag: para
#: index.docbook:417
#, no-c-format
msgid "Setting volume level (0-100%):"
msgstr "आयतनस्तरं (0-100%) सेट् करणम् :"

#. Tag: programlisting
#: index.docbook:419
#, no-c-format
msgid ""
"qdbus org.kde.kmix /Mixers/0/Master_0 org.freedesktop.DBus.Properties.Set "
"org.kde.KMix.Control volume 70"
msgstr ""
"qdbus org.kde.kmix /Mixers/0/Master_0 org.freedesktop.DBus.Properties.Set "
"org.kde.KMix.Control आयतन 70"

