"    <prop name=\"template\">%{@id}</prop>\n"
"   </field>\n"
"\n"
"  </fields>\n"
"]]>"
msgstr ""
"<![सीडीएटीए[\n"
"  <क्षेत्राणि>\n"
"   <field flags=\"8\" title=\"शीर्षक\" category=\"सामान्य\" format=\"1\" type="
"\"1\" name=\"शीर्षक\" />\n"
"   <field flags=\"7\" title=\"लेखक\" category=\"सामान्य\" format=\"2\" type="
"\"1\" name=\"लेखक\" />\n"
"   <field flags=\"2\" title=\"बाइंडिंग\" category=\"सामान्य\" allowed=\"हार्डबैक;"
"पेपरबैक;व्यापार पेपरबैक;ई-पुस्तक;पत्रिका;जर्नल\" format=\"4\" type=\"3\" name="
"\"banding\" >\n"
"    <prop name=\"default\">कागदपृष्ठ</prop>\n"
"   </field> इति\n"
"   <field flags=\"6\" title=\"प्रकाशक\" category=\"प्रकाशन\" format=\"0\" type="
"\"1\" name=\"प्रकाशक\" />\n"
"   <field flags=\"4\" title=\"संस्करण\" category=\"प्रकाशन\" format=\"0\" type="
"\"1\" name=\"संस्करण\" />\n"
"   <field flags=\"3\" title=\"प्रतिलिपिधर्म वर्ष\" category=\"प्रकाशन\" format="
"\"4\" type=\"6\" name=\"cr_year\" />\n"
"   <field flags=\"2\" title=\"प्रकाशनवर्ष\" category=\"प्रकाशन\" format=\"4\" "
"type=\"6\" name=\"प्रकाशनवर्ष\" />\n"
"   <field flags=\"0\" title=\"ISBN#\" category=\"प्रकाशन\" format=\"4\" type="
"\"1\" name=\"isbn\" description=\"अन्तर्राष्ट्रीय मानक पुस्तक संख्या\" />\n"
"   <field flags=\"7\" title=\"विधा\" category=\"वर्गीकरण\" format=\"0\" type="
"\"1\" name=\"विधा\" />\n"
"   <field flags=\"7\" title=\"कीवर्ड\" category=\"वर्गीकरण\" format=\"0\" type="
"\"1\" name=\"कीवर्ड\" />\n"
"   <field flags=\"0\" title=\"अग्रे आवरण\" category=\"अग्रभाग\" format=\"4\" "
"type=\"10\" name=\"कवर\" />\n"
"   <field flags=\"0\" title=\"टिप्पणियाँ\" category=\"व्यक्तिगत\" format=\"4\" "
