#. Tag: title
#: menus.docbook:2
#, no-c-format
msgid "Command Reference"
msgstr "आदेश सन्दर्भ"

#. Tag: title
#: menus.docbook:13
#, no-c-format
msgid "The Main &tellico; Window"
msgstr "मुख्यं &tellico; कोष्ठ"

#. Tag: para
#: menus.docbook:15
#, no-c-format
msgid ""
"Each menu item is discussed below. When there is a keyboard shortcut that "
"performs a menu item function, the default shortcut is listed with the menu "
"item."
msgstr ""
"प्रत्येकं मेनू-वस्तु अधः चर्चा कृता अस्ति । यदा कीबोर्ड-शॉर्टकट् अस्ति यः मेनू-वस्तु-कार्यं करोति "
"तदा पूर्वनिर्धारितः शॉर्टकट् मेनू-वस्तुना सह सूचीकृतः भवति ।"

#. Tag: title
#: menus.docbook:20
#, no-c-format
msgid "The File Menu"
msgstr "सञ्चिकामेनू इति"

#. Tag: menuchoice
#: menus.docbook:27
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>New</guimenuitem>"
msgstr "<guimenu>सञ्चिका</guimenu> <guimenuitem>नवीन</guimenuitem>"

#. Tag: para
#: menus.docbook:34
#, no-c-format
msgid ""
"This command <action>creates a new collection</action>. &tellico; supports "
"<link linkend=\"collection-types\">12 default collection types</link> along "
"with an empty user-defined custom collection. Any custom-saved collection "
"templates will also be available."
msgstr ""
"एषः आदेशः<action> नूतनं संग्रहं निर्माति</action> . &amp;tellico; समर्थयति<link "
"linkend=\"collection-types\"> १२ पूर्वनिर्धारितसङ्ग्रहप्रकाराः</link> रिक्तेन "
"उपयोक्तृनिर्धारितेन इष्टसङ्ग्रहेण सह । यत्किमपि कस्टम-रक्षितं संग्रह-सारूप्यम् अपि उपलभ्यते ।"

#. Tag: menuchoice
#: menus.docbook:40
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>O</keycap></keycombo> </shortcut> "
"<guimenu>File</guimenu> <guimenuitem>Open...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>O</keycap></keycombo> </shortcut> "
"<guimenu>सञ्चिका</guimenu> <guimenuitem>उद्घाट्य...</guimenuitem>"

#. Tag: para
#: menus.docbook:50
#, no-c-format
msgid "This command <action>opens a &tellico; file</action>."
msgstr "एषः <action>आदेशः &tellico; सञ्चिका</action> इति ।"

#. Tag: menuchoice
#: menus.docbook:56
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Open Recent</guimenuitem>"
msgstr "<guimenu>सञ्चिका</guimenu> <guimenuitem>अद्यतनं</guimenuitem> उद्घाटयतु"

#. Tag: para
#: menus.docbook:63
#, no-c-format
msgid ""
"This command <action>opens a file</action> from a submenu that contains a "
"list of recently opened files."
msgstr ""
"अयं <action>आदेशः उपमेनूतः सञ्चिकां</action> उद्घाटयति यस्मिन् सद्यः उद्घाटितानां "
"सञ्चिकानां सूची भवति ।"

#. Tag: menuchoice
#: menus.docbook:70
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>S</keycap></keycombo> </shortcut> "
"<guimenu>File</guimenu> <guimenuitem>Save...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>S</keycap></keycombo> </shortcut> "
"<guimenu>सञ्चिका</guimenu> <guimenuitem>रक्षतु...</guimenuitem>"

#. Tag: para
#: menus.docbook:80
#, no-c-format
msgid ""
"This command <action>saves the collection</action>. If the file is "
"<emphasis>Untitled</emphasis> then <guimenuitem>Save...</guimenuitem> is "
"equivalent to <guimenuitem>Save As</guimenuitem>. It is only enabled when "
"the collection has been modified."
msgstr ""
"एषः आदेशः <action>सङ्ग्रहं रक्षति</action> । यदि सञ्चिका <emphasis>अनामिका</"
"emphasis> अस्ति तर्हि <guimenuitem>रक्षतु...</guimenuitem> <guimenuitem>यथा "
"रक्षतु</guimenuitem> इत्यस्य तुल्यम् अस्ति । संग्रहः परिवर्तितः चेत् एव सक्षमः भवति ।"

#. Tag: menuchoice
#: menus.docbook:89
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;&Shift;<keycap>S</keycap></keycombo> </shortcut> "
"<guimenu>File</guimenu> <guimenuitem>Save As...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;&Shift;<keycap>S</keycap></keycombo> </shortcut> "
"<guimenu>सञ्चिका</guimenu> <guimenuitem>यथा रक्षतु...</guimenuitem>"

#. Tag: para
#: menus.docbook:99
#, no-c-format
msgid "This command <action>saves the collection to a new file</action>."
msgstr "एषः आदेशः <action>सङ्ग्रहं नूतनसञ्चिकायां रक्षति</action> ।"

#. Tag: menuchoice
#: menus.docbook:105
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Save As Template...</guimenuitem>"
msgstr "<guimenu>सञ्चिका</guimenu> <guimenuitem>सारूप्यरूपेण रक्षतु...</guimenuitem>"

#. Tag: para
#: menus.docbook:112
#, no-c-format
msgid ""
"This command <action>saves the collection as a new template</action>. Only "
"the fields are saved, and the custom collection type can be created via the "
"<guimenuitem>New Collection</guimenuitem> command."
msgstr ""
"एषः आदेशः <action>सङ्ग्रहं नूतनं टेम्पलेट्</action>रूपेण रक्षति । केवलं क्षेत्राणि रक्षिताः "
"भवन्ति, तथा च <guimenuitem>नवसङ्ग्रहः</guimenuitem> आदेशेन इष्टसङ्ग्रहप्रकारः निर्मातुं "
"शक्यते ।"

#. Tag: menuchoice
#: menus.docbook:118
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>P</keycap></keycombo> </shortcut> "
"<guimenu>File</guimenu> <guimenuitem>Print...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>P</keycap></keycombo> </shortcut> "
"<guimenu>सञ्चिका</guimenu> <guimenuitem>मुद्रणं...</guimenuitem>"

#. Tag: para
#: menus.docbook:128
#, no-c-format
msgid ""
"This command <action>prints the collection</action>. Printing options may be "
"set in the <interface>Configuration Dialog</interface>."
msgstr ""
"एषः आदेशः <action>सङ्ग्रहं</action> मुद्रयति । मुद्रणविकल्पाः "
"<interface>Configuration Dialog</interface> इत्यत्र सेट् कर्तुं शक्यन्ते ।"

#. Tag: menuchoice
#: menus.docbook:134
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Print Preview</guimenuitem>"
msgstr "<guimenu>सञ्चिका</guimenu> <guimenuitem>मुद्रणपूर्वावलोकनम्</guimenuitem>"

#. Tag: para
#: menus.docbook:141
#, no-c-format
msgid ""
"This command <action>shows a preview of the printed collection</action>."
msgstr "एषः आदेशः <action>मुद्रितसङ्ग्रहस्य पूर्वावलोकनं दर्शयति</action> ।"

#. Tag: menuchoice
#: menus.docbook:147
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Import</guimenuitem>"
msgstr "<guimenu>सञ्चिका</guimenu> <guimenuitem>आयात</guimenuitem>"

#. Tag: para
#: menus.docbook:154
#, no-c-format
msgid ""
"This command <action>imports data from another file</action>. &tellico; can "
"import data from a number of <link linkend=\"importing\">other formats</"
"link>."
msgstr ""
"एषः आदेशः<action> अन्यस्मात् सञ्चिकातः दत्तांशं आयातयति</action> . &amp;tellico; "
"सङ्ख्यातः दत्तांशं आयातयितुं शक्नोति<link linkend=\"importing\"> अन्ये प्रारूपाः</link> ."

#. Tag: menuchoice
#: menus.docbook:160
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Export</guimenuitem>"
msgstr "<guimenu>सञ्चिका</guimenu> <guimenuitem>निर्यात</guimenuitem>"

#. Tag: para
#: menus.docbook:167
#, no-c-format
msgid ""
"This command <action>exports the collection to another format</action>. "
"&tellico; can export data to a number of <link linkend=\"exporting\">other "
"formats</link>."
msgstr ""
"एषः आदेशः<action> संग्रहं अन्यस्मिन् प्रारूपे निर्यातयति</action> . &amp;tellico; "
"सङ्ख्यायां दत्तांशं निर्यातयितुं शक्नोति<link linkend=\"exporting\"> अन्ये प्रारूपाः</"
"link> ."

#. Tag: menuchoice
#: menus.docbook:173
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>Q</keycap></keycombo> </shortcut> "
"<guimenu>File</guimenu> <guimenuitem>Quit</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>प्रश्न</keycap></keycombo> </shortcut> "
"<guimenu>सञ्चिका</guimenu> <guimenuitem>निर्गम</guimenuitem>"

#. Tag: para
#: menus.docbook:183
#, no-c-format
msgid ""
"This command <action>closes the &tellico; window</action>. If the collection "
"has unsaved changes, you will be prompted to save them before continuing."
msgstr ""
"एषः <action>आदेशः &tellico; विण्डो</action> इति । यदि संग्रहे अरक्षिताः परिवर्तनाः "
"सन्ति तर्हि भवन्तः अग्रे गन्तुं पूर्वं तान् रक्षितुं प्रेरिताः भविष्यन्ति ।"

#. Tag: title
#: menus.docbook:193
#, no-c-format
msgid "The Edit Menu"
msgstr "सम्पादन मेनू इति"

#. Tag: menuchoice
#: menus.docbook:201
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>Z</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Undo</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>Z</keycap></keycombo> </shortcut> "
"<guimenu>सम्पादनं</guimenu> <guimenuitem>अवस्थापयतु</guimenuitem>"

#. Tag: para
#: menus.docbook:211
#, no-c-format
msgid ""
"This command <action>undoes the previous action</action>. Not all actions "
"are supported by Undo."
msgstr ""
"एषः आदेशः <action>पूर्वं कर्म</action>ं निवर्तयति । सर्वाणि क्रियाणि पूर्ववतद्वारा "
"समर्थितानि न भवन्ति ।"

#. Tag: menuchoice
#: menus.docbook:217
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;&Shift;<keycap>Z</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Redo</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;&Shift;<keycap>Z</keycap></keycombo> </shortcut> "
"<guimenu>सम्पादनं</guimenu> <guimenuitem>पुनः कुरुत</guimenuitem>"

#. Tag: para
#: menus.docbook:227
#, no-c-format
msgid "This command <action>reverts a previous Undo</action>."
msgstr "एषः आदेशः <action>पूर्वं Undo</action>ं प्रत्यागच्छति ।"

#. Tag: menuchoice
#: menus.docbook:233
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>X</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Cut</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>X</keycap></keycombo> </shortcut> "
"<guimenu>सम्पादनं</guimenu> <guimenuitem>कट</guimenuitem>"

#. Tag: para
#: menus.docbook:243
#, no-c-format
msgid ""
"This command <action>removes the selected text</action>, if any, and "
"<action>places a copy of the removed text in the clipboard</action>."
msgstr ""
"एषः आदेशः <action>चयनितपाठं</action>, यदि अस्ति, अपसारयति, "
"<action>निष्कासितपाठस्य प्रतिलिपिं क्लिप्बोर्ड्</action> मध्ये स्थापयति ।"

#. Tag: menuchoice
#: menus.docbook:249
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>C</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Copy</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>C</keycap></keycombo> </shortcut> "
"<guimenu>सम्पादनं</guimenu> <guimenuitem>प्रतिलिपि</guimenuitem>"

#. Tag: para
#: menus.docbook:259
#, no-c-format
msgid ""
"This command <action>copies the selected text</action>, if any, to the "
"clipboard."
msgstr ""
"एषः आदेशः <action>चयनितपाठं</action>, यदि अस्ति, क्लिप्बोर्ड् प्रति प्रतिलिखति ।"

#. Tag: menuchoice
#: menus.docbook:265
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>V</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Paste</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>V</keycap></keycombo> </shortcut> "
"<guimenu>सम्पादनं</guimenu> <guimenuitem>चिपकतु</guimenuitem>"

#. Tag: para
#: menus.docbook:275
#, no-c-format
msgid ""
"This command <action>pastes the text in the clipboard</action>, if any, into "
"the editor at the cursor position."
msgstr ""
"एषः आदेशः <action>क्लिप्बोर्ड्</action> मध्ये पाठं, यदि अस्ति, कर्सरस्थाने सम्पादके चिनोति "
"।"

#. Tag: menuchoice
#: menus.docbook:281
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>A</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Select All</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>A</keycap></keycombo> </shortcut> "
"<guimenu>सम्पादनं</guimenu> <guimenuitem>सर्वं चिनोतु</guimenuitem>"

#. Tag: para
#: menus.docbook:291
#, no-c-format
msgid ""
"This command <action>selects all the entries</action> in the collection, in "
"the <interface>Column View</interface>."
msgstr ""
"एषः आदेशः <action>सङ्ग्रहे, <interface>Column View</interface> इत्यत्र सर्वाणि "
"प्रविष्टयः</action> चिनोति ।"

#. Tag: menuchoice
#: menus.docbook:297
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;&Shift;<keycap>A</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Deselect</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;&Shift;<keycap>A</keycap></keycombo> </shortcut> "
"<guimenu>सम्पादनं</guimenu> <guimenuitem>अचयनं</guimenuitem>"

#. Tag: para
#: menus.docbook:307
#, no-c-format
msgid ""
"This command <action>deselects all the entries</action> in the collection."
msgstr "एषः आदेशः <action>सङ्ग्रहे सर्वाणि प्रविष्टयः</action> विचिनोति ।"

#. Tag: menuchoice
#: menus.docbook:313
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>I</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Internet Search...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>I</keycap></keycombo> </shortcut> "
"<guimenu>सम्पादनं</guimenu> <guimenuitem>अन्तर्जालसन्धानं...</guimenuitem>"

#. Tag: para
#: menus.docbook:323
#, no-c-format
msgid ""
"This command <action>opens the <interface>Internet Search Dialog</"
"interface></action> to search for and import entries from various Internet "
"sites, including <ulink url=\"http://amazon.com\">Amazon.com</ulink>."
msgstr ""
"एषः आदेशः <action> <ulink url=\"http://amazon.com\">Amazon.com इत्यादिभ्यः "
"विभिन्नेभ्यः अन्तर्जालस्थलेभ्यः प्रविष्टीनां अन्वेषणाय आयाताय च "
"<interface>अन्तर्जालसन्धानसंवादः</interface></action> उद्घाटयति </ulink> इति ।"

#. Tag: menuchoice
#: menus.docbook:329
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>J</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Advanced Filter...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>J</keycap></keycombo> </shortcut> "
"<guimenu>सम्पादनं</guimenu> <guimenuitem>उन्नत फ़िल्टर...</guimenuitem>"

#. Tag: para
#: menus.docbook:339
#, no-c-format
msgid ""
"This command <action>opens the <interface>Advanced Filter Dialog</"
"interface></action>."
msgstr ""
"एषः आदेशः <action> <interface>उन्नत-छिद्रसंवाद</interface></action> उद्घाटयति ।"

#. Tag: title
#: menus.docbook:350
#, no-c-format
msgid "The Collection Menu"
msgstr "संग्रहमेनू इति"

#. Tag: menuchoice
#: menus.docbook:357
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>N</keycap></keycombo> </shortcut> "
"<guimenu>Collection</guimenu> <guimenuitem>New Entry</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>N</keycap></keycombo> </shortcut> "
"<guimenu>सङ्ग्रह</guimenu> <guimenuitem>नवीनप्रविष्टिः</guimenuitem>"

#. Tag: para
#: menus.docbook:367
#, no-c-format
msgid ""
"This command <action>opens the <interface>Entry Editor</interface> to edit a "
"new entry</action>."
msgstr ""
"एषः आदेशः <action>नवीनप्रविष्टिं</action> सम्पादयितुं <interface>Entry Editor</"
"interface> उद्घाटयति ।"

#. Tag: menuchoice
#: menus.docbook:373
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>E</keycap></keycombo> </shortcut> "
"<guimenu>Collection</guimenu> <guimenuitem>Edit Entry</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>E</keycap></keycombo> </shortcut> "
"<guimenu>सङ्ग्रह</guimenu> <guimenuitem>प्रविष्टिः सम्पादयतु</guimenuitem>"

#. Tag: para
#: menus.docbook:383
#, no-c-format
msgid ""
"This command <action>opens the <interface>Entry Editor</interface> to edit "
"the selected entries</action>."
msgstr ""
"एषः आदेशः <action>चयनितप्रविष्टीनां सम्पादनार्थं <interface>Entry Editor</"
"interface> उद्घाटयति ।"

#. Tag: menuchoice
#: menus.docbook:389
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>Y</keycap></keycombo> </shortcut> "
"<guimenu>Collection</guimenu> <guimenuitem>Duplicate Entry</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>Y</keycap></keycombo> </shortcut> "
"<guimenu>सङ्ग्रह</guimenu> <guimenuitem>द्वितीयप्रविष्टिः</guimenuitem>"

#. Tag: para
#: menus.docbook:399
#, no-c-format
msgid ""
"This command <action>copies, or duplicates, the selected entries</action> as "
"new entries in the collection."
msgstr ""
"एषः आदेशः <action>चयनितप्रविष्टयः</action> संग्रहे नूतनाः प्रविष्टयः इति प्रतिलिपिं "
"करोति, अथवा द्वितीयकं करोति ।"

#. Tag: menuchoice
#: menus.docbook:405
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>D</keycap></keycombo> </shortcut> "
"<guimenu>Collection</guimenu> <guimenuitem>Delete Entry</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>D</keycap></keycombo> </shortcut> "
"<guimenu>सङ्ग्रह</guimenu> <guimenuitem>प्रविष्टिं विलोपयतु</guimenuitem>"

#. Tag: para
#: menus.docbook:415
#, no-c-format
msgid "This command <action>deletes the selected entries</action>."
msgstr "एषः आदेशः <action>चयनितानि प्रविष्टयः</action> अपास्यति ।"

#. Tag: menuchoice
#: menus.docbook:421
#, no-c-format
msgid "<guimenu>Collection</guimenu> <guimenuitem>Merge Entries</guimenuitem>"
msgstr "<guimenu>सङ्ग्रहः</guimenu> <guimenuitem>प्रविष्टयः विलयन</guimenuitem>"

#. Tag: para
#: menus.docbook:433
#, no-c-format
msgid "This command <action>merges the selected entries</action>."
msgstr "एषः आदेशः <action>चयनितप्रविष्टयः</action> विलीनयति ।"

#. Tag: menuchoice
#: menus.docbook:439
#, no-c-format
msgid "<guimenu>Collection</guimenu> <guimenuitem>Update Entry</guimenuitem>"
msgstr "<guimenu>सङ्ग्रहः</guimenu> <guimenuitem>प्रविष्टिं अद्यतनं कुरुत</guimenuitem>"

#. Tag: para
#: menus.docbook:446
#, no-c-format
msgid ""
"This menu contains a list of all available data sources, and can be used to "
"automatically query the source and <action>update the selected entries</"
"action>."
msgstr ""
"अस्मिन् मेन्यू मध्ये सर्वेषां उपलब्धानां दत्तांशस्रोतानां सूची अस्ति, तथा च स्रोतः स्वयमेव पृच्छितुं "
"<action>चयनितप्रविष्टीनां अद्यतनीकरणाय</action> कर्तुं च उपयोक्तुं शक्यते ।"

#. Tag: menuchoice
#: menus.docbook:453
#, no-c-format
msgid "<guimenu>Collection</guimenu> <guimenuitem>Check-out</guimenuitem>"
msgstr "<guimenu>सङ्ग्रहः</guimenu> <guimenuitem>परीक्षण</guimenuitem>"

#. Tag: para
#: menus.docbook:460
#, no-c-format
msgid ""
"This command <action>opens a dialog box for loaning the selected entries.</"
"action>."
msgstr "एषः आदेशः <action>चयनितप्रविष्टीनां ऋणं दातुं संवादपेटिकां उद्घाटयति ।</action> ।"

#. Tag: menuchoice
#: menus.docbook:466
#, no-c-format
msgid "<guimenu>Collection</guimenu> <guimenuitem>Check-in</guimenuitem>"
msgstr "<guimenu>सङ्ग्रहः</guimenu> <guimenuitem>परीक्षणं कुर्वन्तु</guimenuitem>"

#. Tag: para
#: menus.docbook:473
#, no-c-format
msgid ""
"This command <action>checks-in any of the selected entries which are "
"currently on-loan</action>."
msgstr ""
"एषः आदेशः <action>चयनितप्रविष्टीनां कस्यापि चेक-इनं करोति ये सम्प्रति ऋणं</action> सन्ति "
"।"

#. Tag: menuchoice
#: menus.docbook:479
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>R</keycap></keycombo> </shortcut> "
"<guimenu>Collection</guimenu> <guimenuitem>Rename Collection</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>R</keycap></keycombo> </shortcut> "
"<guimenu>सङ्ग्रह</guimenu> <guimenuitem>सङ्ग्रहस्य नाम परिवर्तनं</guimenuitem>"

#. Tag: para
#: menus.docbook:489
#, no-c-format
msgid ""
"This command <action>opens a dialog box for renaming the collection</action>."
msgstr "एषः आदेशः <action>सङ्ग्रहस्य नामकरणार्थं संवादपेटिकां उद्घाटयति</action> ।"

#. Tag: menuchoice
#: menus.docbook:495
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>U</keycap></keycombo> </shortcut> "
"<guimenu>Collection</guimenu> <guimenuitem>Collection Fields...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>U</keycap></keycombo> </shortcut> "
"<guimenu>सङ्ग्रह</guimenu> <guimenuitem>सङ्ग्रहक्षेत्राणि...</guimenuitem>"

#. Tag: para
#: menus.docbook:505
#, no-c-format
msgid ""
"This command <action>opens the <interface>Collection Fields Dialog</"
"interface></action>."
msgstr ""
"एषः आदेशः <action> <interface>सङ्ग्रहक्षेत्रसंवादः</interface></action> उद्घाटयति ।"

#. Tag: menuchoice
#: menus.docbook:511
#, no-c-format
msgid ""
"<guimenu>Collection</guimenu> <guimenuitem>Generate Reports...</guimenuitem>"
msgstr "<guimenu>सङ्ग्रहः</guimenu> <guimenuitem>रिपोर्ट् जनयन्तु...</guimenuitem>"

#. Tag: para
#: menus.docbook:518
#, no-c-format
msgid ""
"This command <action>opens the <interface>Report Dialog</interface></action> "
"for generating reports about the collection."
msgstr ""
"एषः आदेशः <action>सङ्ग्रहस्य विषये प्रतिवेदनानि जनयितुं <interface>Report Dialog</"
"interface></action> उद्घाटयति ।"

#. Tag: menuchoice
#: menus.docbook:524
#, no-c-format
msgid ""
"<guimenu>Collection</guimenu> <guisubmenu>Bibliography</guisubmenu> "
"<guimenuitem>Convert to Bibliography</guimenuitem>"
msgstr ""
"<guimenu>सङ्ग्रहः</guimenu> <guisubmenu>ग्रन्थसूची</guisubmenu> "
"<guimenuitem>ग्रन्थसूची</guimenuitem> मध्ये परिवर्तनं कुर्वन्तु"

#. Tag: para
#: menus.docbook:532
#, no-c-format
msgid ""
"This command <action>converts a book collection to a bibliography</action> "
"by adding certain fields necessary for Bibtex export, and it is only enabled "
"when a book collection is open."
msgstr ""
"एषः आदेशः <action>पुस्तकसङ्ग्रहं Bibtex निर्यातार्थं आवश्यकानि कानिचन क्षेत्राणि योजयित्वा "
"पुस्तकसङ्ग्रहं ग्रन्थसूचीं</action> परिवर्तयति, तथा च पुस्तकसङ्ग्रहः उद्घाटितः भवति चेत् एव "
"सक्षमः भवति"

#. Tag: menuchoice
#: menus.docbook:538
#, no-c-format
msgid ""
"<guimenu>Collection</guimenu> <guisubmenu>Bibliography</guisubmenu> "
"<guimenuitem>String Macros...</guimenuitem>"
msgstr ""
"<guimenu>सङ्ग्रहः</guimenu> <guisubmenu>ग्रन्थसूची</guisubmenu> "
"<guimenuitem>स्ट्रिंग् मैक्रोस्...</guimenuitem>"

#. Tag: para
#: menus.docbook:546
#, no-c-format
msgid ""
"This command <action>opens a dialog box for editing the Bibtex string "
"macros</action> in the collection. It is only enabled when editing a "
"bibliography."
msgstr ""
"एषः आदेशः <action>सङ्ग्रहे Bibtex स्ट्रिंग् मैक्रोस्</action> सम्पादनार्थं संवादपेटिकां "
"उद्घाटयति । ग्रन्थसूचीं सम्पादयन् एव सक्षमं भवति ।"

#. Tag: menuchoice
#: menus.docbook:552
#, no-c-format
msgid ""
"<guimenu>Collection</guimenu> <guisubmenu>Bibliography</guisubmenu> "
"<guimenuitem>Check for Duplicate Keys</guimenuitem>"
msgstr ""
"<guimenu>सङ्ग्रहः</guimenu> <guisubmenu>ग्रन्थसूची</guisubmenu> "
"<guimenuitem>द्वितीयकुञ्जीनां जाँचं कुर्वन्तु</guimenuitem>"

#. Tag: para
#: menus.docbook:560
#, no-c-format
msgid ""
"This command <action>checks for duplicate Bibtex keys</action> and can "
"filter the collection to show the entries with duplicated keys."
msgstr ""
"एषः आदेशः <action>द्वितीयकानि Bibtex कीलानि</action> परीक्षते तथा च द्वितीयककीलैः "
"सह प्रविष्टयः दर्शयितुं संग्रहं छानयितुं शक्नोति ।"

#. Tag: menuchoice
#: menus.docbook:566
#, no-c-format
msgid ""
"<guimenu>Collection</guimenu> <guisubmenu>Bibliography</guisubmenu> "
"<guimenuitem>Copy Bibtex to Clipboard</guimenuitem>"
msgstr ""
"<guimenu>सङ्ग्रहः</guimenu> <guisubmenu>ग्रन्थसूची</guisubmenu> "
"<guimenuitem>बिब्टेक्सं क्लिप्बोर्ड् प्रति प्रतिलिख्यताम्</guimenuitem>"

#. Tag: para
#: menus.docbook:574
#, no-c-format
msgid ""
"This command <action>copies a Bibtex citation</action> to the clipboard so "
"that it can pasted in a LaTeX document."
msgstr ""
"एषः आदेशः <action> Bibtex citation</action> इत्यस्य प्रतिलिपिं क्लिप्बोर्ड् मध्ये करोति "
"येन सः LaTeX दस्तावेजे चिनोतुम् अर्हति ।"

#. Tag: menuchoice
#: menus.docbook:580
#, no-c-format
msgid ""
"<guimenu>Collection</guimenu> <guisubmenu>Bibliography</guisubmenu> "
"<guimenuitem>Cite Entry in Lyx</guimenuitem>"
msgstr ""
"<guimenu>सङ्ग्रहः</guimenu> <guisubmenu>ग्रन्थसूची</guisubmenu> <guimenuitem>Lyx</"
"guimenuitem> इत्यस्मिन् प्रविष्टेः उद्धरणं ददातु"

#. Tag: para
#: menus.docbook:588
#, no-c-format
msgid ""
"This command <action>sends a citation for the selected entries</action> to "
"the so-called <emphasis><link linkend=\"hidden-bibtex-options\">lyxpipe</"
"link></emphasis> for use in <application>LyX</application>, "
"<application>Kile</application>, or other LaTeX applications. It is only "
"enabled when editing a bibliography."
msgstr ""
"एषः आदेशः<action> चयनितप्रविष्टीनां कृते उद्धरणं प्रेषयति</action> "
"तथाकथिताय<emphasis><link linkend=\"hidden-bibtex-options\"> lyxpipe इति</"
"link></emphasis> प्रयोगाय in<application> LyX</application> , ९.<application> "
"किले</application> , अथवा अन्ये LaTeX अनुप्रयोगाः। ग्रन्थसूचीं सम्पादयन् एव सक्षमं भवति ।"

#. Tag: title
#: menus.docbook:599
#, no-c-format
msgid "The Settings and Help Menu"
msgstr "सेटिंग्स् एण्ड् हेल्प् मेन्यू"

#. Tag: para
#: menus.docbook:601
#, no-c-format
msgid ""
"Apart from the common &kde; Settings and Help menus described in the <ulink "
"url=\"help:/fundamentals/menus.html\">Menu</ulink> chapter of the &kde; "
"Fundamentals documentation &tellico; has these application specific menu "
"entries:"
msgstr ""
"सामान्यं विहाय &kde; &kde; मौलिकता दस्तावेजीकरण &tellico; एतानि अनुप्रयोगविशिष्टानि "
"मेनूप्रविष्टयः सन्ति:"

#. Tag: menuchoice
#: menus.docbook:609
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Show Group View</guimenuitem>"
msgstr "<guimenu>सेटिंग्स्</guimenu> <guimenuitem>समूहदृश्यं दर्शयतु</guimenuitem>"

#. Tag: para
#: menus.docbook:616
#, no-c-format
msgid ""
"This command <action>toggles the display of the <interface>Group View</"
"interface></action>."
msgstr ""
"एषः आदेशः <action> <interface>Group View</interface></action> इत्यस्य प्रदर्शनं "
"टॉग्ल् करोति ।"

#. Tag: menuchoice
#: menus.docbook:622
#, no-c-format
msgid ""
"<guimenu>Settings</guimenu> <guimenuitem>Show Entry Editor</guimenuitem>"
msgstr "<guimenu>सेटिंग्स्</guimenu> <guimenuitem>प्रवेशसम्पादकं दर्शयतु</guimenuitem>"

#. Tag: para
#: menus.docbook:629
#, no-c-format
msgid ""
"This command <action>toggles the display of the <interface>Entry Editor</"
"interface></action>."
msgstr ""
"एषः आदेशः <action> <interface>Entry Editor</interface></action> इत्यस्य प्रदर्शनं "
"टॉग्ल् करोति ।"

#. Tag: menuchoice
#: menus.docbook:635
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Group Selection</guimenuitem>"
msgstr "<guimenu>सेटिंग्स्</guimenu> <guimenuitem>समूहचयन</guimenuitem>"

#. Tag: para
#: menus.docbook:642
#, no-c-format
msgid ""
"This command <action>changes the field used to group the entries</action> in "
"the collection."
msgstr ""
"एषः आदेशः <action>सङ्ग्रहे प्रविष्टीनां समूहीकरणाय प्रयुक्तं क्षेत्रं</action> परिवर्तयति ।"

#. Tag: menuchoice
#: menus.docbook:648
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Lock Layout</guimenuitem>"
msgstr "<guimenu>सेटिंग्स्</guimenu> <guimenuitem>विन्यासः ताडयन्तु</guimenuitem>"

#. Tag: para
#: menus.docbook:655
#, no-c-format
msgid ""
"This command <action>locks the layout</action> such that the various "
"collection views cannot be moved. Unlocking the layout allows the user to "
"rearrange them."
msgstr ""
"एषः आदेशः <action>विन्यासं</action> ताडयति यथा विविधाः संग्रहदृश्यानि चालयितुं न "
"शक्यन्ते । विन्यासस्य अनलॉक् करणेन उपयोक्ता तान् पुनः व्यवस्थितुं शक्नोति ।"

#. Tag: menuchoice
#: menus.docbook:661
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Reset Layout</guimenuitem>"
msgstr ""
"<guimenu>सेटिंग्स्</guimenu> <guimenuitem>विन्यासः पुनः सेट् कुर्वन्तु</guimenuitem>"

#. Tag: para
#: menus.docbook:668
#, no-c-format
msgid ""
"This command <action>resets the layout</action> to the default view, which "
"may be helpful if the various views become hidden or collapsed."
msgstr ""
"एषः आदेशः <action>विन्यासं</action> पूर्वनिर्धारितदृश्यं प्रति पुनः सेट् करोति, यत् यदि "
"विविधानि दृश्यानि गुप्ताः अथवा संकुचिताः भवन्ति तर्हि सहायकं भवितुम् अर्हति ।"

#. Tag: menuchoice
#: menus.docbook:674
#, no-c-format
msgid "<guimenu>Help</guimenu> <guimenuitem>Show Log</guimenuitem>"
msgstr "<guimenu>सहायता</guimenu> <guimenuitem>लॉग् दर्शयतु</guimenuitem>"

#. Tag: para
#: menus.docbook:681
#, no-c-format
msgid ""
"When the <userinput>tellico --log</userinput> option is used, this command "
"shows the diagnostic log."
msgstr ""
"यदा <userinput>tellico --log</userinput> विकल्पः उपयुज्यते तदा एषः आदेशः निदानवृत्तं "
"दर्शयति ।"
