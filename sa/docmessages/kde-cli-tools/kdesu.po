"&kdesu; is a graphical front end for the &UNIX; <command>su</command> "
"command."
msgstr "&kdesu; &UNIX; <command>su</command> आदेशः ।"

#. Tag: keyword
#: index.docbook:35
#, no-c-format
msgid "<keyword>KDE</keyword>"
msgstr "<keyword>WHERE</keyword> इति"

#. Tag: keyword
