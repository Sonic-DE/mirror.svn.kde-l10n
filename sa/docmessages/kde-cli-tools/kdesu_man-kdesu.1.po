#. Tag: author
#: man-kdesu.1.docbook:9
#, no-c-format
msgid "&Lauri.Watts; &Lauri.Watts.mail;"
msgstr "&लौरी.वाट्स; &लौरी.वाट्स.मेल;"

#. Tag: date
#: man-kdesu.1.docbook:10
#, no-c-format
msgid "2010-09-18"
msgstr "२०१०-०९-१८"

#. Tag: productname
#: man-kdesu.1.docbook:11
#, no-c-format
msgid "K Desktop Environment"
msgstr "K डेस्कटॉप वातावरण"

#. Tag: manvolnum
#: man-kdesu.1.docbook:16
#, no-c-format
msgid "<manvolnum>1</manvolnum>"
msgstr "<मन्वोल्नुम्>१</मन्वोल्नुम्>"

#. Tag: refpurpose
#: man-kdesu.1.docbook:21
#, no-c-format
msgid "Runs a program with elevated privileges"
msgstr "उन्नतविशेषाधिकारयुक्तं कार्यक्रमं चालयति"

#. Tag: cmdsynopsis
