#. Tag: para
#: index.docbook:35
#, no-c-format
msgid "&kapptemplate; is a generator of new software projects using templates."
msgstr ""
"&kapptemplate; टेम्पलेट् इत्यस्य उपयोगेन नूतनानां सॉफ्टवेयर परियोजनानां जनरेटरः अस्ति ।"

#. Tag: keyword
#: index.docbook:41
#, no-c-format
msgid "programming"
msgstr "प्रोग्रामिंग"

#. Tag: keyword
#: index.docbook:42
#, no-c-format
