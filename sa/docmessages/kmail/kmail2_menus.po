msgstr "<screeninfo>सहायतामेनू</screeninfo>"

#. Tag: phrase
#: menus.docbook:1331 menus.docbook:2044
#, no-c-format
msgid "<phrase>The Help Menu</phrase>"
msgstr "<phrase>सहायतामेनू</phrase> इति"

#. Tag: para
#: menus.docbook:1334 menus.docbook:2047
#, no-c-format
msgid "<para>The Help Menu</para>"
msgstr "<para>सहायतामेनू</para>"

#. Tag: para
#: menus.docbook:1340
#, no-c-format
msgid ""
"This is the <ulink url=\"help:/fundamentals/menus.html#menus-help\">Help "
"Menu</ulink> of the &kde; Fundamentals, with one additional item."
msgstr "एतत् &kde; मौलिकाः, एकेन अतिरिक्तेन द्रव्येण सह।"

#. Tag: menuchoice
#: menus.docbook:1345
#, no-c-format
msgid "<guimenu>Help</guimenu><guimenuitem>&kmail; Introduction</guimenuitem>"
msgstr "<guimenu>सहायतां</guimenu><guimenuitem>&kmail; आमुख"

#. Tag: para
#: menus.docbook:1346
#, no-c-format
msgid "Opens the <link linkend=\"intro\">Introduction</link> welcome screen."
msgstr "उद्घाटयति<link linkend=\"intro\"> आमुख</link> स्वागतं पटलम्।"

#. Tag: title
#: menus.docbook:1353
#, no-c-format
msgid "The &kmail; Composer Window"
msgstr "इति &kmail; रचनाकार विण्डो"

#. Tag: menuchoice
#: menus.docbook:1375
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>N</keycap></keycombo></"
"shortcut> <guimenu>Message</guimenu><guimenuitem>New Composer</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>N</keycap></keycombo></"
"shortcut> <guimenu>सन्देशः</guimenu><guimenuitem>नव रचयिता</guimenuitem>"

#. Tag: para
#: menus.docbook:1377
#, no-c-format
msgid "Opens a new composer window so you can create a message."
msgstr "नूतनं संगीतकारविण्डो उद्घाटयति येन भवान् सन्देशं निर्मातुम् अर्हति ।"

#. Tag: menuchoice
#: menus.docbook:1397
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>Return</keycap></"
"keycombo></shortcut> <guimenu>Message</guimenu><guimenuitem>Send Mail</"
"guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>पुनरागमन</keycap></"
"keycombo></shortcut> <guimenu>सन्देशः</guimenu><guimenuitem>मेल प्रेषयतु</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:1399
#, no-c-format
msgid ""
"Sends the message immediately. If you use &SMTP; to send your messages and "
"the &SMTP; server is not reachable, the message will remain in the outbox "
"and you will get an error message. After the connection issues have been "
"resolved, you can send the messages in the outbox using <link linkend="
"\"reader-send-queued-messages\"><menuchoice><guimenu>File</"
"guimenu><guimenuitem>Send Queued Messages</guimenuitem></menuchoice></link> "
"(in the reader window)."
msgstr ""
"तत्क्षणमेव सन्देशं प्रेषयति। यदि भवान् &amp;SMTP; भवतः सन्देशान् प्रेषयितुं &amp;SMTP; सर्वरः "
"न प्राप्यते, सन्देशः बहिःपेटिकायां तिष्ठति तथा च भवन्तः त्रुटिसन्देशं प्राप्नुवन्ति । "
"संयोजनसमस्यानां निराकरणानन्तरं भवान् उपयोगेन बहिःपेटिकायां सन्देशान् प्रेषयितुं शक्नोति<link "
"linkend=\"reader-send-queued-messages\"><menuchoice><guimenu> संचिका</"
"guimenu><guimenuitem> कतारबद्धसन्देशान् प्रेषयन्तु</guimenuitem></menuchoice></link> "
"(पाठकविण्डोमध्ये)।"

#. Tag: menuchoice
#: menus.docbook:1407
#, no-c-format
msgid "<guimenu>Message</guimenu><guimenuitem>Send Mail Via &gt;</guimenuitem>"
msgstr "<guimenu>सन्देशः</guimenu><guimenuitem>&gt;</guimenuitem> मार्गेण मेल प्रेषयतु"

#. Tag: para
#: menus.docbook:1408
#, no-c-format
msgid ""
"Allows you to specify which outgoing mail server will be used to send the "
"message."
msgstr "सन्देशं प्रेषयितुं कस्य बहिर्गच्छन् मेलसर्वरस्य उपयोगः भविष्यति इति निर्दिष्टुं शक्नोति ।"

#. Tag: menuchoice
#: menus.docbook:1412
#, no-c-format
msgid "<guimenu>Message</guimenu><guimenuitem>Send Later</guimenuitem>"
msgstr "<guimenu>सन्देशः</guimenu><guimenuitem>पश्चात् प्रेषयतु</guimenuitem>"

#. Tag: para
#: menus.docbook:1413
#, no-c-format
msgid ""
"Launches the send later dialog. Please see the <ulink url=\"help:/"
"akonadi_sendlater_agent\">Send Later</ulink> documentation for details."
msgstr ""
"पश्चात् प्रेषयतु संवादं प्रारभते । कृपया विवरणार्थं <ulink url=\"help:/"
"akonadi_sendlater_agent\">पश्चात् प्रेषयतु</ulink> इति दस्तावेजं पश्यन्तु ।"

#. Tag: menuchoice
#: menus.docbook:1418
#, no-c-format
msgid ""
"<guimenu>Message</guimenu><guimenuitem>Send Later Via &gt;</guimenuitem>"
msgstr ""
"<guimenu>सन्देशः</guimenu><guimenuitem>पश्चात् &gt;</guimenuitem>द्वारा प्रेषयतु"

#. Tag: para
#: menus.docbook:1419
#, no-c-format
msgid ""
"Allows you to specify which outgoing mail server will be used to send the "
"delayed message."
msgstr ""
"विलम्बितसन्देशं प्रेषयितुं कस्य बहिर्गच्छन् मेलसर्वरस्य उपयोगः भविष्यति इति निर्दिष्टुं शक्नोति ।"

#. Tag: menuchoice
#: menus.docbook:1424
#, no-c-format
msgid "<guimenu>Message</guimenu><guimenuitem>Save as File</guimenuitem>"
msgstr "<guimenu>सन्देशः</guimenu><guimenuitem>सञ्चिकारूपेण रक्षतु</guimenuitem>"

#. Tag: para
#: menus.docbook:1425
#, no-c-format
msgid ""
"Saves the message as a file. Three formats are supported: Rich Text (.html), "
"plain text (.txt), and Open Document Format (.odt)."
msgstr ""
"सन्देशं सञ्चिकारूपेण रक्षति । त्रयः प्रारूपाः समर्थिताः सन्ति : Rich Text (.html), plain "
"text (.txt), Open Document Format (.odt) च ।"

#. Tag: menuchoice
#: menus.docbook:1430
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>S</keycap></keycombo></"
"shortcut> <guimenu>Message</guimenu><guimenuitem>Save as Draft</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>S</keycap></keycombo></"
"shortcut> <guimenu>सन्देशः</guimenu><guimenuitem>मसौदेरूपेण रक्षतु</guimenuitem>"

#. Tag: para
#: menus.docbook:1432
#, no-c-format
msgid ""
"Saves the message in the <guilabel>drafts</guilabel> folder so you can "
"finish it later."
msgstr ""
"सन्देशं <guilabel>drafts</guilabel> पुटे रक्षति येन भवन्तः पश्चात् समाप्तुं शक्नुवन्ति ।"

#. Tag: menuchoice
#: menus.docbook:1437
#, no-c-format
msgid "<guimenu>Message</guimenu><guimenuitem>Save as Template</guimenuitem>"
msgstr "<guimenu>सन्देशः</guimenu><guimenuitem>सारूप्यरूपेण रक्षन्तु</guimenuitem>"

#. Tag: para
#: menus.docbook:1438
#, no-c-format
msgid ""
"Lets you save your message as a template. Please see <link linkend=\"new-"
"compose-from-templates\">Compose from templates</link> for more information."
msgstr ""
"भवन्तः स्वसन्देशं टेम्पलेट् रूपेण रक्षितुं शक्नुवन्ति । कृपया पश्यन्तु<link linkend=\"new-compose-"
"from-templates\"> टेम्पलेट् तः रचयतु</link> अधिकविवरणार्थं।"

#. Tag: menuchoice
#: menus.docbook:1443
#, no-c-format
msgid ""
"<guimenu>Message</guimenu><guimenuitem>Insert Text File...</guimenuitem>"
msgstr ""
"<guimenu>सन्देशः</guimenu><guimenuitem>पाठसञ्चिकां सम्मिलितं कुर्वन्तु...</guimenuitem>"

#. Tag: para
#: menus.docbook:1444
#, no-c-format
msgid ""
"Inserts a text file into the message text, starting at the cursor position."
msgstr "कर्सरस्थानात् आरभ्य सन्देशपाठे पाठसञ्चिकां निवेशयति ।"

#. Tag: menuchoice
#: menus.docbook:1448
#, no-c-format
msgid ""
"<guimenu>Message</guimenu><guimenuitem>Insert Recent Text File &gt;</"
"guimenuitem>"
msgstr ""
"<guimenu>सन्देशः</guimenu><guimenuitem>अद्यतनपाठसञ्चिकां सम्मिलितं कुर्वन्तु></"
"guimenuitem>"

#. Tag: para
#: menus.docbook:1449
#, no-c-format
msgid ""
"Lets you choose from a list of recently inserted text files, and inserts "
"that file into your message. Select <guimenuitem>Clear List</guimenuitem> to "
"clear the list."
msgstr ""
"सद्यः प्रविष्टानां पाठसञ्चिकानां सूचीतः चयनं कर्तुं शक्नोति, तां सञ्चिकां च भवतः सन्देशे "
"निवेशयति । सूचीं स्वच्छं कर्तुं <guimenuitem>सूचीं स्वच्छं कुर्वन्तु</guimenuitem> इति चिनोतु ।"

#. Tag: menuchoice
#: menus.docbook:1454
#, no-c-format
msgid "<guimenu>Message</guimenu><guimenuitem>Print Preview</guimenuitem>"
msgstr "<guimenu>सन्देशः</guimenu><guimenuitem>मुद्रणपूर्वावलोकनम्</guimenuitem>"

#. Tag: para
#: menus.docbook:1455
#, no-c-format
msgid ""
"Opens a print preview window and displays your message, formatted for "
"printing."
msgstr ""
"मुद्रणपूर्वावलोकनविण्डो उद्घाटयति तथा च भवतः सन्देशं प्रदर्शयति, मुद्रणार्थं प्रारूपितम् ।"

#. Tag: menuchoice
#: menus.docbook:1459
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>P</keycap></keycombo></"
"shortcut> <guimenu>Message</guimenu><guimenuitem>Print...</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>P</keycap></keycombo></"
"shortcut> <guimenu>सन्देशः</guimenu><guimenuitem>मुद्रणं...</guimenuitem>"

#. Tag: para
#: menus.docbook:1461
#, no-c-format
msgid "Formats and prints the message you have composed."
msgstr "भवता रचितं सन्देशं स्वरूपयति मुद्रयति च ।"

#. Tag: menuchoice
#: menus.docbook:1465
#, no-c-format
msgid ""
"<guimenu>Message</guimenu><guimenuitem>Share Mail Text... &gt;</guimenuitem>"
msgstr ""
"<guimenu>सन्देशः</guimenu><guimenuitem>मेलपाठं साझां कुरुत... &gt;</guimenuitem>"

#. Tag: para
#: menus.docbook:1466
#, no-c-format
msgid ""
"Lets you make a second copy of your message somewhere else. Four options are "
"provided: Nextcloud (an OSS file-sharing app), Pastebin <ulink url=\"https://"
"pastebin.com\">(a freely available web site)</ulink>, Bluetooth, and Email "
"(opens another composer window, and adds the current message to that new "
"message, as an attachment). This option is not available unless the "
"<guilabel>Share Text</guilabel> plugin is active."
msgstr ""
"भवतः सन्देशस्य द्वितीयं प्रतिलिपिं अन्यत्र कर्तुं शक्नोति । चत्वारः विकल्पाः प्रदत्ताः सन्ति : "
"Nextcloud (OSS सञ्चिका-साझेदारी-अनुप्रयोगः), Pastebin <ulink url=\"https://"
"pastebin.com\">(स्वतन्त्रतया उपलब्धं जालस्थलं)</ulink>, Bluetooth, Email च (अन्यं "
"संगीतकारं उद्घाटयति window, तथा च तस्मिन् नूतने सन्देशे वर्तमानसन्देशं योजयति, संलग्नकरूपेण) । "
"यावत् <guilabel>पाठसाझेदारी</guilabel> प्लगिन् सक्रियः न भवति तावत् एषः विकल्पः "
"उपलब्धः नास्ति ।"

#. Tag: menuchoice
#: menus.docbook:1474
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>W</keycap></keycombo></"
"shortcut> <guimenu>Message</guimenu><guimenuitem>Close</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>W</keycap></keycombo></"
"shortcut> <guimenu>सन्देशः</guimenu><guimenuitem>बन्दं कुरुत</guimenuitem>"

#. Tag: para
#: menus.docbook:1476
#, no-c-format
msgid "Closes this composer window."
msgstr "एतत् संगीतकारविण्डो पिधायति ।"

#. Tag: para
#: menus.docbook:1502
#, no-c-format
msgid ""
"If the menu item you are looking for is missing, please see the <ulink url="
"\"help:/fundamentals/menus.html#menus-edit\">Edit Menu</ulink> section of "
"the &kde; Fundamentals Handbook. The items listed here are &kmail; specific."
msgstr ""
"यदि भवान् अन्विष्यमाणः मेनू-वस्तु अनुपलब्धः अस्ति तर्हि कृपया &kde; मौलिकता पुस्तिका। अत्र "
"सूचीकृतानि वस्तूनि &kmail; विशिष्टः।"

#. Tag: menuchoice
#: menus.docbook:1508
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;&Shift;<keycap>O</keycap></"
"keycombo></shortcut> <guimenu>Edit</guimenu><guimenuitem>Paste as Quotation</"
"guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;&Shift;<keycap>O</keycap></"
"keycombo></shortcut> <guimenu>सम्पादन</guimenu><guimenuitem>उद्धरणरूपेण चिनोतु</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:1510
#, no-c-format
msgid ""
"Pastes the text from the clipboard and marks it as a quotation (&ie;, each "
"line preceded by \"&gt;\" and a space)."
msgstr ""
"क्लिप्बोर्डतः पाठं चिनोति, उद्धरणरूपेण च चिह्नयति (&अर्थात्, प्रत्येकं पङ्क्तिः \"&gt;\" "
"इत्यनेन पूर्वं रिक्तस्थानं च) ।"

#. Tag: menuchoice
#: menus.docbook:1515
#, no-c-format
msgid "<guimenu>Edit</guimenu><guimenuitem>Paste as Attachment</guimenuitem>"
msgstr "<guimenu>सम्पादनं</guimenu><guimenuitem>संलग्नकरूपेण चिनोतु</guimenuitem>"

#. Tag: para
#: menus.docbook:1516
#, no-c-format
msgid ""
"Pastes a file that has been copied to the clipboard (&eg;, by using the "
"&dolphin; file manager) as an attachment."
msgstr ""
"क्लिप्बोर्ड् मध्ये प्रतिलिपिकृतां सञ्चिकां (&dolphin; सञ्चिकाप्रबन्धकस्य उपयोगेन) संलग्नकरूपेण "
"चिनोति ।"

#. Tag: menuchoice
#: menus.docbook:1521
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;&Shift;<keycap>V</keycap></"
"keycombo></shortcut> <guimenu>Edit</guimenu><guimenuitem>Paste Without "
"Formatting</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;&Shift;<keycap>V</keycap></"
"keycombo></shortcut> <guimenu>सम्पादन</guimenu><guimenuitem>स्वरूपणं विना चिनोतु</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:1523
#, no-c-format
msgid ""
"Pastes data from the clipboard as plain text, with no &HTML; formatting."
msgstr "क्लिप्बोर्डतः दत्तांशं साधारणपाठरूपेण चिनोति, यत्र &HTML; स्वरूपणम् ।"

#. Tag: menuchoice
#: menus.docbook:1527
#, no-c-format
msgid "<guimenu>Edit</guimenu><guimenuitem>Clean Spaces</guimenuitem>"
msgstr "<guimenu>सम्पादनं</guimenu><guimenuitem>स्थानानि स्वच्छानि</guimenuitem>"

#. Tag: para
#: menus.docbook:1528
#, no-c-format
msgid ""
"This option supposedly replaces multiple adjacent newline characters or "
"spaces with single line breaks / spaces, but in testing, it apparently does "
"absolutely nothing."
msgstr ""
"एषः विकल्पः कथितरूपेण बहुविधं समीपस्थं नवीनपङ्क्तिवर्णं वा रिक्तस्थानं एकपङ्क्तिविच्छेदैः / "
"रिक्तस्थानैः प्रतिस्थापयति, परन्तु परीक्षणे, प्रत्यक्षतया सर्वथा किमपि न करोति ।"

#. Tag: menuchoice
#: menus.docbook:1533
#, no-c-format
msgid "<guimenu>Edit</guimenu><guimenuitem>Add Quote Characters</guimenuitem>"
msgstr "<guimenu>सम्पादन</guimenu><guimenuitem>उद्धरणवर्णान् योजयतु</guimenuitem>"

#. Tag: para
#: menus.docbook:1534
#, no-c-format
msgid ""
"Prepends each line of the selected text with the quotation indicator (&gt; "
"and a space, by default). If no selection is made, adds the indicator to "
"every line in the message."
msgstr ""
"चयनितपाठस्य प्रत्येकं पङ्क्तिं उद्धरणसूचकेन (&gt; तथा च एकं रिक्तस्थानं, पूर्वनिर्धारितरूपेण) "
"पूर्वं स्थापयति । यदि चयनं न क्रियते तर्हि सन्देशे प्रत्येकं पङ्क्तौ सूचकं योजयति ।"

#. Tag: menuchoice
#: menus.docbook:1539
#, no-c-format
msgid ""
"<guimenu>Edit</guimenu><guimenuitem>Remove Quote Characters</guimenuitem>"
msgstr ""
"<guimenu>सम्पादनं</guimenu><guimenuitem>उद्धरणवर्णान् निष्कासयतु</guimenuitem>"

#. Tag: para
#: menus.docbook:1540
#, no-c-format
msgid "Removes the left-most quotation indicator from the selected text."
msgstr "चयनितपाठात् वामतमं उद्धरणसूचकं निष्कासयति ।"

#. Tag: menuchoice
#: menus.docbook:1544
#, no-c-format
msgid "<guimenu>Edit</guimenu><guimenuitem>Insert Email...</guimenuitem>"
msgstr ""
"<guimenu>सम्पादनं</guimenu><guimenuitem>ईमेल सम्मिलितं कुर्वन्तु...</guimenuitem>"

#. Tag: para
#: menus.docbook:1545
#, no-c-format
msgid ""
"Displays a list of all the names in your address book, then inserts the "
"chosen email address at the cursor position (after you make a selection and "
"click the <guibutton>OK</guibutton> button). This option is only available "
"when the <guimenuitem>Insert Email</guimenuitem> plugin has been loaded."
msgstr ""
"भवतः पतापुस्तके सर्वेषां नामानां सूचीं प्रदर्शयति, ततः कर्सरस्थाने चयनितं ईमेल-सङ्केतं निवेशयति "
"(भवता चयनं कृत्वा <guibutton>OK</guibutton> बटनं नुदित्वा) एषः विकल्पः तदा एव "
"उपलभ्यते यदा <guimenuitem>Email सम्मिलितं</guimenuitem> प्लगिन् लोड् कृतम् अस्ति ।"

#. Tag: menuchoice
#: menus.docbook:1551
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;&Space;</keycombo></shortcut> "
"<guimenu>Edit</guimenu><guimenuitem>Insert Non Breaking Space</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;&Space;</keycombo></shortcut> "
"<guimenu>सम्पादन</guimenu><guimenuitem>अविच्छेदनस्थानं सम्मिलितं</guimenuitem>"

#. Tag: para
#: menus.docbook:1553
#, no-c-format
msgid ""
"Inserts a non breaking space at the cursor position. This option is only "
"available when the <guimenuitem>Insert Non Breaking Space</guimenuitem> "
"plugin has been loaded."
msgstr ""
"कर्सरस्थाने अभङ्गस्थानं निवेशयति । एषः विकल्पः तदा एव उपलब्धः यदा <guimenuitem>Insert "
"Non Breaking Space</guimenuitem> प्लगिन् लोड् कृतम् अस्ति ।"

#. Tag: menuchoice
#: menus.docbook:1574
#, no-c-format
msgid ""
"<guimenu>Edit</guimenu><guimenuitem>Insert Special Character...</guimenuitem>"
msgstr ""
"<guimenu>सम्पादनं</guimenu><guimenuitem>विशेषवर्णं सम्मिलितं कुर्वन्तु...</guimenuitem>"

#. Tag: para
#: menus.docbook:1575
#, no-c-format
msgid ""
"Lets you insert a special character at the cursor position. A large number "
"of Unicode characters are made available. This option is only provided if "
"the <guimenuitem>Insert Special Character</guimenuitem> plugin has been "
"activated."
msgstr ""
"कर्सरस्थाने विशेषवर्णं सम्मिलितुं शक्नोति । बहुसंख्याकाः यूनिकोड्-वर्णाः उपलभ्यन्ते । एषः "
"विकल्पः केवलं तदा एव प्रदत्तः यदा <guimenuitem>विशेषवर्णं निवेशयतु</guimenuitem> प्लगिन् "
"सक्रियः अभवत् ।"

#. Tag: para
#: menus.docbook:1579
#, no-c-format
msgid ""
"This menu item was moved to the <guimenu>Insert</guimenu> menu in release "
"5.17. If you have activated the plugin, and this entry does not appear when "
"&kmail; is restarted, check the <guimenu>Insert</guimenu> menu."
msgstr ""
"एतत् मेन्यू-वस्तु 5.17-विमोचने <guimenu>Insert</guimenu> मेन्यू प्रति स्थानान्तरितम् । यदि "
"भवान् प्लगिन् सक्रियं कृतवान्, तथा च &kmail; पुनः आरभ्यते, <guimenu>Insert</guimenu> "
"मेन्यू पश्यन्तु ।"

#. Tag: menuchoice
#: menus.docbook:1585
#, no-c-format
msgid "<guimenu>Edit</guimenu><guimenuitem>Change Case &gt;</guimenuitem>"
msgstr "<guimenu>सम्पादनं</guimenu><guimenuitem>प्रकरणपरिवर्तनं></guimenuitem>"

#. Tag: para
#: menus.docbook:1586
#, no-c-format
msgid ""
"Helps you modify the capitalization of the selected text. There are four "
"options: <guilabel>Uppercase</guilabel> (capitalizes the selected "
"characters), <guilabel>Lowercase</guilabel> (forces selected text to all "
"lower case), <guilabel>Sentence case</guilabel> (capitalizes the first "
"letter of the selection and makes the rest lower case), and "
"<guilabel>Reverse Case</guilabel> (converts capital letters to lower case, "
"and vice versa). This option is only provided if the <guimenuitem>Change "
"Case</guimenuitem> plugin has been activated. This menu item remains grayed "
"out until some snippet of text has been selected for modification."
msgstr ""
"चयनितपाठस्य दीर्घलेखं परिवर्तयितुं भवन्तं साहाय्यं करोति । तत्र चत्वारः विकल्पाः सन्ति : "
"<guilabel>बृहत्</guilabel> (चयनितवर्णानां दीर्घवर्णं करोति), <guilabel>लघुवर्णं</"
"guilabel> (चयनितपाठं सर्वेभ्यः लघुवर्णेभ्यः बाध्यं करोति), <guilabel>वाक्यप्रकरणं</"
"guilabel> (द... चयनस्य प्रथमं अक्षरं कृत्वा शेषं लघु करोति), तथा च <guilabel>Reverse "
"Case</guilabel> (बृहत् अक्षराणि परिवर्तयति लघुवर्णं प्रति, तद्विपरीतम् च)। एषः विकल्पः "
"केवलं तदा एव प्रदत्तः यदा <guimenuitem>Change Case</guimenuitem> प्लगिन् सक्रियः "
"अभवत् । इदं मेन्यू-वस्तु यावत् परिवर्तनार्थं पाठस्य कश्चन स्निपेट् चयनितः न भवति तावत् ग्रे-रूपेण "
"तिष्ठति ।"

#. Tag: menuchoice
#: menus.docbook:1596
#, no-c-format
msgid "<guimenu>Edit</guimenu><guimenuitem>Zoom... &gt;</guimenuitem>"
msgstr "<guimenu>सम्पादनं</guimenu><guimenuitem>जूम... &gt;</guimenuitem>"

#. Tag: para
#: menus.docbook:1597
#, no-c-format
msgid ""
"Lets you zoom in or zoom out on the message you are composing. This is the "
"same function appearing as <menuchoice><guimenu>View</"
"guimenu><guisubmenu>Zoom &gt;</guisubmenu></menuchoice> in the message "
"preview window. This option is not available unless the <guimenuitem>Zoom "
"Text</guimenuitem> plugin has been loaded."
msgstr ""
"भवन्तः यत् सन्देशं रचयन्ति तस्य जूम-इन् अथवा जूम-आउट् कर्तुं शक्नोति । एतत् "
"सन्देशपूर्वावलोकनविण्डो मध्ये <menuchoice><guimenu>दृश्य</guimenu><guisubmenu>Zoom "
"&gt;</guisubmenu></menuchoice> इति समानं कार्यं दृश्यते । यावत् <guimenuitem>Zoom "
"Text</guimenuitem> प्लगिन् लोड् न भवति तावत् एषः विकल्पः उपलब्धः नास्ति ।"

#. Tag: menuchoice
#: menus.docbook:1604
#, no-c-format
msgid "<guimenu>Edit</guimenu><guimenuitem>Variables &gt;</guimenuitem>"
msgstr "<guimenu>सम्पादन</guimenu><guimenuitem>चर &gt;</guimenuitem>"

#. Tag: para
#: menus.docbook:1605
#, no-c-format
msgid ""
"Lets you insert the contents of a named field at the cursor position. You "
"may choose among <guilabel>To &gt;</guilabel>, <guilabel>From &gt;</"
"guilabel>, <guilabel>CC &gt;</guilabel>, <guilabel>Attachment &gt;</"
"guilabel>, <guilabel>Date/Time &gt;</guilabel>, and <guilabel>Misc &gt;</"
"guilabel> (which has just one associated submenu item, \"Subject\"). There "
"is one notable quirk: the date/time displayed in the submenu selections is "
"fixed at the time the Composer window was opened, but the value actually "
"inserted in a message is taken from the system clock."
msgstr ""
"कर्सरस्थाने नामकृतक्षेत्रस्य सामग्रीं सम्मिलितुं शक्नोति । भवान् <guilabel>To &gt;</"
"guilabel>, <guilabel>From &gt;</guilabel>, <guilabel>CC &gt;</guilabel>, "
"<guilabel>Attachment &gt;</guilabel>, <guilabel> इत्येतयोः मध्ये चयनं कर्तुं शक्नोति "
">तिथिः/समयः &gt;</guilabel>, तथा च <guilabel>Misc &gt;</guilabel> (यस्य "
"अधुना... एकं सम्बद्धं उपमेनू-वस्तु, \"विषयः\") । एकः उल्लेखनीयः विचित्रः अस्ति : "
"उपमेनूचयनयोः प्रदर्शितः तिथिः/समयः तस्मिन् समये नियतः भवति यस्मिन् समये Composer विण्डो "
"उद्घाटितः आसीत्, परन्तु सन्देशे वास्तवतः सम्मिलितं मूल्यं सिस्टम् घण्टातः गृह्यते"

#. Tag: para
#: menus.docbook:1636
#, no-c-format
msgid ""
"This menu lets you toggle the display of the header fields and a few other "
"items in the composer window. Selected items will be marked (check box "
"colored in) in the menu."
msgstr ""
"एतत् मेन्यू भवन्तं कम्पोजर विण्डो मध्ये हेडर् फील्ड्स् इत्यस्य प्रदर्शनं अन्येषां च कतिपयानां वस्तूनि "
"टॉग्ल् कर्तुं शक्नोति । चयनितवस्तूनि मेनूमध्ये चिह्नितानि (चेक् बॉक्स् वर्णितानि) भविष्यन्ति ।"

#. Tag: para
#: menus.docbook:1639
#, no-c-format
msgid "Several options are available:"
msgstr "अनेकाः विकल्पाः उपलभ्यन्ते-"

#. Tag: para
#: menus.docbook:1643
#, no-c-format
msgid ""
"<guimenuitem>All Fields</guimenuitem>. Displays all six of the following "
"fields."
msgstr ""
"<guimenuitem>सर्वक्षेत्राणि</guimenuitem> । निम्नलिखित षट् क्षेत्राणि अपि प्रदर्शयति ।"

#. Tag: para
#: menus.docbook:1646
#, no-c-format
msgid ""
"<guimenuitem>Identity</guimenuitem>. If you have defined more than one "
"identity, this will be a drop down box."
msgstr ""
"<guimenuitem>परिचयः</guimenuitem> । यदि भवान् एकादशाधिकं तादात्म्यं परिभाषितवान् "
"तर्हि एतत् एकं पतत्-पेटी भविष्यति ।"

#. Tag: para
#: menus.docbook:1650
#, no-c-format
msgid ""
"<guimenuitem>Dictionary</guimenuitem> used for spell checking. If multiple "
"dictionaries are installed, this will be a drop down box."
msgstr ""
"<guimenuitem>शब्दकोशः</guimenuitem> वर्तनीपरीक्षायै प्रयुक्तः । यदि बहुविधाः "
"शब्दकोशाः संस्थापिताः सन्ति तर्हि एतत् एकं ड्रॉप् डाउन पेटी भविष्यति ।"

#. Tag: para
#: menus.docbook:1654
#, no-c-format
msgid ""
"<guimenuitem>Sent-Mail Folder</guimenuitem>. The <guilabel>&nbsp;"
"<inlinemediaobject><imageobject> <imagedata fileref=\"document-open.png\" "
"format=\"PNG\"/></imageobject></inlinemediaobject>&nbsp;</guilabel> button "
"appearing on the right when this option is checked opens a folder selection "
"dialog."
msgstr ""
"<guimenuitem>प्रेषित-मेलपुट</guimenuitem> । <guilabel>&nbsp;"
"<inlinemediaobject><imageobject> <imagedata fileref=\"document-open.png\" "
"format=\"PNG\"/></imageobject></inlinemediaobject>&nbsp;</guilabel> बटनं यदा "
"दक्षिणतः दृश्यते एषः विकल्पः परीक्षितः भवति चेत् पुटचयनसंवादं उद्घाटयति ।"

#. Tag: para
#: menus.docbook:1659
#, no-c-format
msgid ""
"<guimenuitem>Mail Transport</guimenuitem>. If you have created more than one "
"outgoing account, this will be a drop down box."
msgstr ""
"<guimenuitem>मेलपरिवहन</guimenuitem> । यदि भवान् एकादशाधिकं बहिर्गच्छन्तं खातं "
"निर्मितवान् तर्हि एतत् एकं ड्रॉप् डाउन पेटी भविष्यति ।"

#. Tag: para
#: menus.docbook:1663
#, no-c-format
msgid ""
"<guimenuitem>From</guimenuitem>. The contents of this field may vary, "
"depending on the Identity you use."
msgstr ""
"<guimenuitem></guimenuitem> इत्यस्मात् । अस्य क्षेत्रस्य सामग्री भिन्ना भवितुम् अर्हति, "
"भवता उपयुज्यमानस्य Identity इत्यस्य आधारेण ।"

#. Tag: para
#: menus.docbook:1666
#, no-c-format
msgid ""
"<guimenuitem>Subject</guimenuitem>. Use this field to describe your message, "
"briefly."
msgstr ""
"<guimenuitem>विषय</guimenuitem> इति । भवतः सन्देशस्य वर्णनार्थं एतत् क्षेत्रं उपयुज्यताम्, "
"संक्षेपेण ।"

#. Tag: para
#: menus.docbook:1670
#, no-c-format
msgid ""
"The <guilabel>To <inlinemediaobject><imageobject><imagedata fileref=\"go-"
"down.png\" format=\"PNG\"/></imageobject> </inlinemediaobject></guilabel> "
"drop down box is always present at the top of the composer window. Use it to "
"select <guilabel>CC</guilabel>, <guilabel>BCC</guilabel>, and "
"<guilabel>Reply-To</guilabel> addresses, as needed. Please see <link linkend="
"\"composer-headers\">Composer Headers</link> for further details on message "
"headers."
msgstr ""
"द<guilabel> इत्यस्मै <inlinemediaobject><imageobject><imagedata fileref=\"go-"
"down.png\" format=\"PNG\"/></imageobject></inlinemediaobject></guilabel> "
"drop down box इत्येतत् संगीतकारस्य विण्डो इत्यस्य उपरि सर्वदा वर्तते । चयनार्थं तस्य उपयोगं "
"कुर्वन्तु<guilabel> सीसी</guilabel> , ९.<guilabel> बी.सी.सी</guilabel> , "
"तथा<guilabel> उत्तरम्-To</guilabel> सम्बोधनानि, यथा आवश्यकता। कृपया पश्यन्तु<link "
"linkend=\"composer-headers\"> रचयिता शीर्षकम्</link> सन्देशशीर्षकाणां विषये "
"अधिकविवरणार्थम् ।"

#. Tag: menuchoice
#: menus.docbook:1680
#, no-c-format
msgid "<guimenu>View</guimenu><guimenuitem>Use Fixed Font</guimenuitem>"
msgstr ""
"<guimenu>दृश्य</guimenu><guimenuitem>नियत-अङ्कस्य उपयोगं कुर्वन्तु</guimenuitem>"

#. Tag: para
#: menus.docbook:1681
#, no-c-format
msgid ""
"Uses a fixed width (monospaced) font to display the currently edited "
"message. The particular font to be used can be configured in the "
"<guilabel>Appearance</guilabel> section of &kmail;'s configuration dialog."
msgstr ""
"वर्तमान सम्पादितं सन्देशं प्रदर्शयितुं नियतविस्तारस्य (मोनोस्पेस्ड्) फॉन्ट् इत्यस्य उपयोगं करोति "
"। उपयोक्तव्यः विशेषः फ़ॉन्ट् &kmail;इत्यस्य विन्याससंवादस्य <guilabel>Appearance</"
"guilabel> विभागे विन्यस्तुं शक्यते ।"

#. Tag: menuchoice
#: menus.docbook:1687
#, no-c-format
msgid "<guimenu>View</guimenu><guimenuitem>Snippets</guimenuitem>"
msgstr "<guimenu>दृश्य</guimenu><guimenuitem>स्निपेट्</guimenuitem>"

#. Tag: para
#: menus.docbook:1688
#, no-c-format
msgid ""
"Displays a column on the right hand side of the composer window that allows "
"you to use and create snippets. Please see <link linkend=\"setup-text-"
"snippets\">Snippets</link> for more information."
msgstr ""
"संगीतकारविण्डो इत्यस्य दक्षिणहस्ते स्तम्भं प्रदर्शयति यत् भवन्तं स्निपेट्-उपयोगं निर्मातुं च "
"शक्नोति । कृपया पश्यन्तु<link linkend=\"setup-text-snippets\"> स्निपेट्स्</link> "
"अधिकविवरणार्थं।"

#. Tag: title
#: menus.docbook:1698
#, no-c-format
msgid "Options Menu"
msgstr "विकल्प मेनू"

#. Tag: screeninfo
#: menus.docbook:1700
#, no-c-format
msgid "<screeninfo>The Options Menu</screeninfo>"
msgstr "<screeninfo>विकल्पमेनू</screeninfo>"

#. Tag: phrase
#: menus.docbook:1706
#, no-c-format
msgid "<phrase>The Options Menu</phrase>"
msgstr "<phrase>विकल्पमेनू</phrase> इति"

#. Tag: para
#: menus.docbook:1709
#, no-c-format
msgid "<para>The Options Menu</para>"
msgstr "<para>विकल्पमेनू</para> इति"

#. Tag: para
#: menus.docbook:1715
#, no-c-format
msgid ""
"This menu lets you toggle various options for the current message. Selected "
"items will be marked (check box colored in) in the menu."
msgstr ""
"एतत् मेन्यू वर्तमानसन्देशस्य विविधविकल्पान् टॉग्ल् कर्तुं शक्नोति । चयनितवस्तूनि मेनूमध्ये "
"चिह्नितानि (चेक् बॉक्स् वर्णितानि) भविष्यन्ति ।"

#. Tag: menuchoice
#: menus.docbook:1721
#, no-c-format
msgid "<guimenu>Options</guimenu><guimenuitem>Urgent</guimenuitem>"
msgstr "<guimenu>विकल्पाः</guimenu><guimenuitem>तत्काल</guimenuitem>"

#. Tag: para
#: menus.docbook:1722
#, no-c-format
msgid ""
"Sets the priority of the message to Urgent by inserting two header lines: "
"\"X-PRIORITY: 2 (High)\" and \"Priority: urgent\". The receiver's email "
"client must provide support for these headers; otherwise they will have no "
"effect. &kmail; itself does not support priorities for incoming messages "
"(although you can <link linkend=\"reader-mark-messages\">mark messages</"
"link> as Important)."
msgstr ""
"&quot;X-PRIORITY: 2 (High)&quot; तथा &quot;Priority: urgent&quot; इति "
"शीर्षकपङ्क्तिद्वयं सम्मिलितं कृत्वा सन्देशस्य प्राथमिकता Urgent इति सेट् करोति । ग्राहकस्य "
"ईमेलग्राहकः एतेषां शीर्षकाणां समर्थनं दातव्यः; अन्यथा तेषां प्रभावः न भविष्यति। &amp;"
"kmail; स्वयं आगच्छन्तसन्देशानां प्राथमिकतानां समर्थनं न करोति (यद्यपि भवान् शक्नोति<link "
"linkend=\"reader-mark-messages\"> सन्देशान् चिह्नयन्तु</link> यथा महत्त्वपूर्णम्)।"

#. Tag: menuchoice
#: menus.docbook:1730
#, no-c-format
msgid ""
"<guimenu>Options</guimenu><guimenuitem>Request Disposition Notification</"
"guimenuitem>"
msgstr "<guimenu>विकल्पाः</guimenu><guimenuitem>निवेदनसूचना</guimenuitem>"

#. Tag: para
#: menus.docbook:1732
#, no-c-format
msgid ""
"If you choose this option, &kmail; will insert a Disposition-Notification-"
"To: header line in the message, which is a request to receive an email "
"notification once your message has been downloaded and read by the "
"recipient. This function must be supported, and enabled by the receiver's "
"email client; otherwise, it will not work."
msgstr ""
"यदि भवान् एतत् विकल्पं चिनोति तर्हि &kmail; सन्देशे Disposition-Notification-To: "
"शीर्षकपङ्क्तिं सम्मिलितं करिष्यति, यत् एकवारं भवतः सन्देशं डाउनलोड् कृत्वा प्राप्तकर्त्रेण पठितं "
"चेत् ईमेलसूचना प्राप्तुं अनुरोधः अस्ति एतत् कार्यं समर्थितं भवितुमर्हति, ग्राहकस्य ईमेलग्राहकेन च "
"सक्षमं करणीयम्; अन्यथा न कार्यं करिष्यति।"

#. Tag: para
#: menus.docbook:1738
#, no-c-format
msgid ""
"See <xref linkend=\"configure-security-reading-mdns\"/> for background "
"information and several ways to customize the read receipts that &kmail; "
"itself sends in response to a received Disposition-Notification-To: header "
"line."
msgstr ""
"पृष्ठभूमिसूचनार्थं <xref linkend=\"configure-security-reading-mdns\"/> पश्यन्तु तथा च "
"पठित-रसीदानां अनुकूलनार्थं अनेकाः उपायाः ये &kmail; स्वयं प्राप्तस्य Disposition-"
"Notification-To: शीर्षकरेखायाः प्रतिक्रियारूपेण प्रेषयति ।"

#. Tag: menuchoice
#: menus.docbook:1745
#, no-c-format
msgid ""
"<guimenu>Options</guimenu><guimenuitem>Request Delivery Confirmation</"
"guimenuitem>"
msgstr ""
"<guimenu>विकल्पाः</guimenu><guimenuitem>वितरणपुष्टिकरणस्य अनुरोधः</guimenuitem>"

#. Tag: para
#: menus.docbook:1747
#, no-c-format
msgid ""
"If you choose this option, &kmail; will insert a Return-Receipt-To: header "
"line in the message, which is a request to receive an email notification "
"once your message has been uploaded by your email server and delivered to "
"the recipient. This function must be supported by your outgoing email "
"server; otherwise, it will not work."
msgstr ""
"यदि भवान् एतत् विकल्पं चिनोति तर्हि &kmail; सन्देशे Return-Receipt-To: शीर्षकपङ्क्तिं "
"सम्मिलितं करिष्यति, यत् एकवारं भवतः सन्देशं भवतः ईमेलसर्वरद्वारा अपलोड् कृत्वा प्राप्तकर्त्रे "
"वितरितं चेत् ईमेलसूचना प्राप्तुं अनुरोधः अस्ति एतत् कार्यं भवतः बहिर्गच्छन्त्याः ईमेलसर्वरेण "
"समर्थितं भवितुमर्हति; अन्यथा न कार्यं करिष्यति।"

#. Tag: menuchoice
#: menus.docbook:1756
#, no-c-format
msgid "<guimenu>Options</guimenu><guisubmenu>Sign Message</guisubmenu>"
msgstr "<guimenu>विकल्पाः</guimenu><guisubmenu>सञ्चारसन्देशः</guisubmenu>"

#. Tag: para
#: menus.docbook:1757
#, no-c-format
msgid ""
"Digitally signs the message using <application>OpenPGP</application> or an "
"X.509 certificate. You can learn more about this option in the <link linkend="
"\"pgp\">chapter on OpenPGP</link>."
msgstr ""
"उपयोगेन सन्देशे अङ्कीयरूपेण हस्ताक्षरं करोति<application> ओपनपीजीपी</application> अथवा "
"X.509 प्रमाणपत्रम्। अस्य विकल्पस्य विषये अधिकं ज्ञातुं शक्नुवन्ति<link linkend=\"pgp\"> "
"OpenPGP इत्यस्य अध्यायः</link> ."

#. Tag: menuchoice
#: menus.docbook:1762
#, no-c-format
msgid "<guimenu>Options</guimenu><guisubmenu>Encrypt Message</guisubmenu>"
msgstr "<guimenu>विकल्पाः</guimenu><guisubmenu>सन्देशं गुप्तं कुर्वन्तु</guisubmenu>"

#. Tag: para
#: menus.docbook:1763
#, no-c-format
msgid ""
"Encrypts the message using <application>OpenPGP</application> or an X.509 "
"certificate. You can learn more about encryption in the <link linkend=\"pgp"
"\">chapter on OpenPGP</link>."
msgstr ""
"उपयोगेन सन्देशं गोपनं करोति<application> ओपनपीजीपी</application> अथवा X.509 "
"प्रमाणपत्रम्। भवन्तः एन्क्रिप्शनविषये अधिकं ज्ञातुं शक्नुवन्ति...<link linkend=\"pgp\"> "
"OpenPGP इत्यस्य अध्यायः</link> ."

#. Tag: menuchoice
#: menus.docbook:1768
#, no-c-format
msgid ""
"<guimenu>Options</guimenu><guisubmenu>Cryptographic Message Format &gt;</"
"guisubmenu>"
msgstr ""
"<guimenu>विकल्पाः</guimenu><guisubmenu>क्रिप्टोग्राफिक सन्देशस्वरूपं &gt;</guisubmenu>"

#. Tag: para
#: menus.docbook:1769
#, no-c-format
msgid ""
"Lets you choose the cryptographic message format to use when digitally "
"signing and/or encrypting this message. Please see <link linkend="
"\"cryptographic-message-formats\">Cryptographic Message Formats</link> for "
"more information."
msgstr ""
"अस्य सन्देशस्य डिजिटलरूपेण हस्ताक्षरं कुर्वन्/अथवा गोपनं कुर्वन् उपयोक्तुं क्रिप्टोग्राफिकसन्देशस्वरूपं "
"चिन्वितुं शक्नोति । कृपया पश्यन्तु<link linkend=\"cryptographic-message-formats\"> "
"क्रिप्टोग्राफिक सन्देश प्रारूप</link> अधिकविवरणार्थं।"

#. Tag: menuchoice
#: menus.docbook:1776
#, no-c-format
msgid "<guimenu>Options</guimenu><guisubmenu>Rich Text Editing</guisubmenu>"
msgstr "<guimenu>विकल्पाः</guimenu><guisubmenu>समृद्धपाठसम्पादन</guisubmenu>"

#. Tag: para
#: menus.docbook:1777
#, no-c-format
msgid "Enables Rich Text (&ie;, &HTML;) editing."
msgstr "Rich Text (&ie;, &HTML;) सम्पादनं सक्षमं करोति ।"

#. Tag: menuchoice
#: menus.docbook:1781
#, no-c-format
msgid "<guimenu>Options</guimenu><guisubmenu>Encoding &gt;</guisubmenu>"
msgstr "<guimenu>विकल्पाः</guimenu><guisubmenu>एन्कोडिंग् &gt;</guisubmenu>"

#. Tag: para
#: menus.docbook:1782
#, no-c-format
msgid ""
"Sets the charset encoding of this message. The chosen encoding will be "
"identified by a header line in the outgoing message. You can use "
"<guilabel>Auto</guilabel> in almost every case; &kmail; will notify you if "
"you must select a different encoding manually."
msgstr ""
"अस्य सन्देशस्य charset encoding सेट् करोति । चयनितं एन्कोडिंग् बहिर्गच्छन्त्याः सन्देशे "
"शीर्षकरेखाद्वारा चिह्नितं भविष्यति । प्रायः सर्वेषु सन्दर्भेषु भवान् <guilabel>Auto</"
"guilabel> इत्यस्य उपयोगं कर्तुं शक्नोति; &kmail; यदि भवता भिन्नं एन्कोडिंग् मैन्युअल् रूपेण "
"चयनं कर्तव्यं तर्हि भवन्तं सूचयिष्यति ।"

#. Tag: menuchoice
#: menus.docbook:1788
#, no-c-format
msgid "<guimenu>Options</guimenu><guimenuitem>Wordwrap</guimenuitem>"
msgstr "<guimenu>विकल्पाः</guimenu><guimenuitem>शब्दवेष्टनम्</guimenuitem>"

#. Tag: para
#: menus.docbook:1789
#, no-c-format
msgid ""
"Toggles the automatic wordwrap feature. You may wish to turn this off when "
"pasting long lines (&eg;, &URL;s) that should not be wrapped."
msgstr ""
"स्वचालितशब्दवेष्टनविशेषतां टॉगल करोति । दीर्घपङ्क्तयः (&URL;s) चिनोति समये भवान् एतत् "
"निष्क्रियं कर्तुम् इच्छति यत् न वेष्टितव्यम् ।"

#. Tag: menuchoice
#: menus.docbook:1794
#, no-c-format
msgid ""
"<guimenu>Options</guimenu><guimenuitem>Automatic Spellchecking</guimenuitem>"
msgstr "<guimenu>विकल्पाः</guimenu><guimenuitem>स्वयं वर्तनीपरीक्षण</guimenuitem>"

#. Tag: para
#: menus.docbook:1795
#, no-c-format
msgid "Toggles automatic spellchecking on or off."
msgstr "स्वचालितं वर्तनीपरीक्षणं चालू अथवा निष्क्रियं करोति ।"

#. Tag: menuchoice
#: menus.docbook:1799
#, no-c-format
msgid ""
"<guimenu>Options</guimenu><guimenuitem>Create Follow Up Reminder...</"
"guimenuitem>"
msgstr ""
"<guimenu>विकल्पाः</guimenu><guimenuitem>अनुसरणं स्मरणं रचयन्तु...</guimenuitem>"

#. Tag: para
#: menus.docbook:1800
#, no-c-format
msgid ""
"Initiates a dialog allowing you to add a \"To Do\" item to your calendar. "
"This item is grayed out if the <ulink url=\"help:/"
"akonadi_followupreminder_agent\">Followup Reminder Agent</ulink> plugin has "
"not been activated."
msgstr ""
"एकं संवादं आरभते यत् भवन्तः स्वस्य पञ्चाङ्गे \"To Do\" इति द्रव्यं योजयितुं शक्नुवन्ति । यदि "
"<ullink url=\"help:/akonadi_followupreminder_agent\">अनुसरण-स्मारक-एजेण्ट्</"
"ulink> प्लगिन् सक्रियः न अभवत् तर्हि एतत् द्रव्यं ग्रे-वर्णं भवति ।"

#. Tag: title
#: menus.docbook:1812
#, no-c-format
msgid "Attach Menu"
msgstr "मेनू संलग्नं कुर्वन्तु"

#. Tag: screeninfo
#: menus.docbook:1814
#, no-c-format
msgid "<screeninfo>The Attach Menu</screeninfo>"
msgstr "<screeninfo>संलग्नमेनू</screeninfo> इति"

#. Tag: phrase
#: menus.docbook:1820
#, no-c-format
msgid "<phrase>The Attach Menu</phrase>"
msgstr "<phrase>Attach Menu</phrase> इति"

#. Tag: para
#: menus.docbook:1823
#, no-c-format
msgid "<para>The Attach Menu</para>"
msgstr "<para>संलग्नमेनू</para> इति"

#. Tag: para
#: menus.docbook:1829
#, no-c-format
msgid "This menu lets you select attachment options."
msgstr "एतत् मेन्यू भवन्तं संलग्नविकल्पान् चिन्वितुं शक्नोति ।"

#. Tag: menuchoice
#: menus.docbook:1834
#, no-c-format
msgid "<guimenu>Attach</guimenu><guimenuitem>Append Signature</guimenuitem>"
msgstr "<guimenu>संलग्नं</guimenu><guimenuitem>हस्ताक्षरं योजयतु</guimenuitem>"

#. Tag: para
#: menus.docbook:1835
#, no-c-format
msgid ""
"Appends your signature (<quote>footer</quote>) to the end of the message. "
"Please see <link linkend=\"configure-identity-signature\">Configure Identity "
"Signature</link> for details on configuring your signature."
msgstr ""
"भवतः हस्ताक्षरं योजयति (<quote> पादलेखः</quote> ) सन्देशस्य अन्ते यावत् । कृपया "
"पश्यन्तु<link linkend=\"configure-identity-signature\"> परिचयहस्ताक्षरं विन्यस्यताम्</"
"link> भवतः हस्ताक्षरस्य विन्यासस्य विवरणार्थं ।"

#. Tag: menuchoice
#: menus.docbook:1841
#, no-c-format
msgid "<guimenu>Attach</guimenu><guimenuitem>Prepend Signature</guimenuitem>"
msgstr "<guimenu>संलग्नं</guimenu><guimenuitem>हस्ताक्षरस्य पूर्ववर्ती</guimenuitem>"

#. Tag: para
#: menus.docbook:1842
#, no-c-format
msgid ""
"Prepends your signature (<quote>header</quote>) at the beginning of the "
"message."
msgstr "सन्देशस्य आरम्भे भवतः हस्ताक्षरं (<quote>header</quote>) पूर्वस्थापयति ।"

#. Tag: menuchoice
#: menus.docbook:1846
#, no-c-format
msgid ""
"<guimenu>Attach</guimenu><guimenuitem>Insert Signature At Cursor Position</"
"guimenuitem>"
msgstr ""
"<guimenu>संलग्नं कुर्वन्तु</guimenu><guimenuitem>कर्सरस्थाने हस्ताक्षरं सम्मिलितं कुर्वन्तु</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:1848
#, no-c-format
msgid "Inserts your signature at the current cursor location."
msgstr "वर्तमान कर्सरस्थाने भवतः हस्ताक्षरं निवेशयति ।"

#. Tag: menuchoice
#: menus.docbook:1852
#, no-c-format
msgid ""
"<guimenu>Attach</guimenu><guimenuitem>Attach Public Key...</guimenuitem>"
msgstr ""
"<guimenu>संलग्नं कुर्वन्तु</guimenu><guimenuitem>सार्वजनिककुंजी संलग्नं कुर्वन्तु...</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:1853
#, no-c-format
msgid ""
"Opens the <guilabel>Attach Public OpenPGP Key</guilabel> dialog. Please see "
"<link linkend=\"configure-identity-cryptography-openpgp-sign\">Configure "
"Identity Cryptography OpenPGP Signing</link> for details."
msgstr ""
"उद्घाटयति<guilabel> सार्वजनिक OpenPGP कुञ्जी संलग्नं कुर्वन्तु</guilabel> संवादः । कृपया "
"पश्यन्तु<link linkend=\"configure-identity-cryptography-openpgp-sign\"> "
"परिचयगुप्तलेखनं विन्यस्य OpenPGP हस्ताक्षरं</link> विस्तरेण कृते।"

#. Tag: menuchoice
#: menus.docbook:1859
#, no-c-format
msgid ""
"<guimenu>Attach</guimenu><guimenuitem>Attach My Public Key</guimenuitem>"
msgstr ""
"<guimenu>संलग्नं कुरुत</guimenu><guimenuitem>मम सार्वजनिककुंजी संलग्नं कुरुत</guimenuitem>"

#. Tag: para
#: menus.docbook:1860
#, no-c-format
msgid ""
"Attaches your <application>GnuPG</application> public key, or your X.509 "
"certificate, (&ie;, the public key associated with your current identity) to "
"your message."
msgstr ""
"भवतः <application>GnuPG</application> सार्वजनिककुंजी, अथवा भवतः X.509 प्रमाणपत्रं, "
"(&अर्थात्, भवतः वर्तमानपरिचयेन सह सम्बद्धं सार्वजनिककुंजी) भवतः सन्देशे संलग्नं करोति ।"

#. Tag: menuchoice
#: menus.docbook:1866
#, no-c-format
msgid ""
"<guimenu>Attach</guimenu><guisubmenu>Attach &gt;</guisubmenu> "
"<guimenuitem>Attach File...</guimenuitem>"
msgstr ""
"<guimenu>संलग्नं कुर्वन्तु</guimenu><guisubmenu>संलग्नं कुर्वन्तु &gt;</guisubmenu> "
"<guimenuitem>सञ्चिकां संलग्नं कुर्वन्तु...</guimenuitem>"

#. Tag: para
#: menus.docbook:1868
#, no-c-format
msgid ""
"Attaches one or more files to the current message. Attachments are encrypted "
"by default (if the message is encrypted). Please see <link linkend="
"\"cryptographic-message-formats\">Cryptographic Message Formats</link> for "
"more information on encryption and attachments."
msgstr ""
"वर्तमानसन्देशे एकां वा अधिकं वा सञ्चिकां संलग्नं करोति । संलग्नकानि पूर्वनिर्धारितरूपेण "
"गुप्तीकरणं भवन्ति (यदि सन्देशः गोपनीयः अस्ति) । कृपया पश्यन्तु<link linkend="
"\"cryptographic-message-formats\"> क्रिप्टोग्राफिक सन्देश प्रारूप</link> "
"एन्क्रिप्शनस्य, संलग्नकानां च विषये अधिकाधिकजानकारीं प्राप्तुं।"

#. Tag: menuchoice
#: menus.docbook:1874
#, no-c-format
msgid ""
"<guimenu>Attach</guimenu><guisubmenu>Attach &gt;</guisubmenu> "
"<guimenuitem>Attach Directory...</guimenuitem>"
msgstr ""
"<guimenu>संलग्नं कुर्वन्तु</guimenu><guisubmenu>संलग्नं कुर्वन्तु &gt;</guisubmenu> "
"<guimenuitem>निर्देशिका संलग्नं कुर्वन्तु...</guimenuitem>"

#. Tag: para
#: menus.docbook:1876
#, no-c-format
msgid ""
"Creates a ZIP archive containing the selected Directory, and attaches the "
"archive to this message."
msgstr "चयनितं Directory युक्तं ZIP संग्रहणं निर्माति, अस्मिन् सन्देशे च संग्रहणं संलग्नं करोति ।"

#. Tag: menuchoice
#: menus.docbook:1881
#, no-c-format
msgid ""
"<guimenu>Attach</guimenu><guisubmenu>Attach &gt;</guisubmenu> "
"<guimenuitem>Attach Own vCard</guimenuitem>"
msgstr ""
"<guimenu>संलग्नं कुर्वन्तु</guimenu><guisubmenu>संलग्नं कुर्वन्तु &gt;</guisubmenu> "
"<guimenuitem>स्वयं vCard संलग्नं कुर्वन्तु</guimenuitem>"

#. Tag: para
#: menus.docbook:1883
#, no-c-format
msgid "Attaches your vCard to the current message."
msgstr "वर्तमानसन्देशे भवतः vCard संलग्नं करोति ।"

#. Tag: menuchoice
#: menus.docbook:1887
#, no-c-format
msgid ""
"<guimenu>Attach</guimenu><guisubmenu>Attach &gt;</guisubmenu> "
"<guimenuitem>Attach vCards...</guimenuitem>"
msgstr ""
"<guimenu>संलग्नं कुर्वन्तु</guimenu><guisubmenu>संलग्नं कुर्वन्तु &gt;</guisubmenu> "
"<guimenuitem>vCards संलग्नं कुर्वन्तु...</guimenuitem>"

#. Tag: para
#: menus.docbook:1889
#, no-c-format
msgid ""
"Opens a dialog with &kaddressbook; that lets you select one or more people "
"(&Ctrl; and left-click), and then attaches vCards for all those selected."
msgstr ""
"&kaddressbook; यत् भवन्तं एकं वा अधिकं वा जनान् (&Ctrl; तथा वाम-क्लिक्) चयनं कर्तुं "
"शक्नोति, ततः चयनितानां सर्वेषां कृते vCards संलग्नं करोति ।"

#. Tag: menuchoice
#: menus.docbook:1894
#, no-c-format
msgid ""
"<guimenu>Attach</guimenu><guisubmenu>Attach &gt;</guisubmenu> "
"<guimenuitem>Attach Text From Clipboard...</guimenuitem>"
msgstr ""
"<guimenu>संलग्नं कुर्वन्तु</guimenu><guisubmenu>संलग्नं कुर्वन्तु &gt;</guisubmenu> "
"<guimenuitem>क्लिप्बोर्डतः पाठं संलग्नं कुर्वन्तु...</guimenuitem>"

#. Tag: para
#: menus.docbook:1896
#, no-c-format
msgid ""
"If the topmost item saved on the clipboard contains at least two bytes, a "
"file name dialog will open. &kmail; will create an attachment containing the "
"text from the clipboard, and give the attachment the name you have chosen."
msgstr ""
"यदि क्लिप्बोर्ड् मध्ये रक्षिते सर्वोपरि द्रव्ये न्यूनातिन्यूनं द्वौ बाइट् स्तः तर्हि "
"सञ्चिकानामसंवादः उद्घाट्यते । &kmail; क्लिप्बोर्ड् तः पाठं युक्तं संलग्नकं निर्मास्यति, संलग्नं च "
"भवता चितं नाम दास्यति ।"

#. Tag: menuchoice
#: menus.docbook:1903
#, no-c-format
msgid "<guimenu>Attach</guimenu><guimenuitem>Remove Attachment</guimenuitem>"
msgstr "<guimenu>संलग्नं</guimenu><guimenuitem>संलग्नकं निष्कासयतु</guimenuitem>"

#. Tag: para
#: menus.docbook:1904
#, no-c-format
msgid ""
"Removes the selected attachment (selected via the attachment area beneath "
"the main composer window)."
msgstr ""
"चयनितं संलग्नकं (मुख्यरचनाकारविण्डो इत्यस्य अधः संलग्नक्षेत्रस्य माध्यमेन चयनितं) निष्कासयति ।"

#. Tag: para
#: menus.docbook:1906
#, no-c-format
msgid ""
"This menu item, and the next two, will be grayed out until an attachment is "
"selected."
msgstr "इदं मेनू-वस्तु, अग्रिमद्वयं च यावत् संलग्नकं न चिनोति तावत् ग्रे-वर्णं भविष्यति ।"

#. Tag: menuchoice
#: menus.docbook:1911
#, no-c-format
msgid ""
"<guimenu>Attach</guimenu><guimenuitem>Save Attachment As...</guimenuitem>"
msgstr "<guimenu>संलग्नं</guimenu><guimenuitem>संलग्नकं यथा...</guimenuitem> रक्षतु"

#. Tag: para
#: menus.docbook:1912
#, no-c-format
msgid "Saves the attachment selected in the attachment window as a file."
msgstr "संलग्नकविण्डो मध्ये चयनितं संलग्नकं सञ्चिकारूपेण रक्षति ।"

#. Tag: menuchoice
#: menus.docbook:1916
#, no-c-format
msgid ""
"<guimenu>Attach</guimenu><guimenuitem>Attachment Properties</guimenuitem>"
msgstr "<guimenu>संलग्न</guimenu><guimenuitem>संलग्नगुणाः</guimenuitem>"

#. Tag: para
#: menus.docbook:1917
#, no-c-format
msgid ""
"Displays the <link linkend=\"attachments\">properties of the attachment</"
"link> that has been selected via the attachment window. It also lets you "
"sign/encrypt the attachment, and alter some of its other properties (name, "
"description, &MIME; type, &etc;)."
msgstr ""
"प्रदर्शयति<link linkend=\"attachments\"> आसक्तस्य गुणाः</link> यत् संलग्नकविण्डोद्वारा "
"चयनितम् अस्ति । एतत् भवन्तं संलग्नकं हस्ताक्षरं/गोपनं कर्तुं, तस्य अन्येषां केषाञ्चन गुणानाम् (नाम, "
"वर्णनं, &amp;MIME; प्रकारः, &amp; इत्यादीन्) परिवर्तयितुं च शक्नोति ।"

#. Tag: para
#: menus.docbook:1945
#, no-c-format
msgid ""
"If the menu item you are looking for is missing, please see <ulink url="
"\"help:/fundamentals/menus.html#menus-tools\">Tools Menu</ulink> of the "
"&kde; Fundamentals. The items listed here are &kmail; specific."
msgstr ""
"यदि भवान् अन्विष्यमाणः मेनू-वस्तु लुप्तः अस्ति तर्हि कृपया &kde; मौलिकता। अत्र सूचीकृतानि "
"वस्तूनि &kmail; विशिष्टः।"

#. Tag: menuchoice
#: menus.docbook:1950
#, no-c-format
msgid "<guimenu>Tools</guimenu><guimenuitem>Select Recipients...</guimenuitem>"
msgstr "<guimenu>उपकरणं</guimenu><guimenuitem>प्राप्तकर्तान् चिनोतु...</guimenuitem>"

#. Tag: para
#: menus.docbook:1951
#, no-c-format
msgid ""
"Opens a <guilabel>Select Recipient</guilabel> dialog, with the contents of "
"all your address books to select from."
msgstr ""
"<guilabel>Select Recipient</guilabel> संवादं उद्घाटयति, यत्र भवतः सर्वेषां "
"पतापुस्तकानां सामग्रीः चयनार्थं भवति ।"

#. Tag: menuchoice
#: menus.docbook:1956
#, no-c-format
msgid "<guimenu>Tools</guimenu><guimenuitem>Addressbook...</guimenuitem>"
msgstr "<guimenu>उपकरणं</guimenu><guimenuitem>पतापुस्तिका...</guimenuitem>"

#. Tag: para
#: menus.docbook:1957
#, no-c-format
msgid ""
"Launches the <ulink url=\"help:/kaddressbook\">&kaddressbook;</ulink> "
"program."
msgstr ""
"<ulink url=\"help:/kaddressbook\">&kaddressbook;</ulink> कार्यक्रमं प्रारभते ।"

#. Tag: menuchoice
#: menus.docbook:1961
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu><guimenuitem>Save Distribution List...</guimenuitem>"
msgstr "<guimenu>उपकरणाः</guimenu><guimenuitem>वितरणसूचीं रक्षन्तु...</guimenuitem>"

#. Tag: para
#: menus.docbook:1962
#, no-c-format
msgid ""
"Opens a dialog that lets you save groups of contacts as a single named item. "
"Very handy if you frequently send the same message to all the members of a "
"club, for instance."
msgstr ""
"एकं संवादं उद्घाटयति यत् भवन्तं सम्पर्कसमूहान् एकनामवस्तुरूपेण रक्षितुं शक्नोति । अतीव सुलभं यदि "
"भवान् बहुधा क्लबस्य सर्वेभ्यः सदस्येभ्यः समानं सन्देशं प्रेषयति, उदाहरणार्थम्।"

#. Tag: menuchoice
#: menus.docbook:1967
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu><guimenuitem>Autocorrect Text &gt;</guimenuitem>"
msgstr "<guimenu>उपकरणं</guimenu><guimenuitem>स्वयं सम्यक् पाठः></guimenuitem>"

#. Tag: para
#: menus.docbook:1968
#, no-c-format
msgid ""
"Performs autocorrection. You have two options: scan and autocorrect the "
"selected text, or apply <link linkend=\"configure-composer-autocorrection"
"\">autocorrection</link> to the whole message. This menu item will not be "
"present unless the <guilabel>Autocorrection</guilabel> plugin has been "
"loaded, and it won't work unless the Autocorrection function has been "
"enabled on the Composer configuration page."
msgstr ""
"स्वशुद्धिकरणं करोति। भवतः द्वौ विकल्पौ स्तः : चयनितं पाठं स्कैन् कृत्वा स्वयमेव सम्यक् कुर्वन्तु, "
"अथवा प्रयोजयन्तु<link linkend=\"configure-composer-autocorrection\"> "
"स्वशुद्धिकरणम्</link> समग्रं सन्देशं प्रति। इदं मेनू-वस्तु तावत्पर्यन्तं न भविष्यति यावत्..."
"<guilabel> स्वशुद्धिकरणम्</guilabel> प्लगिन् लोड् कृतम् अस्ति, तथा च यावत् Composer "
"विन्यासपृष्ठे Autocorrection कार्यं सक्षमं न भवति तावत् कार्यं न करिष्यति ।"

#. Tag: menuchoice
#: menus.docbook:1976
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;&Alt;<keycap>T</keycap></"
"keycombo></shortcut> <guimenu>Tools</guimenu><guimenuitem>Translator</"
"guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;&Alt;<keycap>T</keycap></"
"keycombo></shortcut> <guimenu>उपकरणं</guimenu><guimenuitem>अनुवादकः</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:1978
#, no-c-format
msgid ""
"Opens the <link linkend=\"using-the-translator\">translator window</link>."
msgstr "उद्घाटयति<link linkend=\"using-the-translator\"> अनुवादकविण्डो</link> ."

#. Tag: menuchoice
#: menus.docbook:1982
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu><guimenuitem>Check Grammar (Language Tool)</"
"guimenuitem>"
msgstr ""
"<guimenu>उपकरणाः</guimenu><guimenuitem>व्याकरणस्य (भाषासाधनस्य) जाँचं कुर्वन्तु</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:1983
#, no-c-format
msgid ""
"Opens the grammar check window and examines your message, highlighting any "
"errors that are found. This feature does not continuously update the scanned "
"text as you type; you should first compose your message, then invoke grammar "
"check. This tool is not available unless the <guilabel>Grammar Check</"
"guilabel> plugin has been activated. Like the Translator function, Grammar "
"Check passes your message through a server (default server: https://"
"languagetool.org/api/v2) on the internet."
msgstr ""
"व्याकरणपरीक्षाविण्डो उद्घाट्य भवतः सन्देशं परीक्षते, यत्किमपि दोषं लभ्यते तत् प्रकाशयति । "
"एतत् विशेषता भवता टङ्कयन् स्कैन् कृतं पाठं निरन्तरं न अद्यतनं करोति; भवन्तः प्रथमं स्वसन्देशं "
"रचयन्तु, ततः व्याकरणपरीक्षां आह्वयन्तु । यावत् <guilabel>व्याकरणपरीक्षा</guilabel> "
"प्लगिन् सक्रियः न भवति तावत् एतत् साधनं उपलब्धं नास्ति । Translator कार्यवत्, Grammar "
"Check भवतः सन्देशं अन्तर्जालस्य सर्वरेण (पूर्वनिर्धारितसर्वर: https://languagetool.org/"
"api/v2) प्रसारयति ।"

#. Tag: para
#: menus.docbook:2013
#, no-c-format
msgid ""
"If the menu item you seek is missing, please see <ulink url=\"help:/"
"fundamentals/menus.html#menus-settings\">Settings Menu</ulink> of the &kde; "
"Fundamentals. The items listed here are &kmail; specific."
msgstr ""
"यदि भवान् अन्विष्यमाणः मेनू-वस्तु अनुपलब्धः अस्ति, तर्हि कृपया &kde; मौलिकता। अत्र "
"सूचीकृतानि वस्तूनि &kmail; विशिष्टः।"

#. Tag: menuchoice
#: menus.docbook:2018
#, no-c-format
msgid ""
"<guimenu>Settings</guimenu><guimenuitem>Toolbars Shown &gt;</guimenuitem>"
msgstr ""
"<guimenu>सेटिंग्स्</guimenu><guimenuitem>उपकरणपट्टिकाः दर्शिताः &gt;</guimenuitem>"

#. Tag: para
#: menus.docbook:2019
#, no-c-format
msgid ""
"Lets you control which toolbars are displayed. You may choose any "
"combination of three options: Main Toolbar (<guilabel>Send</guilabel>, "
"<guilabel>Queue</guilabel>, <guilabel>Rich Text</guilabel>, &etc;), HTML "
"Toolbar (<guilabel>Style</guilabel>, <guilabel>Font / Size</guilabel>, "
"&etc;), and Text Direction (in case you use a right-to-left script). Note "
"that the HTML Toolbar is easily toggled on and off via the <guibutton>Rich "
"Text</guibutton> button on the Main Toolbar."
msgstr ""
"के साधनपट्टिकाः प्रदर्शिताः इति नियन्त्रयितुं शक्नोति । भवान् त्रयाणां विकल्पानां किमपि "
"संयोजनं चिन्वतु: मुख्यसाधनपट्टिका (<guilabel>प्रेषयतु</guilabel>, <guilabel>पङ्क्ति</"
"guilabel>, <guilabel>समृद्धपाठः</guilabel>, &etc;), HTML साधनपट्टिका "
"(<guilabel> Style</guilabel>, <guilabel>Font / Size</guilabel>, &etc;), तथा "
"Text Direction (यदि भवान् दक्षिणतः वामपर्यन्तं उपयोगं करोति प्रलेखन)। ध्यानं कुर्वन्तु यत् "
"HTML Toolbar मुख्यसाधनपट्टिकायां <guibutton>Rich Text</guibutton> बटन् मार्गेण "
"सहजतया चालू-निष्क्रान्तं च भवति ।"

#. Tag: menuchoice
#: menus.docbook:2027
#, no-c-format
msgid "<guimenu>Settings</guimenu><guimenuitem>Spellchecker...</guimenuitem>"
msgstr "<guimenu>सेटिंग्स्</guimenu><guimenuitem>वर्तनीपरीक्षकः...</guimenuitem>"

#. Tag: para
#: menus.docbook:2028
#, no-c-format
msgid ""
"Allows you to configure <ulink url=\"help:/sonnet/\">&sonnet;</ulink>, "
"&kde;'s spell checker."
msgstr ""
"<ulink url=\"help:/sonnet/\">&sonnet;</ulink>, &kde;इत्यस्य वर्तनीपरीक्षकं विन्यस्तुं "
"अनुमन्यते ।"

#. Tag: para
#: menus.docbook:2053
#, no-c-format
msgid ""
"This is exactly like the <ulink url=\"help:/fundamentals/menus.html#menus-"
"help\">Help Menu</ulink> of the &kde; Fundamentals."
msgstr "इदं &kde; मौलिकता।"
