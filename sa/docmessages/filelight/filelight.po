"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>-</keycap></keycombo> </"
"shortcut> <guimenu>View</guimenu> <guimenuitem>Zoom Out</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>-</keycap></keycombo> </"
"shortcut> <guimenu>दृश्य</guimenu> <guimenuitem>जूम आउट</guimenuitem>"

#. Tag: action
#: index.docbook:243
#, no-c-format
msgid "Decrease the view of the filemap."
msgstr "सञ्चिकानक्शस्य दृश्यं न्यूनीकरोतु ।"

#. Tag: title
#: index.docbook:249
#, no-c-format
msgid "The Go Menu"
msgstr "गो मेनू इति"

#. Tag: menuchoice
#: index.docbook:251
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt;<keycap>Up</keycap></keycombo> </"
"shortcut> <guimenu>Go</guimenu> <guimenuitem>Up</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt;<keycap>उपरि</keycap></keycombo> "
"</shortcut> <guimenu>गच्छ</guimenu> <guimenuitem>उपरि</guimenuitem>"

#. Tag: action
#: index.docbook:258
#, no-c-format
msgid "Moves you up one step in the filesystem to the parent folder."
msgstr "भवन्तं सञ्चिकातन्त्रे एकं पदं उपरि मातापितृपुटं प्रति चालयति ।"

#. Tag: menuchoice
#: index.docbook:262
#, no-c-format
msgid "<guimenu>Go</guimenu> <guimenuitem>Back</guimenuitem>"
msgstr "<guimenu>गच्छ</guimenu> <guimenuitem>पृष्ठतः</guimenuitem>"

