#: index.docbook:266
#, no-c-format
msgid "Moves you one step back in your browsing history of the filesystem."
msgstr "सञ्चिकातन्त्रस्य ब्राउजिंग् इतिहासे भवन्तं एकं पदं पश्चात् गच्छति ।"

#. Tag: menuchoice
#: index.docbook:270
#, no-c-format
msgid "<guimenu>Go</guimenu> <guimenuitem>Forward</guimenuitem>"
msgstr "<guimenu>गच्छ</guimenu> <guimenuitem>अग्रे</guimenuitem>"

#. Tag: action
#: index.docbook:274
#, no-c-format
msgid "Moves you one step forward in your browsing history of the filesystem."
msgstr "सञ्चिकातन्त्रस्य ब्राउजिंग् इतिहासे भवन्तं एकं पदं अग्रे गच्छति ।"

