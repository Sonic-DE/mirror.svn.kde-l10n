#, no-c-format
msgid "Applications 19.12"
msgstr "अनुप्रयोगाः 19.12"

#. Tag: keyword
#: index.docbook:20
#, no-c-format
msgid "<keyword>KDE</keyword>"
msgstr "<keyword>WHERE</keyword> इति"

#. Tag: keyword
