#. Tag: para
#: index.docbook:5446
#, no-c-format
msgid ""
"Provides a dialog window to view and change parameters and meta data of the "
"currently opened file. See section <link linkend=\"fileinfo\" endterm="
"\"title_fileinfo\"></link> in this manual."
msgstr ""
"वर्तमानकाले उद्घाटितायाः सञ्चिकायाः मापदण्डान् मेटादत्तांशं च द्रष्टुं परिवर्तयितुं च "
"संवादविण्डो प्रदाति । खण्डं पश्यन्तु<link linkend=\"fileinfo\" endterm="
"\"title_fileinfo\"></link> अस्मिन् पुस्तिकायां ।"

#. Tag: title
#: index.docbook:5458
#, no-c-format
msgid "&no-i18n-plugin_goto; (Goto Position)"
msgstr "&no-i18n-प्लगिन्_गोटो; (Goto Position)"

