msgid "&no-i18n-plugin_stringenter; (Enter Command)"
msgstr "&no-i18n-प्लगिन्_स्ट्रिंगेन्टर; (आदेशं प्रविशतु)"

#. Tag: phrase
#: index.docbook:6954
#, no-c-format
msgid "Screenshot of the Enter Command Plugin"
msgstr "Enter Command Plugin इत्यस्य स्क्रीनशॉट्"

