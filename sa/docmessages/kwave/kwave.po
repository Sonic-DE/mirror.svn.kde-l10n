#. Tag: entry
#: index.docbook:5524 index.docbook:5616
#, no-c-format
msgid "position is given in percentage of the file length"
msgstr "स्थितिः सञ्चिकादीर्घतायाः प्रतिशते दत्ता अस्ति"

#. Tag: replaceable
#: index.docbook:5532 index.docbook:5624
#, no-c-format
msgid "position"
msgstr "स्थितिः"

#. Tag: para
#: index.docbook:5534
#, no-c-format
