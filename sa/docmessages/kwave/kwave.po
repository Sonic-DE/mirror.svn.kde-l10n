msgid ""
"Scrolls the current view towards the start of the signal by the currently "
"visible range."
msgstr "वर्तमानदृश्यं वर्तमानदृश्यमानपरिधिद्वारा संकेतस्य आरम्भं प्रति स्क्रॉल करोति ।"

#. Tag: link
#: index.docbook:3908
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_next;</command>()"
msgstr "<आदेश>&no-i18n-tag;&no-i18n-cmd_view_scroll_next;</command>()"

