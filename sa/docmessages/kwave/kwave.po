#. Tag: link
#: index.docbook:3955
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_end;</command>()"
msgstr "<आदेश>&no-i18n-tag;&no-i18n-cmd_view_scroll_end;</command>()"

