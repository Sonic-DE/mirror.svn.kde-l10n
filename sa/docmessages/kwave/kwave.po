#. Tag: title
#: index.docbook:2589
#, no-c-format
msgid "&no-i18n-cmd_delete;"
msgstr "&no-i18n-cmd_delete;"

#. Tag: title
#: index.docbook:2591
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_delete;</command>()"
msgstr "&i18n-cmd_syntax;<आदेश>&no-i18n-tag;&no-i18n-cmd_delete;</command>()"

#. Tag: para
#: index.docbook:2592
#, no-c-format
msgid ""
"Deletes the currently selected range of samples. If the selection is empty, "
"this command does nothing. Affects all tracks."
msgstr ""
"वर्तमान चयनितं नमूनानां श्रेणीं विलोपयति । यदि चयनं रिक्तं भवति तर्हि एषः आदेशः किमपि न "
"करोति । सर्वान् पटलान् प्रभावितं करोति।"

#. Tag: title
#: index.docbook:2601
#, no-c-format
msgid "&no-i18n-cmd_delete_track;"
msgstr "&no-i18n-cmd_delete_track;"

#. Tag: title
#: index.docbook:2603
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_delete_track;</"
"command>(<replaceable>index</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<आदेश>&no-i18n-cmd_delete_track;</"
"command>(<प्रतिस्थापनीय>अनुक्रमणिका</replaceable>)"

#. Tag: para
#: index.docbook:2604
#, no-c-format
msgid ""
"Deletes a track, identified by its index (starting from zero). If no track "
"with the given index exists, this command exits with an error."
msgstr ""
"एकं पटलं विलोपयति, तस्य अनुक्रमणिकाद्वारा (शून्यतः आरभ्य) चिह्नितं । यदि दत्तसूचकाङ्कयुक्तः "
"कोऽपि पटलः नास्ति तर्हि एषः आदेशः दोषेण सह निर्गच्छति ।"

#. Tag: entry
#: index.docbook:2610 index.docbook:2733 index.docbook:2772 index.docbook:2800
#: index.docbook:3563 index.docbook:3577 index.docbook:3592
#, no-c-format
msgid "<parameter>index</parameter>:"
msgstr "<पैरामीटर>सूचकाङ्कः</parameter>: ."

#. Tag: entry
#: index.docbook:2610
#, no-c-format
msgid "index of the track to delete, starting with 0"
msgstr "0 इत्यस्मात् आरभ्य विलोपनीयस्य पटलस्य अनुक्रमणिका"

#. Tag: title
#: index.docbook:2615
#, no-c-format
msgid "&no-i18n-cmd_dump_metadata;"
msgstr "&no-i18n-cmd_डम्प_मेटाडाटा;"

#. Tag: title
#: index.docbook:2617
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_dump_metadata;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<आदेश>&no-i18n-tag;&no-i18n-cmd_dump_metadata;</command>()"

#. Tag: para
#: index.docbook:2618
#, no-c-format
msgid ""
"Prints a list of all meta data entries to the console, for diagnostic "
"purposes. (Only available when &kwave; has been compiled with the option "
"<literal>WITH_DEBUG</literal> switched on)."
msgstr ""
"सर्वेषां मेटादत्तांशप्रविष्टीनां सूचीं कन्सोल् मध्ये मुद्रयति, निदानार्थं । (केवलं तदा उपलब्धं यदा "
"&kwave; <literal>WITH_DEBUG</literal> विकल्पेन चालू कृत्वा संकलितं भवति) ।"

#. Tag: title
#: index.docbook:2627
#, no-c-format
msgid "&no-i18n-tag;e"
msgstr "&no-i18n-tag;e"

#. Tag: title
#: index.docbook:2630
#, no-c-format
msgid "&no-i18n-cmd_expandtolabel;"
msgstr "&no-i18n-cmd_expandtolabel;"

#. Tag: title
#: index.docbook:2632
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_expandtolabel;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<आदेश>&no-i18n-tag;&no-i18n-cmd_expandtolabel;</command>()"

#. Tag: para
#: index.docbook:2633
#, no-c-format
msgid ""
"Expands the current selection to the labels left and right from the current "
"selection borders. If the border of selection already is on a label, it "
"stays unchanged. If there is no label left or right of the current "
"selection, it will be expanded to the start or end of the file."
msgstr ""
"वर्तमानचयनसीमाभ्यः वामदक्षिणयोः लेबल् मध्ये वर्तमानचयनं विस्तारयति । यदि चयनस्य सीमा "
"पूर्वमेव लेबले अस्ति तर्हि अपरिवर्तिता एव तिष्ठति । यदि वर्तमानचयनस्य वामभागे दक्षिणभागे "
"वा लेबलं नास्ति तर्हि तत् सञ्चिकायाः आरम्भे वा अन्ते वा विस्तारितं भविष्यति ।"

#. Tag: title
#: index.docbook:2644
#, no-c-format
msgid "&no-i18n-tag;f"
msgstr "&no-i18n-tag;f"

#. Tag: title
#: index.docbook:2647
#, no-c-format
msgid "&no-i18n-cmd_fileinfo;"
msgstr "&no-i18n-cmd_fileinfo;"

#. Tag: title
#: index.docbook:2649
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_fileinfo;</"
"command>(<replaceable>index</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<आदेश>&no-i18n-cmd_fileinfo;</"
"command>(<प्रतिस्थापनीय>अनुक्रमणिका</replaceable>)"

#. Tag: para
#: index.docbook:2650
#, no-c-format
msgid "Set a file info entry to a new value."
msgstr "सञ्चिकासूचनाप्रविष्टिं नूतनमूल्ये सेट् कुर्वन्तु ।"

#. Tag: entry
#: index.docbook:2655
#, no-c-format
msgid "<parameter>keyword</parameter>:"
msgstr "<पैरामीटर>कीवर्ड</parameter>:"

#. Tag: entry
#: index.docbook:2655
#, no-c-format
msgid "keyword of the entry"
msgstr "प्रविष्टेः कीवर्डः"

#. Tag: entry
#: index.docbook:2656
#, no-c-format
msgid "<parameter>value</parameter>:"
msgstr "<पैरामीटर्>मूल्यं</parameter>: ."

#. Tag: entry
#: index.docbook:2656
#, no-c-format
msgid "value of the entry"
msgstr "प्रविष्टेः मूल्यम्"

#. Tag: title
#: index.docbook:2661
#, no-c-format
msgid "&no-i18n-cmd_forward;"
msgstr "&no-i18n-cmd_forward;"

#. Tag: title
#: index.docbook:2663
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_forward;</command>()"
msgstr "&i18n-cmd_syntax;<आदेश>&no-i18n-tag;&no-i18n-cmd_forward;</command>()"

#. Tag: para
#: index.docbook:2664
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Forward</guibutton> toolbar button. If the "
"playback is currently running, it skips forward by 1/10 of the visible "
"range. If the playback is not running, this does the same as the command "
"<command>&no-i18n-cmd_view_scroll_right;</command>()."
msgstr ""
"<guibutton>अग्रे</guibutton> इति साधनपट्टिकाबटनस्य अनुरूपं भवति । यदि प्लेबैक् सम्प्रति "
"प्रचलति तर्हि दृश्यमानस्य परिधिस्य १/१० भागं अग्रे लङ्घयति । यदि प्लेबैक् न चाल्यते तर्हि एतत् "
"<command>&no-i18n-cmd_view_scroll_right;</command>() इत्यस्य आदेशस्य समानं करोति ।"

#. Tag: para
#: index.docbook:2673
#, no-c-format
msgid ""
"<link linkend=\"cmd_sect_view_scroll_right\"><command>&no-i18n-tag;&no-i18n-"
"cmd_view_scroll_right;</command>()</link>, <link linkend=\"cmd_sect_rewind"
"\"><command>&no-i18n-tag;&no-i18n-cmd_rewind;</command>()</link>"
msgstr ""
"<link linkend=\"cmd_sect_view_scroll_right\"><command>&amp;no-i18n-tag;&amp;"
"no-i18n-cmd_view_scroll_right;</command> () ९.</link> , ९.<link linkend="
"\"cmd_sect_rewind\"><command> &amp;no-i18n-tag;&amp;no-i18n-cmd_rewind;</"
"command> () ९.</link>"

#. Tag: title
#: index.docbook:2681
#, no-c-format
msgid "&no-i18n-tag;g"
msgstr "&no-i18n-tag;g"

#. Tag: title
#: index.docbook:2684
#, no-c-format
msgid "&no-i18n-cmd_goto;"
msgstr "&no-i18n-cmd_goto;"

#. Tag: title
#: index.docbook:2686
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_goto;</command>(<replaceable>pos</"
"replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<आदेश>&no-i18n-cmd_goto;</command>(<प्रतिस्थापनीय>पोस्</"
"replaceable>)"

#. Tag: para
#: index.docbook:2687
#, no-c-format
msgid ""
"Sets the cursor to the given position and makes it visible in current view. "
"After this the selection has zero length."
msgstr ""
"कर्सरं दत्तस्थाने सेट् करोति वर्तमानदृश्ये च दृश्यमानं करोति । तदनन्तरं चयनस्य शून्यदीर्घता भवति "
"।"

#. Tag: entry
#: index.docbook:2693 index.docbook:2711 index.docbook:2756
#, no-c-format
msgid "<parameter>pos</parameter>:"
msgstr "<पैरामीटर्>पोस्</पैरामीटर>: ."

#. Tag: entry
#: index.docbook:2693
#, no-c-format
msgid "position in samples where to go to"
msgstr "नमूनासु स्थितिः कुत्र गन्तव्यम् इति"

#. Tag: title
#: index.docbook:2698
#, no-c-format
msgid "&no-i18n-tag;i"
msgstr "&न-इ१८न-टैग;इ"

#. Tag: title
#: index.docbook:2701
#, no-c-format
msgid "&no-i18n-cmd_insert_at;"
msgstr "&no-i18n-cmd_insert_at;"

#. Tag: title
#: index.docbook:2703
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_insert_at;</"
"command>(<replaceable>pos</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<आदेश>&no-i18n-cmd_insert_at;</command>(<प्रतिस्थापनीय>पोस्</"
"replaceable>)"

#. Tag: para
#: index.docbook:2704
#, no-c-format
msgid ""
"Inserts the content of the clipboard at the given position, like the command "
"<command>&no-i18n-cmd_paste;</command>(). If the clipboard is currently "
"empty, this function does nothing."
msgstr ""
"<command>&no-i18n-cmd_paste;</command>() इति आदेशः इव दत्तस्थाने क्लिप्बोर्डस्य "
"सामग्रीं निवेशयति । यदि क्लिप्बोर्ड् सम्प्रति रिक्तं भवति तर्हि एतत् कार्यं किमपि न करोति ।"

#. Tag: entry
#: index.docbook:2711
#, no-c-format
msgid "position in samples where to insert"
msgstr "नमूनासु स्थानं यत्र सम्मिलितं कर्तव्यम्"

#. Tag: title
#: index.docbook:2719
#, no-c-format
msgid "&no-i18n-cmd_insert_track;"
msgstr "&no-i18n-cmd_insert_track;"

#. Tag: title
#: index.docbook:2721
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_insert_track;</"
"command>(<replaceable>index</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<आदेश>&no-i18n-cmd_insert_track;</"
"command>(<प्रतिस्थापनीय>अनुक्रमणिका</replaceable>)"

#. Tag: para
#: index.docbook:2722
#, no-c-format
msgid ""
"Inserts a new track at the given index, using the current length and sample "
"rate settings of the signal. If the index is higher than or equal to the "
"current number of tracks, it will be appended as the last track, same as by "
"the command <command>&no-i18n-cmd_add_track;</command>(). The index of all "
"existing tracks at and after the given index will be incremented by one."
msgstr ""
"संकेतस्य वर्तमानदीर्घता, नमूनादरसेटिंग्स् च उपयुज्य दत्तसूचकाङ्के नूतनं पटलं सम्मिलितं करोति । "
"यदि अनुक्रमणिका वर्तमानपट्टिकासङ्ख्यायाः अपेक्षया अधिका वा समाना वा भवति तर्हि "
"अन्तिमपटलरूपेण संलग्नं भविष्यति, यथा <command>&no-i18n-cmd_add_track;</command>() "
"इति आदेशेन । दत्तसूचकाङ्के पश्चात् च सर्वेषां विद्यमानपट्टिकानां अनुक्रमणिका एकेन वर्धिता "
"भविष्यति ।"

#. Tag: entry
#: index.docbook:2733
#, no-c-format
msgid "index of the track to insert, starting with 0"
msgstr "0 इत्यस्मात् आरभ्य सम्मिलितं कर्तुं पटलस्य अनुक्रमणिका"

#. Tag: link
#: index.docbook:2737
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_add_track;</command>()"
msgstr "<आदेश>&no-i18n-tag;&no-i18n-cmd_add_track;</command>()"

#. Tag: title
#: index.docbook:2743
#, no-c-format
msgid "&no-i18n-tag;l"
msgstr "&no-i18n-tag;l"

#. Tag: title
#: index.docbook:2746
#, no-c-format
msgid "&no-i18n-cmd_label_add;"
msgstr "&कोई-i18n-cmd_लेबल_जोड़े;"

#. Tag: title
#: index.docbook:2748
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_label_add;</"
"command>(<replaceable>pos</replaceable>[,<replaceable>text</replaceable>])"
msgstr ""
"&i18n-cmd_syntax;<आदेश>&no-i18n-cmd_label_add;</command>(<प्रतिस्थापनीय>पोस्</"
"प्रतिस्थापनीय>[,<प्रतिस्थापनीय>पाठ</प्रतिस्थापनीय>])"

#. Tag: para
#: index.docbook:2749
#, no-c-format
msgid ""
"Add a new label at a given position. If the given position already contains "
"a label, then this command does nothing. The label can be given an optional "
"description."
msgstr ""
"दत्तस्थाने नूतनं लेबलं योजयन्तु। यदि दत्तस्थाने पूर्वमेव लेबल् अस्ति तर्हि एषः आदेशः किमपि न "
"करोति । लेबलं वैकल्पिकं वर्णनं दातुं शक्यते ।"

#. Tag: entry
#: index.docbook:2756
#, no-c-format
msgid "position in samples where to insert the label"
msgstr "नमूनासु स्थानं यत्र लेबलं सम्मिलितं कर्तव्यम्"

#. Tag: entry
#: index.docbook:2757 index.docbook:3055
#, no-c-format
msgid "<parameter>text</parameter>:"
msgstr "<पैरामीटर्>पाठ</parameter>: ."

#. Tag: entry
#: index.docbook:2757
#, no-c-format
msgid "some descriptive text (optional)"
msgstr "कश्चन वर्णनात्मकः पाठः (वैकल्पिकः)"

#. Tag: title
#: index.docbook:2762
#, no-c-format
msgid "&no-i18n-cmd_label_delete;"
msgstr "& no-i18n-cmd_label_delete;"

#. Tag: title
#: index.docbook:2764
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_label_delete;</"
"command>(<replaceable>index</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<आदेश>&no-i18n-cmd_label_delete;</"
"command>(<प्रतिस्थापनीय>अनुक्रमणिका</replaceable>)"

#. Tag: para
#: index.docbook:2765
#, no-c-format
msgid ""
"Deletes a label, identified by its index (starting from zero), or all labels "
"when using the special value -1 as index. If no label with the given index "
"exists, this command does nothing."
msgstr ""
"विशेषमूल्यं -1 अनुक्रमणिकारूपेण उपयुज्यमानं लेबलं, तस्य अनुक्रमणिकाद्वारा (शून्यतः आरभ्य), अथवा "
"सर्वाणि लेबलानि अपास्यति । यदि दत्तसूचकाङ्कयुक्तं लेबलं नास्ति तर्हि एषः आदेशः किमपि न "
"करोति ।"

#. Tag: entry
#: index.docbook:2772
#, no-c-format
msgid ""
"index of the label to delete, starting with 0 or -1 to delete all labels"
msgstr ""
"विलोपनीयस्य लेबलस्य अनुक्रमणिका, सर्वाणि लेबलानि विलोपयितुं 0 अथवा -1 इत्यस्मात् आरभ्य"

#. Tag: title
#: index.docbook:2778
#, no-c-format
msgid "&no-i18n-cmd_label_edit;"
msgstr "&no-i18n-cmd_लेबल_संपादन;"

#. Tag: screeninfo
#: index.docbook:2780 index.docbook:4379 index.docbook:4419 index.docbook:4564
#: index.docbook:4923 index.docbook:5231 index.docbook:5424 index.docbook:5460
