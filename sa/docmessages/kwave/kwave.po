"\"cmd_sect_quit\"><command>&no-i18n-tag;&no-i18n-cmd_quit;</command>()</link>"
msgstr ""
"<link linkend=\"cmd_sect_open\"><command>&amp;no-i18n-tag;&amp;no-i18n-"
"cmd_open;</command> (<replaceable> सञ्चिकानाम</replaceable> ) ९.</link> , ९."
"<link linkend=\"cmd_sect_quit\"><command> &amp;no-i18n-tag;&amp;no-i18n-"
"cmd_quit;</command> () ९.</link>"

