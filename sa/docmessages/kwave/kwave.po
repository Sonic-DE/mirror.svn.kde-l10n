#. Tag: title
#: index.docbook:2211
#, no-c-format
msgid "General Structure"
msgstr "सामान्य संरचना"

#. Tag: para
#: index.docbook:2212
#, no-c-format
msgid ""
"A &kwave; <emphasis>script</emphasis> consists of a list of lines, where "
"each line can be:"
msgstr ""
"A &wave; <emphasis>script</emphasis> इति रेखासूची भवति, यत्र प्रत्येकं पङ्क्तिः भवितुम् "
"अर्हति :"

#. Tag: para
#: index.docbook:2217
#, no-c-format
msgid "a single <emphasis>command</emphasis>,"
msgstr "एकः <emphasis>आदेशः</emphasis>,"

#. Tag: para
#: index.docbook:2220
#, no-c-format
msgid ""
"a <emphasis>command list</emphasis>, with two or more commands concatenated "
"by a <quote><token>;</token></quote>."
msgstr ""
"<emphasis>आदेशसूची</emphasis>, यत्र <quote><token>;</token></quote> इत्यनेन "
"संयोजिताः द्वौ वा अधिकौ आदेशौ ।"

#. Tag: para
#: index.docbook:2226
#, no-c-format
msgid "a <emphasis>comment</emphasis>,"
msgstr "a <emphasis>टिप्पणी</emphasis>,"

#. Tag: para
#: index.docbook:2229
#, no-c-format
msgid "a <emphasis>label</emphasis>"
msgstr "a <emphasis>लेबल</emphasis> इति"

#. Tag: para
#: index.docbook:2232
#, no-c-format
msgid "or an <emphasis>empty line</emphasis>, that contains white space only"
msgstr "अथवा <emphasis>रिक्तरेखा</emphasis>, यस्मिन् केवलं श्वेतस्थानं भवति"

#. Tag: title
#: index.docbook:2238
#, no-c-format
msgid "Comments and Empty Lines"
msgstr "टिप्पण्यानि तथा रिक्तपङ्क्तयः"

#. Tag: para
#: index.docbook:2239
#, no-c-format
msgid ""
"All characters that follow a <quote><token>#</token></quote> (except when "
"used in quotes or when escaped) are treated as comments, they will be "
"silently ignored."
msgstr ""
"<quote><token>#</token></quote> (उद्धरणेषु प्रयुक्तं वा पलायितं वा विहाय) ये वर्णाः "
"सन्ति ते सर्वे टिप्पणीरूपेण व्यवह्रियन्ते, ते मौनेन उपेक्षिताः भविष्यन्ति"

#. Tag: para
#: index.docbook:2244
#, no-c-format
msgid "Lines that contain only white space or comments are ignored as well."
msgstr "येषु पङ्क्तयः केवलं श्वेतस्थानं वा टिप्पण्याः वा सन्ति ताः अपि उपेक्षिताः भवन्ति ।"

#. Tag: title
#: index.docbook:2249
#, no-c-format
msgid "Termination"
msgstr "समाप्ति"

#. Tag: para
#: index.docbook:2250
#, no-c-format
msgid ""
"A &kwave; script terminates either when all commands have been executed "
"successfully without an error or when a command has returned an error code. "
"There is no special command for aborting the execution of a script. If you "
"want to implement a possibility for the user to end a script, you can use "
"the command <quote><link linkend=\"cmd_sect_msgbox\"><command>msgbox</"
"command></link>(<parameter><replaceable>text</replaceable></parameter>)</"
"quote>. This shows a message box with the two buttons <guibutton>OK</"
"guibutton> (which lets the script continue) and <guibutton>Cancel</"
"guibutton> (which returns an error code and stops the script)."
msgstr ""
"A &amp;wave; script समाप्तं भवति यदा सर्वे आदेशाः त्रुटिं विना सफलतया निष्पादिताः "
"भवन्ति अथवा यदा आदेशः त्रुटिसङ्केतं प्रत्यागच्छति । स्क्रिप्ट्-निष्पादनस्य निरसनार्थं विशेषः "
"आदेशः नास्ति । यदि भवान् उपयोक्तुः कृते स्क्रिप्ट् समाप्तुं संभावनां कार्यान्वितुं इच्छति तर्हि "
"भवान् आदेशस्य उपयोगं कर्तुं शक्नोति<quote><link linkend=\"cmd_sect_msgbox"
"\"><command> msgbox इति</command></link> (<parameter><replaceable> पाठ</"
"replaceable></parameter> ) ९.</quote> . एतेन द्वयोः बटनयोः सह सन्देशपेटिका "
"दृश्यते<guibutton> अस्तु</guibutton> (यत् लिपिं निरन्तरं कर्तुं शक्नोति) तथा च<guibutton> "
"निरसयतु</guibutton> (यत् त्रुटिसङ्केतं प्रत्यागच्छति स्क्रिप्ट् च स्थगयति) ।"

#. Tag: title
#: index.docbook:2263
#, no-c-format
msgid "Labels"
msgstr "लेबल्स्"

#. Tag: para
#: index.docbook:2264
#, no-c-format
msgid ""
"Lines that consist only of an identifier, followed by a <quote><token>:</"
"token></quote> are treated <emphasis>labels</emphasis>. They can be "
"referenced later in the script by the special keyword <command>GOTO</"
"command> <footnote><para>Note: Please don't mix up the keyword "
"<quote><command>GOTO</command></quote> with the text command <quote><link "
"linkend=\"cmd_sect_goto\"><command>goto</command></link> "
"(<parameter><replaceable>position</replaceable></parameter>)</quote> ! </"
"para></footnote> , which makes the execution of the script continue at the "
"location of that label (see example below)."
msgstr ""
"केवलं परिचयकयुक्ताः रेखाः, तदनन्तरं क<quote><token> : १.</token></quote> चिकित्सिताः "
"भवन्ति<emphasis> लेबल्</emphasis> . तेषां सन्दर्भः लिप्यां पश्चात् विशेषकीवर्डद्वारा कर्तुं "
"शक्यते<command> गोटो</command><footnote><para> नोटः- कृपया कीवर्डं न "
"मिश्रयन्तु<quote><command> गोटो</command></quote> पाठादेशेन सह<quote><link "
"linkend=\"cmd_sect_goto\"><command> गोतो</command></link> "
"(<parameter><replaceable> स्थितिः</replaceable></parameter> ) ९.</quote> !</"
"para></footnote> , यत् तस्य लेबलस्य स्थाने स्क्रिप्ट् इत्यस्य निष्पादनं निरन्तरं करोति (अधः "
"उदाहरणं पश्यन्तु) ।"

#. Tag: para
#: index.docbook:2277
#, no-c-format
msgid ""
"A line that contains a label must not contain any other content (except "
"comments or white space) after the <quote><token>:</token></quote>."
msgstr ""
"यस्मिन् पङ्क्तौ लेबलं भवति तस्मिन् <quote><token>:</token></quote> इत्यस्य अनन्तरं अन्यत् "
"किमपि सामग्री (टिप्पणीं वा श्वेतस्थानं वा विहाय) न भवितुमर्हति ।"

#. Tag: para
#: index.docbook:2281
#, no-c-format
msgid "Example:"
msgstr "उदाहरण:"

#. Tag: screen
#: index.docbook:2283
#, no-c-format
msgid ""
"<replaceable>start:</replaceable><literal>  # &lt;= this is a label</"
"literal>\n"
"            <literal>        # do something...</literal>\n"
"            <literal>        </literal><command>msgbox</"
"command>(<parameter>once again?</parameter>)\n"
"            <literal>        </literal><command>GOTO <parameter>start</"
"parameter></command>"
msgstr ""
"<replaceable>start:</replaceable><literal> # &lt;= एतत् लेबल</literal> अस्ति\n"
"            <literal> # किमपि कुरु…</literal>\n"
"            <literal> </literal><command>msgbox</command>(<parameter>पुनः "
"एकवारं?</parameter>)\n"
"            <literal> </literal><command>GOTO <पैरामीटर्>प्रारम्भ</parameter></"
"command>"

