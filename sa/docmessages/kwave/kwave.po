#: index.docbook:7907
#, no-c-format
msgid "&no-i18n-tag;Date"
msgstr "&no-i18n-tag;तिथिः"

#. Tag: entry
#: index.docbook:7908
#, no-c-format
msgid ""
"Specifies the date the subject of the file was created. Example: "
"<quote>2001-12-24</quote>"
msgstr ""
"सञ्चिकायाः विषयस्य निर्माणस्य तिथिं निर्दिशति । उदाहरणम् : <quote>2001-12-24</quote>"

