#. Tag: literal
#: index.docbook:5473
#, no-c-format
msgid "&no-i18n-plugin_goto;"
msgstr "&no-i18n-प्लगिन्_गोटो;"

#. Tag: para
#: index.docbook:5482
#, no-c-format
msgid ""
"Shows a dialog with the possibility to set the current position of the "
"selection to a new value, either by a time in milliseconds, by a position in "
"samples or by percentage of the length of the current file."
msgstr ""
"चयनस्य वर्तमानस्थानं नूतनमूल्ये सेट् कर्तुं सम्भावनायुक्तं संवादं दर्शयति, मिलीसेकेण्ड् मध्ये समयेन, "
"नमूनासु स्थानेन वा वर्तमानसञ्चिकायाः दीर्घतायाः प्रतिशतेन वा"

#. Tag: replaceable
#: index.docbook:5503 index.docbook:5595 index.docbook:5794 index.docbook:6022
#: index.docbook:7055
#, no-c-format
msgid "mode"
msgstr "मोड्"

#. Tag: entry
#: index.docbook:5516 index.docbook:5608
#, no-c-format
