#: index.docbook:6355
#, no-c-format
msgid ""
"Open the recording dialog and select the <guilabel>Format</guilabel> tab."
msgstr "रिकार्डिङ्ग् संवादं उद्घाट्य <guilabel>Format</guilabel> ट्याब् चिनोतु ।"

#. Tag: entry
#: index.docbook:6360
#, no-c-format
msgid "&no-i18n-tag;<command>source</command>"
msgstr "&no-i18n-tag;<आदेश>स्रोतः</command>"

