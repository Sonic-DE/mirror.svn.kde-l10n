#. Tag: title
#: index.docbook:5229
#, no-c-format
msgid "&no-i18n-plugin_export_k3b; (Export to K3b Project)"
msgstr "&no-i18n-प्लगइन_निर्यात_k3b; (K3b परियोजनायाः निर्यातः)"

#. Tag: phrase
#: index.docbook:5237
#, no-c-format
msgid "Screenshot of the K3b Export Plugin"
msgstr "K3b निर्यात प्लगिन् इत्यस्य स्क्रीनशॉट्"

#. Tag: literal
#: index.docbook:5244
#, no-c-format
msgid "&no-i18n-plugin_export_k3b;"
msgstr "&no-i18n-प्लगइन_निर्यात_k3b;"

#. Tag: para
#: index.docbook:5253
#, no-c-format
msgid ""
"Saves all sections between markers into a separate file and creates a K3b "
"project file. After having successfully written all files it is possible to "
"start <ulink url=\"&url_k3b;\">K3b</ulink> and burn the result to an audio "
"&CD;. This is useful for splitting a file with a recording that consists of "
"several parts, which are separated by labels, and then burn it to an audio "
"&CD; with multiple tracks, including &CD; text meta data which is extracted "
"from the descriptions of the labels."
msgstr ""
"मार्करयोः मध्ये सर्वान् विभागान् पृथक् सञ्चिकायां रक्षति तथा च K3b परियोजनासञ्चिकां "
"निर्माति । सर्वाणि सञ्चिकानि सफलतया लिखित्वा <ulink url=\"&url_k3b;\">K3b</"
"ulink> आरभ्य परिणामं श्रव्यं &CD;. एतत् अनेकभागैः युक्तेन रिकार्डिङ्ग् इत्यनेन सह सञ्चिकां "
"विभज्य, ये लेबलैः पृथक् भवन्ति, ततः श्रव्ये &CD; अनेकपट्टिकाभिः सह, यत्र &CD; text meta "
"data यत् लेबलानां वर्णनात् निष्कासितम् अस्ति।"

#. Tag: para
#: index.docbook:5263
#, no-c-format
msgid ""
"(This plugin is internally using the <link linkend=\"plugin_sect_saveblocks"
"\" endterm=\"plugin_title_saveblocks\"></link> plugin.)"
msgstr ""
"(एतत् प्लगिन् आन्तरिकरूपेण...<link linkend=\"plugin_sect_saveblocks\" endterm="
"\"plugin_title_saveblocks\"></link> प्लगिन्।)"

#. Tag: replaceable
#: index.docbook:5275 index.docbook:6503
#, no-c-format
msgid "pattern"
msgstr "प्रतिमानम्‌"

#. Tag: para
#: index.docbook:5277
#, no-c-format
msgid ""
"A pattern that will be used for detecting title and artist from the label at "
"the start of a section. It supports the following wildcards which will be "
"replaced by the corresponding content when creating the &CD; text meta data:"
msgstr ""
"एकं प्रतिरूपं यत् कस्यचित् विभागस्य आरम्भे लेबलतः शीर्षकं कलाकारं च ज्ञातुं प्रयुक्तं भविष्यति । "
"एतत् निम्नलिखितवाइल्डकार्ड्स् समर्थयति येषां स्थाने &CD; पाठ मेटा दत्तांशः :"

#. Tag: entry
#: index.docbook:5289 index.docbook:6516
#, no-c-format
msgid "wildcard"
msgstr "वाइल्डकार्ड"

#. Tag: entry
#: index.docbook:5295
#, no-c-format
msgid "&no-i18n-tag;<command>[%artist]</command>"
msgstr "&no-i18n-tag;<command>[%कलाकार]</command>"

#. Tag: entry
#: index.docbook:5296
#, no-c-format
msgid ""
"Will be replaced with the artist that performed the corresponding block or "
"alternatively the author."
msgstr "तत्सम्बद्धं खण्डं कृतवान् कलाकारः अथवा वैकल्पिकरूपेण लेखकः प्रतिस्थापितः भविष्यति।"

#. Tag: entry
#: index.docbook:5302 index.docbook:6559
#, no-c-format
msgid "&no-i18n-tag;<command>[%title]</command>"
msgstr "&no-i18n-tag;<command>[%title]</command> इति"

#. Tag: entry
#: index.docbook:5303 index.docbook:6560
#, no-c-format
msgid ""
"Will be replaced with the title of the block, which is taken from the "
"descriptive text of the label at the <emphasis>start</emphasis> of the "
"block. If that text is empty it will fall back to the title of the file (see "
"file information item \"<link linkend=\"INF_NAME\">Name</link>\"). If this "
"also does not exist, it will fall back to the base file name as described "
"above."
msgstr ""
"खण्डस्य शीर्षकं प्रतिस्थाप्यते, यत् लेबलस्य वर्णनात्मकपाठात् गृहीतम् अस्ति<emphasis> प्रारंभः</"
"emphasis> खण्डस्य । यदि सः पाठः रिक्तः अस्ति तर्हि सः पुनः सञ्चिकायाः शीर्षकं प्रति "
"पतति (सञ्चिकासूचना मदं पश्यन्तु &quot; ।<link linkend=\"INF_NAME\"> नामः</link> "
"&quot;). यदि इदमपि नास्ति तर्हि पूर्वोक्तरीत्या आधारसञ्चिकानाम्नि पुनः पतति ।"

#. Tag: para
#: index.docbook:5317
#, no-c-format
msgid ""
"Example: <quote><command><literal>[%title] ([%artist])</literal></command></"
"quote> will detect author <quote><command><literal>Beethoven</literal></"
"command></quote> and title <quote><command><literal>Symphony No. 5</"
"literal></command></quote> from the string <quote><command><literal>Symphony "
"No. 5 (Beethoven)</literal></command></quote>."
msgstr ""
"उदाहरणम् : <quote><command><literal>[%title] ([%artist])</literal></command></"
"quote> लेखकस्य <quote><command><literal>बीथोवेन्</literal> इति ज्ञास्यति </"
"command></quote> इति शीर्षकं च <quote><command><literal>सिम्फोनी क्रमाङ्कः ५</"
"literal></command></quote> इति तारात् <quote><command><literal>सिम्फोनी क्रमाङ्क "
"५ (बीथोवेन)</literal></command></quote> ।"

#. Tag: replaceable
#: index.docbook:5327 index.docbook:6644
#, no-c-format
msgid "selection only"
msgstr "चयनमात्रम्"

