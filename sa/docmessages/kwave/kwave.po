#: index.docbook:7955
#, no-c-format
msgid "&no-i18n-tag;Keywords"
msgstr "&no-i18n-tag;कीवर्ड"

#. Tag: entry
#: index.docbook:7956
#, no-c-format
msgid ""
"Provides a list of keywords that refer to the file or subject of the file."
msgstr "सञ्चिकायाः सञ्चिकां वा विषयं वा निर्दिशन्ति इति कीवर्डस्य सूचीं प्रदाति ।"

