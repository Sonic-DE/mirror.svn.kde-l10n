msgstr "<आदेश>&no-i18n-tag;&no-i18n-cmd_view_zoom_out;</command>()"

#. Tag: title
#: index.docbook:3998
#, no-c-format
msgid "&no-i18n-cmd_view_zoom_normal;"
msgstr "&no-i18n-cmd_view_zoom_normal;"

#. Tag: title
#: index.docbook:4000
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_zoom_normal;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<आदेश>&no-i18n-tag;&no-i18n-cmd_view_zoom_normal;</command>()"

#. Tag: para
#: index.docbook:4001
#, no-c-format
msgid ""
"Sets the zoom factor to one pixel per sample (factor 1.0) and tries to keep "
"the previous center of the view."
msgstr ""
"जूम् कारकं प्रति नमूना एकं पिक्सेलं (factor 1.0) सेट् करोति तथा च दृश्यस्य पूर्वकेन्द्रं स्थापयितुं "
"प्रयतते ।"

#. Tag: title
#: index.docbook:4009
#, no-c-format
msgid "&no-i18n-cmd_view_zoom_out;"
msgstr "&no-i18n-cmd_view_zoom_out;"

#. Tag: title
#: index.docbook:4011
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_view_zoom_out;"
"([<replaceable>position</replaceable>])</command>"
msgstr ""
"&i18n-cmd_syntax;<आदेश>&no-i18n-cmd_view_zoom_out;([<प्रतिस्थापनीय>स्थिति</"
"replaceable>])</command>"

#. Tag: para
#: index.docbook:4012
#, no-c-format
msgid ""
"Increases the zoom factor (in samples per pixel) by 30%, so that less "
"details get visible. If a <replaceable>position</replaceable> is given, it "
"tries to show that position centered in the current view, otherwise the "
"center of the view before the zoom change is used for centering. The maximum "
"zoom factor is limited to the number of samples of the complete signal and "
"the width of the view."
msgstr ""
"जूम-कारकं (प्रतिपिक्सेल-नमूनेषु) ३०% वर्धयति, येन न्यूनाः विवरणाः दृश्यन्ते । यदि "
"<replaceable>position</replaceable> दत्तं भवति तर्हि वर्तमानदृश्ये केन्द्रीकृतं तत् स्थानं "
"दर्शयितुं प्रयतते, अन्यथा जूमपरिवर्तनात् पूर्वं दृश्यस्य केन्द्रं केन्द्रीकरणार्थं उपयुज्यते अधिकतमं जूम "
"कारकं सम्पूर्णसंकेतस्य नमूनानां संख्यायां दृश्यस्य विस्तारं च सीमितं भवति ।"

#. Tag: entry
#: index.docbook:4025
#, no-c-format
msgid "a zero based position is samples to center the view (optional)"
msgstr "शून्याधारितं स्थानं दृश्यं केन्द्रीकृत्य नमूनानि भवति (वैकल्पिकम्) ।"

#. Tag: link
#: index.docbook:4029
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_view_zoom_in;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_view_zoom_in;</command>()"

#. Tag: title
#: index.docbook:4035
#, no-c-format
msgid "&no-i18n-cmd_view_zoom_selection;"
msgstr "&no-i18n-cmd_view_zoom_चयन;"

#. Tag: title
#: index.docbook:4037
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_zoom_selection;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<आदेश>&no-i18n-tag;&no-i18n-cmd_view_zoom_selection;</"
"command>()"

#. Tag: para
#: index.docbook:4038
#, no-c-format
msgid ""
"Adjusts the view (zoom factor and start of visible area) so that it matches "
"the current selection. This command does nothing if the selection is empty."
msgstr ""
"दृश्यं (zoom factor and start of visible area) समायोजयति यत् वर्तमानचयनेन सह मेलनं "
"करोति । एषः आदेशः किमपि न करोति यदि चयनं रिक्तं भवति ।"

#. Tag: title
#: index.docbook:4047
#, no-c-format
msgid "&no-i18n-tag;w"
msgstr "&no-i18n-tag;w"

#. Tag: title
#: index.docbook:4050
#, no-c-format
msgid "&no-i18n-cmd_window_activate;"
msgstr "&no-i18n-cmd_window_सक्रिय करना;"

#. Tag: title
#: index.docbook:4052
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_activate;</"
"command>(<replaceable>title</replaceable>])"
msgstr ""
"&i18n-cmd_syntax;<आदेश>&no-i18n-cmd_window_activate;</"
"command>(<प्रतिस्थापनीय>शीर्षक</प्रतिस्थापनीय>])"

#. Tag: para
#: index.docbook:4053
#, no-c-format
msgid ""
"Activates a sub-window, identified by its window <replaceable>title</"
"replaceable>. If the sub-window is minimized it will be restored. Only "
"available if in MDI and Tab mode. This command is internally used by the "
"<guisubmenu>Window</guisubmenu> menu."
msgstr ""
"उपविण्डो सक्रिययति, तस्य विण्डो <replaceable>title</replaceable> इत्यनेन चिह्नितं । "
"यदि उपविण्डो न्यूनीकृतं भवति तर्हि पुनः स्थाप्यते। केवलं MDI तथा Tab मोड् मध्ये चेत् एव "
"उपलब्धम् । एषः आदेशः आन्तरिकरूपेण <guisubmenu>Window</guisubmenu> मेन्यू द्वारा उपयुज्यते "
"।"

#. Tag: entry
#: index.docbook:4061
#, no-c-format
msgid "<parameter>title</parameter>:"
msgstr "<पैरामीटर्>शीर्षक</parameter>: ."

#. Tag: entry
#: index.docbook:4062
#, no-c-format
msgid "the title of the sub-window that should be activated"
msgstr "उपविण्डो इत्यस्य शीर्षकं यत् सक्रियं कर्तव्यम्"

#. Tag: title
#: index.docbook:4067
#, no-c-format
msgid "&no-i18n-cmd_window_cascade;"
msgstr "&no-i18n-cmd_विंडो_झरना;"

#. Tag: title
#: index.docbook:4069
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_cascade;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<आदेश>&no-i18n-tag;&no-i18n-cmd_window_cascade;</command>()"

#. Tag: para
#: index.docbook:4070
#, no-c-format
msgid ""
"Cascades all sub-windows when in MDI mode. All sub-windows that are "
"currently minimized stay minimized, they will not be restored."
msgstr ""
"MDI मोड् मध्ये सति सर्वाणि उप-विण्डोस् कैस्केड् करोति । सर्वे उपविण्डोः ये सम्प्रति न्यूनीकृताः "
"सन्ति ते न्यूनीकृताः तिष्ठन्ति, ते पुनः न स्थापिताः भविष्यन्ति ।"

#. Tag: title
#: index.docbook:4078
#, no-c-format
msgid "&no-i18n-cmd_window_click;"
msgstr "&no-i18n-cmd_window_click;"

#. Tag: title
#: index.docbook:4080
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_click;</"
"command>( <replaceable>class</replaceable>, <replaceable>x</replaceable>, "
"<replaceable>y</replaceable> )"
msgstr ""
"&i18n-cmd_syntax;<आदेश>&no-i18n-cmd_window_click;</"
"command>( <प्रतिस्थापनीय>वर्ग</प्रतिस्थापनीय>, <प्रतिस्थापनीय>x</प्रतिस्थापनीय>, "
"<प्रतिस्थापनीय>y</प्रतिस्थापनीय> )"

#. Tag: para
#: index.docbook:4085
#, no-c-format
msgid ""
"Sends a mouse click event to window, identified by its <replaceable>class</"
"replaceable> name. The event will only be sent to the first window that has "
"the given class name, therefore you should make sure that you have only one "
"instance of the given window when this command gets executed."
msgstr ""
"मूषकस्य क्लिक् इवेण्ट् विण्डो मध्ये प्रेषयति, यत् तस्य <replaceable>class</replaceable> "
"इति नाम्ना चिह्नितं भवति । घटना केवलं प्रथमविण्डो प्रति प्रेषिता भविष्यति यस्य दत्तं "
"वर्गनाम अस्ति, अतः भवता सुनिश्चितं कर्तव्यं यत् यदा एषः आदेशः निष्पादितः भवति तदा भवता "
"दत्तस्य विण्डो इत्यस्य एकः एव उदाहरणः अस्ति"

#. Tag: entry
#: index.docbook:4095 index.docbook:4119 index.docbook:4153 index.docbook:4204
#: index.docbook:4232 index.docbook:4257
#, no-c-format
msgid "<parameter>class</parameter>:"
msgstr "<पैरामीटर्>वर्गः</parameter>: ."

#. Tag: entry
#: index.docbook:4096 index.docbook:4120 index.docbook:4154 index.docbook:4205
#: index.docbook:4233 index.docbook:4258
#, no-c-format
msgid "name of the window class"
msgstr "विण्डो क्लास् इत्यस्य नाम"

#. Tag: entry
#: index.docbook:4097 index.docbook:4155
#, no-c-format
msgid "<parameter>x</parameter>:"
msgstr "<पैरामीटर्>x</पैरामीटर्>: ."

#. Tag: entry
#: index.docbook:4098 index.docbook:4156
#, no-c-format
msgid "x position, relative to the left border of the window (in pixels)"
msgstr "x स्थानं, विण्डो इत्यस्य वामसीमायाः सापेक्षम् (पिक्सेलरूपेण)"

#. Tag: entry
#: index.docbook:4099 index.docbook:4157
#, no-c-format
msgid "<parameter>y</parameter>:"
msgstr "<पैरामीटर्>य</पैरामीटर>: ."

#. Tag: entry
#: index.docbook:4100 index.docbook:4158
#, no-c-format
msgid "y position, relative to the top border of the window (in pixels)"
msgstr "y स्थानं, विण्डो इत्यस्य उपरितनसीमायाः सापेक्षम् (पिक्सेलेषु)"

#. Tag: title
#: index.docbook:4105
#, no-c-format
msgid "&no-i18n-cmd_window_close;"
msgstr "&no-i18n-cmd_window_close;"

#. Tag: title
#: index.docbook:4107
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_close;</"
"command>( <replaceable>class</replaceable> )"
msgstr ""
"&i18n-cmd_syntax;<आदेश>&no-i18n-cmd_window_close;</"
"command>( <प्रतिस्थापनीय>वर्ग</replaceable> )"

#. Tag: para
#: index.docbook:4110
#, no-c-format
msgid ""
"Closes a window, identified by its <replaceable>class</replaceable> name. "
"Only the first window that has the given class name will be closed, "
"therefore you should make sure that you have only one instance of the given "
"window when this command gets executed."
msgstr ""
"तस्य <replaceable>वर्ग</replaceable> इति नाम्ना चिह्नितं विण्डो पिधायति । केवलं प्रथमं "
"विण्डो यस्य दत्तं वर्गनाम अस्ति तत् एव पिहितं भविष्यति, अतः भवता सुनिश्चितं कर्तव्यं यत् यदा "
"एषः आदेशः निष्पादितः भवति तदा भवता दत्तस्य विण्डो इत्यस्य एकः एव उदाहरणः अस्ति ।"

#. Tag: title
#: index.docbook:4125
#, no-c-format
msgid "&no-i18n-cmd_window_minimize;"
msgstr "&no-i18n-cmd_window_minimize;"

#. Tag: title
#: index.docbook:4127
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-cmd_window_minimize;</command>"
msgstr "&i18n-cmd_syntax;<आदेश>&no-i18n-cmd_window_minimize;</command>"

#. Tag: para
#: index.docbook:4128
#, no-c-format
msgid ""
"Minimizes the currently active sub-window when in MDI mode or the current "
"toplevel window when in SDI or Tab mode."
msgstr ""
"MDI मोड् मध्ये वर्तमानं सक्रियं उप-विण्डो अथवा SDI अथवा Tab मोड् मध्ये वर्तमानं toplevel "
"विण्डो न्यूनीकरोति ।"

#. Tag: title
#: index.docbook:4136
#, no-c-format
msgid "&no-i18n-cmd_window_mousemove;"
msgstr "&no-i18n-cmd_window_mousemove;"

#. Tag: title
#: index.docbook:4138
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_resize;</"
"command>( <replaceable>class</replaceable>, <replaceable>x</replaceable>, "
"<replaceable>y</replaceable> )"
msgstr ""
"&i18n-cmd_syntax;<आदेश>&no-i18n-cmd_window_resize;</"
"command>( <प्रतिस्थापनीय>वर्ग</प्रतिस्थापनीय>, <प्रतिस्थापनीय>x</प्रतिस्थापनीय>, "
"<प्रतिस्थापनीय>y</प्रतिस्थापनीय> )"

#. Tag: para
#: index.docbook:4143
#, no-c-format
msgid ""
"Sends a mouse move event to window, identified by its <replaceable>class</"
"replaceable> name. The event will only be sent to the first window that has "
"the given class name, therefore you should make sure that you have only one "
"instance of the given window when this command gets executed."
msgstr ""
"मूषकस्य चालनघटनां विण्डो मध्ये प्रेषयति, तस्य <replaceable>वर्ग</replaceable> इति "
"नाम्ना चिह्नितं । घटना केवलं प्रथमविण्डो प्रति प्रेषिता भविष्यति यस्य दत्तं वर्गनाम अस्ति, "
"अतः भवता सुनिश्चितं कर्तव्यं यत् यदा एषः आदेशः निष्पादितः भवति तदा भवता दत्तस्य विण्डो "
"इत्यस्य एकः एव उदाहरणः अस्ति"

#. Tag: title
#: index.docbook:4163
#, no-c-format
msgid "&no-i18n-cmd_window_next_sub;"
msgstr "&no-i18n-cmd_विंडो_अगला_उप;"

#. Tag: title
#: index.docbook:4165
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_next_sub;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<आदेश>&no-i18n-tag;&no-i18n-cmd_window_next_sub;</command>()"

#. Tag: para
#: index.docbook:4166
#, no-c-format
msgid ""
"Activates the <emphasis>next</emphasis> sub-window when in MDI or Tab mode. "
"If the next sub-window is minimized it will be restored."
msgstr ""
"MDI अथवा Tab मोड् मध्ये <emphasis>next</emphasis> उप-विण्डो सक्रियं करोति । यदि "
"अग्रिमः उप-विण्डो न्यूनीकृतः भवति तर्हि तत् पुनः स्थापितं भविष्यति ।"

#. Tag: title
#: index.docbook:4174
#, no-c-format
msgid "&no-i18n-cmd_window_prev_sub;"
msgstr "&no-i18n-cmd_विंडो_पूर्व_उप;"

#. Tag: title
#: index.docbook:4176
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_prev_sub;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<आदेश>&no-i18n-tag;&no-i18n-cmd_window_prev_sub;</command>()"

#. Tag: para
#: index.docbook:4177
#, no-c-format
msgid ""
"Activates the <emphasis>previous</emphasis> sub-window when in MDI or Tab "
"mode. If the previous sub-window is minimized it will be restored."
msgstr ""
"MDI अथवा Tab मोड् मध्ये <emphasis>पूर्वं</emphasis> उपविण्डो सक्रियं करोति । यदि "
"पूर्वस्य उपविण्डो न्यूनीकृतः भवति तर्हि पुनः स्थाप्यते ।"

#. Tag: title
#: index.docbook:4185
#, no-c-format
msgid "&no-i18n-cmd_window_resize;"
msgstr "& no-i18n-cmd_विंडो_आकार;"

#. Tag: title
#: index.docbook:4187
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_resize;</"
"command>( <replaceable>class</replaceable>, <replaceable>width</"
"replaceable>, <replaceable>height</replaceable> )"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_resize;</"
"command>( <प्रतिस्थापनीय>वर्ग</replaceable>, <प्रतिस्थापनीय>विस्तार</replaceable>, "
"<प्रतिस्थापनीय>उच्चता</replaceable> )"

#. Tag: para
#: index.docbook:4192
#, no-c-format
msgid ""
"Changes the size of a window, identified by its <replaceable>class</"
"replaceable> name to a new <replaceable>width</replaceable> and "
"<replaceable>height</replaceable>. The change will only be applied to the "
"first window that has the given class name, therefore you should make sure "
"that you have only one instance of the given window when this command gets "
"executed."
msgstr ""
"तस्य <replaceable>class</replaceable> इति नाम्ना चिह्नितस्य विण्डो इत्यस्य आकारं नूतनं "
"<replaceable>width</replaceable> तथा <replaceable>height</replaceable> इति "
"परिवर्तयति । परिवर्तनं केवलं प्रथमे विण्डो मध्ये प्रयुक्तं भविष्यति यस्य दत्तं वर्गनाम अस्ति, "
"अतः भवता सुनिश्चितं कर्तव्यं यत् यदा एषः आदेशः निष्पादितः भवति तदा भवता दत्तस्य विण्डो "
"इत्यस्य एकः एव उदाहरणः अस्ति"

#. Tag: entry
#: index.docbook:4206
#, no-c-format
msgid "<parameter>width</parameter>:"
msgstr "<पैरामीटर्>विस्तार</parameter>: ."

#. Tag: entry
#: index.docbook:4207
#, no-c-format
msgid "new width of the window (in pixels)"
msgstr "विण्डो इत्यस्य नूतनविस्तारः (पिक्सेलरूपेण)"

#. Tag: entry
#: index.docbook:4208
#, no-c-format
msgid "<parameter>height</parameter>:"
msgstr "<पैरामीटर्>उच्चता</parameter>: ."

#. Tag: entry
#: index.docbook:4209
#, no-c-format
msgid "new height of the window (in pixels)"
msgstr "विण्डो इत्यस्य नूतना ऊर्ध्वता (पिक्सेल-मात्रायां) ।"

#. Tag: title
#: index.docbook:4214
#, no-c-format
msgid "&no-i18n-cmd_window_screenshot;"
msgstr "&no-i18n-cmd_window_screenshot;"

#. Tag: title
#: index.docbook:4216
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_screenshot;</"
"command>( <replaceable>class</replaceable>, <replaceable>filename</"
"replaceable> )"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_screenshot;</"
"command>( <प्रतिस्थापनीय>वर्ग</replaceable>, <प्रतिस्थापनीय>सञ्चिकानाम</"
"प्रतिस्थापनीय> )"

#. Tag: para
#: index.docbook:4220
#, no-c-format
msgid ""
"Takes a screenshot of a window, identified by its <replaceable>class</"
"replaceable> and saves it to a file. The screenshot will be taken from the "
"first window that has the given class name, therefore you should make sure "
"that you have only one instance of the given window when this command gets "
"executed. Currently the format of the file is hardcoded and has to be "
"<literal>*.png</literal>."
msgstr ""
"विण्डो इत्यस्य स्क्रीनशॉट् गृहीत्वा, तस्य <replaceable>वर्गेण</replaceable> इत्यनेन "
"चिह्नितं कृत्वा सञ्चिकायां रक्षति । स्क्रीनशॉट् प्रथमविण्डोतः गृहीतं भविष्यति यस्य दत्तं "
"वर्गनाम अस्ति, अतः भवन्तः सुनिश्चितं कुर्वन्तु यत् यदा एषः आदेशः निष्पादितः भवति तदा "
"दत्तस्य विण्डो इत्यस्य एकः एव उदाहरणं भवतः अस्ति सम्प्रति सञ्चिकायाः प्रारूपं हार्डकोडेड् "
"अस्ति तथा च <literal>*.png</literal> भवितुमर्हति ।"

#. Tag: entry
#: index.docbook:4235
#, no-c-format
msgid ""
"name of the file to save the screenshot, must have the extension <literal>*."
"png</literal>"
msgstr ""
"स्क्रीनशॉट् रक्षितुं सञ्चिकायाः नाम, <literal>*.png</literal> इति विस्तारः भवितुमर्हति"

#. Tag: title
#: index.docbook:4241
#, no-c-format
msgid "&no-i18n-cmd_window_sendkey;"
msgstr "&no-i18n-cmd_window_sendkey;"

#. Tag: title
#: index.docbook:4243
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_sendkey;</"
"command>( <replaceable>class</replaceable>, <replaceable>key code</"
"replaceable> )"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_sendkey;</"
"command>( <प्रतिस्थापनीय>वर्ग</replaceable>, <प्रतिस्थापनीय>कुंजीसङ्केत</"
"replaceable> )"

#. Tag: para
#: index.docbook:4247
#, no-c-format
msgid ""
"Sends a key press and release event to a window, identified by its "
"<replaceable>class</replaceable> name. The key will only be sent to the "
"first window that has the given class name, therefore you should make sure "
"that you have only one instance of the given window when this command gets "
"executed."
msgstr ""
"तस्य <replaceable>वर्ग</replaceable> इति नाम्ना चिह्नितं विण्डो मध्ये कील-दबाव-"
"विमोचन-घटनाम् प्रेषयति । कीलः केवलं प्रथमे विण्डो मध्ये प्रेषितः भविष्यति यस्य दत्तं वर्गनाम "
"अस्ति, अतः भवता सुनिश्चितं कर्तव्यं यत् यदा एषः आदेशः निष्पादितः भवति तदा भवता दत्तस्य "
"विण्डो इत्यस्य एकः एव उदाहरणः अस्ति"

#. Tag: entry
#: index.docbook:4259
#, no-c-format
msgid "<parameter>key code</parameter>:"
msgstr "<parameter>कुंजीसङ्केतः</parameter>:"

#. Tag: entry
#: index.docbook:4260
#, no-c-format
msgid ""
"the key code that should be sent, using the same syntax as used for setting "
"up menus"
msgstr ""
"मेनूस्थापनार्थं यत् वाक्यविन्यासं प्रयुक्तं तत् एव वाक्यविन्यासं उपयुज्य यः कीलसङ्केतः प्रेषितव्यः"

#. Tag: para
#: index.docbook:4264
#, no-c-format
msgid ""
"Description of the parameter <link linkend=\"cmd_menu_param_hotkey"
"\"><parameter>hotkey</parameter></link> of the <command>&no-i18n-cmd_menu;</"
"command>() command."
msgstr ""
"पैरामीटर् इत्यस्य वर्णनम्<link linkend=\"cmd_menu_param_hotkey\"><parameter> "
"हॉटकी</parameter></link> इति<command> &amp;no-i18n-cmd_menu;</command> () "
"आदेश।"

#. Tag: title
#: index.docbook:4273
#, no-c-format
msgid "&no-i18n-cmd_window_tile;"
msgstr "&no-i18n-cmd_विंडो_टाइल;"

#. Tag: title
#: index.docbook:4275
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_tile;</command>()"
msgstr ""
"&i18n-cmd_syntax;<आदेश>&no-i18n-tag;&no-i18n-cmd_window_tile;</command>()"

#. Tag: para
#: index.docbook:4276
#, no-c-format
msgid ""
"Tiles all sub-windows when in MDI mode, using some scheme of &plasma;. All "
"sub-windows that are currently minimized stay minimized, they will not be "
"restored."
msgstr ""
"MDI मोड् मध्ये स्थित्वा सर्वाणि उप-विण्डोस् टाइल् करोति, &plasma; इत्यस्य किञ्चित् योजनां "
"उपयुज्य । सर्वे उपविण्डोः ये सम्प्रति न्यूनीकृताः सन्ति ते न्यूनीकृताः तिष्ठन्ति, ते पुनः न "
"स्थापिताः भविष्यन्ति ।"

#. Tag: title
#: index.docbook:4285
#, no-c-format
msgid "&no-i18n-cmd_window_tile_vertical;"
msgstr "&no-i18n-cmd_विंडो_टाइल_ऊर्ध्वाधर;"

#. Tag: title
#: index.docbook:4287
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_tile_vertical;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_tile_vertical;</"
"command>()"

#. Tag: para
#: index.docbook:4288
#, no-c-format
msgid ""
"Tiles all sub-windows vertically when in MDI mode. All windows that are "
"currently minimized stay minimized, they will not be restored."
msgstr ""
"MDI मोड् मध्ये सर्वाणि उप-विण्डो-इत्येतत् लम्बवत् टाइल् करोति । सर्वे विण्डोः ये सम्प्रति "
"न्यूनीकृताः सन्ति ते न्यूनीकृताः तिष्ठन्ति, ते पुनः न स्थापिताः भविष्यन्ति ।"

