#. Tag: para
#: index.docbook:40
#, no-c-format
msgid ""
"&ktorrent; is a bittorrent application by KDE which allows you to download "
"files using the BitTorrent protocol. It enables you to run multiple torrents "
"at the same time and comes with extended features to make it a full-featured "
"client for BitTorrent."
msgstr ""
"&ktorrent; KDE द्वारा bittorrent अनुप्रयोगः अस्ति यत् BitTorrent प्रोटोकॉलस्य "
"उपयोगेन सञ्चिकाः डाउनलोड् कर्तुं शक्नोति । एतत् भवन्तं एकस्मिन् समये बहुविधं टोरेण्ट् चालयितुं "
"समर्थयति तथा च विस्तारितविशेषताभिः सह आगच्छति यत् इदं BitTorrent कृते पूर्णविशेषतायुक्तं "
"क्लायन्ट् भवति ।"

#. Tag: title
#: index.docbook:43
#, no-c-format
msgid "Features"
msgstr "गुणाः"

#. Tag: para
#: index.docbook:44
#, no-c-format
msgid "Queuing of torrents"
msgstr "धाराणां पङ्क्तिः"

#. Tag: para
#: index.docbook:45
#, no-c-format
msgid "Global and per torrent speed limits"
msgstr "वैश्विकं तथा प्रति धारा गतिसीमा"

#. Tag: para
#: index.docbook:46
#, no-c-format
msgid "Previewing of certain file types, build in (video and audio)"
msgstr "कतिपयानां सञ्चिकाप्रकारस्य पूर्वावलोकनं, बिल्ड् इन (वीडियो तथा श्रव्य)"

#. Tag: para
#: index.docbook:47
#, no-c-format
msgid "Importing of partially or fully downloaded files"
msgstr "आंशिकरूपेण अथवा पूर्णतया अवतरणं कृतानां सञ्चिकानां आयातम्"

#. Tag: para
#: index.docbook:48
#, no-c-format
msgid "File prioritization for multi-file torrents"
msgstr "बहुसञ्चिका-प्रवाहानाम् कृते सञ्चिका-प्राथमिकता"

#. Tag: para
#: index.docbook:49
#, no-c-format
msgid "Selective downloading for multi-file torrents"
msgstr "बहुसञ्चिका-प्रवाहानाम् कृते चयनात्मकं डाउनलोड् करणं"

#. Tag: para
#: index.docbook:50
#, no-c-format
msgid ""
"Kick/ban peers with an additional IP Filter dialog for list/edit purposes"
msgstr "सूची/सम्पादनार्थं अतिरिक्तं IP Filter संवादं सह किक/बैन् समवयस्कानाम्"

#. Tag: para
#: index.docbook:51
#, no-c-format
msgid "UDP tracker support"
msgstr "UDP ट्रैकर समर्थनम्"

#. Tag: para
#: index.docbook:52
#, no-c-format
msgid "Support for private trackers and torrents"
msgstr "निजी ट्रैकर तथा टोरेण्ट् इत्येतयोः समर्थनम्"

#. Tag: para
#: index.docbook:53
#, no-c-format
msgid "Support for µTorrent's peer exchange"
msgstr "μTorrent इत्यस्य सहकर्मीविनिमयस्य समर्थनम्"

#. Tag: para
#: index.docbook:54
#, no-c-format
msgid "Support for protocol encryption (compatible with Azureus)"
msgstr "प्रोटोकॉल एन्क्रिप्शनस्य समर्थनम् (Azureus इत्यनेन सह सङ्गतम्)"

#. Tag: para
#: index.docbook:55
#, no-c-format
msgid "Support for creating trackerless torrents"
msgstr "trackerless torrents निर्मातुं समर्थनम्"

#. Tag: para
#: index.docbook:56
#, no-c-format
msgid "Support for distributed hash tables (DHT, the Mainline version)"
msgstr "वितरितहैशसारणीनां समर्थनम् (DHT, Mainline संस्करणम्)"

#. Tag: para
#: index.docbook:57
#, no-c-format
msgid ""
"Support for UPnP to automatically forward ports on a LAN with dynamic "
"assigned hosts"
msgstr ""
"गतिशीलनिर्धारितहोस्ट्-सहितं LAN-मध्ये स्वयमेव पोर्ट्-अग्रे प्रेषणार्थं UPnP-इत्यस्य समर्थनम्"

#. Tag: para
#: index.docbook:58
#, no-c-format
msgid "Support for webseeds"
msgstr "जालबीजानां समर्थनम्"

#. Tag: para
#: index.docbook:59
#, no-c-format
msgid "System tray integration"
msgstr "प्रणाली ट्रे एकीकरण"

#. Tag: para
#: index.docbook:60
#, no-c-format
msgid "Tracker authentication support"
msgstr "ट्रैकर प्रमाणीकरणसमर्थनम्"

#. Tag: para
#: index.docbook:61
#, no-c-format
msgid "Connection though a proxy"
msgstr "संयोजनं यद्यपि प्रॉक्सी"

#. Tag: para
#: index.docbook:62
#, no-c-format
msgid "Interprocess control via DBus interface"
msgstr "DBus अन्तरफलकद्वारा अन्तरप्रक्रियानियन्त्रणम्"

