#, no-c-format
msgid "Procedure to edit layout:"
msgstr "विन्यासं सम्पादयितुं प्रक्रिया :"

#. Tag: para
#: index.docbook:303
#, no-c-format
msgid ""
"Use the board editor toolbar to create a new layout or to load and edit an "
"existing one."
msgstr ""
"नूतनं विन्यासं निर्मातुं अथवा विद्यमानं लोड् सम्पादयितुं वा board editor toolbar इत्यस्य "
"उपयोगं कुर्वन्तु ।"

#. Tag: para
#: index.docbook:304
#, no-c-format
msgid ""
"Save the layout in your user's local home folder in <filename>"
"$<envar>XDG_DATA_HOME</envar>/kmahjongg/layouts</filename>"
msgstr ""
"<filename>$<envar>XDG_DATA_HOME</envar>/kmahjongg/layouts</filename> इत्यत्र "
"स्वस्य उपयोक्तुः स्थानीयगृहपुटे विन्यासं रक्षन्तु"

#. Tag: para
#: index.docbook:305
#, no-c-format
msgid ""
"Create the <filename><replaceable>name_of_your_layout</replaceable>.desktop</"
"filename> file in the same folder."
msgstr ""
"<filename><replaceable>name_of_your_layout</replaceable>.desktop</filename> "
"सञ्चिकां तस्मिन् एव पुटे रचयन्तु ।"

#. Tag: para
#: index.docbook:306
#, no-c-format
msgid "Put the following lines in this file using your favorite text editor:"
msgstr "अस्मिन् सञ्चिकायां स्वस्य प्रियपाठसम्पादकस्य उपयोगेन निम्नलिखितपङ्क्तयः स्थापयन्तु ।"

#. Tag: programlisting
#: index.docbook:307
#, no-c-format
msgid ""
"[KMahjonggLayout]\n"
"Name=<replaceable>name_of_your_layout</replaceable>\n"
"Description=<replaceable>description_of_your_layout</replaceable>\n"
"VersionFormat=1\n"
"Author=<replaceable>your_name</replaceable>\n"
"AuthorEmail=<replaceable>your_email</replaceable>\n"
"FileName=<replaceable>name_of_your_layout</replaceable>.layout"
msgstr ""
"[KMahjonggLayout] इति ।\n"
"Name=<replaceable>भवतः_विन्यासस्य_नाम</replaceable>\n"
"Description=<replaceable>भवतः_विन्यासस्य_वर्णनम्</replaceable>\n"
"संस्करणस्वरूप=1\n"
"लेखक=<replaceable>भवतः_नाम</replaceable>\n"
"AuthorEmail=<replaceable>भवतः_ईमेल</replaceable>\n"
"FileName=<प्रतिस्थापनीय>भवतः_विन्यासस्य_नाम</replaceable>.layout"

#. Tag: para
#: index.docbook:308
#, no-c-format
msgid "Reload &kmahjongg; to use your new layout."
msgstr "पुनः लोड करें &kmahjongg; भवतः नूतनविन्यासस्य उपयोगाय ।"

#. Tag: menuchoice
