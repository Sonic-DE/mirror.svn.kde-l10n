#: index.docbook:415
#, no-c-format
msgid "<phrase>Configure Dialog</phrase>"
msgstr "<phrase>संवादं विन्यस्य</phrase>"

#. Tag: para
#: index.docbook:420
#, no-c-format
msgid ""
"<menuchoice><guimenu>Settings</guimenu><guimenuitem>Configure &kmahjongg;…</"
"guimenuitem></menuchoice> opens the <guilabel>Configure - &kmahjongg;</"
"guilabel> dialog."
msgstr ""
"<menuchoice><guimenu>सेटिंग्स्</guimenu><guimenuitem>&kmahjongg;…</guimenuitem></"
"menuchoice> विन्यस्तं कुर्वन्तु <guilabel>विन्यस्तं कुर्वन्तु - &kmahjongg;</guilabel> "
"संवादं उद्घाटयति ।"

