#. Tag: keyword
#: index.docbook:22
#, no-c-format
msgid "System Settings"
msgstr "सिस्टम् सेटिंग्स्"

#. Tag: keyword
#: index.docbook:23
#, no-c-format
msgid "desktop"
msgstr "डेस्कटॉप् इति"

#. Tag: keyword
#: index.docbook:24
#, no-c-format
msgid "workspace"
msgstr "कार्यक्षेत्रम्"

#. Tag: para
#: index.docbook:29
#, no-c-format
msgid "This is a module to configure general workspace behavior."
msgstr "सामान्यकार्यक्षेत्रव्यवहारं विन्यस्तुं एतत् मॉड्यूल् अस्ति ।"

#. Tag: guilabel
#: index.docbook:35
#, no-c-format
msgid "Allow Plasma to show panel and widget tooltips"
msgstr ""

#. Tag: para
#: index.docbook:37
#, no-c-format
msgid ""
"If this option is checked, tooltips are displayed hovering items in the "
"&plasma; panel or on the desktop."
msgstr "यदि एषः विकल्पः परीक्षितः अस्ति तर्हि &plasma; panel अथवा डेस्कटॉप् इत्यत्र ।"

#. Tag: guilabel
#: index.docbook:43
#, no-c-format
msgid "Allow Plasma to show OSD popups for status changes"
msgstr ""

#. Tag: para
#: index.docbook:45
#, no-c-format
msgid ""
"If this option is checked, all Plasma widgets are allowed to show on-screen "
"display (OSD) popups for changes like volume and brightness level, or audio "
"device switching."
msgstr ""

#. Tag: guilabel
#: index.docbook:50
#, no-c-format
msgid "Animation speed"
msgstr "एनिमेशन वेग"

#. Tag: para
#: index.docbook:52
#, no-c-format
msgid ""
"Allows you to set the speed of desktop effect animations from "
"<guilabel>Slow</guilabel> to <guilabel>Instant</guilabel>."
msgstr ""
"<guilabel>Slow</guilabel> इत्यस्मात् <guilabel>Instant</guilabel> इत्यस्मै डेस्कटॉप् "
"इफेक्ट् एनिमेशन्स् इत्यस्य गतिं सेट् कर्तुं शक्नोति ।"

#. Tag: menuchoice
#: index.docbook:57
#, no-c-format
msgid ""
"<guimenu>Clicking files or folders</guimenu><guimenuitem>Opens them</"
"guimenuitem>"
msgstr ""
"<guimenu>सञ्चिकाः अथवा पुटं क्लिक् कृत्वा</guimenu><guimenuitem>ताः उद्घाटयति</"
"guimenuitem>"

#. Tag: para
#: index.docbook:59
#, no-c-format
msgid ""
"If this option is checked, then files and folders will be opened with a "
"single click of the <mousebutton>left</mousebutton> mouse button. To select "
"files and folders, you can <mousebutton>left</mousebutton>-click on their "
"selection markers, drag a selection rectangle around them, or <keycombo "
"action=\"simul\">&Ctrl;<mousebutton>Left</mousebutton></keycombo>-click. "
"This is the default behavior, and it's designed to be consistent with what "
"you would expect when you click links in web browsers."
msgstr ""
"यदि एषः विकल्पः परीक्षितः अस्ति तर्हि <mousebutton>left</mousebutton> मूषकस्य "
"बटनस्य एकेन क्लिक् कृत्वा सञ्चिकाः, पुटं च उद्घाटिताः भविष्यन्ति । सञ्चिकाः, पुटं च चिन्वितुं, "
"भवान् <mousebutton>वाम</mousebutton>-तेषां चयनचिह्नेषु क्लिक् कर्तुं, तेषां परितः चयनआयतं "
"कर्षयितुं, अथवा <keycombo action=\"simul\">&Ctrl;<mousebutton>वाम</"
"mousebutton>< कर्तुं शक्नोति /keycombo>-क्लिक् कुर्वन्तु। एषः पूर्वनिर्धारितः व्यवहारः "
"अस्ति, तथा च जालपुटेषु लिङ्क् क्लिक् कृत्वा भवन्तः यत् अपेक्षन्ते तस्य अनुरूपं भवितुं विनिर्मितम् "
"अस्ति ।"

#. Tag: menuchoice
#: index.docbook:64
#, no-c-format
msgid ""
"<guimenu>Clicking files or folders</guimenu><guimenuitem>Selects them</"
"guimenuitem>"
msgstr ""
"<guimenu>सञ्चिकाः अथवा पुटं क्लिक् कृत्वा</guimenu><guimenuitem>तान् चयनं करोति</"
"guimenuitem>"

#. Tag: para
#: index.docbook:66
#, no-c-format
msgid ""
"If this option is checked, then files and folders must be double-clicked to "
"be opened, while a single click will select them. This is the behavior you "
"may know from other desktops or operating systems."
msgstr ""
"यदि एषः विकल्पः परीक्षितः अस्ति तर्हि सञ्चिकाः, पुटं च उद्घाटयितुं द्विवारं क्लिक् "
"करणीयाः, यदा तु एकेन क्लिक् कृत्वा तान् चयनं करिष्यति । एषः एव व्यवहारः अन्येभ्यः डेस्कटॉप्-"
"भ्यः अथवा ऑपरेटिङ्ग्-सिस्टम्-भ्यः भवन्तः ज्ञातुं शक्नुवन्ति ।"

#. Tag: menuchoice
#: index.docbook:71
#, no-c-format
msgid ""
"<guimenu>Clicking in scrollbar track</guimenu><guimenuitem>Scrolls one page "
"up and down</guimenuitem>"
msgstr ""
"<guimenu>स्क्रॉलबार ट्रैक इत्यत्र क्लिक् करणं</guimenu><guimenuitem>एकं पृष्ठं उपरि अधः च "
"स्क्रॉल करोति</guimenuitem>"

#. Tag: para
#: index.docbook:73
#, no-c-format
msgid ""
"This is the default setting. Left-click in scrollbar track moves scrollbar "
"by one page."
msgstr ""
"एतत् पूर्वनिर्धारितं सेटिङ्ग् अस्ति । स्क्रॉलबार-पट्टिकायां वाम-क्लिक् कृत्वा स्क्रॉलबारं एकेन "
"पृष्ठेन चालयति ।"

#. Tag: menuchoice
#: index.docbook:78
#, no-c-format
msgid ""
"<guimenu>Clicking in scrollbar track</guimenu><guimenuitem>Scrolls to the "
"clicked location</guimenuitem>"
msgstr ""
"<guimenu>स्क्रॉलबार ट्रैक इत्यत्र क्लिक् करणं</guimenu><guimenuitem>क्लिक् कृतं स्थानं प्रति "
"स्क्रॉलं करोति</guimenuitem>"

#. Tag: para
#: index.docbook:80
#, no-c-format
msgid ""
"Turns on the behavior when the scroll handle position jumps right to the "
"position in the document where you have clicked. This is the behavior you "
"may know from other desktops or operating systems."
msgstr ""
"यदा स्क्रॉल-हन्डल-स्थानं दस्तावेजे यत्र भवान् क्लिक् कृतवान् तत्रैव कूर्दति तदा व्यवहारं चालू "
"करोति । एषः एव व्यवहारः अन्येभ्यः डेस्कटॉप्-भ्यः अथवा ऑपरेटिङ्ग्-सिस्टम्-भ्यः भवन्तः ज्ञातुं "
"शक्नुवन्ति ।"

#. Tag: menuchoice
#: index.docbook:85
#, no-c-format
msgid ""
"<guimenu>Middle Click</guimenu><guimenuitem>Paste selected text</guimenuitem>"
msgstr ""
"<guimenu>मध्यं क्लिक् कुर्वन्तु</guimenu><guimenuitem>चयनितं पाठं चिनोतु</guimenuitem>"

#. Tag: para
#: index.docbook:87
#, no-c-format
msgid ""
"If this option is checked, middle-clicking in a text field will paste from "
"the clipboard, just like you would with <keycombo action=\"simul\">&Ctrl;"
"<keysym>V</keysym></keycombo>."
msgstr ""
"यदि एषः विकल्पः परीक्षितः अस्ति तर्हि पाठक्षेत्रे मध्य-क्लिक् करणं क्लिप्बोर्डतः चिनोति, "
"यथा भवान् <keycombo action=\"simul\">&Ctrl;<keysym>V</keysym></keycombo> "
"इत्यनेन सह करोति ।"

#. Tag: guimenuitem
#: index.docbook:92
#, no-c-format
msgid "Tablet Mode"
msgstr ""

#. Tag: para
#: index.docbook:94
#, no-c-format
msgid "In Tablet Mode, the virtual keyboard will appear when needed."
msgstr ""

#. Tag: menuchoice
#: index.docbook:99
#, fuzzy, no-c-format
#| msgid ""
#| "<guimenu>Touch Mode</guimenu><guimenuitem>Automatically enable as needed</"
#| "guimenuitem>"
msgid ""
"<guimenu>Tablet Mode</guimenu><guimenuitem>Automatically enable as needed</"
"guimenuitem>"
msgstr ""
"<guimenu>स्पर्शविधिः</guimenu><guimenuitem>आवश्यकतानुसारं स्वयमेव सक्षमं कुर्वन्तु</"
"guimenuitem>"

#. Tag: para
#: index.docbook:101
#, fuzzy, no-c-format
#| msgid ""
#| "If this option is selected, Touch Mode will be automatically activated "
#| "whenever the system detects a touchscreen but no mouse or touchpad. For "
#| "example: when a transformable laptop's keyboard is flipped around or "
#| "detached."
msgid ""
"If this option is selected, Tablet Mode will be automatically activated "
"whenever the system detects a touchscreen but no mouse or touchpad. For "
"example: when a transformable laptop's keyboard is flipped around or "
"detached."
msgstr ""
"यदि एषः विकल्पः चयनितः अस्ति तर्हि यदा कदापि प्रणाली स्पर्शपट्टिकां पश्यति परन्तु मूषकं "
"स्पर्शपटलं वा न पश्यति तदा स्पर्शविधिः स्वयमेव सक्रियः भविष्यति । यथा : यदा "
"परिवर्तनीयस्य लैपटॉपस्य कीबोर्डः परितः प्लवते अथवा विरक्तः भवति।"

#. Tag: menuchoice
#: index.docbook:108
#, fuzzy, no-c-format
#| msgid ""
#| "<guimenu>Touch Mode</guimenu><guimenuitem>Always enabled</guimenuitem>"
msgid "<guimenu>Tablet Mode</guimenu><guimenuitem>Always enabled</guimenuitem>"
msgstr "<guimenu>स्पर्शविधिः</guimenu><guimenuitem>सदैव सक्षमः</guimenuitem>"

#. Tag: para
#: index.docbook:110
#, fuzzy, no-c-format
#| msgid ""
#| "If this option is selected, Touch Mode will always be enabled. Use this "
#| "option if you use &plasma; primarily with a touchscreen, or prefer larger "
#| "click targets for other reasons."
msgid ""
"If this option is selected, Tablet Mode will always be enabled. Use this "
"option if you use &plasma; primarily with a touchscreen."
msgstr ""
"यदि एषः विकल्पः चयनितः अस्ति तर्हि Touch Mode सर्वदा सक्षमः भविष्यति । यदि भवान् "
"&plasma; मुख्यतया स्पर्शपटलेन सह, अथवा अन्यकारणात् बृहत्तरं क्लिक् लक्ष्यं प्राधान्यं ददति ।"

#. Tag: menuchoice
#: index.docbook:115
#, fuzzy, no-c-format
#| msgid ""
#| "<guimenu>Touch Mode</guimenu><guimenuitem>Never enabled</guimenuitem>"
msgid "<guimenu>Tablet Mode</guimenu><guimenuitem>Never enabled</guimenuitem>"
msgstr "<guimenu>स्पर्शविधिः</guimenu><guimenuitem>कदापि सक्षमः न</guimenuitem>"

#. Tag: para
#: index.docbook:117
#, fuzzy, no-c-format
#| msgid ""
#| "If this option is selected, Touch Mode will always be disabled. Use this "
#| "option if you don't need Touch Mode on your device."
msgid ""
"If this option is selected, Tablet Mode will always be disabled. Use this "
"option if you don't need Tablet Mode on your device."
msgstr ""
"यदि एषः विकल्पः चयनितः अस्ति तर्हि Touch Mode सर्वदा निष्क्रियः भविष्यति । यदि भवतः "
"उपकरणे Touch Mode इत्यस्य आवश्यकता नास्ति तर्हि एतस्य विकल्पस्य उपयोगं कुर्वन्तु ।"

