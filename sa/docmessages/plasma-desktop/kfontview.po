#, no-c-format
msgid "Plasma 5.12"
msgstr "प्लाज्मा ५.१२"

#. Tag: keyword
#: index.docbook:22
#, no-c-format
msgid "<keyword>KDE</keyword>"
msgstr "<keyword>WHERE</keyword> इति"

