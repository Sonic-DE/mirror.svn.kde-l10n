#. Tag: para
#: index.docbook:41
#, no-c-format
msgid ""
"&knetattach; is a wizard which makes it easier to integrate your network "
"resources with your &kde; Desktop."
msgstr ""
"&knetattach; एकः विजार्डः अस्ति यः भवतः जालसंसाधनानाम् एकीकरणं भवतः &kde; डेस्कटॉप।"

#. Tag: keyword
#: index.docbook:52
#, no-c-format
msgid "<keyword>KDE</keyword>"
msgstr "<keyword>WHERE</keyword> इति"

#. Tag: keyword
