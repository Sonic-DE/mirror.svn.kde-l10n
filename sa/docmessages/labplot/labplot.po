#: index.docbook:1875
#, no-c-format
msgid ""
"fifth-order Debye function D<subscript>5</subscript>(x) = (5/"
"x<superscript>5</superscript>) &int;<subscript>0</subscript><superscript>x</"
"superscript> (t<superscript>5</superscript>/(e<superscript>t</superscript> - "
"1)) dt"
msgstr ""
"पञ्चम-क्रमस्य Debye फंक्शन D<subscript>5</subscript>(x) = (5/x<superscript>5</"
"superscript>) &int;<subscript>0</subscript><superscript>x</superscript> "
"( त<superscript>5</superscript>/(ई<superscript>t</superscript> - 1)) dt"

#. Tag: entry
#: index.docbook:1876
#, no-c-format
msgid "D6(x)"
msgstr "D6(x)"

#. Tag: action
#: index.docbook:1876
#, no-c-format
msgid ""
"sixth-order Debye function D<subscript>6</subscript>(x) = (6/"
"x<superscript>6</superscript>) &int;<subscript>0</subscript><superscript>x</"
"superscript> (t<superscript>6</superscript>/(e<superscript>t</superscript> - "
"1)) dt"
msgstr ""
"षष्ठी-क्रमस्य Debye फंक्शन D<subscript>6</subscript>(x) = (6/x<superscript>6</"
"superscript>) &int;<subscript>0</subscript><superscript>x</superscript> "
"( त<superscript>6</superscript>/(इ<superscript>t</superscript> - 1)) dt"

