#, no-c-format
msgid "RC(x,y)"
msgstr "आर सी(x,y)"

#. Tag: action
#: index.docbook:1884
#, no-c-format
msgid "incomplete elliptic integral RC(x,y)"
msgstr "अपूर्ण अण्डाकार अभिन्न RC(x,y) 1 ."

#. Tag: entry
#: index.docbook:1885
#, no-c-format
msgid "RD(x,y,z)"
msgstr "आर डी(x,y,z)"

#. Tag: action
#: index.docbook:1885
#, no-c-format
msgid "incomplete elliptic integral RD(x,y,z)"
msgstr "अपूर्ण अण्डाकार अभिन्न RD(x,y,z)"

#. Tag: entry
#: index.docbook:1886
#, no-c-format
