msgstr "अपूर्ण अण्डाकार अभिन्न RJ(x,y,z,p)"

#. Tag: entry
#: index.docbook:1888
#, no-c-format
msgid "erf(x)"
msgstr "यार्ड(x)"

#. Tag: action
#: index.docbook:1888
#, no-c-format
msgid ""
"error function erf(x) = 2/&radic;&pi; &int;<subscript>0</"
"subscript><superscript>x</superscript> exp(-t<superscript>2</superscript>) dt"
msgstr ""
"त्रुटि फ़ंक्शन erf(x) = 2/&radic;&pi; &int;<उपस्क्रिप्ट>0</subscript><superscript>x</"
"superscript> exp(-t<superscript>2</superscript>) dt"

#. Tag: entry
#: index.docbook:1889
#, no-c-format
msgid "erfc(x)"
msgstr "erfc(x)"

#. Tag: action
#: index.docbook:1889
#, no-c-format
msgid ""
"complementary error function erfc(x) = 1 - erf(x) = 2/&radic;&pi; &int;"
"<subscript>x</subscript><superscript>&infin;</superscript> exp(-"
"t<superscript>2</superscript>) dt"
msgstr ""
"पूरक त्रुटि फ़ंक्शन erfc(x) = 1 - erf(x) = 2/&radic;&pi; &int;<उपस्क्रिप्ट्>x</"
"subscript><superscript>&infin;</superscript> exp(-t<superscript>2</"
"superscript>) dt"

#. Tag: entry
#: index.docbook:1890
#, no-c-format
msgid "log_erfc(x)"
msgstr "log_erfc (x) 1.1."

#. Tag: action
#: index.docbook:1890
#, no-c-format
msgid "logarithm of the complementary error function log(erfc(x))"
msgstr "पूरक त्रुटि फ़ंक्शन log(erfc(x)) का लघुगणक"

#. Tag: entry
#: index.docbook:1891
#, no-c-format
msgid "erf_Z(x)"
msgstr "यार्ड_Z(x)"

#. Tag: action
#: index.docbook:1891
#, no-c-format
msgid ""
"Gaussian probability function Z(x) = (1/(2&pi;)) exp(-x<superscript>2</"
"superscript>/2)"
msgstr ""
"गाउसीय संभाव्यता फलन Z (x) = (1/(2&pi;)) exp(-x<superscript>2</superscript>/2)"

#. Tag: entry
#: index.docbook:1892
#, no-c-format
msgid "erf_Q(x)"
msgstr "hof_Q(x) 1.1."

#. Tag: action
#: index.docbook:1892
#, no-c-format
msgid ""
"upper tail of the Gaussian probability function Q(x) = (1/(2&pi;)) &int;"
"<subscript>x</subscript><superscript>&infin;</superscript> exp(-"
"t<superscript>2</superscript>/2) dt"
msgstr ""
"गाउसी संभाव्यता फलन के ऊपरी पूंछ Q(x) = (1/(2&pi;)) &int;<subscript>x</"
"subscript><superscript>&infin;</superscript> exp(-t<superscript>2</"
"superscript >/2) dt"

#. Tag: entry
#: index.docbook:1893
#, no-c-format
msgid "hazard(x)"
msgstr "खतरा(x)"

#. Tag: action
#: index.docbook:1893
#, no-c-format
msgid "hazard function for the normal distribution"
msgstr "सामान्यवितरणस्य कृते खतराकार्यम्"

#. Tag: entry
#: index.docbook:1894
#, no-c-format
msgid "exp(x)"
msgstr "exp(x)"

#. Tag: action
#: index.docbook:1894
#, no-c-format
msgid "Exponential, base e"
msgstr "घातीय, आधार ङ"

#. Tag: entry
#: index.docbook:1895
#, no-c-format
msgid "expm1(x)"
msgstr "expm1(x)"

#. Tag: action
#: index.docbook:1895
#, no-c-format
msgid "exp(x)-1"
msgstr "exp(x)-1"

#. Tag: entry
#: index.docbook:1896
#, no-c-format
msgid "exp_mult(x,y)"
msgstr "exp_mult (x, y) 1.1."

#. Tag: action
#: index.docbook:1896
#, no-c-format
msgid ""
"exponentiate x and multiply by the factor y to return the product y exp(x)"
msgstr "x घातीयं कृत्वा y गुणनखण्डेन गुणयित्वा y exp(x) उत्पादं प्रत्यागच्छतु ।"

#. Tag: entry
#: index.docbook:1897
#, no-c-format
msgid "exprel(x)"
msgstr "exprel(x)"

#. Tag: action
#: index.docbook:1897
#, no-c-format
msgid "(exp(x)-1)/x using an algorithm that is accurate for small x"
msgstr "(exp(x)-1)/x एकं एल्गोरिदम् उपयुज्य यत् लघु x कृते सटीकं भवति"

#. Tag: entry
#: index.docbook:1898
#, no-c-format
msgid "exprel2(x)"
msgstr "exprel2(x)"

#. Tag: action
#: index.docbook:1898
#, no-c-format
msgid ""
"2(exp(x)-1-x)/x<superscript>2</superscript> using an algorithm that is "
"accurate for small x"
msgstr ""
"2(exp(x)-1-x)/x<superscript>2</superscript> एकं अल्गोरिदम् उपयुज्य यत् लघु x कृते "
"सटीकं भवति"

#. Tag: entry
#: index.docbook:1899
#, no-c-format
msgid "expreln(n,x)"
msgstr "expreln(n,x)"

#. Tag: action
#: index.docbook:1899
#, no-c-format
msgid ""
"n-relative exponential, which is the n-th generalization of the functions "
"`exprel'"
msgstr "न-सापेक्ष-घटकं, यत् `exprel' इति कार्याणां न-तमं सामान्यीकरणं भवति ।"

#. Tag: entry
#: index.docbook:1900
#, no-c-format
msgid "E1(x)"
msgstr "ई१(x)"

#. Tag: action
#: index.docbook:1900
#, no-c-format
msgid ""
"exponential integral E<subscript>1</subscript>(x), E<subscript>1</"
"subscript>(x) := Re &int;<subscript>1</subscript><superscript>&infin;</"
"superscript> exp(-xt)/t dt"
msgstr ""
"घातीय अभिन्न E<subscript>1</subscript>(x), E<subscript>1</subscript>(x) := Re "
"&int;<subscript>1</subscript><superscript>&infin;</superscript> exp (-xt)/t "
"dt"

#. Tag: entry
#: index.docbook:1901
#, no-c-format
msgid "E2(x)"
msgstr "ई२(x)"

#. Tag: action
#: index.docbook:1901
#, no-c-format
msgid ""
"second-order exponential integral E<subscript>2</subscript>(x), "
"E<subscript>2</subscript>(x) := Re &int;<subscript>1</"
"subscript><superscript>&infin;</superscript> exp(-xt)/t<superscript>2</"
"superscript> dt"
msgstr ""
"द्वितीयक्रम घातीय अभिन्न E<subscript>2</subscript>(x), E<subscript>2</"
"subscript>(x) := Re &int;<subscript>1</subscript><superscript>&infin;</ "
"सुपरस्क्रिप्ट्> exp(-xt)/त<सुपरस्क्रिप्ट्>2</superscript> dt"

#. Tag: entry
#: index.docbook:1902
#, no-c-format
msgid "En(x)"
msgstr "In(x)"

#. Tag: action
#: index.docbook:1902
#, no-c-format
msgid ""
"exponential integral E_n(x) of order n, E<subscript>n</subscript>(x) := Re "
"&int;<subscript>1</subscript><superscript>&infin;</superscript> exp(-xt)/"
"t<superscript>n</superscript> dt)"
msgstr ""
"घातीय अभिन्न E_n(x) क्रम n, E<subscript>n</subscript>(x) := Re &int;"
"<subscript>1</subscript><superscript>&infin;</superscript> exp(-xt)/ "
"त<superscript>n</superscript> dt)"

#. Tag: entry
#: index.docbook:1903
#, no-c-format
msgid "Ei(x)"
msgstr "न(x)"

#. Tag: action
#: index.docbook:1903
#, no-c-format
msgid ""
"exponential integral E_i(x), Ei(x) := PV(&int;<subscript>-x</"
"subscript><superscript>&infin;</superscript> exp(-t)/t dt)"
msgstr ""
"घातीय अभिन्न E_i(x), Ei(x) := PV(&int;<subscript>-x</"
"subscript><superscript>&infin;</superscript> exp(-t)/t dt)"

#. Tag: entry
#: index.docbook:1904
#, no-c-format
msgid "shi(x)"
msgstr "शि(x)"

#. Tag: action
#: index.docbook:1904
#, no-c-format
msgid ""
"Shi(x) = &int;<subscript>0</subscript><superscript>x</superscript> sinh(t)/t "
"dt"
msgstr ""
"शि(x) = &int;<subscript>0</subscript><superscript>x</superscript> सिन्ह(त)/त "
"द्त"

#. Tag: entry
#: index.docbook:1905
#, no-c-format
msgid "chi(x)"
msgstr "यः(x)"

#. Tag: action
#: index.docbook:1905
#, no-c-format
msgid ""
"integral Chi(x) := Re[ &gamma;<subscript>E</subscript> + log(x) + &int;"
"<subscript>0</subscript><superscript>x</superscript> (cosh[t]-1)/t dt ]"
msgstr ""
"अभिन्न Chi(x) := पुनः[ &gamma;<subscript>E</subscript> + log(x) + &int;"
"<subscript>0</subscript><superscript>x</superscript> (कोश[t]-1 )/त दत् ] ."

#. Tag: entry
#: index.docbook:1906
#, no-c-format
msgid "Ei3(x)"
msgstr "Ei3(x)"

#. Tag: action
#: index.docbook:1906
#, no-c-format
msgid ""
"exponential integral Ei<subscript>3</subscript>(x) = &int;<subscript>0</"
"subscript><superscript>x</superscript> exp(-t<superscript>3</superscript>) "
"dt for x &gt;= 0"
msgstr ""
"घातीय अभिन्न Ei<subscript>3</subscript>(x) = &int;<subscript>0</"
"subscript><superscript>x</superscript> exp(-t<superscript>3</superscript>) "
"dt for x &gt ;= 0"

#. Tag: entry
#: index.docbook:1907
#, no-c-format
msgid "si(x)"
msgstr "षष्टं)"

#. Tag: action
#: index.docbook:1907
#, no-c-format
msgid ""
"Sine integral Si(x) = &int;<subscript>0</subscript><superscript>x</"
"superscript> sin(t)/t dt"
msgstr ""
"साइन अभिन्न Si(x) = &int;<subscript>0</subscript><superscript>x</superscript> "
"sin(t)/t dt"

#. Tag: entry
#: index.docbook:1908
#, no-c-format
msgid "ci(x)"
msgstr "in(x)"

#. Tag: action
#: index.docbook:1908
#, no-c-format
msgid ""
"Cosine integral Ci(x) = -&int;<subscript>x</subscript><superscript>&infin;</"
"superscript> cos(t)/t dt for x &gt; 0"
msgstr ""
"कोसाइन अभिन्न Ci(x) = -&int;<subscript>x</subscript><superscript>&infin;</"
"superscript> cos(t)/t dt for x &gt; ०"

#. Tag: entry
#: index.docbook:1909
#, no-c-format
msgid "atanint(x)"
msgstr "अतनिन्त्(x)"

#. Tag: action
#: index.docbook:1909
#, no-c-format
msgid ""
"Arctangent integral AtanInt(x) = &int;<subscript>0</"
"subscript><superscript>x</superscript> arctan(t)/t dt"
msgstr ""
"आर्कटान्जेंट अभिन्न AtanInt(x) = &int;<subscript>0</subscript><superscript>x</"
"superscript> arctan(t)/t dt"

#. Tag: entry
#: index.docbook:1910
#, no-c-format
msgid "Fm1(x)"
msgstr "Fm1(x)"

#. Tag: action
#: index.docbook:1910
#, no-c-format
msgid ""
"complete Fermi-Dirac integral with an index of -1, F<subscript>-1</"
"subscript>(x) = e<superscript>x</superscript> / (1 + e<superscript>x</"
"superscript>)"
msgstr ""
"-1 इत्यस्य अनुक्रमणिकायुक्तं Fermi-Dirac अभिन्नं सम्पूर्णं, F<subscript>-1</subscript>(x) "
"= e<superscript>x</superscript> / (1 + e<superscript>x</superscript>)"

#. Tag: entry
#: index.docbook:1911
#, no-c-format
msgid "F0(x)"
msgstr "च०(x)"

#. Tag: action
#: index.docbook:1911
#, no-c-format
msgid ""
"complete Fermi-Dirac integral with an index of 0, F<subscript>0</"
"subscript>(x) = ln(1 + e<superscript>x</superscript>)"
msgstr ""
"0, F<subscript>0</subscript>(x) = ln(1 + e<superscript>x</superscript>) "
"इत्यनेन सह सम्पूर्णं Fermi-Dirac अभिन्नं ।"

#. Tag: entry
#: index.docbook:1912
#, no-c-format
msgid "F1(x)"
msgstr "F1(x)"

#. Tag: action
#: index.docbook:1912
#, no-c-format
msgid ""
"complete Fermi-Dirac integral with an index of 1, F<subscript>1</"
"subscript>(x) = &int;<subscript>0</subscript><superscript>&infin;</"
"superscript> (t /(exp(t-x)+1)) dt"
msgstr ""
"1 इत्यस्य अनुक्रमणिकायुक्तं Fermi-Dirac अभिन्नं सम्पूर्णं, F<subscript>1</subscript>(x) = "
"&int;<subscript>0</subscript><superscript>&infin;</superscript> (t /(exp(t-"
"x )+१)) दत्"

#. Tag: entry
#: index.docbook:1913
#, no-c-format
msgid "F2(x)"
msgstr "F2(x)"

#. Tag: action
#: index.docbook:1913
#, no-c-format
msgid ""
"complete Fermi-Dirac integral with an index of 2, F<subscript>2</"
"subscript>(x) = (1/2) &int;<subscript>0</subscript><superscript>&infin;</"
"superscript> (t<superscript>2</superscript> /(exp(t-x)+1)) dt"
msgstr ""
"२ अनुक्रमणिकायुक्तं फर्मी-डायराक अभिन्नं सम्पूर्णं, F<subscript>2</subscript>(x) = (१/२) "
"&int;<subscript>0</subscript><superscript>&infin;</superscript> (t "
"<superscript>2</superscript> /(exp(t-x)+1)) dt"

#. Tag: entry
#: index.docbook:1914
#, no-c-format
msgid "Fj(j,x)"
msgstr "Fj(ज,x)"

#. Tag: action
#: index.docbook:1914
#, no-c-format
msgid ""
"complete Fermi-Dirac integral with an index of j, F<subscript>j</"
"subscript>(x) = (1/&Gamma;(j+1)) &int;<subscript>0</"
"subscript><superscript>&infin;</superscript> (t<superscript>j</superscript> /"
"(exp(t-x)+1)) dt"
msgstr ""
"j, F<subscript>j</subscript>(x) = (1/&Gamma;(j+1)) &int;<subscript>0</"
"subscript><superscript>&infin; </superscript> (t<superscript>j</"
"superscript> /(exp(t-x)+1)) dt"

#. Tag: entry
#: index.docbook:1915
#, no-c-format
msgid "Fmhalf(x)"
msgstr "Fmhalf(x)"

#. Tag: action
#: index.docbook:1915
#, no-c-format
msgid "complete Fermi-Dirac integral F<subscript>-1/2</subscript>(x)"
msgstr "complete Fermi-Dirac अभिन्न F<subscript>-1/2</subscript>(x) 1.1."

#. Tag: entry
#: index.docbook:1916
#, no-c-format
msgid "Fhalf(x)"
msgstr "फल्फ(x)"

#. Tag: action
#: index.docbook:1916
#, no-c-format
msgid "complete Fermi-Dirac integral F<subscript>1/2</subscript>(x)"
msgstr "complete Fermi-Dirac अभिन्न F<subscript>1/2</subscript>(x) 1.1."

#. Tag: entry
#: index.docbook:1917
#, no-c-format
msgid "F3half(x)"
msgstr "F3अर्ध(x) 1.1."

#. Tag: action
#: index.docbook:1917
#, no-c-format
msgid "complete Fermi-Dirac integral F<subscript>3/2</subscript>(x)"
msgstr "complete Fermi-Dirac अभिन्न F<subscript>3/2</subscript>(x) 1.1."

#. Tag: entry
#: index.docbook:1918
#, no-c-format
msgid "Finc0(x,b)"
msgstr "Finc0(x,b)"

#. Tag: action
#: index.docbook:1918
#, no-c-format
msgid ""
"incomplete Fermi-Dirac integral with an index of zero, F<subscript>0</"
"subscript>(x,b) = ln(1 + e<superscript>b-x</superscript>) - (b-x)"
msgstr ""
"शून्यस्य अनुक्रमणिकायुक्तः अपूर्णः Fermi-Dirac अभिन्नः, F<subscript>0</subscript>(x,b) "
"= ln(1 + e<superscript>b-x</superscript>) - (b-x)"

#. Tag: entry
#: index.docbook:1919
#, no-c-format
msgid "lngamma(x)"
msgstr "लङ्गमम्(x)"

#. Tag: action
#: index.docbook:1919
#, no-c-format
msgid "logarithm of the Gamma function"
msgstr "गामा फलनस्य लघुगणकम्"

#. Tag: entry
#: index.docbook:1920
#, no-c-format
msgid "gammastar(x)"
msgstr "गामातार(x)"

#. Tag: action
#: index.docbook:1920
#, no-c-format
msgid ""
"regulated Gamma Function &Gamma;<superscript>*</superscript>(x) for x &gt; 0"
