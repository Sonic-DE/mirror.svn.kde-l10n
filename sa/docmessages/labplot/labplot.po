msgid "D(phi,k,n)"
msgstr "द(फी,क्,न)"

#. Tag: action
#: index.docbook:1883
#, no-c-format
msgid "incomplete elliptic integral D(phi,k,n)"
msgstr "अपूर्ण अण्डाकार अभिन्न D(phi,k,n)"

#. Tag: entry
