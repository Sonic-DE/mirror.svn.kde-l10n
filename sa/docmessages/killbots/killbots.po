msgstr "उपरि वामे च तिर्यक् गतिं सूचयति कर्सरः ।"

#. Tag: varname
#: index.docbook:385
#, no-c-format
msgid "cursor4"
msgstr "कर्सर4"

#. Tag: para
#: index.docbook:386
#, no-c-format
msgid "A cursor indicating movement to the left."
msgstr "वामभागे गतिं सूचयति कर्सरः ।"

#. Tag: varname
#: index.docbook:389
#, no-c-format
msgid "cursor5"
msgstr "कर्सर5"

#. Tag: para
#: index.docbook:390
#, no-c-format
msgid "A cursor indicating diagonal movement down and to the left."
msgstr "अधः वामभागे च तिर्यक् गतिं सूचयति कर्सरः ।"

#. Tag: varname
#: index.docbook:393
#, no-c-format
msgid "cursor6"
msgstr "कर्सर6"

#. Tag: para
#: index.docbook:394
#, no-c-format
msgid "A cursor indicating movement down."
msgstr "अधः गतिं सूचयति कर्सरः ।"

#. Tag: varname
#: index.docbook:397
#, no-c-format
msgid "cursor7"
msgstr "कर्सर7"

#. Tag: para
#: index.docbook:398
#, no-c-format
msgid "A cursor indicating movement down and to the right."
msgstr "अधः दक्षिणतः च गतिं सूचयति कर्सरः ।"

#. Tag: varname
#: index.docbook:401
#, no-c-format
msgid "cursor8"
msgstr "कर्सर८"

#. Tag: para
#: index.docbook:402
#, no-c-format
