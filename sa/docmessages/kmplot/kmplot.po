msgstr ""
"ID <parameter>id</parameter> इत्यनेन सह फंक्शन् इत्यस्य अभिन्नस्य रेखाविस्तारं "
"प्रत्यागच्छति । यदि फंक्शन् नास्ति तर्हि 0 प्रत्यागच्छति ।"

#. Tag: term
#: index.docbook:1695
#, no-c-format
msgid "/parser org.kde.kmplot.Parser.setFunctionFLineWidth id linewidth"
msgstr "/पार्सर org.kde.kmplot.Parser.setFunctionFLineWidth id रेखाचौड़ाई"

#. Tag: para
#: index.docbook:1699
#, no-c-format
msgid ""
"Sets the line width of the function with the ID <parameter>id</parameter> to "
"<parameter>linewidth</parameter>. True is returned if the function exists, "
"otherwise false."
msgstr ""
"ID <parameter>id</parameter> इत्यनेन सह फंक्शन् इत्यस्य रेखाविस्तारं "
"<parameter>linewidth</parameter> इति सेट् करोति । True प्रत्यागच्छति यदि फंक्शन् "
"अस्ति, अन्यथा false ।"

#. Tag: term
#: index.docbook:1703
#, no-c-format
msgid "/parser org.kde.kmplot.Parser.setFunctionF1LineWidth id linewidth"
msgstr "/पार्सर org.kde.kmplot.Parser.setFunctionF1LineWidth id रेखाचौड़ाई"

#. Tag: para
#: index.docbook:1707
#, no-c-format
msgid ""
"Sets the line width of the first derivative of the function with the ID "
"<parameter>id</parameter> to <parameter>linewidth</parameter>. True is "
