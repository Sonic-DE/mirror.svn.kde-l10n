msgstr "आर्कसिंह(x)"

#. Tag: term
#: index.docbook:773
#, no-c-format
msgid "cosech(x)"
msgstr "फसल(x)"

#. Tag: term
#: index.docbook:774
#, no-c-format
msgid "arccosech(x)"
msgstr "आर्कोसेक(x)"

#. Tag: para
#: index.docbook:775
#, no-c-format
msgid ""
"The hyperbolic sine, inverse sine, cosecant and inverse cosecant "
