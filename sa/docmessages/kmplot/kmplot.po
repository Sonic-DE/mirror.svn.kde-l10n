msgstr ""
"ID <parameter>id</parameter> इत्यनेन सह फंक्शन् इत्यस्य प्रथमस्य व्युत्पन्नस्य रेखाविस्तारं "
"प्रत्यागच्छति । यदि फंक्शन् नास्ति तर्हि 0 प्रत्यागच्छति ।"

#. Tag: term
#: index.docbook:1679
#, no-c-format
msgid "/parser org.kde.kmplot.Parser.functionF2LineWidth id"
msgstr "/पार्सर org.kde.kmplot.पार्सर.फंक्शनF2LineWidth id"

#. Tag: para
#: index.docbook:1683
#, no-c-format
msgid ""
"Returns the line width of the second derivative of the function with the ID "
