msgstr "अतिपरवलयिकसाइनः, विलोमसाइनः, सहसेकन्ट्, विलोमकोसेकन्ट् च क्रमशः ।"

#. Tag: term
#: index.docbook:779
#, no-c-format
msgid "cosh(x)"
msgstr "कोष(x)"

#. Tag: term
#: index.docbook:780
#, no-c-format
msgid "arccosh(x)"
msgstr "आर्क्कोश(x)"

#. Tag: term
#: index.docbook:781
#, no-c-format
msgid "sech(x)"
msgstr "स्वयं(x) ."

#. Tag: term
#: index.docbook:782
#, no-c-format
msgid "arcsech(x)"
msgstr "चापसेच(x)"

#. Tag: para
#: index.docbook:783
#, no-c-format
msgid ""
"The hyperbolic cosine, inverse cosine, secant and inverse secant "
