msgstr "अतिपरवलयिककोसाइनः, विलोमकोसाइनः, सेकन्टः, विलोमकोसाइनः च क्रमशः ।"

#. Tag: term
#: index.docbook:787
#, no-c-format
msgid "tanh(x)"
msgstr "मत्स्य(x)"

#. Tag: term
#: index.docbook:788
#, no-c-format
msgid "arctanh(x)"
msgstr "आर्कटनः(x)"

#. Tag: term
#: index.docbook:789
#, no-c-format
msgid "coth(x)"
msgstr "आकार(x)"

#. Tag: term
#: index.docbook:790
#, no-c-format
msgid "arccoth(x)"
msgstr "अर्ककोथ(x)"

#. Tag: para
#: index.docbook:791
#, no-c-format
msgid ""
"The hyperbolic tangent, inverse tangent, cotangent and inverse cotangent "
"respectively."
msgstr "अतिशयोक्ति स्पर्शरेखा, विलोम स्पर्शरेखा, सहस्पर्श तथा विलोम सहस्पर्श क्रमशः।"

#. Tag: title
#: index.docbook:798
#, no-c-format
msgid "Other Functions"
msgstr "अन्ये कार्यम्"

#. Tag: term
#: index.docbook:802
#, no-c-format
msgid "sqr(x)"
msgstr "sqr(x)"

#. Tag: para
#: index.docbook:803
#, no-c-format
msgid "The square x^2 of x."
msgstr "x इत्यस्य वर्गः x^2 ।"

#. Tag: term
#: index.docbook:807
#, no-c-format
msgid "sqrt(x)"
msgstr "sqrt(x)"

#. Tag: para
#: index.docbook:808
#, no-c-format
msgid "The square root of x."
msgstr "x इत्यस्य वर्गमूलम् ।"

#. Tag: term
#: index.docbook:812
#, no-c-format
msgid "sign(x)"
msgstr "चिह्न(x)"

#. Tag: para
#: index.docbook:813
#, no-c-format
msgid ""
"The sign of x. Returns 1 if x is positive, 0 if x is zero, or &minus;1 if x "
"is negative."
msgstr ""
"क्षस्य चिह्नम् । यदि x सकारात्मकः अस्ति तर्हि 1, यदि x शून्यः अस्ति तर्हि 0, अथवा x "
"ऋणात्मकः चेत् &minus;1 प्रेषयति ।"

#. Tag: term
#: index.docbook:817
#, no-c-format
msgid "H(x)"
msgstr "ह(x)"

#. Tag: para
#: index.docbook:818
#, no-c-format
msgid ""
"The Heaviside Step Function. Returns 1 if x is positive, 0.5 if x is zero, "
"or 0 if x is negative."
msgstr ""
"हेविसाइड स्टेप फंक्शन् इति । यदि x सकारात्मकः अस्ति तर्हि 1, यदि x शून्यः अस्ति तर्हि "
"0.5, अथवा x ऋणात्मकः चेत् 0 प्रेषयति ।"

#. Tag: term
#: index.docbook:822
#, no-c-format
msgid "exp(x)"
msgstr "exp(x)"

#. Tag: para
#: index.docbook:823
#, no-c-format
msgid "The exponent e^x of x."
msgstr "x इत्यस्य घातांक e^x ।"

#. Tag: term
#: index.docbook:827
#, no-c-format
msgid "ln(x)"
msgstr "ln(x)"

#. Tag: para
#: index.docbook:828
#, no-c-format
msgid "The natural logarithm (inverse exponent) of x."
msgstr "x का प्राकृतिक लघुगणक (विलोम घातांक)।"

#. Tag: term
#: index.docbook:832
#, no-c-format
msgid "log(x)"
msgstr "log(x)"

#. Tag: para
#: index.docbook:833
#, no-c-format
msgid "The logarithm of x to base 10."
msgstr "x तः आधार 10 पर्यन्तं लघुगणकम् ।"

#. Tag: term
#: index.docbook:837
#, no-c-format
msgid "abs(x)"
msgstr "अब्स्(x)"

#. Tag: para
#: index.docbook:838
#, no-c-format
msgid "The absolute value of x."
msgstr "x इत्यस्य निरपेक्षं मूल्यम् ।"

#. Tag: term
#: index.docbook:842
#, no-c-format
msgid "floor(x)"
msgstr "तल(x)"

#. Tag: para
#: index.docbook:843
#, no-c-format
msgid "Rounds x to closest integer less than or equal to x."
msgstr "x इत्यस्मात् x इत्यस्मात् न्यूनं वा समानं वा निकटतमं पूर्णाङ्कं यावत् गोलं करोति ।"

#. Tag: term
#: index.docbook:847
#, no-c-format
msgid "ceil(x)"
msgstr "ceil(x)"

#. Tag: para
#: index.docbook:848
#, no-c-format
msgid "Rounds x to the closest integer greater than or equal to x."
msgstr "x इत्यस्मात् अधिकं वा समं वा निकटतमं पूर्णाङ्कं प्रति x गोलं करोति ।"

#. Tag: term
#: index.docbook:852
#, no-c-format
msgid "round(x)"
msgstr "गोल(x)"

#. Tag: para
#: index.docbook:853
#, no-c-format
msgid "Rounds x to the closest integer."
msgstr "x इत्यस्य समीपस्थं पूर्णाङ्कं यावत् गोलं करोति ।"

#. Tag: term
#: index.docbook:857
#, no-c-format
msgid "gamma(x)"
msgstr "गामा(x)"

#. Tag: para
#: index.docbook:858
#, no-c-format
msgid "The gamma function."
msgstr "गामा कार्यम् ।"

#. Tag: term
#: index.docbook:862
#, no-c-format
msgid "factorial(x)"
msgstr "कारक(x)"

#. Tag: para
#: index.docbook:863
#, no-c-format
msgid "The factorial of x."
msgstr "x इत्यस्य गुणनखण्डः ।"

#. Tag: term
#: index.docbook:867
#, no-c-format
msgid ""
"min(x<subscript>1</subscript>,x<subscript>2</subscript>,...,x<subscript>n</"
"subscript>)"
msgstr ""
"min(x<subscript>1</subscript>,x<subscript>2</subscript>,...,x<subscript>n</"
"subscript>)"

#. Tag: para
#: index.docbook:868
#, no-c-format
msgid ""
"Returns the minimum of the set of numbers {x<subscript>1</subscript>,"
"x<subscript>2</subscript>,...,x<subscript>n</subscript>}."
msgstr ""
"{x<subscript>1</subscript>,x<subscript>2</subscript>,...,x<subscript>n</"
"subscript>} इति संख्यासमूहस्य न्यूनतमं प्रत्यागच्छति ।"

#. Tag: term
#: index.docbook:872
#, no-c-format
msgid ""
"max(x<subscript>1</subscript>,x<subscript>2</subscript>,...,x<subscript>n</"
"subscript>)"
msgstr ""
"max(x<subscript>1</subscript>,x<subscript>2</subscript>,...,x<subscript>n</"
"subscript>)"

#. Tag: para
#: index.docbook:873
#, no-c-format
msgid ""
"Returns the maximum of the set of numbers {x<subscript>1</subscript>,"
"x<subscript>2</subscript>,...,x<subscript>n</subscript>}."
msgstr ""
"{x<subscript>1</subscript>,x<subscript>2</subscript>,...,x<subscript>n</"
"subscript>} इति संख्यासमूहस्य अधिकतमं प्रत्यागच्छति ।"

#. Tag: term
#: index.docbook:877
#, no-c-format
msgid ""
"mod(x<subscript>1</subscript>,x<subscript>2</subscript>,...,x<subscript>n</"
"subscript>)"
msgstr ""
"mod(x<subscript>1</subscript>,x<subscript>2</subscript>,...,x<subscript>n</"
"subscript>)"

#. Tag: para
#: index.docbook:878
#, no-c-format
msgid ""
"Returns the modulus (Euclidean length) of the set of numbers {x<subscript>1</"
"subscript>,x<subscript>2</subscript>,...,x<subscript>n</subscript>}."
msgstr ""
"{x<subscript>1</subscript>,x<subscript>2</subscript>,...,x<subscript>n</"
"subscript>} इति संख्यासमूहस्य मापांकं (Euclidean length) प्रत्यागच्छति ।"

#. Tag: title
#: index.docbook:887
#, no-c-format
msgid "Predefined Constants"
msgstr "पूर्वनिर्धारित स्थिरांक"

#. Tag: term
#: index.docbook:891
#, no-c-format
msgid "<term>pi</term>"
msgstr "<पद>पि</term> इति"

#. Tag: term
#: index.docbook:892
#, no-c-format
msgid "&pgr;"
msgstr "&pgr;"

#. Tag: para
#: index.docbook:894
#, no-c-format
msgid "Constants representing &pgr; (3.14159...)."
msgstr "प्रतिनिधित्वं कुर्वन्तः नित्याः &pgr; (३.१४१५९...) इति ।"

#. Tag: term
#: index.docbook:899
#, no-c-format
msgid "<term>e</term>"
msgstr "<पद>इ</term> इति"

#. Tag: para
#: index.docbook:901
#, no-c-format
msgid "Constant representing Euler's Number e (2.71828...)."
msgstr "यूलरस्य संख्या e (2.71828...) इत्यस्य प्रतिनिधित्वं कुर्वन् नित्यः ।"

#. Tag: title
#: index.docbook:910
#, no-c-format
msgid "Extensions"
msgstr "विस्तारः"

#. Tag: para
#: index.docbook:911
#, no-c-format
msgid ""
"An extension for a function is specified by entering a semicolon, followed "
"by the extension, after the function definition. The extension can be "
"entered by using the &DBus; method <quote><methodname>parser addFunction</"
"methodname></quote>. None of the extensions are available for parametric "
"functions but N and D[a,b] work for polar functions too. For example: "
"<screen>\n"
"                        <userinput>\n"
"                                f(x)=x^2; A1\n"
"                        </userinput>\n"
"                </screen> will show the graph y=x<superscript>2</"
"superscript> with its first derivative. Supported extensions are described "
"below:"
msgstr ""
"फंक्शन् कृते विस्तारः फंक्शन् परिभाषायाः अनन्तरं अर्धविरामं प्रविष्ट्वा निर्दिष्टः भवति, "
"तदनन्तरं विस्तारः । विस्तारं &DBus; विधिः <quote><methodname>पार्सरः addFunction</"
"methodname></quote> इति । पैरामेट्रिकफलकानां कृते कोऽपि विस्तारः उपलब्धः नास्ति किन्तु "
"N तथा D[a,b] ध्रुवीयफलनानां कृते अपि कार्यं कुर्वन्ति । यथा - <screen>\n"
"                        <उपयोक्तृपुटम्>\n"
"                                च (x) = x ^ 2; अ१\n"
"                        </userinput> इति\n"
"                </screen> इत्यनेन y=x<superscript>2</superscript> इति आलेखं तस्य "
"प्रथमव्युत्पन्नेन सह दर्शयिष्यति । समर्थिताः विस्ताराः अधः वर्णिताः सन्ति ।"

#. Tag: term
#: index.docbook:919
#, no-c-format
msgid "<term>N</term>"
msgstr "<पद>न</term> इति"

#. Tag: para
#: index.docbook:921
#, no-c-format
msgid ""
"The function will be stored but not be drawn. It can be used like any other "
"user-defined or predefined function."
msgstr ""
"फंक्शन् संगृहीतं भविष्यति परन्तु न आकृष्टं भविष्यति। अन्येषां उपयोक्तृनिर्धारितस्य पूर्वनिर्धारितस्य "
"वा कार्यस्य इव अस्य उपयोगः कर्तुं शक्यते ।"

#. Tag: term
#: index.docbook:928
#, no-c-format
msgid "<term>A1</term>"
msgstr "<पद>क१</term> इति"

#. Tag: para
#: index.docbook:930
#, no-c-format
msgid ""
"The graph of the derivative of the function will be drawn additionally with "
"the same color but less line width."
msgstr ""
"फंक्शन् इत्यस्य व्युत्पन्नस्य आलेखः अतिरिक्तरूपेण समानवर्णेन परन्तु रेखाविस्तारेण न्यूनेन आकृष्टः "
"भविष्यति ।"

#. Tag: term
#: index.docbook:937
#, no-c-format
msgid "<term>A2</term>"
msgstr "<पद>अ२</term> इति"

#. Tag: para
#: index.docbook:939
#, no-c-format
msgid ""
"The graph of the second derivative of the function will be drawn "
"additionally with the same color but less line width."
msgstr ""
"फंक्शन् इत्यस्य द्वितीयव्युत्पन्नस्य आलेखः अतिरिक्तरूपेण समानवर्णेन परन्तु रेखाविस्तारेण न्यूनेन "
"आकृष्टः भविष्यति ।"

#. Tag: term
#: index.docbook:946
#, no-c-format
msgid "D[a,b]"
msgstr "द[क,ख]"

#. Tag: para
#: index.docbook:948
#, no-c-format
msgid "Sets the domain for which the function will be displayed."
msgstr "यस्य डोमेनस्य कृते कार्यं प्रदर्शितं भविष्यति तत् डोमेन् सेट् करोति ।"

#. Tag: term
#: index.docbook:954
#, no-c-format
msgid "P[a{,b...}]"
msgstr "प[ा{,ब...}] ।"

#. Tag: para
#: index.docbook:956
#, no-c-format
msgid ""
"Give a set of values of a group parameter for which the function should be "
"displayed. For example: <userinput>f(x,k)=k*x;P[1,2,3]</userinput> will plot "
"the functions f(x)=x, f(x)=2*x and f(x)=3*x. You can also use functions as "
"the arguments to the P option."
msgstr ""
"यस्य समूहस्य पैरामीटर् इत्यस्य मूल्यानां समुच्चयं ददातु यस्य कृते फंक्शन् प्रदर्शितव्यम् । यथा : "
"<userinput>f(x,k)=k*x;P[1,2,3]</userinput> इत्यनेन f(x)=x, f(x)=2*x तथा f "
"इत्येतयोः फंक्शन् प्लॉट् भविष्यति (x)=3*x. P विकल्पस्य आर्गुमेण्ट् रूपेण फंक्शन्स् अपि उपयोक्तुं "
"शक्नुवन्ति ।"

#. Tag: para
#: index.docbook:966
#, no-c-format
msgid ""
"Please note that you can do all of these operations by editing the items in "
"the <guilabel>Derivatives</guilabel> tab, the <guilabel>Custom plot range</"
"guilabel> section and the <guilabel>Parameters</guilabel> section in the "
"<guilabel>Functions</guilabel> sidebar too."
msgstr ""
"कृपया ज्ञातव्यं यत् भवान् एतानि सर्वाणि कार्याणि <guilabel>व्युत्पन्न</guilabel> ट्याब्, "
"<guilabel>Custom plot range</guilabel> विभागे तथा च <guilabel>Parameters</"
"guilabel> विभागे in <guilabel>कार्य</guilabel> पार्श्वपट्टिका अपि ।"

#. Tag: title
#: index.docbook:972
#, no-c-format
msgid "Mathematical Syntax"
msgstr "गणितीय वाक्य रचना"

#. Tag: para
#: index.docbook:973
#, no-c-format
msgid ""
"&kmplot; uses a common way of expressing mathematical functions, so you "
"should have no trouble working it out. The operators &kmplot; understands "
"are, in order of decreasing precedence:"
msgstr ""
"&kmplot; गणितीयकार्यं व्यञ्जयितुं सामान्यमार्गं प्रयुङ्क्ते, अतः भवद्भिः तस्य कार्यं कर्तुं कोऽपि "
"कष्टः न भवितुमर्हति । संचालकाः &kmplot; अवगच्छति भवन्ति, प्राधान्यस्य न्यूनीकरणक्रमेण-"

#. Tag: term
#: index.docbook:979
#, no-c-format
msgid "<term>^</term>"
msgstr "<पद>^</term> इति"

#. Tag: para
#: index.docbook:980
#, no-c-format
msgid ""
"The caret symbol performs exponentiation. &eg;, <userinput>2^4</userinput> "
"returns 16."
msgstr ""
"कैरेट् चिह्नं घातीकरणं करोति । &eg;, <userinput>2^4</userinput> इत्यनेन 16 "
"प्रत्यागच्छति ।"

#. Tag: term
#: index.docbook:986
#, no-c-format
msgid "<term>*</term>"
msgstr "<पद>*</term> इति"

#. Tag: term
#: index.docbook:987
#, no-c-format
msgid "<term>/</term>"
msgstr "<पद>/</term> इति"

#. Tag: para
#: index.docbook:989
#, no-c-format
msgid ""
"The asterisk and slash symbols perform multiplication and division . &eg;, "
"<userinput>3*4/2</userinput> returns 6."
msgstr ""
"ताराचिह्नं स्लैश च चिह्नं गुणनं विभागं च कुर्वन्ति | &eg;, <userinput>3*4/2</userinput> "
"इत्यनेन 6 प्रत्यागच्छति ।"

#. Tag: term
#: index.docbook:996
#, no-c-format
msgid "<term>+</term>"
msgstr "<पद>+</term> इति"

#. Tag: term
#: index.docbook:997
#, no-c-format
msgid "&minus;"
msgstr "&माइनस;"

#. Tag: para
#: index.docbook:998
#, no-c-format
msgid ""
"The plus and minus symbols perform addition and subtraction. &eg;, "
"<userinput>1+3&minus;2</userinput> returns 2."
msgstr ""
"प्लस्, माइनस् च चिह्नौ योगहरणं च कुर्वन्ति । &eg;, <userinput>1+3&minus;2</"
"userinput> इत्यनेन 2 प्रत्यागच्छति ।"

#. Tag: term
#: index.docbook:1004
#, no-c-format
msgid "&lt;"
msgstr "&lt;"

#. Tag: term
#: index.docbook:1005
#, no-c-format
msgid "&gt;"
msgstr "&gt;"

#. Tag: term
#: index.docbook:1006
#, no-c-format
msgid "&le;"
msgstr "& the;"

#. Tag: term
#: index.docbook:1007
#, no-c-format
msgid "&ge;"
msgstr "&ge;"

#. Tag: para
#: index.docbook:1008
#, no-c-format
msgid ""
"Comparison operators. They return 1 if the expression is true, otherwise "
"they return 0. &eg;, <userinput>1 &le; 2</userinput> returns 1."
msgstr ""
"तुलना संचालकाः। ते 1 प्रत्यागच्छन्ति यदि व्यञ्जनं सत्यं भवति, अन्यथा ते 0 प्रत्यागच्छन्ति "
"&eg;, <userinput>1 &le; २</userinput> इत्यनेन १ प्रत्यागच्छति ।"

#. Tag: term
#: index.docbook:1014
#, no-c-format
msgid "&radic;"
msgstr "&radic;"

#. Tag: para
#: index.docbook:1015
#, no-c-format
msgid ""
"The square root of a number. &eg;, <userinput>&radic;4</userinput> returns 2."
msgstr ""
"सङ्ख्यायाः वर्गमूलम् । &eg;, <userinput>&radic;4</userinput> इत्यनेन २ प्रत्यागच्छति ।"

#. Tag: term
#: index.docbook:1021
#, no-c-format
msgid "<term>|x|</term>"
msgstr "<पद>|x|</term>"

#. Tag: para
#: index.docbook:1022
#, no-c-format
msgid ""
"The absolute value of x. &eg;, <userinput>|&minus;4|</userinput> returns 4."
msgstr ""
"x इत्यस्य निरपेक्षं मूल्यम् । &eg;, <userinput>|&minus;4|</userinput> इत्यनेन ४ "
"प्रत्यागच्छति ।"

#. Tag: term
#: index.docbook:1028
#, no-c-format
msgid "&plusmn;"
msgstr "&plusmn;"

#. Tag: para
#: index.docbook:1030
#, no-c-format
msgid ""
"Each plus-minus sign gives two sets of plots: one in which the plus is "
"taken, and one in which the minus is taken.&eg;. <userinput>y = &plusmn;"
"sqrt(1&minus;x^2)</userinput> will draw a circle. These, therefore, cannot "
"be used in constants."
msgstr ""
"प्रत्येकं प्लस्-माइनस् चिह्नं द्वौ प्लस् समुच्चयौ ददाति : एकः यस्मिन् प्लस् गृह्यते, एकः च यस्मिन् "
"माइनस् गृह्यते।&eg;. <userinput>y = &plusmn;sqrt(1&minus;x^2)</userinput> एकं वृत्तं "
"आकर्षयिष्यति। एतानि अतः नित्येषु प्रयोक्तुं न शक्यन्ते ।"

#. Tag: para
#: index.docbook:1040
#, no-c-format
msgid ""
"Note the precedence, which means that if parentheses are not used, "
"exponentiation is performed before multiplication/division, which is "
"performed before addition/subtraction. So <userinput>1+2*4^2</userinput> "
"returns 33, and not, say 144. To override this, use parentheses. To use the "
"above example, <userinput>((1+2)*4)^2</userinput> <emphasis>will</emphasis> "
"return 144."
msgstr ""
"प्राधान्यं लक्ष्यताम्, यस्य अर्थः अस्ति यत् यदि कोष्ठकानां प्रयोगः न भवति तर्हि गुणन/"
"विभाजनात् पूर्वं घातांकनं भवति, यत् योग/हरणात् पूर्वं क्रियते । अतः <userinput>1+2*4^2</"
"userinput> 33 प्रेषयति, न तु, कथयन्तु 144. एतत् अधिलिखितुं कोष्ठकस्य उपयोगं कुर्वन्तु । "
"उपर्युक्तं उदाहरणं उपयोक्तुं <userinput>((1+2)*4)^2</userinput> <emphasis></"
"emphasis> 144 प्रत्यागमिष्यति ।"

#. Tag: title
#: index.docbook:1049
#, no-c-format
msgid "Plotting Area"
msgstr "प्लॉटिंग एरिया"

#. Tag: para
#: index.docbook:1050
#, no-c-format
msgid ""
"By default, explicitly given functions are plotted for the whole of the "
"visible part of the horizontal axis. You can specify an other range in the "
"edit-dialog for the function. If the plotting area contains the resulting "
"point it is connected to the last drawn point by a line."
msgstr ""
"पूर्वनिर्धारितरूपेण, स्पष्टतया दत्तानि कार्याणि क्षैतिज-अक्षस्य दृश्यभागस्य समग्रस्य कृते प्लॉट् "
"भवन्ति । फंक्शन् कृते edit-dialog मध्ये अन्यं श्रेणीं निर्दिष्टुं शक्नुवन्ति । यदि प्लॉटिङ्ग् क्षेत्रे "
"परिणामबिन्दुः भवति तर्हि अन्तिमेन आकृष्टबिन्दुना सह रेखाद्वारा सम्बद्धः भवति ।"

#. Tag: para
#: index.docbook:1056
#, no-c-format
msgid ""
"Parametric and polar functions have a default plotting range of 0 to 2&pgr;. "
"This plotting range can also be changed in the <guilabel>Functions</"
"guilabel> sidebar."
msgstr ""
"पैरामेट्रिक तथा ध्रुवीयफलनानां पूर्वनिर्धारितं प्लॉटिंग् परिधिः 0 तः 2&pgr;पर्यन्तं भवति । "
"इदं प्लॉटिंग्-परिधिं <guilabel>Functions</guilabel> पार्श्वपट्टिकायां अपि परिवर्तयितुं "
"शक्यते ।"

#. Tag: title
#: index.docbook:1063
#, no-c-format
msgid "Crosshair Cursor"
msgstr "क्रॉसशेयर कर्सर"

#. Tag: para
#: index.docbook:1064
#, no-c-format
msgid ""
"While the mouse cursor is over the plotting area the cursor changes to a "
"crosshair. The current coordinates can be seen at the intersections with the "
"coordinate axes and also in the status bar at the bottom of the main window."
msgstr ""
"यदा मूषकस्य कर्सरः प्लॉटिंग् क्षेत्रस्य उपरि भवति तदा कर्सरः क्रॉस्हेर् इति परिवर्तते । "
"वर्तमान निर्देशांकाः निर्देशांक-अक्षैः सह खण्डेषु अपि च मुख्य-विण्डो-अधः स्थिते स्थिति-"
"पट्टिकायां द्रष्टुं शक्यन्ते ।"

#. Tag: para
#: index.docbook:1067
#, no-c-format
msgid ""
"You can trace a function's values more precisely by clicking onto or next to "
"a graph. The selected function is shown in the status bar in the right "
"column. The crosshair then will be caught and be colored in the same color "
"as the graph. If the graph has the same color as the background color, the "
"crosshair will have the inverted color of the background. When moving the "
"mouse or pressing the keys &Left; or &Right; the crosshair will follow the "
"function and you see the current horizontal and vertical value. If the "
"crosshair is close to vertical axis, the root-value is shown in the "
"statusbar. You can switch function with the &Up; and &Down; keys. A second "
"click anywhere in the window or pressing any non-navigating key will leave "
"this trace mode."
msgstr ""
"भवन्तः ग्राफ् इत्यस्य उपरि वा पार्श्वे वा क्लिक् कृत्वा फंक्शन् इत्यस्य मूल्यानि अधिकतया "
"अनुसन्धानं कर्तुं शक्नुवन्ति । चयनितं कार्यं दक्षिणस्तम्भे स्थितिपट्टिकायां दर्शितं भवति । ततः "
"क्रॉसहेयरः गृहीतः भविष्यति, आलेखस्य समानवर्णे च वर्णितः भविष्यति । यदि आलेखस्य "
"पृष्ठभूमिवर्णस्य समानः वर्णः अस्ति तर्हि क्रॉसहेयरस्य पृष्ठभूमिस्य विपर्यस्तवर्णः भविष्यति । "
"मूषकं चालयन् अथवा कीलानि नुदन् &Left; अथवा &Right; crosshair function इत्यस्य अनुसरणं "
"करिष्यति तथा च भवन्तः वर्तमानं क्षैतिजं ऊर्ध्वाधरं च मूल्यं पश्यन्ति । यदि क्रॉसहेयरः ऊर्ध्वाधर-"
"अक्षस्य समीपे अस्ति तर्हि मूल-मूल्यं स्थितिपट्टिकायां दर्शितं भवति । भवान् &Up; तथा &Down; "
"कीलानि । विण्डो मध्ये कुत्रापि द्वितीयं क्लिक् कृत्वा अथवा कस्यापि अ-नेविगेटिंग् कीलस्य नुदने "
"एतत् ट्रेस मोड् त्यक्ष्यति ।"

#. Tag: para
#: index.docbook:1070
#, no-c-format
msgid ""
"For more advanced tracing, open up the configuration dialog, and select "
"<guilabel>Draw tangent and normal when tracing</guilabel> from the "
"<guilabel>General Settings</guilabel> page. This option will draw the "
"tangent, normal and oscillating circle of the plot currently being traced."
msgstr ""
"अधिक उन्नत-अनुसन्धानार्थं, विन्यास-संवादं उद्घाटयन्तु, <guilabel>सामान्य-सेटिंग्स्</"
"guilabel> पृष्ठात् <guilabel>अनुसन्धानं कुर्वन् स्पर्शरेखां सामान्यं च आकर्षयन्तु</guilabel> "
"इति चिनोतु । एषः विकल्पः वर्तमानकाले अनुसन्धानं क्रियमाणस्य प्लॉट् इत्यस्य स्पर्शरेखा, "
"सामान्यं, दोलनशीलं च वृत्तं आकर्षयिष्यति ।"

#. Tag: title
#: index.docbook:1077
#, no-c-format
msgid "Coordinate System Configuration"
msgstr "समन्वय प्रणाली विन्यास"

#. Tag: para
#: index.docbook:1078
#, no-c-format
msgid ""
"To open this dialog select <menuchoice><guimenu>View</"
"guimenu><guimenuitem>Coordinate System...</guimenuitem></menuchoice> from "
"the menubar."
msgstr ""
"एतत् संवादं उद्घाटयितुं मेनूपट्टिकातः <menuchoice><guimenu>दृश्य</"
"guimenu><guimenuitem>समन्वयप्रणाली...</guimenuitem></menuchoice> इति चिनोतु ।"

#. Tag: screeninfo
#: index.docbook:1080
#, no-c-format
msgid "<screeninfo>Screenshot of the Coordinate System dialog</screeninfo>"
msgstr "<screeninfo>समन्वयप्रणालीसंवादस्य स्क्रीनशॉट्</screeninfo>"

#. Tag: phrase
#: index.docbook:1086
#, no-c-format
msgid "<phrase>Screenshot of the Coordinate System dialog</phrase>"
msgstr "<phrase>Coordinate System संवादस्य स्क्रीनशॉट्</phrase>"

#. Tag: title
#: index.docbook:1092
#, no-c-format
msgid "Axes Configuration"
msgstr "अक्ष विन्यास"

#. Tag: guilabel
#: index.docbook:1097
#, no-c-format
msgid "Horizontal axis Range"
msgstr "क्षैतिज अक्ष श्रेणी"

#. Tag: para
#: index.docbook:1099
#, no-c-format
msgid ""
"Sets the range for the horizontal axis scale. Note that you can use the "
"predefined functions and constants (see <xref linkend=\"func-predefined\"/>) "
"as the extremes of the range (&eg;, set <guilabel>Min:</guilabel> to "
"<userinput>2*pi</userinput>). You can even use functions you have defined to "
"set the extremes of the axis range. For example, if you have defined a "
"function <userinput>f(x) = x^2</userinput>, you could set <guilabel>Min:</"
"guilabel> to <userinput>f(3)</userinput>, which would make the lower end of "
"the range equal to 9."
msgstr ""
"क्षैतिज-अक्ष-मापदण्डस्य कृते परिधिं सेट् करोति । ध्यानं कुर्वन्तु यत् भवान् पूर्वनिर्धारितकार्यं "
"नित्यं च (द्रष्टव्यम् <xref linkend=\"func-predefined\"/>) परिधिस्य चरमरूपेण उपयोक्तुं "
"शक्नोति (&eg;, <guilabel>Min:</guilabel> इत्येतत् <userinput>2* इति सेट् कुर्वन्तु । "
"पि</userinput>) इति । अक्षपरिधिस्य अत्यन्तं सेट् कर्तुं भवता परिभाषितानि कार्याणि अपि "
"उपयोक्तुं शक्नुवन्ति । यथा, यदि भवान् <userinput>f(x) = x^2</userinput> इति फंक्शन् "
"परिभाषितवान् तर्हि <guilabel>Min:</guilabel> इति <userinput>f(3)</userinput> "
"इति सेट् कर्तुं शक्नोति, यत् श्रेणीयाः अधोभागं ९ इत्यस्य समं करिष्यति स्म ।"

#. Tag: guilabel
#: index.docbook:1112
#, no-c-format
msgid "Vertical axis Range"
msgstr "ऊर्ध्वाधर अक्ष श्रेणी"

#. Tag: para
#: index.docbook:1114
#, no-c-format
msgid ""
"Sets the range for the vertical axis. See <quote>Horizontal axis Range</"
"quote> above."
msgstr ""
"ऊर्ध्वाधर-अक्षस्य कृते परिधिं सेट् करोति । उपरि <quote>क्षैतिजः अक्षः श्रेणी</quote> इति "
"पश्यन्तु ।"

#. Tag: guilabel
#: index.docbook:1119
#, no-c-format
msgid "Horizontal axis Grid Spacing"
msgstr "क्षैतिज अक्ष जाल अन्तराल"

#. Tag: para
#: index.docbook:1121
#, no-c-format
msgid ""
"This controls the spacing between grid lines in the horizontal direction. If "
"<guilabel>Automatic</guilabel> is selected, then &kmplot; will try to find a "
"grid line spacing of about two centimeters that is also numerically nice. If "
"<guilabel>Custom:</guilabel> is selected, then you can enter the horizontal "
"grid spacing. This value will be used regardless of the zoom. For example, "
"if a value of 0.5 is entered, and the x range is 0 to 8, then 16 grid lines "
"will be shown."
msgstr ""
"एतेन क्षैतिजदिशि जालरेखायोः मध्ये अन्तरं नियन्त्र्यते । यदि <guilabel>स्वचालित</guilabel> "
"चयनितं तर्हि &kmplot; प्रायः द्वौ सेन्टिमीटर् यावत् जालरेखाअन्तरं अन्वेष्टुं प्रयतते यत् "
"संख्यात्मकरूपेण अपि सुन्दरम् अस्ति । यदि <guilabel>Custom:</guilabel> चयनितम् अस्ति, "
"तर्हि भवन्तः क्षैतिजजालान्तरं प्रविष्टुं शक्नुवन्ति । जूम इत्यस्य अपेक्षां विना एतत् मूल्यं उपयुज्यते "
"। यथा, यदि 0.5 इत्यस्य मूल्यं प्रविष्टं भवति, तथा च x परिधिः 0 तः 8 पर्यन्तं भवति, तर्हि "
"16 जालरेखाः दर्शिताः भविष्यन्ति ।"

#. Tag: guilabel
#: index.docbook:1129
#, no-c-format
msgid "Vertical axis Grid Spacing"
msgstr "ऊर्ध्वाधर अक्ष जाल अन्तराल"

#. Tag: para
#: index.docbook:1131
#, no-c-format
msgid ""
"This controls the spacing between grid lines in the vertical direction. See "
"<quote>Horizontal axis Grid Spacing</quote> above."
msgstr ""
"एतेन लम्बदिशि जालरेखानां मध्ये अन्तरं नियन्त्र्यते । उपरि <quote>क्षैतिज-अक्षः जाल-अन्तरालः</"
"quote> इति पश्यन्तु ।"

#. Tag: title
#: index.docbook:1144
#, no-c-format
msgid "Constants Configuration"
msgstr "स्थिरताः विन्यासः"

#. Tag: para
#: index.docbook:1145
#, no-c-format
msgid ""
"To open this dialog select <menuchoice><guimenu>Edit</"
"guimenu><guimenuitem>Constants...</guimenuitem></menuchoice> from the "
"menubar."
msgstr ""
"एतत् संवादं उद्घाटयितुं मेनूपट्टिकातः <menuchoice><guimenu>Edit</"
"guimenu><guimenuitem>Constants...</guimenuitem></menuchoice> इति चिनोतु ।"

#. Tag: screeninfo
#: index.docbook:1148
#, no-c-format
msgid "<screeninfo>Screenshot of the Constants dialog</screeninfo>"
msgstr "<screeninfo>नित्यसंवादस्य स्क्रीनशॉट्</screeninfo>"

#. Tag: phrase
#: index.docbook:1154
#, no-c-format
msgid "<phrase>Screenshot of the Constants dialog</phrase>"
msgstr "<phrase>Constants संवादस्य स्क्रीनशॉट्</phrase>"

#. Tag: para
#: index.docbook:1159
#, no-c-format
msgid ""
"Constants can be used as part of an expression anywhere inside of &kmplot;. "
"Each constant must have a name and a value. Some names are invalid, however, "
"such as existing function names or existing constants."
msgstr ""
"&kmplot; इत्यस्य अन्तः कुत्रापि व्यञ्जनस्य भागरूपेण नित्यं उपयोक्तुं शक्यते । प्रत्येकं नित्यं नाम "
"मूल्यं च भवितुमर्हति । केचन नामानि तु असिद्धानि सन्ति यथा विद्यमानकार्यनामानि "
"विद्यमाननित्यानि वा ।"

#. Tag: para
#: index.docbook:1163
#, no-c-format
msgid "There are two options that control the scope of a constant:"
msgstr "नित्यस्य व्याप्तिम् नियन्त्रयन्ति द्वौ विकल्पौ स्तः ।"

#. Tag: guilabel
#: index.docbook:1169
#, no-c-format
msgid "Document"
msgstr "प्रलेख"

#. Tag: para
#: index.docbook:1171
#, no-c-format
msgid ""
"If you select the <guilabel>Document</guilabel> checkbox, then the Constant "
"will be saved along with the current diagram when you save it to file. "
"However, unless you have also selected the <guilabel>Global</guilabel> "
"option, the constant will not be available between instances of &kmplot;."
msgstr ""
"यदि भवान् <guilabel>Document</guilabel> इति चेकबॉक्सं चिनोति तर्हि Constant इत्येतत् "
"वर्तमानचित्रेण सह रक्षितं भविष्यति यदा भवान् तत् सञ्चिकायां रक्षति । परन्तु यावत् भवता "
"<guilabel>Global</guilabel> विकल्पः अपि न चिनोति तावत् &kmplot; इत्यस्य "
"उदाहरणानां मध्ये नित्यं उपलब्धं न भविष्यति ।"

#. Tag: guilabel
#: index.docbook:1176
#, no-c-format
msgid "Global"
msgstr "वैश्विक"

#. Tag: para
#: index.docbook:1178
#, no-c-format
msgid ""
"If you select the <guilabel>Global</guilabel> checkbox, then the Constant's "
"name and value will be written to &kde; settings (where it can also be used "
"by &kcalc;). The constant will not be lost when &kmplot; is closed, and will "
"be available again for use when &kmplot; is started again."
msgstr ""
"यदि भवान् <guilabel>Global</guilabel> चेकबॉक्सं चिनोति तर्हि Constant इत्यस्य नाम "
"मूल्यं च &kde; सेटिंग्स् (यत्र &kcalc; इत्यनेन अपि उपयोक्तुं शक्यते) । नित्यं न नष्टं भविष्यति "
"यदा &kmplot; पिहितः अस्ति, पुनः उपयोगाय उपलभ्यते यदा &kmplot; पुनः आरभ्यते।"

#. Tag: title
#: index.docbook:1190
#, no-c-format
msgid "Command Reference"
msgstr "आदेश सन्दर्भ"

#. Tag: title
#: index.docbook:1193
#, no-c-format
msgid "Menu Items"
msgstr "मेनू आइटम"

#. Tag: para
#: index.docbook:1195
#, no-c-format
msgid ""
"Apart from the common &kde; menus described in the <ulink url=\"help:/"
"fundamentals/menus.html\">Menu</ulink> chapter of the &kde; Fundamentals "
"documentation &kmplot; has these application specific menu entries:"
msgstr ""
"सामान्यं विहाय &kde; &kde; मौलिकता दस्तावेजीकरण &kmplot; एतानि अनुप्रयोगविशिष्टानि "
"मेनूप्रविष्टयः सन्ति:"

#. Tag: title
#: index.docbook:1200
#, no-c-format
msgid "The File Menu"
msgstr "सञ्चिकामेनू इति"

#. Tag: menuchoice
#: index.docbook:1205
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Export...</guimenuitem>"
msgstr "<guimenu>सञ्चिका</guimenu> <guimenuitem>निर्यात...</guimenuitem>"

#. Tag: para
#: index.docbook:1208
#, no-c-format
msgid ""
"<action>Exports</action> the plotted graphs to an image file in all formats "
"supported by &kde;."
msgstr ""
"<action>निष्कासयति</action> प्लॉट् कृतानि आलेखानि &kde;द्वारा समर्थितसर्वस्वरूपेषु "
"चित्रसञ्चिकायां ।"

#. Tag: menuchoice
#: index.docbook:1212
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Print...</guimenuitem>"
msgstr "<guimenu>सञ्चिका</guimenu> <guimenuitem>मुद्रणं...</guimenuitem>"

#. Tag: para
#: index.docbook:1218
#, no-c-format
msgid ""
"<action>Opens</action> print configuration window. Press the "
"<guibutton>Options >></guibutton> button then choose the <guilabel>KmPlot "
"Options</guilabel> tab to configure options that are specific for &kmplot;."
msgstr ""
"<action>मुद्रणविन्यासविण्डो उद्घाटयति</action> । <guibutton>विकल्पाः >></"
"guibutton> बटनं नुदन्तु ततः &kmplot;-कृते विशिष्टान् विकल्पान् विन्यस्तुं <guilabel>KmPlot "
"विकल्पाः</guilabel> ट्याब् चिनोतु ।"

#. Tag: menuchoice
#: index.docbook:1223
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Print Preview</guimenuitem>"
msgstr "<guimenu>सञ्चिका</guimenu> <guimenuitem>मुद्रणपूर्वावलोकनम्</guimenuitem>"

#. Tag: para
#: index.docbook:1229
#, no-c-format
msgid ""
"<action>Shows</action> the preliminary image of the current plot as printed "
"on the current default printer. Press the rightmost button on the toolbar of "
"the print preview window to configure options that are specific for &kmplot;."
msgstr ""
"<action>वर्तमानस्य पूर्वनिर्धारितमुद्रके मुद्रितरूपेण वर्तमानस्य प्लॉटस्य प्रारम्भिकं चित्रं "
"दर्शयति</action> । &kmplot; कृते विशिष्टानि विकल्पानि विन्यस्तुं मुद्रणपूर्वावलोकनविण्डो "
"इत्यस्य साधनपट्टिकायां दक्षिणतमं बटनं नुदन्तु ।"

#. Tag: title
#: index.docbook:1236
#, no-c-format
msgid "The Edit Menu"
msgstr "सम्पादन मेनू इति"

#. Tag: menuchoice
#: index.docbook:1239
#, no-c-format
msgid "<guimenu>Edit</guimenu><guimenuitem>Constants...</guimenuitem>"
msgstr "<guimenu>सम्पादन</guimenu><guimenuitem>नित्यं...</guimenuitem>"

#. Tag: para
#: index.docbook:1241
#, no-c-format
msgid ""
"Displays the <guilabel>Constants Editor</guilabel> dialog box. See <xref "
"linkend=\"constants-config\"/>."
msgstr ""
"<guilabel>नित्यसम्पादक</guilabel> संवादपेटिकां प्रदर्शयति । <xref linkend=\"नित्य-"
"विन्यासः\"/> पश्यन्तु ।"

#. Tag: title
#: index.docbook:1249
#, no-c-format
msgid "The View Menu"
msgstr "दृश्य मेनू इति"

#. Tag: para
#: index.docbook:1250
#, no-c-format
msgid "The first three items in the menu are related to zooming."
msgstr "मेनूमध्ये प्रथमत्रयवस्तूनि जूमिंग् इत्यनेन सह सम्बद्धानि सन्ति ।"

#. Tag: para
#: index.docbook:1252
#, no-c-format
msgid ""
"The mouse wheel can also be used as a zoom control. To zoom in or out using "
"the mouse, hold down the &Ctrl; key while you turn the mouse wheel. Each "
"tick increases or decreases the zoom factor by the value defined in the "
"<link linkend=\"general-config\">&kmplot; General settings</link>."
msgstr ""
"मूषकचक्रस्य उपयोगः जूम नियन्त्रणरूपेण अपि कर्तुं शक्यते । मूषकस्य उपयोगेन जूम इन अथवा आउट् कर्तुं "
"&amp;Ctrl; कीलं यदा भवन्तः मूषकचक्रं परिवर्तयन्ति। प्रत्येकं टिकं जूम् कारकं वर्धयति "
"न्यूनीकरोति वा मूल्येन परिभाषितेन मूल्येन<link linkend=\"general-config\"> &amp;"
"kmplot; सामान्य सेटिंग्स्</link> ."

#. Tag: menuchoice
#: index.docbook:1260
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>1</keycap></keycombo> </"
"shortcut> <guimenu>View</guimenu> <guimenuitem>Zoom In</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>1</keycap></keycombo> </"
"shortcut> <guimenu>दृश्य</guimenu> <guimenuitem>जूम इन</guimenuitem>"

#. Tag: para
#: index.docbook:1269
#, no-c-format
msgid ""
"This tool can be operator in two different manners. To zoom in on a point on "
"the graph, click on it. To zoom in on a specific section of the graph, hold "
"and drag the mouse to form a rectangle, which will be the new axes ranges "
"when the mouse button is released."
msgstr ""
"एतत् साधनं द्वयोः भिन्नयोः प्रकारयोः संचालकः भवितुम् अर्हति । आलेखे कस्यापि बिन्दुस्य जूम-इन् "
"कर्तुं तस्मिन् क्लिक् कुर्वन्तु । आलेखस्य विशिष्टखण्डे जूम-इन् कर्तुं मूषकं धारयित्वा कर्षयित्वा आयतं "
"निर्मायताम्, यत् मूषकस्य बटनस्य मुक्तौ नूतनानि अक्षपरिधिः भविष्यन्ति"

#. Tag: menuchoice
#: index.docbook:1275
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>2</keycap></keycombo> </"
"shortcut> <guimenu>View</guimenu> <guimenuitem>Zoom Out</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>2</keycap></keycombo> </"
"shortcut> <guimenu>दृश्य</guimenu> <guimenuitem>जूम आउट</guimenuitem>"

#. Tag: para
#: index.docbook:1284
#, no-c-format
msgid ""
"The tool can also be used in two different manners. To zoom out and center "
"on a point, click on that point. To fit the existing view into a rectangle, "
"hold and drag the mouse to form that rectangle."
msgstr ""
"साधनस्य उपयोगः द्वयोः भिन्नयोः प्रकारयोः अपि कर्तुं शक्यते । कस्यचित् बिन्दुस्य जूम् आउट् "
"कृत्वा केन्द्रं कर्तुं तस्मिन् बिन्दौ क्लिक् कुर्वन्तु । विद्यमानं दृश्यं आयतरूपेण स्थापयितुं, तत् आयतं "
"निर्मातुं मूषकं धारयित्वा कर्षयन्तु ।"

#. Tag: menuchoice
#: index.docbook:1289
#, no-c-format
msgid ""
"<guimenu>View</guimenu> <guimenuitem>Fit Widget to Trigonometric Functions</"
"guimenuitem>"
msgstr ""
"<guimenu>दृश्य</guimenu> <guimenuitem>त्रिकोणमितीयकार्यं प्रति विजेट् फिट्</"
"guimenuitem>"

#. Tag: para
#: index.docbook:1294
#, no-c-format
msgid ""
"The scale will be adapted to trigonometric functions. This works both for "
"radians and degrees."
msgstr ""
"स्केलः त्रिकोणमितीयकार्यस्य अनुकूलः भविष्यति । एतत् रेडियन् तथा डिग्री इत्येतयोः कृते कार्यं "
"करोति ।"

#. Tag: menuchoice
#: index.docbook:1298
#, no-c-format
msgid "<guimenu>View</guimenu><guimenuitem>Reset View</guimenuitem>"
msgstr "<guimenu>दृश्य</guimenu><guimenuitem>दृश्यं पुनः सेट् कुर्वन्तु</guimenuitem>"

#. Tag: para
#: index.docbook:1300
#, no-c-format
msgid "Resets the view."
msgstr "दृश्यं पुनः सेट् करोति ।"

#. Tag: menuchoice
#: index.docbook:1306
#, no-c-format
msgid "<guimenu>View</guimenu><guimenuitem>Coordinate System...</guimenuitem>"
msgstr "<guimenu>दृश्य</guimenu><guimenuitem>समन्वयप्रणाली...</guimenuitem>"

#. Tag: para
#: index.docbook:1308
#, no-c-format
msgid ""
"Displays the <guilabel>Coordinate System</guilabel> dialog box. See <xref "
"linkend=\"coords-config\"/>."
msgstr ""
"<guilabel>Coordinate System</guilabel> इति संवादपेटिकां प्रदर्शयति । <xref "
"linkend=\"coords-config\"/> पश्यन्तु ।"

#. Tag: menuchoice
#: index.docbook:1314
#, no-c-format
msgid "<guimenu>View</guimenu> <guimenuitem>Show Sliders</guimenuitem>"
msgstr "<guimenu>दृश्य</guimenu> <guimenuitem>स्लाइडरं दर्शयतु</guimenuitem>"

#. Tag: para
#: index.docbook:1318
#, no-c-format
msgid ""
"<action>Toggles</action> the visibility of the slider dialog. In the dialog "
"move a slider to change the parameter of the function plot connected to it."
msgstr ""
"<action>स्लाइडरसंवादस्य दृश्यतां टोग्ल्</action> करोति । संवादे तया सह सम्बद्धस्य फंक्शन् "
"प्लॉट् इत्यस्य पैरामीटर् परिवर्तयितुं स्लाइडरं चालयन्तु ।"

#. Tag: para
#: index.docbook:1320
#, no-c-format
msgid ""
"Enable this on the Function tab and select one of the sliders to change the "
"parameter value dynamically. The values vary from 0 (left) to 10 (right) by "
"default, but can be changed in the slider dialog."
msgstr ""
"Function ट्याब् मध्ये एतत् सक्षमं कुर्वन्तु तथा च पैरामीटर् मूल्यं गतिशीलरूपेण परिवर्तयितुं "
"स्लाइडर् मध्ये एकं चिनोतु । मूल्यानि पूर्वनिर्धारितरूपेण 0 (वाम) तः 10 (दक्षिणे) पर्यन्तं "
"भिद्यन्ते, परन्तु स्लाइडर् संवादे परिवर्तयितुं शक्यन्ते ।"

#. Tag: para
#: index.docbook:1321
#, no-c-format
msgid ""
"For a small tutorial see <ulink url=\"https://userbase.kde.org/Special:"
"MyLanguage/KmPlot/Using_Sliders\">Using Sliders</ulink>."
msgstr ""
"लघुपाठ्यक्रमाय <ulink url=\"https://userbase.kde.org/Special:MyLanguage/KmPlot/"
"Using_Sliders\">स्लाइडर्-उपयोगः</ulink> इति पश्यन्तु ।"

#. Tag: title
#: index.docbook:1331
#, no-c-format
msgid "The Tools Menu"
msgstr "Tools Menu इति"

#. Tag: para
#: index.docbook:1333
#, no-c-format
msgid "This menu contains some tools for the functions that can be useful:"
msgstr "अस्मिन् मेन्यू मध्ये कार्याणां कृते केचन साधनानि सन्ति ये उपयोगिनो भवितुम् अर्हन्ति:"

#. Tag: menuchoice
#: index.docbook:1338
#, no-c-format
msgid "<guimenu>Tools</guimenu> <guimenuitem>Calculator</guimenuitem>"
msgstr "<guimenu>उपकरणं</guimenu> <guimenuitem>गणक</guimenuitem>"

#. Tag: menuchoice
#: index.docbook:1347
#, no-c-format
msgid "<guimenu>Tools</guimenu> <guimenuitem>Plot Area...</guimenuitem>"
msgstr "<guimenu>उपकरणं</guimenu> <guimenuitem>प्लॉटक्षेत्रं...</guimenuitem>"

#. Tag: para
#: index.docbook:1351
#, no-c-format
msgid ""
"Select a graph and the values of the horizontal axis in the new dialog that "
"appears. Calculates the integral and draws the area between the graph and "
"the horizontal axis in the range of the selected values in the color of the "
"graph."
msgstr ""
"यत् नूतनं संवादं दृश्यते तस्मिन् एकं आलेखं तथा क्षैतिज-अक्षस्य मूल्यानि चिनोतु । अभिन्नस्य गणनां "
"करोति तथा च आलेखस्य वर्णेन चयनितमूल्यानां परिधिमध्ये आलेखस्य क्षैतिज-अक्षस्य च मध्ये क्षेत्रं "
"आकर्षयति ।"

#. Tag: menuchoice
#: index.docbook:1358
#, no-c-format
msgid "<guimenu>Tools</guimenu> <guimenuitem>Find Minimum...</guimenuitem>"
msgstr "<guimenu>उपकरणं</guimenu> <guimenuitem>न्यूनतमं अन्वेष्टुम्...</guimenuitem>"

#. Tag: para
#: index.docbook:1362
#, no-c-format
msgid "Find the minimum value of the graph in a specified range."
msgstr "निर्दिष्टे परिधिमध्ये आलेखस्य न्यूनतमं मूल्यं ज्ञातव्यम् ।"

#. Tag: menuchoice
#: index.docbook:1367
#, no-c-format
msgid "<guimenu>Tools</guimenu> <guimenuitem>Find Maximum...</guimenuitem>"
msgstr "<guimenu>उपकरणं</guimenu> <guimenuitem>अधिकतमं अन्वेष्टुम्...</guimenuitem>"

#. Tag: para
#: index.docbook:1371
#, no-c-format
msgid "Find the maximum value of the graph in a specified range."
msgstr "निर्दिष्टे परिधिमध्ये आलेखस्य अधिकतमं मूल्यं ज्ञातव्यम् ।"

#. Tag: title
#: index.docbook:1379
#, no-c-format
msgid "The Help Menu"
msgstr "सहायता मेनू"

#. Tag: para
#: index.docbook:1381
#, no-c-format
msgid ""
"&kmplot; has a standard &kde; <guimenu>Help</guimenu> with one addition:"
msgstr ""
"&kmplot; एकः मानकः अस्ति &kde; <guimenu>सहायतां</guimenu> एकेन परिवर्तनेन सह:"

#. Tag: menuchoice
#: index.docbook:1385
#, no-c-format
msgid ""
"<guimenu>Help</guimenu> <guimenuitem>Predefined Math Functions...</"
"guimenuitem>"
msgstr ""
"<guimenu>सहायता</guimenu> <guimenuitem>पूर्वनिर्धारितगणितकार्यं...</guimenuitem>"

#. Tag: para
#: index.docbook:1389
#, no-c-format
msgid ""
"Opens this handbook with a list of the predefined function names and "
"constants that &kmplot; knows."
msgstr ""
"पूर्वनिर्धारितफंक्शननामानां नित्यानां च सूचीं कृत्वा एतत् हस्तपुस्तिका उद्घाटयति यत् &kmplot; "
"जानाति।"

#. Tag: title
#: index.docbook:1401
#, no-c-format
msgid "Scripting &kmplot;"
msgstr "स्क्रिप्टिंग् &kmplot;"

#. Tag: para
#: index.docbook:1402
#, no-c-format
msgid ""
"You can write scripts for &kmplot; using &DBus;. For example, if you want to "
"define a new function <userinput>f(x)=2sin x+3cos x</userinput>, set its "
"line width to 20 and then draw it, you type in a console:"
msgstr ""
"भवन्तः &kmplot; &DBus; इत्यस्य उपयोगेन। यथा, यदि भवान् नूतनं फंक्शन् "
"<userinput>f(x)=2sin x+3cos x</userinput> परिभाषितुं इच्छति, तस्य रेखाविस्तारं 20 "
"इति सेट् कृत्वा ततः तत् आकर्षयितुम् इच्छति तर्हि भवान् कन्सोल् टङ्कयति:"

#. Tag: para
#: index.docbook:1404
#, no-c-format
msgid ""
"<command>qdbus org.kde.kmplot-PID /parser org.kde.kmplot.Parser.addFunction "
"\"f(x)=2sin x+3cos x\" \"\"</command> As a result, the new function's id "
"number will be returned, or -1 if the function could not be defined."
msgstr ""
"<command>qdbus org.kde.kmplot-PID /parser org.kde.kmplot.Parser.addFunction "
"\"f(x)=2sin x+3cos x\" \"\"</command> फलतः, नूतनकार्यस्य id सङ्ख्या भविष्यति "
"प्रत्यागन्तुं भवति, अथवा -1 यदि कार्यं परिभाषितुं न शक्यते स्म ।"

#. Tag: para
#: index.docbook:1406
#, no-c-format
msgid ""
"<command>qdbus org.kde.kmplot-PID /parser org.kde.kmplot.Parser."
"setFunctionFLineWidth ID 20</command> This command sets the function with "
"the id number ID the line width to 20."
msgstr ""
"<command>qdbus org.kde.kmplot-PID /parser org.kde.kmplot.Parser."
"setFunctionFLineWidth ID 20</command> एषः आदेशः id सङ्ख्या ID इत्यनेन सह कार्यं "
"रेखाविस्तारं 20 इति सेट् करोति ।"

#. Tag: para
#: index.docbook:1408
#, no-c-format
msgid ""
"<command>qdbus org.kde.kmplot-PID /view org.kde.kmplot.View.drawPlot</"
"command> This command repaints the window so that the function get visible."
msgstr ""
"<command>qdbus org.kde.kmplot-PID /view org.kde.kmplot.View.drawPlot</"
"command> एषः आदेशः विण्डो पुनः रङ्गयति यथा फंक्शन् दृश्यमानं भवति ।"

#. Tag: para
#: index.docbook:1410
#, no-c-format
msgid "A list of the available functions:"
msgstr "उपलब्धकार्यस्य सूची :"

#. Tag: term
#: index.docbook:1414
#, no-c-format
msgid "/kmplot org.kde.kmplot.KmPlot.fileOpen url"
msgstr "/kmplot org.kde.kmplot.KmPlot.fileUrl खोलें"

#. Tag: para
#: index.docbook:1418
#, no-c-format
msgid "Load the file <parameter>url</parameter>."
msgstr "<parameter>url</parameter> इति सञ्चिकां लोड् कुर्वन्तु ।"

#. Tag: term
#: index.docbook:1422
#, no-c-format
msgid "/maindlg org.kde.kmplot.MainDlg.isModified"
msgstr "/maindlg org.kde.kmplot.MainDlg.isModified"

#. Tag: para
#: index.docbook:1426
#, no-c-format
msgid "Returns true if any changes are done."
msgstr "यदि किमपि परिवर्तनं कृतम् अस्ति तर्हि सत्यं प्रत्यागच्छति ।"

#. Tag: term
#: index.docbook:1430
#, no-c-format
msgid "/maindlg org.kde.kmplot.MainDlg.checkModified"
msgstr "/maindlg org.kde.kmplot.MainDlg.checkसंशोधित"

#. Tag: para
#: index.docbook:1434
#, no-c-format
msgid ""
"If there are any unsaved changes, a dialog appears to save, discard or "
"cancel the plots."
msgstr ""
"यदि किमपि अरक्षितं परिवर्तनं भवति तर्हि प्लॉट् रक्षितुं, परित्यक्तुं वा रद्दं कर्तुं वा संवादः "
"दृश्यते ।"

#. Tag: term
#: index.docbook:1438
#, no-c-format
msgid "/maindlg org.kde.kmplot.MainDlg.editAxes"
msgstr "/ maindlg org.kde.kmplot.MainDlg.editAxes"

#. Tag: para
#: index.docbook:1442
#, no-c-format
msgid "Opens the coordinate system edit dialog."
msgstr "समन्वयप्रणालीसम्पादनसंवादं उद्घाटयति ।"

#. Tag: term
#: index.docbook:1446
#, no-c-format
msgid "/maindlg org.kde.kmplot.MainDlg.toggleShowSlider"
msgstr "/maindlg org.kde.kmplot.MainDlg.toggleShowSlider"

#. Tag: para
#: index.docbook:1450
#, no-c-format
msgid "Shows/hides parameter slider window."
msgstr "पैरामीटर् स्लाइडर विण्डो दर्शयति/गोपयति ।"

#. Tag: term
#: index.docbook:1454
#, no-c-format
msgid "/maindlg org.kde.kmplot.MainDlg.slotSave"
msgstr "/maindlg org.kde.kmplot.MainDlg.slotSave"

#. Tag: para
#: index.docbook:1458
#, no-c-format
msgid "Saves the functions (opens the save dialog if it is a new file)."
msgstr "कार्याणि रक्षति (यदि नूतनसञ्चिका अस्ति तर्हि save संवादं उद्घाटयति) ।"

#. Tag: term
#: index.docbook:1462
#, no-c-format
msgid "/maindlg org.kde.kmplot.MainDlg.slotSaveas"
msgstr "/maindlg org.kde.kmplot.MainDlg.slotSaveas"

#. Tag: para
#: index.docbook:1466
#, no-c-format
msgid ""
"The same as choosing the <menuchoice><guimenu>File</"
"guimenu><guimenuitem>Save As...</guimenuitem></menuchoice> in the menu."
msgstr ""
"मेन्यू मध्ये <menuchoice><guimenu>File</guimenu><guimenuitem>Save As...</"
"guimenuitem></menuchoice> इति चयनं यथा ।"

#. Tag: term
#: index.docbook:1470
#, no-c-format
msgid "/maindlg org.kde.kmplot.MainDlg.slotPrint"
msgstr "/maindlg org.kde.kmplot.MainDlg.slotPrint"

#. Tag: para
#: index.docbook:1474
#, no-c-format
msgid "Opens the print dialog."
msgstr "मुद्रणसंवादं उद्घाटयति ।"

#. Tag: term
#: index.docbook:1478
#, no-c-format
msgid "/maindlg org.kde.kmplot.MainDlg.slotResetView"
msgstr "/ maindlg org.kde.kmplot.MainDlg.slotResetView"

#. Tag: para
#: index.docbook:1482
#, no-c-format
msgid ""
"The same as choosing <menuchoice><guimenu>View</guimenu><guimenuitem>Reset "
"View</guimenuitem></menuchoice> in the menu."
msgstr ""
"मेनूमध्ये <menuchoice><guimenu>दृश्य</guimenu><guimenuitem>दृश्यं पुनः सेट् कुर्वन्तु</"
"guimenuitem></menuchoice> इति चयनं यथा ।"

#. Tag: term
#: index.docbook:1486
#, no-c-format
msgid "/maindlg org.kde.kmplot.MainDlg.slotExport"
msgstr "/maindlg org.kde.kmplot.MainDlg.slotनिर्यात"

#. Tag: para
#: index.docbook:1490
#, no-c-format
msgid "Opens the export dialog."
msgstr "निर्यातसंवादं उद्घाटयति ।"

#. Tag: term
#: index.docbook:1494
#, no-c-format
msgid "/maindlg org.kde.kmplot.MainDlg.slotSettings"
msgstr "/maindlg org.kde.kmplot.MainDlg.slotसेटिंग्स"

#. Tag: para
#: index.docbook:1498
#, no-c-format
msgid "Opens the settings dialog."
msgstr "सेटिंग्स् संवादं उद्घाटयति ।"

#. Tag: term
#: index.docbook:1502
#, no-c-format
msgid "/maindlg org.kde.kmplot.MainDlg.slotNames"
msgstr "/ maindlg org.kde.kmplot.MainDlg.slotNames"

#. Tag: para
#: index.docbook:1506
#, no-c-format
msgid "Shows the predefined math functions in the handbook."
msgstr "हस्तपुस्तिकायां पूर्वनिर्धारितगणितकार्यं दर्शयति ।"

#. Tag: term
#: index.docbook:1510
#, no-c-format
msgid "/maindlg org.kde.kmplot.MainDlg.findMinimumValue"
msgstr "/maindlg org.kde.kmplot.MainDlg.findन्यूनतममूल्यं"

#. Tag: para
#: index.docbook:1514
#, no-c-format
msgid ""
"The same as choosing <menuchoice><guimenu>Tools</"
"guimenu><guimenuitem>Minimum Value...</guimenuitem></menuchoice> in the menu."
msgstr ""
"मेनूमध्ये <menuchoice><guimenu>उपकरण</guimenu><guimenuitem>न्यूनतममूल्यं...</"
"guimenuitem></menuchoice> इति चयनं यथा ।"

#. Tag: term
#: index.docbook:1518
#, no-c-format
msgid "/maindlg org.kde.kmplot.MainDlg.findMaximumValue"
msgstr "/maindlg org.kde.kmplot.MainDlg.findMaximumValue"

#. Tag: para
#: index.docbook:1522
#, no-c-format
msgid ""
"The same as choosing <menuchoice><guimenu>Tools</"
"guimenu><guimenuitem>Maximum Value...</guimenuitem></menuchoice> in the menu."
msgstr ""
"मेनूमध्ये <menuchoice><guimenu>उपकरण</guimenu><guimenuitem>अधिकतममूल्यं...</"
"guimenuitem></menuchoice> इति चयनं यथा ।"

#. Tag: term
#: index.docbook:1526
#, no-c-format
msgid "/maindlg org.kde.kmplot.MainDlg.graphArea"
msgstr "/maindlg org.kde.kmplot.मुख्यDlg.graphक्षेत्र"

#. Tag: para
#: index.docbook:1530
#, no-c-format
msgid ""
"The same as choosing <menuchoice><guimenu>Tools</guimenu><guimenuitem>Plot "
"Area...</guimenuitem></menuchoice> in the menu."
msgstr ""
"मेनूमध्ये <menuchoice><guimenu>Tools</guimenu><guimenuitem>Plot Area...</"
"guimenuitem></menuchoice> इति चयनं यथा भवति तथा एव ।"

#. Tag: term
#: index.docbook:1534
#, no-c-format
msgid "/maindlg org.kde.kmplot.MainDlg.calculator"
msgstr "/maindlg org.kde.kmplot.MainDlg.गणकयंत्र"

#. Tag: para
#: index.docbook:1538
#, no-c-format
msgid ""
"The same as choosing <menuchoice><guimenu>Tools</"
"guimenu><guimenuitem>Calculator</guimenuitem></menuchoice> in the menu."
msgstr ""
"मेन्यू मध्ये <menuchoice><guimenu>Tools</guimenu><guimenuitem>Calculator</"
"guimenuitem></menuchoice> इति चयनं यथा भवति तथा एव ।"

#. Tag: term
#: index.docbook:1542
#, no-c-format
msgid "/parser org.kde.kmplot.Parser.addFunction f_str0 f_fstr1"
msgstr "/पार्सर org.kde.kmplot.पार्सर.addFunction f_str0 च_fstr1"

#. Tag: para
#: index.docbook:1546
#, no-c-format
msgid ""
"Adds a new function with the expressions <parameter>f_str0</parameter> and "
"<parameter>f_str1</parameter>. If the expression does not contain a function "
"name, it will be auto-generated. The id number of the new function is "
"returned, or -1 if the function could not be defined."
msgstr ""
"<parameter>f_str0</parameter> तथा <parameter>f_str1</parameter> इति व्यञ्जनैः "
"सह नूतनं फंक्शन् योजयति । यदि व्यञ्जने फंक्शन् नाम नास्ति तर्हि तत् स्वयमेव जनितं भविष्यति । "
"नूतनस्य फंक्शन् इत्यस्य id सङ्ख्या प्रत्यागच्छति, अथवा -1 यदि फंक्शन् परिभाषितुं न शक्यते स्म ।"

#. Tag: term
#: index.docbook:1550
#, no-c-format
msgid "/parser org.kde.kmplot.Parser.removeFunction id"
msgstr "/पार्सर org.kde.kmplot.पार्सर.removeFunction आईडी"

#. Tag: para
#: index.docbook:1554
#, no-c-format
msgid ""
"Removes the function with the id number <parameter>id</parameter>. If the "
"function could not be deleted, false is returned, otherwise true."
msgstr ""
"id संख्या <parameter>id</parameter> इत्यनेन सह कार्यं निष्कासयति । यदि फंक्शन् लोपयितुं "
"न शक्यते स्म तर्हि false प्रत्यागच्छति, अन्यथा सत्यम् ।"

#. Tag: term
#: index.docbook:1558
#, no-c-format
msgid "/parser org.kde.kmplot.Parser.setFunctionExpression id eq f_str"
msgstr "/पार्सर org.kde.kmplot.पार्सर.सेटफंक्शनअभिव्यक्ति आईडी eq f_str"

#. Tag: para
#: index.docbook:1562
#, no-c-format
msgid ""
"Sets the expression for the function with the id number <parameter>id</"
"parameter> to <parameter>f_str</parameter>. Returns true if it succeed, "
"otherwise false."
msgstr ""
"id संख्या <parameter>id</parameter> इत्यनेन सह फंक्शन् इत्यस्य अभिव्यक्तिं "
"<parameter>f_str</parameter> इति सेट् करोति । यदि सफलं भवति तर्हि सत्यं "
"प्रत्यागच्छति, अन्यथा मिथ्या ।"

#. Tag: term
#: index.docbook:1566
#, no-c-format
msgid "/parser org.kde.kmplot.Parser.countFunctions"
msgstr "/पार्सर org.kde.kmplot.पार्सर.गणनाकार्यं"

#. Tag: para
#: index.docbook:1570
#, no-c-format
msgid ""
"Returns the number of functions (parametric functions are calculated as two)."
msgstr "फंक्शन्स् इत्यस्य संख्यां ददाति (पैरामेट्रिक फंक्शन्स् द्वौ इति गण्यन्ते) ।"

#. Tag: term
#: index.docbook:1575
#, no-c-format
msgid "/parser org.kde.kmplot.Parser.listFunctionNames"
msgstr "/पार्सर org.kde.kmplot.पार्सर.सूचीकार्यनाम"

#. Tag: para
#: index.docbook:1579
#, no-c-format
msgid "Returns a list with all functions."
msgstr "सर्वैः कार्यैः सह सूचीं प्रत्यागच्छति ।"

#. Tag: term
#: index.docbook:1583
#, no-c-format
msgid "/parser org.kde.kmplot.Parser.fnameToID f_str"
msgstr "/पार्सर org.kde.kmplot.पार्सर.fnameToID f_str"

#. Tag: para
#: index.docbook:1587
#, no-c-format
msgid ""
"Returns the id number of <parameter>f_str</parameter> or -1 if the function "
"name <parameter>f_str</parameter> was not found."
msgstr ""
"<parameter>f_str</parameter> अथवा -1 इत्यस्य id सङ्ख्यां ददाति यदि "
"<parameter>f_str</parameter> इति फंक्शन् नाम न प्राप्तम् ।"

#. Tag: term
#: index.docbook:1591
#, no-c-format
msgid "/parser org.kde.kmplot.Parser.functionFVisible id"
msgstr "/पार्सर org.kde.kmplot.Parser.functionFदृश्यमान आईडी"

#. Tag: para
#: index.docbook:1595
#, no-c-format
msgid ""
"Returns true if the function with the ID <parameter>id</parameter> is "
"visible, otherwise false."
msgstr ""
"यदि ID <parameter>id</parameter> इत्यनेन सह कार्यं दृश्यते तर्हि सत्यं ददाति, अन्यथा "
"मिथ्या ।"

#. Tag: term
#: index.docbook:1599
#, no-c-format
msgid "/parser org.kde.kmplot.Parser.functionF1Visible id"
msgstr "/पार्सर org.kde.kmplot.पार्सर.फंक्शनF1दृश्यमान आईडी"

#. Tag: para
#: index.docbook:1603
#, no-c-format
msgid ""
"Returns true if the first derivative of the function with the ID "
"<parameter>id</parameter> is visible, otherwise false."
msgstr ""
"यदि ID <parameter>id</parameter> इत्यनेन सह फंक्शन् इत्यस्य प्रथमं व्युत्पन्नं दृश्यते तर्हि "
"सत्यं ददाति, अन्यथा मिथ्या ।"

#. Tag: term
#: index.docbook:1607
#, no-c-format
msgid "/parser org.kde.kmplot.Parser.functionF2Visible id"
msgstr "/पार्सर org.kde.kmplot.पार्सर.फंक्शनF2दृश्यमान आईडी"

#. Tag: para
#: index.docbook:1611
#, no-c-format
msgid ""
"Returns true if the second derivative of the function with the ID "
"<parameter>id</parameter> is visible, otherwise false."
msgstr ""
"यदि ID <parameter>id</parameter> इत्यनेन सह फंक्शन् इत्यस्य द्वितीयं व्युत्पन्नं दृश्यते तर्हि "
"सत्यं ददाति, अन्यथा मिथ्या ।"

#. Tag: term
#: index.docbook:1615
#, no-c-format
msgid "/parser org.kde.kmplot.Parser.functionIntVisible id"
msgstr "/पार्सर org.kde.kmplot.पार्सर.फंक्शनइंटदृश्यमान आईडी"

#. Tag: para
#: index.docbook:1619
#, no-c-format
msgid ""
"Returns true if the integral of the function with the ID <parameter>id</"
"parameter> is visible, otherwise false."
msgstr ""
"यदि ID <parameter>id</parameter> इत्यनेन सह फंक्शन् इत्यस्य अभिन्नं दृश्यते तर्हि सत्यं "
"ददाति, अन्यथा मिथ्या ।"

#. Tag: term
#: index.docbook:1623
#, no-c-format
msgid "/parser org.kde.kmplot.Parser.setFunctionFVisible id visible"
msgstr "/parser org.kde.kmplot.Parser.setFunctionFदृश्यमान आईडी दृश्यमानम्"

#. Tag: para
#: index.docbook:1627
#, no-c-format
msgid ""
"Shows the function with the ID <parameter>id</parameter> if "
"<parameter>visible</parameter> is true. If <parameter>visible</parameter> is "
"false, the function will be hidden. True is returned if the function exists, "
"otherwise false."
msgstr ""
"<parameter>visible</parameter> सत्यं चेत् ID <parameter>id</parameter> इत्यनेन सह "
"कार्यं दर्शयति । यदि <parameter>visible</parameter> मिथ्या अस्ति तर्हि कार्यं गोपनीयं "
"भविष्यति । True प्रत्यागच्छति यदि फंक्शन् अस्ति, अन्यथा false ।"

#. Tag: term
#: index.docbook:1631
#, no-c-format
msgid "/parser org.kde.kmplot.Parser.setFunctionF1Visible id visible"
msgstr "/parser org.kde.kmplot.Parser.setFunctionF1दृश्यमान आईडी दृश्यमानम्"

#. Tag: para
#: index.docbook:1635
#, no-c-format
msgid ""
"Shows the first derivative of the function with the ID <parameter>id</"
"parameter> if <parameter>visible</parameter> is true. If <parameter>visible</"
"parameter> is false, the function will be hidden. True is returned if the "
"function exists, otherwise false."
msgstr ""
"<parameter>visible</parameter> सत्यं चेत् ID <parameter>id</parameter> इत्यनेन सह "
"फंक्शन् इत्यस्य प्रथमं व्युत्पन्नं दर्शयति । यदि <parameter>visible</parameter> मिथ्या "
"अस्ति तर्हि कार्यं गोपनीयं भविष्यति । True प्रत्यागच्छति यदि फंक्शन् अस्ति, अन्यथा false ।"

#. Tag: term
#: index.docbook:1639
#, no-c-format
msgid "/parser org.kde.kmplot.Parser.setFunctionF2Visible id visible"
msgstr "/parser org.kde.kmplot.Parser.setFunctionF2दृश्यमान आईडी दृश्यमानम्"

#. Tag: para
#: index.docbook:1643
#, no-c-format
msgid ""
"Shows the second derivative of the function with the ID <parameter>id</"
"parameter> if <parameter>visible</parameter> is true. If <parameter>visible</"
"parameter> is false, the function will be hidden. True is returned if the "
"function exists, otherwise false."
msgstr ""
"<parameter>visible</parameter> सत्यं चेत् ID <parameter>id</parameter> इत्यनेन सह "
"फंक्शन् इत्यस्य द्वितीयं व्युत्पन्नं दर्शयति । यदि <parameter>visible</parameter> मिथ्या "
"अस्ति तर्हि कार्यं गोपनीयं भविष्यति । True प्रत्यागच्छति यदि फंक्शन् अस्ति, अन्यथा false ।"

#. Tag: term
#: index.docbook:1647
#, no-c-format
msgid "/parser org.kde.kmplot.Parser.setFunctionIntVisible id visible"
msgstr "/पार्सर org.kde.kmplot.Parser.setFunctionIntVisible आईडी दृश्यमानम्"

#. Tag: para
#: index.docbook:1651
#, no-c-format
msgid ""
"Shows the integral of the function with the ID <parameter>id</parameter> if "
"<parameter>visible</parameter> is true. If <parameter>visible</parameter> is "
"false, the function will be hidden. True is returned if the function exists, "
"otherwise false."
msgstr ""
"<parameter>visible</parameter> सत्यं चेत् ID <parameter>id</parameter> इत्यनेन सह "
"फंक्शन् इत्यस्य अभिन्नं दर्शयति । यदि <parameter>visible</parameter> मिथ्या अस्ति तर्हि "
"कार्यं गोपनीयं भविष्यति । True प्रत्यागच्छति यदि फंक्शन् अस्ति, अन्यथा false ।"

#. Tag: term
#: index.docbook:1655
#, no-c-format
msgid "/parser org.kde.kmplot.Parser.functionStr id eq"
msgstr "/पार्सर org.kde.kmplot.पार्सर.फंक्शनStr आईडी समीकरण"

#. Tag: para
#: index.docbook:1659
#, no-c-format
msgid ""
"Returns the function expression of the function with the ID <parameter>id</"
"parameter>. If the function not exists, an empty string is returned instead."
msgstr ""
"ID <parameter>id</parameter> इत्यनेन सह फंक्शन् इत्यस्य फंक्शन् एक्सप्रेशनं प्रत्यागच्छति । "
"यदि फंक्शन् नास्ति तर्हि तस्य स्थाने रिक्तं स्ट्रिंग् प्रत्यागच्छति ।"

#. Tag: term
#: index.docbook:1663
#, no-c-format
msgid "/parser org.kde.kmplot.Parser.functionFLineWidth id"
msgstr "/पार्सर org.kde.kmplot.पार्सर.फंक्शनFLineWidth आईडी"

#. Tag: para
#: index.docbook:1667
#, no-c-format
msgid ""
"Returns the line width of the function with the ID <parameter>id</"
"parameter>. If the function not exists, 0 is returned."
msgstr ""
"ID <parameter>id</parameter> इत्यनेन सह फंक्शन् इत्यस्य रेखाविस्तारं प्रत्यागच्छति । यदि "
"फंक्शन् नास्ति तर्हि 0 प्रत्यागच्छति ।"

