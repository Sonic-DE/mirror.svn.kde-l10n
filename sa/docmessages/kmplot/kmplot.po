#: index.docbook:1671
#, no-c-format
msgid "/parser org.kde.kmplot.Parser.functionF1LineWidth id"
msgstr "/पार्सर org.kde.kmplot.पार्सर.फंक्शनF1रेखाचौड़ाई आईडी"

#. Tag: para
#: index.docbook:1675
#, no-c-format
msgid ""
"Returns the line width of the first derivative of the function with the ID "
