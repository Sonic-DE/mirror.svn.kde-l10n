msgstr "अतिपरवलयिककार्यम् ।"

#. Tag: term
#: index.docbook:771
#, no-c-format
msgid "sinh(x)"
msgstr "जन्म(x)"

#. Tag: term
#: index.docbook:772
#, no-c-format
