#. Tag: title
#: man-okular.1.docbook:9
#, no-c-format
msgid "Okular User's Manual"
msgstr "Okular उपयोक्तृपुस्तिका"

#. Tag: author
#: man-okular.1.docbook:10
#, no-c-format
msgid ""
"<firstname>Yuri</firstname><surname>Chornoivan</surname> <contrib>Okular man "
"page.</contrib> <email>yurchor@ukr.net</email>"
msgstr ""
"<firstname>युरी</firstname><surname>चोर्नोइवान</surname> <contrib>ओकुलर "
"मनुष्यपृष्ठम्।</contrib> <email>yurchor@ukr.net</email>"

#. Tag: date
#: man-okular.1.docbook:13
#, no-c-format
msgid "2022-02-19"
msgstr "२०२२-०२-१९"

#. Tag: releaseinfo
#: man-okular.1.docbook:14
#, no-c-format
msgid "Okular 22.04"
msgstr "नेत्रदर्शी २२.०४"

#. Tag: productname
#: man-okular.1.docbook:15
#, no-c-format
msgid "KDE Gear"
msgstr "केडीई गियर"

#. Tag: manvolnum
#: man-okular.1.docbook:20
#, no-c-format
msgid "<manvolnum>1</manvolnum>"
msgstr "<मन्वोल्नुम्>१</मन्वोल्नुम्>"

#. Tag: refname
#: man-okular.1.docbook:24
#, no-c-format
msgid "<refname>okular</refname>"
msgstr "<refname>नेत्र</refname> इति"

#. Tag: refpurpose
#: man-okular.1.docbook:25
#, no-c-format
msgid "a universal document viewer"
msgstr "एकः सार्वभौमिकः दस्तावेजदर्शकः"

#. Tag: cmdsynopsis
#: man-okular.1.docbook:29
#, no-c-format
msgid ""
"<command>okular</command> <arg choice=\"opt\"><replaceable>Okular options</"
"replaceable></arg> <arg choice=\"opt\"><replaceable>URL</replaceable></arg>"
msgstr ""
"<command>okular</command> <arg choice=\"opt\"><replaceable>ओकुलर विकल्पाः</"
"replaceable></arg> <arg choice=\"opt\"><replaceable>URL</replaceable></arg>"

#. Tag: title
#: man-okular.1.docbook:37
#, no-c-format
msgid "Description"
msgstr "वर्णनम्‌"

#. Tag: para
#: man-okular.1.docbook:38
#, no-c-format
msgid ""
"<command>okular</command> is aimed to show documents in different formats."
msgstr "<command>okular</command> इत्यस्य उद्देश्यं भिन्नस्वरूपेषु दस्तावेजान् दर्शयितुं भवति ।"

#. Tag: title
#: man-okular.1.docbook:43
#, no-c-format
msgid "Okular options"
msgstr "नेत्रविकल्पाः"

#. Tag: option
#: man-okular.1.docbook:47
#, no-c-format
msgid "-p, --page <replaceable>number</replaceable>"
msgstr "-प, --पृष्ठ <प्रतिस्थापनीय>संख्या</प्रतिस्थापनीय>"

#. Tag: para
#: man-okular.1.docbook:49
#, no-c-format
msgid "Open a page with a given number in the document."
msgstr "दस्तावेजे दत्तसङ्ख्यायुक्तं पृष्ठं उद्घाटयन्तु ।"

#. Tag: option
#: man-okular.1.docbook:54
#, no-c-format
msgid "--presentation"
msgstr "--प्रस्तुति"

#. Tag: para
#: man-okular.1.docbook:56
#, no-c-format
msgid "Start the document in presentation mode."
msgstr "दस्तावेजं प्रस्तुतिविधाने आरभत ।"

#. Tag: option
#: man-okular.1.docbook:61
#, no-c-format
msgid "--print"
msgstr "--मुद्रणम्"

#. Tag: para
#: man-okular.1.docbook:63
#, no-c-format
msgid "Start with print dialog."
msgstr "मुद्रणसंवादेन आरभत।"

#. Tag: option
#: man-okular.1.docbook:68
#, no-c-format
msgid "--print-and-exit"
msgstr "--मुद्रण-निर्गम"

#. Tag: para
#: man-okular.1.docbook:70
#, no-c-format
msgid "Start with print dialog and exit after printing."
msgstr "मुद्रणसंवादेन आरभ्य मुद्रणानन्तरं निर्गच्छतु ।"

#. Tag: option
#: man-okular.1.docbook:75
#, no-c-format
msgid "--unique"
msgstr "--अद्वितीयः"

#. Tag: para
#: man-okular.1.docbook:77
#, no-c-format
msgid "Unique instance control."
msgstr "अद्वितीयं उदाहरणनियन्त्रणम्।"

#. Tag: option
#: man-okular.1.docbook:82
#, no-c-format
msgid "--noraise"
msgstr "-- उन्नत"

#. Tag: para
#: man-okular.1.docbook:84
#, no-c-format
msgid "Allows to prevent Okular window raising after the start."
msgstr "आरम्भस्य अनन्तरं Okular विण्डो उत्थापनं निवारयितुं शक्नोति ।"

#. Tag: option
#: man-okular.1.docbook:89
#, no-c-format
msgid "--find <replaceable>string</replaceable>"
msgstr "--<replaceable>string</replaceable> इति अन्वेष्टुम्"

#. Tag: para
#: man-okular.1.docbook:91
#, no-c-format
msgid ""
"Tries to find and highlight a given string in the document. Only works if "
"just one document is given as an argument of the okular command."
msgstr ""
"दस्तावेजे दत्तं स्ट्रिंग् अन्वेष्टुं हाइलाइट् कर्तुं च प्रयतते । केवलं तदा एव कार्यं करोति यदा "
"okular आदेशस्य तर्करूपेण केवलं एकं दस्तावेजं दत्तं भवति ।"

#. Tag: option
#: man-okular.1.docbook:96
#, no-c-format
msgid "--editor-cmd <replaceable>string</replaceable>"
msgstr "--editor-cmd <प्रतिस्थापनीय>स्ट्रिंग्</प्रतिस्थापनीय>"

#. Tag: para
#: man-okular.1.docbook:98
#, no-c-format
msgid ""
"Sets the external editor command. You cannot set the editor command in an "
"already running Okular instance. Please note that <option>--unique</option> "
"is not supported when setting the editor command at the commandline."
msgstr ""
"बाह्य सम्पादक आदेशं सेट् करोति । पूर्वमेव चालितस्य Okular दृष्टान्तस्य मध्ये editor आदेशं सेट् "
"कर्तुं न शक्नुवन्ति । कृपया तत् अवलोकयन्तु<option value=--unique> --अद्वितीयः</option> "
"आदेशपङ्क्तौ सम्पादक-आदेशं सेट् कुर्वन् समर्थितः नास्ति ।"

#. Tag: title
#: man-okular.1.docbook:104
#, no-c-format
msgid "Arguments"
msgstr "तर्काः"

#. Tag: option
#: man-okular.1.docbook:107
#, no-c-format
msgid "<option>URL</option>"
msgstr "<option value=URL>URL</option>"

#. Tag: para
#: man-okular.1.docbook:109
#, no-c-format
msgid ""
"An address of the document to be opened. For PDF, can be given as "
"<replaceable>document_name</replaceable>#<replaceable>named_destination</"
"replaceable> where <replaceable>named_destination</replaceable> is a "
"particular named destination embedded in the document."
msgstr ""
"उद्घाटनीयस्य दस्तावेजस्य एकः पता। PDF कृते, <replaceable>document_name</"
"replaceable>#<replaceable>named_destination</replaceable> इति दातुं शक्यते यत्र "
"<replaceable>named_destination</replaceable> इति दस्तावेजे निहितं विशेषं नाम गन्तव्यं "
"भवति"

#. Tag: title
#: man-okular.1.docbook:115
#, no-c-format
msgid "Feedback"
msgstr "स्पर्शावबोध"

#. Tag: para
#: man-okular.1.docbook:116
#, no-c-format
msgid ""
"On IRC, irc.libera.chat #okular or via email, okular-devel@kde.org or on the "
"web, &lt;<ulink url=\"https://okular.kde.org/\">https://okular.kde.org/</"
"ulink>&gt;."
msgstr ""
"IRC इत्यत्र, irc.libera.chat #okular इत्यत्र अथवा ईमेलद्वारा, okular-devel@kde.org "
"इत्यत्र अथवा जालपुटे, &lt;<ulink url=\"https://okular.kde.org/\">https://okular "
"इत्यत्र .kde.org/</ulink>&gt;."

#. Tag: title
#: man-okular.1.docbook:120
#, no-c-format
msgid "See Also"
msgstr "इदमपि पश्यन्तु"

#. Tag: member
#: man-okular.1.docbook:122
#, no-c-format
msgid ""
"More detailed user documentation is available from <ulink url=\"help:/okular"
"\">help:/okular</ulink> (either enter this <acronym>URL</acronym> into "
"&konqueror;, or run <userinput><command>khelpcenter</command> "
"<parameter>help:/okular</parameter></userinput>)."
msgstr ""
"अधिकविस्तृतं उपयोक्तृदस्तावेजं <ulink url=\"help:/okular\">help:/okular</ulink> "
"इत्यस्मात् उपलभ्यते (एतत् <acronym>URL</acronym> इत्येतत् &konqueror; इत्यत्र प्रविशन्तु, "
"अथवा <userinput><command> चालयन्तु khelpcenter</command> <parameter>सहाय्यम्:/"
"okular</parameter></userinput>) इति ।"

#. Tag: member
#: man-okular.1.docbook:127
#, no-c-format
msgid "kf6options(7)"
msgstr "kf6विकल्पाः(7) ."

#. Tag: member
#: man-okular.1.docbook:128
#, no-c-format
msgid "qt6options(7)"
msgstr "qt6विकल्प(7) 1.1."

#. Tag: member
#: man-okular.1.docbook:129
#, no-c-format
msgid ""
"There is also further information available at <ulink url=\"https://okular."
"kde.org/\">https://okular.kde.org/</ulink>"
msgstr ""
"<ulink url=\"https://okular.kde.org/\">https://okular.kde.org/</ulink> इत्यत्र "
"अपि अधिकानि सूचनानि उपलभ्यन्ते"

