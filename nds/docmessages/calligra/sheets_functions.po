msgid "<title>SUM</title>"
msgstr ""

#. Tag: para
#: functions.docbook:7383
#, no-c-format
msgid ""
"The SUM() function calculates the sum of all the values given as parameters. "
"You can calculate the sum of a range SUM(A1:B5) or a list of values like "
"SUM(12;5;12.5)."
msgstr ""
"De Funkschoon SUM() reekt de Summ vun all as Parameters angeven Weerten ut. "
"Een kann de Summ vun en Rebeet SUM(A1:B5) oder en List vun Weerten liek "
"SUM(12;5;12.5) utreken."

#. Tag: para
#: functions.docbook:7388 functions.docbook:7417
#, no-c-format
msgid "SUM(value;value;...)"
msgstr "SUM(Weert;Weert;...)"

#. Tag: para
#: functions.docbook:7395
#, no-c-format
msgid "SUM(12;5;7) equals 24"
msgstr "SUM(12;5;7) gifft \"24\" torüch"

#. Tag: para
#: functions.docbook:7398
#, no-c-format
msgid "SUM(12.5;2) equals 14.5"
msgstr "SUM(12,5;2) gifft \"14,5\" torüch"

