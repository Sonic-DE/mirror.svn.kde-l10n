msgid "Integer value to convert"
msgstr "Heeltallweert, de ümwannelt warrn schall"

#. Tag: para
#: functions.docbook:379
#, no-c-format
msgid "INT2BOOL(1) returns true"
msgstr "INT2BOOL(1) gifft \"wohr\" torüch"

#. Tag: para
#: functions.docbook:382
#, no-c-format
msgid "INT2BOOL(0) returns false"
msgstr "INT2BOOL(0) gifft \"falsch\" torüch"

#. Tag: para
#: functions.docbook:385
#, no-c-format
msgid "OR(INT2BOOL(1); false) returns true"
msgstr "OR(INT2BOOL(1); falsch) gifft \"wohr\" torüch"

