#: org.kde.kmenuedit.appdata.xml:9
msgid "Menu Editor"
msgstr "Éditeur de menus"

#. (itstool) path: component/summary
#: org.kde.kmenuedit.appdata.xml:10
msgid "Edit how applications are presented in app launchers"
msgstr ""
"Modifier la présentation des applications dans les lanceurs d'applications"

#. (itstool) path: description/p
#: org.kde.kmenuedit.appdata.xml:12
msgid ""
"KDE Menu Edit lets you edit how your apps are presented in application "
"launchers, such as Plasma's Application Launcher widget."
msgstr ""
"Le menu « Édition » de KDE vous permet de modifier la présentation des "
"applications dans les lanceurs d'applications, comme le composant graphique "
"« Lanceur d'applications » de Plasma."
