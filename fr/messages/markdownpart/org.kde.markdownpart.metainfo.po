#: org.kde.markdownpart.metainfo.xml:16
msgid "Markdown Viewer KPart"
msgstr "Afficheur « KPart » de fichiers « Markdown »"

#. (itstool) path: component/summary
#: org.kde.markdownpart.metainfo.xml:17
msgid "Rendered display of Markdown files in KParts-using software"
msgstr ""
"Affichage de rendu des fichiers « Markdown » avec un logiciel utilisant "
"« KParts »"

#. (itstool) path: description/p
#: org.kde.markdownpart.metainfo.xml:19
msgid ""
"The Markdown Viewer KPart allows KParts-using software to display files in "
"Markdown format in a rendered view."
msgstr ""
"L'afficheur « KPart » de fichiers « Markdown » permet à un logiciel "
"utilisant « KParts » d'afficher les fichiers dans le format « Markdown » "
"dans un affichage de rendu."
