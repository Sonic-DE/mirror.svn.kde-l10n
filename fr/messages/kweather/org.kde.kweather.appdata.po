#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:161
msgid "Performance improvements in Dynamic view"
msgstr "Améliorations des performances dans la vue dynamique"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:162
msgid "Dynamic view action bar rewritten to be inline to content"
msgstr ""
"La barre d'actions de vue dynamique a été réécrite pour être intégrée au "
"contenu"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:163
msgid "Allow setting non-current location in default forecasts page"
msgstr ""
"Autoriser la définition d'un emplacement non courant sur la page par défaut "
"des prévisions"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:164
msgid "Added ability to fetch temperature units from system locale"
msgstr ""
"Ajout de la possibilité de charger les unités de température à partir des "
"paramètres régionaux du système"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:165
msgid "Fixed timezone format not being correctly read for local location time"
msgstr ""
"Correction du format de fuseau horaire fixe incorrectement lu pour l’heure "
"locale"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:176
