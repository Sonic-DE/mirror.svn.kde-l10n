#. (itstool) path: component/name
#: org.kde.gwenview.appdata.xml:9
msgid "Gwenview"
msgstr "Gwenview"

#. (itstool) path: component/summary
#: org.kde.gwenview.appdata.xml:10
msgid "Image Viewer"
msgstr "Afficheur d'image"

#. (itstool) path: description/p
#: org.kde.gwenview.appdata.xml:12
msgid ""
"Gwenview is a fast and easy to use image viewer by KDE, ideal for browsing "
"and displaying a collection of images."
msgstr ""
"Gwenview est un afficheur d'images rapide et facile à utiliser pour KDE, "
"idéal pour parcourir et afficher une collection d'images."

#. (itstool) path: description/p
#: org.kde.gwenview.appdata.xml:15
msgid "Features:"
msgstr "Fonctionnalités :"

#. (itstool) path: ul/li
#: org.kde.gwenview.appdata.xml:17
msgid ""
"Simple image editing: rotate, crop, resize, mirror, flip, reduce red eye, "
"and adjust brightness, contrast, or gamma"
msgstr ""
"Modifications simples d'images : rotation, rognage, re-dimensionnement, "
"inversion, réduction des yeux rouges, ajustement de la luminosité, du "
"contraste et du gamma."

#. (itstool) path: ul/li
#: org.kde.gwenview.appdata.xml:18
msgid ""
"Annotate and mark up images with arrows, shapes, text boxes, image stamps, "
"and more"
msgstr ""
"Annotez et balisez les images avec des flèches, des formes, des zones de "
"texte, des timbres d'images et plus encore"

#. (itstool) path: ul/li
#: org.kde.gwenview.appdata.xml:19
msgid "Basic file management actions such as copy, move, delete, and others"
msgstr ""
"Actions basiques de gestion de fichiers comme copier, déplacer, supprimer et "
"autres"

#. (itstool) path: screenshot/caption
#: org.kde.gwenview.appdata.xml:29
msgid "Main application window displaying an image and controls on the left"
msgstr ""
"Fenêtre principale de l'application affichant sur la gauche, une image et "
"les contrôles"

#. (itstool) path: screenshot/caption
#: org.kde.gwenview.appdata.xml:33
msgid "Use Gwenview to manage your image collection"
msgstr "Utiliser Gwenview pour gérer votre collection d'images."

#~ msgid ""
#~ "Functions both as a standalone application and an embedded viewer in the "
#~ "Konqueror web browser"
#~ msgstr ""
#~ "Fonctionne à la fois comme application autonome et comme afficheur "
#~ "embarqué dans le navigateur web Konqueror"

#~ msgid "KDE"
#~ msgstr "KDE"

#~ msgid ""
#~ "Supports simple image manipulations: rotate, mirror, flip, and resize"
#~ msgstr ""
#~ "Prise en charge des manipulations d'image simples : rotation, miroir, "
#~ "basculer, et redimensionner"

#~ msgid ""
#~ "Gwenview displaying an image, with additional metadata shown in the "
#~ "sidebar"
#~ msgstr ""
#~ "Gwenview en train d'afficher une image, avec des métadonnées "
#~ "supplémentaires dans le panneau latéral."

#~ msgid "Can be extended using KIPI plugins."
#~ msgstr "Peut être étendu en utilisant des modules KIPI."
