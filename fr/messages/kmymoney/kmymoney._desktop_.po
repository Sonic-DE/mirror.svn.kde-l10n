#: kmymoney/plugins/ibanbicdata/germany/germany.desktop.in:29
msgctxt "Comment"
msgid ""
"IBAN and BIC information as published by Deutsche Bundesbank, Frankfurt am "
"Main, Deutschland."
msgstr ""
"Les informations « IBAN » et « BIC » comme publiées par la banque "
"d'Allemagne, Francfort sur le Main, Allemagne."

#: kmymoney/plugins/ibanbicdata/ibanbicdata.desktop.in:4
