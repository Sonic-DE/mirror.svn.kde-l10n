#. (itstool) path: component/name
#: org.kde.keepsecret.metainfo.xml:8
msgid "KeepSecret"
msgstr "KeepSecret"

#. (itstool) path: component/summary
#: org.kde.keepsecret.metainfo.xml:9
msgid "Manage passwords"
msgstr "Gérer des mots de passe"

#. (itstool) path: description/p
#: org.kde.keepsecret.metainfo.xml:16
msgid ""
"Password manager for viewing, editing, creating, or deleting passwords, "
"suitable for both desktop and mobile platforms."
msgstr ""
"Gestionnaire de mots de passe pour afficher, modifier, créer ou supprimer "
"des mots de passe, adapté à la fois aux plate-formes de bureau et mobiles."

#. (itstool) path: description/p
#: org.kde.keepsecret.metainfo.xml:17
msgid ""
"Works with KeepassXC, KWallet, Gnome Keyring, oo7, and any other password "
"backend that's compatible with the Secret Service system."
msgstr ""
"Fonctionne avec KeePassXC, KWallet, Gnome Keyring, oo7 et tout autre moteur "
"de mot de passe compatible avec le système « Secret Service »."
