#. (itstool) path: component/name
#: org.kde.dragonplayer.appdata.xml:9
msgid "Dragon Player"
msgstr "Dragon Player"

#. (itstool) path: component/summary
#: org.kde.dragonplayer.appdata.xml:10
msgid "Play video files and streams"
msgstr "Lire des fichiers et des flux vidéo"

#. (itstool) path: description/p
#: org.kde.dragonplayer.appdata.xml:12
msgid ""
"Dragon Player is a video player focusing on simplicity instead of features. "
"Its easy-to-use interface is designed to get out of your way and simply play "
"your video files and streams."
msgstr ""
"Dragon Player est un lecteur vidéo conçu pour la facilité d'utilisation, "
"plutôt que d'offrir de nombreuses fonctionnalités. Son interface simple est "
"conçue pour ne pas vous embarrasser mais plutôt vous donner la capacité de "
"lire le plus simplement possible des fichiers et des flux vidéo."

#. (itstool) path: description/p
#: org.kde.dragonplayer.appdata.xml:15
msgid "Features:"
msgstr "Fonctionnalités :"

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:17
msgid ""
"Click to play or pause, and double-click to enter or exit full screen mode."
msgstr ""
"Veuillez effectuer un clic pour lire ou mettre en pause, puis un double clic "
"pour basculer ou sortie du mode « Plein écran »."

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:18
msgid ""
"Choose the subtitle language, and automatically load the right one for your "
"language, if possible."
msgstr ""
"Veuillez sélectionner la langue de sous-titres et charger automatiquement "
"celle convenant à votre langue, si possible."

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:19
msgid "Choose the audio track."
msgstr "Veuillez sélectionner la piste audio."

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:20
msgid "Choose the video track."
msgstr "Veuillez sélectionner la piste vidéo."

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:21
msgid "Adjust the volume by scrolling."
msgstr "Ajustez le volume par un simple défilement."

#~ msgid "Video player with focus on simplicity"
#~ msgstr "Un lecteur vidéo conçu pour la facilité d'utilisation"

#~ msgid "Simple Interface"
#~ msgstr "Interface simple"

#~ msgid ""
#~ "Resuming videos: Starts playing a video where you were watching it last "
#~ "time"
#~ msgstr ""
#~ "Reprise des vidéos : démarre la lecture d'une vidéo de là où vous la "
#~ "regardiez la dernière fois"

#~ msgid ""
#~ "Support for subtitles: Automatically loads subtitles with the matching "
#~ "name"
#~ msgstr ""
#~ "Prise en charge des sous-titres : charge automatiquement les sous-titres "
#~ "don le nom correspond"

#~ msgid "Video display settings (brightness, contrast)"
#~ msgstr "Réglages de l'affichage de la vidéo (luminosité, contraste)"

#~ msgid ""
#~ "Due to using Solid and Phonon DragonPlayer is independent of any "
#~ "multimedia framework or hardware abstraction layer"
#~ msgstr ""
#~ "Grâce à l'utilisation de Solid et Phonon, Dragon Player est indépendant "
#~ "de toute infrastructure multimédia ou couche d'abstraction matérielle"

#~ msgid "Supports playing CDs and DVDs"
#~ msgstr "Prend en charge la lecture des CD et DVD"
