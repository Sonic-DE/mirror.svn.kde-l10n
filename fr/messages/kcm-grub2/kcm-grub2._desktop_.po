#: src/helper/kcmgrub2.actions:2
msgctxt "Name"
msgid "GRUB2 Bootloader Control Module"
msgstr "Module de contrôle du chargeur d'amorçage GRUB2"

#: src/helper/kcmgrub2.actions:50
msgctxt "Name"
msgid "Restore the default GRUB2 Bootloader settings"
msgstr "Restaure les paramètres par défaut du chargeur d'amorçage GRUB2"

#: src/helper/kcmgrub2.actions:94
msgctxt "Description"
msgid ""
"Administrator authorization is required to restore the default GRUB2 "
"Bootloader settings"
msgstr ""
"L'autorisation de l'administrateur est requise pour restaurer les paramètres "
"par défaut du chargeur d'amorçage GRUB2 "

#: src/helper/kcmgrub2.actions:141
msgctxt "Name"
msgid "Install the GRUB2 Bootloader"
msgstr "Installer le chargeur d'amorçage GRUB2"

#: src/helper/kcmgrub2.actions:187
msgctxt "Description"
msgid "Administrator authorization is required to install the GRUB2 Bootloader"
msgstr ""
"L'autorisation de l'administrateur est requise pour installer le chargeur "
"d'amorçage GRUB2"

#: src/helper/kcmgrub2.actions:235
msgctxt "Name"
msgid "Load the GRUB2 Bootloader settings"
msgstr "Charger les paramètres du chargeur d'amorçage GRUB2"

#: src/helper/kcmgrub2.actions:281
msgctxt "Description"
msgid ""
"Administrator authorization is required to load the GRUB2 Bootloader settings"
msgstr ""
"L'autorisation de l'administrateur est requise pour charger les paramètres "
"du chargeur d'amorçage GRUB2"

#: src/helper/kcmgrub2.actions:329
msgctxt "Name"
msgid "Save the GRUB2 Bootloader settings"
msgstr "Enregistrer les paramètres du chargeur d'amorçage GRUB2"

#: src/helper/kcmgrub2.actions:374
msgctxt "Description"
msgid ""
"Administrator authorization is required to save the GRUB2 Bootloader settings"
msgstr ""
"L'autorisation de l'administrateur est requise pour enregistrer les "
"paramètres du chargeur d'amorçage GRUB2"

