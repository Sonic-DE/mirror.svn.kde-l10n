#: host/org.kde.plasma.browser_integration.host.desktop.in:3
msgctxt "Name"
msgid "Plasma Browser Integration Host"
msgstr "Hôte pour l'intégration du navigateur dans Plasma"

#: host/plasma-runner-browserhistory.desktop:3
msgctxt "Name|plasma runner"
msgid "Browser History"
msgstr "Historique de navigation"

#: host/plasma-runner-browserhistory.desktop:48
msgctxt "Comment"
msgid "Search the browser history for visited websites"
msgstr "Rechercher l'historique de navigation pour les sites Internet visités."

#: host/plasma-runner-browserhistory.desktop:108
msgctxt "X-Plasma-Runner-Syntax-Descriptions"
msgid "Finds websites in the browser history whose title or URL match :q:"
msgstr ""
"Trouve les sites Internet dans l'historique du navigateur dont le titre ou "
"l'URL correspondent :q:"

#: host/plasma-runner-browsertabs.desktop:3
msgctxt "Name|plasma runner"
msgid "Browser Tabs"
msgstr "Onglets du navigateur"

#: host/plasma-runner-browsertabs.desktop:49
msgctxt "Comment"
msgid "Find and activate browser tabs"
msgstr "Chercher et activer les onglets du navigateur"

#: host/plasma-runner-browsertabs.desktop:115
msgctxt "X-Plasma-Runner-Syntax-Descriptions"
msgid "Finds open browser tabs whose title or URL match :q:"
msgstr ""
"Trouve des onglets ouverts du navigateur dont le titre ou l'URL "
"correspondent :q:"

#~ msgctxt "Name"
#~ msgid "Plasma Browser Integration Installation Reminder"
#~ msgstr "Rappel d'installation de l'intégration au navigateur Plasma"

#~ msgctxt "Comment"
#~ msgid ""
#~ "Provides a link to the browser extension if the Plasma Browser "
#~ "Integration host is installed"
#~ msgstr ""
#~ "Fournit un lien vers l'extension du navigateur si l'hôte d'intégration au "
#~ "navigateur Plasma est installé"
