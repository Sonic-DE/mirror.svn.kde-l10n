msgid "Plasma Browser Integration Flatpak Integration"
msgstr "Installation de Flatpak dans le navigateur de Plasma"

#: reminder/browserintegrationreminder.json
msgctxt "Name"
msgid "Plasma Browser Integration Installation Reminder"
msgstr "Rappel d'installation de l'intégration au navigateur Plasma"

#: flatpak-integrator/browserintegrationflatpakintegrator.json
msgctxt "Description"
msgid "Automatically enables support for Firefox Flatpak"
msgstr "Active automatiquement la prise en charge de Flatpak pour Firefox"

#: reminder/browserintegrationreminder.json
msgctxt "Description"
msgid ""
"Provides a link to the browser extension if the Plasma Browser Integration "
"host is installed"
msgstr ""
"Fournit un lien vers l'extension du navigateur si l'hôte d'intégration de "
"Plasma au navigateur est installé"

