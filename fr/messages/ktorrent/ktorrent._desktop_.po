msgctxt "Name"
msgid "Torrent silently opened"
msgstr "Torrent ouvert silencieusement"

#: ktorrent/ktorrent.notifyrc:117
msgctxt "Name"
msgid "Torrent stopped by error"
msgstr "Torrent arrêté par erreur"

