#. (itstool) path: component/name
#: org.kde.okular.appdata.xml:7
msgid "Okular"
msgstr "Okular"

#. (itstool) path: component/summary
#: org.kde.okular.appdata.xml:8
msgid "View and annotate documents"
msgstr "Afficher et annoter les documents"

#. (itstool) path: description/p
#: org.kde.okular.appdata.xml:10
msgid ""
"Okular is a universal document viewer developed by KDE. Okular works on "
"multiple platforms, including but not limited to Linux, Windows, Mac OS X, "
"*BSD, etc."
msgstr ""
"Okular est un afficheur universel de documents développé par KDE. Okular "
"fonctionne sur de multiples plate-formes, comme Linux, Windows, Mac OS X, "
"etc."

#. (itstool) path: description/p
#: org.kde.okular.appdata.xml:13
msgid "Features:"
msgstr "Fonctionnalités :"

#. (itstool) path: ul/li
#: org.kde.okular.appdata.xml:15
msgid ""
"Supported Formats: PDF, PS, Tiff, DjVu, Images, DVI, XPS, Fiction Book, "
"Comic Book, Plucker, EPub, Fax"
msgstr ""
"Formats de fichiers pris en charge : pdf, ps, Tiff, DjVU, Images, DVI, XPS, "
"Fiction Book, Comic Book, Plucker, ePub, Fax"

#. (itstool) path: ul/li
#: org.kde.okular.appdata.xml:16
msgid "Sidebar with contents, thumbnails, reviews and bookmarks"
msgstr ""
"Barre latérale montrant les contenus, vignettes, informations de relecture "
"et signets"

#. (itstool) path: ul/li
#: org.kde.okular.appdata.xml:17
msgid "Annotations support"
msgstr "Gestion des annotations"

#. (itstool) path: screenshot/caption
#: org.kde.okular.appdata.xml:22
msgid "Reading manual in Okular"
msgstr "Lecture d'un manuel dans Okular"

