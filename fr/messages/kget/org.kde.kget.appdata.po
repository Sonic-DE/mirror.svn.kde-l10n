#. (itstool) path: component/name
#: org.kde.kget.appdata.xml:9
msgid "KGet"
msgstr "KGet"

#. (itstool) path: component/summary
#: org.kde.kget.appdata.xml:10
msgid "Download manager"
msgstr "Gestionnaire de téléchargement"

#. (itstool) path: description/p
#: org.kde.kget.appdata.xml:12
msgid "KGet is a versatile and user-friendly download manager."
msgstr "KGet est un gestionnaire de téléchargements intuitif et polyvalent"

#. (itstool) path: description/p
#: org.kde.kget.appdata.xml:15
msgid "Features:"
msgstr "Fonctionnalités :"

#. (itstool) path: ul/li
#: org.kde.kget.appdata.xml:17
msgid "Downloading files from FTP and HTTP(S) sources."
msgstr "Téléchargement de fichiers depuis des sources FTP et HTTP(S)."

#. (itstool) path: ul/li
#: org.kde.kget.appdata.xml:18
msgid ""
"Pausing and resuming of downloading files, as well as the ability to restart "
"a download."
msgstr ""
"Mise en pause et reprise du téléchargement de fichiers, possibilité de "
"relancer un téléchargement."

#. (itstool) path: ul/li
#: org.kde.kget.appdata.xml:19
msgid "Tells lots of information about current and pending downloads."
msgstr ""
"Affichage de nombreuses informations relatives aux téléchargements en cours "
"et en attente."

#. (itstool) path: ul/li
#: org.kde.kget.appdata.xml:20
msgid "Embedding into system tray."
msgstr "Intégration dans la boite à miniatures."

#. (itstool) path: ul/li
#: org.kde.kget.appdata.xml:21
msgid "Integration with the Konqueror web browser."
msgstr "Intégration avec le navigateur Internet Konqueror."

#. (itstool) path: ul/li
#: org.kde.kget.appdata.xml:22
msgid ""
"Metalink support which contain multiple URLs for downloads, along with "
"checksums and other information."
msgstr ""
"Prise en charge des méta-liens contenant plusieurs URL de téléchargement, "
"des sommes de contrôle et d'autres informations."

#. (itstool) path: screenshot/caption
#: org.kde.kget.appdata.xml:31
msgid "Downloading files with KGet"
msgstr "Téléchargement de fichiers avec KGet"
