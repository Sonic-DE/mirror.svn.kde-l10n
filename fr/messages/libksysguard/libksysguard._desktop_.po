#: faces/systemmonitor-faces.knsrc:2
msgctxt "Name"
msgid "System monitor Sensor Display Styles"
msgstr "Styles d'affichage pour le senseur de surveillance du système"

#: faces/systemmonitor-presets.knsrc:2
msgctxt "Name"
msgid "System monitor Sensor Presets"
msgstr "Préréglages du senseur de surveillance du système"

#: processcore/actions.actions:2
msgctxt "Name"
msgid "KSysGuard"
msgstr "KSysGuard"

#: processcore/actions.actions:82
msgctxt "Name"
msgid "Kill or stop etc a process"
msgstr "Tue, arrête ou autres actions relatives à un processus"

#: processcore/actions.actions:148
msgctxt "Description"
msgid "Sends a given signal to a given process"
msgstr "Envoie le signal donné à un processus donné"

#: processcore/actions.actions:218
msgctxt "Name"
msgid "Change the priority of a process"
msgstr "Modifie la priorité d'un processus"

#: processcore/actions.actions:286
msgctxt "Description"
msgid "Change the niceness of a given process"
msgstr "Modifie la courtoisie d'un processus donné"

#: processcore/actions.actions:355
msgctxt "Name"
msgid "Change IO Scheduler and priority"
msgstr "Modifie la priorité et l'ordonnancement des entrées / sorties"

#: processcore/actions.actions:420
msgctxt "Description"
msgid "Change how the read and writes of a given process are prioritized"
msgstr "Modifie la priorité des lectures et écritures d'un processus donné"

#: processcore/actions.actions:487
msgctxt "Name"
msgid "Change CPU Scheduler and priority"
msgstr "Modifie les priorités et l'ordonnancement du processeur"

#: processcore/actions.actions:552
msgctxt "Description"
msgid ""
"Change which CPU scheduler is to schedule the running of a given process"
msgstr ""
"Modifie quel ordonnanceur de processeur doit gérer l'exécution d'un "
"processus donné"

