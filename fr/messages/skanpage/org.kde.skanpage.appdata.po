msgid "Skanpage"
msgstr "SKanpage"

#. (itstool) path: component/summary
#: org.kde.skanpage.appdata.xml:15
msgid "Scan multi-page documents and images"
msgstr "Numériser des documents et des images sur plusieurs pages"

#. (itstool) path: description/p
#: org.kde.skanpage.appdata.xml:17
msgid ""
"Skanpage is a simple scanning application optimized for multi-page document "
"scanning. It can also scan and save single-page documents and images."
msgstr ""
"SKanpage est une application simple de numérisation conçue pour la "
"numérisation de documents composés de plusieurs pages et l'enregistrement de "
"documents et d'images sur une unique page."

#. (itstool) path: description/p
#: org.kde.skanpage.appdata.xml:18
msgid "Features:"
msgstr "Fonctionnalités :"

#. (itstool) path: ul/li
#: org.kde.skanpage.appdata.xml:20
msgid "Scanning from flatbed and ADF scanners"
msgstr ""
"Numérisation à partir de périphériques de numérisation à plat ou « ADF »."

#. (itstool) path: ul/li
#: org.kde.skanpage.appdata.xml:21
msgid "Configurable options for scanning device"
msgstr "Options configurables pour un périphérique de numérisation"

#. (itstool) path: ul/li
#: org.kde.skanpage.appdata.xml:22
msgid "Reordering, rotation, and deletion of scanned pages"
msgstr "Tri, rotation et suppression des pages numérisées."

#. (itstool) path: ul/li
#: org.kde.skanpage.appdata.xml:23
msgid "Saving to multi-page PDF documents and image files"
msgstr ""
"Enregistrement de documents « PDF » sur plusieurs pages et de fichiers "
"d'image."

