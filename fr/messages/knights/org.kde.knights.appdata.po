#. (itstool) path: component/name
#: org.kde.knights.appdata.xml:9
msgid "KNights"
msgstr "KNights"

#. (itstool) path: component/summary
#: org.kde.knights.appdata.xml:10
msgid "Chess game"
msgstr "Jeu d'échecs"

#. (itstool) path: description/p
#: org.kde.knights.appdata.xml:12
msgid ""
"KNights is a chess game. As a player, your goal is to defeat your opponent "
"by checkmating their king."
msgstr ""
"KNights est un jeu d'échecs. En tant que joueur, votre objectif est de "
"vaincre votre adversaire en mettant son roi échec et mat."

#. (itstool) path: description/p
#: org.kde.knights.appdata.xml:15
msgid "Features:"
msgstr "Fonctionnalités :"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:17
msgid "Local play between two players on the same computer"
msgstr "Jouez en local entre deux joueurs sur le même ordinateur"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:18
msgid "Play against any computer program that supports the XBoard protocol"
msgstr ""
"Jouez contre un programme informatique prenant en charge le protocole XBoard"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:19
msgid "Play on the Free Internet Chess Server (FICS)"
msgstr "Jouez sur le serveur « FICS » (Free Internet Chess Server)"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:20
msgid "Watching two computer engines play against each other"
msgstr "Regardez deux moteurs de jeu s'affronter"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:21
msgid "Support for legal move checking"
msgstr "Prise en charge de la vérification de la légalité des déplacements"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:22
msgid "Markers for possible moves, opponent’s last move and sources of check"
msgstr ""
"Marquage des déplacements possibles, dernier mouvement de l'adversaire et "
"sources d'échec"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:23
msgid "Board borders and site notations"
msgstr "Bordures du plateau et notations des sites"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:24
msgid "Complete time control, with Plasma-styled clocks"
msgstr "Contrôle du temps intégral, avec des horloges de style Plasma"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:25
msgid ""
"Several themes, with the possibility of downloading new ones from within the "
"program"
msgstr ""
"Plusieurs thèmes et la possibilité d'en télécharger de nouveaux au sein du "
"programme"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:26
msgid "Animated moves (configurable)"
msgstr "Déplacements animés (configurable)"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:27
msgid ""
"Views for playing on a chess server, including a seek graph, text console, "
"and chat widget"
msgstr ""
"Fonctionnalités pour jouer sur un serveur d'échecs, notamment un graphique "
"de recherche, une console texte et un composant graphique de discussion"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:28
msgid "Option to undo and redo moves"
msgstr "Options pour annuler et refaire des mouvements"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:29
msgid "Graphic interface for making and receiving offers from remote players"
msgstr ""
"Interface graphique pour envoyer et recevoir des offres avec des joueurs à "
"distance"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:30
msgid ""
"Support for the UCI protocol (used by Stockfish, Chessbase, and many others)"
msgstr ""
"Prise en charge du protocole « UCI » (utilisé par Stockfish, Chessbase et "
"bien d'autres)"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:31
msgid "Support for saving and loading Portable game notation (PGN) files"
msgstr ""
"Prise en charge de l'enregistrement et du chargement de fichiers "
"« PGN » (Notation portable de jeu)"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:32
msgid "Speak opponent’s moves"
msgstr "Exprimer vocalement les mouvements de l'adversaire"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:33
msgid "Ability to control the program via a D-Bus interface"
msgstr "Possibilité de contrôler le programme grâce à une interface D-Bus"

