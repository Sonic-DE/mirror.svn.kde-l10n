msgid "Changes:"
msgstr "Modifications :"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:135
msgid "Updated the application icon"
msgstr "Mise à jour de l'icône de l'application"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:136
msgid "Added support for parentheses keyboard input"
msgstr "Ajout de la prise en charge pour la saisie au clavier des parenthèses"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:137
msgid "Fixed the calculator drawer opening when the application opens"
msgstr ""
"Correction de l'ouverture du tiroir de la calculatrice à l'ouverture de "
"l'application"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:138
msgid ""
"Changed backspace icon to use a proper system icon instead of a font "
"provided one"
msgstr ""
"Modification de l'icône de retour en arrière pour utiliser une icône système "
"appropriée au lieu d’une icône fournie par une fonte"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:139
msgid "Added keyboard support to unit converter"
msgstr "Ajout de la prise en charge du clavier pour le convertisseur d'unités"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:140
msgid "Fixed page change animation for binary calculator"
msgstr ""
"Correction de l'animation de changement de page pour la calculatrice binaire"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:141
msgid "Enabled qml debugging when compiled in debug mode"
msgstr "Activation du débogage de QML lorsque compilé en mode débogage"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:142
msgid "Added ability to recognize the decimal separator in other locales"
msgstr ""
"Ajout de la capacité à reconnaître le séparateur décimal avec d'autres "
"paramètres régionaux"

