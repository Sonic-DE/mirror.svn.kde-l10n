#: org.kde.kalk.appdata.xml:112
msgid "Rearrange trigonometric functions to be together"
msgstr "Regroupement des fonctions trigonométriques ensemble"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:113
msgid "Various user-interface improvements"
msgstr "Diverses améliorations de l'interface utilisateur"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:120
msgid "Rework sidebar design"
msgstr "Travailler une nouvelle conception de la barre latérale"

