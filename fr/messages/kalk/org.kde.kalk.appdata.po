#: org.kde.kalk.appdata.xml:96
msgid "Fix bug preventing input of comma"
msgstr "Correction du bogue empêchant la saisie de la virgule"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:104
msgid "General bugfixing and code quality improvements"
msgstr "Correction générale de bogues et améliorations de la qualité du code"

