msgctxt "Description"
msgid "Adds a shortcut to minimize and restore all windows"
msgstr "Ajoute un raccourci pour minimiser et restaurer toutes les fenêtres"

#: src/plugins/mouseclick/metadata.json
msgctxt "Description"
msgid ""
"Creates an animation whenever a mouse button is clicked. This is useful for "
"screenrecordings/presentations. Activated with a keyboard shortcut"
msgstr ""
"Crée une animation associée à un clic avec le bouton de la souris. Ceci est "
"utile pour les enregistrements d'écran ou les présentations. Activé grâce à "
"un raccourci clavier."

#: src/plugins/mousemark/metadata.json
msgctxt "Description"
msgid ""
"Allows you to draw lines on the desktop; activated with a keyboard shortcut"
msgstr ""
"Vous permet de tracer des lignes sur le bureau. Activé grâce à un raccourci "
"clavier."

#: src/plugins/outputlocator/metadata.json
msgctxt "Description"
msgid "Show screen names"
msgstr "Afficher le nom des écrans"

#: src/plugins/overview/metadata.json
msgctxt "Description"
msgid ""
"Allows you to overview virtual desktops and windows; activated with a "
"keyboard shortcut"
msgstr ""
"Permet d'avoir un aperçu des bureaux virtuels et des fenêtres. Activé grâce "
"à un raccourci clavier."

#: src/plugins/scale/package/metadata.json
msgctxt "Description"
msgid "Make windows scale in and out when they are shown or hidden"
msgstr ""
"Faire un re-dimensionnement en avant ou en arrière des fenêtres lors de "
"leurs affichages ou de leurs masquages"

#: src/plugins/screenedge/metadata.json
msgctxt "Description"
msgid ""
"Highlights screen edges and corners that trigger actions when touched as the "
"cursor approaches them"
msgstr ""
"Mettre en valeur les bords des écrans et les coins actifs qui déclenchent "
"des actions lorsqu'ils sont touchés lorsque le pointeur s'approche d'eux"

#: src/plugins/screenshot/metadata.json
msgctxt "Description"
msgid "Helper effect for screenshot tools"
msgstr "Effet d'assistance pour les outils de copie d'écran"

#: src/plugins/sessionquit/package/metadata.json
msgctxt "Description"
msgid "Keep the desktop background alive during logout until the end"
msgstr ""
"Conserver l'arrière-plan du bureau actif jusqu'à la fin de la déconnexion"

#: src/plugins/sheet/metadata.json
msgctxt "Description"
msgid ""
"Make modal dialogs smoothly fly in and out when they are shown or hidden"
msgstr ""
"Fait voler progressivement en avant ou en arrière les boites de dialogue "
"modales lors de leurs affichages ou masquages"

#: src/plugins/showfps/metadata.json
msgctxt "Description"
msgid "Display KWin's performance in the corner of the screen"
msgstr "Afficher les performances de KWin dans le coin de l'écran"

#: src/plugins/showpaint/metadata.json
msgctxt "Description"
msgid ""
"Highlight areas of the desktop that have been recently updated; activated "
"with a keyboard shortcut"
msgstr ""
"Mettre en valeur les zones de bureau ayant été récemment mises à jour. "
"Activé grâce à un raccourci clavier."

#: src/plugins/slideback/metadata.json
msgctxt "Description"
msgid "Slide back windows when another window is raised"
msgstr ""
"Faire glisser les fenêtres vers l'arrière lors de l'apparition d'une autre "
"fenêtre"

#: src/plugins/slide/metadata.json
msgctxt "Description"
msgid "Slide between virtual desktops when switching"
msgstr ""
"Faire un effet de diaporama entre les bureaux virtuels lors d'un basculement"

#: src/plugins/slidingpopups/metadata.json
msgctxt "Description"
msgid "Slide Plasma popups in and out"
msgstr "Faire un effet de diaporama avant et arrière des menus contextuels"

#: src/plugins/squash/package/metadata.json
msgctxt "Description"
msgid "Squash windows when they are minimized"
msgstr "Déformer les fenêtres lors de leur minimisation"

#: src/plugins/startupfeedback/metadata.json
msgctxt "Description"
msgid "Helper effect for startup feedback"
msgstr "Effet d'assistance du témoin de démarrage "

#: src/plugins/synchronizeskipswitcher/package/metadata.json
msgctxt "Description"
msgid ""
"Hides all windows marked as Skip Taskbar to be also excluded from window "
"switchers (e.g. Alt+Tab)"
msgstr ""
"Masque toutes les fenêtres marquées « Ignorer la barre de tâches » pour être "
"également exclues des commutateurs de fenêtres (par ex. « ALT » + « Tab »)"

#: src/plugins/systembell/metadata.json
msgctxt "Description"
msgid "Provides the bell"
msgstr "Fournit la cloche"

#: src/plugins/thumbnailaside/metadata.json
msgctxt "Description"
msgid ""
"Display window thumbnails on the edge of the screen; activated with a "
"keyboard shortcut"
msgstr ""
"Afficher les vignettes de fenêtres sur le bord de l'écran. Activé grâce à un "
"raccourci clavier."

#: src/plugins/tileseditor/metadata.json
msgctxt "Description"
msgid "Editor for the tiling areas"
msgstr "Éditeur pour les zones de recouvrement"

#: src/plugins/trackmouse/metadata.json
msgctxt "Description"
msgid ""
"Display a mouse cursor locating effect; activated with a keyboard shortcut"
msgstr ""
"Afficher un effet indiquant la position du pointeur de la souris. Activé "
"grâce à un raccourci clavier."

#: src/plugins/translucency/package/metadata.json
msgctxt "Description"
msgid "Make windows translucent under different conditions"
msgstr "Rendre les fenêtres translucides sous différentes conditions"

#: src/plugins/videowall/package/metadata.json
msgctxt "Description"
msgid ""
"Spans fullscreen video player over all attached screens to create a Video "
"Wall"
msgstr ""
"Affiche le lecteur vidéo en plein écran sur tous les écrans connectés pour "
"créer un mur d'images"

#: src/plugins/windowaperture/package/metadata.json
msgctxt "Description"
msgid "Move windows into screen corners"
msgstr "Déplacer les fenêtres vers les coins de l'écran"

#: src/plugins/windowview/metadata.json
msgctxt "Description"
msgid "Zoom out until all opened windows can be displayed side-by-side"
msgstr ""
"Faire un zoom arrière jusqu'à ce que toutes les fenêtres ouvertes puissent "
"être affichées côte à côte"

#: src/plugins/wobblywindows/metadata.json
msgctxt "Description"
msgid "Deform windows while they are moving"
msgstr "Déformer les fenêtres pendant leur déplacement"

#: src/plugins/zoom/metadata.json
msgctxt "Description"
msgid "Magnify the entire desktop; activated with a keyboard shortcut"
msgstr "Agrandir l'ensemble du bureau. Activé grâce à un raccourci clavier."

#: src/tabbox/switchers/thumbnail_grid/metadata.json
msgctxt "Description"
msgid "A window switcher layout using a small grid of thumbnails"
msgstr ""
"Une disposition du sélecteur de fenêtres utilisant une petite grille de "
"vignettes."

