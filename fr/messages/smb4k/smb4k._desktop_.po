msgctxt "Name"
msgid "Synchronization failed"
msgstr "Échec de la synchronisation"

#: core/smb4k.notifyrc:1240
msgctxt "Comment"
msgid "The synchronization of a share and a local copy failed"
msgstr "La synchronisation d'un partage et d'une copie locale a échoué"

