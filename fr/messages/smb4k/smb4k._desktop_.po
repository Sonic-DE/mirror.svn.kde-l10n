msgctxt "Name"
msgid "Unmounting not allowed"
msgstr "Libération non autorisée"

#: core/smb4k.notifyrc:1158
msgctxt "Comment"
msgid "The unmounting of a certain share is not allowed"
msgstr "La libération d'un certain partage n'est pas autorisée"

