msgctxt "Name"
msgid "Cannot bookmark printer"
msgstr "Impossible d'ajouter l'imprimante aux signets"

#: core/smb4k.notifyrc:1403
msgctxt "Comment"
msgid "A printer cannot be bookmarked"
msgstr "Une imprimante n'a pas pu être ajoutée aux signets"

#: core/smb4k.notifyrc:1446
msgctxt "Name"
msgid "File not found"
msgstr "Fichier introuvable"

#: core/smb4k.notifyrc:1487
msgctxt "Comment"
msgid "A file could not be found"
msgstr "Impossible de trouver un fichier"

#: core/smb4k.notifyrc:1530
msgctxt "Name"
msgid "Opening file failed"
msgstr "Échec de l'ouverture d'un fichier"

#: core/smb4k.notifyrc:1568
msgctxt "Comment"
msgid "A file could not be opened"
msgstr "Impossible d'ouvrir un fichier"

#: core/smb4k.notifyrc:1611
msgctxt "Name"
msgid "Reading file failed"
msgstr "Échec de la lecture d'un fichier"

#: core/smb4k.notifyrc:1649
msgctxt "Comment"
msgid "A file could not be read"
msgstr "Impossible de lire un fichier"

#: core/smb4k.notifyrc:1692
msgctxt "Name"
msgid "mkdir failed"
msgstr "Échec de la commande mkdir"

#: core/smb4k.notifyrc:1731
msgctxt "Comment"
msgid "A directory could not be created"
msgstr "Impossible de créer un dossier"

#: core/smb4k.notifyrc:1774
msgctxt "Name"
msgid "Process error"
msgstr "Erreur du processus"

#: core/smb4k.notifyrc:1814
msgctxt "Comment"
msgid "A process error occurred"
msgstr "Une erreur du processus est survenue"

#: core/smb4k.notifyrc:1857
msgctxt "Name"
msgid "Action failed"
msgstr "Échec de l'action"

#: core/smb4k.notifyrc:1897
msgctxt "Comment"
msgid "A KAuth action failed"
msgstr "Une action KAuth a échoué"

#: core/smb4k.notifyrc:1939
msgctxt "Name"
msgid "Invalid URL"
msgstr "URL mal formée"

#: core/smb4k.notifyrc:1980
msgctxt "Comment"
msgid "An invalid URL was passed"
msgstr "Une URL mal formée a été transmise"

#: core/smb4k.notifyrc:2022
msgctxt "Name"
msgid "Network communication failed"
msgstr "Échec de la communication réseau"

#: core/smb4k.notifyrc:2057
msgctxt "Comment"
msgid "A network related action could not be performed or failed"
msgstr "Impossible d'effectuer une action réseau"

#: core/smb4k.notifyrc:2097
msgctxt "Name"
msgid "Zeroconf error"
msgstr "Erreur du démon « Zeroconf »."

#: core/smb4k.notifyrc:2130
msgctxt "Comment"
msgid "An error with the Zeroconf daemon occurred"
msgstr "Une erreur est survenue avec le démon « Zeroconf »."

#: core/smb4k.notifyrc:2167
msgctxt "Name"
msgid "Keychain error"
msgstr "Erreur « Trousseau »"

#: core/smb4k.notifyrc:2196
msgctxt "Comment"
msgid ""
"An error occurred while reading the login credentials from the secure storage"
msgstr ""
"Une erreur est survenue lors de la lecture des identifiants de connexion à "
"partir d'un média sécurisé."

#: helpers/smb4kmounthelper.actions:2
msgctxt "Name"
msgid "Mount action"
msgstr "Action de montage"

#: helpers/smb4kmounthelper.actions:39
msgctxt "Description"
msgid "Mounts a share"
msgstr "Monte un partage"

#: helpers/smb4kmounthelper.actions:80
msgctxt "Name"
msgid "Unmount action"
msgstr "Action de libération"

#: helpers/smb4kmounthelper.actions:117
msgctxt "Description"
msgid "Unmounts a share"
msgstr "Libère un partage"

