msgid "Allow the user to choose the keyboard layout."
msgstr "Permettre à l'utilisateur de définir la disposition de clavier."

#: modules/language/metadata.json
msgctxt "Description"
msgid "Allow the user to set the system language."
msgstr "Permettre à l'utilisateur de définir la langue du système."

#: modules/prepare/metadata.json
msgctxt "Description"
msgid "Allows the user to configure the environment before using it."
msgstr ""
"Permettre à l'utilisateur de configurer l'environnement avant de l'utiliser."

#: modules/time/metadata.json
msgctxt "Description"
msgid "Allow the user to set the timezone."
msgstr "Permettre à l'utilisateur de définir le fuseau horaire."

#: modules/wifi/metadata.json
msgctxt "Description"
msgid "Allow the user to connect to a Wi-Fi network."
msgstr "Permettre à l'utilisateur de se connecter à un réseau Wi-Fi."

