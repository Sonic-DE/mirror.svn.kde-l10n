#: files/plasma-setup.desktop.in:9 src/auth/org.kde.plasmasetup.actions:8
msgctxt "Name"
msgid "Plasma Setup"
msgstr "Configuration de Plasma"

#: files/plasma-setup.desktop.in:39
msgctxt "Comment"
msgid "Run the initial system setup for KDE"
msgstr "Exécuter la configuration initiale du système pour KDE"

#: src/auth/org.kde.plasmasetup.actions:42
msgctxt "Name"
msgid "Create User"
msgstr "Créer un utilisateur"

#: src/auth/org.kde.plasmasetup.actions:71
msgctxt "Description"
msgid "Create the initial user account"
msgstr "Créer le compte utilisateur initial"

#: src/auth/org.kde.plasmasetup.actions:103
msgctxt "Name"
msgid "Create Completion Flag File"
msgstr "Créer un fichier d'indicateurs d'achèvement"

#: src/auth/org.kde.plasmasetup.actions:131
msgctxt "Description"
msgid "Write the /etc/plasma-setup-done marker to prevent rerunning setup"
msgstr ""
"Écrivez le marqueur « /etc/plasma-setup-done » pour éviter une nouvelle "
"application de la configuration"

#: src/auth/org.kde.plasmasetup.actions:162
msgctxt "Name"
msgid "Create New User Autostart Hook"
msgstr ""
"Créer un nouveau script final pour démarrage de démarrage automatique de "
"l'utilisateur"

#: src/auth/org.kde.plasmasetup.actions:191
msgctxt "Description"
msgid "Create an autostart hook for the newly created user"
msgstr ""
"Créer un script final pour démarrage automatique de l'utilisateur "
"nouvellement créé"

#: src/auth/org.kde.plasmasetup.actions:223
msgctxt "Name"
msgid "Remove Autologin"
msgstr "Supprimer la connexion automatique"

#: src/auth/org.kde.plasmasetup.actions:252
msgctxt "Description"
msgid "Remove Display Manager autologin configuration"
msgstr ""
"Supprimer la configuration de connexion automatique du gestionnaire "
"d'affichage"

#: src/auth/org.kde.plasmasetup.actions:282
msgctxt "Name"
msgid "Set New User Global Theme"
msgstr "Définir un nouveau thème global d'utilisateur"

#: src/auth/org.kde.plasmasetup.actions:311
msgctxt "Description"
msgid "Set the global theme for the new user"
msgstr "Définir le thème global pour le nouvel utilisateur"

#: src/auth/org.kde.plasmasetup.actions:343
msgctxt "Name"
msgid "Set New User Display Scaling"
msgstr "Définir le dimensionnement pour le nouvel utilisateur"

#: src/auth/org.kde.plasmasetup.actions:372
msgctxt "Description"
msgid "Set display scaling for the new user"
msgstr "Définir le dimensionnement de l'écran pour le nouvel utilisateur"

#: src/auth/org.kde.plasmasetup.actions:404
msgctxt "Name"
msgid "Set New User Home Directory Ownership"
msgstr "Définir la propriété du dossier personnel du nouvel utilisateur"

#: src/auth/org.kde.plasmasetup.actions:433
msgctxt "Description"
msgid "Set ownership of the new users home directory to the newly created user"
msgstr ""
"Définissez la propriété du dossier personnel des nouveaux utilisateurs sur "
"l'utilisateur nouvellement créé"

#: src/auth/org.kde.plasmasetup.actions:465
msgctxt "Name"
msgid "Set New User Temporary Autologin"
msgstr "Définir la connexion automatique temporaire du nouvel utilisateur"

#: src/auth/org.kde.plasmasetup.actions:494
msgctxt "Description"
msgid ""
"Set display manager temporary autologin configuration for the newly created "
"user"
msgstr ""
"Définir une configuration temporaire de connexion automatique pour le "
"gestionnaire d'affichage pour l'utilisateur nouvellement créé"

#~ msgctxt "Name"
#~ msgid "Disable Systemd Unit"
#~ msgstr "Désactiver le module « systemd »"

#~ msgctxt "Description"
#~ msgid "Disable the systemd unit for Plasma Setup"
#~ msgstr "Désactiver le module « systemd » pour la configuration de Plasma"

#~ msgctxt "Name"
#~ msgid "KDE Initial System Setup"
#~ msgstr "Configuration initiale du système de KDE"
