#. (itstool) path: component/name
#: org.kde.kdiff3.appdata.xml:13
msgid "KDiff3"
msgstr "KDiff3"

#. (itstool) path: component/summary
#: org.kde.kdiff3.appdata.xml:14
msgid "A file and folder comparison and merge tool"
msgstr "Un outil de comparaison et de fusion de fichiers et de dossiers"

#. (itstool) path: description/p
#: org.kde.kdiff3.appdata.xml:17
msgid "KDiff3 is a file and folder diff and merge tool which"
msgstr ""
"KDiff3 est un outil de comparaison et de fusion de fichiers et de dossiers "
"qui"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:19
msgid "compares and merges two or three text input files or folders,"
msgstr "compare et fusionne deux ou trois fichiers ou dossiers en entrée,"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:20
msgid "shows the differences line by line and character by character(!),"
msgstr ""
"affiche les différences ligne par ligne et caractère par caractère (!),"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:21
msgid "provides an automatic merge-facility,"
msgstr "offre des fonctionnalités de fusion automatique,"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:22
msgid "has an editor for comfortable solving of merge-conflicts,"
msgstr ""
"dispose d'un éditeur pour résoudre confortablement les conflits lors de la "
"fusion,"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:23
msgid "provides network transparency via KIO,"
msgstr "fournit une transparence réseau via KIO,"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:24
msgid "has options to highlight or hide changes in white-space or comments,"
msgstr ""
"dispose d'options permettant de surligner ou de cacher les différences "
"d'espaces ou de commentaires,"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:25
msgid "supports Unicode, UTF-8 and other file encodings,"
msgstr "prend en charge Unicode, UTF-8 et d'autres encodages de fichiers,"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:26
msgid "prints differences,"
msgstr "affiche les différences,"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:27
msgid "supports version control keyword and history merging."
msgstr ""
"prend en charge les mots clés de contrôle de version et la fusion des "
"historiques."
