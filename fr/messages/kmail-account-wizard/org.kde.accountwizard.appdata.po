#. (itstool) path: component/name
#: org.kde.accountwizard.appdata.xml:9
msgid "Account Wizard"
msgstr "Assistant de comptes"

#. (itstool) path: component/summary
#: org.kde.accountwizard.appdata.xml:10
msgid "Configure accounts"
msgstr "Configurer les comptes"

#. (itstool) path: description/p
#: org.kde.accountwizard.appdata.xml:12
msgid ""
"Accountwizard allows to edit, create, delete accounts. Accountwizard "
"supports IMAP/POP3/Kolab account type. Account information can be found by "
"using ispd service."
msgstr ""
"L'assistant de comptes vous permet de modifier, créer, supprimer des "
"comptes. Il prend en charge le type de compte IMAP / POP3 / Kolab. Les "
"informations de compte peuvent être trouvées en utilisant le service "
"« ispd »."
