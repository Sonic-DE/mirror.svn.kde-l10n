#: kcm_sddm.actions:2
msgctxt "Name"
msgid "SDDM"
msgstr "sddm"

#: kcm_sddm.actions:58
msgctxt "Name"
msgid "Save Settings"
msgstr "Enregistrer les paramètres"

#: kcm_sddm.actions:109
msgctxt "Description"
msgid "Save Settings in SDDM"
msgstr "Enregistrer une configuration dans « sddm »"

#: kcm_sddm.actions:163
msgctxt "Name"
msgid "Install an SDDM theme"
msgstr "Installer un thème « sddm »"

#: kcm_sddm.actions:213
msgctxt "Description"
msgid "Extract a zip file containing an SDDM theme to the SDDM theme location"
msgstr ""
"Extraire un thème « sddm » contenu dans un fichier « zip » vers "
"l'emplacement des thèmes « sddm »"

#: kcm_sddm.actions:254
msgctxt "Name"
msgid "Uninstall an SDDM theme"
msgstr "Désinstaller un thème « sddm »"

#: kcm_sddm.actions:304
msgctxt "Description"
msgid "Remove a previously installed SDDM theme"
msgstr "Supprimer un thème « sddm » précédemment installé"

#: kcm_sddm.actions:345
msgctxt "Name"
msgid "Synchronize Settings"
msgstr "Synchroniser les paramètres"

#: kcm_sddm.actions:391
msgctxt "Description"
msgid "Synchronize user settings with SDDM settings"
msgstr "Synchroniser la configuration utilisateur avec les paramètres « sddm »"

#: kcm_sddm.actions:432
msgctxt "Name"
msgid "Reset Settings"
msgstr "Réinitialiser les paramètres"

#: kcm_sddm.actions:478
msgctxt "Description"
msgid "Reset SDDM settings to factory default state"
msgstr "Réinitialiser la configuration « sddm » à sa configuration par défaut"

