#. (itstool) path: screenshot/caption
#: org.kde.kclock.appdata.xml:45
msgid "Timer page"
msgstr "Page de chronomètre"

#. (itstool) path: screenshot/caption
#: org.kde.kclock.appdata.xml:49
msgid "Stopwatch page"
msgstr "Page de minuteur"

#. (itstool) path: screenshot/caption
#: org.kde.kclock.appdata.xml:53
msgid "Alarms page"
msgstr "Page d'alarmes"

#. (itstool) path: description/p
#: org.kde.kclock.appdata.xml:111
msgid "New features and bugfixes in this release:"
msgstr ""
"Nouvelles fonctionnalités et corrections de bogues dans cette version :"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:113
msgid "Fixed timer add one minute button."
msgstr "Correction du bouton permettant d'ajouter une minute au minuteur fixe."

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:114
msgid "Switched to tab bar based sidebar (similar to bottom navigation bar)."
msgstr ""
"Basculement vers une barre latérale avec des onglets (Similaire à la barre "
"inférieure de navigation)."

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:131
msgid "Support for background daemon when using flatpak"
msgstr ""
"Prise en charge du démon en arrière-plan lors de l'utilisation de FlatPak"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:132
msgid "Fix excessive log generation on non-Plasma system"
msgstr ""
"Correction de la génération excessive de journaux sur les systèmes non-Plasma"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:140
msgid "Fix \"Clock daemon not found\" popup message"
msgstr ""
"Correction du message contextuel « Impossible de trouver le démon de "
"l’horloge »"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:141
msgid "Various bugfixes and user interface improvements"
msgstr "Divers correctifs et améliorations de l'interface utilisateur"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:142
msgid "Add a sound picker component for listing alarm sounds"
msgstr "Ajouter un composant de sélection de son pour lister les sons d'alarme"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:143
msgid "Start snooze only after button is pressed"
msgstr "Démarrer la répétition uniquement après avoir appuyé sur le bouton"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:144
msgid "Fix alarms not working on PinePhone"
msgstr "Correction des alarmes ne fonctionnant pas sur le PinePhone"

#. (itstool) path: description/p
#: org.kde.kclock.appdata.xml:150 org.kde.kclock.appdata.xml:167
msgid "Changes:"
msgstr "Modifications :"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:152
msgid "Kirigami's bottom navigation bar component is now used for mobile"
msgstr ""
"Le composant de barre inférieure de navigation de Kirigami est maintenant "
"utilisé pour les périphériques mobiles"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:153
msgid "A Plasma style sidebar is now used on desktop"
msgstr ""
"Une barre latérale de style pour Plasma est maintenant utilisée sur le "
"bureau."

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:154
msgid "The system tray item now only shows when alarms are pending"
msgstr ""
"L’icône de la boîte à miniatures ne s’affiche maintenant que lorsque des "
"alarmes sont en attente"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:155
msgid "The daemon automatically stops if no alarms and timers are pending"
msgstr ""
"Le démon s'arrête automatiquement s'il n'y a aucune alarme ou minuteur en "
"attente"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:156
msgid "Action bars are now used on the timer and alarms forms page"
msgstr ""
"Les barres d’action sont désormais utilisées sur la page des formulaires de "
"minuteurs et d’alarmes"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:157
msgid "The settings button has been moved to the top actions bar"
msgstr ""
"Le bouton de configuration a été déplacé vers la barre supérieure d'actions"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:169
msgid ""
"Watch DBus for PowerDevil, so wake from suspend always works if PowerDevil "
"is found"
msgstr ""
"Surveiller DBus pour PowerDevil, afin que le réveil depuis la suspension "
"fonctionne toujours si PowerDevil est présent"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:170
msgid "Use consistent dialog style on the settings page"
msgstr "Utilisez un style de dialogue cohérent sur la page de configuration"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:171
msgid "After editing an alarm, the alarm now automatically is activated"
msgstr ""
"Après avoir modifié une alarme, celle-ci s'active désormais automatiquement"

#. (itstool) path: description/p
#: org.kde.kclock.appdata.xml:178
msgid "New features and bugfixes:"
msgstr "Nouvelles fonctionnalités et corrections de bogues :"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:180
msgid "Added the ability to set timer presets"
msgstr "Ajout de la possibilité de définir des préréglages de minuteurs"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:181
msgid "Added ability to increase timer duration by 1m as timer is running"
msgstr ""
"Ajout de la possibilité d'augmenter la durée du minuteur de 1 minute pendant "
"que celui-ci est actif"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:182
msgid ""
"Fixed multiple alarm sounds and notifications being played for one alarm"
msgstr ""
"Correction de la lecture de plusieurs sons d'alarme et notifications pour "
"une seule alarme"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:183
msgid "Fixed errors that prevented the application from working in a Flatpak"
msgstr ""
"Correction des erreurs empêchant l'application de fonctionner dans un FlatPak"

