#: desktop/org.kde.spectacle.desktop.cmake:611
msgctxt "Name"
msgid "Launch without taking a screenshot"
msgstr "Lancer sans réalisation de copie d'écran"

#: desktop/spectacle.notifyrc:57
msgctxt "Comment"
msgid "Screenshot Capture Utility"
msgstr "Utilitaire de capture d'écran"

#: desktop/spectacle.notifyrc:113
msgctxt "Name"
msgid "New Screenshot Saved"
msgstr "Nouvelle capture d'écran enregistrée"

#: desktop/spectacle.notifyrc:167
msgctxt "Comment"
msgid "A new screenshot was captured and saved"
msgstr "Une nouvelle photo d'écran a été capturée et enregistrée"

#: desktop/spectacle.notifyrc:224
msgctxt "Name"
msgid "Recording Saved"
msgstr "Capture enregistrée"

#: desktop/spectacle.notifyrc:270
