msgid "A recording was captured and saved"
msgstr "Une capture a été réalisée et enregistrée"

#: desktop/spectacle.notifyrc:319
msgctxt "Name"
msgid "Text Extracted"
msgstr "Texte extrait"

#: desktop/spectacle.notifyrc:351
msgctxt "Comment"
msgid "Text has been extracted from image using OCR"
msgstr ""
"Le texte a été extrait de l'image à l'aide d'un logiciel de reconnaissance "
"optique de caractères"

