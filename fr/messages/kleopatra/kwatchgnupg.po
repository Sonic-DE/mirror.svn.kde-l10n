msgid "&History size:"
msgstr "Taille de l'&historique :"

#: kwatchgnupgconfig.cpp:61
#, kde-format
msgctxt "@action:button"
msgid "Set &Unlimited"
msgstr "Ne définir a&ucune limite"

#: kwatchgnupgmainwin.cpp:69
#, kde-format
msgid "[%1] Log cleared"
msgstr "[%1] Journal effacé"

#: kwatchgnupgmainwin.cpp:76
#, kde-format
msgid "C&lear History"
msgstr "Effacer &l'historique"

#: kwatchgnupgmainwin.cpp:105
#, kde-format
msgid "[%1] Log stopped"
msgstr "[%1] Journal arrêté"

#: kwatchgnupgmainwin.cpp:110
#, kde-format
msgid ""
"The watchgnupg logging program could not be found.\n"
"Please make sure that watchgnupg is installed."
msgstr ""
"Le programme de journalisation « Watchgnupg » est introuvable. \n"
"Veuillez vous assurer que ce dernier est bien installé."

#: kwatchgnupgmainwin.cpp:111 kwatchgnupgmainwin.cpp:121
#, kde-format
msgid "[%1] Failed to start %2"
msgstr "[%1] Le démarrage de %2 a échoué"

#: kwatchgnupgmainwin.cpp:120
#, kde-format
msgid ""
"The watchgnupg logging process could not be started.\n"
"Please make sure that watchgnupg is installed properly."
msgstr ""
"Il a été impossible de démarrer le programme de journalisation "
"« Watchgnupg ». \n"
"Veuillez vous assurer que ce dernier est installé correctement."

#: kwatchgnupgmainwin.cpp:125
#, kde-format
msgid "[%1] Log started"
msgstr "[%1] Journal démarré"

#: kwatchgnupgmainwin.cpp:134
#, kde-format
msgid ""
"The watchgnupg logging process died.\n"
"Do you want to try to restart it?"
msgstr ""
"Le processus de journalisation « watchgnupg » s'est arrêté.\n"
"Voulez-vous essayer de le redémarrer ?"

#: kwatchgnupgmainwin.cpp:136
#, kde-format
msgctxt "@action:button"
msgid "Try Restart"
msgstr "Essayer de redémarrer"

#: kwatchgnupgmainwin.cpp:137
#, kde-format
msgctxt "@action:button"
msgid "Do Not Try"
msgstr "Ne pas essayer"

#: kwatchgnupgmainwin.cpp:139
#, kde-format
msgid "====== Restarting logging process ====="
msgstr "====== Redémarrage du processus de journalisation en cours ====="

#: kwatchgnupgmainwin.cpp:143
#, kde-format
msgid ""
"The watchgnupg logging process is not running.\n"
"This log window is unable to display any useful information."
msgstr ""
"Le processus de journalisation « watchgnupg » n'est pas en cours "
"d'exécution.\n"
"Cette fenêtre des journaux ne peut afficher aucune information utile."

#: kwatchgnupgmainwin.cpp:167
#, kde-format
msgid "Save Log to File"
msgstr "Enregistrer le journal dans un fichier"

#: kwatchgnupgmainwin.cpp:175
#, kde-format
msgid "Could not save file %1: %2"
msgstr "Impossible d'enregistrer le fichier %1 : %2"

