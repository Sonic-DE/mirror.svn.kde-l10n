#, kde-format
msgid "Log Window"
msgstr "Fenêtre des journaux"

#: kwatchgnupgconfig.cpp:55
#, kde-format
msgctxt "history size spinbox suffix"
msgid "%v line"
msgid_plural "%v lines"
msgstr[0] "ligne %v"
msgstr[1] "%v lignes"

#: kwatchgnupgconfig.cpp:56
#, kde-format
msgid "unlimited"
msgstr "illimité"

#: kwatchgnupgconfig.cpp:57
#, kde-format
