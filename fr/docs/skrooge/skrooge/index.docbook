            <imageobject>
                <imagedata fileref="settings_search.png" format="PNG"/>
            </imageobject>
            </mediaobject>
        </screenshot>
        <para
>Une seule option ici pour choisir la fréquence de l'alarme.</para>
        </sect1
>     
        
        <sect1 id="settings_report">
        <title
>Rapports</title>
        
        <screenshot>
            <mediaobject>
