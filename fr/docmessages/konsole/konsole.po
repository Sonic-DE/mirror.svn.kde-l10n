"<shortcut><keycombo action=\"simul\">&Ctrl;&Maj;<keycap>Q</keycap></"
"keycombo></shortcut> <guimenu>Fichier</guimenu><guimenuitem>Quitter</"
"guimenuitem>"

#. Tag: action
#: index.docbook:579
#, no-c-format
msgid "Saves the current scrollback as a text or html file"
msgstr "Enregistre l'historique actuel dans un fichier texte ou HTML."

#. Tag: menuchoice
#: index.docbook:584
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;&Shift;<keycap>P</keycap></"
"keycombo></shortcut> <guimenu>File</guimenu> <guimenuitem>Print Screen ...</"
"guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;&Maj;<keycap>P</keycap></"
"keycombo></shortcut> <guimenu>Fichier</guimenu><guimenuitem>Faire une copie "
"d'écran…</guimenuitem>"

#. Tag: para
#: index.docbook:588
#, no-c-format
msgid ""
"<action>Print the current screen.</action> By default the output is scaled "
"to fit the size of the paper being printed on with black text color and no "
"background. In the print dialog these options can be changed on the "
"<guilabel>Output Options</guilabel> tab."
msgstr ""
"<action>Imprime l'écran actuel.</action> Par défaut, le format de sortie est "
"ajusté aux dimensions du papier utilisé avec des caractères noirs et sans "
"arrière-plan. Ces options sont modifiables depuis l'onglet <guilabel>Options "
"de sortie</guilabel>."

#. Tag: menuchoice
#: index.docbook:594
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Open File Manager</guimenuitem>"
msgstr ""
"<guimenu>Fichier</guimenu> <guimenuitem>Ouvrir le gestionnaire de fichiers</"
"guimenuitem>"

#. Tag: para
#: index.docbook:597
#, no-c-format
msgid ""
"<action>Opens &kde;'s file manager at the current directory</action>. By "
"default, that is <ulink url=\"help:/dolphin/index.html\">&dolphin;</ulink>."
msgstr ""
"<action>Ouvre le gestionnaire de fichiers de &kde; dans le dossier actuel</"
"action>. Par défaut, il s'agit de <ulink url=\"help:/dolphin/index.html"
"\">&dolphin;</ulink>."

#. Tag: menuchoice
#: index.docbook:604
#, fuzzy, no-c-format
#| msgid ""
#| "<shortcut><keycombo action=\"simul\">&Ctrl;&Shift;<keycap>W</keycap></"
#| "keycombo></shortcut> <guimenu>File</guimenu> <guimenuitem>Close Tab</"
