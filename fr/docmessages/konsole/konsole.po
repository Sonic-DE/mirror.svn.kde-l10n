"guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;&Maj;<keycap>N</keycap></"
"keycombo></shortcut> <guimenu>Fichier</guimenu><guimenuitem>Nouvelle "
"fenêtre</guimenuitem>"

#. Tag: action
#: index.docbook:548
#, no-c-format
msgid "Opens a new separate &konsole; window with the default profile"
msgstr "Ouvre une nouvelle fenêtre &konsole; utilisant le profil par défaut."

#. Tag: menuchoice
#: index.docbook:552
#, no-c-format
