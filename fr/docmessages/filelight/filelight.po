"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>+</keycap></keycombo> </"
"shortcut> <guimenu>Affichage</guimenu> <guimenuitem>Zoom avant</guimenuitem>"

#. Tag: action
#: index.docbook:231
#, no-c-format
msgid "Increase the view of the filemap."
msgstr "Agrandit la vue de la cartographie des fichiers."

#. Tag: menuchoice
#: index.docbook:236
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>-</keycap></keycombo> </"
"shortcut> <guimenu>View</guimenu> <guimenuitem>Zoom Out</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>-</keycap></keycombo> </"
"shortcut> <guimenu>Affichage</guimenu> <guimenuitem>Zoom arrière</"
"guimenuitem>"

#. Tag: action
#: index.docbook:243
#, no-c-format
msgid "Decrease the view of the filemap."
msgstr "Réduit la vue de la cartographie des fichiers."

#. Tag: title
#: index.docbook:249
#, no-c-format
msgid "The Go Menu"
msgstr "Le menu <quote>Aller</quote>"

#. Tag: menuchoice
#: index.docbook:251
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt;<keycap>Up</keycap></keycombo> </"
"shortcut> <guimenu>Go</guimenu> <guimenuitem>Up</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt;<keycap>Haut</keycap></keycombo> "
"</shortcut> <guimenu>Aller</guimenu> <guimenuitem>Haut</guimenuitem>"

#. Tag: action
#: index.docbook:258
#, no-c-format
msgid "Moves you up one step in the filesystem to the parent folder."
msgstr ""
"Remonte d'un niveau dans le système de fichiers vers le dossier parent."

#. Tag: menuchoice
#: index.docbook:262
#, no-c-format
msgid "<guimenu>Go</guimenu> <guimenuitem>Back</guimenuitem>"
msgstr "<guimenu>Aller</guimenu> <guimenuitem>Précédent</guimenuitem>"

#. Tag: action
