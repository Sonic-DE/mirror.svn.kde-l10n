"   <command>kdiff3</command> <replaceable>dos1 dos2 dos3</replaceable>\n"
"   <command>kdiff3</command> <replaceable>dos1 dos2 dos3</replaceable> -o "
"<replaceable>dossier-de-destination</replaceable>"

# Tag: para
