msgstr ""
"\"Modèle\"/\"Anti-modèle\" : Inclure/exclure les éléments qui correspondent"

#. Tag: guilabel
#: index.docbook:1458
#, fuzzy, no-c-format
msgid "Exclude Hidden Files"
msgstr "\"Exclure les fichiers cachés\""

#. Tag: para
#: index.docbook:1459
#, no-c-format
msgid ""
"<link linkend=\"selectingvisiblefiles\">Show options</link> (<guilabel>Show "
"Identical/Different Files</guilabel>, <guilabel>Files only in A/B/C</"
"guilabel>)"
msgstr ""

#. Tag: para
#: index.docbook:1461
#, no-c-format
msgid ""
"If you change the settings in order to list more files, you must do a rescan "
