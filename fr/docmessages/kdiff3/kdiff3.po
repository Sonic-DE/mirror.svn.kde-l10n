msgstr ""
"Les données traversent tous les préprocesseurs internes et externes dans "
"l'ordre suivant :"

# Tag: para
#. Tag: para
#: index.docbook:1113
#, no-c-format
msgid "Normal preprocessor,"
msgstr "Préprocesseur normal,"

#. Tag: para
#: index.docbook:1114
#, no-c-format
msgid "Line-matching preprocessor,"
msgstr "Préprocesseur de traitement de ligne,"

# Tag: para
#. Tag: para
#: index.docbook:1115
#, fuzzy, no-c-format
