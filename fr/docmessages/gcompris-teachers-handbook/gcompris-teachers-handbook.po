#. Tag: para
#: index.docbook:59
#, no-c-format
msgid ""
"GCompris is a multi-activity educational software. This documentation is for "
"the gcompris-teachers administration tool we provide."
msgstr ""
"&gcompris; est un jeu éducatif multi-activités. Cette documentation décrit "
"le logiciel d'administration gcompris-teachers que l'équipe fournit."

#. Tag: keyword
#: index.docbook:65
#, no-c-format
msgid "<keyword>KDE</keyword>"
msgstr "<keyword>KDE</keyword>"

#. Tag: keyword
#: index.docbook:66
