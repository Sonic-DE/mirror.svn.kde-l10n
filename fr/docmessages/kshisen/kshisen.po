#. Tag: title
#: index.docbook:205
#, no-c-format
msgid "The Game Menu"
msgstr "Le menu « Jeu »"

#. Tag: para
#: index.docbook:207
#, no-c-format
msgid ""
"The <guimenu>Game</guimenu> menu lets you control the status of the current "
"game:"
msgstr ""
"Le menu <guimenu>Jeu</guimenu> vous permet de contrôler l'état de la partie "
"courante, à savoir :"

#. Tag: menuchoice
#: index.docbook:214
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>N</keycap></keycombo></"
"shortcut> <guimenu>Game</guimenu><guimenuitem>New</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl; <keycap>N</keycap></keycombo></"
"shortcut> <guimenu>Jeu</guimenu><guimenuitem>Nouveau</guimenuitem>"

#. Tag: para
#: index.docbook:219
#, no-c-format
msgid ""
"<action>Finishes the current game</action> and starts a new session with new "
"tiles."
msgstr ""
"<action>Termine le jeu en cours</action>, crée et commence un nouveau jeu "
"avec de nouvelles tuiles."

#. Tag: menuchoice
#: index.docbook:224
#, no-c-format
msgid ""
"<shortcut><keycombo><keycap>F5</keycap></keycombo></shortcut> <guimenu>Game</"
"guimenu><guimenuitem>Restart Game</guimenuitem>"
msgstr ""
"<shortcut><keycombo><keycap>F5</keycap></keycombo></shortcut> <guimenu>Jeu</"
"guimenu><guimenuitem>Recommencer la partie</guimenuitem>"

#. Tag: action
#: index.docbook:229
#, no-c-format
msgid "Restarts the current game with the same tiles."
msgstr "Recommence le jeu en cours avec les mêmes tuiles."

#. Tag: menuchoice
#: index.docbook:234
#, no-c-format
msgid ""
"<shortcut><keycombo><keycap>P</keycap></keycombo></shortcut> <guimenu>Game</"
"guimenu><guimenuitem>Pause</guimenuitem>"
msgstr ""
"<shortcut><keycombo><keycap>P</keycap></keycombo></shortcut> <guimenu>Jeu</"
"guimenu> <guimenuitem>Pause</guimenuitem>"

#. Tag: para
#: index.docbook:239
#, no-c-format
msgid ""
"<action>Pauses the game</action>, especially the timer which affects the "
"scoring. The menu entry is also used for resuming the game."
msgstr ""
"<action>Met l'ensemble du jeu en pause</action>, spécialement le "
"chronomètre, qui sert pour les meilleurs scores. Cette entrée est aussi "
"utilisée pour résumer une partie."

#. Tag: menuchoice
#: index.docbook:244
#, no-c-format
msgid ""
