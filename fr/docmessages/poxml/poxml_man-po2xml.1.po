#. Tag: refpurpose
#: man-po2xml.1.docbook:20
#, no-c-format
msgid "Translates an DocBook XML file using a PO file"
msgstr "Traduit un fichier XML DocBook en utilisant un fichier PO."

#. Tag: cmdsynopsis
#: man-po2xml.1.docbook:24
#, no-c-format
msgid ""
"<command>po2xml</command> <group><option><replaceable>original-XML</"
"replaceable> <replaceable>translated-PO</replaceable></option></group>"
msgstr ""
"<command>po2xml</command> <group><option><replaceable>XML-original</"
"replaceable> <replaceable>PO-traduit</replaceable></option></group>"

#. Tag: title
#: man-po2xml.1.docbook:33
#, no-c-format
msgid "Description"
msgstr "Description"

#. Tag: para
#: man-po2xml.1.docbook:35
#, no-c-format
msgid ""
"<command>po2xml</command> is a command-line tool that translates the DocBook "
"XML file <replaceable>original-XML</replaceable> using the gettext message "
"file <replaceable>translated-PO</replaceable>. The resulting translated XML "
"file is sent to standard output."
msgstr ""
"<command>po2xml</command> est un outil en ligne de commande traduisant le "
"fichier XML DocBook <replaceable>XML-original</replaceable> en utilisant le "
"fichier de message Gettext <replaceable>PO-Traduit</replaceable>. Le fichier "
"« XML » traduit qui en résulte est envoyé vers la sortie standard."

#. Tag: para
#: man-po2xml.1.docbook:40
#, no-c-format
msgid "This utility is part of the KDE Software Development Kit."
msgstr "Cet utilitaire est un élément du kit de développement logiciel de KDE."

