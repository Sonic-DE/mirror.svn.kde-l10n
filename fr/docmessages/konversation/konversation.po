"<guilabel>Konsole</guilabel> que vous le souhaitez."

#. Tag: menuchoice
#: index.docbook:3131
#, no-c-format
msgid ""
"<shortcut> <keycap>F5</keycap> </shortcut> <guimenu>Window</guimenu> "
"<guimenuitem>Channel List for</guimenuitem>"
msgstr ""
"<shortcut> <keycap>F5</keycap> </shortcut> <guimenu>Fenêtre</guimenu> "
"<guimenuitem>Liste des canaux pour</guimenuitem>"

#. Tag: action
#: index.docbook:3139
#, no-c-format
msgid ""
"Displays a <link linkend=\"list-channels\">list of channels</link> available "
"on the server."
msgstr ""
"Ouvre une <link linkend=\"list-channels\">liste des canaux</link> "
"disponibles sur le serveur."

#. Tag: menuchoice
#: index.docbook:3143
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>O</keycap></keycombo> </"
