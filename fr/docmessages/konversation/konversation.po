msgstr ""
"Ferme l'écran actuel. Si c'est un canal, il est aussi quitté. Si vous fermez "
"un onglet <interface>Messages Serveurs</interface>, tous les canaux ouverts "
"sur ce serveur sont fermés ainsi que la connexion avec le serveur."

#. Tag: menuchoice
#: index.docbook:3069
#, no-c-format
msgid ""
"<shortcut> <keycap>F11</keycap> </shortcut> <guimenu>Window</guimenu> "
"<guimenuitem>Close All Open Queries</guimenuitem>"
msgstr ""
"<shortcut> <keycap>F11</keycap> </shortcut> <guimenu>Fenêtre</guimenu> "
"<guimenuitem>Fermer toutes les conversations ouvertes</guimenuitem>"

#. Tag: action
#: index.docbook:3077
