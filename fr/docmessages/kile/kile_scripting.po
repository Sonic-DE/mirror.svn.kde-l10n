msgstr "void document.insertLabel();"

#. Tag: para
#: scripting.docbook:1147
#, no-c-format
msgid "Insert a <userinput>\\label</userinput> command."
msgstr "Insérez une commande <userinput>\\label</userinput>."

#. Tag: synopsis
