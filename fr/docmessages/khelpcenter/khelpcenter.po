#: index.docbook:143
#, no-c-format
msgid "A Man page"
msgstr "Une page de man"

#. Tag: para
#: index.docbook:145
#, no-c-format
msgid ""
"<command>khelpcenter</command> <option>man:/<replaceable>strcpy</"
"replaceable></option>"
msgstr ""
"<command>khelpcenter</command> <option>man:/<replaceable>strcpy</"
"replaceable></option>"

#. Tag: term
#: index.docbook:153
#, no-c-format
msgid "An Info page"
msgstr "Une page info"

#. Tag: para
#: index.docbook:155
#, no-c-format
msgid ""
"<command>khelpcenter</command> <option>info:/<replaceable>gcc</replaceable></"
"option>"
