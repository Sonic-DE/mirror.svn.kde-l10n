#, no-c-format
msgid ""
"<guimenu>Options</guimenu><guisubmenu>View</guisubmenu> <guimenuitem>Tree "
"View</guimenuitem>"
msgstr ""
"<guimenu>Options</guimenu><guisubmenu>Affichage</guisubmenu> "
"<guimenuitem>Affichage arborescent</guimenuitem>"

#. Tag: para
#: tasks.docbook:316
#, no-c-format
msgid "Like Short View, but folders can be expanded to view their contents."
msgstr ""
