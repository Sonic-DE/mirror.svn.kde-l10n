"<guimenu>Options</guimenu><guisubmenu>Tri</guisubmenu> <guimenuitem>Par "
"date</guimenuitem>"

#. Tag: para
#: tasks.docbook:249
#, no-c-format
msgid ""
"Sort files listed in the folder view by the date they were last modified."
msgstr ""
"Trie les fichiers listés dans la vue de dossier par la date de dernière "
"modification."

