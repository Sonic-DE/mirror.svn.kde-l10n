"<guimenu>Options</guimenu><guisubmenu>Sorting</guisubmenu> <guimenuitem>By "
"Type</guimenuitem>"
msgstr ""
"<guimenu>Options</guimenu><guisubmenu>Tri</guisubmenu> <guimenuitem>Par "
