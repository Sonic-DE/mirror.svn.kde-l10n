msgstr ""
"<guimenu>Options</guimenu><guisubmenu>Tri</guisubmenu> <guimenuitem>Les "
"dossiers d'abord</guimenuitem>"

#. Tag: para
#: tasks.docbook:279
#, no-c-format
msgid "When enabled (the default), folders will appear before regular files."
msgstr ""
"Quand activé (par défaut), les dossiers s'afficheront avant les fichiers."

