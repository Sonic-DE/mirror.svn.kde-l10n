"<guimenuitem>Affichage simple</guimenuitem>"

#. Tag: para
#: tasks.docbook:299
#, no-c-format
msgid "Displays only the filenames."
msgstr "Affiche seulement les noms de fichiers."

#. Tag: menuchoice
#: tasks.docbook:303
#, no-c-format
msgid ""
"<guimenu>Options</guimenu><guisubmenu>View</guisubmenu> "
"<guimenuitem>Detailed View</guimenuitem>"
msgstr ""
"<guimenu>Options</guimenu><guisubmenu>Affichage</guisubmenu> "
"<guimenuitem>Affichage détaillé</guimenuitem>"

#. Tag: para
#: tasks.docbook:307
#, no-c-format
msgid ""
"Displays <guilabel>Name</guilabel>, <guilabel>Date</guilabel> and "
"<guilabel>Size</guilabel> of the files."
msgstr ""
"Affiche le <guilabel>Nom</guilabel>, la <guilabel>Date</guilabel> et la "
"<guilabel>Taille</guilabel> des fichiers."

#. Tag: menuchoice
