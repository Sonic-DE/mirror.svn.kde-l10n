#. Tag: title
#: index.docbook:167
#, no-c-format
msgid "Application Launcher"
msgstr "Lanceur d'applications"

#. Tag: screeninfo
#: index.docbook:170
#, no-c-format
msgid "<screeninfo>Application launcher</screeninfo>"
