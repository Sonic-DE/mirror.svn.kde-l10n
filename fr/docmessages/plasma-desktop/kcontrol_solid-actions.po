#~ msgstr ""
#~ "Cette boîte de dialogue vous permet de modifier les divers détails à "
#~ "propos du conteneur et affichera les différentes informations, cela "
#~ "dépend de quel type d'élément il s'agit."

#~ msgid "Container Type"
#~ msgstr "Type de conteneur"

