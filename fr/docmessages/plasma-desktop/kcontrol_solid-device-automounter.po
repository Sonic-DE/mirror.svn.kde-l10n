msgstr "<keyword>KDE</keyword>"

#. Tag: keyword
#: index.docbook:20
#, no-c-format
msgid "Systemsettings"
msgstr "Configuration du système"

#. Tag: keyword
#: index.docbook:21
#, no-c-format
