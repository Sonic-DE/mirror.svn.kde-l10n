#, no-c-format
msgid "Device Auto-Mount"
msgstr "Montage automatique de périphérique"

#. Tag: author
#: index.docbook:11
#, no-c-format
msgid "<firstname>Trever</firstname><surname>Fischer</surname>"
msgstr "<firstname>Trever</firstname><surname>Fischer</surname>"

