msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>W</keycap></keycombo></"
"shortcut> <guimenu>Fenêtre</guimenu><guimenuitem>Fermer l'onglet courant</"
"guimenuitem>"

#. Tag: para
#: index.docbook:3459
#, no-c-format
msgid "Close the current tab page."
