#. Tag: title
#: man-kpackagetool6.1.docbook:8
#, no-c-format
msgid "KPackage Manager"
msgstr "Gestion « KPackage »"

#. Tag: date
#: man-kpackagetool6.1.docbook:9
#, no-c-format
msgid "2017-01-03"
msgstr "03-01-2017"

#. Tag: releaseinfo
#: man-kpackagetool6.1.docbook:10
#, no-c-format
msgid "Frameworks 5.30"
msgstr "Environnement de développement 5.30"

#. Tag: productname
#: man-kpackagetool6.1.docbook:11
#, no-c-format
msgid "KDE Frameworks"
msgstr "Environnement de développement pour KDE"

#. Tag: manvolnum
#: man-kpackagetool6.1.docbook:16
#, no-c-format
msgid "<manvolnum>1</manvolnum>"
msgstr "<manvolnum>1</manvolnum>"

#. Tag: refpurpose
#: man-kpackagetool6.1.docbook:21
#, no-c-format
msgid "Install, list, remove &plasma; packages"
msgstr "Installer, lister, supprimer des paquets de &plasma; "

#. Tag: cmdsynopsis
#: man-kpackagetool6.1.docbook:25
#, no-c-format
msgid ""
"<command>kpackagetool6</command> <group choice=\"opt\"><option>-v, --"
"version</option></group> <group choice=\"opt\"><option>-h, --help</option></"
"group> <group choice=\"opt\"><option>--hash</option> <replaceable> path</"
"replaceable></group> <group choice=\"opt\"><option>-g, --global</option></"
"group> <group choice=\"opt\"><option>-t, --type</option> <replaceable> type</"
"replaceable></group> <group choice=\"opt\"><option>-i, --install</option> "
"<replaceable> path</replaceable></group> <group choice=\"opt\"><option>-s, --"
"show</option> <replaceable> name</replaceable></group> <group choice=\"opt"
"\"><option>-u, --upgrade</option> <replaceable> path</replaceable></group> "
"<group choice=\"opt\"><option>-l, --list</option></group> <group choice=\"opt"
"\"><option>--list-types</option></group> <group choice=\"opt\"><option>-r, --"
"remove</option> <replaceable> name</replaceable></group> <group choice=\"opt"
"\"><option>-p, --packageroot</option> <replaceable> path</replaceable></"
"group> <group choice=\"opt\"><option>--generate-index</option></group>"
msgstr ""
"<command>kpackagetool6</command> <group choice=\"opt\"><option>-v, --"
"version</option></group> <group choice=\"opt\"><option>-h, --help</option></"
"group> <group choice=\"opt\"><option>--hash</option> <replaceable> "
"emplacement</replaceable></group> <group choice=\"opt\"><option>-g, --"
"global</option></group> <group choice=\"opt\"><option>-t, --type</option> "
"<replaceable> type</replaceable></group> <group choice=\"opt\"><option>-i, --"
"install</option> <replaceable> emplacement</replaceable></group> <group "
"choice=\"opt\"><option>-s, --show</option> <replaceable> nom</replaceable></"
"group> <group choice=\"opt\"><option>-u, --upgrade</option> <replaceable> "
"emplacement</replaceable></group> <group choice=\"opt\"><option>-l, --list</"
"option></group> <group choice=\"opt\"><option>--list-types</option></group> "
"<group choice=\"opt\"><option>-r, --remove</option> <replaceable> nom</"
"replaceable></group> <group choice=\"opt\"><option>-p, --packageroot</"
"option> <replaceable> emplacement</replaceable></group> <group choice=\"opt"
"\"><option>--generate-index</option></group>"

#. Tag: title
#: man-kpackagetool6.1.docbook:45
#, no-c-format
msgid "Description"
msgstr "Description"

#. Tag: para
#: man-kpackagetool6.1.docbook:46
#, no-c-format
msgid ""
"<command>kpackagetool6</command> is a command line tool to install, list, "
"remove &plasma; packages."
msgstr ""
"<command>kpackagetool6</command> est un outil en ligne de commandes pour "
"installer, lister et supprimer des paquets de &plasma;."

#. Tag: title
#: man-kpackagetool6.1.docbook:52
#, no-c-format
msgid "Options"
msgstr "Options"

#. Tag: option
#: man-kpackagetool6.1.docbook:56
#, no-c-format
msgid "-v, --version"
msgstr "-v, --version"

#. Tag: para
#: man-kpackagetool6.1.docbook:57
#, no-c-format
msgid "Displays version information."
msgstr "Affiche les informations."

#. Tag: option
#: man-kpackagetool6.1.docbook:60
#, no-c-format
msgid "-h, --help"
msgstr "-h, --help"

#. Tag: para
#: man-kpackagetool6.1.docbook:61
#, no-c-format
msgid "Displays this help."
msgstr "Affiche cette aide."

#. Tag: term
#: man-kpackagetool6.1.docbook:64
#, no-c-format
msgid "<option>--hash</option> <replaceable> path</replaceable>"
msgstr "<option>--hash</option> <replaceable> emplacement</replaceable>"

#. Tag: para
#: man-kpackagetool6.1.docbook:65
#, no-c-format
msgid "Generate a SHA1 hash for the package at <quote>path</quote>."
msgstr ""
"Génère un somme de hachage SHA1 pour le paquet à l'<quote>emplacement</"
"quote>."

#. Tag: option
#: man-kpackagetool6.1.docbook:68
#, no-c-format
msgid "-g, --global"
msgstr "-g, --global"

#. Tag: para
#: man-kpackagetool6.1.docbook:69
#, no-c-format
msgid "For install or remove, operates on packages installed for all users."
msgstr ""
"Pour installer ou supprimer, traite les paquets installés par les "
"utilisateurs."

#. Tag: term
#: man-kpackagetool6.1.docbook:72
#, no-c-format
msgid "<option>-t, --type</option> <replaceable> type</replaceable>"
msgstr "<option>-t, --type</option> <replaceable> type</replaceable>"

#. Tag: para
#: man-kpackagetool6.1.docbook:73
#, no-c-format
msgid ""
"The type of package, corresponding to the service type of the package "
"plugin, &eg; KPackage/Generic, Plasma/Theme, Plasma/Wallpaper, Plasma/"
"Applet, &etc;"
msgstr ""
"Le type de paquets, correspondant au type de service de module externe de "
"paquets, &pex; KPackage / Générique, Plasma / Thème, Plasma / Fond d'écran, "
"Plasma / Composant graphique, &etc;."

#. Tag: term
#: man-kpackagetool6.1.docbook:77
#, no-c-format
msgid "<option>-i, --install</option> <replaceable> path</replaceable>"
msgstr "<option>-i, --install</option> <replaceable> emplacement</replaceable>"

#. Tag: para
#: man-kpackagetool6.1.docbook:78
#, no-c-format
msgid "Install the package at <quote>path</quote>."
msgstr "Installer le paquet à <quote>l'emplacement</quote>."

#. Tag: term
#: man-kpackagetool6.1.docbook:81
#, no-c-format
msgid "<option>-s, --show</option> <replaceable> name</replaceable>"
msgstr "<option>-s, --show</option> <replaceable> nom</replaceable>"

#. Tag: para
#: man-kpackagetool6.1.docbook:82
#, no-c-format
msgid "Show information of package <quote>name</quote>."
msgstr "Affiche les informations sur le paquet <quote>nom</quote>."

#. Tag: term
#: man-kpackagetool6.1.docbook:85
#, no-c-format
msgid "<option>-u, --upgrade</option> <replaceable> path</replaceable>"
msgstr "<option>-u, --upgrade</option> <replaceable> emplacement</replaceable>"

#. Tag: para
#: man-kpackagetool6.1.docbook:86
#, no-c-format
msgid "Upgrade the package at <quote>path</quote>."
msgstr "Met à jour le paquet à l'<quote>emplacement</quote>."

#. Tag: option
#: man-kpackagetool6.1.docbook:89
#, no-c-format
msgid "-l, --list"
msgstr "-l, --list"

#. Tag: para
#: man-kpackagetool6.1.docbook:90
#, no-c-format
msgid "List installed packages."
msgstr "Liste les paquets installés."

#. Tag: option
#: man-kpackagetool6.1.docbook:93
#, no-c-format
msgid "--list-types"
msgstr "--list-types"

#. Tag: para
#: man-kpackagetool6.1.docbook:94
#, no-c-format
msgid "Lists all known Package types that can be installed."
msgstr "Liste tous les types connus de paquets pouvant être installé"

#. Tag: term
#: man-kpackagetool6.1.docbook:97
#, no-c-format
msgid "<option>-r, --remove</option> <replaceable> name</replaceable>"
msgstr "<option>-r, --remove</option> <replaceable> nom</replaceable>"

#. Tag: para
#: man-kpackagetool6.1.docbook:98
#, no-c-format
msgid "Remove the package named <quote>name</quote>."
msgstr "Supprime le paquet nommé <quote>nom</quote>."

#. Tag: term
#: man-kpackagetool6.1.docbook:101
#, no-c-format
msgid "<option>-p, --packageroot</option> <replaceable> path</replaceable>"
msgstr ""
"<option>-p, --packageroot</option> <replaceable>emplacement</replaceable>"

#. Tag: para
#: man-kpackagetool6.1.docbook:102
#, no-c-format
msgid ""
"Absolute path to the package root. If not supplied, then the standard data "
"directories for this &plasma; session will be searched instead."
msgstr ""
"Emplacement absolu de la racine du paquet. S'il n'est pas fourni, alors, les "
"emplacements standards de données pour cette session de &plasma; seront "
"recherchés à la place."

#. Tag: term
#: man-kpackagetool6.1.docbook:106
#, no-c-format
msgid "<option>--generate-index</option> <replaceable> path</replaceable>"
msgstr ""
"<option>--generate-index</option> <replaceable> emplacement</replaceable>"

#. Tag: para
#: man-kpackagetool6.1.docbook:107
#, no-c-format
msgid ""
"Recreate the plugin index. To be used in conjunction with either the option "
"<option>-t</option> or <option>-g</option>. Recreates the index for the "
"given type or package root. Operates in the user directory, unless <option>-"
"g</option> is used."
msgstr ""
"Re-génère l'index des modules externes. A utiliser en conjonction soit de "
"l'option <option>-t</option> ou <option>-g</option>. Re-génère l'index pour "
"le type donné ou une racine du paquet. Fonctionne dans le dossier de "
"l'utilisateur, sauf si l'option <option>-g</option> est utilisée."

#. Tag: title
#: man-kpackagetool6.1.docbook:118
#, no-c-format
msgid "See Also"
msgstr "Voir aussi"

#. Tag: para
#: man-kpackagetool6.1.docbook:120
#, no-c-format
msgid ""
"More detailed user documentation is available from <ulink url=\"help:/plasma-"
"desktop\">help:/plasma-desktop</ulink> (either enter this &URL; into "
"&konqueror;, or run <userinput><command>khelpcenter</command> "
"<parameter>help:/plasma-desktop</parameter></userinput>)."
msgstr ""
"Une documentation utilisateur plus détaillée est disponible à l'adresse "
"<ulink url=\"help:/plasma-desktop\">help:/plasma-desktop</ulink> (soit, "
"saisissez cette <acronym>&URL;</acronym> dans &konqueror; ou lancer "
"<userinput><command>khelpcenter</command> <parameter>help:/plasma-desktop</"
"parameter></userinput>)."

#. Tag: title
#: man-kpackagetool6.1.docbook:129
#, no-c-format
msgid "Authors"
msgstr "Auteurs"

#. Tag: para
#: man-kpackagetool6.1.docbook:130
#, no-c-format
msgid ""
"<command>kpackagetool6</command> was written by "
"<personname><firstname>Aaron</firstname><surname>Seigo</surname></"
"personname> <email>aseigo@kde.org</email>."
msgstr ""
"<command>kpackagetool6</command> a été écrit par "
"<personname><firstname>Aaron</firstname><surname>Seigo</surname></"
"personname> <email>aseigo@kde.org</email>."

