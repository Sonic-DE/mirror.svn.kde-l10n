#. Tag: para
#: index.docbook:980
#, no-c-format
msgid ""
"<guimenuitem>Configure Keyboard Shortcuts…</guimenuitem>: To change the "
"shortcuts of each command"
msgstr ""
"<guimenuitem>Configurer les raccourcis clavier…</guimenuitem> : pour "
"modifier les raccourcis de chaque commande"

#. Tag: para
#: index.docbook:981
#, no-c-format
msgid ""
"<guimenuitem>Configure Toolbars…</guimenuitem>: To modify the toolbars "
"layouts"
msgstr ""
"<guimenuitem>Configurer les barres d'outils…</guimenuitem> : pour modifier "
