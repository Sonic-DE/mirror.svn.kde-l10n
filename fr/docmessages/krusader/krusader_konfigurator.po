#. Tag: para
#: konfigurator.docbook:1138
#, fuzzy, no-c-format
#| msgid ""
#| "<guilabel>Default viewer mode</guilabel>: either generic, text or hex "
#| "mode."
msgid "<guilabel>Text mode</guilabel>: view the file in text-only mode."
msgstr ""
"<guilabel>Mode d'affichage par défaut</guilabel> : soit générique, texte ou "
"mode hexadécimal."

#. Tag: para
#: konfigurator.docbook:1142
#, fuzzy, no-c-format
#| msgid "<guilabel>Size</guilabel>: Shows the size field."
