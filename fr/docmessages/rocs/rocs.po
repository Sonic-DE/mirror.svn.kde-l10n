#~ msgid ""
#~ "Sometimes it is useful if you can use functions for standard tasks, like "
#~ "computing shortest distances between two nodes. Currently we support the "
#~ "following algorithms that can be called from the scripting engine with "
#~ "nodes from the same graph."
#~ msgstr ""
#~ "Parfois, il est pratique d'utiliser des fonctions toute prêtes "
#~ "automatisant certaines tâches, comme calculer la distance la plus courte "
#~ "entre deux sommets. Actuellement, nous fournissons les algorithmes "
#~ "suivants, qui peuvent être appelés depuis vos scripts, avec des sommets "
#~ "provenant du même graphe."

#~ msgid ""
#~ "Here is a simple script example that sets the color of the 4 first nodes "
#~ "in the first graph:"
#~ msgstr ""
#~ "Voici un script simple qui définit la couleur des 4 premiers sommets dans "
#~ "le premier graphe :"

#~ msgid ""
#~ "/* A simple example that sets the color of the 4 first nodes in the "
#~ "first\n"
#~ "graph: */\n"
#~ "\n"
#~ "var colors = new Array(\"red\", \"green\", \"blue\", \"yellow\");\n"
#~ "\n"
#~ "/* graphs is an array of graphs, you can access a graph by its index in "
#~ "the\n"
#~ "array or by its name, so if the first graph's name is Untitled0, the "
#~ "following\n"
#~ "sentence are right  */\n"
#~ "var list1= graphs[0].list_nodes(); //  1st form.\n"
#~ "var list2=Untitled0.list_nodes();              // 2nd form\n"
#~ "\n"
#~ " for ( var i = 0; i &lt; colors.length; i++){\n"
#~ "        if (i > list2.length) break;\n"
#~ "        list2[i].color = colors[i]\n"
#~ " }"
#~ msgstr ""
#~ "/* Un script simple qui définit la couleur des 4 premiers sommets dans le "
#~ "premier\n"
#~ "graph : */\n"
#~ "\n"
#~ "var colors = new Array(\"red\", \"green\", \"blue\", \"yellow\");\n"
#~ "\n"
#~ "/* graphs est un tableau de graphes ; vous pouvez accéder à un graphe "
#~ "grâce\n"
#~ "à son index dans le tableau ou bien grâce à son nom, donc si le premier "
#~ "nom\n"
#~ "de graphe est Untitled0, les deux lignes suivantes sont équivalentes */\n"
#~ "var list1= graphs[0].list_nodes(); //  1ère façon.\n"
#~ "var list2=Untitled0.list_nodes();              // 2ème façon.\n"
#~ "\n"
#~ " for ( var i = 0; i &lt; colors.length; i++){\n"
#~ "        if (i > list2.length) break;\n"
#~ "        list2[i].color = colors[i]\n"
#~ " }"

