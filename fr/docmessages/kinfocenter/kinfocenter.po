#~ msgid "IEEE 1394 Device Information Module"
#~ msgstr "Module d'informations sur les périphériques IEEE 1394"

#~ msgid ""
#~ "The IEEE 1394 interface, also known as <trademark>FireWire</trademark>, "
#~ "is a serial bus interface standard for high-speed communications and "
#~ "isochronous real-time data transfer."
#~ msgstr ""
#~ "L'interface IEEE 1394, aussi connu sous le nom de <trademark>FireWire</"
#~ "trademark>, est une interface standard de bus série pour les "
#~ "communications à grande vitesse et les transferts isochrones en temps "
#~ "réel des données."

#~ msgid ""
#~ "The list in this module displays all devices attached to IEEE 1394 bus "
#~ "and allows you to reset the bus by clicking the <guibutton>Generate 1394 "
#~ "Bus Reset</guibutton> button."
#~ msgstr ""
#~ "La liste de ce module affiche tous les périphériques sur le bus IEEE 1394 "
#~ "et vous permet de redémarrer le bus en appuyant sur le bouton "
#~ "<guibutton>Générer un redémarrage du Bus 1394</guibutton>."

#~ msgid "The meaning of the columns in this list:"
#~ msgstr "Signification des colonnes dans cette liste :"

#~ msgid ""
#~ "<guilabel>Name</guilabel>: port or node name, the number can change with "
#~ "each bus reset"
#~ msgstr ""
#~ "<guilabel>Nom</guilabel> : nom du port ou du nœud, le nombre peut changer "
#~ "après chaque redémarrage du bus."

#~ msgid "<guilabel>GUID</guilabel>: the 64 bit GUID of the node"
#~ msgstr "<guilabel>GUID</guilabel> : le GUID 64 bits du nœud "

#~ msgid ""
#~ "<guilabel>Local</guilabel>: checked if the node is an IEEE 1394 port of "
#~ "your computer"
#~ msgstr ""
#~ "<guilabel>Local</guilabel> : coché si le nœud est un port IEEE 1394 de "
#~ "ordinateur"

#~ msgid ""
#~ "<guilabel>IRM</guilabel>: checked if the node is isochronous resource "
#~ "manager capable"
#~ msgstr ""
#~ "<guilabel>IRM</guilabel> : coché si le nœud est un gestionnaire de "
#~ "ressource isochrone"

#~ msgid ""
#~ "<guilabel>CRM</guilabel>: checked if the node is cycle master capable"
#~ msgstr ""
#~ "<guilabel>CRM</guilabel> : coché si le nœud est dans un cycle maître"

#~ msgid ""
#~ "<guilabel>ISO</guilabel>: checked if the node supports isochronous "
#~ "transfers"
#~ msgstr ""
#~ "<guilabel>ISO</guilabel> : coché si le nœud prend en charge les "
#~ "transferts isochrones"

#~ msgid "<guilabel>BM</guilabel>: checked if the node is bus manager capable"
#~ msgstr ""
#~ "<guilabel>BM</guilabel> : coché si le nœud est un gestionnaire de bus"

#~ msgid ""
#~ "<guilabel>PM</guilabel>: checked if the node is power management capable"
#~ msgstr ""
#~ "<guilabel>PM</guilabel> : coché si le nœud est un gestionnaire d'énergie"

#~ msgid ""
#~ "<guilabel>Acc</guilabel>: the cycle clock accuracy of the node, valid "
#~ "from 0 to 100"
#~ msgstr ""
#~ "<guilabel>Acc</guilabel> : c'est la précision de l'horloge interne du "
#~ "nœud, valable de 0 à 100"

#~ msgid "<guilabel>Speed</guilabel>: the speed of the node"
#~ msgstr "<guilabel>Vitesse</guilabel> : c'est la vitesse du nœud"

#~ msgid "<guilabel>Vendor</guilabel>: the vendor of the device"
#~ msgstr "<guilabel>Vendeur</guilabel> : c'est le fabricant du périphérique"

#~ msgid "File Indexer Monitor Module"
#~ msgstr "Module de surveillance pour l'indexation de fichiers"

#~ msgid ""
#~ "This Module shows the state of the file indexer. If the indexer is not "
#~ "running you can start it and then suspend or resume the indexing."
#~ msgstr ""
#~ "Ce module affiche l'état de l'indexation des fichiers. Si l'indexation "
#~ "n'est pas lancée, vous pouvez la démarrer et ensuite la mettre en pause "
#~ "ou reprendre l'indexation."

