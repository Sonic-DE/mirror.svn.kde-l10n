#~ msgstr "<firstname>Michael</firstname> <surname>McBride</surname>"

#~ msgid "Matthias Hoelzer-Kluepfel &Matthias.Hoelzer-Kluepfel.mail;"
#~ msgstr "Matthias Hoelzer-Kluepfel &Matthias.Hoelzer-Kluepfel.mail;"

