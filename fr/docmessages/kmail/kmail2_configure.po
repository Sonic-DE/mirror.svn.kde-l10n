#. Tag: term
#: configure.docbook:1125
#, no-c-format
msgid "Activity by Date, Flat"
msgstr "Activité par date, liste simple"

#. Tag: para
#: configure.docbook:1126
#, fuzzy, no-c-format
#| msgid ""
#| "This view uses day-by-day groups. Messages are threaded. So for example, "
#| "in <quote>Today</quote> you will find all the messages arrived today and "
