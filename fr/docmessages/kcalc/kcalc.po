"<guibutton>&Shift;</guibutton> <guibutton>x³</guibutton> or <guibutton>∛x</"
"guibutton>"
msgstr ""
"<guibutton>&Maj;</guibutton> <guibutton>x³</guibutton> ou <guibutton>∛x</"
