#. Tag: title
#: commands.docbook:3
#, no-c-format
msgid "Command Reference"
msgstr "Table des commandes"

#. Tag: title
#: commands.docbook:6
#, no-c-format
msgid "Menu Items"
msgstr "Éléments de menu"

#. Tag: para
#: commands.docbook:8
#, no-c-format
msgid "A brief overview of some special menu items in &kcalc;:"
msgstr ""
"Un aperçu succinct de certains éléments spéciaux de menus dans &kcalc; :"

#. Tag: menuchoice
#: commands.docbook:12
#, no-c-format
msgid "<guimenu>Constants</guimenu> <guimenuitem>Mathematics</guimenuitem>"
msgstr "<guimenu>Constantes</guimenu> <guimenuitem>Mathématiques</guimenuitem>"

#. Tag: action
#: commands.docbook:16
#, no-c-format
msgid "Display Pi, Euler Number or Golden Ratio."
msgstr "Affiche Pi, le Nombre d'Euler ou le Nombre d'or."

#. Tag: menuchoice
#: commands.docbook:21
#, no-c-format
msgid ""
"<guimenu>Constants</guimenu> <guimenuitem>Electromagnetism</guimenuitem>"
msgstr ""
"<guimenu>Constantes</guimenu><guimenuitem>électromagnétisme</guimenuitem>"

#. Tag: action
#: commands.docbook:25
#, no-c-format
msgid ""
"Display Light Speed, Elementary Charge, Impedance of Vacuum, Permeability of "
"Vacuum or Permittivity of Vacuum."
msgstr ""
"Affiche la vitesse de la lumière, la charge élémentaire, l'impédance du "
"vide, la perméabilité du vide et la permittivité du vide."

#. Tag: menuchoice
#: commands.docbook:31
#, no-c-format
msgid ""
"<guimenu>Constants</guimenu> <guimenuitem>Atomic &amp; Nuclear</guimenuitem>"
msgstr ""
"<guimenu>Constantes</guimenu> <guimenuitem>Atome et noyau</guimenuitem>"

#. Tag: action
#: commands.docbook:35
#, no-c-format
msgid ""
"Display Planck's Constant, Elementary Charge or Fine-Structure Constant."
msgstr ""
"Affiche la constante de Planck, la charge élémentaire, ou la constante de "
"structure fine."

#. Tag: menuchoice
#: commands.docbook:41
#, no-c-format
msgid "<guimenu>Constants</guimenu> <guimenuitem>Thermodynamics</guimenuitem>"
msgstr ""
"<guimenu>Constantes</guimenu> <guimenuitem>Thermodynamique</guimenuitem>"

#. Tag: action
#: commands.docbook:45
#, no-c-format
msgid ""
"Display Boltzmann Constant, Atomic Mass Unit, Molar Gas Constant, Stefan-"
"Boltzmann Constant or Avogadro's Number."
msgstr ""
"Affiche la constante de Boltzmann, l'unité de masse atomique, la constante "
"des gaz Parfaits, la constante de Stefan-Boltzmann ou le nombre d'Avogadro."

#. Tag: menuchoice
#: commands.docbook:51
#, no-c-format
msgid "<guimenu>Constants</guimenu> <guimenuitem>Gravitation</guimenuitem>"
msgstr "<guimenu>Constantes</guimenu> <guimenuitem>Gravitation</guimenuitem>"

#. Tag: para
#: commands.docbook:55
#, no-c-format
msgid "Display Constant of Gravitation or Earth Acceleration."
msgstr "Affiche le constante de gravitation et l'accélération terrestre."

#. Tag: menuchoice
#: commands.docbook:60
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Simple Mode</guimenuitem>"
msgstr ""
"<guimenu>Configuration</guimenu> <guimenuitem>Mode Simple</guimenuitem>"

#. Tag: action
#: commands.docbook:64
#, no-c-format
msgid "Displays the simple math buttons."
msgstr "Affiche les boutons de maths standards"

#. Tag: menuchoice
#: commands.docbook:69
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Science Mode</guimenuitem>"
msgstr ""
"<guimenu>Configuration</guimenu> <guimenuitem>Mode Scientifique</guimenuitem>"

#. Tag: action
#: commands.docbook:73
#, no-c-format
msgid "Displays trigonometric and science buttons."
msgstr "Affiche les boutons de trigonométrie et scientifiques."

#. Tag: menuchoice
#: commands.docbook:78
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Statistic Mode</guimenuitem>"
msgstr ""
"<guimenu>Configuration</guimenu> <guimenuitem>Mode statistique</guimenuitem>"

#. Tag: action
#: commands.docbook:82
#, no-c-format
msgid "Displays <link linkend=\"statistical-mode\">statistic buttons.</link>"
msgstr ""
"Affiche <link linkend=\"statistical-mode\">les boutons liés à la statistique."
"</link>"

#. Tag: menuchoice
#: commands.docbook:88
#, no-c-format
msgid ""
"<guimenu>Settings</guimenu> <guimenuitem>Numeral System Mode</guimenuitem>"
msgstr ""
"<guimenu>Configuration</guimenu> <guimenuitem>Mode système numérique</"
"guimenuitem>"

#. Tag: action
#: commands.docbook:92
#, no-c-format
msgid ""
"Displays <link linkend=\"and-or-xor\">logic buttons</link> and allows "
"changing the numeral system."
msgstr ""
"Affiche <link linkend=\"and-or-xor\">les boutons des opérateurs logiques</"
"link> et permet de changer de mode numérique."

#. Tag: menuchoice
#: commands.docbook:98
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Show History</guimenuitem>"
msgstr ""
"<guimenu>Configuration</guimenu> <guimenuitem>Afficher l'historique</"
"guimenuitem>"

#. Tag: action
#: commands.docbook:102
#, no-c-format
msgid "Display the history."
msgstr "Afficher l'historique."

#. Tag: menuchoice
#: commands.docbook:107
#, no-c-format
msgid ""
"<guimenu>Settings</guimenu> <guimenuitem>Constants Buttons</guimenuitem>"
msgstr ""
"<guimenu>Configuration</guimenu> <guimenuitem>Boutons des constantes</"
"guimenuitem>"

#. Tag: action
#: commands.docbook:111
#, no-c-format
msgid ""
"Display constants buttons. They are available in <link linkend=\"science-mode"
"\">science mode</link> and <link linkend=\"statistical-mode\">statistic "
"mode</link>."
msgstr ""
"Affiche les boutons de constantes. Ils sont disponibles dans le <link "
"linkend=\"science-mode\">mode scientifique</link> et dans le <link linkend="
"\"statistical-mode\">mode statistique</link>."

#. Tag: menuchoice
#: commands.docbook:117
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Show Bit Edit</guimenuitem>"
msgstr ""
"<guimenu>Configuration</guimenu> <guimenuitem>Afficher la modifications des "
"bits</guimenuitem>"

#. Tag: action
#: commands.docbook:121
#, no-c-format
msgid ""
"Displays a bit edit field. Click on a bit to toggle it. Only available in "
"<link linkend=\"numeral-system-mode\">numeral system mode</link>."
msgstr ""
"Affiche un champ d'édition des bits. Cliquez dessus pour l'activer. "
"Disponible uniquement dans le <link linkend=\"numeral-system-mode\">mode "
"système numérique</link>."

#. Tag: para
#: commands.docbook:128
#, no-c-format
msgid ""
"Additionally &kcalc; has the common <guimenu>File</guimenu>, <guimenu>Edit</"
"guimenu>, <guimenu>Settings</guimenu> and <guimenu>Help</guimenu> menu "
"items, for more information read the sections about the <ulink url=\"help:/"
"fundamentals/menus.html\">Menus</ulink> in the &kde; Fundamentals."
msgstr ""
"En plus, &kcalc; possède des éléments communs de menu <guimenu>Fichier</"
"guimenu>, <guimenu>Édition</guimenu>, <guimenu>Configuration</guimenu> et "
"<guimenu>Aide</guimenu>. Pour plus d'informations, veuillez consulter les "
"sections <ulink url=\"help:/fundamentals/menus.html\">Menus</ulink> des "
"fondamentaux de &kde;."

