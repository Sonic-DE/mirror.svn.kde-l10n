msgstr "<phrase>Chercher des fichiers et du contenu dans des fichiers</phrase>"

#. Tag: para
#: index.docbook:847
#, no-c-format
msgid "&dolphin; searching with More Options."
msgstr "Recherche avec &dolphin; avec plus d'options."

#. Tag: para
#: index.docbook:851
#, fuzzy, no-c-format
#| msgid ""
#| "The <guilabel>Search</guilabel> panel provides a very comfortable way for "
