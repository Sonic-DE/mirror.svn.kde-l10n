msgstr "La police par défaut employée sur la carte."

#. Tag: title
#: index.docbook:865
#, no-c-format
msgid "Navigation Configuration"
msgstr "Configuration de la navigation"

#. Tag: screeninfo
#: index.docbook:868
#, no-c-format
