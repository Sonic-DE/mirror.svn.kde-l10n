msgstr "Introduction"

#. Tag: title
#: index.docbook:72
#, no-c-format
msgid "Gametype:"
msgstr "Type de Jeu : "

#. Tag: para
#: index.docbook:72
#, no-c-format
msgid "Strategy, Board"
msgstr "Stratégie, plateau"

#. Tag: title
#: index.docbook:73
#, no-c-format
msgid "Number of possible players:"
