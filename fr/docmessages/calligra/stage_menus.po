#~ msgid "<guimenu>View</guimenu> <guimenuitem>Remove View</guimenuitem>"
#~ msgstr ""
#~ "<guimenu>Affichage</guimenu><guimenuitem>Fermer l'affichage</guimenuitem>"

#~ msgid ""
