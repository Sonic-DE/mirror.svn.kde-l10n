#. Tag: menuchoice
#: commands.docbook:551
#, no-c-format
msgid "<guimenu>Insert</guimenu> <guimenuitem>Function...</guimenuitem>"
msgstr "<guimenu>Insertion</guimenu><guimenuitem>Fonction...</guimenuitem>"

#. Tag: para
#: commands.docbook:555
#, no-c-format
