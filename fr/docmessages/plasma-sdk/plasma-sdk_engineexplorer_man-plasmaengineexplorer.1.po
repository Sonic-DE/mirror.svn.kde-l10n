msgstr "<manvolnum>1</manvolnum>"

#. Tag: refpurpose
#: man-plasmaengineexplorer.1.docbook:21
#, no-c-format
msgid "Provides direct access to plasma data engines"
msgstr "Fournit un accès direct aux moteurs de données de Plasma"

