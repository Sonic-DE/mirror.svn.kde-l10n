#. Tag: para
#: index.docbook:17
#, no-c-format
msgid ""
"The <emphasis>file</emphasis> protocol is used by all &kde; applications to "
"display locally available files."
msgstr ""
"Le protocole <emphasis>file</emphasis> est utilisé par toutes les "
"applications &kde; pour afficher les fichiers disponibles en local."

#. Tag: para
#: index.docbook:21
#, no-c-format
msgid ""
"Entering <userinput><command>file:/directoryname</command></userinput> in "
"&konqueror; lists the files of this folder."
msgstr ""
"Saisissez <userinput><command>file:/nom_du_dossier</command></userinput> "
"dans &konqueror; pour lister les dossiers et les fichiers."
