#. Tag: refpurpose
#: man-zonetab2pot.py.1.docbook:20
#, no-c-format
msgid "Converts a timezone list to a PO file template."
msgstr "Convertit une liste de fuseau horaire vers un modèle de fichier PO."

#. Tag: cmdsynopsis
#: man-zonetab2pot.py.1.docbook:24
#, no-c-format
msgid ""
"<command>zonetab2pot.py</command> <group><option><replaceable>timezone-list</"
"replaceable></option></group>"
msgstr ""
"<command>zonetab2pot.py</command> <group><option><replaceable>timezone-list</"
"replaceable></option></group>"

#. Tag: title
#: man-zonetab2pot.py.1.docbook:32
#, no-c-format
msgid "Description"
msgstr "Description"

#. Tag: para
#: man-zonetab2pot.py.1.docbook:34
#, no-c-format
msgid ""
"<command>zonetab2pot.py</command> reads the timezone list given on the "
"command-line and converts it to a gettext message file (PO-file) template "
"containing the names of the individual timezones."
msgstr ""
"<command>zonetab2pot.py</command> lit la liste de fuseau horaire donnée par "
"la ligne de commande et la convertit en un modèle de fichier de message "
"Gettext (fichier PO) contenant les noms des fuseaux horaires individuels."

#. Tag: para
#: man-zonetab2pot.py.1.docbook:39
#, no-c-format
msgid ""
"The given timezone list should be in the same format as the system zone.tab. "
"If no timezone list is specified on the command-line, <filename>/usr/share/"
"zoneinfo/zone.tab</filename> will be used."
msgstr ""
"La liste de fuseaux horaires doit être dans le même format que le fichier du "
"système « zone.tab ». Si aucune liste de fuseaux horaires n'est spécifiée "
"dans la ligne de commandes, le fichier <filename>/usr/share/zoneinfo/zone."
"tab</filename> sera utilisé."

#. Tag: para
#: man-zonetab2pot.py.1.docbook:43
#, no-c-format
msgid "The new PO-file template will be written to standard output."
msgstr "Le nouveau modèle de fichier PO sera écrit vers la sortie standard."

#. Tag: para
#: man-zonetab2pot.py.1.docbook:45
#, no-c-format
