msgid "D[a,b]"
msgstr "D[a,b]"

#. Tag: para
#: index.docbook:948
#, fuzzy, no-c-format
msgid "Sets the domain for which the function will be displayed."
msgstr "Fixe le domaine sur lequel la fonction sera affichée."

