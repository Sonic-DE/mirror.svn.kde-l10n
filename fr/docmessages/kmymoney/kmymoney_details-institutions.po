"The name of the institution or account. This column is always displayed."
msgstr ""

#. Tag: term
#: details-institutions.docbook:60
#, no-c-format
msgid "Balance"
msgstr ""

#. Tag: para
#: details-institutions.docbook:62
#, no-c-format
msgid ""
"The current balance of the account. No value is displayed for institutions."
msgstr ""

#. Tag: term
#: details-institutions.docbook:69
#, no-c-format
msgid "Total Value"
msgstr ""

#. Tag: para
#: details-institutions.docbook:71
#, no-c-format
msgid ""
"For accounts, this is the same value as the balance. For Institutions, this "
"is the total of the balances for all accounts in that institution."
msgstr ""

#. Tag: term
#: details-institutions.docbook:79
#, no-c-format
msgid "IBAN"
msgstr ""

