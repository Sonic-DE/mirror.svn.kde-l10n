msgid "Duplicating schedules"
msgstr "Suppression d'opérations récurrentes"

#. Tag: para
#: details-schedules.docbook:258
#, fuzzy, no-c-format
#| msgid ""
#| "To delete a schedule simply select the entry in the list and right click "
