msgstr ""
"Au démarrage, &kappname; ouvre ou importe un fichier de données existant, ou "
"en crée un nouveau. Ensuite, sélectionnez <guimenuitem>Enregistrer comme "
"base de données</guimenuitem> dans le menu <guimenu>Fichier</guimenu>. La "
"boîte de dialogue suivante vous est alors proposée : "

#. Tag: screeninfo
#: details-database.docbook:166
#, no-c-format
msgid "<screeninfo>creating a database</screeninfo>"
msgstr ""

#. Tag: phrase
#: details-database.docbook:172
#, fuzzy, no-c-format
#| msgid "Creating a Database"
msgid "<phrase>creating a database</phrase>"
msgstr "Création d'une base de données"

#. Tag: para
#: details-database.docbook:177
#, no-c-format
msgid ""
"Complete the fields appropriate to the database type you have selected (as "
"usual, mandatory fields will be highlighted) and click <guibutton>OK</"
