#~ "correct account into which to import the data."
#~ msgstr ""
#~ "Ceci demande au module externe d'importer les données du fichier en se "
#~ "basant sur les choix que vous avez faits dans les onglets "
#~ "<guilabel>Banque</guilabel> ou <guilabel>Investissement</guilabel> de "
#~ "l'onglet <guilabel>Configuration</guilabel> conformément à ce qui est "
#~ "expliqué ci-dessous. Un message de &kappname; vous sollicitera pour le "
#~ "choix ou la confirmation du compte dans lequel l'importation devra avoir "
#~ "lieu."

#~ msgid "Save as QIF"
#~ msgstr "Sauvegarder en tant que QIF"

#~ msgid ""
#~ "This button gives you the ability, after the import has been completed, "
#~ "to save the data from the csv file as a qif file, should you require one "
#~ "for any reason."
#~ msgstr ""
#~ "Ce bouton vous permet, après l'importation, de sauvegarder les données du "
#~ "fichier CSV en tant que fichier QIF au cas où, pour une raison "
#~ "quelconque, vous en auriez besoin."

#~ msgid "Quit"
#~ msgstr "Quitter"

