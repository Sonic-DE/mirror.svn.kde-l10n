msgstr "Gestion des polices"

#. Tag: author
#: index.docbook:12
#, no-c-format
msgid "&Craig.Drummond; &Craig.Drummond.Mail;"
msgstr "&Craig.Drummond; &Craig.Drummond.Mail;"

