#. Tag: guilabel
#: configuring.docbook:418
#, no-c-format
msgid "Copy and paste"
msgstr ""

#. Tag: guilabel
#: configuring.docbook:422
#, no-c-format
msgid "Move selected text when dragged"
msgstr ""

#. Tag: para
#: configuring.docbook:423
#, fuzzy, no-c-format
#| msgid "Deselects the selected text in the editor if any."
msgid ""
"This option enables drag-and-drop of the selected text inside the editor "
"window."
msgstr "Désélectionne le texte sélectionné dans l'éditeur, s'il y a lieu."

#. Tag: guilabel
#: configuring.docbook:426
#, fuzzy, no-c-format
#| msgid "Copy/Cut the current line if no selection"
msgid "Copy/cut the current line if invoked without any text selected"
msgstr "Copier/Couper la ligne actuelle s'il n'existe aucune sélection"

#. Tag: para
#: configuring.docbook:427
#, no-c-format
msgid ""
"If this option is enabled and the text selection is empty, copy and cut "
"action are performed for the line of text at the actual cursor position."
msgstr ""
"Si cette option est activée et que la sélection de texte est vide, les "
"action couper et coller seront effectuées pour la ligne de texte contenant "
