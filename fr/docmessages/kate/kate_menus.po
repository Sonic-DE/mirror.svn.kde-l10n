"<shortcut> <keycombo action=\"simul\"><keycap>F5</keycap></keycombo> </"
"shortcut> <guimenu>Fichier</guimenu> <guimenuitem>Recharger</guimenuitem>"

#. Tag: para
#: menus.docbook:159
#, fuzzy, no-c-format
#| msgid ""
#| "<action>Reloads the active file</action>. This command is useful if "
#| "another program or process has changed the file while you have it open in "
#| "&kate;"
msgid ""
"Reloads the active file from disk. This command is useful if another program "
"or process has changed the file while you have it open in &kappname;."
msgstr ""
"<action>Recharge le fichier actif</action>. Cette commande est utile si un "
"autre programme ou processus a modifié le fichier pendant qu'il est ouvert "
"dans &kate;"

#. Tag: menuchoice
#: menus.docbook:168
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Reload All</guimenuitem>"
msgstr "<guimenu>Fichier</guimenu> <guimenuitem>Tout recharger</guimenuitem>"

#. Tag: para
#: menus.docbook:174
#, no-c-format
msgid "<action>Reloads all opened files.</action>."
msgstr "<action>Recharge tous les fichiers ouverts</action>."

#. Tag: menuchoice
#: menus.docbook:181
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>P</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Print...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>P</keycap></keycombo> </"
"shortcut> <guimenu>Fichier</guimenu> <guimenuitem>Imprimer...</guimenuitem>"

#. Tag: para
#: menus.docbook:189
#, no-c-format
msgid ""
"Opens a simple print dialog allowing the user to specify what, where, and "
"how to print."
msgstr ""

#. Tag: menuchoice
#: menus.docbook:199
#, fuzzy, no-c-format
#| msgid ""
#| "<guimenu>File</guimenu> <guimenuitem>Export as &HTML;...</guimenuitem>"
msgid "<guimenu>File</guimenu> <guimenuitem>Export as HTML</guimenuitem>"
msgstr ""
"<guimenu>Fichier</guimenu> <guimenuitem>Exporter en &HTML;...</guimenuitem>"

#. Tag: para
#: menus.docbook:204
#, no-c-format
msgid ""
"Save the currently open document as an &HTML; file, which will be formatted "
"using the current syntax highlighting and color scheme settings."
msgstr ""
"Enregistre le document actuel dans un fichier &HTML;, qui sera formaté en "
"utilisant la coloration syntaxique actuelle et les réglages du schéma de "
"couleurs."

#. Tag: menuchoice
#: menus.docbook:210
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>W</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Close</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>W</keycap></keycombo> </"
"shortcut> <guimenu>Fichier</guimenu> <guimenuitem>Fermer</guimenuitem>"

#. Tag: para
#: menus.docbook:218
#, no-c-format
msgid ""
"Close the active file with this command. If you have made unsaved changes, "
"you will be prompted to save the file before &kate; closes it."
msgstr ""
"Fermez le fichier actif avec cette commande. Si vous avez effectué des "
"changements non enregistrés, vous serez invité à enregistrer le fichier "
"avant que &kate; ne le ferme."

#. Tag: menuchoice
#: menus.docbook:227
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Close Other</guimenuitem>"
msgstr ""
"<guimenu>Fichier</guimenu> <guimenuitem>Fermer les autres</guimenuitem>"

#. Tag: para
#: menus.docbook:233
#, no-c-format
msgid "Close other open documents."
msgstr "Ferme les autres documents ouverts."

#. Tag: menuchoice
#: menus.docbook:241
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Close All</guimenuitem>"
msgstr "<guimenu>Fichier</guimenu> <guimenuitem>Tout fermer</guimenuitem>"

#. Tag: para
#: menus.docbook:247
#, no-c-format
msgid ""
"This command <action>closes all the files you have open</action> in &kate;."
msgstr ""
"Cette commande <action>ferme tous les fichiers que vous avez ouverts </"
"action> dans &kate;."

#. Tag: menuchoice
#: menus.docbook:256
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Close Orphaned</guimenuitem>"
msgstr ""
"<guimenu>Fichier</guimenu> <guimenuitem>Fermer les documents orphelins</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:262
#, no-c-format
msgid ""
"<action>Close</action> all documents in the file list, which could not be "
"reopened during startup, because they are not accessible anymore."
msgstr ""
"<action>Ferme</action> tous les documents de la liste des fichiers qui ne "
"pourront pas être rouvert lors du prochain démarrage, parce qu'ils ne seront "
"plus accessibles."

#. Tag: menuchoice
#: menus.docbook:269
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>Q</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Quit</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>Q</keycap></keycombo> </"
"shortcut> <guimenu>Fichier</guimenu> <guimenuitem>Quitter</guimenuitem>"

#. Tag: para
#: menus.docbook:277
#, no-c-format
msgid ""
"This command <action>closes &kate;</action> and any files you were editing. "
"If you have made unsaved changes to any of the files you were editing, you "
"will be prompted to save them."
msgstr ""
"Cette commande <action>ferme &kate;</action> et tout fichier en cours "
"d'édition. Si vous avez apporté des changements non enregistrés à n'importe "
"lequel des fichiers en cours d'édition, vous serez invité à les enregistrer."

