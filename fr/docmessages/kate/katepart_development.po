msgstr ""
"<emphasis>firstNonSpace</emphasis> : s'applique uniquement si la chaine est "
"le premier espace autre qu'un blanc dans la ligne. Par défaut : "
"<emphasis>false</emphasis>."

#. Tag: para
#: development.docbook:726
#, no-c-format
msgid ""
"<emphasis>column</emphasis>: Match only, if the column matches. Default: "
"unset."
msgstr ""
"<emphasis>column</emphasis> : concorde uniquement si la colonne correspond. "
