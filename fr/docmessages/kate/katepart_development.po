#~ "Pour rechercher une <literal>(</literal> ou une <literal>)</literal>, "
#~ "vous devez la faire  précéder d'une barre oblique inverse, qui joue le "
#~ "rôle de <emphasis>caractère d'échappement</emphasis> : <userinput>\\(\\)</"
#~ "userinput>"

