msgid "Former maintainer: &Primoz.Anzur; &Primoz.Anzur.mail;"
msgstr "Ancien mainteneur : &Primoz.Anzur; &Primoz.Anzur.mail;"

#. Tag: para
#: index.docbook:540
#, no-c-format
msgid ""
"Swedish data files, coding help, transparent pictures and i18n fixes: Stefan "
"Asserhäll <email>stefan.asserhall@telia.com </email>"
msgstr ""
"Fichiers de données suédois, aide au codage, images transparentes et "
"corrections dans l'internationalisation : Stefan Asserhäll <email>stefan."
"asserhall@telia.com </email>"

#. Tag: para
#: index.docbook:544
#, no-c-format
msgid ""
"Spanish data files: eXParTaKus <email>expartakus@expartakus.com </email>"
msgstr ""
"Fichiers de données espagnols : eXParTaKus <email>expartakus@expartakus.com</"
"email>"

#. Tag: para
#: index.docbook:547
