#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:136 org.kde.kweather.appdata.xml:144
#: org.kde.kweather.appdata.xml:152
msgid "User interface improvements and bugfixes"
msgstr "Подобрения в потребителския интерфейс и корекции на грешки"

#. (itstool) path: description/p
#: org.kde.kweather.appdata.xml:159 org.kde.kweather.appdata.xml:174
#: org.kde.kweather.appdata.xml:185
msgid "Changes:"
msgstr "Промени:"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:161
msgid "Performance improvements in Dynamic view"
msgstr "Подобрения в производителността в динамичния изглед"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:162
msgid "Dynamic view action bar rewritten to be inline to content"
msgstr ""
"Динамична лента за действие на изгледа, пренаписана така, че да е вградена в "
"съдържанието"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:163
msgid "Allow setting non-current location in default forecasts page"
msgstr ""
"Разрешаване на задаване на неактуално местоположение на страницата с "
"прогнози по подразбиране"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:164
msgid "Added ability to fetch temperature units from system locale"
msgstr ""
"Добавена е възможност за извличане на температурни единици от системния език"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:165
msgid "Fixed timezone format not being correctly read for local location time"
msgstr ""
"Поправен е форматът на часовата зона, който не се четеше правилно за "
"местното време"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:176
msgid "Rewrote the weather plasmoid"
msgstr "Пренаписан е плазмоид за метеорологичните данни"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:177
msgid "Use inline page indicator for flat mode forecasts"
msgstr ""
"Използване на вграден индикатор на страницата за прогнози в плосък режим"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:178
msgid "Fix location ordering not persisting"
msgstr "Поправка на подреждането на местоположенията, което не се запазва"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:187
msgid "Reworked the locations page to better handle long location names"
msgstr ""
"Страницата с местоположения е преработена, за да се обработват по-добре "
"дългите имена на местоположения."

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:188
msgid "Add maximum width to dynamic forecast to better deal with widescreen"
msgstr ""
"Добавена е максимална ширина към динамичната прогноза, за да се представи по-"
"добре в широкоекранен режим"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:189
msgid "Remove plasmoid (it is being reworked!)"
msgstr "Премахнат е плазмоида (той се преработва!)"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:190
msgid "Fixed default page not being loaded when new locations are added"
msgstr ""
"Поправена е страницата по подразбиране, която не се зареждаше при добавяне "
"на нови местоположения"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:191
msgid "Unify application settings location"
msgstr "Унифициране на местоположението на настройките на приложението"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:192
msgid "Enable qml debugging when in debug mode"
msgstr "Активиране на qml дебъгване в режим на дебъгване"
