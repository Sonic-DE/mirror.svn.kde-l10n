#. (itstool) path: component/name
#: org.kde.kolourpaint.appdata.xml:10
msgid "KolourPaint"
msgstr "KolourPaint"

#. (itstool) path: component/summary
#: org.kde.kolourpaint.appdata.xml:11
msgid "Paint Program"
msgstr "Програма за рисуване"

#. (itstool) path: description/p
#: org.kde.kolourpaint.appdata.xml:13
msgid ""
"KolourPaint is a simple painting program to quickly create raster images. It "
"is useful as a touch-up tool and for simple image editing tasks."
msgstr ""
"KolourPaint е проста програма за рисуване на растерни изображения. Тя е "
"полезна като инструмент за ретуширане и при стандартни задачи за редактиране "
"на изображения."

#. (itstool) path: description/p
#: org.kde.kolourpaint.appdata.xml:17
msgid "Features:"
msgstr "Функции:"

#. (itstool) path: ul/li
#: org.kde.kolourpaint.appdata.xml:19
msgid ""
"Support for drawing various shapes - lines, rectangles, rounded rectangles, "
"ovals and polygons"
msgstr ""
"Поддръжка на чертане на различни фигури - линии, правоъгълници, овали и "
"полигони. "

#. (itstool) path: ul/li
#: org.kde.kolourpaint.appdata.xml:20
msgid "Curves, lines and text"
msgstr "Криви, линии и текст"

#. (itstool) path: ul/li
#: org.kde.kolourpaint.appdata.xml:21
msgid "Color picker"
msgstr "Избор на цвят"

#. (itstool) path: ul/li
