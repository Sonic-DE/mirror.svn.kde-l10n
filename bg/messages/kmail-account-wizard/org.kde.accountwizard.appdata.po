#. (itstool) path: component/name
#: org.kde.accountwizard.appdata.xml:9
msgid "Account Wizard"
msgstr "Съветник създаване на акаунт"

#. (itstool) path: component/summary
#: org.kde.accountwizard.appdata.xml:10
msgid "Configure accounts"
msgstr "Конфигуриране на акаунт"

#. (itstool) path: description/p
#: org.kde.accountwizard.appdata.xml:12
msgid ""
"Accountwizard allows to edit, create, delete accounts. Accountwizard "
"supports IMAP/POP3/Kolab account type. Account information can be found by "
"using ispd service."
msgstr ""
"Accountwizard позволява редактиране, създаване, изтриване на акаунти. "
"Accountwizard поддържа IMAP/POP3/Kolab тип акаунт. Информацията за акаунта "
"може да бъде намерена чрез услугата ispd."
