#. (itstool) path: component/summary
#: org.kde.kmousetool.appdata.xml:10
msgid "Automatic clicks to reduce the effects of repetitive strain injury"
msgstr "Automatické kliknutia na zníženie účinkov opakovaného zranenia"

#. (itstool) path: description/p
#: org.kde.kmousetool.appdata.xml:12
msgid ""
"KMouseTool clicks the mouse for you, so you don't have to. KMouseTool works "
"with any mouse or pointing device."
msgstr ""
"KMouseTool za vás klikne myšou, takže vy nemusíte. KMouseTool spolupracuje s "
"akoukoľvek myšou alebo ukazovacím zariadením."

#~ msgid "Automatic Mouse Click"
#~ msgstr "Automatické klikanie myšou"
