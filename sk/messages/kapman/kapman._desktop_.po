#: src/org.kde.kapman.desktop:4
msgctxt "Name"
msgid "Kapman"
msgstr "Kapman"

#: src/org.kde.kapman.desktop:63
msgctxt "GenericName"
msgid "Pac-Man Clone"
msgstr "Klon Pac-mana"

#: src/org.kde.kapman.desktop:117
msgctxt "Comment"
msgid "Eat pills escaping ghosts"
msgstr "Jedzte pilulky a utekajte duchom"

#: themes/invisible.desktop:2
msgctxt "Name"
msgid "Invisible"
msgstr "Neviditeľný"

#: themes/invisible.desktop:59
msgctxt "Description"
msgid ""
"Getting bored with Kapman? More than 100,000 points over level 20? Next "
"step: the invisible maze!"
msgstr ""
"Začína vás kapman nudiť? Máte viac ako 100 000 bodov a úroveň nad 20? Ďalší "
"krok: neviditeľné bludisko!"

#: themes/matches.desktop:2
msgctxt "Name"
msgid "Matches"
msgstr "Zápalky"

#: themes/matches.desktop:59
msgctxt "Description"
msgid "A matches drawn maze"
msgstr "Bludisko zo zápaliek"

#: themes/mountain.desktop:2
msgctxt "Name"
msgid "Mountain Adventure"
msgstr "Horské dobrodružstvo"

#: themes/mountain.desktop:55
msgctxt "Description"
msgid "Default"
msgstr "Štandardné"

#: themes/mummies_crypt.desktop:2
msgctxt "Name"
msgid "Mummies Crypt"
msgstr "Hrobka múmií"

#: themes/mummies_crypt.desktop:54
msgctxt "Description"
msgid "Avoid the mummies at all costs!"
msgstr "Za každú cenu uniknite múmiám!"

#: themes/retro.desktop:2
msgctxt "Name"
msgid "Retro"
msgstr "Retro"

#: themes/retro.desktop:58
