msgstr "Napájací zdroj bol pripojený"

#: powerdevil.notifyrc:987
msgctxt "Name"
msgid "Power source disconnected"
msgstr "Zdroj energie odpojený"

#: powerdevil.notifyrc:1034
msgctxt "Comment"
msgid "The power source has been disconnected"
msgstr "Napájací zdroj bol odpojený"

