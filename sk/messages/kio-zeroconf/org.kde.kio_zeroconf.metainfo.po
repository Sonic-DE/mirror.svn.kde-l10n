#. (itstool) path: component/summary
#: org.kde.kio_zeroconf.metainfo.xml:10
msgid "Browse local network services in Dolphin's Network page"
msgstr "Prehliadať sieťové služby v stránke Dolphina Siete"

#. (itstool) path: description/p
#: org.kde.kio_zeroconf.metainfo.xml:12
msgid ""
"Adds an entry to Dolphin's Network page to show local services such as "
"printers which advertise themselves with DNSSD (called Avahi or Bonjour by "
"other projects)."
msgstr ""
"Pridá položku na stránku siete v Dolphin, na zobrazenie miestnych služieb, "
"ako sú tlačiarne, ktoré sa propagujú sami s DNSSD (nazývané Avahi alebo "
"Bonjour podľa iných projektov)."
