#. (itstool) path: component/name
#: org.kde.kdf.appdata.xml:9
msgid "KDiskFree"
msgstr "KDiskFree"

#. (itstool) path: component/summary
#: org.kde.kdf.appdata.xml:10
msgid "View Disk Usage"
msgstr "Zobraziť využitie disku"

#. (itstool) path: description/p
#: org.kde.kdf.appdata.xml:12
msgid ""
"KDiskFree displays the available file devices (hard drive partitions, floppy "
"and CD drives, etc.) along with information on their capacity, free space, "
"type and mount point. It also allows you to mount and unmount drives and "
"view them in a file manager."
msgstr ""
"KDiskFree zobrazuje dostuné zariadenia na súbory (pevné disky, partície, "
"diskety, CD, atď.) tak isto informácie o ich kapacite, voľnom mieste, type a "
"prípojnom bode. Tiež vám umožnuje pripájať a odpájať disky a prehliadať ich "
"v správcovi súborov."

