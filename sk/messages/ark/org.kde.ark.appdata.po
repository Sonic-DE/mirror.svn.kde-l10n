msgid "Ark"
msgstr "Ark"

#. (itstool) path: component/summary
#: org.kde.ark.appdata.xml:12
msgid "Archiving Tool"
msgstr "Archivačný nástroj"

#. (itstool) path: description/p
#: org.kde.ark.appdata.xml:14
msgid ""
"Ark is a graphical file compression/decompression utility with support for "
"multiple formats, including tar, gzip, bzip2, rar and zip, as well as CD-ROM "
"images. Ark can be used to browse, extract, create, and modify archives."
msgstr ""
"Ark je grafický nástroj na kompresiu a dekompresiu súborov s podporou pre "
"mnoho formátov, vrátane tar, gzip bzip2, rar a zip, ako ako CD-ROM obrazy. "
"Ark sa dá použiť na prehliadanie, rozbaľovanie vytváranie a úpravu archívov."

