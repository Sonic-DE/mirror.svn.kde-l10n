#. (itstool) path: component/name
#: org.kde.partitionmanager.appdata.xml:11
msgid "KDE Partition Manager"
msgstr "KDE Správca partícií"

#. (itstool) path: component/summary
#: org.kde.partitionmanager.appdata.xml:12
msgid "Manage disks, partitions, and file systems"
msgstr "Spravujte diskové zariadenia, oddiely a súborové systémy"

#. (itstool) path: description/p
#: org.kde.partitionmanager.appdata.xml:14
msgid ""
"KDE Partition Manager is a utility to help you manage the disks, partitions, "
"and file systems on your computer. It allows you to easily create, copy, "
"move, delete, back up, restore, and resize them without losing data. It "
"supports a large number of file systems, including ext2/3/4, btrfs, "
"reiserfs, NTFS, FAT16/32, JFS, XFS and more."
msgstr ""
"KDE správca partícií je nástroj, ktorý vám má pomôcť spravovať diskové "
"zariadenia, partície a súborové systémy na vašom počítači. Umožňuje vám "
"jednoducho vytvoriť, kopírovať, presúvať, mazať a meniť veľkosť bez straty "
"dám, zálohovať a obnovovať partície. Podporuje veľké množstvo súborových "
"systémov vrátane ext2/3/4, btrfs,reiserfs, NTFS, FAT16/32, JFS, XFS a ďalšie."

