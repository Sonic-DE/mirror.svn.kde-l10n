#. Tag: guibutton
#: index.docbook:37
#, fuzzy, no-c-format
msgid "<guibutton>Add</guibutton>"
msgstr "Pridať"

#. Tag: para
#: index.docbook:39
#, no-c-format
msgid ""
"Click this button to select the camera's model and the port it is connected "
"to on your computer (&eg; USB, Serial). If your camera does not appear in "
"the list of <guilabel>Supported Cameras</guilabel>, go to the <ulink url="
"\"http://www.gphoto.org\">GPhoto web site</ulink> for a possible update."
msgstr ""

#. Tag: guibutton
#: index.docbook:48
#, fuzzy, no-c-format
msgid "Test"
msgstr "Test"

#. Tag: para
#: index.docbook:50
#, no-c-format
msgid "Click this button to test the connection to the selected camera."
msgstr ""
"Kliknutím na toto tlačidlo otestujete spojenie s vybraným fotoaparátom."

#. Tag: guibutton
#: index.docbook:54
#, no-c-format
msgid "Remove"
msgstr "Odstrániť"

#. Tag: para
#: index.docbook:56
#, no-c-format
msgid "Removes the selected camera from the list."
msgstr ""

#. Tag: guibutton
#: index.docbook:61
#, fuzzy, no-c-format
msgid "Configure"
msgstr "Nastaviť"

#. Tag: para
#: index.docbook:63
#, fuzzy, no-c-format
msgid ""
"Click this button to change the configuration of the selected camera. The "
"availability of this feature and the contents of the Configuration dialog "
"depend on the camera model."
msgstr ""
"Kliknutím na toto tlačidlo môžete zmeniť nastavenie vybraného fotoaparátu."
"<br><br>Dostupnosť tejto funkcie a obsah konfiguračného dialógu závisí na "
"modeli fotoaparátu."

#. Tag: guibutton
#: index.docbook:69
#, fuzzy, no-c-format
msgid "Information"
msgstr "Informácia"

#. Tag: para
#: index.docbook:71
#, fuzzy, no-c-format
msgid ""
"Click this button to view a summary of the current status of the selected "
"camera. The availability of this feature and the contents of the Information "
"dialog depend on the camera model."
msgstr ""
"Kliknutím na toto tlačidlo môžete zobraziť aktuálny stav vybraného "
"fotoaparátu.<br><br>Dostupnosť tejto funkcie a obsah konfiguračného dialógu "
"závisí na modeli fotoaparátu."

#. Tag: guibutton
#: index.docbook:77
#, fuzzy, no-c-format
msgid "Cancel"
msgstr "Zrušiť"

#. Tag: para
#: index.docbook:79
#, no-c-format
msgid "Click this button to cancel the current camera operation."
msgstr "Kliknutím na toto tlačidlo zrušíte aktuálnu operáciu fotoaparátu."

#. Tag: para
#: index.docbook:85
#, no-c-format
msgid ""
"To view and download images from the digital camera, enter "
"<userinput>camera:/</userinput> in &konqueror;&apos;s or &dolphin;&apos;s "
"location bar."
msgstr ""
