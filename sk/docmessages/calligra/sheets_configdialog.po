#. Tag: phrase
#: configdialog.docbook:321
#, no-c-format
msgid "Author Configuration."
msgstr ""

#. Tag: para
#: configdialog.docbook:325
#, no-c-format
msgid "Choose an author profile for your document."
msgstr ""

#. Tag: para
#: configdialog.docbook:328
#, no-c-format
