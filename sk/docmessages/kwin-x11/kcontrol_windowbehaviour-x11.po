#: index.docbook:1078
#, no-c-format
msgid "Random"
msgstr ""

#. Tag: para
#: index.docbook:1080
#, no-c-format
msgid "Will place all new windows in random locations."
msgstr ""

#. Tag: guilabel
#: index.docbook:1087
#, no-c-format
msgid "Centered"
msgstr ""

#. Tag: para
#: index.docbook:1089
#, no-c-format
msgid "Will place all new windows in the center of the screen."
msgstr ""

#. Tag: guilabel
#: index.docbook:1096
#, no-c-format
msgid "In Top-Left Corner"
msgstr ""

#. Tag: para
#: index.docbook:1098
#, no-c-format
msgid ""
"Will place all new windows with their top left corner in the top left corner "
"of the screen."
msgstr ""

