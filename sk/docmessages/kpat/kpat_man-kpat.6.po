msgid ""
"<command>kpat</command> <group choice=\"opt\"><option>--solvegame</option> "
"<replaceable> file</replaceable></group> <group choice=\"opt\"><option>--"
"solve</option> <replaceable> num</replaceable></group> <group choice=\"opt"
