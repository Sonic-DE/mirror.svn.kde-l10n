#: index.docbook:193
#, no-c-format
msgid "Reset Parameter"
msgstr "Obnoviť parameter"

#. Tag: para
#: index.docbook:195
#, no-c-format
msgid "Reverts any unsaved changes you have made to this parameter."
msgstr ""

