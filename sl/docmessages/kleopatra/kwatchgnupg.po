#~ msgid ""
#~ "&watchgnupg; is the process that actually monitors the logging socket for "
#~ "activity and formats the lines as seen in the &kwatchgnupg; text view. "
#~ "Settings in this group are passed down to the backend using the &gpgconf; "
#~ "mechanism."
#~ msgstr ""
#~ "&watchgnupg; je proces, ki dejansko nadzira aktivnost vtiča za beleženje "
#~ "in oblikuje vrstice, kot je prikazano v datoteki &kwatchgnupg; pogled "
#~ "besedila. Nastavitve v tej skupini se prenesejo v zaledje z uporabo "
#~ "&gpgconf; mehanizma."

#~ msgid ""
#~ "<guilabel>Executable</guilabel> contains the path to the &watchgnupg; "
#~ "application. If &watchgnupg; is in your <varname>$PATH</varname>, you can "
#~ "keep the default <userinput>watchgnupg</userinput>. If &watchgnupg; is "
#~ "not in your <varname>$PATH</varname>, or if you have more than one "
#~ "version installed, enter the absolute filename of the watchgnupg "
#~ "executable here."
#~ msgstr ""
#~ "<guilabel>Izvedljiva</guilabel> vsebuje pot do datoteke &watchgnupg; "
#~ "aplikacije. Če je &watchgnupg; v vašem <varname>$PATH</varname>, lahko "
#~ "obdržite privzeti <userinput>watchgnupg</userinput>. Če &watchgnupg; ni v "
#~ "vašem <varname>$PATH</varname> ali če imate nameščeno več kot eno "
#~ "različico, tukaj vnesite absolutno ime datoteke izvršljive datoteke "
#~ "watchgnupg."

#~ msgid ""
#~ "<guilabel>Socket</guilabel> contains the socket that &watchgnupg; should "
#~ "listen on. A change here is distributed to all &gnupg; backend modules "
#~ "using &gpgconf;, so you don't need to change this setting if your &gnupg; "
#~ "config files have another <varname>log-file</varname> set."
#~ msgstr ""
#~ "<guilabel>Vtič</guilabel> vsebuje vtič, ki ga bi &watchgnupg; moral "
#~ "poslušati. Sprememba tukaj je razdeljena vsem &gnupg; zalednim modulom, "
#~ "ki uporabljajo &gpgconf;, zato vam te nastavitve ni treba spreminjati, če "
#~ "imajo vaše &gnupg; konfiguracijske datoteke nastavljeno drugo "
#~ "<varname>log-datoteko</varname>."

#~ msgid ""
#~ "<guilabel>Default log level</guilabel> determines the amount of logging "
#~ "information returned by the backend modules. See the &watchgnupg; "
#~ "documentation for what level includes which information. A change here is "
#~ "distributed to all &gnupg; backend modules using &gpgconf;, so you don't "
#~ "need to change this setting if your &gnupg; config files have another "
#~ "<varname>log-level</varname> set."
#~ msgstr ""
#~ "<guilabel>Privzeta raven dnevnika</guilabel> določa količino zapisovalnih "
#~ "informacij, ki jih vrnejo zaledni moduli. Oglejte si &watchgnupg; "
#~ "dokumentacijo za katero raven vključuje katere informacije. Sprememba "
#~ "tukaj je razdeljena vsem &gnupg; zalednim modulom, ki uporabljajo "
#~ "&gpgconf;, zato vam te nastavitve ni treba spreminjati, če imajo vaše "
#~ "&gnupg; konfiguracijske datoteke drug nastavljen set <varname>na ravni "
#~ "dnevnika</varname>."

