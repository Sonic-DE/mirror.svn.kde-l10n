msgstr "Začne novo igro."

#. Tag: menuchoice
#: index.docbook:143
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;&End;</keycombo></shortcut> "
"<guimenu>Game</guimenu> <guimenuitem>End Game</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;&End;</keycombo></shortcut> "
"<guimenu>Igra</guimenu> <guimenuitem>Končaj igro</guimenuitem>"

#. Tag: action
#: index.docbook:148
#, no-c-format
msgid "Ends a running game."
msgstr "Konča tekočo igro."

#. Tag: menuchoice
#: index.docbook:151
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>H</keycap></keycombo></"
"shortcut> <guimenu>Game</guimenu> <guimenuitem>Show High Scores…</"
