#. Tag: title
#: settings.docbook:2
#, no-c-format
msgid "Settings"
msgstr "Nastavitve"

#. Tag: title
#: settings.docbook:5
#, no-c-format
msgid "<title>General Settings</title>"
msgstr "<title>Splošne nastavitve</title>"

#. Tag: screeninfo
#: settings.docbook:8
#, no-c-format
msgid "<screeninfo>General Settings</screeninfo>"
msgstr "<screeninfo>Splošne nastavitve</screeninfo>"

#. Tag: phrase
#: settings.docbook:14
#, no-c-format
msgid "<phrase>Options for the General Settings in &umbrello;</phrase>"
msgstr "<phrase>Možnosti za splošne nastavitve v &umbrello;</phrase>"

#. Tag: para
#: settings.docbook:17
#, no-c-format
msgid "<para>Options for the General Settings in &umbrello;</para>"
msgstr "<para>Možnosti za splošne nastavitve v &umbrello;</para>"

#. Tag: title
#: settings.docbook:25
#, no-c-format
msgid "Miscellaneous"
msgstr "Razno"

#. Tag: para
#: settings.docbook:28
#, no-c-format
msgid ""
"The option <guilabel>Enable undo</guilabel> allows undoing a previous action."
msgstr ""
"Možnost <guilabel>Omogoči razveljavitev</guilabel> omogoča razveljavitev "
"prejšnjega dejanja."

#. Tag: para
#: settings.docbook:30
#, no-c-format
msgid ""
"<guilabel>Use new C++/Java/Ruby generators</guilabel> lets the user select "
"either the old or new code generators"
msgstr ""
"<guilabel>Uporabi nove generatorje C++/Java/Ruby</guilabel> omogoča "
"uporabniku izbiro starih ali novih generatorjev kode"

#. Tag: para
#: settings.docbook:33
#, no-c-format
msgid ""
"<guilabel>Turn on footer and page numbers when printing</guilabel> when "
"selected, prints diagram information for the diagram being printed and the "
"page number."
msgstr ""
"<guilabel>Vklopi nogo in številke strani pri tiskanju</guilabel> ko je "
"izbrana, natisne informacije o diagramu za diagram, ki se tiska, in številko "
"strani."

#. Tag: para
#: settings.docbook:36
#, no-c-format
msgid ""
"<guilabel>Use tabbed diagrams</guilabel> gives the option of having multiple "
"tabbed diagram windows open at a time."
msgstr ""
"<guilabel>Uporaba diagramov z zavihki</guilabel> daje možnost, da imate "
"hkrati odprtih več oken diagramov z zavihki."

#. Tag: title
#: settings.docbook:45
#, no-c-format
msgid "Autosave"
msgstr "Samodejno shranjevanje"

#. Tag: para
#: settings.docbook:47
#, no-c-format
msgid ""
"<guilabel>Enable autosave</guilabel> gives a choice to autosave the file."
msgstr ""
"<guilabel>Omogoči samodejno shranjevanje</guilabel> omogoča izbiro "
"samodejnega shranjevanja datoteke."

#. Tag: para
#: settings.docbook:49
#, no-c-format
msgid ""
"<guilabel>Select auto-save time interval (mins):</guilabel> allows setting "
"the time before the file is autosaved."
msgstr ""
"<guilabel>Izberi časovni interval samodejnega shranjevanja (min):</guilabel> "
"omogoča nastavitev časa, preden se datoteka samodejno shrani."

#. Tag: para
#: settings.docbook:52
#, no-c-format
msgid ""
"<guilabel>Set autosave suffix:</guilabel> defaults to .xmi but allows a "
"different file extension to be set."
msgstr ""
"<guilabel>Nastavi pripono za samodejno shranjevanje:</guilabel> je privzeto "
"nastavljena na .xmi, vendar dovoljuje nastavitev druge datotečne pripone."

#. Tag: title
#: settings.docbook:60
#, no-c-format
msgid "Startup"
msgstr "Začetek"

#. Tag: para
#: settings.docbook:62
#, no-c-format
msgid ""
"<guilabel>Load last project</guilabel> if set, always loads the last work "
"project upon program startup."
msgstr ""
"<guilabel>Naloži zadnji projekt</guilabel>, če je nastavljeno, vedno naloži "
"zadnji delovni projekt ob zagonu programa."

#. Tag: para
#: settings.docbook:65
#, no-c-format
msgid ""
"<guilabel>Start new project with:</guilabel> gives a choice of which UML "
"diagram type to start with in a new project."
msgstr ""
"<guilabel>Začni nov projekt z:</guilabel> omogoča izbiro, s katero vrsto "
"diagrama UML začeti v novem projektu."

#. Tag: para
#: settings.docbook:68
#, no-c-format
msgid ""
"<guilabel>Default Language:</guilabel> is a setting for the default "
"programming language used."
msgstr ""
"<guilabel>Privzeti jezik:</guilabel> je nastavitev za uporabljeni privzeti "
"programski jezik."

#. Tag: title
#: settings.docbook:75
#, no-c-format
msgid "Notifications"
msgstr "Obvestila"

#. Tag: para
#: settings.docbook:77
#, no-c-format
msgid ""
"<guilabel>Enable all messages</guilabel> is an option to either see all "
"notifications or a reduced set of notifications."
msgstr ""
"<guilabel>Omogoči vsa sporočila</guilabel> je možnost za ogled vseh obvestil "
"ali zmanjšanega nabora obvestil."

#. Tag: para
#: settings.docbook:80
#, no-c-format
msgid ""
"<guilabel>Enable 'delete association' related messages</guilabel> ensures "
"that you will receive all messages of this type if checked."
msgstr ""
"<guilabel>Omogoči 'izbriši povezavo' povezana sporočila</guilabel> "
"zagotavlja, da boste prejeli vsa sporočila te vrste, če je označeno."

#. Tag: para
#: settings.docbook:83
#, no-c-format
msgid ""
"<guilabel>Enable 'delete diagram' related messages</guilabel> will enable "
"all messages of this type if checked."
msgstr ""
"<guilabel>Omogoči 'izbriši diagram' povezana sporočila</guilabel> bo "
"omogočila vsa sporočila te vrste, če je označeno."

#. Tag: title
#: settings.docbook:93
#, no-c-format
msgid "<title>Font Settings</title>"
msgstr "<title>Nastavitve pisave</title>"

#. Tag: screeninfo
#: settings.docbook:96
#, no-c-format
msgid "<screeninfo>Font Settings</screeninfo>"
msgstr "<screeninfo>Nastavitve pisave</screeninfo>"

#. Tag: phrase
#: settings.docbook:102
#, no-c-format
msgid "<phrase>Options for the Diagram Font Settings in &umbrello;</phrase>"
msgstr "<phrase>Možnosti za nastavitve pisave diagrama v &umbrello;</phrase>"

#. Tag: para
#: settings.docbook:105
#, no-c-format
msgid "<para>Options for the Diagram Font Settings in &umbrello;</para>"
msgstr "<para>Možnosti za nastavitve pisave diagrama v &umbrello;</para>"

#. Tag: para
#: settings.docbook:112
#, no-c-format
msgid ""
"These font settings set the characteristics of the text in the diagrams. "
"Font style and size are the only selectable options."
msgstr ""
"Te nastavitve pisave določajo značilnosti besedila v diagramih. Slog in "
"velikost pisave sta edini izbirni možnosti."

#. Tag: title
#: settings.docbook:118
#, no-c-format
msgid "<title>User Interface Settings</title>"
msgstr "<title>Nastavitve uporabniškega vmesnika</title>"

#. Tag: screeninfo
#: settings.docbook:121
#, no-c-format
msgid "<screeninfo>User Interface Settings</screeninfo>"
msgstr "<screeninfo>Nastavitve uporabniškega vmesnika</screeninfo>"

#. Tag: phrase
#: settings.docbook:127
#, no-c-format
msgid "<phrase>Options for the User Interface Settings in &umbrello;</phrase>"
msgstr ""
"<phrase>Možnosti za nastavitve uporabniškega vmesnika v &umbrello;</phrase>"

#. Tag: para
#: settings.docbook:130
#, no-c-format
msgid "<para>Options for the User Interface Settings in &umbrello;</para>"
msgstr ""
"<para>Možnosti za nastavitve uporabniškega vmesnika v &umbrello;</para>"

#. Tag: title
#: settings.docbook:138 settings.docbook:391
#, no-c-format
msgid "General"
msgstr "Splošno"

#. Tag: para
#: settings.docbook:139
#, no-c-format
msgid ""
"<guilabel>Right to left user interface</guilabel> configures the interface "
"for the right to left languages."
msgstr ""
"<guilabel>Uporabniški vmesnik od desne proti levi</guilabel> konfigurira "
"vmesnik za jezike od desne proti levi."

#. Tag: title
#: settings.docbook:145
#, no-c-format
msgid "Associations"
msgstr "Asociacije"

#. Tag: para
#: settings.docbook:146
#, no-c-format
msgid ""
"<guilabel>Create new association lines as:</guilabel> gives the ability to "
"change the association line style."
msgstr ""
"<guilabel>Ustvari nove asociacijske črte kot:</guilabel> daje možnost "
"spreminjanja sloga asociacijskih črt."

#. Tag: title
#: settings.docbook:152
#, no-c-format
msgid "Color"
msgstr "Barva"

#. Tag: para
#: settings.docbook:153
#, no-c-format
msgid ""
"The color section gives several options to change the text, line, fill, grid "
"and background colors as well as the line width."
msgstr ""
"Oddelek za barve ponuja več možnosti za spreminjanje besedila, črt, barv "
"polnila, mreže in ozadja ter širine črt."

#. Tag: title
#: settings.docbook:160
#, no-c-format
msgid "<title>Class Settings</title>"
msgstr "<title>Nastavitve razreda</title>"

#. Tag: screeninfo
#: settings.docbook:163
#, no-c-format
msgid "<screeninfo>Class Settings</screeninfo>"
msgstr "<screeninfo>Nastavitve razreda</screeninfo>"

#. Tag: phrase
#: settings.docbook:169
#, no-c-format
msgid "<phrase>Options for the Class Settings in &umbrello;</phrase>"
msgstr "<phrase>Možnosti za nastavitve razreda v &umbrello;</phrase>"

#. Tag: para
#: settings.docbook:172
#, no-c-format
msgid "<para>Options for the Class Settings in &umbrello;</para>"
msgstr "<para>Možnosti za nastavitve razreda v &umbrello;</para>"

#. Tag: title
#: settings.docbook:180
#, no-c-format
msgid "Show"
msgstr "Pokaži"

#. Tag: para
#: settings.docbook:181
#, no-c-format
msgid ""
"The Show section has numerous settings that determine which class "
"characteristics are shown in the Class Diagram."
msgstr ""
"Razdelek Pokaži ima številne nastavitve, ki določajo, katere značilnosti "
"razreda so prikazane v diagramu razreda."

#. Tag: title
#: settings.docbook:186
#, no-c-format
msgid "Starting Scope"
msgstr "Začetni obseg"

#. Tag: para
#: settings.docbook:187
#, no-c-format
msgid ""
"Choices for attribute and operation default settings, public, private or "
"protected."
msgstr ""
"Možnosti privzetih nastavitev atributov in operacij, javne, zasebne ali "
"zaščitene."

#. Tag: title
#: settings.docbook:194
#, no-c-format
msgid "<title>Code Import Settings</title>"
msgstr "<title>Nastavitve uvoza kode</title>"

#. Tag: screeninfo
#: settings.docbook:197
#, no-c-format
msgid "<screeninfo>Code Import Settings</screeninfo>"
msgstr "<screeninfo>Nastavitve uvoza kode</screeninfo>"

#. Tag: phrase
#: settings.docbook:203
#, no-c-format
msgid "<phrase>Options for the Code Import Settings in &umbrello;</phrase>"
msgstr "<phrase>Možnosti za nastavitve uvoza kode v &umbrello;</phrase>"

#. Tag: para
#: settings.docbook:206
#, no-c-format
msgid "<para>Options for the Code Import Settings in &umbrello;</para>"
msgstr "<para>Možnosti za nastavitve uvoza kode v &umbrello;</para>"

#. Tag: title
#: settings.docbook:214
#, no-c-format
msgid "Include Search Paths"
msgstr "Vključi iskalne poti"

#. Tag: para
#: settings.docbook:215
#, no-c-format
msgid ""
"A general recommendation is given to improve searching by including UMBRELLO "
"INCPATH as an environment variable."
msgstr ""
"Podano je splošno priporočilo za izboljšanje iskanja z vključitvijo UMBRELLO "
"INCPATH kot spremenljivke okolja."

#. Tag: title
#: settings.docbook:220
#, no-c-format
msgid "C++-Import"
msgstr "C++-Uvoz"

#. Tag: para
#: settings.docbook:223
#, no-c-format
msgid ""
"<guilabel>For each imported file create an artifact in the component view</"
"guilabel> The artifact created can then be dragged into the Class Diagram "
"view where dependencies can be easily seen along with the attributes and "
"functions of each file."
msgstr ""
"<guilabel>Za vsako uvoženo datoteko ustvarite artefakt v pogledu komponent</"
"guilabel> Ustvarjeni artefakt lahko nato povlečete v pogled diagrama "
"razredov, kjer so odvisnosti zlahka vidne skupaj z atributi in funkcijami "
"vsake datoteke."

#. Tag: para
#: settings.docbook:230
#, no-c-format
msgid ""
"<guilabel>Resolve dependencies (reduces import speed)</guilabel> Ensures all "
"file dependencies are resolved which then shows up in class dependencies in "
"the Class Diagram."
msgstr ""
"<guilabel>Razreši odvisnosti (zmanjša hitrost uvoza)</guilabel> Zagotovi, da "
"so razrešene vse odvisnosti datotek, kar se nato prikaže v odvisnostih "
"razreda v diagramu razredov."

#. Tag: para
#: settings.docbook:235
#, no-c-format
msgid ""
"<guilabel>Enable C++11 standard (experimental)</guilabel> An experimental "
"feature to conform to C++11, disable if not needed."
msgstr ""
"<guilabel>Omogoči standard C++11 (eksperimentalno)</guilabel> "
"Eksperimentalna funkcija za skladnost s C++11, onemogočite, če ni potrebna."

#. Tag: title
#: settings.docbook:246
#, no-c-format
msgid "Code Generation Settings"
msgstr "Nastavitve generiranja kode"

#. Tag: title
#: settings.docbook:249
#, no-c-format
msgid "Code Generation Settings General Tab"
msgstr "Nastavitve generiranja kode Zavihek Splošno"

#. Tag: screeninfo
#: settings.docbook:253
#, no-c-format
msgid "Code Generation General Settings"
msgstr "Splošne nastavitve za ustvarjanje kode"

#. Tag: phrase
#: settings.docbook:259
#, no-c-format
msgid ""
"<phrase>Options for the Code Generation General Settings in &umbrello;</"
"phrase>"
msgstr ""
"<phrase>Možnosti za splošne nastavitve generiranja kode v &umbrello;</phrase>"

#. Tag: para
#: settings.docbook:262
#, no-c-format
msgid ""
"<para>Options for the Code Generation General Settings in &umbrello;</para>"
msgstr ""
"<para>Možnosti za splošne nastavitve generiranja kode v &umbrello;</para>"

#. Tag: para
#: settings.docbook:269
#, no-c-format
msgid ""
"Umbrello UML Modeller can generate source code for various programming "
"languages based on your UML Model to help you get started with the "
"implementation of your project. The code generated consists of the class "
"declarations, with their methods and attributes so you can \"fill in the "
"blanks\" by providing the functionality of your classes' operations."
msgstr ""
"Umbrello UML Modeller lahko ustvari izvorno kodo za različne programske "
"jezike, ki temeljijo na vašem modelu UML, da vam pomaga pri začetku "
"izvajanja vašega projekta. Ustvarjena koda je sestavljena iz deklaracij "
"razredov z njihovimi metodami in atributi, tako da lahko \"zapolnite praznine"
"\" z zagotavljanjem funkcionalnosti operacij vaših razredov."

#. Tag: title
#: settings.docbook:276
#, no-c-format
msgid "Language"
msgstr "Jezik"

#. Tag: para
#: settings.docbook:277
#, no-c-format
msgid ""
"Choose the programming language to use for projects. The choices offered are "
"ActionScript, Ada, C++, C#, D, IDL, Java, JavaScript, MYSQL, Pascal, Perl, "
"PHP, PHP5, PastgreSQL, Python, Ruby, SQL, Tcl, Vala and XMLSchema"
msgstr ""
"Izberite programski jezik za uporabo pri projektih. Na voljo so "
"ActionScript, Ada, C++, C#, D, IDL, Java, JavaScript, MYSQL, Pascal, Perl, "
"PHP, PHP5, PastgreSQL, Python, Ruby, SQL, Tcl, Vala in XMLSchema"

#. Tag: title
#: settings.docbook:284
#, no-c-format
msgid "Folders"
msgstr "Mape"

#. Tag: para
#: settings.docbook:285
#, no-c-format
msgid ""
"<guilabel>Write all generated files to folder:</guilabel> has an editable "
"field for the desired path for generated files or optionally a browse button "
"to select the path."
msgstr ""
"<guilabel>Zapiši vse ustvarjene datoteke v mapo:</guilabel> ima polje za "
"urejanje želene poti do ustvarjenih datotek ali izbirno gumb za brskanje za "
"izbiro poti."

#. Tag: para
#: settings.docbook:288
#, no-c-format
msgid ""
"<guilabel>Include heading files from folder:</guilabel> if checked, lets the "
"user specify a path in an editable field or choose it with a browse button."
msgstr ""
"<guilabel>Vključi datoteke z naslovi iz mape:</guilabel> če je označeno, "
"uporabniku omogoča, da določi pot v polju za urejanje ali jo izbere z gumbom "
"za brskanje."

#. Tag: title
#: settings.docbook:295
#, no-c-format
msgid "Overwrite Policy"
msgstr "Politika prepisovanja"

#. Tag: para
#: settings.docbook:296
#, no-c-format
msgid ""
"When the code is generated into the specified folder, this setting "
"determines what happens if a file with the same name is encountered."
msgstr ""
"Ko je koda ustvarjena v podani mapi, ta nastavitev določa, kaj se zgodi, če "
"se najde datoteka z enakim imenom."

#. Tag: para
#: settings.docbook:301
#, no-c-format
msgid "<guilabel>Overwrite</guilabel> the file without a warning or option."
msgstr "<guilabel>Prepiši</guilabel> datoteko brez opozorila ali možnosti."

#. Tag: para
#: settings.docbook:304
#, no-c-format
msgid "<guilabel>Ask</guilabel> whether to overwrite the file or rename it."
msgstr ""
"<guilabel>Vprašajte</guilabel>, ali želite prepisati datoteko ali jo "
"preimenovati."

#. Tag: para
#: settings.docbook:307
#, no-c-format
msgid ""
"<guilabel>Use a different name</guilabel> when a file already exists by "
"renaming it using a suffix."
msgstr ""
"<guilabel>Uporabite drugo ime</guilabel>, ko datoteka že obstaja, tako da jo "
"preimenujete s pripono."

#. Tag: title
#: settings.docbook:318
#, no-c-format
msgid "Code Generation Settings Formatting Tab"
msgstr "Zavihek Nastavitve generiranja kode Oblikovanje"

#. Tag: screeninfo
#: settings.docbook:321
#, no-c-format
msgid "Code Generation Formatting Settings"
msgstr "Nastavitve oblikovanja za ustvarjanje kode"

#. Tag: phrase
#: settings.docbook:327
#, no-c-format
msgid ""
"<phrase>Options for the Code Generation Formatting Settings in &umbrello;</"
"phrase>"
msgstr ""
"<phrase>Možnosti za nastavitve oblikovanja za ustvarjanje kode v &umbrello;</"
"phrase>"

#. Tag: para
#: settings.docbook:330
#, no-c-format
msgid ""
"<para>Options for the Code Generation Formatting Settings in &umbrello;</"
"para>"
msgstr ""
"<para>Možnosti za nastavitve oblikovanja za ustvarjanje kode v &umbrello;</"
"para>"

#. Tag: title
#: settings.docbook:338
#, no-c-format
msgid "Comment Verbosity"
msgstr "Besedljivost komentarja"

#. Tag: para
#: settings.docbook:339
#, no-c-format
msgid ""
"<guilabel>Write documentation comments even if empty</guilabel> Generates "
"comments for classes and functions even if they are empty."
msgstr ""
"<guilabel>Pisanje komentarjev dokumentacije, tudi če so prazni</guilabel> "
"Ustvari komentarje za razrede in funkcije, tudi če so prazni."

#. Tag: para
#: settings.docbook:341
#, no-c-format
msgid ""
"<guilabel>Write section comments</guilabel> allow users to choose whether to "
"write section comments. The possible values are: None, When section is non "
"empty, Always."
msgstr ""
"<guilabel>Napiši komentarje razdelkov</guilabel> uporabnikom omogoča, da "
"izberejo, ali želijo napisati komentarje razdelkov. Možne vrednosti so: "
"Brez, Ko razdelek ni prazen, Vedno."

#. Tag: title
#: settings.docbook:347
#, no-c-format
msgid "Lines"
msgstr "Črte"

#. Tag: para
#: settings.docbook:348
#, no-c-format
msgid ""
"<guilabel>Indentation type:</guilabel> offers a choice between no "
"indentation, tab or space."
msgstr ""
"<guilabel>Vrsta zamika:</guilabel> ponuja izbiro med brez zamika, "
"tabulatorjem ali presledkom."

#. Tag: para
#: settings.docbook:350
#, no-c-format
msgid ""
"<guilabel>Indentation amount:</guilabel> lets the user specify the number of "
"spaces for the tab or space indentation choice."
msgstr ""
"<guilabel>Količina zamika:</guilabel> omogoča uporabniku, da določi število "
"presledkov za izbiro zamika tabulatorja ali presledka."

#. Tag: para
#: settings.docbook:352
#, no-c-format
msgid ""
"<guilabel>Line ending style:</guilabel> is a choice between the line ending "
"styles of *NIX, Windows and Mac."
msgstr ""
"<guilabel>Slog konca vrstice:</guilabel> je izbira med slogi konca vrstice "
"*NIX, Windows in Mac."

#. Tag: title
#: settings.docbook:359
#, no-c-format
msgid "Language Options"
msgstr "Jezikovne možnosti"

#. Tag: screeninfo
#: settings.docbook:362
#, no-c-format
msgid "Code Generation Language Options"
msgstr "Možnosti jezika za ustvarjanje kode"

#. Tag: phrase
#: settings.docbook:368
#, no-c-format
msgid ""
"<phrase>Options for the Code Generation Language Settings in &umbrello;</"
"phrase>"
msgstr ""
"<phrase>Možnosti za jezikovne nastavitve za generiranje kode v &umbrello;</"
"phrase>"

#. Tag: para
#: settings.docbook:371
#, no-c-format
msgid ""
"<para>Options for the Code Generation Language Settings in &umbrello;</para>"
msgstr ""
"<para>Možnosti za jezikovne nastavitve za generiranje kode v &umbrello;</"
"para>"

#. Tag: para
#: settings.docbook:377
#, no-c-format
msgid ""
"This page changes for each programming language selected under the General "
"tab. Currently the only options available are for the C++ language."
msgstr ""
"Ta stran se spremeni za vsak programski jezik, izbran pod zavihkom Splošno. "
"Trenutno so na voljo edine možnosti za jezik C++."

#. Tag: title
#: settings.docbook:381
#, no-c-format
msgid "C++ Code Generation"
msgstr "Generiranje kode C++"

#. Tag: title
#: settings.docbook:385
#, no-c-format
msgid "Documentation"
msgstr "Dokumentacija"

#. Tag: para
#: settings.docbook:386
#, no-c-format
msgid ""
"<guilabel>Style:</guilabel> gives a choice to use either \"/** */\" or \"//"
"\" as the documentation style"
msgstr ""
"<guilabel>Slog:</guilabel> omogoča izbiro uporabe \"/** */\" ali \"//\" kot "
"sloga dokumentacije"

#. Tag: para
#: settings.docbook:392
#, no-c-format
msgid ""
"Under the <guilabel>General</guilabel> tab of the <guilabel>Language "
"Options</guilabel> tab, several code generation options are listed."
msgstr ""
"Pod zavihkom <guilabel>Splošno</guilabel> na zavihku <guilabel>Jezikovne "
"možnosti</guilabel> je navedenih več možnosti generiranja kode."

#. Tag: guilabel
#: settings.docbook:396
#, no-c-format
msgid "Class member prefix"
msgstr "Predpona člana razreda"

#. Tag: para
#: settings.docbook:397
#, no-c-format
msgid ""
"An option that allows a prefix determined by the user, to be added to class "
"members when code is generated."
msgstr ""
"Možnost, ki omogoča dodajanje predpone, ki jo določi uporabnik, članom "
"razreda, ko se ustvari koda."

#. Tag: guilabel
#: settings.docbook:401
#, no-c-format
msgid "Package is a namespace"
msgstr "Paket je imenski prostor"

#. Tag: para
#: settings.docbook:402
#, no-c-format
msgid ""
"Namespaces provide a method for preventing name conflicts in large projects. "
"Symbols declared inside a namespace block are placed in a named scope that "
"prevents them from being mistaken for identically-named symbols in other "
"scopes."
msgstr ""
"Imenski prostori zagotavljajo metodo za preprečevanje konfliktov imen v "
"velikih projektih. Simboli, deklarirani znotraj bloka imenskega prostora, so "
"postavljeni v poimenovan obseg, ki preprečuje, da bi jih zamenjali za enako "
"imenovane simbole v drugih obsegih."

#. Tag: guilabel
#: settings.docbook:408
#, no-c-format
msgid "Virtual destructors"
msgstr "Virtualni destruktorji"

#. Tag: para
#: settings.docbook:409
#, no-c-format
msgid ""
"Even though destructors are not inherited, if a base class declares its "
"destructor virtual, the derived destructor always overrides it. This makes "
"it possible to delete dynamically allocated objects of polymorphic type "
"through pointers to base."
msgstr ""
"Čeprav destruktorji niso podedovani, če osnovni razred svoj destruktor "
"razglasi za navideznega, ga izpeljani destruktor vedno preglasi. To omogoča "
"brisanje dinamično dodeljenih objektov polimorfnega tipa prek kazalcev na "
"bazo."

#. Tag: guilabel
#: settings.docbook:416
#, no-c-format
msgid "Generate empty constructors"
msgstr "Ustvarite prazne konstruktorje"

#. Tag: para
#: settings.docbook:417
#, no-c-format
msgid "This will generate constructors that have empty braces."
msgstr "To bo ustvarilo konstruktorje s praznimi oklepaji."

#. Tag: guilabel
#: settings.docbook:420
#, no-c-format
msgid "Generate accessor methods"
msgstr "Ustvari metode dostopnika"

#. Tag: para
#: settings.docbook:421
#, no-c-format
msgid "Will generate methods to access datatypes."
msgstr "Ustvaril bo metode za dostop do podatkovnih vrst."

#. Tag: guilabel
#: settings.docbook:424
#, no-c-format
msgid "Operations are inline"
msgstr "Operacije so znorajvrstične"

#. Tag: para
#: settings.docbook:425
#, no-c-format
msgid ""
"Generate the methods as inline, but compilers are free to choose not to "
"inline the method."
msgstr ""
"Generirajte metode kot vgrajene, vendar se lahko prevajalniki odločijo, da "
"metode ne bodo vdelane."

#. Tag: guilabel
#: settings.docbook:429
#, no-c-format
msgid "Accessors are inline"
msgstr "Pripomočki so znotrajvrstični"

#. Tag: para
#: settings.docbook:430
#, no-c-format
msgid ""
"Methods that access the class' data will be generated inline, but compilers "
"are free to choose not to inline the method."
msgstr ""
"Metode, ki dostopajo do podatkov razreda, bodo ustvarjene v vrstici, vendar "
"se lahko prevajalniki odločijo, da metode ne bodo vdelali."

#. Tag: guilabel
#: settings.docbook:435
#, no-c-format
msgid "Accessors are public"
msgstr "Dostopniki so javni"

#. Tag: para
#: settings.docbook:436
#, no-c-format
msgid ""
"Methods that are generated as public will be available to any instantiation "
"of the class."
msgstr ""
"Metode, ki so ustvarjene kot javne, bodo na voljo kateri koli primerku "
"razreda."

#. Tag: guilabel
#: settings.docbook:440
#, no-c-format
msgid "Create getters with 'get' prefix"
msgstr "Ustvarite getterje s predpono 'get'"

#. Tag: para
#: settings.docbook:441
#, no-c-format
msgid ""
"This will put the prefix \"get\" on the methods that get/return the class "
"data."
msgstr ""
"S tem boste metodam, ki dobijo/vrnejo podatke razreda, dodali predpono \"get"
"\"."

#. Tag: guilabel
#: settings.docbook:445
#, no-c-format
msgid "Remove prefix '[a-zA-Z]_' from accessor method names"
msgstr "Odstranite predpono '[a-zA-Z]_' iz imen metod dostopnikov"

#. Tag: para
#: settings.docbook:446
#, no-c-format
msgid ""
"If a prefix was entered in <guilabel>Class member prefix</guilabel>, this "
"will remove it."
msgstr ""
"Če je bila predpona vnesena v <guilabel>Predpona člana razreda</guilabel>, "
"jo boste s tem odstranili."

#. Tag: guilabel
#: settings.docbook:450
#, no-c-format
msgid "Accessor methods start with capital letters"
msgstr "Metode dostopnikov se začnejo z velikimi črkami"

#. Tag: para
#: settings.docbook:451
#, no-c-format
msgid "This capitalizes the first letter of the method name."
msgstr "To naredi prvo črko imena metode z veliko začetnico."

#. Tag: guilabel
#: settings.docbook:454
#, no-c-format
msgid "Use '\\' as documentation tag instead of @"
msgstr "Uporabite '\\' kot oznako dokumentacije namesto @"

#. Tag: para
#: settings.docbook:455
#, no-c-format
msgid "A tag choice to use when documenting parameters of a method."
msgstr "Izbira oznake za uporabo pri dokumentiranju parametrov metode."

#. Tag: title
#: settings.docbook:461
#, no-c-format
msgid "Method Body Generation"
msgstr "Generacija telesa metode"

#. Tag: screeninfo
#: settings.docbook:464
#, no-c-format
msgid "Code Generation Language Method Body Options"
msgstr "Možnosti telesa metode generiranja kode"

#. Tag: phrase
#: settings.docbook:470
#, no-c-format
msgid ""
"<phrase>Options for the Code Generation Language Method Body Settings in "
"&umbrello;</phrase>"
msgstr ""
"<phrase>Možnosti za nastavitve telesa metode generiranja kode v &umbrello;</"
"phrase>"

#. Tag: para
#: settings.docbook:473
#, no-c-format
msgid ""
"<para>Options for the Code Generation Language Method Body Settings in "
"&umbrello;</para>"
msgstr ""
"<para>Možnosti za nastavitve telesa jezika metode generiranja kode v "
"&umbrello;</para>"

#. Tag: guilabel
#: settings.docbook:479
#, no-c-format
msgid "List"
msgstr "Seznam"

#. Tag: para
#: settings.docbook:480
#, no-c-format
msgid ""
"Has options of QPtrList, vector, and std::vector for the list type. An "
"editable or selectable field follows to specify the include file along with "
"a browse button to find a select the include file. There is also an option "
"to make the list global."
msgstr ""
"Ima možnosti QPtrList, vector in std::vector za vrsto seznama. Sledi polje, "
"ki ga je mogoče urejati ali izbrati, da določite vključeno datoteko skupaj z "
"gumbom za brskanje, da poiščete in izberete vključeno datoteko. Obstaja tudi "
"možnost, da seznam postane globalen."

#. Tag: guilabel
#: settings.docbook:484
#, no-c-format
msgid "String"
msgstr "Niz"

#. Tag: para
#: settings.docbook:485
#, no-c-format
msgid ""
"Options of string or QString for the string type. An editable or selectable "
"field follows to specify the include file along with a browse button to find "
"a select the include file. There is also an option to make the string global."
msgstr ""
"Možnosti niza ali QString za vrsto niza. Sledi polje, ki ga je mogoče "
"urejati ali izbrati, da določite vključeno datoteko skupaj z gumbom za "
"brskanje, da poiščete in izberete vključeno datoteko. Obstaja tudi možnost, "
"da niz naredite globalnega."

#. Tag: title
#: settings.docbook:500
#, no-c-format
msgid "<title>Code Viewer Settings</title>"
msgstr "<title>Nastavitve pregledovalnika kode</title>"

#. Tag: screeninfo
#: settings.docbook:503
#, no-c-format
msgid "<screeninfo>Code Viewer Settings</screeninfo>"
msgstr "<screeninfo>Nastavitve pregledovalnika kode</screeninfo>"

#. Tag: phrase
#: settings.docbook:509
#, no-c-format
msgid "<phrase>Options for the Code Viewer Settings in &umbrello;</phrase>"
msgstr ""
"<phrase>Možnosti za nastavitve pregledovalnika kode v &umbrello;</phrase>"

#. Tag: para
#: settings.docbook:512
#, no-c-format
msgid "<para>Options for the Code Viewer Settings in &umbrello;</para>"
msgstr "<para>Možnosti za nastavitve pregledovalnika kode v &umbrello;</para>"

#. Tag: para
#: settings.docbook:518
#, no-c-format
msgid ""
"Allows customization of the Code Viewer. The <guilabel>Requested Font</"
"guilabel> section allows the selection of the font, font style, and font "
"size. A representation of your choices is shown below the choices."
msgstr ""
"Omogoča prilagajanje pregledovalnika kode. Razdelek <guilabel>Zahtevana "
"pisava</guilabel> omogoča izbiro pisave, sloga pisave in velikosti pisave. "
"Predstavitev vaših izbir je prikazana pod možnostmi."

#. Tag: para
#: settings.docbook:522
#, no-c-format
msgid ""
"In the <guilabel>Colors</guilabel> section, changes can be made to Paper, "
"Font, Selected, UML object block, Hidden block, Editable text, and "
"Uneditable text. Changes to the colors can be made by clicking on the color "
"box by the respective label."
msgstr ""
"V razdelku <guilabel>Barve</guilabel> lahko spremenite Papir, Pisavo, "
"Izbrano, Blok predmeta UML, Skrit blok, Besedilo, ki ga je mogoče urejati, "
"in Besedilo, ki ga ni mogoče urejati. Spremembe barv lahko izvedete s klikom "
"na barvno polje ob ustrezni oznaki."

#. Tag: title
#: settings.docbook:530
#, no-c-format
msgid "<title>Auto Layout Settings</title>"
msgstr "<title>Nastavitve samodejne postavitve</title>"

#. Tag: screeninfo
#: settings.docbook:533
#, no-c-format
msgid "<screeninfo>Auto Layout Settings</screeninfo>"
msgstr "<screeninfo>Nastavitve samodejne postavitve</screeninfo>"

#. Tag: phrase
#: settings.docbook:539
#, no-c-format
msgid "<phrase>Options for the Auto Layout Settings in &umbrello;</phrase>"
msgstr ""
"<phrase>Možnosti za nastavitve samodejne postavitve v &umbrello;</phrase>"

#. Tag: para
#: settings.docbook:542
#, no-c-format
msgid "<para>Options for the Auto Layout Settings in &umbrello;</para>"
msgstr "<para>Možnosti za nastavitve samodejne postavitve v &umbrello;</para>"

#. Tag: guilabel
#: settings.docbook:548
#, no-c-format
msgid "Auto detect layout generator"
msgstr "Samodejno zaznaj generator postavitve"

#. Tag: para
#: settings.docbook:549
#, no-c-format
msgid ""
"The auto layout feature depends on layout generators provided by the "
"GraphViz package, which is normally installed alongside Umbrello by a "
"package manager. Umbrello has built-in support for detecting the installed "
"location of these layout generators. For cases where this dependency is not "
"available or does not fit, a different installation path could be selected."
msgstr ""
"Funkcija samodejne postavitve je odvisna od generatorjev postavitev, ki jih "
"zagotavlja paket GraphViz, ki ga upravitelj paketov običajno namesti poleg "
"Umbrella. Umbrello ima vgrajeno podporo za zaznavanje nameščene lokacije teh "
"generatorjev postavitev. V primerih, ko ta odvisnost ni na voljo ali ne "
"ustreza, lahko izberete drugo pot namestitve."

#. Tag: guilabel
#: settings.docbook:556
#, no-c-format
msgid "Show export layout in diagram context menu"
msgstr "Pokaži izvozno postavitev v kontekstnem meniju diagrama"

#. Tag: para
#: settings.docbook:557
#, no-c-format
msgid ""
"Dot file export is performed by using the export layout. With this option "
"checked, the export layout is added to the list of available diagram layouts "
"and enables a quick dot export preview."
msgstr ""
"Izvoz datoteke s pikami se izvede z uporabo izvozne postavitve. Ko je ta "
"možnost izbrana, se izvozna postavitev doda na seznam razpoložljivih "
"postavitev diagramov in omogoči hiter predogled izvoza pik."

