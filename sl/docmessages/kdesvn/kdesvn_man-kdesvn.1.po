#. Tag: title
#: man-kdesvn.1.docbook:39
#, no-c-format
msgid "Description"
msgstr "Opis"

#. Tag: para
#: man-kdesvn.1.docbook:40
#, no-c-format
msgid "<para>A Subversion client by KDE (standalone application)</para>"
msgstr "<para>Odjemalec Subversion iz KDE (samostojna aplikacija)</para>"

#. Tag: title
#: man-kdesvn.1.docbook:43
#, no-c-format
msgid "Options"
msgstr "Možnosti"

#. Tag: title
#: man-kdesvn.1.docbook:45
#, no-c-format
msgid "Arguments:"
msgstr "Argumenti:"

#. Tag: term
#: man-kdesvn.1.docbook:48
#, no-c-format
msgid "<emphasis>exec</emphasis> &lt;command&gt;"
msgstr "<emphasis>exec</emphasis> &lt;command&gt;"

#. Tag: para
#: man-kdesvn.1.docbook:49
#, no-c-format
msgid ""
"Execute subversion command (\"exec help\" for more information, opens KDE "
"Help Center)"
msgstr ""
"Izvedi ukaz subversion (\"exec help\" za več informacij odpre Center za "
"pomoč KDE)"

#. Tag: emphasis
#: man-kdesvn.1.docbook:53
#, no-c-format
msgid "<emphasis>URL</emphasis>"
msgstr "<emphasis>URL</emphasis>"

#. Tag: para
#: man-kdesvn.1.docbook:55
#, no-c-format
msgid "Path to local working copy or a repository."
msgstr "Pot do lokalne delovne kopije ali repozitorija."

#. Tag: title
#: man-kdesvn.1.docbook:61
#, no-c-format
msgid "Options:"
msgstr "Možnosti:"

#. Tag: option
#: man-kdesvn.1.docbook:64
#, no-c-format
msgid "-r startrev[:endrev]"
msgstr "-r startrev[:endrev]"

#. Tag: para
#: man-kdesvn.1.docbook:66
#, no-c-format
msgid "Execute single subversion command on specific revision(-range)"
msgstr "Izvedi posamezen ukaz subverzije na določeni reviziji (-range)"

#. Tag: option
#: man-kdesvn.1.docbook:70
#, no-c-format
msgid "<option>-R</option>"
msgstr "<option>-R</option>"

#. Tag: para
#: man-kdesvn.1.docbook:72
#, no-c-format
msgid "Ask for revision when executing single command"
msgstr "Zahtevaj revizijo pri izvajanju posameznega ukaza"

#. Tag: option
#: man-kdesvn.1.docbook:76
#, no-c-format
msgid "<option>-f</option>"
msgstr "<option>-f</option>"

#. Tag: para
#: man-kdesvn.1.docbook:78
#, no-c-format
msgid "Force operation"
msgstr "Prisili operacijo"

#. Tag: option
#: man-kdesvn.1.docbook:82
#, no-c-format
msgid "-o &lt;file&gt;"
msgstr "-o &lt;file&gt;"

#. Tag: para
#: man-kdesvn.1.docbook:84
#, no-c-format
msgid ""
"Save output of subversion command (eg <quote>cat</quote>) into file &lt;"
"file&gt;"
msgstr ""
"Shrani izhod ukaza subversion (npr. <quote>cat</quote>) v datoteko &lt;"
"file&gt;"

#. Tag: option
#: man-kdesvn.1.docbook:88
#, no-c-format
msgid "-l &lt;number&gt;"
msgstr "-l &lt;number&gt;"

#. Tag: para
#: man-kdesvn.1.docbook:90
#, no-c-format
msgid "Limit log output to &lt;number&gt;"
msgstr "Omeji izpis dnevnika na &lt;number&gt;"

#. Tag: title
#: man-kdesvn.1.docbook:99
#, no-c-format
msgid "Example"
msgstr "Primer"

#. Tag: para
#: man-kdesvn.1.docbook:100
#, no-c-format
msgid "kdesvn file:///<replaceable>path/to/local/working/copy</replaceable>"
msgstr "kdesvn file:///<replaceable>path/to/local/working/copy</replaceable>"

#. Tag: para
#: man-kdesvn.1.docbook:101
#, no-c-format
msgid "kdesvn http://<replaceable>remote/svn/project/trunk</replaceable>"
msgstr "kdesvn http://<replaceable>remote/svn/project/trunk</replaceable>"

#. Tag: title
#: man-kdesvn.1.docbook:105
#, no-c-format
msgid "See Also"
msgstr "Poglejte tudi"

#. Tag: member
#: man-kdesvn.1.docbook:107
#, no-c-format
msgid ""
"Full user documentation is available through the &khelpcenter;. You can also "
"enter the &URL; <emphasis>help:/kdesvn/</emphasis> directly into &konqueror; "
"or you can run <emphasis>`khelpcenter help:/kdesvn/'</emphasis> from the "
"command-line."
msgstr ""
"Celotna uporabniška dokumentacija je na voljo v &khelpcenter;. Vnesete lahko "
"tudi &URL; <emphasis>help:/kdesvn/</emphasis> neposredno v &konqueror; lahko "
"pa zaženete <emphasis>`khelpcenter help:/kdesvn/'</emphasis> iz ukazne "
"vrstice."

