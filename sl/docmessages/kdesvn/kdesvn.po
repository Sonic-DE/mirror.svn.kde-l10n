msgstr "Označite obseg potrditev za datoteko."

#. Tag: menuchoice
#: index.docbook:1858
#, no-c-format
msgid ""
"<guimenu>Subversion</guimenu> <guisubmenu>General</guisubmenu> "
"<guimenuitem>Cat head</guimenuitem>"
msgstr ""
"<guimenu>Subversion</guimenu> <guisubmenu>Splošno</guisubmenu> "
"<guimenuitem>Mačja glava</guimenuitem>"

#. Tag: para
#: index.docbook:1863
#, no-c-format
