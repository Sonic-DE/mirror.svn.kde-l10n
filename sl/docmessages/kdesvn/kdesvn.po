msgstr ""
"Poleg običajnega &kde; Elementi menija <guimenu>Nastavitve</guimenu> in "
"<guimenu>Pomoč</guimenu>, opisani v <ulink url=\"help:/fundamentals/menus."
"html#menus-settings\">meniju z nastavitvami</ulink> in <ulink url=\"help:/"
"fundamentals/menus.html#menus-help\">Meni Pomoč</ulink> v &kde; Osnove "
"&kdesvn; ta dodatni menijski vnos:"

#. Tag: menuchoice
#: index.docbook:2155
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Quick settings</guimenuitem>"
msgstr ""
"<guimenu>Nastavitve</guimenu> <guimenuitem>Hitre nastavitve</guimenuitem>"

#. Tag: guimenuitem
#: index.docbook:2165
#, no-c-format
msgid "Load last opened URL on start"
msgstr "Naloži zadnji odprt URL ob začetku"

#. Tag: para
#: index.docbook:2167
#, no-c-format
msgid "Reload last opened URL if no one is given on command line."
msgstr ""
"Znova naloži nazadnje odprti URL, če v ukazni vrstici ni podanega nobenega."

#. Tag: guimenuitem
#: index.docbook:2173
#, no-c-format
msgid "Logs follow node changes"
msgstr "Dnevniki sledijo spremembam vozlišča"

#. Tag: guimenuitem
#: index.docbook:2181
#, no-c-format
msgid "<guimenuitem>Display ignored files</guimenuitem>"
msgstr "<guimenuitem>Prikaži prezrte datoteke</guimenuitem>"

#. Tag: para
#: index.docbook:2183
#, no-c-format
msgid "<para>Show items marked in subversion for ignore or not.</para>"
msgstr ""
"<para>Prikaži elemente, ki so v Subversion označeni za prezrtje ali ne.</"
"para>"

#. Tag: guimenuitem
#: index.docbook:2189
#, no-c-format
msgid "Display unknown files"
msgstr "Prikaži neznane datoteke"

#. Tag: para
#: index.docbook:2191
#, no-c-format
msgid "Show files not added to the subversion repository."
msgstr "Prikaži datoteke, ki niso bile dodane v repozitorij subversion."

#. Tag: guimenuitem
#: index.docbook:2197
#, no-c-format
msgid "Hide unchanged files"
msgstr "Skrij nespremenjene datoteke"

#. Tag: para
#: index.docbook:2199
#, no-c-format
msgid ""
"Use this action to show only changed files and provide a clear and concise "
"overview."
msgstr ""
"S tem dejanjem prikažete samo spremenjene datoteke in zagotovite jasen in "
"jedrnat pregled."

#. Tag: guimenuitem
#: index.docbook:2205
#, no-c-format
msgid "Work online"
msgstr "Delaj na spletu"

#. Tag: para
#: index.docbook:2207
#, no-c-format
msgid ""
"Working offline the log cache will not be updated, therefore the cached log "
"may differ from real log."
msgstr ""
"Če delate brez povezave, se predpomnilnik dnevnika ne bo posodobil, zato se "
"lahko predpomnjeni dnevnik razlikuje od pravega dnevnika."

