"shortcut> <guimenu>Datoteka</guimenu> <guimenuitem>Zapri</guimenuitem>"

#. Tag: para
#: index.docbook:1793
#, no-c-format
msgid "<action>Quits</action> &kdesvn;"
msgstr "<action>Zapusti</action> &kdesvn;"

#. Tag: title
