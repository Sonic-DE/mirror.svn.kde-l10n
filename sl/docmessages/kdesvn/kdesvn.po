"<guimenuitem>Checkout a repository</guimenuitem>"
msgstr ""
"<guimenu>Subversion</guimenu> <guisubmenu>Splošno</guisubmenu> "
"<guimenuitem>Preveri repozitorij</guimenuitem>"

#. Tag: para
#: index.docbook:1914
