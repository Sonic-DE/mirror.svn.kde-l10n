msgstr "Odprite okno z novim pojavkom &kdesvn;"

#. Tag: menuchoice
#: index.docbook:1757
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Subversion Admin</guimenuitem>"
msgstr ""
"<guimenu>Datoteka</guimenu> <guimenuitem>Skrbnik za Subversion</guimenuitem>"

#. Tag: para
#: index.docbook:1761
#, no-c-format
