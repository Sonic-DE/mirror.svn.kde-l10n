msgid "Creates a new working copy of a repository"
msgstr "Ustvari novo delovno kopijo repozitorija"

#. Tag: menuchoice
#: index.docbook:1917
#, no-c-format
msgid ""
"<guimenu>Subversion</guimenu> <guisubmenu>General</guisubmenu> "
"<guimenuitem>Export a repository</guimenuitem>"
msgstr ""
"<guimenu>Subversion</guimenu> <guisubmenu>Splošno</guisubmenu> "
"<guimenuitem>Izvoz repozitorija</guimenuitem>"

#. Tag: para
#: index.docbook:1922
#, no-c-format
msgid ""
"Exports a repository to file system, &ie; creates a clean revision tree "
"without subversion information."
msgstr ""
"Izvozi repozitorij v datotečni sistem, &ie;. ustvari čisto revizijsko drevo "
"brez informacij subversion."

#. Tag: menuchoice
#: index.docbook:1927
#, no-c-format
msgid ""
"<guimenu>Subversion</guimenu> <guisubmenu>General</guisubmenu> "
"<guimenuitem>Lock current items</guimenuitem>"
msgstr ""
"<guimenu>Subversion</guimenu> <guisubmenu>Splošno</guisubmenu> "
"<guimenuitem>Zakleni trenutne elemente</guimenuitem>"

#. Tag: para
#: index.docbook:1932
#, no-c-format
msgid ""
"Mark current items as locked. Read the subversion handbook before using this!"
msgstr ""
"Označite trenutne elemente kot zaklenjene. Pred uporabo tega preberite "
"priročnik za subversion!"

#. Tag: menuchoice
#: index.docbook:1936
#, no-c-format
msgid ""
"<guimenu>Subversion</guimenu> <guisubmenu>General</guisubmenu> "
"<guimenuitem>Unlock current items</guimenuitem>"
msgstr ""
"<guimenu>Subversion</guimenu> <guisubmenu>Splošno</guisubmenu> "
"<guimenuitem>Odkleni trenutne elemente</guimenuitem>"

#. Tag: para
#: index.docbook:1941
#, no-c-format
msgid ""
"Remove locks on current items. Read the subversion handbook before using "
"this!"
msgstr ""
"Odstranite ključavnice na trenutnih elementih. Pred uporabo tega preberite "
"priročnik za subversion!"

#. Tag: title
#: index.docbook:1947
#, no-c-format
msgid "<title>Working copy</title>"
msgstr "<title>Delovna kopija</title>"

#. Tag: menuchoice
#: index.docbook:1949
#, no-c-format
msgid ""
"<guimenu>Subversion</guimenu> <guisubmenu>Working copy</guisubmenu> "
"<guimenuitem>Update to head</guimenuitem>"
msgstr ""
"<guimenu>Subversion</guimenu> <guisubmenu>Delovna kopija</guisubmenu> "
"<guimenuitem>Posodobitev na glavo</guimenuitem>"

#. Tag: para
#: index.docbook:1954
#, no-c-format
