msgstr "Posodobite delovno kopijo na HEAD repozitorija"

#. Tag: menuchoice
#: index.docbook:1957
#, no-c-format
msgid ""
"<guimenu>Subversion</guimenu> <guisubmenu>Working copy</guisubmenu> "
"<guimenuitem>Update to revision...</guimenuitem>"
msgstr ""
"<guimenu>Subversion</guimenu> <guisubmenu>Delovna kopija</guisubmenu> "
"<guimenuitem>Posodobitev na revizijo...</guimenuitem>"

#. Tag: para
#: index.docbook:1962
#, no-c-format
