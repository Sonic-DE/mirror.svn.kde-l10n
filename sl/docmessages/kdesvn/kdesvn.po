msgstr "Kopirajte element znotraj delovne kopije ali v repozitorij"

#. Tag: menuchoice
#: index.docbook:1884
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\"><keycap>Del</keycap></keycombo></"
"shortcut> <guimenu>Subversion</guimenu> <guisubmenu>General</guisubmenu> "
"<guimenuitem>Delete selected files/dirs</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\"><keycap>Del</keycap></keycombo></"
"shortcut> <guimenu>Subversion</guimenu> <guisubmenu>Splošno</guisubmenu> "
"<guimenuitem>Izbriši izbrane datoteke/ imeniki</guimenuitem>"

#. Tag: para
#: index.docbook:1890
#, no-c-format
