msgid "&Ctrl;<keycap>A</keycap>"
msgstr "&Ctrl;<keycap>A</keycap>"

#. Tag: entry
#: index.docbook:1597
#, no-c-format
msgid "Select all"
msgstr "Izberi vse"

#. Tag: keycombo
#: index.docbook:1600
#, no-c-format
msgid "&Ctrl;<keycap>C</keycap>"
msgstr "&Ctrl;<keycap>C</keycap>"

#. Tag: entry
#: index.docbook:1601
#, no-c-format
msgid "<entry>Copy</entry>"
msgstr "<entry>Kopiraj</entry>"

#. Tag: keycombo
#: index.docbook:1605
#, no-c-format
msgid "&Ctrl;<keycap>R</keycap>"
msgstr "&Ctrl;<keycap>R</keycap>"

#. Tag: entry
#: index.docbook:1606
#, no-c-format
msgid "Rename file"
msgstr "Preimenuj datoteko"

#. Tag: keycombo
#: index.docbook:1610
#, no-c-format
msgid "&Ctrl;<keycap>I</keycap>"
msgstr "&Ctrl;<keycap>I</keycap>"

#. Tag: entry
#: index.docbook:1611
#, no-c-format
msgid "Guess tags from the Internet."
msgstr "Ugani oznake iz interneta."

#. Tag: keycombo
#: index.docbook:1615
#, no-c-format
msgid "&Ctrl;<keycap>G</keycap>"
msgstr "&Ctrl;<keycap>G</keycap>"

#. Tag: entry
#: index.docbook:1616
#, no-c-format
msgid "Guess tags from the filename."
msgstr "Ugani oznake iz imena datoteke."

#. Tag: keycombo
#: index.docbook:1620
#, no-c-format
msgid "&Ctrl;<keycap>F</keycap>"
msgstr "&Ctrl;<keycap>F</keycap>"

#. Tag: entry
#: index.docbook:1621
#, no-c-format
msgid "New <link linkend=\"juk-search-playlists\">search playlist</link>."
msgstr ""
"Nov <link linkend=\"juk-search-playlists\">seznam predvajanja za iskanje</"
"link>."

#. Tag: keycombo
#: index.docbook:1625
#, no-c-format
msgid "&Ctrl;<keycap>N</keycap>"
msgstr "&Ctrl;<keycap>N</keycap>"

#. Tag: entry
#: index.docbook:1626
#, no-c-format
msgid "New empty Playlist"
msgstr "Nov prazen seznam predvajanja"

#. Tag: keycombo
#: index.docbook:1630
#, no-c-format
msgid "&Ctrl;<keycap>D</keycap>"
msgstr "&Ctrl;<keycap>D</keycap>"

#. Tag: entry
#: index.docbook:1631
#, no-c-format
msgid "New playlist from folder."
msgstr "Nov seznam predvajanja iz mape."

#. Tag: keycombo
#: index.docbook:1635
#, no-c-format
msgid "&Ctrl;<keycap>T</keycap>"
msgstr "&Ctrl;<keycap>T</keycap>"

#. Tag: entry
#: index.docbook:1636
#, no-c-format
msgid "Save changes to edited tags."
msgstr "Shrani spremembe urejenih oznak."

