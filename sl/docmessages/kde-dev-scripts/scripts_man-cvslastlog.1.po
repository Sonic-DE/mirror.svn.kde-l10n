#. Tag: title
#: man-cvslastlog.1.docbook:32
#, no-c-format
msgid "Description"
msgstr "Opis"

#. Tag: para
#: man-cvslastlog.1.docbook:34
#, no-c-format
msgid ""
"<command>cvslastlog</command> shows the log associated with the last CVS "
"commit for the given file. It depends on the version of the local file, not "
"the one on the server."
msgstr ""
"<command>cvslastlog</command> prikazuje dnevnik, povezan z zadnjo "
"potrditvijo CVS za dano datoteko. Odvisno je od različice lokalne datoteke, "
"ne tiste na strežniku."

#. Tag: para
#: man-cvslastlog.1.docbook:38
#, no-c-format
msgid "This utility is part of the &kde; Software Development Kit."
msgstr ""
"Ta pripomoček je del programa &kde; Software Development Kit. (Komplet za "
"razvoj programske opreme)."
