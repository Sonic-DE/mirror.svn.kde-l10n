#. Tag: title
#: man-cxxmetric.1.docbook:33
#, no-c-format
msgid "Description"
msgstr "Opis"

#. Tag: para
#: man-cxxmetric.1.docbook:35
#, no-c-format
msgid ""
"cxxmetric counts lines of code, comment and blank space and calculates "
"various other statistics for each given source file. Source files must be in "
"C or C++."
msgstr ""
"cxxmetric prešteje vrstice kode, komentarje in prazen prostor ter izračuna "
"različne druge statistike za vsako dano izvorno datoteko. Izvorne datoteke "
"morajo biti v C ali C++."

#. Tag: para
#: man-cxxmetric.1.docbook:39
#, no-c-format
msgid "This utility is part of the KDE Software Development Kit."
msgstr "Ta pripomoček je del kompleta za razvoj programske opreme KDE."
