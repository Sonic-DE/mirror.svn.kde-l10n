#, no-c-format
msgid "Description"
msgstr "Opis"

#. Tag: para
#: man-cvslastchange.1.docbook:35
#, no-c-format
msgid ""
"&cvslastchange; displays the last change committed to &CVS; for a file. It "
"uses <command>cvs diff</command> and <command>cvs log</command> to do this."
msgstr ""
"&cvslastchange; prikaže zadnjo spremembo, dodeljeno &CVS; za datoteko. Za to "
"uporablja <command>cvs diff</command> in <command>cvs log</command>."

#. Tag: para
#: man-cvslastchange.1.docbook:39
#, no-c-format
msgid "&cvslastchange; works on any &CVS; branch, not just HEAD."
msgstr "&cvslastchange; deluje na vseh vejah &CVS; ne samo HEAD."

#. Tag: para
#: man-cvslastchange.1.docbook:41
#, no-c-format
msgid "This utility is part of the &kde; Software Development Kit."
msgstr ""
"Ta pripomoček je del programa &kde; Software Development Kit. (Komplet za "
"razvoj programske opreme)."

