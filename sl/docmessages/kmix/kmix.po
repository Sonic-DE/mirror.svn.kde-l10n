#. Tag: para
#: index.docbook:55
#, no-c-format
msgid ""
"&kmix; is an application that allows you to change the volume of your sound "
"card."
msgstr ""
"&kmix; je aplikacija, ki vam omogoča spreminjanje glasnosti vaše zvočne "
"kartice."

#. Tag: keyword
#: index.docbook:59
#, no-c-format
msgid "<keyword>KDE</keyword>"
msgstr "<keyword>KDE</keyword>"

