#: index.docbook:162
#, no-c-format
msgid "<phrase>&kmix; Settings</phrase>"
msgstr "<phrase>&kmix; Nastavitve</phrase>"

#. Tag: menuchoice
#: index.docbook:169
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Audio Setup</guimenuitem>"
msgstr ""
"<guimenu>Nastavitve</guimenu> <guimenuitem>Nastavitev zvoka</guimenuitem>"

#. Tag: para
#: index.docbook:173
#, no-c-format
msgid ""
"<action>Open <ulink url=\"help:/kcontrol/phonon\">&phonon; &systemsettings; "
"module</ulink></action> to configure the sound and video device preference "
"and the backends used by &kde; multimedia API, &phonon;."
msgstr ""
"<action>Odpri <ulink url=\"help:/kcontrol/phonon\">&phonon; &systemsettings; "
"modul</ulink></action> za konfiguracijo nastavitev zvočne in video naprave "
"ter ozadij, ki jih uporablja &kde; multimedijski API, &phonon;."

#. Tag: title
#: index.docbook:197
#, no-c-format
msgid "Select Master Channel"
msgstr "Izberi glavni kanal"

#. Tag: screeninfo
#: index.docbook:199
#, no-c-format
msgid "<screeninfo>&kmix; Master Channel</screeninfo>"
msgstr "<screeninfo>&kmix; Glavni kanal</screeninfo>"

#. Tag: phrase
#: index.docbook:205
#, no-c-format
msgid "<phrase>&kmix; Master Channel</phrase>"
msgstr "<phrase>&kmix; Glavni kanal</phrase>"

#. Tag: para
#: index.docbook:209
#, no-c-format
msgid "Select your &kmix; master channel."
msgstr "Izberi svoj &kmix; glavni kanal."

#. Tag: title
#: index.docbook:213
#, no-c-format
msgid "Configure &kmix;"
msgstr "Konfigurirajte &kmix;"

#. Tag: title
#: index.docbook:215
#, no-c-format
msgid "General configuration"
msgstr "Splošna konfiguracija"

#. Tag: screeninfo
#: index.docbook:219
#, no-c-format
msgid "<screeninfo>General configuration of &kmix;</screeninfo>"
msgstr "<screeninfo>Splošna konfiguracija &kmix;</screeninfo>"

#. Tag: phrase
#: index.docbook:225
#, no-c-format
msgid "<phrase>General configuration of &kmix;</phrase>"
msgstr "<phrase>Splošna konfiguracija &kmix;</phrase>"

#. Tag: para
#: index.docbook:229
#, no-c-format
msgid "Configure general &kmix; parameters."
msgstr "Konfigurirajte splošno &kmix; parametri."

#. Tag: menuchoice
#: index.docbook:233
#, no-c-format
msgid "<guimenu>Behavior</guimenu> <guimenuitem>Volume Overdrive</guimenuitem>"
msgstr ""
"<guimenu>Vedenje</guimenu> <guimenuitem>Prekoračitev glasnosti</guimenuitem>"

#. Tag: para
#: index.docbook:237
#, no-c-format
msgid ""
"Check this box to allow volume to be more than recommended value (sometimes "
"PulseAudio maximal volume exceeds the normal value). &kmix; restart is "
"needed for this setting to take effect."
msgstr ""
"Označite to polje, če želite omogočiti, da je glasnost večja od priporočene "
"vrednosti (včasih največja glasnost PulseAudio preseže normalno vrednost). "
"&kmix; za uveljavitev te nastavitve je potreben ponovni zagon."

#. Tag: para
#: index.docbook:239
#, no-c-format
msgid ""
"Uncheck this item if there are audible sound distortions at the maximal "
"volume."
msgstr ""
"Počistite to postavko, če so slišna popačenja zvoka pri največji glasnosti."

#. Tag: menuchoice
#: index.docbook:247
#, no-c-format
msgid "<guimenu>Behavior</guimenu> <guimenuitem>Volume Feedback</guimenuitem>"
msgstr ""
"<guimenu>Obnašanje</guimenu> <guimenuitem>Povratne informacije o glasnosti</"
"guimenuitem>"

#. Tag: action
#: index.docbook:251
#, no-c-format
msgid "Check this box to enable audible feedback on volume change."
msgstr ""
"Označite to polje, če želite omogočiti zvočne povratne informacije o "
"spremembi glasnosti."

#. Tag: menuchoice
#: index.docbook:255
#, no-c-format
msgid "<guimenu>Behavior</guimenu> <guimenuitem>Volume step</guimenuitem>"
msgstr ""
"<guimenu>Obnašanje</guimenu> <guimenuitem>Korak glasnosti</guimenuitem>"

#. Tag: para
#: index.docbook:260
#, no-c-format
msgid "Set the volume step as a percentage of the volume range."
msgstr "Nastavite korak glasnosti kot odstotek obsega glasnosti."

#. Tag: para
#: index.docbook:263
#, no-c-format
msgid ""
"This affects changing the volume via hot keys, with the mouse wheel over the "
"system tray icon, or moving sliders by a page step."
msgstr ""
"To vpliva na spreminjanje glasnosti z vročimi tipkami, z miškinim kolescem "
"nad ikono sistemske vrstice ali premikanjem drsnikov za korak strani."

#. Tag: para
#: index.docbook:266
#, no-c-format
msgid "&kmix; must be restarted for this change to take effect."
msgstr "&kmix; je treba znova zagnati, da bo ta sprememba začela veljati."

#. Tag: menuchoice
#: index.docbook:273
#, no-c-format
msgid ""
"<guimenu>Visual</guimenu> <guimenuitem>Show slider tickmarks</guimenuitem>"
msgstr ""
"<guimenu>Vizualno</guimenu> <guimenuitem>Prikaži kljukice drsnika</"
"guimenuitem>"

#. Tag: action
#: index.docbook:277
#, no-c-format
msgid "Check this box to show tickmarks on the sliders."
msgstr "Označite to polje, če želite na drsnikih prikazati kljukice."

#. Tag: menuchoice
#: index.docbook:281
#, no-c-format
msgid ""
"<guimenu>Visual</guimenu> <guimenuitem>Show control labels</guimenuitem>"
msgstr ""
"<guimenu>Vizualno</guimenu> <guimenuitem>Pokaži nadzorne oznake</guimenuitem>"

#. Tag: action
#: index.docbook:285
#, no-c-format
msgid "Check this box to show labels of controls."
msgstr "Označite to polje, če želite prikazati oznake kontrolnikov."

#. Tag: menuchoice
#: index.docbook:289
#, no-c-format
msgid ""
"<guimenu>Visual</guimenu> <guimenuitem>Show On Screen Display (OSD)</"
"guimenuitem>"
msgstr ""
"<guimenu>Vizualno</guimenu> <guimenuitem>Prikaži prikaz na zaslonu (OSD)</"
"guimenuitem>"

#. Tag: action
#: index.docbook:293
#, no-c-format
msgid "Check this box to enable OSD show on hovering &kmix; tray widget."
msgstr ""
"Označite to polje, če želite omogočiti prikaz OSD ob miški nad pladnjem "
"&kmix;."

#. Tag: menuchoice
#: index.docbook:297
#, no-c-format
msgid ""
"<guimenu>Slider orientation (main window)</guimenu> <guimenuitem>Horizontal</"
"guimenuitem>"
msgstr ""
"<guimenu>Usmerjenost drsnika (glavno okno)</guimenu> <guimenuitem>Vodoravno</"
"guimenuitem>"

#. Tag: action
#: index.docbook:301
#, no-c-format
msgid "Check this radio button to orientate the control slider horizontally."
msgstr ""
"Označite ta izbirni gumb, če želite nadzorni drsnik usmeriti vodoravno."

#. Tag: menuchoice
#: index.docbook:305
#, no-c-format
msgid ""
"<guimenu>Slider orientation (main window)</guimenu> <guimenuitem>Vertical</"
"guimenuitem>"
msgstr ""
"<guimenu>Usmerjenost drsnika (glavno okno)</guimenu> <guimenuitem>Navpično</"
"guimenuitem>"

#. Tag: action
#: index.docbook:309
#, no-c-format
msgid "Check this radio button to orientate the control slider vertically."
msgstr ""
"Označite ta izbirni gumb, če želite upravljalni drsnik usmeriti navpično."

#. Tag: menuchoice
#: index.docbook:313
#, no-c-format
msgid ""
"<guimenu>Slider orientation (system tray popup)</guimenu> "
"<guimenuitem>Horizontal/Vertical</guimenuitem>"
msgstr ""
"<guimenu>Usmerjenost drsnika (pojavno okno sistemske vrstice)</guimenu> "
"<guimenuitem>Vodoravno/navpično</guimenuitem>"

#. Tag: para
#: index.docbook:317
#, no-c-format
msgid ""
"Same as the previous two radio buttons but for the system tray volume "
"control (the panel that is shown after &LMB; click on &kmix; tray icon)."
msgstr ""
"Enako kot prejšnja dva izbirna gumba, vendar za nadzor glasnosti sistemskega "
"pladnja (plošča, ki je prikazana po &LMB; kliknite ikono &kmix; pladnja)."

#. Tag: title
#: index.docbook:324
#, no-c-format
msgid "Start configuration"
msgstr "Zaženi konfiguracijo"

#. Tag: screeninfo
#: index.docbook:328
#, no-c-format
msgid "<screeninfo>Start configuration of &kmix;</screeninfo>"
msgstr "<screeninfo>Začni konfiguracijo &kmix;</screeninfo>"

#. Tag: phrase
#: index.docbook:334
#, no-c-format
msgid "<phrase>Start configuration of &kmix;</phrase>"
msgstr "<phrase>Začni konfiguracijo &kmix;</phrase>"

#. Tag: para
#: index.docbook:338
#, no-c-format
msgid "This page allows you to configure various &kmix; start parameters."
msgstr ""
"Ta stran vam omogoča konfiguracijo različnih &kmix; začetnih parametrov."

#. Tag: menuchoice
#: index.docbook:342
#, no-c-format
msgid ""
"<guimenu>Startup</guimenu> <guimenuitem>Start KMix on desktop startup</"
"guimenuitem>"
msgstr ""
"<guimenu>Zagon</guimenu> <guimenuitem>Zaženi KMix ob zagonu namizja</"
"guimenuitem>"

#. Tag: action
#: index.docbook:346
#, no-c-format
msgid "Check this box to enable &kmix; autostart with desktop environment."
msgstr ""
"Označite to polje, da omogočite samodejni zagon &kmix; z namiznim okoljem."

#. Tag: menuchoice
#: index.docbook:350
#, no-c-format
msgid ""
"<guimenu>Startup</guimenu> <guimenuitem>Restore previous volume settings on "
"desktop startup</guimenuitem>"
msgstr ""
"<guimenu>Zagon</guimenu> <guimenuitem>Obnovi prejšnje nastavitve glasnosti "
"ob zagonu namizja</guimenuitem>"

#. Tag: action
#: index.docbook:354
#, no-c-format
msgid ""
"Check this box to enable volume levels and switches restoration to their "
"last used settings on desktop start."
msgstr ""
"Označite to polje, da omogočite ravni glasnosti in obnovitev stikal na "
"njihove zadnje uporabljene nastavitve ob zagonu namizja."

#. Tag: para
#: index.docbook:356
#, no-c-format
msgid ""
"The volume of PulseAudio or MPRIS2 dynamic controls will not be restored."
msgstr ""
"Glasnost dinamičnih kontrolnikov PulseAudio ali MPRIS2 ne bo obnovljena."

#. Tag: title
#: index.docbook:367
#, no-c-format
msgid "Volume control configuration"
msgstr "Konfiguracija nadzora glasnosti"

#. Tag: screeninfo
#: index.docbook:371
#, no-c-format
msgid "<screeninfo>Volume control configuration of &kmix;</screeninfo>"
msgstr "<screeninfo>Konfiguracija nadzora glasnosti &kmix;</screeninfo>"

#. Tag: phrase
#: index.docbook:377
#, no-c-format
msgid "<phrase>Volume control configuration of &kmix;</phrase>"
msgstr "<phrase>Konfiguracija nadzora glasnosti &kmix;</phrase>"

#. Tag: para
#: index.docbook:381
#, no-c-format
msgid ""
"This page allows you to configure various &kmix; popup volume control "
"parameters."
msgstr ""
"Ta stran vam omogoča konfiguracijo različnih &kmix; pojavnih parametrov "
"nadzora glasnosti."

#. Tag: guilabel
#: index.docbook:385
#, no-c-format
msgid "Dock in system tray"
msgstr "Priklop v sistemski vrstici"

#. Tag: action
#: index.docbook:387
#, no-c-format
msgid "Check this box to dock &kmix; in system tray."
msgstr "Označite to polje, če želite &kmix; v sistemski vrstici."

#. Tag: para
#: index.docbook:391
#, no-c-format
msgid ""
"It is possible to select mixers that will be shown in the volume control "
"using the corresponding list on this page."
msgstr ""
"Z ustreznim seznamom na tej strani je mogoče izbrati mešalnike, ki bodo "
"prikazani v nadzoru glasnosti."

#. Tag: title
#: index.docbook:400
#, no-c-format
msgid "Advanced usage"
msgstr "Napredna uporaba"

#. Tag: title
#: index.docbook:402
#, no-c-format
msgid "Remote controlling and scripting via &DBus;"
msgstr "Daljinsko upravljanje in skriptiranje prek &DBus;"

#. Tag: para
#: index.docbook:403
#, no-c-format
msgid ""
"You can control &kmix; via &DBus;. This is for advanced users who want to "
"achieve special tasks, like muting the PC every day at 10 pm, or for any "
"other scripting task."
msgstr ""
"Nadzorujete lahko &kmix; prek &DBus;. To je za napredne uporabnike, ki "
"želijo doseči posebne naloge, kot je utišanje računalnika vsak dan ob 22. "
"uri, ali za katero koli drugo skriptno nalogo."

#. Tag: para
#: index.docbook:407
#, no-c-format
msgid "List all &kmix; related &DBus; methods and properties"
msgstr "Prikaži vse &kmix; povezanih &DBus; metode in lastnosti"

#. Tag: programlisting
#: index.docbook:409
#, no-c-format
msgid "qdbus org.kde.kmix"
msgstr "qdbus org.kde.kmix"

#. Tag: para
#: index.docbook:412
#, no-c-format
msgid "Getting volume level (0-100%):"
msgstr "Pridobivanje ravni glasnosti (0-100%):"

#. Tag: programlisting
#: index.docbook:414
#, no-c-format
msgid ""
"qdbus org.kde.kmix /Mixers/0/Master_0 org.freedesktop.DBus.Properties.Get "
"org.kde.KMix.Control volume"
msgstr ""
"qdbus org.kde.kmix /Mixers/0/Master_0 org.freedesktop.DBus.Properties.Get "
"org.kde.KMix.Control volume"

#. Tag: para
#: index.docbook:417
#, no-c-format
msgid "Setting volume level (0-100%):"
msgstr "Nastavitev glasnosti (0-100%):"

#. Tag: programlisting
#: index.docbook:419
#, no-c-format
msgid ""
"qdbus org.kde.kmix /Mixers/0/Master_0 org.freedesktop.DBus.Properties.Set "
"org.kde.KMix.Control volume 70"
msgstr ""
"qdbus org.kde.kmix /Mixers/0/Master_0 org.freedesktop.DBus.Properties.Set "
"org.kde.KMix.Control volume 70"

