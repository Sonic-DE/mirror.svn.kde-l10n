msgstr "<phrase>Urejevalnik plošče</phrase>"

#. Tag: para
#: index.docbook:300
#, no-c-format
msgid "Procedure to edit layout:"
msgstr "Postopek urejanja postavitve:"

#. Tag: para
#: index.docbook:303
#, no-c-format
msgid ""
"Use the board editor toolbar to create a new layout or to load and edit an "
"existing one."
msgstr ""
"Uporabite orodno vrstico urejevalnika plošče, da ustvarite novo postavitev "
"ali naložite in uredite obstoječo."

#. Tag: para
#: index.docbook:304
#, no-c-format
msgid ""
"Save the layout in your user's local home folder in <filename>"
"$<envar>XDG_DATA_HOME</envar>/kmahjongg/layouts</filename>"
msgstr ""
"Shranite postavitev v lokalno domačo mapo vašega uporabnika v <filename>"
"$<envar>XDG_DATA_HOME</envar>/kmahjongg/layouts</filename>"

#. Tag: para
#: index.docbook:305
#, no-c-format
msgid ""
"Create the <filename><replaceable>name_of_your_layout</replaceable>.desktop</"
"filename> file in the same folder."
msgstr ""
"V isti mapi ustvarite datoteko <filename><replaceable>name_of_your_layout</"
"replaceable>.desktop</filename>."

#. Tag: para
#: index.docbook:306
#, no-c-format
msgid "Put the following lines in this file using your favorite text editor:"
msgstr ""
"V to datoteko vnesite naslednje vrstice s svojim najljubšim urejevalnikom "
"besedil:"

#. Tag: programlisting
#: index.docbook:307
#, no-c-format
msgid ""
"[KMahjonggLayout]\n"
"Name=<replaceable>name_of_your_layout</replaceable>\n"
"Description=<replaceable>description_of_your_layout</replaceable>\n"
"VersionFormat=1\n"
"Author=<replaceable>your_name</replaceable>\n"
"AuthorEmail=<replaceable>your_email</replaceable>\n"
"FileName=<replaceable>name_of_your_layout</replaceable>.layout"
msgstr ""
"[KMahjonggLayout]\n"
"Name=<replaceable>name_of_your_layout</replaceable>\n"
"Description=<replaceable>description_of_your_layout</replaceable>\n"
"VersionFormat=1\n"
"Author=<replaceable>your_name</replaceable>\n"
"AuthorEmail=<replaceable>your_email</replaceable>\n"
"FileName=<replaceable>name_of_your_layout</replaceable>.layout"

#. Tag: para
#: index.docbook:308
#, no-c-format
msgid "Reload &kmahjongg; to use your new layout."
msgstr "Ponovno naloži &kmahjongg; za uporabo vaše nove postavitve."

#. Tag: menuchoice
