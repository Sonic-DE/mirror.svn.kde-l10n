#, no-c-format
msgid "The tabs are located on the right side."
msgstr "Zavihki se nahajajo na desni strani."

#. Tag: para
#: index.docbook:1572
#, no-c-format
msgid "Default: <guimenuitem>Bottom</guimenuitem>"
msgstr "Privzeto: <guimenuitem>Dno</guimenuitem>"

#. Tag: guibutton
#: index.docbook:1577
#, no-c-format
msgid "Show custom bookmark label if available"
msgstr "Prikaži oznako zaznamka po meri, če je na voljo"

#. Tag: para
#: index.docbook:1580
#, no-c-format
msgid ""
"The custom description (label) of the bookmark is shown. It can be defined "
"in the <link linkend=\"bookmarks_editor\">bookmark editor</link>."
msgstr ""
"Prikaže se opis po meri (oznaka) zaznamka. Določite ga lahko v <link linkend="
"\"bookmarks_editor\">urejevalniku zaznamkov</link>."

#. Tag: para
#: index.docbook:1581 index.docbook:1610 index.docbook:1619 index.docbook:1628
