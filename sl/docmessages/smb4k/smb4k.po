#~ msgid "Default: not selected; empty"
#~ msgstr "Privzeto: ni izbrano; prazno"

#~ msgid "Default: your UID"
#~ msgstr "Privzeto: vaš UID"

#~ msgid "Default: your GID"
#~ msgstr "Privzeto: vaš GID"

