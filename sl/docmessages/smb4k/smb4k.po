#. Tag: guibutton
#: index.docbook:2534
#, no-c-format
msgid "3 (Version 3.0 and above)"
msgstr "3 (Različica 3.0 in novejše)"

#. Tag: para
#: index.docbook:2537
#, no-c-format
msgid ""
"This causes <ulink url=\"man:/mount.cifs"
"\"><citerefentry><refentrytitle>mount.cifs</refentrytitle><manvolnum>8</"
"manvolnum></citerefentry></ulink> to use the SMBv3.0 protocol version and "
