msgstr ""
"Uporabljen je argument ukazne vrstice <option>sec=krb5i</option>. To "
"povzroči, da <ulink url=\"man:/mount.cifs"
"\"><citerefentry><refentrytitle>mount.cifs</refentrytitle><manvolnum>8</"
"manvolnum></citerefentry></ulink> uporablja preverjanje pristnosti Kerberos "
"različice 5 in prisilno podpisovanje paketov."

#. Tag: guibutton
#: index.docbook:2623
#, no-c-format
msgid "NTLM protocol"
msgstr "protokol NTLM"

#. Tag: para
#: index.docbook:2626
#, no-c-format
msgid ""
"The <option>sec=ntlm</option> command line argument is used. This causes "
"<ulink url=\"man:/mount.cifs\"><citerefentry><refentrytitle>mount.cifs</"
