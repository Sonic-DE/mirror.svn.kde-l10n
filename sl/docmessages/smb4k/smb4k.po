msgstr ""
"Uporabljen je argument ukazne vrstice <option>sec=ntlm</option>. To "
"povzroči, da <ulink url=\"man:/mount.cifs"
"\"><citerefentry><refentrytitle>mount.cifs</refentrytitle><manvolnum>8</"
"manvolnum></citerefentry></ulink> uporablja zgoščevanje gesel NTLM. Do "
"&Linux; različica jedra 3.8 je to privzeta nastavitev."

#. Tag: guibutton
#: index.docbook:2631
#, no-c-format
msgid "NTLM protocol and packet signing"
msgstr "Protokol NTLM in podpisovanje paketov"

#. Tag: para
#: index.docbook:2634
#, no-c-format
msgid ""
"The <option>sec=ntlmi</option> command line argument is used. This causes "
"<ulink url=\"man:/mount.cifs\"><citerefentry><refentrytitle>mount.cifs</"
"refentrytitle><manvolnum>8</manvolnum></citerefentry></ulink> to use NTLM "
"password hashing and force packet signing."
msgstr ""
"Uporabljen je argument ukazne vrstice <option>sec=ntlmi</option>. To "
"povzroči, da <ulink url=\"man:/mount.cifs"
"\"><citerefentry><refentrytitle>mount.cifs</refentrytitle><manvolnum>8</"
"manvolnum></citerefentry></ulink> uporablja zgoščevanje gesel NTLM in "
"prisilno podpisovanje paketa."

#. Tag: guibutton
#: index.docbook:2639
#, no-c-format
msgid "NTLMv2 protocol"
msgstr "protokol NTLMv2"

#. Tag: para
#: index.docbook:2642
#, no-c-format
msgid ""
"The <option>sec=ntlmv2</option> command line argument is used. This causes "
"<ulink url=\"man:/mount.cifs\"><citerefentry><refentrytitle>mount.cifs</"
"refentrytitle><manvolnum>8</manvolnum></citerefentry></ulink> to use NTLMv2 "
"password hashing."
msgstr ""
"Uporabljen je argument ukazne vrstice <option>sec=ntlmv2</option>. To "
"povzroči, da <ulink url=\"man:/mount.cifs"
"\"><citerefentry><refentrytitle>mount.cifs</refentrytitle><manvolnum>8</"
"manvolnum></citerefentry></ulink> uporablja zgoščevanje gesel NTLMv2."

#. Tag: guibutton
#: index.docbook:2647
#, no-c-format
msgid "NTLMv2 protocol and packet signing"
msgstr "Protokol NTLMv2 in podpisovanje paketov"

#. Tag: para
#: index.docbook:2650
#, no-c-format
msgid ""
"The <option>sec=ntlmv2i</option> command line argument is used. This causes "
"<ulink url=\"man:/mount.cifs\"><citerefentry><refentrytitle>mount.cifs</"
"refentrytitle><manvolnum>8</manvolnum></citerefentry></ulink> to use NTLMv2 "
"password hashing and force packet signing."
msgstr ""
"Uporabljen je argument ukazne vrstice <option>sec=ntlmv2i</option>. To "
"povzroči, da <ulink url=\"man:/mount.cifs"
"\"><citerefentry><refentrytitle>mount.cifs</refentrytitle><manvolnum>8</"
"manvolnum></citerefentry></ulink> uporablja zgoščevanje gesel NTLMv2 in "
"prisilno podpisovanje paketa."

#. Tag: guibutton
#: index.docbook:2655
#, no-c-format
msgid "NTLMSSP protocol"
msgstr "protokol NTLMSSP"

