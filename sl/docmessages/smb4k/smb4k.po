#~ msgstr "Vsili, da so ustvarjeni podimeniki napisani z malimi črkami"

#~ msgid ""
#~ "All subdirectories that are created by &smb4k; below the mount prefix "
#~ "will be lower case."
#~ msgstr ""
#~ "Vsi podimeniki, ki jih ustvari &smb4k; pod predpono namestitve bodo male "
#~ "črke."

#~ msgid "Allow the unmounting of shares that are owned by other users"
#~ msgstr "Dovoli odklop skupnih virov, ki so v lasti drugih uporabnikov"

#~ msgid ""
#~ "This option will allow you to unmount shares that were mounted by other "
#~ "users."
#~ msgstr ""
#~ "Ta možnost vam bo omogočila, da odklopite skupne vire, ki so jih "
#~ "priklopili drugi uporabniki."

#~ msgid "USE WITH EXTREME CAUTION!"
#~ msgstr "UPORABLJAJTE IZREDNO PREVIDNO!"

#~ msgid "File system port"
#~ msgstr "Vrata datotečnega sistema"

#~ msgid "Option: <option>port=PORT</option>"
#~ msgstr "Možnost: <option>port=PORT</option>"

#~ msgid ""
#~ "Sets the port number that is used by <ulink url=\"man:/mount.cifs"
#~ "\"><citerefentry><refentrytitle>mount.cifs</refentrytitle><manvolnum>8</"
#~ "manvolnum></citerefentry></ulink> when mounting a remote share. The "
#~ "default port number (445) should work for all modern operating systems. "
#~ "If you experience problems, try setting the port number to 139. If the "
#~ "problems only occur with a few hosts, it is recommended to leave this "
#~ "option untouched and to use the <link linkend=\"custom_settings\">Custom "
#~ "Settings</link> editor to define individual port numbers for the "
#~ "problematic hosts."
#~ msgstr ""
#~ "Nastavi številko vrat, ki jih uporablja <ulink url=\"man:/mount.cifs"
#~ "\"><citerefentry><refentrytitle>mount.cifs</refentrytitle><manvolnum>8</"
#~ "manvolnum></citerefentry></ulink> pri nameščanju oddaljene skupne rabe. "
#~ "Privzeta številka vrat (445) bi morala delovati za vse sodobne "
#~ "operacijske sisteme. Če imate težave, poskusite nastaviti številko vrat "
#~ "na 139. Če se težave pojavljajo le pri nekaj gostiteljih, je "
#~ "priporočljivo, da te možnosti ne dotaknete in uporabite urejevalnik <link "
#~ "linkend=\"custom_settings\">Nastavitve po meri</link> za določitev "
#~ "posameznih številk vrat za problematične gostitelje."

#~ msgid "Default: not selected; PORT: 445"
#~ msgstr "Privzeto: ni izbrano; PORT: 445"

#~ msgid "User ID"
#~ msgstr "Uporabniško ime"

#~ msgid "Option: <option>uid=UID</option>"
#~ msgstr "Možnost: <option>uid=UID</option>"

#~ msgid ""
#~ "Sets the owner of the files and directories on the file system. By "
#~ "default, your UID is used. To change the UID, press the search button and "
#~ "choose one from the drop down menu."
#~ msgstr ""
#~ "Nastavi lastnika datotek in imenikov v datotečnem sistemu. Privzeto se "
#~ "uporablja vaš UID. Če želite spremeniti UID, pritisnite gumb za iskanje "
#~ "in ga izberite v spustnem meniju."

#~ msgid "Group ID"
#~ msgstr "ID skupine"

#~ msgid "Option: <option>uid=GID</option>"
#~ msgstr "Možnost: <option>uid=GID</option>"

#~ msgid ""
#~ "Sets the group that owns the files and directories on the file system. By "
#~ "default, your GID is used. To change the GID, press the search button and "
#~ "choose one from the drop down menu."
#~ msgstr ""
#~ "Nastavi skupino, ki ima v lasti datoteke in imenike v datotečnem sistemu. "
#~ "Privzeto se uporablja vaš GID. Če želite spremeniti GID, pritisnite gumb "
#~ "za iskanje in izberite enega v spustnem meniju."

#~ msgid "Default: selected; GID: your GID"
#~ msgstr "Privzeto: izbrano; GID: vaš GID"

#~ msgid "Additional options"
#~ msgstr "Dodatne možnosti"

