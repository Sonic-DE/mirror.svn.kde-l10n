#: index.docbook:709
#, no-c-format
msgid "Opens a recent &LabPlot; project file."
msgstr "Odpre nedavno &LabPlot; projektno datoteko."

#. Tag: para
#: index.docbook:710
#, no-c-format
msgid "Here the last used 10 project files are listed."
msgstr "Tukaj je navedenih 10 zadnjih uporabljenih projektnih datotek."

