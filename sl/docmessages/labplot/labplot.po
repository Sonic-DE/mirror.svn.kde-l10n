msgstr "nepopolni eliptični integral D(phi,k,n)"

#. Tag: entry
#: index.docbook:1884
#, no-c-format
msgid "RC(x,y)"
msgstr "RC(x,y)"

#. Tag: action
#: index.docbook:1884
#, no-c-format
msgid "incomplete elliptic integral RC(x,y)"
msgstr "nepopolni eliptični integral RC(x,y)"

#. Tag: entry
#: index.docbook:1885
#, no-c-format
msgid "RD(x,y,z)"
msgstr "RD(x,y,z)"

#. Tag: action
#: index.docbook:1885
#, no-c-format
msgid "incomplete elliptic integral RD(x,y,z)"
msgstr "nepopolni eliptični integral RD(x,y,z)"

#. Tag: entry
#: index.docbook:1886
#, no-c-format
msgid "RF(x,y,z)"
msgstr "RF(x,y,z)"

#. Tag: action
#: index.docbook:1886
#, no-c-format
msgid "incomplete elliptic integral RF(x,y,z)"
msgstr "nepopolni eliptični integral RF(x,y,z)"

#. Tag: entry
#: index.docbook:1887
#, no-c-format
msgid "RJ(x,y,z)"
msgstr "RJ(x,y,z)"

#. Tag: action
#: index.docbook:1887
#, no-c-format
msgid "incomplete elliptic integral RJ(x,y,z,p)"
msgstr "nepopolni eliptični integral RJ(x,y,z,p)"

#. Tag: entry
#: index.docbook:1888
#, no-c-format
msgid "erf(x)"
msgstr "erf(x)"

#. Tag: action
#: index.docbook:1888
#, no-c-format
msgid ""
"error function erf(x) = 2/&radic;&pi; &int;<subscript>0</"
"subscript><superscript>x</superscript> exp(-t<superscript>2</superscript>) dt"
msgstr ""
"funkcija napake erf(x) = 2/&radic;&pi; &int;<subscript>0</"
"subscript><superscript>x</superscript> exp(-t<superscript>2</superscript>) dt"

#. Tag: entry
#: index.docbook:1889
#, no-c-format
msgid "erfc(x)"
msgstr "erfc(x)"

#. Tag: action
#: index.docbook:1889
#, no-c-format
msgid ""
"complementary error function erfc(x) = 1 - erf(x) = 2/&radic;&pi; &int;"
"<subscript>x</subscript><superscript>&infin;</superscript> exp(-"
"t<superscript>2</superscript>) dt"
msgstr ""
"komplementarna funkcija napake erfc(x) = 1 - erf(x) = 2/&radic;&pi; &int;"
"<subscript>x</subscript><superscript>&infin;</superscript> exp(-"
"t<superscript>2</superscript>) dt"

#. Tag: entry
#: index.docbook:1890
#, no-c-format
msgid "log_erfc(x)"
msgstr "log_erfc(x)"

#. Tag: action
#: index.docbook:1890
#, no-c-format
msgid "logarithm of the complementary error function log(erfc(x))"
msgstr "logaritem komplementarne funkcije napake log(erfc(x))"

#. Tag: entry
#: index.docbook:1891
#, no-c-format
msgid "erf_Z(x)"
msgstr "erf_Z(x)"

#. Tag: action
#: index.docbook:1891
#, no-c-format
msgid ""
"Gaussian probability function Z(x) = (1/(2&pi;)) exp(-x<superscript>2</"
"superscript>/2)"
msgstr ""
"Gaussova verjetnostna funkcija Z(x) = (1/(2&pi;)) exp(-x<superscript>2</"
"superscript>/2)"

#. Tag: entry
#: index.docbook:1892
#, no-c-format
msgid "erf_Q(x)"
msgstr "erf_Q(x)"

#. Tag: action
#: index.docbook:1892
#, no-c-format
msgid ""
"upper tail of the Gaussian probability function Q(x) = (1/(2&pi;)) &int;"
"<subscript>x</subscript><superscript>&infin;</superscript> exp(-"
"t<superscript>2</superscript>/2) dt"
msgstr ""
"zgornji rep Gaussove verjetnostne funkcije Q(x) = (1/(2&pi;)) &int;"
"<subscript>x</subscript><superscript>&infin;</superscript> exp(-"
"t<superscript>2</superscript >/2) dt"

#. Tag: entry
#: index.docbook:1893
#, no-c-format
msgid "hazard(x)"
msgstr "hazard(x)"

#. Tag: action
#: index.docbook:1893
#, no-c-format
msgid "hazard function for the normal distribution"
msgstr "funkcija tveganja za normalno porazdelitev"

#. Tag: entry
#: index.docbook:1894
#, no-c-format
msgid "exp(x)"
msgstr "exp(x)"

#. Tag: action
#: index.docbook:1894
#, no-c-format
msgid "Exponential, base e"
msgstr "Eksponentna, osnova e"

#. Tag: entry
#: index.docbook:1895
#, no-c-format
msgid "expm1(x)"
msgstr "expm1(x)"

#. Tag: action
#: index.docbook:1895
#, no-c-format
msgid "exp(x)-1"
msgstr "exp(x)-1"

#. Tag: entry
#: index.docbook:1896
#, no-c-format
msgid "exp_mult(x,y)"
msgstr "exp_mult(x,y)"

#. Tag: action
#: index.docbook:1896
#, no-c-format
msgid ""
"exponentiate x and multiply by the factor y to return the product y exp(x)"
msgstr "potenciramo x in pomnožimo s faktorjem y, da vrnemo produkt y exp(x)"

#. Tag: entry
#: index.docbook:1897
#, no-c-format
msgid "exprel(x)"
msgstr "eksprel(x)"

#. Tag: action
#: index.docbook:1897
#, no-c-format
msgid "(exp(x)-1)/x using an algorithm that is accurate for small x"
msgstr "(exp(x)-1)/x z uporabo algoritma, ki je natančen za majhne x"

#. Tag: entry
#: index.docbook:1898
#, no-c-format
msgid "exprel2(x)"
msgstr "eksprel2(x)"

#. Tag: action
#: index.docbook:1898
#, no-c-format
msgid ""
"2(exp(x)-1-x)/x<superscript>2</superscript> using an algorithm that is "
"accurate for small x"
msgstr ""
"2(exp(x)-1-x)/x<superscript>2</superscript> z uporabo algoritma, ki je "
"natančen za majhne x"

#. Tag: entry
#: index.docbook:1899
#, no-c-format
msgid "expreln(n,x)"
msgstr "eksprel(n,x)"

#. Tag: action
#: index.docbook:1899
#, no-c-format
msgid ""
"n-relative exponential, which is the n-th generalization of the functions "
"`exprel'"
msgstr "n-relativna eksponenta, ki je n-ta posplošitev funkcij `exprel'"

#. Tag: entry
#: index.docbook:1900
#, no-c-format
msgid "E1(x)"
msgstr "E1(x)"

#. Tag: action
#: index.docbook:1900
#, no-c-format
msgid ""
"exponential integral E<subscript>1</subscript>(x), E<subscript>1</"
"subscript>(x) := Re &int;<subscript>1</subscript><superscript>&infin;</"
"superscript> exp(-xt)/t dt"
msgstr ""
"eksponentni integral E<subscript>1</subscript>(x), E<subscript>1</"
"subscript>(x) := Re &int;<subscript>1</subscript><superscript>&infin;</"
"superscript> exp (-xt)/t dt"

#. Tag: entry
#: index.docbook:1901
#, no-c-format
msgid "E2(x)"
msgstr "E2(x)"

#. Tag: action
#: index.docbook:1901
#, no-c-format
msgid ""
"second-order exponential integral E<subscript>2</subscript>(x), "
"E<subscript>2</subscript>(x) := Re &int;<subscript>1</"
"subscript><superscript>&infin;</superscript> exp(-xt)/t<superscript>2</"
"superscript> dt"
msgstr ""
"eksponentni integral drugega reda E<subscript>2</subscript>(x), "
"E<subscript>2</subscript>(x) := Re &int;<subscript>1</"
"subscript><superscript>&infin;</superscript> exp(-xt)/t<superscript>2</"
"superscript> dt"

#. Tag: entry
#: index.docbook:1902
#, no-c-format
msgid "En(x)"
msgstr "En(x)"

#. Tag: action
#: index.docbook:1902
#, no-c-format
msgid ""
"exponential integral E_n(x) of order n, E<subscript>n</subscript>(x) := Re "
"&int;<subscript>1</subscript><superscript>&infin;</superscript> exp(-xt)/"
"t<superscript>n</superscript> dt)"
msgstr ""
"eksponentni integral E_n(x) reda n, E<subscript>n</subscript>(x) := Re &int;"
"<subscript>1</subscript><superscript>&infin;</superscript> exp(-xt)/ "
"t<superscript>n</superscript> dt)"

#. Tag: entry
#: index.docbook:1903
#, no-c-format
msgid "Ei(x)"
msgstr "Ei(x)"

#. Tag: action
#: index.docbook:1903
#, no-c-format
msgid ""
"exponential integral E_i(x), Ei(x) := PV(&int;<subscript>-x</"
"subscript><superscript>&infin;</superscript> exp(-t)/t dt)"
msgstr ""
"eksponentni integral E_i(x), Ei(x) := PV(&int;<subscript>-x</"
"subscript><superscript>&infin;</superscript> exp(-t)/t dt)"

#. Tag: entry
#: index.docbook:1904
#, no-c-format
msgid "shi(x)"
msgstr "shi(x)"

#. Tag: action
#: index.docbook:1904
#, no-c-format
msgid ""
"Shi(x) = &int;<subscript>0</subscript><superscript>x</superscript> sinh(t)/t "
"dt"
msgstr ""
"Shi(x) = &int;<subscript>0</subscript><superscript>x</superscript> sinh(t)/t "
"dt"

#. Tag: entry
#: index.docbook:1905
#, no-c-format
msgid "chi(x)"
msgstr "chi(x)"

#. Tag: action
#: index.docbook:1905
#, no-c-format
msgid ""
"integral Chi(x) := Re[ &gamma;<subscript>E</subscript> + log(x) + &int;"
"<subscript>0</subscript><superscript>x</superscript> (cosh[t]-1)/t dt ]"
msgstr ""
"integral Chi(x) := Re[ &gamma;<subscript>E</subscript> + log(x) + &int;"
"<subscript>0</subscript><superscript>x</superscript> (cosh[t]-1)/t dt ]"

#. Tag: entry
#: index.docbook:1906
#, no-c-format
msgid "Ei3(x)"
msgstr "Ei3(x)"

#. Tag: action
#: index.docbook:1906
#, no-c-format
msgid ""
"exponential integral Ei<subscript>3</subscript>(x) = &int;<subscript>0</"
"subscript><superscript>x</superscript> exp(-t<superscript>3</superscript>) "
"dt for x &gt;= 0"
msgstr ""
"eksponentni integral Ei<subscript>3</subscript>(x) = &int;<subscript>0</"
"subscript><superscript>x</superscript> exp(-t<superscript>3</superscript>) "
"dt za x &gt;= 0"

#. Tag: entry
#: index.docbook:1907
#, no-c-format
msgid "si(x)"
msgstr "si(x)"

#. Tag: action
#: index.docbook:1907
#, no-c-format
msgid ""
"Sine integral Si(x) = &int;<subscript>0</subscript><superscript>x</"
"superscript> sin(t)/t dt"
msgstr ""
"Sinusni integral Si(x) = &int;<subscript>0</subscript><superscript>x</"
"superscript> sin(t)/t dt"

#. Tag: entry
#: index.docbook:1908
#, no-c-format
msgid "ci(x)"
msgstr "ci(x)"

#. Tag: action
#: index.docbook:1908
#, no-c-format
msgid ""
"Cosine integral Ci(x) = -&int;<subscript>x</subscript><superscript>&infin;</"
"superscript> cos(t)/t dt for x &gt; 0"
msgstr ""
"Kosinusni integral Ci(x) = -&int;<subscript>x</subscript><superscript>&infin;"
"</superscript> cos(t)/t dt za x &gt; 0"

#. Tag: entry
#: index.docbook:1909
#, no-c-format
msgid "atanint(x)"
msgstr "atanint(x)"

#. Tag: action
#: index.docbook:1909
#, no-c-format
msgid ""
"Arctangent integral AtanInt(x) = &int;<subscript>0</"
"subscript><superscript>x</superscript> arctan(t)/t dt"
msgstr ""
"Arktangensni integral AtanInt(x) = &int;<subscript>0</"
"subscript><superscript>x</superscript> arctan(t)/t dt"

#. Tag: entry
#: index.docbook:1910
#, no-c-format
msgid "Fm1(x)"
msgstr "Fm1(x)"

#. Tag: action
#: index.docbook:1910
#, no-c-format
msgid ""
"complete Fermi-Dirac integral with an index of -1, F<subscript>-1</"
"subscript>(x) = e<superscript>x</superscript> / (1 + e<superscript>x</"
"superscript>)"
msgstr ""
"popoln Fermi-Diracov integral z indeksom -1, F<subscript>-1</subscript>(x) = "
"e<superscript>x</superscript> / (1 + e<superscript>x</superscript>)"

#. Tag: entry
#: index.docbook:1911
#, no-c-format
msgid "F0(x)"
msgstr "F0(x)"

#. Tag: action
#: index.docbook:1911
#, no-c-format
msgid ""
"complete Fermi-Dirac integral with an index of 0, F<subscript>0</"
"subscript>(x) = ln(1 + e<superscript>x</superscript>)"
msgstr ""
"popoln Fermi-Diracov integral z indeksom 0, F<subscript>0</subscript>(x) = "
"ln(1 + e<superscript>x</superscript>)"

#. Tag: entry
#: index.docbook:1912
#, no-c-format
msgid "F1(x)"
msgstr "F1(x)"

#. Tag: action
#: index.docbook:1912
#, no-c-format
msgid ""
"complete Fermi-Dirac integral with an index of 1, F<subscript>1</"
"subscript>(x) = &int;<subscript>0</subscript><superscript>&infin;</"
"superscript> (t /(exp(t-x)+1)) dt"
msgstr ""
"popoln Fermi-Diracov integral z indeksom 1, F<subscript>1</subscript>(x) = "
"&int;<subscript>0</subscript><superscript>&infin;</superscript> (t /(exp(t-"
"x) )+1)) dt"

#. Tag: entry
#: index.docbook:1913
#, no-c-format
msgid "F2(x)"
msgstr "F2(x)"

#. Tag: action
#: index.docbook:1913
#, no-c-format
msgid ""
"complete Fermi-Dirac integral with an index of 2, F<subscript>2</"
"subscript>(x) = (1/2) &int;<subscript>0</subscript><superscript>&infin;</"
"superscript> (t<superscript>2</superscript> /(exp(t-x)+1)) dt"
msgstr ""
"popoln Fermi-Diracov integral z indeksom 2, F<subscript>2</subscript>(x) = "
"(1/2) &int;<subscript>0</subscript><superscript>&infin;</superscript> (t "
"<superscript>2</superscript> /(exp(t-x)+1)) dt"

#. Tag: entry
#: index.docbook:1914
#, no-c-format
msgid "Fj(j,x)"
msgstr "Fj(j,x)"

#. Tag: action
#: index.docbook:1914
#, no-c-format
msgid ""
"complete Fermi-Dirac integral with an index of j, F<subscript>j</"
"subscript>(x) = (1/&Gamma;(j+1)) &int;<subscript>0</"
"subscript><superscript>&infin;</superscript> (t<superscript>j</superscript> /"
"(exp(t-x)+1)) dt"
msgstr ""
"popoln Fermi-Diracov integral z indeksom j, F<subscript>j</subscript>(x) = "
"(1/&Gamma;(j+1)) &int;<subscript>0</subscript><superscript>&infin; </"
"superscript> (t<superscript>j</superscript> /(exp(t-x)+1)) dt"

#. Tag: entry
#: index.docbook:1915
#, no-c-format
msgid "Fmhalf(x)"
msgstr "Fmhalf(x)"

#. Tag: action
#: index.docbook:1915
#, no-c-format
msgid "complete Fermi-Dirac integral F<subscript>-1/2</subscript>(x)"
msgstr "popoln Fermi-Diracov integral F<subscript>-1/2</subscript>(x)"

#. Tag: entry
#: index.docbook:1916
#, no-c-format
msgid "Fhalf(x)"
msgstr "Fhalf(x)"

#. Tag: action
#: index.docbook:1916
#, no-c-format
msgid "complete Fermi-Dirac integral F<subscript>1/2</subscript>(x)"
msgstr "popoln Fermi-Diracov integral F<subscript>1/2</subscript>(x)"

#. Tag: entry
#: index.docbook:1917
#, no-c-format
msgid "F3half(x)"
msgstr "F3half(x)"

#. Tag: action
#: index.docbook:1917
#, no-c-format
msgid "complete Fermi-Dirac integral F<subscript>3/2</subscript>(x)"
msgstr "popoln Fermi-Diracov integral F<subscript>3/2</subscript>(x)"

#. Tag: entry
#: index.docbook:1918
#, no-c-format
msgid "Finc0(x,b)"
msgstr "Finc0(x,b)"

#. Tag: action
#: index.docbook:1918
#, no-c-format
msgid ""
"incomplete Fermi-Dirac integral with an index of zero, F<subscript>0</"
"subscript>(x,b) = ln(1 + e<superscript>b-x</superscript>) - (b-x)"
msgstr ""
"nepopoln Fermi-Diracov integral z indeksom nič, F<subscript>0</subscript>(x,"
"b) = ln(1 + e<superscript>b-x</superscript>) - (b-x)"

#. Tag: entry
#: index.docbook:1919
#, no-c-format
msgid "lngamma(x)"
msgstr "lngamma(x)"

#. Tag: action
#: index.docbook:1919
#, no-c-format
msgid "logarithm of the Gamma function"
msgstr "logaritem funkcije gama"

#. Tag: entry
#: index.docbook:1920
#, no-c-format
msgid "gammastar(x)"
msgstr "gammastar(x)"

#. Tag: action
#: index.docbook:1920
#, no-c-format
msgid ""
"regulated Gamma Function &Gamma;<superscript>*</superscript>(x) for x &gt; 0"
msgstr ""
"regulirana funkcija gama &Gamma;<superscript>*</superscript>(x) za x &gt; 0"

#. Tag: entry
#: index.docbook:1921
#, no-c-format
msgid "gammainv(x)"
msgstr "gammainv(x)"

#. Tag: action
#: index.docbook:1921
#, no-c-format
msgid ""
"reciprocal of the gamma function, 1/&Gamma;(x) using the real Lanczos method."
msgstr ""
"recipročna vrednost gama funkcije, 1/&Gamma;(x) z uporabo prave Lanczosove "
"metode."

#. Tag: entry
#: index.docbook:1922
#, no-c-format
msgid "fact(n)"
msgstr "fact(n)"

#. Tag: action
#: index.docbook:1922
#, no-c-format
msgid "factorial n!"
msgstr "faktoriel n!"

#. Tag: entry
#: index.docbook:1923
#, no-c-format
msgid "doublefact(n)"
msgstr "doublefact(n)"

#. Tag: action
#: index.docbook:1923
#, no-c-format
msgid "double factorial n!! = n(n-2)(n-4)..."
msgstr "dvojni faktoriel n!! = n(n-2)(n-4)..."

#. Tag: entry
#: index.docbook:1924
#, no-c-format
msgid "lnfact(n)"
msgstr "lnfact(n)"

#. Tag: action
#: index.docbook:1924
#, no-c-format
msgid "logarithm of the factorial of n, log(n!)"
msgstr "logaritem faktorijela od n, log(n!)"

#. Tag: entry
#: index.docbook:1925
#, no-c-format
msgid "lndoublefact(n)"
msgstr "lndoublefact(n)"

#. Tag: action
#: index.docbook:1925
#, no-c-format
msgid "logarithm of the double factorial log(n!!)"
msgstr "logaritem dvojnega faktoriela log(n!!)"

#. Tag: entry
#: index.docbook:1926
#, no-c-format
msgid "choose(n,m)"
msgstr "choose(n,m)"

#. Tag: action
#: index.docbook:1926
#, no-c-format
msgid "combinatorial factor `n choose m' = n!/(m!(n-m)!)"
msgstr "kombinatorni faktor `n izberi m' = n!/(m!(n-m)!)"

#. Tag: entry
#: index.docbook:1927
#, no-c-format
msgid "lnchoose(n,m)"
msgstr "lnchoose(n,m)"

#. Tag: action
#: index.docbook:1927
#, no-c-format
msgid "logarithm of `n choose m'"
msgstr "logaritem `n izberi m'"

#. Tag: entry
#: index.docbook:1928
#, no-c-format
msgid "taylor(n,x)"
msgstr "taylor(n,x)"

#. Tag: action
#: index.docbook:1928
#, no-c-format
msgid ""
"Taylor coefficient x<superscript>n</superscript> / n! for x >= 0, n >= 0"
msgstr ""
"Taylorjev koeficient x<superscript>n</superscript> / n! za x >= 0, n >= 0"

#. Tag: entry
#: index.docbook:1929
#, no-c-format
msgid "poch(a,x)"
msgstr "poch(a,x)"

#. Tag: action
#: index.docbook:1929
#, no-c-format
msgid ""
"Pochhammer symbol (a)<subscript>x</subscript> := &Gamma;(a + x)/&Gamma;(x)"
msgstr ""
"Pochhammer simbol (a)<subscript>x</subscript> := &Gamma;(a + x)/&Gamma;(x)"

#. Tag: entry
#: index.docbook:1930
#, no-c-format
msgid "lnpoch(a,x)"
msgstr "lnpoch(a,x)"

#. Tag: action
#: index.docbook:1930
#, no-c-format
msgid ""
"logarithm of the Pochhammer symbol (a)<subscript>x</subscript> := &Gamma;(a "
"+ x)/&Gamma;(x)"
msgstr ""
"logaritem simbola Pochhammer (a)<subscript>x</subscript> := &Gamma;(a + x)/"
"&Gamma;(x)"

#. Tag: entry
#: index.docbook:1931
#, no-c-format
msgid "pochrel(a,x)"
msgstr "pochrel(a,x)"

#. Tag: action
#: index.docbook:1931
#, no-c-format
msgid ""
"relative Pochhammer symbol ((a,x) - 1)/x where (a,x) = (a)<subscript>x</"
"subscript> := &Gamma;(a + x)/&Gamma;(a)"
msgstr ""
"relativni simbol Pochhammer ((a,x) - 1)/x kjer je (a,x) = (a)<subscript>x</"
"subscript> := &Gamma;(a + x)/&Gamma;(a)"

#. Tag: entry
#: index.docbook:1932
#, no-c-format
msgid "gammainc(a,x)"
msgstr "gamainc(a,x)"

#. Tag: action
#: index.docbook:1932
#, no-c-format
msgid ""
"incomplete Gamma Function &Gamma;(a,x) = &int;<subscript>x</"
"subscript><superscript>&infin;</superscript> t<superscript>a-1</superscript> "
"exp(-t) dt for a &gt; 0, x &gt;= 0"
msgstr ""
"nepopolna funkcija gama &Gamma;(a,x) = &int;<subscript>x</"
"subscript><superscript>&infin;</superscript> t<superscript>a-1</superscript> "
"exp(-t) dt for a &gt; 0, x &gt;= 0"

#. Tag: entry
#: index.docbook:1933
#, no-c-format
msgid "gammaincQ(a,x)"
msgstr "gamaincQ(a,x)"

#. Tag: action
#: index.docbook:1933
#, no-c-format
msgid ""
"normalized incomplete Gamma Function P(a,x) = 1/&Gamma;(a) &int;"
"<subscript>x</subscript><superscript>&infin;</superscript> "
"t<superscript>a-1</superscript> exp(-t) dt for a &gt; 0, x &gt;= 0"
msgstr ""
"normalizirana nepopolna funkcija gama P(a,x) = 1/&Gamma;(a) &int;"
"<subscript>x</subscript><superscript>&infin;</superscript> "
"t<superscript>a-1</superscript> exp( -t) dt za a &gt; 0, x &gt;= 0"

#. Tag: entry
#: index.docbook:1934
#, no-c-format
msgid "gammaincP(a,x)"
msgstr "gamaincP(a,x)"

#. Tag: action
#: index.docbook:1934
#, no-c-format
msgid ""
