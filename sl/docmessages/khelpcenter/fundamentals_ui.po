#. Tag: title
#: ui.docbook:18
#, no-c-format
msgid "A Visual Dictionary"
msgstr "Vizualni slovar"

#. Tag: para
#: ui.docbook:20
#, no-c-format
msgid ""
"The &plasma-workspaces; feature many different graphical user interface "
"elements, commonly known as <quote>widgets</quote>. This guide will "
"introduce you to their names and functions."
msgstr ""
"&plasma-workspaces; vsebuje veliko različnih elementov grafičnega "
"uporabniškega vmesnika, splošno znanih kot <quote>pripomočki</quote>. Ta "
"vodnik vam bo predstavil njihova imena in funkcije."

#. Tag: title
#: ui.docbook:25
#, no-c-format
msgid "The Big Picture"
msgstr "Širša slika"

#. Tag: title
#: ui.docbook:28
#, no-c-format
msgid "Windows"
msgstr "Okna"

#. Tag: screeninfo
#: ui.docbook:31
#, no-c-format
msgid "A Window"
msgstr "Okno"

#. Tag: para
#: ui.docbook:55
#, no-c-format
msgid ""
"This is the window of the &kwrite;, a text editor. Click on part of the "
"window to learn more about it."
msgstr ""
"To je okno &kwrite;, urejevalnika besedil. Kliknite na del okna, če želite "
"izvedeti več o tem."

#. Tag: para
#: ui.docbook:60
#, no-c-format
msgid "The <emphasis role=\"bold\">Window Menu</emphasis>"
msgstr "<emphasis role=\"bold\">Meni okna</emphasis>"

#. Tag: para
#: ui.docbook:64
#, no-c-format
msgid ""
"The <emphasis role=\"bold\"><link linkend=\"visualdict-titlebar\">Titlebar</"
"link></emphasis>"
msgstr ""
"<emphasis role=\"bold\"><link linkend=\"visualdict-titlebar\">Naslovna "
"vrstica</link></emphasis>"

#. Tag: para
#: ui.docbook:68
#, no-c-format
msgid ""
"Buttons to <emphasis>minimize</emphasis>, <emphasis>maximize</emphasis>, or "
"<emphasis>close</emphasis> the window"
msgstr ""
"Gumbi za <emphasis>strnjenje</emphasis>, <emphasis>razpetje</emphasis> ali "
"<emphasis>zapiranje</emphasis> okna"

#. Tag: para
#: ui.docbook:73
#, no-c-format
msgid ""
"The <emphasis role=\"bold\"><link linkend=\"visualdict-menubar\">Menubar</"
"link></emphasis>"
msgstr ""
"<emphasis role=\"bold\"><link linkend=\"visualdict-menubar\">Menijska "
"vrstica</link></emphasis>"

#. Tag: para
#: ui.docbook:77
#, no-c-format
msgid ""
"The <emphasis role=\"bold\"><link linkend=\"visualdict-toolbar\">Toolbar</"
"link></emphasis>"
msgstr ""
"<emphasis role=\"bold\"><link linkend=\"visualdict-toolbar\">Orodna vrstica</"
"link></emphasis>"

#. Tag: para
#: ui.docbook:81
#, no-c-format
msgid ""
"A very large <emphasis role=\"bold\"><link linkend=\"visualdict-text-area"
"\">Text Area</link></emphasis> that acts as this program's <emphasis role="
"\"bold\"><link linkend=\"visualdict-central-widget\">Central Widget</link></"
"emphasis>"
msgstr ""
"Zelo veliko <emphasis role=\"bold\"><link linkend=\"visualdict-text-area"
"\">besedilno območje</link></emphasis>, ki deluje kot <emphasis role=\"bold"
"\"><link linkend=\"visualdict-central-widget\">Osrednji pripomoček</link></"
"emphasis>tega programa"

#. Tag: para
#: ui.docbook:88
#, no-c-format
msgid ""
"A vertical <emphasis role=\"bold\"><link linkend=\"visualdict-scrollbar"
"\">Scrollbar</link></emphasis> (there is also a horizontal scrollbar below "
"the text box)"
msgstr ""
"Navpični <emphasis role=\"bold\"><link linkend=\"visualdict-scrollbar"
"\">drsni trak</link></emphasis> (pod besedilnim poljem je tudi vodoravni "
"drsni trak)"

#. Tag: para
#: ui.docbook:93
#, no-c-format
msgid ""
"The <emphasis role=\"bold\"><link linkend=\"visualdict-statusbar"
"\">Statusbar</link></emphasis>"
msgstr ""
"<emphasis role=\"bold\"><link linkend=\"visualdict-statusbar\">Statusna "
"vrstica</link></emphasis>"

#. Tag: screeninfo
#: ui.docbook:100
#, no-c-format
msgid "Another Window"
msgstr "Drugo okno"

#. Tag: para
#: ui.docbook:119
#, no-c-format
msgid ""
"This is the another window, that of the &dolphin; file manager. Click on "
"part of the window to learn more about it."
msgstr ""
"To je drugo okno, okno &dolphin; upravitelj datotek. Kliknite na del okna, "
"če želite izvedeti več o njem."

#. Tag: para
#: ui.docbook:124
#, no-c-format
msgid ""
"A <emphasis role=\"bold\"><link linkend=\"visualdict-panel\">panel</link></"
"emphasis> that contains a list of Places on the computer system"
msgstr ""
"<emphasis role=\"bold\"><link linkend=\"visualdict-panel\">plošča</link></"
"emphasis>, ki vsebuje seznam mest v računalniškem sistemu"

#. Tag: para
#: ui.docbook:129
#, no-c-format
msgid ""
"A <emphasis role=\"bold\"><link linkend=\"visualdict-breadcrumb"
"\">Breadcrumb</link></emphasis> of the path of the displayed folder"
msgstr ""
"<emphasis role=\"bold\"><link linkend=\"visualdict-breadcrumb\">Drobtinica</"
"link></emphasis> poti prikazane mape"

#. Tag: para
#: ui.docbook:134
#, no-c-format
msgid ""
"A folder <emphasis role=\"bold\"><link linkend=\"visualdict-icon\">Icon</"
"link></emphasis>"
msgstr ""
"Mapa <emphasis role=\"bold\"><link linkend=\"visualdict-icon\">Ikona</link></"
"emphasis>"

#. Tag: para
#: ui.docbook:138
#, no-c-format
msgid ""
"A file <emphasis role=\"bold\"><link linkend=\"visualdict-icon\">Icon</"
"link></emphasis>"
msgstr ""
"Datoteka <emphasis role=\"bold\"><link linkend=\"visualdict-icon\">Ikona</"
"link></emphasis>"

#. Tag: para
#: ui.docbook:142
#, no-c-format
msgid ""
"A highlighted <emphasis role=\"bold\"><link linkend=\"visualdict-icon"
"\">Icon</link></emphasis>"
msgstr ""
"Označena <emphasis role=\"bold\"><link linkend=\"visualdict-icon\">ikona</"
"link></emphasis>"

#. Tag: para
#: ui.docbook:146
#, no-c-format
msgid ""
"A <emphasis role=\"bold\"><link linkend=\"visualdict-context-menu\">Context "
"Menu</link></emphasis> listing actions that can be performed on a file"
msgstr ""
"<emphasis role=\"bold\"><link linkend=\"visualdict-context-menu\">Kontekstni "
"meni</link></emphasis> s seznamom dejanj, ki jih je mogoče izvesti v datoteki"

#. Tag: para
#: ui.docbook:151
#, no-c-format
msgid ""
"A <emphasis role=\"bold\"><link linkend=\"visualdict-slider\">Slider</link></"
"emphasis> that changes the size of the <link linkend=\"visualdict-icon"
"\">Icons</link> displayed"
msgstr ""
"<emphasis role=\"bold\"><link linkend=\"visualdict-slider\">Drsnik</link></"
"emphasis>, ki spremeni velikost prikazanih <link linkend=\"visualdict-icon"
"\">ikon</link>"

#. Tag: para
#: ui.docbook:157
#, no-c-format
msgid ""
"More <emphasis role=\"bold\"><link linkend=\"visualdict-panel\">Panels</"
"link></emphasis>"
msgstr ""
"Več <emphasis role=\"bold\"><link linkend=\"visualdict-panel\">plošč</link></"
"emphasis>"

