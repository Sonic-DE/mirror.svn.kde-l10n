#. Tag: title
#: menu-commands.docbook:8
#, no-c-format
msgid "Menu Commands"
msgstr "Menijski ukazi"

#. Tag: primary
#: menu-commands.docbook:10
#, no-c-format
msgid "Commands"
msgstr "Ukazi"

#. Tag: secondary
#: menu-commands.docbook:11
#, no-c-format
msgid "Menu"
msgstr "Meni"

#. Tag: title
#: menu-commands.docbook:14
#, no-c-format
msgid "File Menu"
msgstr "Meni Datoteka"

#. Tag: menuchoice
#: menu-commands.docbook:18
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Shift; <keycap>F4</keycap></keycombo> "
"</shortcut> <guimenu>File</guimenu> <guimenuitem>New Text File...</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Shift; <keycap>F4</keycap></keycombo> "
"</shortcut> <guimenu>Datoteka</guimenu> <guimenuitem>Nova besedilna "
"datoteka ...</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:28
#, no-c-format
msgid ""
"Creates a new text file in the current folder, unless another folder is "
"specified. The new file is opened for editing after it is created."
msgstr ""
"Ustvari novo besedilno datoteko v trenutni mapi, razen če je navedena druga "
"mapa. Nova datoteka se po izdelavi odpre za urejanje."

#. Tag: menuchoice
#: menu-commands.docbook:35
#, no-c-format
msgid ""
"<shortcut> <keycap>F7</keycap> </shortcut> <guimenu>File</guimenu> "
"<guimenuitem>New Folder</guimenuitem>"
msgstr ""
"<shortcut> <keycap>F7</keycap> </shortcut> <guimenu>Datoteka</guimenu> "
"<guimenuitem>Nova mapa</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:44
#, no-c-format
msgid "Creates a new folder in the current folder."
msgstr "Ustvari novo mapo v trenutni mapi."

#. Tag: menuchoice
#: menu-commands.docbook:50
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> &Alt;&Ctrl; <keycap>S</keycap></"
"keycombo> </shortcut> <guimenu>File</guimenu> <guimenuitem>New Symlink...</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> &Alt;&Ctrl; <keycap>S</keycap></"
"keycombo> </shortcut> <guimenu>Datoteka</guimenu> <guimenuitem>Nova simbolna "
"povezava ...</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:61
#, no-c-format
msgid "Creates a symbolic link to the currently selected file."
msgstr "Ustvari simbolično povezavo do trenutno izbrane datoteke."

#. Tag: menuchoice
#: menu-commands.docbook:67
#, no-c-format
msgid ""
"<shortcut> <keycap>F3</keycap> </shortcut> <guimenu>File</guimenu> "
"<guimenuitem>View File</guimenuitem>"
msgstr ""
"<shortcut> <keycap>F3</keycap> </shortcut> <guimenu>Datoteka</guimenu> "
"<guimenuitem>Ogled datoteke</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:76
#, no-c-format
msgid ""
"Opens the currently selected file for <link linkend=\"kredit\">viewing</"
"link>."
msgstr ""
"Odpre trenutno izbrano datoteko za <link linkend=\"kredit\">ogled</link>."

#. Tag: menuchoice
#: menu-commands.docbook:82
#, no-c-format
msgid ""
"<shortcut> <keycap>F4</keycap> </shortcut> <guimenu>File</guimenu> "
"<guimenuitem>Edit File</guimenuitem>"
msgstr ""
"<shortcut> <keycap>F4</keycap> </shortcut> <guimenu>Datoteka</guimenu> "
"<guimenuitem>Uredi datoteko</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:91
#, no-c-format
msgid ""
"Opens the currently selected file for <link linkend=\"kredit\">editing</"
"link>."
msgstr ""
"Odpre trenutno izbrano datoteko za <link linkend=\"kredit\">urejanje</link>."

#. Tag: menuchoice
#: menu-commands.docbook:97
#, no-c-format
msgid ""
"<shortcut> <keycap>F5</keycap> </shortcut> <guimenu>File</guimenu> "
"<guimenuitem>Copy to other panel</guimenuitem>"
msgstr ""
"<shortcut> <keycap>F5</keycap> </shortcut> <guimenu>Datoteka</guimenu> "
"<guimenuitem>Kopiraj na drugo ploščo</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:106
#, no-c-format
msgid "Copy the currently selected files or folders to the other panel."
msgstr "Kopirajte trenutno izbrane datoteke ali mape na drugo ploščo."

#. Tag: menuchoice
#: menu-commands.docbook:112
#, no-c-format
msgid ""
"<shortcut> <keycap>F6</keycap> </shortcut> <guimenu>File</guimenu> "
"<guimenuitem>Move</guimenuitem>"
msgstr ""
"<shortcut> <keycap>F6</keycap> </shortcut> <guimenu>Datoteka</guimenu> "
"<guimenuitem>Premakni</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:121
#, no-c-format
msgid ""
"Opens a dialog to <link linkend=\"copying\">move</link> the currently "
"selected files or folders to a specified location."
msgstr ""
"Odpre pogovorno okno za <link linkend=\"copying\">premaknitev</link> "
"trenutno izbranih datotek ali map na določeno lokacijo."

#. Tag: menuchoice
#: menu-commands.docbook:128
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift; <keycap>P</keycap></"
"keycombo> </shortcut> <guimenu>File</guimenu> <guimenuitem>Pack...</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift; <keycap>P</keycap></"
"keycombo> </shortcut> <guimenu>Datoteka</guimenu> <guimenuitem>Paket ...</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:138
#, no-c-format
msgid ""
"Creates a <link linkend=\"pack-archive\">new archive</link> of all the "
"selected files and folders in the active panel."
msgstr ""
"Ustvari <link linkend=\"pack-archive\">nov arhiv</link> vseh izbranih "
"datotek in map v aktivni plošči."

#. Tag: menuchoice
#: menu-commands.docbook:146
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift; <keycap>U</keycap></"
"keycombo> </shortcut> <guimenu>File</guimenu> <guimenuitem>Unpack...</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift; <keycap>U</keycap></"
"keycombo> </shortcut> <guimenu>Datoteka</guimenu> <guimenuitem>Razpakiraj ..."
"</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:156
#, no-c-format
msgid ""
"<link linkend=\"unpacking-archives\">Unpacks</link> all the selected files "
"in the active panel."
msgstr ""
"<link linkend=\"unpacking-archives\">Razpakira</link> vse izbrane datoteke v "
"aktivni plošči."

#. Tag: menuchoice
#: menu-commands.docbook:163
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift; <keycap>E</keycap></"
"keycombo> </shortcut> <guimenu>File</guimenu> <guimenuitem>Test Archive</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift; <keycap>E</keycap></"
"keycombo> </shortcut> <guimenu>Datoteka</guimenu> <guimenuitem>Preizkusni "
"arhiv</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:173
#, no-c-format
msgid "<link linkend=\"test-archive\">Tests archive</link> for corruption."
msgstr "<link linkend=\"test-archive\">Arhiv testov</link> za poškodbe."

#. Tag: menuchoice
#: menu-commands.docbook:180
#, no-c-format
msgid ""
"<guimenu>File</guimenu> <guimenuitem>Compare by Content...</guimenuitem>"
msgstr ""
"<guimenu>Datoteka</guimenu> <guimenuitem>Primerjaj po vsebini ...</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:186
#, no-c-format
msgid ""
"Compares two current files by content - one from each panel via an external "
"graphical diff utility. By default &kompare; is used, but you can also use "
"&eg; <ulink url=\"http://furius.ca/xxdiff/\"><application>xxdiff</"
"application></ulink> or <ulink url=\"https://apps.kde.org/"
"kdiff3\"><application>KDiff3</application></ulink> , change it in the <link "
"linkend=\"konfig-dependencies\">Konfigurator Dependencies page</link>."
msgstr ""
"Primerja dve trenutni datoteki po vsebini - po eno iz vsake plošče prek "
"zunanjega grafičnega pripomočka za razlikovanje. Privzeto  se uporablja "
"&kompare;, vendar lahko uporabite tudi &eg; <ulink url=\"http://furius.ca/"
"xxdiff/\"><application>xxdiff</application></ulink> ali <ulink url=\"https://"
"www.kde.org/applications/development/kdiff3 /\"><application>KDiff3</"
"application></ulink> , spremenite na <link linkend=\"konfig-dependencies"
"\">strani z odvisnostmi konfiguratorja</link>."

#. Tag: menuchoice
#: menu-commands.docbook:196
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Shift; <keycap>F2</keycap></keycombo> "
"</shortcut> <guimenu>File</guimenu> <guimenuitem>Multi Rename...</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Shift; <keycap>F2</keycap></keycombo> "
"</shortcut> <guimenu>Datoteka</guimenu> <guimenuitem>Večkratno "
"preimenovanje...</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:206
#, no-c-format
msgid ""
"This menu option starts <ulink url=\"hhttps://apps.kde.org/krename"
"\"><application>Krename</application></ulink>, a very powerful external "
"batch renamer."
msgstr ""
"Ta menijska možnost zažene <ulink url=\"hhttps://apps.kde.org/krename"
"\"><application>Krename</application></ulink>, zelo zmogljiv zunanji paketni "
"preimenovanje."

#. Tag: title
#: menu-commands.docbook:209
#, no-c-format
msgid "Krename Features"
msgstr "Krename Lastnosti"

#. Tag: para
#: menu-commands.docbook:211
#, no-c-format
msgid "Renaming a list of files based on a set of expressions"
msgstr "Preimenovanje seznama datotek na podlagi niza izrazov"

#. Tag: para
#: menu-commands.docbook:215
#, no-c-format
msgid "Copying/moving a list of files to another folder"
msgstr "Kopiranje/premikanje seznama datotek v drugo mapo"

#. Tag: para
#: menu-commands.docbook:219
#, no-c-format
msgid "Convert filenames to upper/lower case"
msgstr "Pretvori imena datotek v velike/male črke"

#. Tag: para
#: menu-commands.docbook:222
#, no-c-format
msgid "Adding numbers to filenames"
msgstr "Dodajanje številk v imena datotek"

#. Tag: para
#: menu-commands.docbook:225
#, no-c-format
msgid "Finding and replacing parts of the filename"
msgstr "Iskanje in zamenjava delov imena datoteke"

#. Tag: para
#: menu-commands.docbook:229
#, no-c-format
msgid "Renaming MP3/OGG Vorbis files based on their ID3 tags"
msgstr "Preimenovanje datotek MP3/OGG Vorbis na podlagi njihovih oznak ID3"

#. Tag: para
#: menu-commands.docbook:233
#, no-c-format
msgid "Setting access and modification dates"
msgstr "Nastavitev datumov dostopa in spreminjanja"

#. Tag: para
#: menu-commands.docbook:236
#, no-c-format
msgid "Changing permissions and file ownership"
msgstr "Spreminjanje dovoljenj in lastništva datoteke"

#. Tag: para
#: menu-commands.docbook:239
#, no-c-format
msgid "A plugin API which allows you to extend KRename's features"
msgstr "API vtičnika, ki vam omogoča razširitev funkcij KRename"

#. Tag: para
#: menu-commands.docbook:243
#, no-c-format
msgid "Renaming folders recursively"
msgstr "Rekurzivno preimenovanje map"

#. Tag: para
#: menu-commands.docbook:246
#, no-c-format
msgid "Support for KFilePlugins"
msgstr "Podpora za KFilePlugins"

#. Tag: para
#: menu-commands.docbook:249
#, no-c-format
msgid "Undo renaming"
msgstr "Razveljavi preimenovanje"

#. Tag: para
#: menu-commands.docbook:252
#, no-c-format
msgid "And many more...."
msgstr "In še veliko več...."

#. Tag: menuchoice
#: menu-commands.docbook:259
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Create Checksum...</guimenuitem>"
msgstr ""
"<guimenu>Datoteka</guimenu> <guimenuitem>Ustvari kontrolno vsoto ...</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:265
#, no-c-format
msgid ""
"<link linkend=\"checksum\">Checksum creation</link> on file(s) and/or "
"folder(s)."
msgstr ""
"<link linkend=\"checksum\">Ustvarjanje kontrolne vsote</link> v datotekah in/"
"ali mapah."

#. Tag: menuchoice
#: menu-commands.docbook:272
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Verify Checksum...</guimenuitem>"
msgstr ""
"<guimenu>Datoteka</guimenu> <guimenuitem>Preveri kontrolno vsoto ...</"
"guimenuitem>"

#. Tag: link
#: menu-commands.docbook:279
#, no-c-format
msgid "Verify Checksum"
msgstr "Preveri kontrolno vsoto"

#. Tag: menuchoice
#: menu-commands.docbook:286
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>P</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Split File...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>P</keycap></keycombo> </"
"shortcut> <guimenu>Datoteka</guimenu> <guimenuitem>Razdeli datoteko ...</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:296
#, no-c-format
msgid ""
"The <link linkend=\"splitter\">Split file</link> function splits a file up "
"into multiple smaller files so that it can be stored on several smaller "
"media (like <hardware>diskettes, zip-drives, ...</hardware>) or sent by e-"
"mail."
msgstr ""
"Funkcija <link linkend=\"splitter\">Razdeli datoteko</link> datoteko razdeli "
"na več manjših datotek, tako da jo je mogoče shraniti na več manjših medijev "
"(kot so <hardware>diskete, zip pogoni, ...</hardware>) ali poslano po e-"
"pošti."

#. Tag: menuchoice
#: menu-commands.docbook:305
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>B</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Combine Files...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>B</keycap></keycombo> </"
"shortcut> <guimenu>Datoteka</guimenu> <guimenuitem>Združi datoteke ...</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:315
#, no-c-format
msgid ""
"The <link linkend=\"splitter\">Combine files</link> function combines "
"multiple files into one file after the <link linkend=\"splitter\">Split "
"file</link> function was used."
msgstr ""
"Funkcija <link linkend=\"splitter\">Združi datoteke</link> združi več "
"datotek v eno datoteko po uporabi funkcije <link linkend=\"splitter"
"\">Razdeli datoteko</link>."

#. Tag: menuchoice
#: menu-commands.docbook:323
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>Q</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Quit</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>Q</keycap></keycombo> </"
"shortcut> <guimenu>Datoteka</guimenu> <guimenuitem>Zapri</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:333
#, no-c-format
msgid ""
"Closes &krusader; and cleans up the temporary folder, the same as pressing "
"<keycap>F10</keycap> key."
msgstr ""
"Zapre &krusader; in počisti začasno mapo, enako kot bi pritisnili tipko "
"<keycap>F10</keycap>."

#. Tag: title
#: menu-commands.docbook:341
#, no-c-format
msgid "Edit Menu"
msgstr "Meni Uredi"

#. Tag: menuchoice
#: menu-commands.docbook:345
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>X</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Cut</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>X</keycap></keycombo> </"
"shortcut> <guimenu>Uredi</guimenu> <guimenuitem>Izreži</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:355
#, no-c-format
msgid ""
"<link linkend=\"copying\">Cuts</link> the selected file(s) to the clipboard "
"to be moved to another location."
msgstr ""
"<link linkend=\"copying\">Izreže</link> izbrane datoteke v odložišče, da jih "
"premaknete na drugo mesto."

#. Tag: menuchoice
#: menu-commands.docbook:362
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>C</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Copy</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>C</keycap></keycombo> </"
"shortcut> <guimenu>Uredi</guimenu> <guimenuitem>Kopiraj</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:372
#, no-c-format
msgid ""
"<link linkend=\"copying\">Copies</link> the selected file(s) to the "
"clipboard to be moved to another location."
msgstr ""
"<link linkend=\"copying\">Kopira</link> izbrane datoteke v odložišče, da jih "
"premakne na drugo mesto."

#. Tag: menuchoice
#: menu-commands.docbook:379
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>V</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Paste</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>V</keycap></keycombo> </"
"shortcut> <guimenu>Uredi</guimenu> <guimenuitem>Prilepi</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:389
#, no-c-format
msgid ""
"<link linkend=\"copying\">Pastes</link> previously cut or copied items from "
"the clipboard to the current folder."
msgstr ""
"<link linkend=\"copying\">Prilepi</link> predhodno izrezane ali kopirane "
"elemente iz odložišča v trenutno mapo."

#. Tag: menuchoice
#: menu-commands.docbook:414
#, no-c-format
msgid ""
"<shortcut> <keycap>F8</keycap> </shortcut> <guimenu>Edit</guimenu> "
"<guimenuitem>Delete</guimenuitem>"
msgstr ""
"<shortcut> <keycap>F8</keycap> </shortcut> <guimenu>Uredi</guimenu> "
"<guimenuitem>Izbriši</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:423
#, no-c-format
msgid ""
"<link linkend=\"deleting\">Deletes</link> the currently selected file(s)."
msgstr "<link linkend=\"deleting\">Izbriše</link> trenutno izbrane datoteke."

#. Tag: menuchoice
#: menu-commands.docbook:430
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>+</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Select Group...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>+</keycap></keycombo> </"
"shortcut> <guimenu>Uredi</guimenu> <guimenuitem>Izberi skupino ...</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:440
#, no-c-format
msgid ""
"Opens a dialog which allows you to select files in the active panel. In the "
"<guilabel>Search for</guilabel> dialog place the main search criteria. Enter "
"a filename, a wildcard ( <literal role=\"extension\">*.o.*</literal>, "
"<literal role=\"extension\">*.c</literal> &etc;) or both - separated by a "
"space. When using <literal>'text'</literal>, the results are the same as "
"<literal>'*text*'</literal>. You can exclude files from the search with "
"'|' (&eg; <literal role=\"extension\">'*.cpp *.h | *.moc.cpp'</literal>). "
"With the <link linkend=\"profiles\">profile handler</link> you can manage "
"your selections for future usage. A double-click on a profile is the same as "
"entering the selection and pressing the <guibutton>OK</guibutton> button. "
"More options for <guilabel>Select Group</guilabel> dialog are explained in "
"the <link linkend=\"krusearcher\">Search dialog</link>, which are basically "
"almost the same dialogs."
msgstr ""
"Odpre pogovorno okno, ki vam omogoča izbiro datotek na aktivni plošči. V "
"pogovorno okno <guilabel>Išči</guilabel> vnesite glavne iskalne kriterije. "
"Vnesite ime datoteke, nadomestni znak ( <literal role=\"extension\">*.o.*</"
"literal>, <literal role=\"extension\">*.c</literal> &etc;) ali oboje – "
"ločeno s presledkom . Pri uporabi <literal>'text'</literal> so rezultati "
"enaki kot <literal>'*text*'</literal>. Datoteke lahko izključite iz iskanja "
"z '|' (&eg; <literal role=\"extension\">'*.cpp *.h | *.moc.cpp'</literal>). "
"Z <link linkend=\"profiles\">obravnavalcem profilov</link> lahko upravljate "
"svoje izbire za prihodnjo uporabo. Dvojni klik na profil je enak vnosu "
"izbire in pritisku gumba <guibutton>V redu</guibutton>. Več možnosti za "
"pogovorno okno <guilabel>Izberi skupino</guilabel> je razloženo v <link "
"linkend=\"krusearcher\">pogovornem oknu za iskanje</link>, ki so v bistvu "
"skoraj enaka pogovorna okna."

#. Tag: menuchoice
#: menu-commands.docbook:465
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>-</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Unselect Group...</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>-</keycap></keycombo> </"
"shortcut> <guimenu>Uredi</guimenu> <guimenuitem>Prekliči izbiro skupine ...</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:475
#, no-c-format
msgid ""
"The opposite of <guimenuitem>Select Group</guimenuitem>. The files that "
"match the pattern in the active panel will be deselected."
msgstr ""
"Nasprotje od <guimenuitem>Izberi skupino</guimenuitem>. Datoteke, ki se "
"ujemajo z vzorcem v aktivni plošči, bodo preklicane."

#. Tag: menuchoice
#: menu-commands.docbook:483
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt; <keycap>+</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Select All</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt; <keycap>+</keycap></keycombo> </"
"shortcut> <guimenu>Uredi</guimenu> <guimenuitem>Izberi vse</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:493
#, no-c-format
msgid ""
"Selects all files in the active panel. You can also select all folders by "
"activating the <guilabel>Autoselect folders</guilabel> option in the <link "
"linkend=\"konfig-panel\">Konfigurator Panel page</link>."
msgstr ""
"Izbere vse datoteke v aktivni plošči. Vse mape lahko izberete tudi tako, da "
"aktivirate možnost <guilabel>Samodejno izberi mape</guilabel> na <link "
"linkend=\"konfig-panel\">strani plošče konfiguratorja</link>."

#. Tag: menuchoice
#: menu-commands.docbook:501
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt; <keycap>-</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Unselect All</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt; <keycap>-</keycap></keycombo> </"
"shortcut> <guimenu>Uredi</guimenu> <guimenuitem>Prekliči izbiro vseh</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:511
#, no-c-format
msgid "Unselects all the files in the active panel."
msgstr "Prekliče izbor vseh datotek na aktivni plošči."

#. Tag: menuchoice
#: menu-commands.docbook:516
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt; <keycap>*</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Invert Selection</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt; <keycap>*</keycap></keycombo> </"
"shortcut> <guimenu>Uredi</guimenu> <guimenuitem>Obrni izbor</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:526
#, no-c-format
msgid ""
"Inverts the selection status of all the files in the active panel (&ie; "
"selected files will become unselected and deselected files will become "
"selected)."
msgstr ""
"Obrne status izbire vseh datotek v aktivni plošči (&ie; izbrane datoteke "
"bodo postale neizbrane, preklicane pa izbrane)."

#. Tag: menuchoice
#: menu-commands.docbook:534
#, no-c-format
msgid "<guimenu>Edit</guimenu> <guimenuitem>Restore Selection</guimenuitem>"
msgstr "<guimenu>Uredi</guimenu> <guimenuitem>Obnovi izbor</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:540
#, no-c-format
msgid "Restore the selection status of previously unselected items."
msgstr "Obnovi status izbire predhodno neizbranih elementov."

#. Tag: menuchoice
#: menu-commands.docbook:545
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>F</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Find in folder...</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>F</keycap></keycombo> </"
"shortcut> <guimenu>Uredi</guimenu> <guimenuitem>Najdi v mapi ...</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:555
#, no-c-format
msgid ""
"Toggles &krusader; <link linkend=\"quicksearch\">quick search</link> "
"function."
msgstr ""
"Preklopi &krusader; <link linkend=\"quicksearch\">funkcija hitrega iskanja</"
"link>."

#. Tag: menuchoice
#: menu-commands.docbook:561
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift; <keycap>C</keycap></"
"keycombo> </shortcut> <guimenu>Edit</guimenu> <guimenuitem>Compare Folders</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift; <keycap>C</keycap></"
"keycombo> </shortcut> <guimenu>Uredi</guimenu> <guimenuitem>Primerjaj mape</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:571
#, no-c-format
msgid ""
"Toggles &krusader; <link linkend=\"compare-dir\">Compare Folders</link> "
"function."
msgstr ""
"Preklopi &krusader; Funkcija <link linkend=\"compare-dir\">Primerjaj mape</"
"link>."

#. Tag: menuchoice
#: menu-commands.docbook:577
#, no-c-format
msgid "<guimenu>Edit</guimenu> <guimenuitem>Compare Setup</guimenuitem>"
msgstr ""
"<guimenu>Uredi</guimenu> <guimenuitem>Primerjaj nastavitev</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:583
#, no-c-format
msgid "Configures the <guimenuitem>Compare Folders</guimenuitem> function."
msgstr "Konfigurira funkcijo <guimenuitem>Primerjaj mape</guimenuitem>."

#. Tag: para
#: menu-commands.docbook:587
#, no-c-format
msgid "<guimenuitem>Select Newer and Single</guimenuitem> (default)"
msgstr "<guimenuitem>Izberi novejše in enojno</guimenuitem> (privzeto)"

#. Tag: guimenuitem
#: menu-commands.docbook:592
#, no-c-format
msgid "Select Single"
msgstr "Izberite Single"

#. Tag: guimenuitem
#: menu-commands.docbook:597
#, no-c-format
msgid "Select Newer"
msgstr "Izberite Novejše"

#. Tag: guimenuitem
#: menu-commands.docbook:602
#, no-c-format
msgid "Select Different and Single"
msgstr "Izberite različne in posamezne"

#. Tag: guimenuitem
#: menu-commands.docbook:607
#, no-c-format
msgid "Select Different"
msgstr "Izberi drugo"

#. Tag: menuchoice
#: menu-commands.docbook:615
#, no-c-format
msgid ""
"<guimenu>Edit</guimenu> <guimenuitem>Calculate Occupied Space</guimenuitem>"
msgstr ""
"<guimenu>Uredi</guimenu> <guimenuitem>Izračunaj zaseden prostor</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:621
#, no-c-format
msgid ""
"<link linkend=\"calculate\">Calculates occupied space</link> of files and "
"folders, archives and remote filesystems."
msgstr ""
"<link linkend=\"calculate\">Izračuna zaseden prostor</link> datotek in map, "
"arhivov in oddaljenih datotečnih sistemov."

#. Tag: menuchoice
#: menu-commands.docbook:629
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt; <keysym>Return</keysym></"
"keycombo> </shortcut> <guimenu>Edit</guimenu> <guimenuitem>Properties...</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt; <keysym>Vrni se</keysym></"
"keycombo> </shortcut> <guimenu>Uredi</guimenu> <guimenuitem>Lastnosti ...</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:639
#, no-c-format
msgid ""
"Opens the properties dialog for the currently selected file. (KP refers to "
"Key Pad.)"
msgstr ""
"Odpre pogovorno okno lastnosti za trenutno izbrano datoteko. (KP se nanaša "
"na tipkovnico.)"

#. Tag: title
#: menu-commands.docbook:646
#, no-c-format
msgid "Go Menu"
msgstr "Pojdi meni"

#. Tag: menuchoice
#: menu-commands.docbook:650
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt; &Up;</keycombo> </shortcut> "
"<guimenu>Go</guimenu> <guimenuitem>Up</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt; &Up;</keycombo> </shortcut> "
"<guimenu>Pojdi</guimenu> <guimenuitem>Gor</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:660
#, no-c-format
msgid "Navigates to the parent folder of the active panel."
msgstr "Krmi do nadrejene mape aktivne plošče."

#. Tag: menuchoice
#: menu-commands.docbook:666
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt; &Left;</keycombo> </shortcut> "
"<guimenu>Go</guimenu> <guimenuitem>Back</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt; &Left;</keycombo> </shortcut> "
"<guimenu>Pojdi</guimenu> <guimenuitem>Nazaj</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:676
#, no-c-format
msgid "Navigates to the previously viewed folder in the active panel."
msgstr "Pomakne se do predhodno ogledane mape v aktivni plošči."

#. Tag: menuchoice
#: menu-commands.docbook:682
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt; &Right;</keycombo> </shortcut> "
"<guimenu>Go</guimenu> <guimenuitem>Forward</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt; &Right;</keycombo> </shortcut> "
"<guimenu>Pojdi</guimenu> <guimenuitem>Naprej</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:692
#, no-c-format
msgid ""
"Navigates to the next viewed folder in the active panel. Becomes available "
"only if <menuchoice><guimenu>Go</guimenu> <guimenuitem>Back</guimenuitem></"
"menuchoice> was used beforehand."
msgstr ""
"Pomika do naslednje ogledane mape v aktivni plošči. Postane na voljo le, če "
"ste predhodno uporabili <menuchoice><guimenu>Pojdi</guimenu> "
"<guimenuitem>Nazaj</guimenuitem></menuchoice>."

#. Tag: menuchoice
#: menu-commands.docbook:699
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt; &Home;</keycombo> </shortcut> "
"<guimenu>Go</guimenu> <guimenuitem>Home</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt; &Home;</keycombo> </shortcut> "
"<guimenu>Pojdi</guimenu> <guimenuitem>Domov</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:709
#, no-c-format
msgid "Navigates to the home folder of the current user."
msgstr "Pomakne se v domačo mapo trenutnega uporabnika."

#. Tag: menuchoice
#: menu-commands.docbook:715
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; &Backspace;</keycombo> </"
"shortcut> <guimenu>Go</guimenu> <guimenuitem>Root</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; &Backspace;</keycombo> </"
"shortcut> <guimenu>Pojdi</guimenu> <guimenuitem>Koren</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:725
#, no-c-format
msgid "Navigates to the root folder of the system."
msgstr "Pomakne se do korenske mape sistema."

#. Tag: menuchoice
#: menu-commands.docbook:731
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>Z</keycap></keycombo> </"
"shortcut> <guimenu>Go</guimenu> <guimenuitem>Popular &URL;s...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>Z</keycap></keycombo> </"
"shortcut> <guimenu>Pojdi</guimenu> <guimenuitem>Priljubljeni URL-ji ...</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:741
#, no-c-format
msgid ""
"Displays a listing of frequently viewed folders from which you may navigate "
"to one by double-clicking on it."
msgstr ""
"Prikaže seznam pogosto ogledovanih map, iz katerih se lahko pomaknete do ene "
"z dvojnim klikom nanjo."

#. Tag: menuchoice
#: menu-commands.docbook:748
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> &Ctrl;&Shift; <keycap>J</keycap></"
"keycombo> </shortcut> <guimenu>Go</guimenu> <guimenuitem>Set Jump Back "
"Point</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> &Ctrl;&Shift; <keycap>J</keycap></"
"keycombo> </shortcut> <guimenu>Pojdi</guimenu> <guimenuitem>Nastavi točko "
"skoka nazaj</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:759
#, no-c-format
msgid ""
"Sets the current folder as a <quote>jump back</quote> point. To navigate to "
"this folder quickly, select the <guimenuitem>Jump Back</guimenuitem> command "
"from the <guimenu>Go</guimenu> menu."
msgstr ""
"Nastavi trenutno mapo kot točko <quote>skoka nazaj</quote>. Za hiter "
"navigacijo do te mape izberite ukaz <guimenuitem>Skoči nazaj</guimenuitem> v "
"meniju <guimenu>Pojdi</guimenu>."

#. Tag: menuchoice
#: menu-commands.docbook:766
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>J</keycap></keycombo> </"
"shortcut> <guimenu>Go</guimenu> <guimenuitem>Jump Back</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>J</keycap></keycombo> </"
"shortcut> <guimenu>Pojdi</guimenu> <guimenuitem>Skoči nazaj</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:776
#, no-c-format
msgid "Returns to a previous <quote>jump back</quote> point."
msgstr "Vrnitev na prejšnjo točko <quote>skoka nazaj</quote>."

#. Tag: title
#: menu-commands.docbook:782
#, no-c-format
msgid "View Menu"
msgstr "Ogled menija"

#. Tag: para
#: menu-commands.docbook:783
#, no-c-format
msgid ""
"The action in this submenu usually affects the current &krusader; session. "
"If you want to make permanent changes use <link linkend=\"konfigurator"
"\">Konfigurator Startup page</link>."
msgstr ""
"Dejanje v tem podmeniju običajno vpliva na trenutni &krusader; sejo. Če "
"želite izvesti trajne spremembe, uporabite <link linkend=\"konfigurator"
"\">Zagonsko stran Konfiguratorja</link>."

#. Tag: menuchoice
#: menu-commands.docbook:789
#, no-c-format
msgid "<guimenu>View</guimenu> <guimenuitem>Zoom In</guimenuitem>"
msgstr "<guimenu>View</guimenu> <guimenuitem>Zoom In</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:795
#, no-c-format
msgid "Increase the view scale."
msgstr "Povečajte merilo pogleda."

#. Tag: menuchoice
#: menu-commands.docbook:800
#, no-c-format
msgid "<guimenu>View</guimenu> <guimenuitem>Zoom Out</guimenuitem>"
msgstr "<guimenu>Pogled</guimenu> <guimenuitem>Pomanjšaj</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:806
#, no-c-format
msgid "Decrease the view scale."
msgstr "Zmanjšajte merilo pogleda."

#. Tag: menuchoice
#: menu-commands.docbook:811
#, no-c-format
msgid "<guimenu>View</guimenu> <guimenuitem>Default Zoom</guimenuitem>"
msgstr "<guimenu>Pogled</guimenu> <guimenuitem>Privzeta povečava</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:817
#, no-c-format
msgid "Reset the view scale."
msgstr "Ponastavite merilo pogleda."

#. Tag: menuchoice
#: menu-commands.docbook:822
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> &Alt;&Shift; <keycap>D</keycap></"
"keycombo> </shortcut> <guimenu>View</guimenu> <guimenuitem>Detailed View</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> &Alt;&Shift; <keycap>D</keycap></"
"keycombo> </shortcut> <guimenu>Pogled</guimenu> <guimenuitem>Podroben "
"pogled</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:833
#, no-c-format
msgid ""
"Shows the file names, file size, creation date and time and their attributes."
msgstr ""
"Prikazuje imena datotek, velikost datoteke, datum in čas ustvarjanja ter "
"njihove atribute."

#. Tag: menuchoice
#: menu-commands.docbook:838
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> &Alt;&Shift; <keycap>B</keycap></"
"keycombo> </shortcut> <guimenu>View</guimenu> <guimenuitem>Brief View</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> &Alt;&Shift; <keycap>B</keycap></"
"keycombo> </shortcut> <guimenu>Pogled</guimenu> <guimenuitem>Kratek pogled</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:849
#, no-c-format
msgid "Shows only the file names."
msgstr "Prikaže samo imena datotek."

#. Tag: menuchoice
#: menu-commands.docbook:854
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt; <keycap>.</keycap></keycombo> </"
"shortcut> <guimenu>View</guimenu> <guimenuitem>Show Hidden Files</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt; <keycap>.</keycap></keycombo> </"
"shortcut> <guimenu>Pogled</guimenu> <guimenuitem>Pokaži skrite datoteke</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:864
#, no-c-format
msgid ""
"Toggles the option to display the hidden files in the &krusader; panels."
msgstr "Preklopi možnost prikaza skritih datotek v &krusader; plošče."

#. Tag: menuchoice
#: menu-commands.docbook:870
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Shift; <keycap>F10</keycap></"
"keycombo> </shortcut> <guimenu>View</guimenu> <guimenuitem>All Files</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Shift; <keycap>F10</keycap></"
"keycombo> </shortcut> <guimenu>Ogled</guimenu> <guimenuitem>Vse datoteke</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:880
#, no-c-format
msgid "Turns off all filters and display all files."
msgstr "Izklopi vse filtre in prikaže vse datoteke."

#. Tag: menuchoice
#: menu-commands.docbook:885
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Shift; <keycap>F12</keycap></"
"keycombo> </shortcut> <guimenu>View</guimenu> <guimenuitem>Custom</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Shift; <keycap>F12</keycap></"
"keycombo> </shortcut> <guimenu>Pogled</guimenu> <guimenuitem>Po meri</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:895
#, no-c-format
msgid ""
"Allows you to install a custom filter on the &krusader; panel. Only files "
"that match the filter pattern(s) and folders will be displayed. Do not "
"forget to deactivate the custom filter after use, or some files may not be "
"visible."
msgstr ""
"Omogoča namestitev filtra po meri na &krusader; panel. Prikazane bodo samo "
"datoteke, ki se ujemajo z vzorcem(-i) filtrov, in mape. Po uporabi ne "
"pozabite deaktivirati filtra po meri, sicer nekatere datoteke morda ne bodo "
"vidne."

#. Tag: menuchoice
#: menu-commands.docbook:904
#, no-c-format
msgid "<guimenu>View</guimenu> <guimenuitem>Show Previews</guimenuitem>"
msgstr ""
"<guimenu>Pogled</guimenu> <guimenuitem>Prikaži predoglede</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:910
#, no-c-format
msgid ""
"If checked, show the previews for all files and folders on the active panel."
msgstr ""
"Če je označeno, prikaži predoglede za vse datoteke in mape na aktivni plošči."

#. Tag: menuchoice
#: menu-commands.docbook:915
#, no-c-format
msgid ""
"<guimenu>View</guimenu> <guimenuitem>Select Remote Charset</guimenuitem>"
msgstr ""
"<guimenu>Pogled</guimenu> <guimenuitem>Izberite oddaljeni nabor znakov</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:921
#, no-c-format
msgid ""
"Selects the remote charset for <link linkend=\"remote-connections\">Remote "
"Connections</link>."
msgstr ""
"Izbere oddaljeni nabor znakov za <link linkend=\"remote-connections"
"\">Oddaljene povezave</link>."

#. Tag: menuchoice
#: menu-commands.docbook:927
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>R</keycap></keycombo> </"
"shortcut> <guimenu>View</guimenu> <guimenuitem>Reload</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>R</keycap></keycombo> </"
"shortcut> <guimenu>Pogled</guimenu> <guimenuitem>Znova naloži</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:937
#, no-c-format
msgid "Refreshes the contents of the active panel."
msgstr "Osveži vsebino aktivne plošče."

#. Tag: menuchoice
#: menu-commands.docbook:942
#, no-c-format
msgid ""
"<guimenu>View</guimenu> <guimenuitem>Save settings as default</guimenuitem>"
msgstr ""
"<guimenu>Pogled</guimenu> <guimenuitem>Shrani nastavitve kot privzete</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:948
#, no-c-format
msgid ""
"Allows you to save the view settings of the current tab for new instances of "
"this view type."
msgstr ""
"Omogoča vam shranjevanje nastavitev pogleda trenutnega zavihka za nove "
"primerke te vrste pogleda."

#. Tag: menuchoice
#: menu-commands.docbook:953
#, no-c-format
msgid ""
"<guimenu>View</guimenu> <guimenuitem>Apply settings to other tabs</"
"guimenuitem>"
msgstr ""
"<guimenu>Pogled</guimenu> <guimenuitem>Uporaba nastavitev za druge zavihke</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:959
#, no-c-format
msgid ""
"Allows you to apply the view settings of the current tab to the other tabs."
msgstr ""
"Omogoča uporabo nastavitev pogleda trenutnega zavihka na druge zavihke."

#. Tag: title
#: menu-commands.docbook:965
#, no-c-format
msgid "Useractions Menu"
msgstr "Meni uporabniških dejanj"

#. Tag: para
#: menu-commands.docbook:966
#, no-c-format
msgid ""
"You can add your own menu entries here by defining your own <link linkend="
"\"useractions\">UserActions</link>."
msgstr ""
"Tukaj lahko dodate lastne menijske vnose tako, da definirate lastna <link "
"linkend=\"useractions\">uporabniška dejanja</link>."

#. Tag: menuchoice
#: menu-commands.docbook:971
#, no-c-format
msgid ""
"<guimenu>Useractions</guimenu> <guimenuitem>Manage User Actions...</"
"guimenuitem>"
msgstr ""
"<guimenu>Uporabniška dejanja</guimenu> <guimenuitem>Upravljanje uporabniških "
"dejanj ...</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:977
#, no-c-format
msgid "Opens the <link linkend=\"useractions\">UserActions</link> manager."
msgstr ""
"Odpre upravitelja <link linkend=\"useractions\">uporabniških dejanj</link>."

#. Tag: menuchoice
#: menu-commands.docbook:983
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> &Meta; <keycap>A</keycap> </keycombo> "
"</shortcut> <guimenu>Useractions</guimenu><guisubmenu>Multimedia</"
"guisubmenu> <guimenuitem>Enqueue in Amarok</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> &Meta; <keycap>A</keycap> </keycombo> "
"</shortcut> <guimenu>Uporabniške akcije</"
"guimenu><guisubmenu>Večpredstavnost</guisubmenu> <guimenuitem>Dodaj v "
"čakalno vrsto v Amaroku</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:995
#, no-c-format
msgid "Appends selected item(s) to &amarok; playlist."
msgstr "Dodaja izbrane elemente v &amarok; seznam predvajanja."

#. Tag: menuchoice
#: menu-commands.docbook:1000
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> &Ctrl;&Alt; </keycombo> </shortcut> "
"<guimenu>Useractions</guimenu><guisubmenu>Samples</guisubmenu> "
"<guimenuitem>Equal panel-size</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> &Ctrl;&Alt; </keycombo> </shortcut> "
"<guimenu>Uporabniške akcije</guimenu><guisubmenu>Vzorci</guisubmenu> "
"<guimenuitem>Enaka velikost plošče</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1011
#, no-c-format
msgid "Sets the ratio between the two panels to 50/50."
msgstr "Nastavi razmerje med obema ploščama na 50/50."

#. Tag: menuchoice
#: menu-commands.docbook:1017
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> &Ctrl;<keycap>E</keycap> </keycombo> "
"</shortcut> <guimenu>Useractions</guimenu><guisubmenu>Samples</guisubmenu> "
"<guimenuitem>Edit as root</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> &Ctrl;<keycap>E</keycap> </keycombo> "
"</shortcut> <guimenu>Uporabniške akcije</guimenu><guisubmenu>Vzorci</"
"guisubmenu> <guimenuitem>Uredi kot koren</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1028
#, no-c-format
msgid ""
"Allows you to edit a file with <application>kwrite</application> using root "
"permissions."
msgstr ""
"Omogoča urejanje datoteke z <application>kwrite</application> z uporabo "
"korenskih dovoljenj."

#. Tag: menuchoice
#: menu-commands.docbook:1034
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> &Ctrl;&Alt;<keycap>M</keycap> </"
"keycombo> </shortcut> <guimenu>Useractions</guimenu><guisubmenu>Samples</"
"guisubmenu> <guimenuitem>Mount</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> &Ctrl;&Alt;<keycap>M</keycap> </"
"keycombo> </shortcut> <guimenu>Uporabniške akcije</"
"guimenu><guisubmenu>Vzorci</guisubmenu> <guimenuitem> Namesti</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1045
#, no-c-format
msgid "Mounts a new filesystem."
msgstr "Priklopi nov datotečni sistem."

#. Tag: menuchoice
#: menu-commands.docbook:1050
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> &Ctrl;&Alt;<keycap>C</keycap> </"
"keycombo> </shortcut> <guimenu>Useractions</guimenu><guisubmenu>Samples</"
"guisubmenu> <guimenuitem>Copy current item to clipboard</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> &Ctrl;&Alt;<keycap>C</keycap> </"
"keycombo> </shortcut> <guimenu>Uporabniške akcije</"
"guimenu><guisubmenu>Vzorci</guisubmenu> <guimenuitem> Kopiraj trenutni "
"element v odložišče</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1062
#, no-c-format
msgid "Copies current item name to the clipboard."
msgstr "Kopira trenutno ime elementa v odložišče."

#. Tag: menuchoice
#: menu-commands.docbook:1067
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> &Meta;<keycap>F5</keycap> </keycombo> "
"</shortcut> <guimenu>Useractions</guimenu><guisubmenu>System</guisubmenu> "
"<guimenuitem>Backup current</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> &Meta;<keycap>F5</keycap> </keycombo> "
"</shortcut> <guimenu>Uporabniške akcije</guimenu><guisubmenu>Sistem</"
"guisubmenu> <guimenuitem>Varnostna kopija trenutne </guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1078
#, no-c-format
msgid ""
"Backups current file in current folder and asks the user for a new filename. "
"By default <literal role=\"extension\">.old</literal> is appended to the "
"original filename."
msgstr ""
"Varnostno kopira trenutno datoteko v trenutno mapo in od uporabnika zahteva "
"novo ime datoteke. Privzeto je izvirnemu imenu datoteke pripet <literal role="
"\"extension\">.old</literal>."

#. Tag: menuchoice
#: menu-commands.docbook:1084
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> &Meta; <keycap>1</keycap> </keycombo> "
"</shortcut> <guimenu>Useractions</guimenu><guisubmenu>User Interface</"
"guisubmenu> <guimenuitem>Sort By Name</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> &Meta; <keycap>1</keycap> </keycombo> "
"</shortcut> <guimenu>Uporabniške akcije</guimenu><guisubmenu>Uporabniški "
"vmesnik</guisubmenu> <guimenuitem>Razvrsti po imenu</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1096
#, no-c-format
msgid ""
"When this action is turned on, the main sorting key in the &krusader; panel "
"becomes the file name."
msgstr ""
"Ko je to dejanje vklopljeno, bo glavni ključ za razvrščanje v &krusader; "
"panel postane ime datoteke."

#. Tag: menuchoice
#: menu-commands.docbook:1103
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> &Meta; <keycap>2</keycap> </keycombo> "
"</shortcut> <guimenu>Useractions</guimenu><guisubmenu>User Interface</"
"guisubmenu> <guimenuitem>Sort By Extension</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> &Meta; <keycap>2</keycap> </keycombo> "
"</shortcut> <guimenu>Uporabniške akcije</guimenu><guisubmenu>Uporabniški "
"vmesnik</guisubmenu> <guimenuitem>Razvrsti po razširitvi</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1115
#, no-c-format
msgid ""
"When this action is turned on, the main sorting key in the &krusader; panel "
"becomes the file extension (the part of the filename after the last '.'). "
"This is useful for grouping files of the same type closer together."
msgstr ""
"Ko je to dejanje vklopljeno, bo glavni ključ za razvrščanje v &krusader; "
"plošča postane končnica datoteke (del imena datoteke za zadnjim '.'). To je "
"uporabno za združevanje datotek iste vrste bližje skupaj."

#. Tag: menuchoice
#: menu-commands.docbook:1124
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> &Meta; <keycap>3</keycap> </keycombo> "
"</shortcut> <guimenu>Useractions</guimenu><guisubmenu>User Interface</"
"guisubmenu> <guimenuitem>Sort By Size</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> &Meta; <keycap>3</keycap> </keycombo> "
"</shortcut> <guimenu>Uporabniške akcije</guimenu><guisubmenu>Uporabniški "
"vmesnik</guisubmenu> <guimenuitem>Razvrsti po velikosti</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1136
#, no-c-format
msgid ""
"When this action is turned on, the main sorting key in the &krusader; panel "
"becomes the file size. This is useful for determining the largest files in a "
"particular folder."
msgstr ""
"Ko je to dejanje vklopljeno, bo glavni ključ za razvrščanje v &krusader; "
"plošča postane velikost datoteke. To je uporabno za določanje največjih "
"datotek v določeni mapi."

#. Tag: menuchoice
#: menu-commands.docbook:1144
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> &Meta; <keycap>4</keycap> </keycombo> "
"</shortcut> <guimenu>Useractions</guimenu><guisubmenu>User Interface</"
"guisubmenu> <guimenuitem>Sort By Modified</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> &Meta; <keycap>4</keycap> </keycombo> "
"</shortcut> <guimenu>Uporabniške akcije</guimenu><guisubmenu>Uporabniški "
"vmesnik</guisubmenu> <guimenuitem>Razvrsti po spremenjenem</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1156
#, no-c-format
msgid ""
"When this action is turned on, the main sorting key in the &krusader; panel "
"becomes the last modified date for each file. This is useful for finding "
"files you recently worked on."
msgstr ""
"Ko je to dejanje vklopljeno, bo glavni ključ za razvrščanje v &krusader; "
"plošča postane datum zadnje spremembe za vsako datoteko. To je uporabno za "
"iskanje datotek, s katerimi ste nedavno delali."

#. Tag: title
#: menu-commands.docbook:1165
#, no-c-format
msgid "Tools Menu"
msgstr "Meni Orodja"

#. Tag: menuchoice
#: menu-commands.docbook:1169
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>S</keycap></keycombo> </"
"shortcut> <guimenu>Tools</guimenu> <guimenuitem>Search...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>S</keycap></keycombo> </"
"shortcut> <guimenu>Orodja</guimenu> <guimenuitem>Iskanje ...</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1179
#, no-c-format
msgid ""
"Opens <link linkend=\"krusearcher\">KruSearcher</link> - the &krusader; "
"search module."
msgstr ""
"Odpre <link linkend=\"krusearcher\">KruSearcher</link> - &krusader; iskalni "
"modul."

#. Tag: menuchoice
#: menu-commands.docbook:1186
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> &Ctrl;&Shift; <keycap>L</keycap></"
"keycombo> </shortcut> <guimenu>Tools</guimenu> <guimenuitem>Locate...</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> &Ctrl;&Shift; <keycap>L</keycap></"
"keycombo> </shortcut> <guimenu>Orodja</guimenu> <guimenuitem>Poišči ...</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1197
#, no-c-format
msgid ""
"Opens the <link linkend=\"locate\">Locate</link> &GUI; frontend for fast "
"file searching."
msgstr ""
"Odpre <link linkend=\"locate\">Poišči</link> &GUI; frontend za hitro iskanje "
"datotek."

#. Tag: menuchoice
#: menu-commands.docbook:1203
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>Y</keycap></keycombo> </"
"shortcut> <guimenu>Tools</guimenu> <guimenuitem>Synchronize Folders</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>Y</keycap></keycombo> </"
"shortcut> <guimenu>Orodja</guimenu> <guimenuitem>Sinhroniziraj mape</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1213
#, no-c-format
msgid ""
"The <link linkend=\"synchronizer\">Synchronize Folders</link> function "
"compares the left and right panels and shows the differences between them. "
"After the compare function, you can move files/folders so that they can be "
"synchronized."
msgstr ""
"Funkcija <link linkend=\"synchronizer\">Sinhroniziraj mape</link> primerja "
"levo in desno ploščo ter prikaže razlike med njima. Po funkciji primerjave "
"lahko premaknete datoteke/mape, da jih je mogoče sinhronizirati."

#. Tag: menuchoice
#: menu-commands.docbook:1222
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt; <keycap>/</keycap></keycombo> </"
"shortcut> <guimenu>Tools</guimenu> <guimenuitem>MountMan...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt; <keycap>/</keycap></keycombo> </"
"shortcut> <guimenu>Orodja</guimenu> <guimenuitem>MountMan...</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1232
#, no-c-format
msgid ""
"Opens submenu with items to open <link linkend=\"mount-man\">MountMan</link> "
"or mount/unmount various mounting points."
msgstr ""
"Odpre podmeni z elementi za odpiranje <link linkend=\"mount-man\">MountMan</"
"link> ali priklop/odpenjanje različnih pritrdilnih točk."

#. Tag: menuchoice
#: menu-commands.docbook:1239
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift; <keycap>S</keycap></"
"keycombo> </shortcut> <guimenu>Tools</guimenu> <guimenuitem>Disk Usage...</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift; <keycap>S</keycap></"
"keycombo> </shortcut> <guimenu>Orodja</guimenu> <guimenuitem>Uporaba "
"diska ...</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1249
#, no-c-format
msgid "Opens <link linkend=\"diskusage\">Disk Usage</link>."
msgstr "Odpre <link linkend=\"diskusage\">Uporaba diska</link>."

#. Tag: menuchoice
#: menu-commands.docbook:1254
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>N</keycap></keycombo> </"
"shortcut> <guimenu>Tools</guimenu> <guimenuitem>New Net Connection</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>N</keycap></keycombo> </"
"shortcut> <guimenu>Orodja</guimenu> <guimenuitem>Nova omrežna povezava</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1264
#, no-c-format
msgid ""
"Opens the <link linkend=\"remote-connections\">New Network Connection</link> "
"dialog to start a &FTP;, SMB, FISH or SFTP connection to a remote host. If "
"you leave the user name and password fields empty, you will login as "
"anonymous. You can <link linkend=\"bookman\">Bookmark</link> these remote "
"sessions."
msgstr ""
"Odpre pogovorno okno <link linkend=\"remote-connections\">Nova omrežna "
"povezava</link> za začetek povezave &FTP;, SMB, FISH ali SFTP z oddaljenim "
"gostiteljem. Če pustite polji za uporabniško ime in geslo prazni, se boste "
"prijavili kot anonimni. Te oddaljene seje lahko dodate med <link linkend="
"\"bookman\">zaznamke</link>."

#. Tag: menuchoice
#: menu-commands.docbook:1276
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> &Ctrl;&Shift; <keycap>D</keycap></"
"keycombo> </shortcut> <guimenu>Tools</guimenu> <guimenuitem>Disconnect From "
"Net</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> &Ctrl;&Shift; <keycap>D</keycap></"
"keycombo> </shortcut> <guimenu>Orodja</guimenu> <guimenuitem>Prekini "
"povezavo z omrežjem</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1287
#, no-c-format
msgid ""
"Ends the <link linkend=\"remote-connections\">remote connection</link> in "
"the active panel and returns to the start-up path."
msgstr ""
"Konča <link linkend=\"remote-connections\">oddaljeno povezavo</link> v "
"aktivni plošči in se vrne na začetno pot."

#. Tag: menuchoice
#: menu-commands.docbook:1296
#, no-c-format
msgid "<guimenu>Tools</guimenu> <guimenuitem>Start Terminal</guimenuitem>"
msgstr "<guimenu>Orodja</guimenu> <guimenuitem>Zaženi terminal</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1302
#, no-c-format
msgid ""
"Opens a terminal window in the default folder (usually your home folder). "
"You can choose your favorite terminal application in the <link linkend="
"\"konfig-general\">Konfigurator General page</link>."
msgstr ""
"Odpre terminalsko okno v privzeti mapi (običajno vaša domača mapa). Svojo "
"najljubšo terminalsko aplikacijo lahko izberete na <link linkend=\"konfig-"
"general\">strani Konfigurator General</link>."

#. Tag: menuchoice
#: menu-commands.docbook:1310
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift; <keycap>K</keycap></"
"keycombo> </shortcut> <guimenu>Tools</guimenu> <guimenuitem>Start Root Mode "
"Krusader</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift; <keycap>K</keycap></"
"keycombo> </shortcut> <guimenu>Orodja</guimenu> <guimenuitem>Zaženi korenski "
"način Krusader</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1320
#, no-c-format
msgid ""
"Starts &krusader; in <link linkend=\"root-mode\">Root mode</link> at the "
"same location. Root mode &krusader; requires <command>kdesu</command> by "
"default, if <command>kdesu</command> is not available or if you prefer &eg; "
"<command>gksu</command> when using <ulink url=\"https://www.gnome.org"
"\"><application>GNOME</application></ulink> you can change this behaviour in "
"the <link linkend=\"konfig-dependencies\">Konfigurator Dependencies page</"
"link>."
msgstr ""
"Zažene &krusader; v <link linkend=\"root-mode\">Korenskem načinu</link> na "
"isti lokaciji. Korenski način &krusader; privzeto zahteva <command>kdesu</"
"command>, če <command>kdesu</command> ni na voljo ali če vam je ljubše &eg; "
"<command>gksu</command> pri uporabi <ulink url=\"https://www.gnome.org"
"\"><application>GNOME</application></ulink> lahko spremenite to vedenje v "
"<link linkend=\"konfig-dependencies\">Stran z odvisnostmi konfiguratorja</"
"link>."

#. Tag: para
#: menu-commands.docbook:1326
#, no-c-format
msgid "Be careful when using &krusader; with ROOT PRIVILEGES."
msgstr "Bodite previdni pri uporabi &krusader; s ROOT PRIVILEGIJI."

#. Tag: menuchoice
#: menu-commands.docbook:1334
#, no-c-format
msgid "<guimenu>Tools</guimenu> <guimenuitem>Empty Trash</guimenuitem>"
msgstr "<guimenu>Orodja</guimenu> <guimenuitem>Izprazni koš</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1340
#, no-c-format
msgid "Empties the <link linkend=\"deleting\">trash bin</link>."
msgstr "Izprazni <link linkend=\"deleting\">koš</link>."

#. Tag: title
#: menu-commands.docbook:1346
#, no-c-format
msgid "Window Menu"
msgstr "Okenski meni"

#. Tag: menuchoice
#: menu-commands.docbook:1350
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> &Ctrl;&Shift; <keycap>N</keycap></"
"keycombo> </shortcut> <guimenu>Window</guimenu> <guimenuitem>New Tab</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> &Ctrl;&Shift; <keycap>N</keycap></"
"keycombo> </shortcut> <guimenu>Okno</guimenu> <guimenuitem>Nov zavihek</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1361
#, no-c-format
msgid "Opens a new tab in the active panel."
msgstr "Odpre nov zavihek v aktivni plošči."

#. Tag: menuchoice
#: menu-commands.docbook:1366
#, no-c-format
msgid ""
"<guimenu>Window</guimenu> <guimenuitem>Lock Tab/Unlock Tab</guimenuitem>"
msgstr ""
"<guimenu>Okno</guimenu> <guimenuitem>Zakleni zavihek/Odkleni zavihek</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1372
#, no-c-format
msgid "Locks then unlocks current tab in the active panel."
msgstr "Zaklene in nato odklene trenutni zavihek v aktivni plošči."

#. Tag: menuchoice
#: menu-commands.docbook:1377
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> &Ctrl;&Alt;&Shift; <keycap>N</"
"keycap></keycombo> </shortcut> <guimenu>Window</guimenu> "
"<guimenuitem>Duplicate Current Tab</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> &Ctrl;&Alt;&Shift; <keycap>N</"
"keycap></keycombo> </shortcut> <guimenu>Okno</guimenu> <guimenuitem>Podvoji "
"trenutni zavihek</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1388
#, no-c-format
msgid ""
"Opens a new tab that is a duplicate of the active tab in the active panel."
msgstr "Odpre nov zavihek, ki je dvojnik aktivnega zavihka v aktivni plošči."

#. Tag: menuchoice
#: menu-commands.docbook:1394
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> &Ctrl;&Shift; <keycap>O</keycap></"
"keycombo> </shortcut> <guimenu>Window</guimenu> <guimenuitem>Move Current "
"Tab to Other Side</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> &Ctrl;&Shift; <keycap>O</keycap></"
"keycombo> </shortcut> <guimenu>Okno</guimenu> <guimenuitem>Premakni trenutni "
"zavihek na drugo stran</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1405
#, no-c-format
msgid "Moves current tab to the other side of &krusader; window."
msgstr "Premakne trenutni zavihek na drugo stran &krusader; okno."

#. Tag: menuchoice
#: menu-commands.docbook:1410
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>W</keycap></keycombo> </"
"shortcut> <guimenu>Window</guimenu> <guimenuitem>Close Current Tab</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>W</keycap></keycombo> </"
"shortcut> <guimenu>Okno</guimenu> <guimenuitem>Zapri trenutni zavihek</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1420
#, no-c-format
msgid ""
"Closes the current tab in the active panel. This command is only available "
"if there is more than one tab in the active panel."
msgstr ""
"Zapre trenutni zavihek v aktivni plošči. Ta ukaz je na voljo le, če je na "
"aktivni plošči več kot en zavihek."

#. Tag: menuchoice
#: menu-commands.docbook:1427
#, no-c-format
msgid ""
"<guimenu>Window</guimenu> <guimenuitem>Close Inactive Tabs</guimenuitem>"
msgstr ""
"<guimenu>Okno</guimenu> <guimenuitem>Zapri neaktivne zavihke</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1433
#, no-c-format
msgid "Closes all the tabs in the active panel except for the active."
msgstr "Zapre vse zavihke v aktivni plošči razen aktivnega."

#. Tag: menuchoice
#: menu-commands.docbook:1438
#, no-c-format
msgid ""
"<guimenu>Window</guimenu> <guimenuitem>Close Duplicated Tabs</guimenuitem>"
msgstr ""
"<guimenu>Okno</guimenu> <guimenuitem>Zapri podvojene zavihke</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1444
#, no-c-format
msgid "Closes the duplicated tabs in the active panel."
msgstr "Zapre podvojene zavihke v aktivni plošči."

#. Tag: menuchoice
#: menu-commands.docbook:1449
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>.</keycap></keycombo> </"
"shortcut> <guimenu>Window</guimenu> <guimenuitem>Next Tab</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>.</keycap></keycombo> </"
"shortcut> <guimenu>Okno</guimenu> <guimenuitem>Naslednji zavihek</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1459
#, no-c-format
msgid ""
"Navigates to the next tab in the active panel. This command is only "
"available if there is more than one tab in the active panel."
msgstr ""
"Pomika na naslednji zavihek v aktivni plošči. Ta ukaz je na voljo le, če je "
"na aktivni plošči več kot en zavihek."

#. Tag: menuchoice
#: menu-commands.docbook:1466
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>,</keycap></keycombo> </"
"shortcut> <guimenu>Window</guimenu> <guimenuitem>Previous Tab</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>,</keycap></keycombo> </"
"shortcut> <guimenu>Okno</guimenu> <guimenuitem>Prejšnji zavihek</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1476
#, no-c-format
msgid ""
"Navigates to the previous tab in the active panel. This command is only "
"available if there is more than one tab in the active panel."
msgstr ""
"Pomakne se na prejšnji zavihek v aktivni plošči. Ta ukaz je na voljo le, če "
"je na aktivni plošči več kot en zavihek."

#. Tag: menuchoice
#: menu-commands.docbook:1483
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift; <keycap>L</keycap></"
"keycombo> </shortcut> <guimenu>Window</guimenu> <guimenuitem>Profiles</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift; <keycap>L</keycap></"
"keycombo> </shortcut> <guimenu>Okno</guimenu> <guimenuitem>Profili</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1493
#, no-c-format
msgid ""
"Opens a menu where <link linkend=\"panel_profiles\">Panel profiles</link> "
"can be saved and restored."
msgstr ""
"Odpre meni, v katerem je mogoče shraniti in obnoviti <link linkend="
"\"panel_profiles\">profile plošč</link>."

#. Tag: menuchoice
#: menu-commands.docbook:1500
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>U</keycap></keycombo> </"
"shortcut> <guimenu>Window</guimenu> <guimenuitem>Swap Panels</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>U</keycap></keycombo> </"
"shortcut> <guimenu>Okno</guimenu> <guimenuitem>Zamenjaj plošče</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1510
#, no-c-format
msgid ""
"The left panel will become the right panel and vice versa, only the current "
"tabs will be swapped."
msgstr ""
"Leva plošča bo postala desna plošča in obratno, zamenjani bodo samo trenutni "
"zavihki."

#. Tag: menuchoice
#: menu-commands.docbook:1516
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> &Ctrl;&Shift; <keycap>U</keycap></"
"keycombo> </shortcut> <guimenu>Window</guimenu> <guimenuitem>Swap Sides</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> &Ctrl;&Shift; <keycap>U</keycap></"
"keycombo> </shortcut> <guimenu>Okno</guimenu> <guimenuitem>Zamenjaj strani</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1527
#, no-c-format
msgid ""
"The complete left panel will become the right panel and vice versa, and all "
"tabs will be swapped."
msgstr ""
"Celotna leva plošča bo postala desna plošča in obratno, vsi zavihki pa bodo "
"zamenjani."

#. Tag: menuchoice
#: menu-commands.docbook:1533
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> &Ctrl;&Alt; <keycap>R</keycap></"
"keycombo> </shortcut> <guimenu>Window</guimenu> <guimenuitem>Vertical Mode</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> &Ctrl;&Alt; <keycap>R</keycap></"
"keycombo> </shortcut> <guimenu>Okno</guimenu> <guimenuitem>Navpični način</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1544
#, no-c-format
msgid ""
"Toggles the <link linkend=\"list_panel\">List Panel</link> between "
"horizontal and vertical mode."
msgstr ""
"Preklopi <link linkend=\"list_panel\">podokno seznama</link> med vodoravnim "
"in navpičnim načinom."

#. Tag: menuchoice
#: menu-commands.docbook:1550
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Alt; <keycap>F</keycap></"
"keycombo> </shortcut> <guimenu>Window</guimenu> <guimenuitem>Toggle "
"Fullscreen Terminal Emulator</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Alt; <keycap>F</keycap></"
"keycombo> </shortcut> <guimenu>Okno</guimenu> <guimenuitem>Preklopi "
"celozaslonski terminalski emulator</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1561
#, no-c-format
msgid ""
"Toggles full screen mode of the terminal emulator. This option is only "
"available when <guilabel>Show Terminal Emulator</guilabel> is activated."
msgstr ""
"Preklopi celozaslonski način emulatorja terminala. Ta možnost je na voljo "
"le, če je aktiviran <guilabel>Pokaži terminalski emulator</guilabel>."

#. Tag: menuchoice
#: menu-commands.docbook:1568
#, no-c-format
msgid "<guimenu>Window</guimenu> <guimenuitem>Save Position</guimenuitem>"
msgstr "<guimenu>Okno</guimenu> <guimenuitem>Shrani položaj</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1574
#, no-c-format
msgid ""
"Saves the current size and position of the &krusader; main window. This "
"action can be automated with <guilabel>Save last position, size and panel "
"settings</guilabel> in <link linkend=\"konfigurator\">Konfigurator Startup "
"page</link>"
msgstr ""
"Shrani trenutno velikost in položaj &krusader; glavno okno. To dejanje je "
"mogoče avtomatizirati z <guilabel>Shrani zadnji položaj, velikost in "
"nastavitve plošče</guilabel> na <link linkend=\"konfigurator\">strani za "
"zagon konfiguratorja</link>"

#. Tag: title
#: menu-commands.docbook:1584
#, no-c-format
msgid "Settings Menu"
msgstr "Meni z nastavitvami"

#. Tag: menuchoice
#: menu-commands.docbook:1588
#, no-c-format
msgid ""
"<guimenu>Settings</guimenu> <guisubmenu>Toolbars</guisubmenu> "
"<guimenuitem>Show Main Toolbar</guimenuitem>"
msgstr ""
"<guimenu>Nastavitve</guimenu> <guisubmenu>Orodne vrstice</guisubmenu> "
"<guimenuitem>Prikaži glavno orodno vrstico</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1595
#, no-c-format
msgid "Shows the <link linkend=\"mainwindow\">Main Toolbar</link> if checked."
msgstr ""
"Prikaže <link linkend=\"mainwindow\">glavno orodno vrstico</link>, če je "
"potrjena."

#. Tag: menuchoice
#: menu-commands.docbook:1601
#, no-c-format
msgid ""
"<guimenu>Settings</guimenu> <guisubmenu>Toolbars</guisubmenu> "
"<guimenuitem>Show Job Toolbar</guimenuitem>"
msgstr ""
"<guimenu>Nastavitve</guimenu> <guisubmenu>Orodne vrstice</guisubmenu> "
"<guimenuitem>Pokaži orodno vrstico za opravila</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1608
#, no-c-format
msgid "Shows the <link linkend=\"job_toolbar\">Job Toolbar</link> if checked."
msgstr ""
"Prikaže <link linkend=\"job_toolbar\">orodno vrstico opravil</link>, če je "
"označeno."

#. Tag: menuchoice
#: menu-commands.docbook:1614
#, no-c-format
msgid ""
"<guimenu>Settings</guimenu> <guisubmenu>Toolbars</guisubmenu> "
"<guimenuitem>Show Actions Toolbar</guimenuitem>"
msgstr ""
"<guimenu>Nastavitve</guimenu> <guisubmenu>Orodne vrstice</guisubmenu> "
"<guimenuitem>Pokaži orodno vrstico dejanj</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1621
#, no-c-format
msgid ""
"Shows the <link linkend=\"actions_toolbar\">Actions Toolbar</link> if "
"checked."
msgstr ""
"Prikaže <link linkend=\"actions_toolbar\">orodno vrstico za dejanja</link>, "
"če je označeno."

#. Tag: menuchoice
#: menu-commands.docbook:1627
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Show Statusbar</guimenuitem>"
msgstr ""
"<guimenu>Nastavitve</guimenu> <guimenuitem>Prikaži vrstico stanja</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1633
#, no-c-format
msgid "Shows the <link linkend=\"mainwindow\">Statusbar</link> if chosen."
msgstr ""
"Prikaže <link linkend=\"mainwindow\">vrstico stanja</link>, če je izbrana."

#. Tag: menuchoice
#: menu-commands.docbook:1640
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Show FN Keys Bar</guimenuitem>"
msgstr ""
"<guimenu>Nastavitve</guimenu> <guimenuitem>Prikaži vrstico tipk FN</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1646
#, no-c-format
msgid "Shows the <link linkend=\"fnkeys\">FN Keys Bar</link> if checked."
msgstr ""
"Prikaže <link linkend=\"fnkeys\">vrstico s tipkami FN</link>, če je označeno."

#. Tag: menuchoice
#: menu-commands.docbook:1652
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> &Ctrl;&Alt; <keycap>T</keycap></"
"keycombo> </shortcut> <guimenu>Settings</guimenu> <guimenuitem>Show Terminal "
"Emulator</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> &Ctrl;&Alt; <keycap>T</keycap></"
"keycombo> </shortcut> <guimenu>Nastavitve</guimenu> <guimenuitem>Pokaži "
"terminalski emulator</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1663
#, no-c-format
msgid "Show the <link linkend=\"cmdline\">Terminal Emulator</link> if checked."
msgstr ""
"Prikaži <link linkend=\"cmdline\">terminalski emulator</link>, če je "
"potrjeno."

#. Tag: menuchoice
#: menu-commands.docbook:1670
#, no-c-format
msgid ""
"<guimenu>Settings</guimenu> <guimenuitem>Show Command Line</guimenuitem>"
msgstr ""
"<guimenu>Nastavitve</guimenu> <guimenuitem>Pokaži ukazno vrstico</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1676
#, no-c-format
msgid "Shows the <link linkend=\"cmdline\">Command Line</link> if checked."
msgstr ""
"Prikaže <link linkend=\"cmdline\">ukazno vrstico</link>, če je označeno."

#. Tag: menuchoice
#: menu-commands.docbook:1683
#, no-c-format
msgid ""
"<guimenu>Settings</guimenu> <guimenuitem>Command Execution Mode Setup</"
"guimenuitem>"
msgstr ""
"<guimenu>Nastavitve</guimenu> <guimenuitem>Nastavitev načina izvajanja "
"ukazov</guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1689
#, no-c-format
msgid ""
"Allows you to choose command execution mode. You can choose one of the "
"following options."
msgstr ""
"Omogoča izbiro načina izvajanja ukazov. Izberete lahko eno od naslednjih "
"možnosti."

#. Tag: para
#: menu-commands.docbook:1693
#, no-c-format
msgid ""
"<guimenuitem>Start and Forget</guimenuitem>: start execution and do not wait "
"for the results."
msgstr ""
"<guimenuitem>Začni in pozabi</guimenuitem>: začnite z izvajanjem in ne "
"čakajte na rezultate."

#. Tag: para
#: menu-commands.docbook:1697
#, no-c-format
msgid ""
"<guimenuitem>Display Separated Standard and Error Output</guimenuitem>: show "
"the output to stdout and stderr on the separate panels."
msgstr ""
"<guimenuitem>Prikaži ločeni standardni in izhod napak</guimenuitem>: prikaži "
"izhod v stdout in stderr na ločenih ploščah."

#. Tag: para
#: menu-commands.docbook:1702
#, no-c-format
msgid ""
"<guimenuitem>Display Mixed Standard and Error Output</guimenuitem>: show the "
"output to stdout and stderr on the single panel (default)."
msgstr ""
"<guimenuitem>Prikaži mešani standardni in izhod napak</guimenuitem>: prikaži "
"izhod v stdout in stderr na eni plošči (privzeto)."

#. Tag: para
#: menu-commands.docbook:1707
#, no-c-format
msgid ""
"<guimenuitem>Start in New Terminal</guimenuitem>: execute the command in the "
"new terminal window."
msgstr ""
"<guimenuitem>Začni v novem terminalu</guimenuitem>: izvedite ukaz v novem "
"terminalskem oknu."

#. Tag: para
#: menu-commands.docbook:1712
#, no-c-format
msgid ""
"<guimenuitem>Send to Embedded Terminal Emulator</guimenuitem>: send the "
"command to the embedded terminal emulator."
msgstr ""
"<guimenuitem>Pošlji v vgrajen terminalski emulator</guimenuitem>: pošlji "
"ukaz v vdelani terminalski emulator."

#. Tag: menuchoice
#: menu-commands.docbook:1721
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Job Queue Mode</guimenuitem>"
msgstr ""
"<guimenu>Nastavitve</guimenu> <guimenuitem>Način čakalne vrste opravil</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1727
#, no-c-format
msgid ""
"Toggles the <link linkend=\"queue\">Queue Manager</link> mode. If checked "
"then pressing <keycap>F2</keycap> or the corresponding button in the copy/"
"move dialog immediately starts the job even if there are running jobs in "
"queue. If unchecked then the job will be put into the queue if the queue is "
"not empty. Otherwise the job will be started immediately."
msgstr ""
"Preklopi način <link linkend=\"queue\">Upravitelj čakalnih vrst</link>. Če "
"je označeno, se s pritiskom <keycap>F2</keycap> ali ustreznega gumba v "
"pogovornem oknu za kopiranje/premaknitev opravilo takoj zažene, tudi če so v "
"čakalni vrsti opravila v teku. Če ni označeno, bo opravilo postavljeno v "
"čakalno vrsto, če čakalna vrsta ni prazna. V nasprotnem primeru se bo delo "
"začelo takoj."

#. Tag: menuchoice
#: menu-commands.docbook:1734
#, no-c-format
msgid ""
"<guimenu>Settings</guimenu> <guimenuitem>Configure Shortcuts...</guimenuitem>"
msgstr ""
"<guimenu>Nastavitve</guimenu> <guimenuitem>Konfiguriraj bližnjice ...</"
"guimenuitem>"

#. Tag: primary
#: menu-commands.docbook:1741
#, no-c-format
msgid "Configure"
msgstr "Konfiguriraj"

#. Tag: secondary
#: menu-commands.docbook:1742
#, no-c-format
msgid "Shortcuts"
msgstr "Bližnjice"

#. Tag: para
#: menu-commands.docbook:1744
#, no-c-format
msgid ""
"Opens a dialog which allows you to configure the &krusader; key bindings."
msgstr ""
"Odpre pogovorno okno, ki vam omogoča konfiguracijo &krusader; vezave tipk."

#. Tag: para
#: menu-commands.docbook:1746
#, no-c-format
msgid ""
"With the <guibutton>Import shortcuts</guibutton> and <guibutton>Export "
"shortcuts</guibutton> buttons you can load and save a Key-binding profile. "
"This allows &krusader; to have the <trademark class=\"copyright\">Total "
"Commander</trademark>, <application>Midnight Commander</application>, foo-"
"commander, or your custom Key-bindings. The only limitation is that global "
"&plasma; key-bindings and some &krusader; key-bindings cannot be changed "
"yet, as well as some features in foo-commander that we either do not have or "
"need. The Key-bindings are stored in <filename>/usr/share/krusader</"
"filename>, <filename>foo.keymap.info</filename> contains a description, "
"<filename>foo.keymap</filename> is an ini file that holds the Key-bindings. "
"Until &krusader;-1.70.1 this was a binary file, &krusader; is backwards "
"compatible for importing this legacy binary format. If a <filename>*.keymap."
"info</filename> text file exists, &krusader; will display it, showing "
"additional information regarding the loaded Key-bindings file. Here you have "
"a chance to exit without importing the proposed Key-bindings file."
msgstr ""
"Z gumboma <guibutton>Uvozi bližnjice</guibutton> in <guibutton>Izvozi "
"bližnjice</guibutton> lahko naložite in shranite profil vezave tipk. To "
"omogoča &krusader; da imate <trademark class=\"copyright\">Total Commander</"
"trademark>, <application>Midnight Commander</application>, foo-commander ali "
"svoje vezave tipk po meri. Edina omejitev je, da globalni &plasma; vezave "
"tipk in nekaj &krusader; vezav tipk še ni mogoče spremeniti, kot tudi "
"nekaterih funkcij v foo-commanderju, ki jih nimamo ali jih potrebujemo. "
"Povezave tipk so shranjene v <filename>/usr/share/krusader</filename>, "
"<filename>foo.keymap.info</filename> vsebuje opis, <filename>foo.keymap</"
"filename> je ini datoteko, ki vsebuje vezave tipk. Do &krusader;-1.70.1 je "
"bila to binarna datoteka, &krusader; je združljiv za nazaj za uvoz te "
"podedovane binarne oblike. Če besedilna datoteka <filename>*.keymap.info</"
"filename> obstaja, &krusader; ga bo prikazal in prikazal dodatne informacije "
"o naloženi datoteki s povezavami tipk. Tukaj imate možnost, da zaprete, ne "
"da bi uvozili predlagano datoteko z vezavami tipk."

#. Tag: para
#: menu-commands.docbook:1770
#, no-c-format
msgid ""
"A <trademark class=\"copyright\">Total Commander</trademark> Key-bindings "
"file is provided. Please <link linkend=\"help_krusader\"> upload your "
"favorite Key-bindings schemes</link> so that they become available for the "
"&krusader; community. Thanks!"
msgstr ""
"Na voljo je datoteka s povezavami tipk <trademark class=\"copyright\">Total "
"Commander</trademark>. Prosimo <link linkend=\"help_krusader\"> naložite "
"svoje priljubljene sheme vezave tipk</link>, da bodo na voljo za &krusader; "
"skupnosti. Hvala!"

#. Tag: menuchoice
#: menu-commands.docbook:1781
#, no-c-format
msgid ""
"<guimenu>Settings</guimenu> <guimenuitem>Configure Toolbars...</guimenuitem>"
msgstr ""
"<guimenu>Nastavitve</guimenu> <guimenuitem>Konfiguriraj orodne vrstice ...</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1787
#, no-c-format
msgid ""
"Opens a dialog which allows you to configure the <link linkend=\"mainwindow"
"\">Main Toolbar</link> or the <link linkend=\"actions_toolbar\">Actions "
"Toolbar</link>. You can add action buttons of your favourite <link linkend="
"\"useractions\">UserActions</link> to the desired toolbar."
msgstr ""
"Odpre pogovorno okno, v katerem lahko konfigurirate <link linkend="
"\"mainwindow\">Glavno orodno vrstico</link> ali <link linkend="
"\"actions_toolbar\">Orodno vrstico z dejanji</link>. V želeno orodno vrstico "
"lahko dodate akcijske gumbe svojih najljubših <link linkend=\"useractions"
"\">uporabniških dejanj</link>."

#. Tag: menuchoice
#: menu-commands.docbook:1796
#, no-c-format
msgid ""
"<guimenu>Settings</guimenu> <guimenuitem>Configure &krusader;...</"
"guimenuitem>"
msgstr ""
"<guimenu>Nastavitve</guimenu> <guimenuitem>Konfiguriraj &krusader;...</"
"guimenuitem>"

#. Tag: para
#: menu-commands.docbook:1803
#, no-c-format
msgid ""
"Opens <link linkend=\"konfigurator\">Konfigurator</link> - the &krusader; "
"configuration center."
msgstr ""
"Odpre <link linkend=\"konfigurator\">Konfigurator</link> - &krusader; "
