msgstr "Vrsta igre:"

#. Tag: para
#: index.docbook:92
#, no-c-format
msgid "Card"
msgstr "Kartična"

#. Tag: title
#: index.docbook:93
#, no-c-format
msgid "Number of possible players:"
msgstr "Število možnih igralcev:"

#. Tag: para
#: index.docbook:93
#, no-c-format
