msgstr "Navede avtorje &kpatience; v oknu terminala"

#. Tag: option
#: man-kpat.6.docbook:123
#, no-c-format
msgid "--license"
msgstr "--license"

#. Tag: para
#: man-kpat.6.docbook:124
#, no-c-format
msgid "Shows license information"
msgstr "Prikazuje informacije o licenci"

#. Tag: term
#: man-kpat.6.docbook:128
#, no-c-format
msgid "<option>--desktopfile</option> <replaceable>file name</replaceable>"
