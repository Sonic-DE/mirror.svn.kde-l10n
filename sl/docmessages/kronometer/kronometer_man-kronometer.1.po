#. Tag: title
#: man-kronometer.1.docbook:29
#, no-c-format
msgid "DESCRIPTION"
msgstr "OPIS"

#. Tag: para
#: man-kronometer.1.docbook:30
#, no-c-format
msgid "Kronometer is a stopwatch (timer/chronometer) application."
msgstr "Kronometer je aplikacija za štoparico (timer/kronometer)."

#. Tag: para
#: man-kronometer.1.docbook:32
#, no-c-format
msgid "Kronometer’s main features are the following:"
msgstr "Glavne značilnosti Kronometra so naslednje:"

#. Tag: para
#: man-kronometer.1.docbook:36
#, no-c-format
msgid "Start/pause/resume the stopwatch widget;"
msgstr "Zagon/začasna zaustavitev/nadaljevanje gradnika štoparice;"

#. Tag: para
#: man-kronometer.1.docbook:39
#, no-c-format
msgid "Laps recording: you can capture the stopwatch time when you want;"
msgstr "Beleženje krogov: čas štoparice lahko posnamete, kadar želite;"

#. Tag: para
#: man-kronometer.1.docbook:42
#, no-c-format
msgid ""
"Lap times sorting: you can easily find the shortest lap time or the longest "
"one;"
msgstr ""
"Razvrščanje časov krogov: zlahka najdete najkrajši čas kroga ali najdaljšega;"

#. Tag: para
#: man-kronometer.1.docbook:46
#, no-c-format
msgid "Reset the stopwatch widget and the lap times;"
msgstr "Ponastavite gradnik štoparice in čase krogov;"

#. Tag: para
#: man-kronometer.1.docbook:49
#, no-c-format
msgid "Time format settings: you can choose the stopwatch granularity;"
msgstr "Nastavitve zapisa časa: izberete lahko razdrobljenost štoparice;"

#. Tag: para
#: man-kronometer.1.docbook:52
#, no-c-format
msgid ""
"Times saving and resuming: you can save the stopwatch status and resume it "
"later;"
msgstr ""
"Shranjevanje in nadaljevanje časa: stanje štoparice lahko shranite in ga "
"pozneje nadaljujete;"

#. Tag: para
#: man-kronometer.1.docbook:56
#, no-c-format
msgid ""
"Font customization: you can choose the fonts for each of the stopwatch "
"digits;"
msgstr "Prilagoditev pisave: izberete lahko pisave za vsako števko štoparice;"

#. Tag: para
#: man-kronometer.1.docbook:60
#, no-c-format
msgid ""
"Color customization: you can choose the color for the stopwatch digits and "
"the stopwatch background;"
msgstr ""
"Barvna prilagoditev: izberete lahko barvo za števke štoparice in ozadje "
"štoparice;"

#. Tag: para
#: man-kronometer.1.docbook:64
#, no-c-format
msgid ""
"Lap times export: you can export the lap times on a file using the JSON or "
"CSV format."
msgstr ""
"Izvoz časov krogov: čase krogov lahko izvozite v datoteko v formatu JSON ali "
"CSV."

