#, no-c-format
msgid "Places the bird's-eye view at the bottom right corner;"
msgstr "Postavi pogled iz ptičje perspektive v desni spodnji kot;"

#. Tag: guimenuitem
#: index.docbook:552 index.docbook:671
#, no-c-format
msgid "Automatic"
msgstr "Samodejno"

#. Tag: para
#: index.docbook:553 index.docbook:672
