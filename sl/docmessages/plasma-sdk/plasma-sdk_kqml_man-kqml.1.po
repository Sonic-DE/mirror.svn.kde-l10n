msgstr "Plasma 6.0"

#. Tag: productname
#: man-kqml.1.docbook:16
#, no-c-format
msgid "KDE Plasma"
msgstr "KDE Plasma"

#. Tag: manvolnum
#: man-kqml.1.docbook:21
#, no-c-format
