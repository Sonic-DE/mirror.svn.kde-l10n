#: index.docbook:4269
#, no-c-format
msgid "<refname>scheduleCommand</refname>"
msgstr "<refname>scheduleCommand</refname>"

#. Tag: refpurpose
#: index.docbook:4270 index.docbook:4631
#, no-c-format
msgid "schedule a new alarm which executes a shell command."
msgstr "načrtovanje novega alarma, ki izvede ukaz lupine."

