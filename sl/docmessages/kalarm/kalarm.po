#: index.docbook:4071
#, no-c-format
msgid "<refname>scheduleFile</refname>"
msgstr "<refname>scheduleFile</refname>"

#. Tag: refpurpose
#: index.docbook:4072
#, no-c-format
msgid ""
"schedule a new alarm which displays the contents of a text or image file."
msgstr ""
"načrtovanje novega alarma, ki prikaže vsebino besedilne ali slikovne "
"datoteke."

