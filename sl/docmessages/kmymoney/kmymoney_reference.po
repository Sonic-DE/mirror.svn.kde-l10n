#. Tag: title
#: reference.docbook:14
#, no-c-format
msgid "Menus"
msgstr "Meniji"

#. Tag: para
#: reference.docbook:16
#, no-c-format
msgid ""
"Below is a complete list of the menu selections in &kmymoney;, with a very "
"brief description of what each one does. Note that many of these menu "
"choices will be unavailable, or grayed out, depending on the current display "
"or state of the application. In addition, some may not be present if it "
"relates to a feature not included in your particular version. For example, "
"you are not able to edit an account unless you have an account selected or "
"displayed in the current view."
msgstr ""
"Spodaj je popoln seznam menijskih izbir v &kmymoney; z zelo kratkim opisom, "
"kaj vsaka počne. Upoštevajte, da bo veliko teh izbir menija nedosegljivih "
"ali zatemnjenih, odvisno od trenutnega zaslona ali stanja aplikacije. Poleg "
"tega nekateri morda niso prisotni, če se nanašajo na funkcijo, ki ni "
"vključena v vaši različici. Na primer, ne morete urejati računa, če nimate "
"računa izbranega ali prikazanega v trenutnem pogledu."

#. Tag: title
#: reference.docbook:25
#, no-c-format
msgid "File Menu"
msgstr "Meni Datoteka"

#. Tag: menuchoice
#: reference.docbook:28
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>N</keycap></keycombo> </shortcut> "
"<guimenu>File</guimenu><guimenuitem>New book</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>N</keycap></keycombo> </shortcut> "
"<guimenu>Datoteka</guimenu><guimenuitem>Nova knjiga</guimenuitem>"

#. Tag: para
#: reference.docbook:35
#, no-c-format
msgid ""
"Creates a new, empty &kmymoney; data file. Only one &kmymoney; file can be "
"open at once, so this will close your current file first, if one is open."
msgstr ""
"Ustvari novo prazno podatkovno datoteko &kmymoney;. Samo ena datoteka "
"&kmymoney; je lahko odprta naenkrat, tako da bo to najprej zaprlo vašo "
"trenutno datoteko, če je še odprta."

#. Tag: menuchoice
#: reference.docbook:43
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>O</keycap></keycombo> </shortcut> "
"<guimenu>File</guimenu><guimenuitem>Open</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>O</keycap></keycombo> </shortcut> "
"<guimenu>Datoteka</guimenu><guimenuitem>Odpri</guimenuitem>"

#. Tag: para
#: reference.docbook:50
#, no-c-format
msgid "Opens an existing &kmymoney; data file."
msgstr "Odpre obstoječo podatkovno datoteko &kmymoney;."

#. Tag: menuchoice
#: reference.docbook:55
#, no-c-format
msgid ""
"<guimenu>File</guimenu> <guimenuitem>Open Recent</"
"guimenuitem><guimenuitem>...</guimenuitem>"
msgstr ""
"<guimenu>Datoteka</guimenu> <guimenuitem>Odpri nedavno</guimenuitem> "
"<guimenuitem>...</guimenuitem>"

#. Tag: para
#: reference.docbook:60
#, no-c-format
msgid "Provides quick access to recently opened files."
msgstr "Omogoča hiter dostop do nedavno odprtih datotek."

#. Tag: menuchoice
#: reference.docbook:65
#, no-c-format
msgid "<guimenu>File</guimenu><guimenuitem>Open Database...</guimenuitem>"
msgstr ""
"<guimenu>Datoteka</guimenu><guimenuitem>Odpri zbirko podatkov...</"
"guimenuitem>"

#. Tag: para
#: reference.docbook:69
#, no-c-format
msgid "Opens an existing database."
msgstr "Odpre obstoječo bazo podatkov."

#. Tag: menuchoice
#: reference.docbook:74
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>S</keycap></keycombo> </shortcut> "
"<guimenu>File</guimenu><guimenuitem>Save</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>S</keycap></keycombo> </shortcut> "
"<guimenu>Datoteka</guimenu><guimenuitem>Shrani</guimenuitem>"

#. Tag: para
#: reference.docbook:81
#, no-c-format
msgid ""
"Saves the currently open file. Only enabled if there are any changes to save."
msgstr ""
"Shrani trenutno odprto datoteko. Omogočeno samo, če je treba shraniti "
"kakršne koli spremembe."

#. Tag: menuchoice
#: reference.docbook:90
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;&Shift;<keycap>S</keycap></keycombo> </shortcut> "
"<guimenu>File</guimenu><guimenuitem>Save As...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;&Shift;<keycap>S</keycap></keycombo> </shortcut> "
"<guimenu>Datoteka</guimenu><guimenuitem>Shrani kot...</guimenuitem>"

#. Tag: para
#: reference.docbook:97
#, no-c-format
msgid "Saves the currently open file with a different filename."
msgstr "Shrani trenutno odprto datoteko z drugim imenom datoteke."

#. Tag: menuchoice
#: reference.docbook:102
#, no-c-format
msgid ""
"<guimenu>File</guimenu> <guisubmenu>Import</guisubmenu> <guimenuitem>...</"
"guimenuitem>"
msgstr ""
"<guimenu>Datoteka</guimenu> <guisubmenu>Uvozi</guisubmenu> <guimenuitem>...</"
"guimenuitem>"

#. Tag: para
#: reference.docbook:108
#, no-c-format
msgid ""
"Imports financial data from other file types, such as QIF and &gnucash;, or "
"a template file of accounts and categories that can be used in setting up "
"new accounts."
msgstr ""
"Uvozi finančne podatke iz drugih vrst datotek, kot sta QIF ali &gnucash;, "
"ali datoteke predloge računov in kategorij, ki jih je mogoče uporabiti pri "
"nastavljanju novih računov."

#. Tag: menuchoice
#: reference.docbook:117
#, no-c-format
msgid ""
"<guimenu>File</guimenu> <guimenuitem>Export</guimenuitem> <guimenuitem>...</"
"guimenuitem>"
msgstr ""
"<guimenu>Datoteka</guimenu> <guimenuitem>Izvoz</guimenuitem> <guimenuitem>..."
"</guimenuitem>"

#. Tag: para
#: reference.docbook:123
#, no-c-format
msgid ""
"Exports the current file as a different file type, such as QIF, or exports a "
"list of your accounts and categories as a template."
msgstr ""
"Izvozi trenutno datoteko kot drugo vrsto datoteke, na primer QIF, ali izvozi "
"seznam vaših računov in kategorij kot predlogo."

#. Tag: menuchoice
#: reference.docbook:131
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>P</keycap></keycombo> </shortcut> "
"<guimenu>File</guimenu><guimenuitem>Print...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>P</keycap></keycombo> </shortcut> "
"<guimenu>Datoteka</guimenu><guimenuitem>Natisni...</guimenuitem>"

#. Tag: para
#: reference.docbook:138
#, no-c-format
msgid "Prints the current file."
msgstr "Natisne trenutno datoteko."

#. Tag: menuchoice
#: reference.docbook:143
#, no-c-format
msgid "<guimenu>File</guimenu><guimenuitem>Backup...</guimenuitem>"
msgstr ""
"<guimenu>Datoteka</guimenu><guimenuitem>Varnostna kopija...</guimenuitem>"

#. Tag: para
#: reference.docbook:147
#, no-c-format
msgid "Saves a backup the current file."
msgstr "Shrani varnostno kopijo trenutne datoteke."

#. Tag: menuchoice
#: reference.docbook:152
#, no-c-format
msgid "<guimenu>File</guimenu><guimenuitem>Personal Data...</guimenuitem>"
msgstr ""
"<guimenu>Datoteka</guimenu><guimenuitem>Osebni podatki...</guimenuitem>"

#. Tag: para
#: reference.docbook:156
#, no-c-format
msgid "Allows to edit personal data."
msgstr "Omogoča urejanje osebnih podatkov."

#. Tag: menuchoice
#: reference.docbook:161
#, no-c-format
msgid "<guimenu>File</guimenu><guimenuitem>File information...</guimenuitem>"
msgstr ""
"<guimenu>Datoteka</guimenu><guimenuitem>Informacije o datoteki...</"
"guimenuitem>"

#. Tag: para
#: reference.docbook:165
#, no-c-format
msgid "Displays information about the currently open &kmymoney; file."
msgstr "Prikaže informacije o trenutno odprti datoteki &kmymoney;."

#. Tag: menuchoice
#: reference.docbook:170
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>W</keycap></keycombo> </shortcut> "
"<guimenu>File</guimenu><guimenuitem>Close</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>W</keycap></keycombo> </shortcut> "
"<guimenu>Datoteka</guimenu><guimenuitem>Zapri</guimenuitem>"

#. Tag: para
#: reference.docbook:177
#, no-c-format
msgid "Closes the currently open data file."
msgstr "Zapre trenutno odprto podatkovno datoteko."

#. Tag: menuchoice
#: reference.docbook:182
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>Q</keycap></keycombo> </shortcut> "
"<guimenu>File</guimenu><guimenuitem>Quit</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>Q</keycap></keycombo> </shortcut> "
"<guimenu>Datoteka</guimenu><guimenuitem>Zapusti</guimenuitem>"

#. Tag: para
#: reference.docbook:189
#, no-c-format
msgid ""
"Quits &kmymoney;. Offers to save the currently open data file, if there are "
"any changes."
msgstr ""
"Zapusti &kmymoney;. Ponudi shranjevanje trenutno odprte podatkovne datoteke, "
"če je prišlo do sprememb."

#. Tag: title
#: reference.docbook:198
#, no-c-format
msgid "Edit Menu"
msgstr "Meni Uredi"

#. Tag: menuchoice
#: reference.docbook:201
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>Z</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu><guimenuitem>Undo</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>Z</keycap></keycombo> </shortcut> "
"<guimenu>Uredi</guimenu><guimenuitem>Razveljavi</guimenuitem>"

#. Tag: para
#: reference.docbook:208
#, no-c-format
msgid "Reverses the most recent action."
msgstr "Razveljavi zadnje dejanje."

#. Tag: menuchoice
#: reference.docbook:215
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;&Shift;<keycap>Z</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu><guimenuitem>Redo</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;&Shift;<keycap>Z</keycap></keycombo> </shortcut> "
"<guimenu>Uredi</guimenu><guimenuitem>Uveljavi</guimenuitem>"

#. Tag: para
#: reference.docbook:222
#, no-c-format
msgid "Re-applies the most recently undone action."
msgstr "Ponovno uveljavi zadnje razveljavljeno dejanje."

#. Tag: menuchoice
#: reference.docbook:229
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;&Shift;<keycap>F</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu><guimenuitem>Find transaction...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>F</keycap></keycombo> </shortcut> "
"<guimenu>Uredi</guimenu><guimenuitem>Poišči transakcijo...</guimenuitem>"

#. Tag: para
#: reference.docbook:236
#, no-c-format
msgid "Searches transactions."
msgstr "Išče transakcije."

#. Tag: title
#: reference.docbook:242
#, no-c-format
msgid "View Menu"
msgstr "Meni pogleda"

#. Tag: menuchoice
#: reference.docbook:245
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>T</keycap></keycombo> </shortcut> "
"<guimenu>View</guimenu> <guimenuitem>Show Transaction Detail</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>T</keycap></keycombo> </shortcut> "
"<guimenu>Pogled</guimenu> <guimenuitem>Pokaži podrobnosti transakcije</"
"guimenuitem>"

#. Tag: para
#: reference.docbook:253
#, no-c-format
msgid ""
"Shows transaction details in the <link linkend=\"details.ledgers\">Ledgers</"
"link> View. With this option turned on, all lines of the transaction will be "
"shown. When it is turned off, only one line will be shown."
msgstr ""
"Prikaže podrobnosti transakcije v pogledu <link linkend=\"details.ledgers"
"\">Glavna knjiga</link>. Ko je ta možnost vklopljena, bodo vse vrstice "
"transakcije prikazane v knjigi. Ko je izklopljen, bo prikazana samo ena "
"vrstica."

#. Tag: para
#: reference.docbook:259
#, no-c-format
msgid ""
"If you only want to see details for the currently selected transaction, but "
"only one line for the others, you can turn on the <link linkend=\"details."
"settings.register.lens\">Ledger Lens</link>."
msgstr ""
"Če želite videti samo podrobnosti za trenutno izbrano transakcijo, vendar "
"samo eno vrstico za druge, lahko vklopite <link linkend=\"details.settings."
"register.lens\">Leče glavne knjige</link>."

#. Tag: menuchoice
#: reference.docbook:268
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>R</keycap></keycombo> </shortcut> "
"<guimenu>View</guimenu> <guimenuitem>Hide reconciled transactions</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>R</keycap></keycombo> </shortcut> "
"<guimenu>Pogled</guimenu> <guimenuitem>Skrij usklajene transakcije</"
"guimenuitem>"

#. Tag: para
#: reference.docbook:276
#, no-c-format
msgid "Hides reconciled transactions in the ledger."
msgstr "Skrije usklajene transakcije v glavni knjigi."

#. Tag: menuchoice
#: reference.docbook:281
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>U</keycap></keycombo> </shortcut> "
"<guimenu>View</guimenu> <guimenuitem>Hide unused categories</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>U</keycap></keycombo> </shortcut> "
"<guimenu>Pogled</guimenu> <guimenuitem>Skrij neuporabljene kategorije</"
"guimenuitem>"

#. Tag: para
#: reference.docbook:289
#, no-c-format
msgid "Hides unused categories in the views."
msgstr "Skrije neuporabljene kategorije v pogledih."

#. Tag: menuchoice
#: reference.docbook:294
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;&Shift;<keycap>A</keycap></keycombo> </shortcut> "
"<guimenu>View</guimenu><guimenuitem>Show all accounts</guimenuitem>"
msgstr ""
"<shortcut> <keycombo> &Ctrl;&Shift;<keycap>A</keycap> </keycombo> </"
"shortcut> <guimenu>Pogled</guimenu><guimenuitem>Prikaži vse račune</"
"guimenuitem>"

#. Tag: para
#: reference.docbook:301
#, no-c-format
msgid ""
"Shows all accounts in the views, including closed accounts and accounts with "
"zero balance."
msgstr ""
"Prikaže vse račune v pogledih, vključno z zaprtimi računi in računi z "
"ničelnim stanjem."

#. Tag: title
#: reference.docbook:310
#, no-c-format
msgid "Institution Menu"
msgstr "Meni institucije"

#. Tag: menuchoice
#: reference.docbook:313
#, no-c-format
msgid ""
"<guimenu>Institution</guimenu> <guimenuitem>New institution...</guimenuitem>"
msgstr ""
"<guimenu>Institucija</guimenu> <guimenuitem>Nova institucija...</guimenuitem>"

#. Tag: para
#: reference.docbook:318
#, no-c-format
msgid "Add a new institution."
msgstr "Doda novo institucijo."

#. Tag: menuchoice
#: reference.docbook:323
#, no-c-format
msgid ""
"<guimenu>Institution</guimenu> <guimenuitem>Edit institution...</guimenuitem>"
msgstr ""
"<guimenu>Institucija</guimenu> <guimenuitem>Uredi institucijo...</"
"guimenuitem>"

#. Tag: para
#: reference.docbook:328
#, no-c-format
msgid "Edit an institution."
msgstr "Uredi institucijo."

#. Tag: menuchoice
#: reference.docbook:333
#, no-c-format
msgid ""
"<guimenu>Institution</guimenu> <guimenuitem>Delete institution...</"
"guimenuitem>"
msgstr ""
"<guimenu>Institucija</guimenu> <guimenuitem>Izbriši institucijo...</"
"guimenuitem>"

#. Tag: para
#: reference.docbook:338
#, no-c-format
msgid "Delete an institution."
msgstr "Izbriši institucijo."

#. Tag: title
#: reference.docbook:344
#, no-c-format
msgid "Account Menu"
msgstr "Meni računa"

#. Tag: menuchoice
#: reference.docbook:347
#, no-c-format
msgid "<guimenu>Account</guimenu> <guimenuitem>New account...</guimenuitem>"
msgstr "<guimenu>Račun</guimenu> <guimenuitem>Novi račun...</guimenuitem>"

#. Tag: para
#: reference.docbook:352
#, no-c-format
msgid "Adds a new account."
msgstr "Doda nov račun."

#. Tag: menuchoice
#: reference.docbook:357
#, no-c-format
msgid "<guimenu>Account</guimenu><guimenuitem>Edit account...</guimenuitem>"
msgstr "<guimenu>Račun</guimenu><guimenuitem>Uredi račun...</guimenuitem>"

#. Tag: para
#: reference.docbook:361
#, no-c-format
msgid "Edits an account."
msgstr "Ureja račun."

#. Tag: menuchoice
#: reference.docbook:366
#, no-c-format
msgid "<guimenu>Account</guimenu><guimenuitem>Delete account...</guimenuitem>"
msgstr "<guimenu>Račun</guimenu><guimenuitem>Izbriši račun...</guimenuitem>"

#. Tag: para
#: reference.docbook:370
#, no-c-format
msgid "Deletes an account."
msgstr "Izbriše račun."

#. Tag: menuchoice
#: reference.docbook:375
#, no-c-format
msgid "<guimenu>Account</guimenu><guimenuitem>Open ledger</guimenuitem>"
msgstr "<guimenu>Račun</guimenu><guimenuitem>Odpri glavno knjigo</guimenuitem>"

#. Tag: para
#: reference.docbook:379
#, no-c-format
msgid "Displays the Ledgers View of the selected account."
msgstr "Prikaže pogled glavne knjige izbranega računa."

#. Tag: menuchoice
#: reference.docbook:384
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;&Shift;<keycap>R</keycap></keycombo> </shortcut> "
"<guimenu>Account</guimenu><guimenuitem>Reconcile...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo> &Ctrl;&Shift;<keycap>R</keycap> </keycombo> </"
"shortcut> <guimenu>Račun</guimenu><guimenuitem>Uskladi...</guimenuitem>"

#. Tag: para
#: reference.docbook:391
#, no-c-format
msgid "Reconciles an account through the reconciliation wizard."
msgstr "Uskladi račun prek čarovnika za usklajevanje."

#. Tag: menuchoice
#: reference.docbook:396
#, no-c-format
msgid "<guimenu>Account</guimenu><guimenuitem>Postpone</guimenuitem>"
msgstr "<guimenu>Račun</guimenu><guimenuitem>Odloži</guimenuitem>"

#. Tag: para
#: reference.docbook:400
#, no-c-format
msgid "Postpones reconciliation of an account."
msgstr "Odloži uskladitev računa."

#. Tag: menuchoice
#: reference.docbook:405
#, no-c-format
msgid "<guimenu>Account</guimenu><guimenuitem>Finish</guimenuitem>"
msgstr "<guimenu>Račun</guimenu><guimenuitem>Dokončaj</guimenuitem>"

#. Tag: para
#: reference.docbook:409
#, no-c-format
msgid "Finishes reconciliation of an account."
msgstr "Dokonča uskladitev računa."

#. Tag: menuchoice
#: reference.docbook:414
#, no-c-format
msgid "<guimenu>Account</guimenu><guimenuitem>Cancel</guimenuitem>"
msgstr "<guimenu>Račun</guimenu><guimenuitem>Prekliči</guimenuitem>"

#. Tag: para
#: reference.docbook:418
#, no-c-format
msgid "Cancels reconciliation of an account."
msgstr "Prekliče uskladitev računa."

#. Tag: menuchoice
#: reference.docbook:423
#, no-c-format
msgid "<guimenu>Account</guimenu><guimenuitem>Transaction report</guimenuitem>"
msgstr ""
"<guimenu>Račun</guimenu><guimenuitem>Poročilo o transakcijah</guimenuitem>"

#. Tag: para
#: reference.docbook:427
#, no-c-format
msgid "Opens a transaction report of the selected account."
msgstr "Odpre poročilo o transakcijah izbranega računa."

#. Tag: menuchoice
#: reference.docbook:432
#, no-c-format
msgid ""
"<guimenu>Account</guimenu><guimenuitem>Show balance chart...</guimenuitem>"
msgstr ""
"<guimenu>Račun</guimenu> <guimenuitem>Prikaži grafikon stanja...</"
"guimenuitem>"

#. Tag: para
#: reference.docbook:436
#, no-c-format
msgid ""
"Opens a YTD (Year to date) chart of the balance of the selected account."
msgstr "Odpre tabelo od začetka leta do datuma stanja izbranega računa."

#. Tag: menuchoice
#: reference.docbook:441
#, no-c-format
msgid "<guimenu>Account</guimenu><guimenuitem>Close account</guimenuitem>"
msgstr "<guimenu>Račun</guimenu><guimenuitem>Zapri račun</guimenuitem>"

#. Tag: para
#: reference.docbook:445
#, no-c-format
