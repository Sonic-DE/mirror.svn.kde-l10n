#~ "proračun je mogoče narediti več sprememb. Če pritisnete "
#~ "<guibutton>Posodobi</guibutton>, boste shranili spremembe in onemogočili "
#~ "te gumbe."

#~ msgid ""
#~ "The <guibutton>Save</guibutton> button only saves changes that have been "
#~ "stored using the <guibutton>Update</guibutton> button. Thus, if you have "
#~ "modified a Budget but not yet stored the changes <guibutton>Save</"
#~ "guibutton> button will not affect the modified Budget and the "
#~ "<guibutton>Update</guibutton> and <guibutton>Revert</guibutton> buttons "
#~ "remain enabled."
#~ msgstr ""
#~ "Gumb <guibutton>Shrani</guibutton> shrani le spremembe, ki so bile "
#~ "shranjene z gumbom <guibutton>Posodobi</guibutton>. Torej, če ste "
#~ "spremenili proračun, vendar še niste shranili sprememb, gumb "
#~ "<guibutton>Shrani</guibutton> ne bo vplival na spremenjeni proračun, "
#~ "gumba <guibutton>Posodobi</guibutton> in <guibutton>Povrni</guibutton> pa "
#~ "ostaneta omogočena."

#~ msgid ""
#~ "Revert undoes any changes made to a Budget since the last Update and "
#~ "disables the <guibutton>Update</guibutton> and <guibutton>Revert</"
#~ "guibutton> buttons."
#~ msgstr ""
#~ "Razveljavi razveljavi vse spremembe proračuna od zadnje posodobitve in "
#~ "onemogoči gumba <guibutton>Posodobi</guibutton> in <guibutton>Povrni</"
#~ "guibutton>."

#~ msgid ""
#~ "Changes stored using <guibutton>Update</guibutton> but not yet saved "
#~ "using <guibutton>Save</guibutton> can only be reverted by reloading the "
#~ "&kmymoney; file."
#~ msgstr ""
#~ "Spremembe, shranjene z <guibutton>Posodobi</guibutton>, vendar še ne "
#~ "shranjene z <guibutton>Shrani</guibutton>, je mogoče razveljaviti samo s "
#~ "ponovnim nalaganjem datoteke &kmymoney;."

