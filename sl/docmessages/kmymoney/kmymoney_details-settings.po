#~ msgstr "31.03.2019"

#~ msgid "5.0.3"
#~ msgstr "5.0.3"

#~ msgid "Show title bar on each page"
#~ msgstr "Pokaži naslovno vrstico na vsaki strani"

#~ msgid ""
#~ "Checking this box will display the blue &kmymoney; title bar across the "
#~ "top of each page. Unchecking it will remove the title bar and provide a "
#~ "larger area for viewing the content of each page."
#~ msgstr ""
#~ "Če potrdite to polje, bo prikazan modri &kmymoney; naslovna vrstica na "
#~ "vrhu vsake strani. Če počistite polje, boste odstranili naslovno vrstico "
#~ "in zagotovili večje območje za ogled vsebine vsake strani."

#~ msgid "Do not show unused categories"
#~ msgstr "Ne prikazuj neuporabljenih kategorij"

#~ msgid "Show equity accounts"
#~ msgstr "Pokaži kapitalske račune"

