#. Tag: title
#: man-kmymoney.1.docbook:121
#, no-c-format
msgid "Description"
msgstr "Opis"

#. Tag: para
#: man-kmymoney.1.docbook:123
#, no-c-format
msgid ""
"&kmymoney; is the Personal Finance Manager by &kde;. It provides the "
"functions required to balance your checkbooks, manage your personal loans "
"and categories your incomes and expenses using a checkbook style graphical "
"user interface."
msgstr ""
"&kmymoney; je skrbnik osebnih financ &kde;. Zagotavlja funkcije, potrebne za "
"uravnoteženje vaših čekovnih knjižic, upravljanje vaših osebnih posojil in "
"razvrščanje vaših dohodkov in odhodkov z uporabo grafičnega uporabniškega "
"vmesnika v slogu čekovne knjižice."

#. Tag: title
#: man-kmymoney.1.docbook:131
#, no-c-format
msgid "Options"
msgstr "Možnosti"

#. Tag: option
#: man-kmymoney.1.docbook:136
#, no-c-format
msgid "--lang"
msgstr "--lang"

#. Tag: para
#: man-kmymoney.1.docbook:138
#, no-c-format
msgid "Language to be used"
msgstr "Jezik, ki se uporablja"

#. Tag: option
#: man-kmymoney.1.docbook:143
#, no-c-format
msgid "<option>-n</option>"
msgstr "<option>-n</option>"

#. Tag: para
#: man-kmymoney.1.docbook:145
#, no-c-format
msgid "Do not open last used file"
msgstr "Ne odpirajte zadnje uporabljene datoteke"

#. Tag: option
#: man-kmymoney.1.docbook:150
#, no-c-format
msgid "--timers"
msgstr "--timers"

#. Tag: para
#: man-kmymoney.1.docbook:152
#, no-c-format
msgid "Enable performance timers"
msgstr "Omogoči časovnike delovanja"

#. Tag: option
#: man-kmymoney.1.docbook:157
#, no-c-format
msgid "--nocatch"
msgstr "--nocatch"

#. Tag: para
#: man-kmymoney.1.docbook:159
#, no-c-format
msgid "Do not globally catch uncaught exceptions"
msgstr "Globalno ne lovi neulovljenih izjem"

#. Tag: option
#: man-kmymoney.1.docbook:164
#, no-c-format
msgid "--trace"
msgstr "--trace"

#. Tag: para
#: man-kmymoney.1.docbook:166
#, no-c-format
msgid ""
"Turn on program traces. This option is only available when &kmymoney; is "
"compiled in debug mode."
msgstr ""
"Vklopite programske sledi. Ta možnost je na voljo le, ko &kmymoney; je "
"preveden v načinu za odpravljanje napak."

#. Tag: option
#: man-kmymoney.1.docbook:174
#, no-c-format
msgid "--dump-actions"
msgstr "--dump-actions"

#. Tag: para
#: man-kmymoney.1.docbook:176
#, no-c-format
msgid ""
"Dump the names of all defined QAction objects to stdout and quit. This "
"option is only available when &kmymoney; is compiled in debug mode."
msgstr ""
"Prenesi imena vseh definiranih objektov QAction v stdout in zapri. Ta "
"možnost je na voljo le, ko &kmymoney; je preveden v načinu za odpravljanje "
"napak."

#. Tag: title
