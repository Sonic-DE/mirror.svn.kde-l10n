#. Tag: guimenuitem
#: index.docbook:2113
#, no-c-format
msgid "Font name"
msgstr "Ime pisave"

#. Tag: para
#: index.docbook:2114
#, no-c-format
msgid ""
"The Font name combo box provides you with a choice of which font to use in "
