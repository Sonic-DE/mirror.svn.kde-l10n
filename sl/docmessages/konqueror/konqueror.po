#~ "keycap></keycombo></shortcut> <guimenu>Pogled</guimenu> "
#~ "<guimenuitem>Povečaj pisavo</guimenuitem></menuchoice> / <menuchoice> "
#~ "<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>-</keycap></keycombo></"
#~ "shortcut> <guimenu>Pogled</guimenu> <guimenuitem>Skrči pisavo</"
#~ "guimenuitem></menuchoice> (način brskalnika - pogled KHTML)"

#~ msgid ""
#~ "Use these to adjust the size of the text in the page if you find it "
#~ "difficult to read. How well this works will depend on how the web page "
#~ "has been constructed."
#~ msgstr ""
#~ "Uporabite jih za prilagajanje velikosti besedila na strani, če ga težko "
#~ "berete. Kako dobro bo to delovalo, bo odvisno od tega, kako je bila "
#~ "spletna stran izdelana."

#~ msgid ""
#~ "<menuchoice> <shortcut><keycombo action=\"simul\">&Ctrl;<keycap>I</"
#~ "keycap> </keycombo> </shortcut> <guimenu>View</guimenu> <guimenuitem>View "
#~ "Document Information</guimenuitem></menuchoice> (Browser mode - KHTML "
#~ "view)"
#~ msgstr ""
#~ "<menuchoice> <shortcut><keycombo action=\"simul\">&Ctrl;<keycap>I</"
#~ "keycap> </keycombo> </shortcut> <guimenu>Pogled</guimenu> "
#~ "<guimenuitem>Ogled informacij o dokumentu</guimenuitem> </menuchoice> "
#~ "(način brskalnika – pogled KHTML)"

#~ msgid ""
#~ "View document information, such as title, &URL;, and &HTTP; headers used "
#~ "in retrieving the document."
#~ msgstr ""
#~ "Oglejte si informacije o dokumentu, kot so naslov, &URL; in &HTTP; glave, "
#~ "uporabljene pri pridobivanju dokumenta."

#~ msgid "Only available if you are viewing an &HTML; page."
#~ msgstr "Na voljo samo, če si ogledujete &HTML; strani."

#~ msgid ""
#~ "<menuchoice> <guimenu>Go</guimenu> <guimenuitem>Settings</guimenuitem></"
#~ "menuchoice> (File Manager mode)"
#~ msgstr ""
#~ "<menuchoice> <guimenu>Pojdi</guimenu> <guimenuitem>Nastavitve</"
#~ "guimenuitem></menuchoice> (način upravitelja datotek)"

#~ msgid ""
#~ "Open a virtual folder with all &systemsettings; modules in "
#~ "<guimenuitem>Icons</guimenuitem>, <guimenuitem>Details</guimenuitem> or "
#~ "<guimenuitem>Columns</guimenuitem> view. Select an item to display the "
#~ "settings module in a separate dialog window."
#~ msgstr ""
#~ "Odprite navidezno mapo z vsemi &systemsettings; moduli v pogledu "
#~ "<guimenuitem>Ikone</guimenuitem>, <guimenuitem>Podrobnosti</guimenuitem> "
#~ "ali <guimenuitem>Stolpci</guimenuitem>. Izberite element za prikaz modula "
#~ "nastavitev v ločenem pogovornem oknu."

#~ msgid ""
#~ "How can I change the timeout values used by &konqueror; when web browsing?"
#~ msgstr ""
