"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>Left</keycap></"
"keycombo></shortcut> <guimenu>Window</guimenu> <guimenuitem>Move Tab Left</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>Levo</keycap></"
