msgstr ""
"Pogovorno okno Mape se uporablja za izbiro mesta shranjevanja galerije. To "
"pogovorno okno se uporablja tudi za konfiguracijo uporabljenih map."

#. Tag: screeninfo
#: index.docbook:2142
#, no-c-format
msgid "Folders Dialog Screenshot"
msgstr "Posnetek zaslona pogovornega okna map"

#. Tag: guimenuitem
#: index.docbook:2156
#, no-c-format
msgid "Save to HTML file"
msgstr "Shrani v datoteko HTML"

#. Tag: para
#: index.docbook:2157
#, no-c-format
msgid ""
"The Save to file selector allows you to decide where you want to save your "
"image gallery html page."
msgstr ""
"Izbirnik Shrani v datoteko vam omogoča, da se odločite, kam želite shraniti "
"svojo html stran galerije slik."

#. Tag: guimenuitem
#: index.docbook:2162
#, no-c-format
msgid "Recurse subfolders"
msgstr "Ponovne podmape"

