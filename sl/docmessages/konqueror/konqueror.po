#~ "Preferences</guimenuitem></menuchoice> page."
#~ msgstr ""
#~ "V &systemsettings; kategorija <guilabel>Omrežje</guilabel> na strani "
#~ "<menuchoice><guimenu>Nastavitve</guimenu> <guimenuitem>Nastavitve "
#~ "povezave</guimenuitem></menuchoice>."

