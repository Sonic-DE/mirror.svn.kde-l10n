msgstr ""
"<menuchoice> <guimenu>Pojdi</guimenu> <guimenuitem>Samodejni zagon</"
"guimenuitem></menuchoice> (način upravljalnika datotek)"

#. Tag: para
#: index.docbook:3151
#, no-c-format
msgid "Open your <filename class=\"directory\">Autostart</filename> folder."
msgstr "Odprite mapo <filename class=\"directory\">Samodejni zagon</filename>."

#. Tag: menuchoice
#: index.docbook:3156
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>H</keycap></"
"keycombo> </shortcut><guimenu>Go</guimenu> <guimenuitem>Show History</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>H</keycap></"
"keycombo> </shortcut><guimenu>Pojdi</guimenu> <guimenuitem>Pokaži zgodovino</"
"guimenuitem>"

#. Tag: para
#: index.docbook:3162
#, no-c-format
msgid "Shows a tree view of your browsing history in a separate window."
msgstr "Prikaže drevesni pogled vaše zgodovine brskanja v ločenem oknu."

#. Tag: menuchoice
#: index.docbook:3166
#, no-c-format
msgid "<guimenu>Go</guimenu> <guisubmenu>Most Often Visited</guisubmenu>"
msgstr ""
"<guimenu>Pojdi</guimenu> <guisubmenu>Najpogosteje obiskano</guisubmenu>"

#. Tag: para
#: index.docbook:3171
#, no-c-format
msgid ""
"Displays a submenu showing the &URL;s you visit most often. Selecting one of "
"these will make &konqueror; open that &URL;."
msgstr ""
"Prikaže podmeni, ki prikazuje &URL;-je, ki jih najpogosteje obiskujete. Če "
"izberete enega od teh, bo &konqueror; odpri ta &URL;."

#. Tag: menuchoice
#: index.docbook:3177
#, no-c-format
msgid "<guimenu>Go</guimenu> <guisubmenu>Recently Visited</guisubmenu>"
msgstr "<guimenu>Pojdi</guimenu> <guisubmenu>Nedavno obiskano</guisubmenu>"

#. Tag: para
#: index.docbook:3182
#, no-c-format
msgid ""
"Displays a submenu showing the &URL;s you recently visited. Selecting one of "
"these will make &konqueror; open that &URL;."
msgstr ""
"Prikaže podmeni, ki prikazuje &URL;-je, ki ste jih nedavno obiskali. Če "
"izberete enega od teh, bo &konqueror; odpri ta &URL;."

#. Tag: menuchoice
#: index.docbook:3188
#, no-c-format
msgid "<guimenu>Go</guimenu> <guisubmenu>Closed Items</guisubmenu>"
msgstr "<guimenu>Pojdi</guimenu> <guisubmenu>Zaprti predmeti</guisubmenu>"

#. Tag: para
#: index.docbook:3193
#, no-c-format
msgid ""
"Displays a submenu showing the closed &URL;s you visit. Selecting one of "
"these will make &konqueror; open that &URL;. Use <guimenuitem>Empty Closed "
"Items History</guimenuitem> to clear the submenu."
msgstr ""
"Prikaže podmeni, ki prikazuje zaprte &URL;-je, ki jih obiščete. Če izberete "
"enega od teh, bo &konqueror; odpri ta &URL;. Uporabite <guimenuitem>Izprazni "
"zgodovino zaprtih elementov</guimenuitem>, da počistite podmeni."

#. Tag: title
