#. Tag: guimenuitem
#: index.docbook:2123
#, no-c-format
msgid "Foreground color"
msgstr "Barva ospredja"

#. Tag: para
#: index.docbook:2124
#, no-c-format
msgid ""
"The Foreground color option has a selector for choosing the foreground color "
"of the gallery, this includes the text areas."
msgstr ""
"Možnost Barva ospredja ima izbirnik za izbiro barve ospredja galerije, to "
"vključuje področja besedila."

#. Tag: guimenuitem
#: index.docbook:2128
#, no-c-format
msgid "Background color"
msgstr "Barva ozadja"

#. Tag: para
#: index.docbook:2129
#, no-c-format
msgid ""
"The Background color option has a selector for choosing the background color "
