"shortcut> <guimenu>Bookmarks</guimenu> <guimenuitem>Add Bookmark</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>B</keycap></keycombo> </"
"shortcut> <guimenu>Zaznamki</guimenu> <guimenuitem>Dodaj zaznamek</"
"guimenuitem>"

#. Tag: para
#: index.docbook:3219
#, no-c-format
msgid "Add current selection to your bookmarks."
msgstr "Doda trenuten izbor med vaše zaznamke."

#. Tag: menuchoice
#: index.docbook:3224
#, no-c-format
msgid ""
"<guimenu>Bookmarks</guimenu> <guimenuitem>Bookmark Tabs as Folder…</"
"guimenuitem>"
msgstr ""
"<guimenu>Zaznamki</guimenu> <guimenuitem>Dodaj zavihke kot mapo...</"
"guimenuitem>"

#. Tag: para
#: index.docbook:3229
#, no-c-format
msgid ""
"Create a bookmark folder containing links to all of the &URL;s currently "
"open in &konqueror; tabs."
msgstr ""
"Ustvarite mapo z zaznamki, ki vsebuje povezave do vseh &URL;-jev, ki so "
"trenutno odprti v &konqueror; zavihki."

#. Tag: menuchoice
#: index.docbook:3235
#, no-c-format
msgid ""
"<guimenu>Bookmarks</guimenu> <guimenuitem>New Bookmark Folder…</guimenuitem>"
msgstr ""
"<guimenu>Zaznamki</guimenu> <guimenuitem>Nova mapa z zaznamki...</"
"guimenuitem>"

#. Tag: para
#: index.docbook:3239
#, no-c-format
msgid "Create a new folder in your Bookmarks folder."
msgstr "Ustvarite novo mapo v mapi Zaznamki."

#. Tag: menuchoice
#: index.docbook:3244
#, no-c-format
msgid "<guimenu>Bookmarks</guimenu> <guimenuitem>Edit Bookmarks…</guimenuitem>"
msgstr ""
"<guimenu>Zaznamki</guimenu> <guimenuitem>Urejanje zaznamkov...</guimenuitem>"

#. Tag: para
#: index.docbook:3248
#, no-c-format
msgid "Open the <link linkend=\"bookmarks\">Bookmark Editor</link>."
msgstr "Odprite <link linkend=\"bookmarks\">urejevalnik zaznamkov</link>."

#. Tag: title
#: index.docbook:3256
#, no-c-format
msgid "The Tools Menu"
msgstr "Meni Orodja"

