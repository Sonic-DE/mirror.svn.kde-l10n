#. Tag: para
#: introduction.docbook:2
#, no-c-format
msgid "Features include:"
msgstr "Zmožnosti vključujejo:"

#. Tag: para
#: introduction.docbook:5
#, no-c-format
msgid ""
"Task management using the <link linkend=\"task-editor\">Task Editor</"
"link>&nbsp;"
msgstr ""
"Upravljanje nalog z <link linkend=\"task-editor\">urejevalnikom nalog</"
"link>&nbsp;"

#. Tag: para
#: introduction.docbook:6
#, no-c-format
msgid "Work breakdown structure with configurable WBS codes"
msgstr "Struktura razčlenitve dela z nastavljivimi kodami WBS"

#. Tag: para
#: introduction.docbook:7
#, no-c-format
msgid "Tasks, summary tasks, and milestones"
msgstr "Naloge, povzetki nalog in mejniki"

#. Tag: para
#: introduction.docbook:8
#, no-c-format
msgid "Different types of time constraints"
msgstr "Različne vrste časovnih omejitev"

#. Tag: para
#: introduction.docbook:9
#, no-c-format
msgid "Different types of dependencies."
msgstr "Različne vrste odvisnosti."

#. Tag: para
#: introduction.docbook:12
#, no-c-format
msgid ""
"Resource management using the <link linkend=\"resource-editor\">Resource "
"Editor</link>&nbsp;"
msgstr ""
"Upravljanje virov z <link linkend=\"resource-editor\">urejevalnikom virov</"
"link>&nbsp;"

#. Tag: para
#: introduction.docbook:13
#, no-c-format
msgid "Resource breakdown structure"
msgstr "Struktura razčlenitve virov"

#. Tag: para
#: introduction.docbook:14
#, no-c-format
msgid "Working- and material resource types"
msgstr "Vrste delovnih in materialnih sredstev"

#. Tag: para
#: introduction.docbook:15
#, no-c-format
msgid "Resource allocation on group level"
msgstr "Dodeljevanje virov na ravni skupine"

#. Tag: para
#: introduction.docbook:16
#, no-c-format
msgid "Resource teams"
msgstr "Ekipe virov"

#. Tag: para
#: introduction.docbook:19
#, no-c-format
msgid ""
"Work time &amp; vacation definition using the <link linkend=\"work-and-"
"vacation-editor\">Work and Vacation Editor</link>&nbsp;"
msgstr ""
"Delovni čas &amp; opredelitev počitnic z <link linkend=\"work-and-vacation-"
"editor\">urejevalnikom dela in počitnic</link>&nbsp;"

#. Tag: para
#: introduction.docbook:20
#, no-c-format
msgid ""
"Cost management using the <link linkend=\"cost-breakdown-structure-editor"
"\">Cost Breakdown Structure Editor</link>&nbsp;"
msgstr ""
"Upravljanje stroškov z <link linkend=\"cost-breakdown-structure-editor"
"\">urejevalnikom strukture razčlenitve stroškov</link>&nbsp;"

#. Tag: para
#: introduction.docbook:21
#, no-c-format
msgid "Earned value management"
msgstr "Upravljanje prislužene vrednosti"

#. Tag: para
#: introduction.docbook:22
#, no-c-format
msgid ""
"Project scheduling using the <link linkend=\"schedules-editor\">Schedules "
"Editor</link>&nbsp;"
msgstr ""
"Načrtovanje projekta z <link linkend=\"schedules-editor\">urejevalnikom "
"časovnih planov</link>&nbsp;"

#. Tag: para
#: introduction.docbook:23
#, no-c-format
msgid "Schedule forward from start time or backward from finish time"
msgstr ""
"Načrtovanje razporeditve naprej od začetnega časa ali nazaj od končnega časa"

#. Tag: para
#: introduction.docbook:24
#, no-c-format
msgid "Allow or avoid resource overbooking"
msgstr "Dovoljevanje ali se izogibanje prezasedenosti virov"

#. Tag: para
#: introduction.docbook:25
#, no-c-format
msgid ""
"PERT distribution with optimistic-, pessimistic-, and most likely estimates"
msgstr ""
"Porazdelitev PERT z optimističnimi, pesimističnimi in najverjetnejšimi "
"ocenami"

#. Tag: para
#: introduction.docbook:26
#, no-c-format
msgid ""
"Multiple schedules with a possibility to schedule from current progress "
"information"
msgstr ""
"Več časovnih planov z možnostjo načrtovanja iz trenutnih informacij o "
"napredku"

#. Tag: para
#: introduction.docbook:29
#, no-c-format
msgid ""
"Task tracking using the <link linkend=\"task-execution-view\">Task Execution "
"View</link> or <link linkend=\"task-status-view\">Task Status View</"
"link>&nbsp;"
msgstr ""
"Sledenje nalogam s <link linkend=\"task-execution-view\">Pogledom izvajanja "
"nalog</link> ali <link linkend=\"task-status-view\">Pogledom stanja nalog</"
"link>&nbsp;"
