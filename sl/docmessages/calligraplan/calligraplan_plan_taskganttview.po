#. Tag: title
#: taskganttview.docbook:2
#, no-c-format
msgid "<title>Description</title>"
msgstr "<title>Opis</title>"

#. Tag: para
#: taskganttview.docbook:3
#, no-c-format
msgid "The Gantt view is used to show tasks in a timeline."
msgstr "Ganttov pogled se uporablja za prikaz nalog na časovnici."

#. Tag: phrase
#: taskganttview.docbook:14
#, no-c-format
msgid "<phrase>Gantt View</phrase>"
msgstr "<phrase>Ganttov pogled</phrase>"

#. Tag: para
#: taskganttview.docbook:17
#, no-c-format
msgid "<para>Gantt View</para>"
msgstr "<para>Ganttov pogled</para>"

#. Tag: title
#: taskganttview.docbook:23
#, no-c-format
msgid "Editing data"
msgstr "Urejanje podatkov"

#. Tag: para
#: taskganttview.docbook:24
#, no-c-format
msgid "Task description and progress can be edited using the context menu."
msgstr "Opis in napredek naloge lahko urejate s pomočjo kontekstnega menija."

#. Tag: para
#: taskganttview.docbook:26
#, no-c-format
msgid "The following columns are displayed as default:"
msgstr "Naslednji stolpci so privzeto prikazani:"

#. Tag: guilabel
#: taskganttview.docbook:33
#, no-c-format
msgid "Column"
msgstr "Stolpec"

#. Tag: guilabel
#: taskganttview.docbook:34
#, no-c-format
msgid "<guilabel>Description</guilabel>"
msgstr "<guilabel>Opis</guilabel>"

#. Tag: para
#: taskganttview.docbook:40
#, no-c-format
msgid "Name"
msgstr "Ime"

#. Tag: para
#: taskganttview.docbook:43
#, no-c-format
msgid "The name of the task."
msgstr "Ime naloge."

#. Tag: para
#: taskganttview.docbook:48
#, no-c-format
msgid "Start Time"
msgstr "Začetni čas"

#. Tag: para
#: taskganttview.docbook:51
#, no-c-format
msgid "The scheduled start time."
msgstr "Načrtovani začetni čas."

#. Tag: para
#: taskganttview.docbook:56
#, no-c-format
msgid "End Time"
msgstr "Končni čas"

#. Tag: para
#: taskganttview.docbook:59
#, no-c-format
msgid "The scheduled end time."
msgstr "Načrtovani končni čas."

#. Tag: para
#: taskganttview.docbook:64
#, no-c-format
msgid "% Completed"
msgstr "% dokončano"

#. Tag: para
#: taskganttview.docbook:67
#, no-c-format
msgid "Completion"
msgstr "Dokončanje"

#. Tag: title
#: taskganttview.docbook:74
#, no-c-format
msgid "Configuration"
msgstr "Konfiguracija"

#. Tag: para
#: taskganttview.docbook:81
#, no-c-format
msgid ""
"Using the context menu, the view can be configured using the configure "
"dialog."
msgstr ""
"Z uporabo kontekstnega menija lahko pogled konfigurirate v pogovornem oknu "
"za konfiguracijo."

#. Tag: para
#: taskganttview.docbook:82
#, no-c-format
msgid ""
"The configure dialog enables you to tailor the amount of information the "
"view displays to fit your needs."
msgstr ""
"Konfiguracijsko pogovorno okno vam omogoča, da količino informacij, ki jih "
"prikaže pogled, prilagodite svojim potrebam."

#. Tag: phrase
