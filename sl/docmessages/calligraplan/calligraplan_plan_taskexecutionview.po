#. Tag: title
#: taskexecutionview.docbook:2
#, no-c-format
msgid "<title>Description</title>"
msgstr "<title>Opis</title>"

#. Tag: para
#: taskexecutionview.docbook:3
#, no-c-format
msgid ""
"The Task Execution View is used to inspect task performance information."
msgstr ""
"Pogled izvajanja nalog se uporablja za pregled informacij o izvajanju nalog."

#. Tag: title
#: taskexecutionview.docbook:20
#, no-c-format
msgid "Data"
msgstr "Podatki"

#. Tag: para
#: taskexecutionview.docbook:27
#, no-c-format
msgid ""
"Progress information can be edited in-line as described <link linkend="
"\"using-the-views\">here</link> or by using the task progress dialog."
msgstr ""
"Podatke o napredku je mogoče urejati neposredno, kot je opisano <link "
"linkend=\"using-the-views\">tukaj</link>, ali v pogovornem oknu napredka "
"naloge."

