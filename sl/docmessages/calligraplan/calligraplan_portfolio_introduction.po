#. Tag: sect2
#: introduction.docbook:1
#, no-c-format
msgid "&WORK-IN-PROGRESS;"
msgstr "&WORK-IN-PROGRESS;"

#. Tag: para
#: introduction.docbook:3
#, no-c-format
msgid ""
"The &portfolio; lets you manage multiple projects from a single application."
msgstr ""
"&portfolio; vam omogoča upravljanje več projektov iz ene same aplikacije."

#. Tag: para
#: introduction.docbook:5
#, no-c-format
msgid "Two use cases:"
msgstr "Dva primera uporabe:"

#. Tag: para
#: introduction.docbook:8
#, no-c-format
msgid ""
"Managing multiple projects, giving an overview of where to focus attention."
msgstr "Vodenje več projektov, ki dajejo pregled, kam usmeriti pozornost."

#. Tag: para
#: introduction.docbook:11
#, no-c-format
msgid ""
"Inspecting and planning projects enterprise wide. Assisting with handling "
"delays, changing priorities or incorporating new projects."
msgstr ""
"Pregledovanje in načrtovanje projektov v celotnem podjetju. Pomoč pri "
"obravnavanju zamud, spreminjanju prioritet ali vključevanju novih projektov."

#. Tag: para
#: introduction.docbook:16
#, no-c-format
msgid "Features:"
msgstr "Zmožnosti:"

#. Tag: para
#: introduction.docbook:19
#, no-c-format
msgid "Schedule or re-schedule multiple projects."
msgstr "Načrtovanje ali ponovno načrtovanje več projektov."

#. Tag: para
#: introduction.docbook:22
#, no-c-format
msgid "Resource levelling across projects."
msgstr "Izravnavanje virov med projekti."

#. Tag: para
#: introduction.docbook:25
#, no-c-format
msgid "Inspect planned resource usage across projects."
msgstr "Pregled načrtovane uporabe virov med projekti."

#. Tag: para
#: introduction.docbook:28
#, no-c-format
msgid ""
"Inspect and update progress information in table form as well as in charts."
msgstr ""
"Pregled in posodobitev informacij o napredku v obliki tabele in grafikonov."

#. Tag: para
#: introduction.docbook:31
#, no-c-format
msgid "Inspect project gantt charts."
msgstr "Pregled Ganttovih diagramov projekta."
