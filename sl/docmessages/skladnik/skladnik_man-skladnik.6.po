#. Tag: para
#: man-skladnik.6.docbook:72
#, no-c-format
msgid "Shows information about the authors."
msgstr "Prikazuje informacije o avtorjih."

#. Tag: option
#: man-skladnik.6.docbook:77
#, no-c-format
msgid "--license"
msgstr "--license"

#. Tag: para
#: man-skladnik.6.docbook:79
#, no-c-format
msgid "Shows license information."
msgstr "Prikaži informacije o licenci."

#. Tag: term
#: man-skladnik.6.docbook:84
#, no-c-format
msgid "<option>--desktopfile</option> <parameter>FILENAME</parameter>"
msgstr "<option>--desktopfile</option> <parameter>FILENAME</parameter>"

#. Tag: para
#: man-skladnik.6.docbook:86
#, no-c-format
msgid ""
"Use FILENAME as the base file name of the desktop entry for this application."
msgstr ""
"Uporabi FILENAME kot osnovno ime datoteke namiznega vnosa za to aplikacijo."

