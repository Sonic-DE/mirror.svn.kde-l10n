msgstr "&Ctrl;<keycap>C</keycap>"

#. Tag: para
#: index.docbook:838
#, no-c-format
msgid "Score a manual game."
msgstr "Zadetek ročne igre."

#. Tag: keycombo
#: index.docbook:845
#, no-c-format
msgid "&Ctrl;<keycap>N</keycap>"
msgstr "&Ctrl;<keycap>N</keycap>"

#. Tag: para
#: index.docbook:847
#, no-c-format
msgid "Play a game with friends or computer players."
msgstr "Igrajte igro s prijatelji ali računalniškimi igralci."

