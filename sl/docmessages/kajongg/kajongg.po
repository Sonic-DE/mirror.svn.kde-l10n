msgstr "&Shift;<keycap>F1</keycap>"

#. Tag: para
#: index.docbook:910
#, no-c-format
msgid "What's this? help."
msgstr "Kaj je to? pomoč."

#. Tag: keycombo
#: index.docbook:917
