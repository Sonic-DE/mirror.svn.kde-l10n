msgstr "<refname>kf6options</refname>"

#. Tag: refpurpose
#: man-kf6options.7.docbook:22
#, no-c-format
msgid "Common commandline options for all applications based on &kf6-full;"
msgstr ""
"Pogoste možnosti ukazne vrstice za vse aplikacije, ki temeljijo na &kf6-full;"

#. Tag: cmdsynopsis
#: man-kf6options.7.docbook:26
#, no-c-format
msgid ""
"<command><replaceable>KDE application</replaceable></command> <arg choice="
"\"opt\"><option>-h, --help</option></arg> <arg choice=\"opt\"><option>-v, --"
"version</option></arg> <arg choice=\"opt\"><option>--author</option></arg> "
"<arg choice=\"opt\"><option>--license</option></arg> <arg choice=\"opt"
"\"><option>--desktopfile</option> <replaceable>file name</replaceable></arg>"
msgstr ""
"<command><replaceable>KDE aplikacija</replaceable></command> <arg choice="
"\"opt\"><option>-h, --help</option></arg> <arg choice=\"opt\"><option>-v, --"
"version</option></arg> <arg choice=\"opt\"><option>--author</option></arg> "
"<arg choice=\"opt\"><option>--license</option></arg> <arg choice=\"opt"
"\"><option>--desktopfile</option> <replaceable>file name</replaceable></arg>"

#. Tag: title
#: man-kf6options.7.docbook:37
#, no-c-format
msgid "Options"
msgstr "Možnosti"

#. Tag: para
#: man-kf6options.7.docbook:39
#, no-c-format
msgid "The following options apply to all &kde; applications:"
msgstr "Naslednje možnosti veljajo za vse &kde; aplikacije:"

#. Tag: term
#: man-kf6options.7.docbook:43
#, no-c-format
msgid "<option>-h</option> <option>--help</option>"
msgstr "<option>-h</option> <option>--help</option>"

#. Tag: para
#: man-kf6options.7.docbook:44
#, no-c-format
msgid "This lists the options available at the command line."
msgstr "To navaja možnosti, ki so na voljo v ukazni vrstici."

#. Tag: term
#: man-kf6options.7.docbook:49
#, no-c-format
msgid "<option>-v</option> <option>--version</option>"
msgstr "<option>-v</option> <option>--version</option>"

#. Tag: para
#: man-kf6options.7.docbook:51
#, no-c-format
msgid ""
"Lists version information for <replaceable>KDE application</replaceable>."
msgstr ""
"Navaja informacije o različici za <replaceable>aplikacijo KDE</replaceable>."

#. Tag: option
#: man-kf6options.7.docbook:55
#, no-c-format
msgid "--author"
msgstr "--author"

#. Tag: para
#: man-kf6options.7.docbook:56
#, no-c-format
msgid ""
"Lists <replaceable>KDE application</replaceable> authors in the terminal "
"window."
msgstr ""
"Navede avtorje <replaceable>aplikacije KDE</replaceable> v terminalskem oknu."

#. Tag: option
#: man-kf6options.7.docbook:60
#, no-c-format
msgid "--license"
msgstr "--license"

#. Tag: para
#: man-kf6options.7.docbook:61
#, no-c-format
msgid "Shows license information."
msgstr "Prikazuje informacije o licenci."

#. Tag: term
#: man-kf6options.7.docbook:65
#, no-c-format
msgid "<option>--desktopfile</option> <replaceable>file name</replaceable>"
msgstr "<option>--desktopfile</option> <replaceable>ime datoteke</replaceable>"

#. Tag: para
#: man-kf6options.7.docbook:66
#, no-c-format
msgid "The base file name of the desktop entry for this application."
msgstr "Osnovno ime datoteke vnosa iz namizja za to aplikacijo."

#. Tag: para
#: man-kf6options.7.docbook:67
#, no-c-format
msgid ""
"This is in particular useful for wrapper applications and applications "
"having in general multiple desktop files. Thus each desktop file can put its "
"own name into the exec command."
msgstr ""
"To je še posebej uporabno za aplikacije ovojnice in aplikacije, ki imajo na "
"splošno več namiznih datotek. Tako lahko vsaka namizna datoteka vnese svoje "
"ime v ukaz exec."

