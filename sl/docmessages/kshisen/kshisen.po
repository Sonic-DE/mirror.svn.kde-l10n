#, no-c-format
msgid "The Game Menu"
msgstr "Meni igre"

#. Tag: para
#: index.docbook:207
#, no-c-format
msgid ""
"The <guimenu>Game</guimenu> menu lets you control the status of the current "
"game:"
msgstr "Meni <guimenu>Igra</guimenu> vam omogoča nadzor statusa trenutne igre:"

#. Tag: menuchoice
#: index.docbook:214
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>N</keycap></keycombo></"
"shortcut> <guimenu>Game</guimenu><guimenuitem>New</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>N</keycap></keycombo></"
"shortcut> <guimenu>Igra</guimenu><guimenuitem>Nova</guimenuitem>"

#. Tag: para
#: index.docbook:219
#, no-c-format
msgid ""
"<action>Finishes the current game</action> and starts a new session with new "
"tiles."
msgstr ""
"<action>Konča trenutno igro</action> in začne novo sejo z novimi ploščicami."

#. Tag: menuchoice
#: index.docbook:224
#, no-c-format
msgid ""
"<shortcut><keycombo><keycap>F5</keycap></keycombo></shortcut> <guimenu>Game</"
"guimenu><guimenuitem>Restart Game</guimenuitem>"
msgstr ""
"<shortcut><keycombo><keycap>F5</keycap></keycombo></shortcut> <guimenu>Igra</"
"guimenu><guimenuitem>Znova zaženi igro</guimenuitem>"

#. Tag: action
#: index.docbook:229
#, no-c-format
msgid "Restarts the current game with the same tiles."
msgstr "Ponovno zažene trenutno igro z istimi ploščicami."

#. Tag: menuchoice
#: index.docbook:234
#, no-c-format
msgid ""
"<shortcut><keycombo><keycap>P</keycap></keycombo></shortcut> <guimenu>Game</"
"guimenu><guimenuitem>Pause</guimenuitem>"
msgstr ""
"<shortcut><keycombo><keycap>P</keycap></keycombo></shortcut> <guimenu>Igra</"
"guimenu><guimenuitem>Premor</guimenuitem>"

#. Tag: para
#: index.docbook:239
#, no-c-format
msgid ""
"<action>Pauses the game</action>, especially the timer which affects the "
"scoring. The menu entry is also used for resuming the game."
msgstr ""
"<action>Začasno ustavi igro</action>, zlasti časovnik, ki vpliva na "
"točkovanje. Vnos v meni se uporablja tudi za nadaljevanje igre."

#. Tag: menuchoice
#: index.docbook:244
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>H</keycap></keycombo></"
"shortcut> <guimenu>Game</guimenu><guimenuitem>Show High Scores</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>H</keycap></keycombo></"
"shortcut> <guimenu>Igra</guimenu><guimenuitem>Prikaži najboljše rezultate</"
"guimenuitem>"

#. Tag: para
#: index.docbook:249
#, no-c-format
msgid "Shows your top ten charts of &kshisen;."
msgstr "Prikaže vaših deset najboljših lestvic &kshisen;."

#. Tag: menuchoice
#: index.docbook:254
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>Q</keycap></keycombo></"
"shortcut> <guimenu>Game</guimenu><guimenuitem>Quit</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>Q</keycap></keycombo></"
"shortcut> <guimenu>Igra</guimenu><guimenuitem>Zapusti</guimenuitem>"

#. Tag: para
#: index.docbook:259
#, no-c-format
msgid "<action>Quits</action> &kshisen;."
msgstr "<action>Zapusti</action> &kshisen;."

#. Tag: para
#: index.docbook:264
#, no-c-format
msgid ""
"Some of the menu items can also be controlled by keyboard shortcuts. See "
"<xref linkend=\"key-bindings\"/> for a list."
msgstr ""
"Nekatere elemente menija lahko upravljate tudi z bližnjicami na tipkovnici. "
"Glejte <xref linkend=\"key-bindings\"/> za seznam."

#. Tag: title
#: index.docbook:272
#, no-c-format
msgid "The Move Menu"
msgstr "Meni Premakni"

#. Tag: menuchoice
#: index.docbook:277
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>Z</keycap></keycombo></"
"shortcut> <guimenu>Move</guimenu><guimenuitem>Undo</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>Z</keycap></keycombo></"
"shortcut> <guimenu>Premakni</guimenu><guimenuitem>Razveljavi</guimenuitem>"

#. Tag: para
#: index.docbook:282
#, no-c-format
msgid ""
"<action>Undoes the last step</action>. Same as the <guibutton>Undo</"
"guibutton> button in the toolbar."
msgstr ""
"<action>Razveljavi zadnji korak</action>. Enako kot gumb "
"<guibutton>Razveljavi</guibutton> v orodni vrstici."

#. Tag: menuchoice
#: index.docbook:287
#, no-c-format
