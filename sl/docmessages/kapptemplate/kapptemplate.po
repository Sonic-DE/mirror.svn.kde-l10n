#. Tag: para
#: index.docbook:35
#, no-c-format
msgid "&kapptemplate; is a generator of new software projects using templates."
msgstr ""
"&kapptemplate; je generator novih programskih projektov z uporabo predlog."

#. Tag: keyword
#: index.docbook:41
#, no-c-format
msgid "programming"
msgstr "programiranje"

#. Tag: keyword
#: index.docbook:42
#, no-c-format
