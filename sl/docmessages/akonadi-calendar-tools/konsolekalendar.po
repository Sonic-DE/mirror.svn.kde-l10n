msgstr "<option>--end-time</option> <replaceable>&nbsp;end-time</replaceable>"

#. Tag: entry
#: index.docbook:563
#, no-c-format
msgid "End at this time [HH:MM]. Default end-time for viewing is 17:00."
msgstr "Konec ob tej uri [HH:MM]. Privzeta končna ura za ogled je 17:00."

#. Tag: entry
#: index.docbook:568
#, no-c-format
