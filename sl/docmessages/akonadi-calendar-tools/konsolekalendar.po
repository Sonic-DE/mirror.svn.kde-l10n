msgstr "Začetek ob tem času [sekunde od epohe]."

#. Tag: entry
#: index.docbook:573
#, no-c-format
msgid ""
"<option>--epoch-end</option> <replaceable>&nbsp;epoch-time</replaceable>"
msgstr ""
"<option>--epoch-end</option> <replaceable>&nbsp;epoch-time</replaceable>"

#. Tag: entry
#: index.docbook:575
#, no-c-format
msgid "End at this time [seconds since epoch]."
msgstr "Končaj ob tem času [sekunde od epohe]."

#. Tag: entry
