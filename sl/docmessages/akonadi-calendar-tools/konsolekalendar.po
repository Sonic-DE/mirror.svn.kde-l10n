#. Tag: entry
#: index.docbook:602
#, no-c-format
msgid ""
"<option>--export-type</option> <replaceable>&nbsp;export-type</replaceable>"
msgstr ""
"<option>--export-type</option> <replaceable>&nbsp;export-type</replaceable>"

#. Tag: entry
#: index.docbook:604
#, no-c-format
