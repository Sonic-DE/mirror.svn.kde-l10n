#. Tag: title
#: man-symmy.1.docbook:11
#, no-c-format
msgid "Symmy User's Manual"
msgstr "Uporabniški priročnik Symmy"

#. Tag: author
#: man-symmy.1.docbook:12
#, no-c-format
msgid ""
"&Elvis.Angelaccio; &Elvis.Angelaccio.mail; <personblurb><para>Authored this "
"program and this man page</para></personblurb>"
msgstr ""
"&Elvis.Angelaccio; &Elvis.Angelaccio.mail; <personblurb><para>Avtor tega "
"programa in te strani z navodili</para></personblurb>"

#. Tag: date
#: man-symmy.1.docbook:17
#, no-c-format
msgid "2017-11-25"
msgstr "25.11.2017"

#. Tag: releaseinfo
#: man-symmy.1.docbook:18
#, no-c-format
msgid "symmy 0.70"
msgstr "simmy 0.70"

#. Tag: manvolnum
#: man-symmy.1.docbook:23
