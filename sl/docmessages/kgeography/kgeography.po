msgstr "<phrase>Izbrali smo Kanado</phrase>"

#. Tag: para
#: index.docbook:129
#, no-c-format
msgid "And &kgeography; main window appears with the map of Canada:"
msgstr "In glavno okno &kgeography; se bo prikazalo z zemljevidom Kanade:"

#. Tag: screeninfo
#: index.docbook:132
#, no-c-format
