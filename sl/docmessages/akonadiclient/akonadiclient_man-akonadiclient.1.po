msgid "tags"
msgstr "tags"

#. Tag: para
#: man-akonadiclient.1.docbook:392
#, no-c-format
msgid "akonadiclient tags [OPTIONS]"
msgstr "akonadiclient tags [MOŽNOSTI]"

