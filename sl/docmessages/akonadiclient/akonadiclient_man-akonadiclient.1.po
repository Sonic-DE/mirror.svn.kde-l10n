#. Tag: title
#: man-akonadiclient.1.docbook:40
#, no-c-format
msgid "Description"
msgstr "Opis"

#. Tag: para
#: man-akonadiclient.1.docbook:41
#, no-c-format
msgid ""
"akonadiclient is a commandline client for manipulating KDE's Akonadi "
"datastore. It provides an easy way to manipulate Akonadi's data through the "
"commandline. For example, adding items, collections, renaming or moving "
"collections and also controlling the Akonadi agents."
msgstr ""
"akonadiclient je odjemalec ukazne vrstice za upravljanje podatkovne shrambe "
"KDE Akonadi. Zagotavlja enostaven način za manipulacijo Akonadijevih "
"podatkov prek ukazne vrstice. Na primer dodajanje elementov, zbirk, "
"preimenovanje ali premikanje zbirk in tudi nadzor nad agenti Akonadi."

