msgstr ""
"Izvozi zbirko, ki jo poda ZBIRKA , v datoteko XML, ki jo poda DATOTEKA."

#. Tag: option
#: man-akonadiclient.1.docbook:295
#, no-c-format
msgid "group"
msgstr "group"

#. Tag: para
#: man-akonadiclient.1.docbook:297
#, no-c-format
msgid "akonadiclient group [OPTIONS] GROUP ARGS"
msgstr "akonadiclient group [MOŽNOSTI] GROUP ARGS"

#. Tag: para
#: man-akonadiclient.1.docbook:298
#, no-c-format
msgid "Expand or modify a contact GROUP"
msgstr "Razširi ali spremeni skupino stikov"

#. Tag: option
#: man-akonadiclient.1.docbook:303
#, no-c-format
msgid "-e, --expand"
msgstr "-e, --expand"

#. Tag: para
#: man-akonadiclient.1.docbook:304
#, no-c-format
