"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>N</keycap></keycombo> </"
"shortcut> <guimenu>Datoteka</guimenu> <guimenuitem>Novo Okno</guimenuitem>"

#. Tag: para
#: index.docbook:218
#, no-c-format
msgid "Opens a new &kmagnifier; window."
msgstr "Odpre novo &kmagnifier; okno."

#. Tag: menuchoice
#: index.docbook:222
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>S</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Save Snapshot As...</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>S</keycap></keycombo> </"
"shortcut> <guimenu>Datoteka</guimenu> <guimenuitem>Shrani posnetek kot...</"
"guimenuitem>"

#. Tag: para
#: index.docbook:230
#, no-c-format
msgid "Saves the zoomed view to an image file."
msgstr "Shrani povečan pogled v slikovno datoteko."

#. Tag: menuchoice
#: index.docbook:234
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>P</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Print...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>P</keycap></keycombo> </"
"shortcut> <guimenu>Datoteka</guimenu> <guimenuitem>Natisni...</guimenuitem>"

#. Tag: para
#: index.docbook:242
#, no-c-format
msgid "Prints the current zoomed view."
msgstr "Natisne trenutni povečani pogled."

#. Tag: menuchoice
#: index.docbook:246
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>Q</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Quit</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>Q</keycap></keycombo> </"
"shortcut> <guimenu>Datoteka</guimenu> <guimenuitem>Zaključi</guimenuitem>"

#. Tag: para
#: index.docbook:254
#, no-c-format
msgid "Quits the application"
msgstr "Zaključi aplikacijo"

#. Tag: title
#: index.docbook:260
#, no-c-format
msgid "The Edit Menu"
msgstr "Meni Urejanje"

#. Tag: menuchoice
#: index.docbook:265
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>C</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Copy</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>C</keycap></keycombo> </"
"shortcut> <guimenu>Uredi</guimenu> <guimenuitem>Kopiraj</guimenuitem>"

#. Tag: para
#: index.docbook:273
#, no-c-format
msgid ""
"Copy the current zoomed view to the clipboard which you can paste in other "
"applications."
msgstr ""
"Kopirajte trenutni povečani pogled v odložišče, ki ga lahko prilepite v "
"druge aplikacije."

#. Tag: title
#: index.docbook:280
#, no-c-format
msgid "The View Menu"
msgstr "Meni Pogled"

#. Tag: menuchoice
#: index.docbook:285
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> <keycap>F5</keycap></keycombo> </"
"shortcut> <guimenu>View</guimenu> <guimenuitem>Start/Stop</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> <keycap>F5</keycap></keycombo> </"
"shortcut> <guimenu>Pogled</guimenu> <guimenuitem>Začetek/zaustavitev</"
"guimenuitem>"

#. Tag: para
#: index.docbook:293
#, no-c-format
msgid ""
"Start/Stop updating of the display. Stopping the update will zero the "
"processing power required (CPU usage)"
msgstr ""
"Začetek/zaustavitev posodabljanja zaslona. Z zaustavitvijo posodobitve se "
"izniči potrebna procesorska moč (poraba procesorja)"

#. Tag: menuchoice
#: index.docbook:299
#, no-c-format
msgid "<guimenu>View</guimenu> <guimenuitem>Zoom</guimenuitem>"
msgstr "<guimenu>Pogled</guimenu> <guimenuitem>Približaj</guimenuitem>"

#. Tag: para
#: index.docbook:303
#, no-c-format
msgid "Select the zoom factor."
msgstr "Izberite faktor povečave."

#. Tag: menuchoice
#: index.docbook:307
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>-</keycap></keycombo> </"
"shortcut> <guimenu>View</guimenu> <guimenuitem>Zoom Out</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>-</keycap></keycombo> </"
"shortcut> <guimenu>Pogled</guimenu> <guimenuitem>Zmanjšaj</guimenuitem>"

#. Tag: para
#: index.docbook:315
#, no-c-format
msgid "Click on this button to zoom-out on the selected region."
msgstr "S klikom na ta gumb zmanjšate izbrano območje."

#. Tag: menuchoice
#: index.docbook:319
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>+</keycap></keycombo> </"
"shortcut> <guimenu>View</guimenu> <guimenuitem>Zoom In</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl; <keycap>+</keycap></keycombo> </"
"shortcut> <guimenu>Pogled</guimenu> <guimenuitem>Povečaj</guimenuitem>"

#. Tag: para
#: index.docbook:327
#, no-c-format
msgid "Click on this button to zoom-in on the selected region."
msgstr "S klikom na ta gumb povečate izbrano območje."

#. Tag: menuchoice
#: index.docbook:331
#, no-c-format
msgid "<guimenu>View</guimenu> <guimenuitem>Rotation</guimenuitem>"
msgstr "<guimenu>Pogled</guimenu> <guimenuitem>Rotacija</guimenuitem>"

#. Tag: para
#: index.docbook:335
#, no-c-format
msgid ""
"Select the rotation degree (<guimenuitem>No Rotation (0 Degrees)</"
"guimenuitem>, <guimenuitem>Left (90 Degrees)</guimenuitem>, "
"<guimenuitem>Upside Down (180 Degrees)</guimenuitem>, <guimenuitem>Right "
"(270 Degrees)</guimenuitem>."
msgstr ""
"Izberite stopnjo vrtenja (<guimenuitem>Brez rotacije (0 stopinj)</"
"guimenuitem>, <guimenuitem>Levo (90 stopinj)</guimenuitem>, "
"<guimenuitem>Navzdol (180 stopinj)</guimenuitem>, <guimenuitem>Desno (270 "
"stopinj)</guimenuitem>."

#. Tag: menuchoice
#: index.docbook:341
#, no-c-format
msgid "<guimenu>View</guimenu> <guimenuitem>Refresh</guimenuitem>"
msgstr "<guimenu>Pogled</guimenu> <guimenuitem>Obnovi</guimenuitem>"

#. Tag: para
#: index.docbook:345
#, no-c-format
msgid ""
"Select the refresh rate (<guimenuitem>Very Low</guimenuitem>, "
"<guimenuitem>Low</guimenuitem>, <guimenuitem>Medium</guimenuitem>, "
"<guimenuitem>High</guimenuitem>, <guimenuitem>Very High</guimenuitem>). The "
"higher the rate, the more computing power (CPU) will be needed."
msgstr ""
"Izberite hitrost osveževanja (<guimenuitem>Najnižja</guimenuitem>, "
"<guimenuitem>Nizka</guimenuitem>, <guimenuitem>Srednja</guimenuitem>, "
"<guimenuitem>Visoka</guimenuitem>, <guimenuitem>Najvišja</guimenuitem>). "
"Višja kot je hitrost, več računske moči (CPU) je potrebnih."

#. Tag: menuchoice
#: index.docbook:353
#, no-c-format
msgid "<guimenu>View</guimenu> <guisubmenu>Colors</guisubmenu>"
msgstr "<guimenu>Pogled</guimenu> <guisubmenu>Barve</guisubmenu>"

#. Tag: para
#: index.docbook:357
#, no-c-format
msgid ""
"Select different color vision deficiencies to simulate color blindness. This "
"is not useful for people with color blindness, but good for designing "
"accessible interfaces."
msgstr ""
"Izberite različne pomanjkljivosti barvnega vida, da simulirate barvno "
"slepoto. To ni uporabno za ljudi z barvno slepoto, je pa dobro za "
"oblikovanje dostopnih vmesnikov."

#. Tag: title
#: index.docbook:366
#, no-c-format
msgid "The Settings Menu"
msgstr "Meni z nastavitvami"

#. Tag: menuchoice
#: index.docbook:371
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> <keycap>F2</keycap></keycombo> </"
"shortcut> <guimenu>Settings</guimenu> <guimenuitem>Follow Mouse Mode</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> <keycap>F2</keycap></keycombo> </"
"shortcut> <guimenu>Nastavitve</guimenu> <guimenuitem>Način sledenja miški</"
"guimenuitem>"

#. Tag: para
#: index.docbook:379
#, no-c-format
msgid ""
"In this mode the area around the mouse cursor is shown in a normal window."
msgstr ""
"V tem načinu je območje okoli kazalca miške prikazano v običajnem oknu."

#. Tag: menuchoice
#: index.docbook:383
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> <keycap>F3</keycap></keycombo> </"
"shortcut> <guimenu>Settings</guimenu> <guimenuitem>Selection Window Mode</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> <keycap>F3</keycap></keycombo> </"
"shortcut> <guimenu>Nastavitve</guimenu> <guimenuitem>Način izbire okna</"
"guimenuitem>"

#. Tag: para
#: index.docbook:391
#, no-c-format
msgid ""
"In this mode a selection window is opened. The selected area is shown in a "
"normal window."
msgstr ""
"V tem načinu se odpre okno za izbiro. Izbrano območje je prikazano v "
"običajnem oknu."

#. Tag: menuchoice
#: index.docbook:395
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> <keycap>F4</keycap></keycombo> </"
"shortcut> <guimenu>Settings</guimenu> <guimenuitem>Whole Screen Mode</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> <keycap>F4</keycap></keycombo> </"
"shortcut> <guimenu>Nastavitve</guimenu> <guimenuitem>Celotno zaslonski "
"način</guimenuitem>"

#. Tag: para
#: index.docbook:403
#, no-c-format
msgid "In this mode the whole screen is magnified in the zoom window."
msgstr "V tem načinu je v oknu povečave povečan celoten zaslon."

#. Tag: menuchoice
#: index.docbook:407
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> <keycap>F6</keycap></keycombo> </"
"shortcut> <guimenu>Settings</guimenu> <guimenuitem>Hide Mouse Cursor</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> <keycap>F6</keycap></keycombo> </"
"shortcut> <guimenu>Nastavitve</guimenu> <guimenuitem>Skrij kazalko miške</"
"guimenuitem>"

#. Tag: para
#: index.docbook:415 index.docbook:482
#, no-c-format
msgid "Show or hide the mouse cursor in the magnified image."
msgstr "Pokažite ali skrijte kazalko miške na povečani sliki."

#. Tag: menuchoice
#: index.docbook:419
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"> <keycap>F7</keycap></keycombo> </"
"shortcut> <guimenu>Settings</guimenu> <guimenuitem>Stays On Top</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"> <keycap>F7</keycap></keycombo> </"
"shortcut> <guimenu>Nastavitve</guimenu> <guimenuitem>Ostaja na vrhu</"
"guimenuitem>"

#. Tag: para
#: index.docbook:427 index.docbook:487
#, no-c-format
msgid "The &kmagnifier; window stays on top of other windows."
msgstr "Okno &kmagnifier; ostane na vrhu drugih oken."

#. Tag: para
#: index.docbook:431
#, no-c-format
msgid ""
"Additionally &kmagnifier; has the common &kde; <guimenu>Settings</guimenu> "
"and <guimenu>Help</guimenu> menu items, for more information read the "
"sections about the <ulink url=\"help:/fundamentals/menus.html#menus-settings"
"\">Settings Menu</ulink> and <ulink url=\"help:/fundamentals/menus."
"html#menus-help\">Help Menu</ulink> of the &kde; Fundamentals."
msgstr ""
"Poleg tega ima &kmagnifier; skupna menija &kde; <guimenu>Nastavitve</"
"guimenu> in <guimenu>Pomoč</guimenu>, za več informacij preberite poglavja o "
"<ulink url=\"help:/fundamentals/menus.html#menus-settings\">Nastavitveni "
"meni</ulink> in <ulink url=\"help:/fundamentals/menus.html#menus-help\">Meni "
"za pomoč</ulink> iz &kde; Osnove."

#. Tag: title
#: index.docbook:442
#, no-c-format
msgid "Command Reference"
msgstr "Referenca ukazov"

#. Tag: para
#: index.docbook:444
#, no-c-format
msgid ""
"&kmagnifier; automatically uses all your default shortcuts for saving file, "
"opening new window, printing, starting/stopping refresh (reload button in "
"&konqueror;), zoom-in, zoom-out &etc;"
msgstr ""
"&kmagnifier; samodejno uporablja vse privzete bližnjice za shranjevanje "
"datoteke, odpiranje novega okna, tiskanje, začetek/zaustavitev osveževanja "
"(gumb za ponovno nalaganje v &konqueror;ju), povečavo, pomanjšanje in "
"podobno;"

#. Tag: title
#: index.docbook:449
#, no-c-format
msgid "Default Keyboard Shortcuts"
msgstr "Privzete bližnjice na tipkovnici"

#. Tag: keycombo
#: index.docbook:453
#, no-c-format
msgid "&Ctrl;<keycap>S</keycap>"
msgstr "&Ctrl;<keycap>S</keycap>"

#. Tag: para
#: index.docbook:454
#, no-c-format
msgid "This will save the contents of the zoom window to a file."
msgstr "S tem se vsebina okna povečave shrani v datoteko."

#. Tag: keycap
#: index.docbook:459
#, no-c-format
msgid "<keycap>F2</keycap>"
msgstr "<keycap>F2</keycap>"

#. Tag: para
#: index.docbook:460
#, no-c-format
msgid "Switch to \"Follow Mouse Mode\"."
msgstr "Preklopi na \"Način Sledi miški\"."

#. Tag: keycap
#: index.docbook:464
#, no-c-format
msgid "<keycap>F3</keycap>"
msgstr "<keycap>F3</keycap>"

#. Tag: para
#: index.docbook:465
#, no-c-format
msgid "Switch to \"Selection Window Mode\"."
msgstr "Preklopi na \"Način izbirnega okna\"."

#. Tag: keycap
#: index.docbook:469
#, no-c-format
msgid "<keycap>F4</keycap>"
msgstr "<keycap>F4</keycap>"

#. Tag: para
#: index.docbook:470
#, no-c-format
msgid "Switch to \"Whole Screen Mode\"."
msgstr "Preklopi na \"Način celotnega zaslona\"."

#. Tag: keycap
#: index.docbook:474
#, no-c-format
msgid "<keycap>F5</keycap>"
msgstr "<keycap>F5</keycap>"

#. Tag: para
#: index.docbook:475
#, no-c-format
msgid ""
"This will start the refresh of the zoom window if it is stopped, or stops "
"the refresh of the zoom window if the refresh is currently on."
msgstr ""
"To sproži osveževanje okna povečave, če je ustavljeno, ali ustavi "
"osveževanje okna povečave, če je osveževanje trenutno vklopljeno."

#. Tag: keycap
#: index.docbook:481
#, no-c-format
msgid "<keycap>F6</keycap>"
msgstr "<keycap>F6</keycap>"

#. Tag: keycap
#: index.docbook:486
#, no-c-format
msgid "<keycap>F7</keycap>"
msgstr "<keycap>F7</keycap>"

#. Tag: keycombo
#: index.docbook:491
#, no-c-format
msgid "&Ctrl;<keycap>N</keycap>"
msgstr "&Ctrl;<keycap>N</keycap>"

#. Tag: para
#: index.docbook:492
#, no-c-format
msgid "This will open a new &kmagnifier; window."
msgstr "Odprlo se bo novo okno &kmagnifier;."

#. Tag: keycombo
#: index.docbook:495
#, no-c-format
msgid "&Ctrl;<keycap>P</keycap>"
msgstr "&Ctrl;<keycap>P</keycap>"

#. Tag: para
#: index.docbook:496
#, no-c-format
msgid ""
"This will open the print dialog for printing the contents of the zoom window."
msgstr ""
"Odpre se pogovorno okno za tiskanje, v katerem lahko natisnete vsebino okna "
"povečave."

#. Tag: keycombo
#: index.docbook:500
#, no-c-format
msgid "&Ctrl;<keycap>C</keycap>"
msgstr "&Ctrl;<keycap>C</keycap>"

#. Tag: para
#: index.docbook:501
#, no-c-format
msgid "This will copy the zoom window contents to the clipboard."
msgstr "To bo kopiralo vsebino okna za povečavo v odložišče."

#. Tag: keycombo
#: index.docbook:506
#, no-c-format
msgid "&Ctrl;<keycap>M</keycap>"
msgstr "&Ctrl;<keycap>M</keycap>"

#. Tag: para
#: index.docbook:507
#, no-c-format
msgid "Show/Hide the menubar."
msgstr "Prikažite/skrijte menijsko vrstico."

#. Tag: keycombo
#: index.docbook:511
#, no-c-format
msgid "&Ctrl;<keycap>-</keycap>"
msgstr "&Ctrl;<keycap>-</keycap>"

#. Tag: para
#: index.docbook:512
#, no-c-format
msgid "Zoom out"
msgstr "Pomanjšaj"

#. Tag: keycombo
#: index.docbook:515
#, no-c-format
msgid "&Ctrl;<keycap>+</keycap>"
msgstr "&Ctrl;<keycap>+</keycap>"

#. Tag: para
#: index.docbook:516
#, no-c-format
msgid "Zoom in"
msgstr "Povečaj"

#. Tag: keycombo
#: index.docbook:519
#, no-c-format
msgid "&Ctrl;<keycap>Q</keycap>"
msgstr "&Ctrl;<keycap>Q</keycap>"

#. Tag: para
#: index.docbook:520
#, no-c-format
msgid "Quits the application."
msgstr "Zaključi aplikacijo."

