#. Tag: para
#: index.docbook:18
#, no-c-format
msgid ""
"The smb worker enables you to browse the shares of a &Windows; (or Samba) "
"network."
msgstr ""
"Smb worker vam omogoča brskanje po deljenih virih omrežja &Windows; (ali "
"Samba)."

#. Tag: para
#: index.docbook:23
#, no-c-format
msgid ""
"To see the workgroups, enter <userinput><command>smb:/</command></userinput>."
msgstr ""
"Za ogled delovnih skupin vnesite <userinput><command>smb:/</command></"
"userinput>."

#. Tag: para
#: index.docbook:27
#, no-c-format
msgid ""
"<userinput><command>smb://</command><replaceable>a_workgroup</replaceable></"
"userinput> will list the hosts in this workgroup."
msgstr ""
"<userinput><command>smb://</command><replaceable>delovna_skupina</"
"replaceable></userinput> izpiše seznam gostiteljev v tej delovni skupini."

#. Tag: para
#: index.docbook:31
#, no-c-format
msgid ""
"To see the shares of a host, enter <userinput><command>smb://</"
"command><replaceable>the_host</replaceable></userinput> or "
"<userinput><command>smb:/</command><replaceable>a_workgroup</replaceable>/"
"<replaceable>the_host</replaceable></userinput>."
msgstr ""
"Za ogled deljenih virov gostitelja vnesite <userinput><command>smb://</"
"command><replaceable>gostitelj</replaceable></userinput> ali "
"<userinput><command>smb:/</command><replaceable>delovna_skupina</"
"replaceable>/<replaceable>gostitelj</replaceable></userinput>."

#. Tag: para
#: index.docbook:37
#, no-c-format
msgid ""
"To access a share directly enter <userinput><command>smb://</"
"command><replaceable>the_host/the_share</replaceable></userinput> or "
"<userinput><command>smb:/</command><replaceable>a_workgroup</replaceable>/"
"<replaceable>the_host</replaceable>/<replaceable>the_share</replaceable></"
"userinput>"
msgstr ""
"Za neposreden dostop do deljenih virov vnesite <userinput><command>smb://</"
"command><replaceable>gostitelj/deljeni_vir</replaceable></userinput> ali pa "
"<userinput><command>smb:/</command><replaceable>delovna_skupina</"
"replaceable>/<replaceable>gostitelj</replaceable>/<replaceable>deljeni_vir</"
"replaceable></userinput>"

#. Tag: para
#: index.docbook:44
#, no-c-format
msgid "The smb worker requires that you have libsmbclient to use this worker."
msgstr "Smb worker zahteva, da imate libsmbclient, da ga lahko uporabljate."

#. Tag: para
#: index.docbook:48
#, no-c-format
msgid ""
"You can set your default user name and password in the &systemsettings; "
"category <guilabel>Network</guilabel> in "
"<menuchoice><guisubmenu>Connectivity</guisubmenu><guimenuitem> Windows "
"Shares</guimenuitem></menuchoice>. This is especially useful if you are a "
"member of a &Windows; <acronym>NT</acronym> domain. There you can also set "
"your workgroup name, but in most cases this is not required. The worker will "
"ask for your username and password if a default is not set."
msgstr ""
"Svoje privzeto uporabniško ime in geslo lahko nastavite v kategoriji "
"&systemsettings; <guilabel>Omrežje</guilabel> v "
"<menuchoice><guisubmenu>Povezljivost</guisubmenu><guimenuitem> Windows "
"Shares</guimenuitem></menuchoice>. To je posebno uporabno, če ste član "
"domene &Windows; <acronym>NT</acronym>. Tam si lahko nastavite tudi ime "
"svoje delovne skupine, vendar v večini primerov to ni potrebno. Worker vas "
"bo vprašal po vašem uporabniškem imenu in geslu, če nista privzeto "
"nastavljena."

