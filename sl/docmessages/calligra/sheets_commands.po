"</guimenuitem >"

#. Tag: para
#: commands.docbook:648 commands.docbook:1127
#, no-c-format
msgid ""
"<action>Format selected cell(s).</action> See the <link linkend="
"\"formatspread\">Spreadsheet Formatting</link> section for more details."
msgstr ""
"<action>Oblikuj izbrano celico(e).</action> Za več podrobnosti glejte "
"razdelek <link linkend=\"formatspread\">Oblikovanje preglednice</link>."

#. Tag: menuchoice
#: commands.docbook:655
#, no-c-format
msgid "<guimenu>Format</guimenu> <guimenuitem>Style Manager</guimenuitem>"
msgstr "<guimenu>Oblika</guimenu> <guimenuitem>Upravitelj slogov</guimenuitem>"

#. Tag: action
#: commands.docbook:659
#, no-c-format
msgid "Create, Modify or delete cell format styles."
msgstr "Ustvari, spremeni ali izbriši sloge oblikovanja celic."

#. Tag: menuchoice
#: commands.docbook:664
#, no-c-format
msgid "<guimenu>Format</guimenu> <guisubmenu>Style</guisubmenu>"
msgstr "<guimenu>Oblika</guimenu> <guisubmenu>Slog</guisubmenu>"

#. Tag: para
#: commands.docbook:668
#, no-c-format
msgid ""
"<action>Apply a style to selected cell(s).</action> To manage styles use "
"<menuchoice> <guimenu>Format</guimenu><guimenuitem>Style Manager...</"
"guimenuitem> </menuchoice>"
msgstr ""
"<action>Uporabi slog za izbrane celice.</action> Za upravljanje slogov "
"uporabi <menuchoice> <guimenu>Oblika</guimenu><guimenuitem>Upravitelj "
"slogov...</guimenuitem> </menuchoice>"

#. Tag: menuchoice
#: commands.docbook:676
#, no-c-format
msgid ""
"<guimenu>Format</guimenu> <guimenuitem>Create Style From Cell...</"
"guimenuitem>"
msgstr ""
"<guimenu>Oblika</guimenu> <guimenuitem>Ustvari slog iz celice...</"
"guimenuitem>"

#. Tag: para
#: commands.docbook:680
#, no-c-format
msgid ""
"<action>Create a new style from the format of the selected cell.</action> To "
"manage styles use <menuchoice> <guimenu>Format</guimenu><guimenuitem>Style "
"Manager...</guimenuitem> </menuchoice>"
msgstr ""
"<action>Ustvari nov slog iz oblike izbrane celice.</action> Za upravljanje "
"slogov uporabi <menuchoice> <guimenu>Oblika</guimenu><guimenuitem>Upravitelj "
"slogov...</guimenuitem> </menuchoice>"

#. Tag: menuchoice
#: commands.docbook:689
#, no-c-format
msgid "<guimenu>Format</guimenu> <guimenuitem>AutoFormat...</guimenuitem>"
msgstr ""
"<guimenu>Oblika</guimenu> <guimenuitem>Samodejno oblikovanje...</guimenuitem>"

#. Tag: action
#: commands.docbook:693
#, no-c-format
msgid ""
"Autoformat the selected cells: a dialog let you choose between two proposed "
"formats."
msgstr ""
"Samodejno oblikuj izbrane celice: pogovorno okno vam omogoča izbiro med "
"dvema predlaganima formatoma."

#. Tag: menuchoice
#: commands.docbook:698
#, no-c-format
msgid "<guimenu>Format</guimenu> <guimenuitem>Merge Cells</guimenuitem>"
msgstr "<guimenu>Oblika</guimenu> <guimenuitem>Združi celice</guimenuitem>"

#. Tag: action
#: commands.docbook:702
#, no-c-format
msgid "Merge selected cells."
msgstr "Spoji izbrane celice."

#. Tag: menuchoice
#: commands.docbook:707
#, no-c-format
msgid "<guimenu>Format</guimenu> <guimenuitem>Dissociate Cells</guimenuitem>"
msgstr "<guimenu>Oblika</guimenu> <guimenuitem>Ločitev celic</guimenuitem>"

#. Tag: action
#: commands.docbook:711
#, no-c-format
msgid "Dissociate (split apart) previously merged cells."
msgstr "Disociirajte (razdelite) predhodno združene celice."

#. Tag: menuchoice
#: commands.docbook:717
#, no-c-format
msgid ""
"<guimenu>Format</guimenu> <guimenuitem>Adjust Row &amp; Column</guimenuitem>"
msgstr ""
"<guimenu>Oblika</guimenu> <guimenuitem>Prilagodi vrstico &amp; Stolpec</"
"guimenuitem>"

#. Tag: action
#: commands.docbook:721
#, no-c-format
msgid "Set row and column sizes to show selected cell(s) properly."
msgstr ""
"Nastavite velikosti vrstic in stolpcev za pravilen prikaz izbranih celic."

#. Tag: menuchoice
#: commands.docbook:727
#, no-c-format
msgid "<guimenu>Format</guimenu> <guisubmenu>Row</guisubmenu>"
msgstr "<guimenu>Oblika</guimenu> <guisubmenu>Vrstica</guisubmenu>"

#. Tag: action
#: commands.docbook:731
#, no-c-format
msgid "Resize, equalize, hide or show row(s)."
msgstr "Spremeni velikost, izenači, skrij ali prikaži vrstico(e)."

#. Tag: menuchoice
#: commands.docbook:736
#, no-c-format
msgid "<guimenu>Format</guimenu> <guisubmenu>Column</guisubmenu>"
msgstr "<guimenu>Oblika</guimenu> <guisubmenu>Stolpec</guisubmenu>"

#. Tag: action
#: commands.docbook:740
#, no-c-format
msgid "Resize, equalize, hide or show column(s)."
msgstr "Spremeni velikost, izenači, skrij ali prikaži stolpce."

#. Tag: menuchoice
#: commands.docbook:745
#, no-c-format
msgid "<guimenu>Format</guimenu> <guisubmenu>Sheet</guisubmenu>"
msgstr "<guimenu>Oblika</guimenu> <guisubmenu>List</guisubmenu>"

#. Tag: action
#: commands.docbook:749
#, no-c-format
msgid "Hide, show worksheet or configure advanced sheet properties."
msgstr ""
"Skrijte, pokažite delovni list ali konfigurirajte napredne lastnosti lista."

#. Tag: menuchoice
#: commands.docbook:755
#, no-c-format
msgid "<guimenu>Format</guimenu> <guimenuitem>Page Layout...</guimenuitem>"
msgstr ""
"<guimenu>Oblika</guimenu> <guimenuitem>Postavitev strani...</guimenuitem>"

#. Tag: action
#: commands.docbook:759
#, no-c-format
msgid "Format printed page layout."
msgstr "Oblikuj postavitev natisnjene strani."

#. Tag: menuchoice
#: commands.docbook:764
#, no-c-format
msgid "<guimenu>Format</guimenu> <guisubmenu>Print Range</guisubmenu>"
msgstr "<guimenu>Oblika</guimenu> <guisubmenu>Obseg tiska</guisubmenu>"

#. Tag: action
#: commands.docbook:768
#, no-c-format
msgid "Define or reset the print range."
msgstr "Določi ali ponastavi obseg tiskanja."

#. Tag: title
#: commands.docbook:777
#, no-c-format
msgid "The Data Menu"
msgstr "Meni Podatki"

#. Tag: menuchoice
#: commands.docbook:781
#, no-c-format
msgid "<guimenu>Data</guimenu> <guimenuitem>Sort...</guimenuitem>"
msgstr "<guimenu>Podatki</guimenu> <guimenuitem>Razvrsti...</guimenuitem>"

#. Tag: para
#: commands.docbook:785
#, no-c-format
msgid ""
"<action>Sort data in selected cells.</action> See the section <link linkend="
"\"sort\">Sorting Data</link> for more details."
msgstr ""
"<action>Razvrsti podatke v izbranih celicah.</action> Za več podrobnosti "
"glejte razdelek <link linkend=\"sort\">Razvrščanje podatkov</link>."

#. Tag: menuchoice
#: commands.docbook:791
#, no-c-format
msgid "<guimenu>Data</guimenu> <guimenuitem>Text to Columns...</guimenuitem>"
msgstr ""
"<guimenu>Podatki</guimenu> <guimenuitem>Besedilo v stolpce...</guimenuitem>"

#. Tag: para
#: commands.docbook:795
#, no-c-format
msgid ""
"This option attempts to interpret text in the selected cell(s) as "
"<acronym>CSV</acronym> data, placing each item into a different cell in the "
"row."
msgstr ""
"Ta možnost poskuša interpretirati besedilo v izbranih celicah kot podatke "
"<acronym>CSV</acronym>, pri čemer vsak element postavi v drugo celico v "
"vrstici."

#. Tag: menuchoice
#: commands.docbook:802
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>G</keycap></"
"keycombo> </shortcut> <guimenu>Data</guimenu> <guimenuitem>Named Areas...</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>G</keycap></"
"keycombo> </shortcut> <guimenu>Podatki</guimenu> <guimenuitem>Imenovana "
"območja...</guimenuitem >"

#. Tag: para
#: commands.docbook:809
#, no-c-format
msgid ""
"<action>Open</action> the <guilabel>Named Areas</guilabel> dialog to select, "
"add, edit and remove named areas. See the section <link linkend=\"namedareas"
"\">Named Cells and Areas</link> for further details."
msgstr ""
"<action>Odpri</action> pogovorno okno <guilabel>Poimenovana območja</"
"guilabel>, da izberete, dodate, uredite in odstranite imenovana območja. Za "
"nadaljnje podrobnosti glejte razdelek <link linkend=\"namedareas"
"\">Poimenovane celice in območja</link>."

#. Tag: menuchoice
#: commands.docbook:816
#, no-c-format
msgid "<guimenu>Data</guimenu> <guimenuitem>Consolidate...</guimenuitem>"
msgstr "<guimenu>Podatki</guimenu> <guimenuitem>Kosolidiraj...</guimenuitem>"

#. Tag: para
#: commands.docbook:820
#, no-c-format
msgid ""
"<action>Consolidate data.</action> See the section <link linkend="
"\"consolidate\">Consolidating Data</link> for more details."
msgstr ""
"<action>Konsolidacija podatkov.</action> Za več podrobnosti si oglejte "
"razdelek <link linkend=\"consolidate\">Konsolidacija podatkov</link>."

#. Tag: menuchoice
#: commands.docbook:826
#, no-c-format
msgid "<guimenu>Data</guimenu> <guimenuitem>Subtotals...</guimenuitem>"
msgstr "<guimenu>Podatki</guimenu> <guimenuitem>Vmesne vsote...</guimenuitem>"

#. Tag: action
#: commands.docbook:830
#, no-c-format
msgid "Create different kinds of subtotals to a database."
msgstr "Ustvari različne vrste delnih seštevkov v zbirki podatkov."

#. Tag: menuchoice
#: commands.docbook:836
#, no-c-format
msgid "<guimenu>Data</guimenu> <guimenuitem>Validity...</guimenuitem>"
msgstr "<guimenu>Podatki</guimenu> <guimenuitem>Veljavnost...</guimenuitem>"

#. Tag: para
#: commands.docbook:840
#, no-c-format
msgid ""
"<action>Set or modify the error checking criteria and error alert message "
"for selected cell(s).</action> See <link linkend=\"validcheck\"> Validity "
"Checking</link> for more details."
msgstr ""
"<action>Nastavi ali spremeni merila za preverjanje napak in opozorilno "
"sporočilo o napaki za izbrane celice.</action> Za več podrobnosti glejte "
"<link linkend=\"validcheck\"> Preverjanje veljavnosti</link>."

#. Tag: menuchoice
#: commands.docbook:847
#, no-c-format
msgid "<guimenu>Data</guimenu> <guimenuitem>Goal Seek...</guimenuitem>"
msgstr "<guimenu>Podatki</guimenu> <guimenuitem>Iskanje cilja...</guimenuitem>"

#. Tag: para
#: commands.docbook:851
#, no-c-format
msgid ""
"<action>Open the Goal Seek dialog box</action>. See <link linkend=\"goalseek"
"\">Goal Seeking</link> for details."
msgstr ""
"<action>Odpri pogovorno okno Iskanje cilja</action>. Za podrobnosti glejte "
"<link linkend=\"goalseek\">Iskanje cilja</link>."

#. Tag: menuchoice
#: commands.docbook:857
#, no-c-format
msgid "<guimenu>Data</guimenu> <guimenuitem>Pivot...</guimenuitem>"
msgstr "<guimenu>Podatki</guimenu> <guimenuitem>Vrtišče...</guimenuitem>"

#. Tag: para
#: commands.docbook:861
#, no-c-format
msgid ""
"<action>Open the Pivot Table configuration dialog</action>. See <link "
"linkend=\"pivottable\">Pivot Table</link> for details."
msgstr ""
"<action>Odpri pogovorno okno za konfiguracijo vrtilne tabele</action>. Za "
"podrobnosti si oglejte <link linkend=\"pivottable\">Vrtilna tabela</link>."

#. Tag: title
#: commands.docbook:870
#, no-c-format
msgid "The Tools Menu"
msgstr "Meni Orodja"

#. Tag: menuchoice
#: commands.docbook:874
#, no-c-format
msgid "<guimenu>Tools</guimenu> <guimenuitem>Spelling...</guimenuitem>"
msgstr "<guimenu>Orodja</guimenu> <guimenuitem>Črkovanje...</guimenuitem>"

#. Tag: action
#: commands.docbook:878
#, no-c-format
msgid "Check spelling of words in the worksheet."
msgstr "Preveri črkovanje besed v delovnem listu."

#. Tag: menuchoice
#: commands.docbook:883
#, no-c-format
msgid "<guimenu>Tools</guimenu> <guimenuitem>Custom Lists...</guimenuitem>"
msgstr ""
"<guimenu>Orodja</guimenu> <guimenuitem>Seznami po meri...</guimenuitem>"

#. Tag: action
#: commands.docbook:887
#, no-c-format
msgid ""
"View or amend the special series of words recognized by &sheets;. These list "
"can be used to insert special <link linkend=\"series\">series</link> into "
"the worksheet."
msgstr ""
"Oglejte si ali spremenite posebne nize besed, ki jih prepozna &sheets;. Ta "
"seznam lahko uporabite za vstavljanje posebnih <link linkend=\"series"
"\">serij</link> v delovni list."

#. Tag: menuchoice
#: commands.docbook:893
#, no-c-format
msgid "<guimenu>Tools</guimenu> <guimenuitem>Protect Sheet...</guimenuitem>"
msgstr "<guimenu>Orodja</guimenu> <guimenuitem>Zaščiti list...</guimenuitem>"

#. Tag: action
#: commands.docbook:898
#, no-c-format
msgid ""
"Protect the sheet with a password. A dialog pops up prompting you for a "
"password. Unchecking this option will prompt you for the password in order "
"to unprotect the sheet. Protecting a sheet means protecting all cells in the "
"sheet. In a protected sheet, the cells cannot be reformatted or overwritten."
msgstr ""
"Zaščiti list z geslom. Odpre se pogovorno okno, ki vas pozove k vnosu gesla. "
"Če počistite to možnost, boste morali vnesti geslo za odstranitev zaščite "
"lista. Zaščita lista pomeni zaščito vseh celic na listu. Na zaščitenem listu "
"celic ni mogoče preoblikovati ali prepisati."

#. Tag: menuchoice
#: commands.docbook:903
#, no-c-format
msgid "<guimenu>Tools</guimenu> <guimenuitem>Protect Document...</guimenuitem>"
msgstr ""
"<guimenu>Orodja</guimenu> <guimenuitem>Zaščiti dokument...</guimenuitem>"

#. Tag: action
#: commands.docbook:908
#, no-c-format
msgid ""
"Protect the whole document with a password. A dialog pops up prompting you "
"for a password. Unchecking this option will prompt you for the password in "
"order to unprotect the document. In a protected document you cannot rename "
"or remove a sheet. Document protection does not mean that each individual "
"sheet is protected."
msgstr ""
"Celoten dokument zaščiti z geslom. Odpre se pogovorno okno, ki vas pozove k "
"vnosu gesla. Če počistite to možnost, boste morali vnesti geslo za "
"odstranitev zaščite dokumenta. V zaščitenem dokumentu ne morete preimenovati "
"ali odstraniti lista. Zaščita dokumenta ne pomeni, da je zaščiten vsak "
"posamezen list."

#. Tag: menuchoice
#: commands.docbook:917
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Shift;<keysym>F9</keysym></keycombo> "
"</shortcut> <guimenu>Tools</guimenu> <guimenuitem>Recalculate Sheet</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Shift;<keysym>F9</keysym></keycombo> "
"</shortcut> <guimenu>Orodja</guimenu> <guimenuitem>Ponovni izračun lista</"
"guimenuitem>"

#. Tag: action
#: commands.docbook:924
#, no-c-format
msgid "Recalculate formulae in the current sheet."
msgstr "Ponovno izračunaj formule na trenutnem listu."

#. Tag: menuchoice
#: commands.docbook:929
#, no-c-format
msgid ""
"<shortcut> <keysym>F9</keysym> </shortcut> <guimenu>Tools</guimenu> "
"<guimenuitem>Recalculate Document</guimenuitem>"
msgstr ""
"<shortcut> <keysym>F9</keysym> </shortcut> <guimenu>Orodja</guimenu> "
"<guimenuitem>Ponovni izračun dokumenta</guimenuitem>"

#. Tag: action
#: commands.docbook:936
#, no-c-format
msgid "Recalculate all sheets."
msgstr "Ponovno izračunaj vse liste."

#. Tag: menuchoice
#: commands.docbook:952
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu> <guimenuitem>Execute Script File...</guimenuitem>"
msgstr ""
"<guimenu>Orodja</guimenu> <guimenuitem>Izvedi skriptno datoteko...</"
"guimenuitem>"

#. Tag: para
#: commands.docbook:956
#, no-c-format
msgid ""
"Execute the chosen external script in &sheets;. &sheets; supports scripting "
"in JavaScript, Python and Ruby. Default examples of the scripts can be found "
"in the <menuchoice><guimenu>Tools</guimenu><guisubmenu>Scripts</guisubmenu></"
"menuchoice> submenu."
msgstr ""
"Izvedite izbrani zunanji skript v &sheets;. &sheets; podpira skriptiranje v "
"JavaScript, Python in Ruby. Privzete primere skriptov lahko najdete v "
"podmeniju <menuchoice><guimenu>Orodja</guimenu><guisubmenu>Skripti</"
"guisubmenu></menuchoice>."

#. Tag: menuchoice
#: commands.docbook:960
#, no-c-format
msgid "<guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu>"
msgstr "<guimenu>Orodja</guimenu> <guisubmenu>Skripte</guisubmenu>"

#. Tag: para
#: commands.docbook:964
#, no-c-format
msgid ""
"Here you can execute the script to export or import data in various formats, "
"save your &sheets; log into file, use <ulink url=\"https://live.gnome.org/"
"Orca\">Orca speech</ulink> for accessibility, debug Python and Ruby scripts "
"or add functions to display stock or weather condition values. You can even "
"use some <ulink url=\"http://www.r-project.org/\">R functions</ulink> "
"(<ulink url=\"http://rpy.sourceforge.net/rpy.html\">RPy module</ulink> "
"should be installed)."
msgstr ""
"Tukaj lahko izvedete skript za izvoz ali uvoz podatkov v različnih formatih, "
"shranite &sheets; prijavite se v datoteko, uporabite <ulink url=\"https://"
"live.gnome.org/Orca\">Orca govor</ulink> za dostopnost, razhroščevanje "
"skriptov Python in Ruby ali dodajte funkcije za prikaz vrednosti zalog ali "
"vremenskih razmer. Uporabite lahko celo nekaj <ulink url=\"http://www.r-"
"project.org/\">funkcij R</ulink> (<ulink url=\"http://rpy.sourceforge.net/"
"rpy.html\" >Modul RPy</ulink> mora biti nameščen)."

#. Tag: menuchoice
#: commands.docbook:968
#, no-c-format
msgid "<guimenu>Tools</guimenu> <guimenuitem>Script Manager...</guimenuitem>"
msgstr ""
"<guimenu>Orodja</guimenu> <guimenuitem>Upravitelj skriptov...</guimenuitem>"

#. Tag: para
#: commands.docbook:972
#, no-c-format
msgid ""
"<action>Opens</action> the <guilabel>Scripts Manager</guilabel> dialog to "
"execute, load, unload, install, uninstall and get more scripts."
msgstr ""
"<action>Odpre</action> pogovorno okno <guilabel>Upravljalnik skriptov</"
"guilabel> za izvajanje, nalaganje, odstranjevanje, namestitev, odstranitev "
"in pridobivanje več skriptov."

#. Tag: menuchoice
#: commands.docbook:977
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu> <guimenuitem>Function Optimizer...</guimenuitem>"
msgstr ""
"<guimenu>Orodja</guimenu> <guimenuitem>Optimizator funkcij...</guimenuitem>"

#. Tag: para
#: commands.docbook:981
#, no-c-format
msgid ""
"<action>Opens</action> the <guilabel>Function Optimizer</guilabel> dialog "
"where you can choose an objective function cell, optimization target "
"(<guilabel>Maximize</guilabel>, <guilabel>Minimize</guilabel> or enter the "
"<guilabel>Value</guilabel>) and a set of decision parameter cells."
msgstr ""
"<action>Odpre</action> pogovorno okno <guilabel>Optimizator funkcij</"
"guilabel>, kjer lahko izberete ciljno funkcijsko celico, cilj optimizacije "
"(<guilabel>Maksimiraj</guilabel>, <guilabel>Minimiziraj</guilabel> ali "
"vnesite <guilabel>Vrednost</guilabel>) in nabor celic parametrov odločitve."

#. Tag: title
#: commands.docbook:988
#, no-c-format
msgid "The Settings Menu"
msgstr "Meni Nastavitve"

#. Tag: menuchoice
#: commands.docbook:992
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guisubmenu>Toolbars Shown</guisubmenu>"
msgstr ""
"<guimenu>Nastavitve</guimenu> <guisubmenu>Prikazane orodne vrstice</"
"guisubmenu>"

#. Tag: action
#: commands.docbook:996
#, no-c-format
msgid ""
"Show or hide the toolbars: <guilabel>File</guilabel>, <guilabel>Edit</"
"guilabel>, <guilabel>Navigation</guilabel>, <guilabel>Font</guilabel>, "
"<guilabel>Format</guilabel> and <guilabel>Color/Border</guilabel>."
msgstr ""
"Pokaži ali skrij orodne vrstice: <guilabel>Datoteka</guilabel>, "
"<guilabel>Uredi</guilabel>, <guilabel>Krmarjenje</guilabel>, "
"<guilabel>Pisava</guilabel>, <guilabel>Oblika</guilabel> in <guilabel>Barva/"
"obroba</guilabel>."

#. Tag: menuchoice
#: commands.docbook:1015
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Status Bar</guimenuitem>"
msgstr ""
"<guimenu>Nastavitve</guimenu> <guimenuitem>Statusna vrstica</guimenuitem>"

#. Tag: para
#: commands.docbook:1019
#, no-c-format
msgid ""
"<action>Show or hide the Status Bar.</action> The Status Bar shows "
"additional information for selected items and instant calculations of the "
"selected cells."
msgstr ""
"<action>Prikaži ali skrij vrstico stanja.</action> Vrstica stanja prikazuje "
"dodatne informacije za izbrane elemente in takojšnje izračune izbranih celic."

#. Tag: menuchoice
#: commands.docbook:1026
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Tab Bar</guimenuitem>"
msgstr ""
"<guimenu>Nastavitve</guimenu> <guimenuitem>Vrstica z zavihki</guimenuitem>"

#. Tag: para
#: commands.docbook:1030
#, no-c-format
msgid ""
"<action>Show or hide the Tab Bar.</action> All Sheets of the current "
"Document can be accessed through the Tab Bar."
msgstr ""
"<action>Prikaži ali skrij vrstico z zavihki.</action> Do vseh listov "
"trenutnega dokumenta je mogoče dostopati prek vrstice z zavihki."

#. Tag: menuchoice
#: commands.docbook:1036
#, no-c-format
msgid ""
"<guimenu>Settings</guimenu> <guimenuitem>Configure Shortcuts...</guimenuitem>"
msgstr ""
"<guimenu>Nastavitve</guimenu> <guimenuitem>Konfiguriraj bližnjice...</"
"guimenuitem>"

#. Tag: para
#: commands.docbook:1040
#, no-c-format
msgid ""
"<action>Configure the keyboard shortcuts used by &sheets;. </action> See the "
"section on <link linkend=\"configshort\">configuring shortcuts </link> for "
"more details."
msgstr ""
"<action>Konfiguriraj bližnjice na tipkovnici, ki jih uporablja &sheets;. </"
"action> Za več podrobnosti glejte razdelek o <link linkend=\"configshort"
"\">konfiguriranju bližnjic </link>."

#. Tag: menuchoice
#: commands.docbook:1048
#, no-c-format
msgid ""
"<guimenu>Settings</guimenu> <guimenuitem>Configure Toolbars...</guimenuitem>"
msgstr ""
"<guimenu>Nastavitve</guimenu> <guimenuitem>Konfiguriraj orodne vrstice...</"
"guimenuitem>"

#. Tag: para
#: commands.docbook:1052
#, no-c-format
msgid ""
"<action>Configure the toolbars.</action> The section on <link linkend="
"\"configtoolbars\">configuring toolbars</link> has more information."
msgstr ""
"<action>Konfiguriraj orodne vrstice.</action> Razdelek o <link linkend="
"\"configtoolbars\">konfiguraciji orodnih vrstic</link> vsebuje več "
"informacij."

#. Tag: menuchoice
#: commands.docbook:1059
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Themes</guimenuitem>"
msgstr "<guimenu>Nastavitve</guimenu> <guimenuitem>Teme</guimenuitem>"

#. Tag: para
#: commands.docbook:1063
#, no-c-format
msgid ""
"<action>Choose the color theme for &sheets; window.</action> You can choose "
"one of the predefined color schemes or select <guimenuitem>Configuration...</"
"guimenuitem> to open <ulink url=\"help:/kcontrol/colors\">&systemsettings; "
"color selection module</ulink>."
msgstr ""
"<action>Izberi barvno temo za &sheets; okno.</action> Izberete lahko eno od "
"vnaprej določenih barvnih shem ali izberete <guimenuitem>Konfiguracija...</"
"guimenuitem>, da odprete <ulink url=\"help:/kcontrol/colors"
"\">&systemsettings; modul za izbiro barv</ulink>."

#. Tag: menuchoice
#: commands.docbook:1070
#, no-c-format
msgid ""
"<guimenu>Settings</guimenu> <guimenuitem>Active Author Profile</guimenuitem>"
msgstr ""
"<guimenu>Nastavitve</guimenu> <guimenuitem>Aktivni avtorski profil</"
"guimenuitem>"

#. Tag: para
#: commands.docbook:1074
#, no-c-format
msgid ""
"<action>Configure the author profile for the current document.</action> You "
"can choose one of the profiles defined using <link linkend=\"configauthor"
"\">&sheets; configuration window</link>, <guimenuitem>Default Author "
"Profile</guimenuitem> as defined by &systemsettings; data or blank "
"<guimenuitem>Anonymous</guimenuitem> profile which can ensure your privacy."
msgstr ""
"<action>Konfiguriraj profil avtorja za trenutni dokument.</action> Izberete "
"lahko enega od profilov, definiranih z <link linkend=\"configauthor"
"\">&sheets; konfiguracijsko okno</link>, <guimenuitem>Privzeti profil "
"avtorja</guimenuitem>, kot ga določa &systemsettings; podatke ali prazen "
"<guimenuitem>Anonimni</guimenuitem> profil, ki lahko zagotovi vašo zasebnost."

#. Tag: menuchoice
#: commands.docbook:1082
#, no-c-format
msgid ""
"<guimenu>Settings</guimenu> <guimenuitem>Configure Notifications...</"
"guimenuitem>"
msgstr ""
"<guimenu>Nastavitve</guimenu> <guimenuitem>Konfiguriraj obvestila...</"
"guimenuitem>"

#. Tag: para
#: commands.docbook:1086
#, no-c-format
msgid ""
"<action>Configure &sheets; notification system.</action> There are no "
"actions that you can be notified in the current version of &sheets;."
msgstr ""
"<action>Konfiguriraj &sheets; sistem obveščanja.</action> V trenutni "
"različici &sheets; ni dejanj, o katerih bi lahko prejeli obvestilo."

#. Tag: menuchoice
#: commands.docbook:1092
#, no-c-format
msgid ""
"<guimenu>Settings</guimenu> <guimenuitem>Configure &sheets;...</guimenuitem>"
msgstr ""
"<guimenu>Nastavitve</guimenu> <guimenuitem>Konfiguriraj &sheets;...</"
"guimenuitem>"

#. Tag: para
#: commands.docbook:1096
#, no-c-format
msgid ""
"<action>General &sheets; configuration.</action> See the section on <link "
"linkend=\"configdialog\">&sheets; configuration</link> for more details."
msgstr ""
"<action>Splošno &sheets; konfiguracija.</action> Oglejte si razdelek <link "
"linkend=\"configdialog\">&sheets; konfiguracijo</link> za več podrobnosti."

#. Tag: title
#: commands.docbook:1106
#, no-c-format
msgid "The Help Menu"
msgstr "Meni Pomoč"

#. Tag: sect1
#: commands.docbook:1106
#, no-c-format
msgid "&help.menu.documentation;"
msgstr "&help.menu.documentation;"

#. Tag: title
#: commands.docbook:1113
#, no-c-format
msgid "The Right Mouse Button Menu"
msgstr "Meni z desnim gumbom miške"

#. Tag: para
#: commands.docbook:1114
#, no-c-format
msgid ""
"This section describes the items in the pop up menu obtained by "
"<mousebutton>right</mousebutton> clicking on a selected cell or cells, "
"row(s) or column(s)."
msgstr ""
"Ta razdelek opisuje elemente v pojavnem meniju, ki ga dobite z "
"<mousebutton>desnim</mousebutton> klikom na izbrano celico ali celice, "
"vrstico(e) ali stolpec(e)."

#. Tag: menuchoice
#: commands.docbook:1121
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Alt;<keycap>F</keycap></"
"keycombo> </shortcut> <guimenuitem>Cell Format...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Alt;<keycap>F</keycap></"
"keycombo> </shortcut> <guimenuitem>Oblika celice...</guimenuitem>"

#. Tag: menuchoice
#: commands.docbook:1134
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>X</keycap></keycombo> </"
"shortcut> <guimenuitem>Cut</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>X</keycap></keycombo> </"
"shortcut> <guimenuitem>Izreži</guimenuitem>"

#. Tag: para
#: commands.docbook:1140
#, no-c-format
msgid ""
"<action>Put selected item(s) into the clipboard.</action> If you then do a "
"<guilabel>Paste</guilabel> the item(s) will be moved from the original "
"location to the new one."
msgstr ""
"<action>Postavi izbrane elemente v odložišče.</action> Če nato izvedete "
"<guilabel>Prilepi</guilabel>, bodo elementi premaknjeni s prvotne lokacije "
"na novo."

#. Tag: menuchoice
#: commands.docbook:1147
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>C</keycap></keycombo> </"
"shortcut> <guimenuitem>Copy</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>C</keycap></keycombo> </"
"shortcut> <guimenuitem>Kopiraj</guimenuitem>"

#. Tag: action
#: commands.docbook:1153
#, no-c-format
msgid "Copy selected item(s) into the clipboard."
msgstr "Kopiraj izbrane elemente na odložišče."

#. Tag: menuchoice
#: commands.docbook:1158
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>V</keycap></keycombo> </"
"shortcut> <guimenuitem>Paste</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>V</keycap></keycombo> </"
"shortcut> <guimenuitem>Prilepi</guimenuitem>"

#. Tag: action
#: commands.docbook:1164
#, no-c-format
msgid "Paste item(s) from the clipboard to the selected cells."
msgstr "Prilepite elemente iz odložišča v izbrane celice."

#. Tag: guimenuitem
#: commands.docbook:1171
#, no-c-format
msgid "Special Paste..."
msgstr "Posebno lepljenje..."

#. Tag: guimenuitem
#: commands.docbook:1182
#, no-c-format
msgid "Paste with Insertion"
msgstr "Prilepi z vstavljanjem"

#. Tag: action
#: commands.docbook:1184
#, no-c-format
msgid ""
"Paste from the clipboard to the selected cell(s), moving the previous "
"cell(s) to make room."
msgstr ""
"Prilepi iz odložišča v izbrano(e) celico(e) in premakni prejšnjo(e) "
"celico(e), da naredite prostor."

#. Tag: guimenuitem
#: commands.docbook:1191
#, no-c-format
msgid "<guimenuitem>All</guimenuitem>"
msgstr "<guimenuitem>Vse</guimenuitem>"

#. Tag: action
#: commands.docbook:1193
#, no-c-format
msgid "Delete contents of selected cell(s)."
msgstr "Izbriši vsebino izbranih celic."

#. Tag: guimenuitem
#: commands.docbook:1199
#, no-c-format
msgid "Adjust Row &amp; Column"
msgstr "Prilagodi vrstico &amp; Stolpec"

#. Tag: action
#: commands.docbook:1201
#, no-c-format
msgid "Change size of row and column to display selected cell(s) completely."
msgstr ""
"Spremeni velikost vrstice in stolpca, da v celoti prikažete izbrane celice."

#. Tag: guimenuitem
#: commands.docbook:1208
#, no-c-format
msgid "Default"
msgstr "Privzeto"

#. Tag: action
#: commands.docbook:1210
#, no-c-format
msgid "Set default formats for selected cell(s)."
msgstr "Nastavi privzete formate za izbrane celice."

#. Tag: guimenuitem
#: commands.docbook:1216
#, no-c-format
msgid "Area Name..."
msgstr "Ime območja..."

#. Tag: para
#: commands.docbook:1218
#, no-c-format
msgid ""
"<action>Name selected area.</action> See the section <link linkend="
"\"namedareas\">Named Areas</link> for more details."
msgstr ""
"<action>Poimenuj izbrano območje.</action> Za več podrobnosti glejte "
"razdelek <link linkend=\"namedareas\">Poimenovana območja</link>."

#. Tag: guimenuitem
#: commands.docbook:1225
#, no-c-format
msgid "Resize Row..."
msgstr "Spremeni velikost vrstice..."

#. Tag: action
#: commands.docbook:1227
#, no-c-format
msgid "Change height of selected row."
msgstr "Spremeni višino izbrane vrstice."

#. Tag: guimenuitem
#: commands.docbook:1233
#, no-c-format
msgid "Adjust Row"
msgstr "Prilagodi vrstico"

#. Tag: action
#: commands.docbook:1235
#, no-c-format
msgid "Change height of selected row to display cell(s) completely."
msgstr "Spremeni višino izbrane vrstice, da v celoti prikažete celico(e)."

#. Tag: guimenuitem
#: commands.docbook:1242
#, no-c-format
msgid "Resize Column..."
msgstr "Spremeni velikost stolpca..."

#. Tag: action
#: commands.docbook:1244
#, no-c-format
msgid "Change width of selected column."
msgstr "Spremeni širino izbranega stolpca."

#. Tag: guimenuitem
#: commands.docbook:1250
#, no-c-format
msgid "Adjust Column"
msgstr "Prilagodi stolpec"

#. Tag: action
#: commands.docbook:1252
#, no-c-format
msgid "Change width of selected column to display cell(s) completely."
msgstr "Spremenite širino izbranega stolpca, da v celoti prikažete celico(e)."

#. Tag: guimenuitem
#: commands.docbook:1259
#, no-c-format
msgid "Insert Cells..."
msgstr "Vstavi celice..."

#. Tag: action
#: commands.docbook:1261
#, no-c-format
msgid ""
"Insert new cell(s) at selected location, moving existing cell(s) to make "
"room."
msgstr ""
"Vstavi nove celice na izbrano mesto in premakni obstoječe celice, da "
"naredite prostor."

#. Tag: guimenuitem
#: commands.docbook:1268
#, no-c-format
msgid "Delete Cells..."
msgstr "Izbriši celice..."

#. Tag: action
#: commands.docbook:1270
#, no-c-format
msgid ""
"Remove selected cell(s), moving other cell(s) to occupy the space left by "
"the removed cell(s)."
msgstr ""
"Odstrani izbrane celice, druge celice premaknite, da zasedejo prostor, ki ga "
"pustijo odstranjene celice."

#. Tag: guimenuitem
#: commands.docbook:1277
#, no-c-format
msgid "Insert Rows"
msgstr "Vstavi vrstice"

#. Tag: action
#: commands.docbook:1279
#, no-c-format
msgid "Insert new row(s) above selected row(s)."
msgstr "Vstavi nove vrstice nad izbrane vrstice."

#. Tag: guimenuitem
#: commands.docbook:1286
#, no-c-format
msgid "Delete Rows"
msgstr "Izbriši vrstice"

#. Tag: action
#: commands.docbook:1288
#, no-c-format
msgid "Delete selected row(s)."
msgstr "Izbriši izbrane vrstice."

#. Tag: guimenuitem
#: commands.docbook:1294
#, no-c-format
msgid "Hide Rows"
msgstr "Skrij vrstice"

#. Tag: action
#: commands.docbook:1296
#, no-c-format
msgid "Hides selected row(s)."
msgstr "Skrije izbrane vrstice."

#. Tag: guimenuitem
#: commands.docbook:1302
#, no-c-format
msgid "Show Rows"
msgstr "Prikaži vrstice"

#. Tag: action
#: commands.docbook:1304
#, no-c-format
msgid ""
"Shows selected row(s). In order to show hidden rows you need to select a "
"range of rows that includes the hidden rows."
msgstr ""
"Prikazuje izbrane vrstice. Če želite prikazati skrite vrstice, morate "
"izbrati obseg vrstic, ki vključuje skrite vrstice."

#. Tag: guimenuitem
#: commands.docbook:1312
#, no-c-format
msgid "Insert Columns"
msgstr "Vstavi stolpce"

#. Tag: action
#: commands.docbook:1314
#, no-c-format
msgid "Insert new column(s) at left of selected column(s)."
msgstr "Vstavi nove stolpce na levi strani izbranih stolpcev."

#. Tag: guimenuitem
#: commands.docbook:1321
#, no-c-format
msgid "Delete Columns"
msgstr "Izbriši stolpce"

#. Tag: action
#: commands.docbook:1323
#, no-c-format
msgid "Delete selected column(s)."
msgstr "Izbriši izbrane stolpce."

#. Tag: guimenuitem
#: commands.docbook:1329
#, no-c-format
msgid "Hide Columns"
msgstr "Skrij stolpce"

#. Tag: action
#: commands.docbook:1331
#, no-c-format
msgid "Hides selected column(s)."
msgstr "Skrije izbrane stolpce."

#. Tag: guimenuitem
#: commands.docbook:1337
#, no-c-format
msgid "Show Columns"
msgstr "Pokaži stolpce"

#. Tag: action
#: commands.docbook:1339
#, no-c-format
msgid ""
"Shows selected column(s). In order to show hidden columns you need to select "
"a range of columns that includes the hidden columns."
msgstr ""
"Prikaže izbrane stolpce. Če želite prikazati skrite stolpce, morate izbrati "
"obseg stolpcev, ki vključuje skrite stolpce."

#. Tag: guimenuitem
#: commands.docbook:1347
#, no-c-format
msgid "Comment..."
msgstr "Komentar..."

#. Tag: action
#: commands.docbook:1349
#, no-c-format
msgid "Add or modify a comment to the selected cell."
msgstr "Dodajte ali spremenite komentar v izbrano celico."

#. Tag: guimenuitem
#: commands.docbook:1355
#, no-c-format
msgid "Selection List..."
msgstr "Izbirni seznam..."

#. Tag: action
#: commands.docbook:1357
#, no-c-format
msgid ""
"Lets you select and paste text from any cell of the current selection of "
"cells into the selected cell."
msgstr ""
"Omogoča izbiro in lepljenje besedila iz katere koli celice trenutnega izbora "
"celic v izbrano celico."

#. Tag: title
#: commands.docbook:1374
#, no-c-format
msgid "Other Shortcuts"
msgstr "Druge bližnjice"

#. Tag: para
#: commands.docbook:1375
#, no-c-format
msgid ""
"This section describes those &sheets; shortcut keys used for operations that "
"do not appear in any of the menus."
msgstr ""
"Ta razdelek opisuje te &sheets; tipke za bližnjice, ki se uporabljajo za "
"operacije, ki niso prikazane v nobenem od menijev."

#. Tag: keycombo
#: commands.docbook:1382
#, no-c-format
msgid "&Ctrl;<keycap>H</keycap>"
msgstr "&Ctrl;<keycap>H</keycap>"

#. Tag: para
#: commands.docbook:1384
#, no-c-format
msgid "Toggle the display of the dockers."
msgstr "Preklopi prikaz sidrišč."

#. Tag: keycombo
#: commands.docbook:1389
#, no-c-format
msgid "&Ctrl;<keysym>Arrow keys</keysym>"
msgstr "&Ctrl;<keysym>Puščične tipke</keysym>"

#. Tag: action
#: commands.docbook:1391
#, no-c-format
msgid ""
"If the selected cell is occupied then move the cell cursor to the start or "
"end of the occupied block in the current row or column. If the selected cell "
"is not occupied then move the cell cursor to the start or end of the block "
"of unoccupied cells in the current row or column."
msgstr ""
"Če je izbrana celica zasedena, premaknite kurzor celice na začetek ali konec "
"zasedenega bloka v trenutni vrstici ali stolpcu. Če izbrana celica ni "
"zasedena, premaknite kurzor celice na začetek ali konec bloka nezasedenih "
"celic v trenutni vrstici ali stolpcu."

#. Tag: keycombo
#: commands.docbook:1401
#, no-c-format
msgid "&Ctrl;&Shift;<keysym>Arrow keys</keysym>"
msgstr "&Ctrl;&Shift;<keysym>Puščične tipke</keysym>"

#. Tag: action
#: commands.docbook:1403
#, no-c-format
msgid ""
"If the selected cell is occupied then select all occupied cells to the start "
"or end of that block of occupied cells in the current row or column. If the "
"selected cell is not occupied then select all unoccupied cells to the start "
"or end of that block of unoccupied cells in the current row or column."
msgstr ""
"Če je izbrana celica zasedena, izberite vse zasedene celice do začetka ali "
"konca tega bloka zasedenih celic v trenutni vrstici ali stolpcu. Če izbrana "
"celica ni zasedena, izberite vse nezasedene celice do začetka ali konca tega "
"bloka nezasedenih celic v trenutni vrstici ali stolpcu."

#. Tag: keysym
