#. Tag: menuchoice
#: commands.docbook:505
#, no-c-format
msgid "<guimenu>View</guimenu> <guisubmenu>Zoom</guisubmenu>"
msgstr "<guimenu>Pogled</guimenu> <guisubmenu>Povečava</guisubmenu>"

#. Tag: action
#: commands.docbook:509
#, no-c-format
msgid ""
"Increase or decrease the magnification used to display the spreadsheet. "
"Range from 33% to 500%."
msgstr ""
"Povečajte ali zmanjšajte povečavo, uporabljeno za prikaz preglednice. Razpon "
"od 33 % do 500 %."

#. Tag: title
#: commands.docbook:521
#, no-c-format
msgid "The Go Menu"
msgstr "Meni Pojdi"

#. Tag: para
#: commands.docbook:522
#, no-c-format
msgid ""
"In this menu you find actions to navigate between the sheets of the "
"currently opened spreadsheet and the <guimenuitem>Goto Cell</guimenuitem> "
"action to jump to a single cell or to select a range of cells."
msgstr ""
"V tem meniju najdete dejanja za krmarjenje med listi trenutno odprte "
"preglednice in dejanje <guimenuitem>Pojdi na celico</guimenuitem> za skok na "
"posamezno celico ali izbiro obsega celic."

#. Tag: title
#: commands.docbook:528
#, no-c-format
msgid "The Insert Menu"
msgstr "Meni Vstavi"

#. Tag: menuchoice
#: commands.docbook:542
#, no-c-format
msgid "<guimenu>Insert</guimenu> <guisubmenu>Comment</guisubmenu>"
msgstr "<guimenu>Vstavi</guimenu> <guisubmenu>Komentar</guisubmenu>"

#. Tag: para
#: commands.docbook:546
#, no-c-format
msgid "Add or modify a comment."
msgstr "Dodaj ali spremeni komentar."

#. Tag: menuchoice
#: commands.docbook:551
#, no-c-format
msgid "<guimenu>Insert</guimenu> <guimenuitem>Function...</guimenuitem>"
msgstr "<guimenu>Vstavi</guimenu> <guimenuitem>Funkcija...</guimenuitem>"

#. Tag: para
#: commands.docbook:555
#, no-c-format
msgid ""
"<action>Insert a mathematical function.</action> See the section <link "
"linkend=\"formulas\">Formulae</link> for more details."
msgstr ""
"<action>Vstavi matematično funkcijo.</action> Za več podrobnosti glejte "
"razdelek <link linkend=\"formulas\">Formule</link>."

#. Tag: menuchoice
#: commands.docbook:561
#, no-c-format
msgid "<guimenu>Insert</guimenu> <guimenuitem>Series...</guimenuitem>"
msgstr "<guimenu>Vstavi</guimenu> <guimenuitem>Serija...</guimenuitem>"

#. Tag: para
#: commands.docbook:565
#, no-c-format
msgid ""
"<action>Insert a series.</action> See the section <link linkend=\"series"
"\">Series</link> for more details."
msgstr ""
"<action>Vstavite serijo.</action> Za več podrobnosti si oglejte razdelek "
"<link linkend=\"series\">Serije</link>."

#. Tag: menuchoice
#: commands.docbook:571
#, no-c-format
msgid "<guimenu>Insert</guimenu> <guimenuitem>Link...</guimenuitem>"
msgstr "<guimenu>Vstavi</guimenu> <guimenuitem>Povezava...</guimenuitem>"

#. Tag: para
#: commands.docbook:575
#, no-c-format
msgid ""
"<action>Insert a link into the selected cell.</action> See the section <link "
"linkend=\"hyper\">Link Cells</link> for more details."
msgstr ""
"<action>Vstavi povezavo v izbrano celico.</action> Za več podrobnosti glejte "
"razdelek <link linkend=\"hyper\">Povezave celic</link>."

#. Tag: menuchoice
#: commands.docbook:582
#, no-c-format
msgid ""
"<guimenu>Insert</guimenu> <guimenuitem>Special Character...</guimenuitem>"
msgstr "<guimenu>Vstavi</guimenu> <guimenuitem>Poseben znak ...</guimenuitem>"

#. Tag: action
#: commands.docbook:586
#, no-c-format
msgid "Insert a special character into the selected cell."
msgstr "V izbrano celico vstavi poseben znak."

#. Tag: menuchoice
#: commands.docbook:621
#, no-c-format
msgid "<guimenu>Insert</guimenu> <guisubmenu>External Data</guisubmenu>"
msgstr "<guimenu>Vstavi</guimenu> <guisubmenu>Zunanji podatki</guisubmenu>"

#. Tag: para
#: commands.docbook:625
#, no-c-format
msgid ""
"<action>Insert data <guilabel>From Database...</guilabel>, <guilabel>From "
"Text File...</guilabel> or <guilabel>From Clipboard...</guilabel>.</action> "
"See the section <link linkend=\"insertdata\">Inserting External Data</link> "
"for more details."
msgstr ""
"<action>Vstavi podatke <guilabel>Iz zbirke podatkov...</guilabel>, "
"<guilabel>Iz besedilne datoteke...</guilabel> ali <guilabel>Iz odložišča...</"
"guilabel>.</action> Glej razdelek <link linkend=\"insertdata\">Vstavljanje "
"zunanjih podatkov</link> za več podrobnosti."

#. Tag: title
#: commands.docbook:637
#, no-c-format
msgid "The Format Menu"
msgstr "Meni Format"

#. Tag: menuchoice
#: commands.docbook:641
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Ctrl;<keycap>F</keycap></"
"keycombo> </shortcut> <guimenu>Format</guimenu> <guimenuitem>Cell Format...</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Ctrl;<keycap>F</keycap></"
