#. Tag: title
#: menus.docbook:2
#, no-c-format
msgid "Command Reference"
msgstr "Referenca ukazov"

#. Tag: title
#: menus.docbook:13
#, no-c-format
msgid "The Main &tellico; Window"
msgstr "Glavno okno &tellico;"

#. Tag: para
#: menus.docbook:15
#, no-c-format
msgid ""
"Each menu item is discussed below. When there is a keyboard shortcut that "
"performs a menu item function, the default shortcut is listed with the menu "
"item."
msgstr ""
"Vsak element menija je obravnavan spodaj. Če obstaja bližnjica na "
"tipkovnici, ki izvaja funkcijo elementa menija, je privzeta bližnjica "
"navedena ob elementu menija."

#. Tag: title
#: menus.docbook:20
#, no-c-format
msgid "The File Menu"
msgstr "Meni Datoteka"

#. Tag: menuchoice
#: menus.docbook:27
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>New</guimenuitem>"
msgstr "<guimenu>Datoteka</guimenu> <guimenuitem>Nova</guimenuitem>"

#. Tag: para
#: menus.docbook:34
#, no-c-format
msgid ""
"This command <action>creates a new collection</action>. &tellico; supports "
"<link linkend=\"collection-types\">12 default collection types</link> along "
"with an empty user-defined custom collection. Any custom-saved collection "
"templates will also be available."
msgstr ""
"Ta ukaz <action>ustvari novo zbirko</action>. &tellico; podpira <link "
"linkend=\"collection-types\">12 privzetih vrst zbirk</link> skupaj s prazno "
"zbirko po meri, ki jo določi uporabnik. Na voljo bodo tudi vse po meri "
"shranjene predloge zbirk."

#. Tag: menuchoice
#: menus.docbook:40
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>O</keycap></keycombo> </shortcut> "
"<guimenu>File</guimenu> <guimenuitem>Open...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>O</keycap></keycombo> </shortcut> "
"<guimenu>Datoteka</guimenu> <guimenuitem>Odpri...</guimenuitem>"

#. Tag: para
#: menus.docbook:50
#, no-c-format
msgid "This command <action>opens a &tellico; file</action>."
msgstr "Ta ukaz <action>odpre &tellico; datoteko</action>."

#. Tag: menuchoice
#: menus.docbook:56
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Open Recent</guimenuitem>"
msgstr "<guimenu>Datoteka</guimenu> <guimenuitem>Odpri nedavno</guimenuitem>"

#. Tag: para
#: menus.docbook:63
#, no-c-format
msgid ""
"This command <action>opens a file</action> from a submenu that contains a "
"list of recently opened files."
msgstr ""
"Ta ukaz <action>odpre datoteko</action> iz podmenija, ki vsebuje seznam "
"nedavno odprtih datotek."

#. Tag: menuchoice
#: menus.docbook:70
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>S</keycap></keycombo> </shortcut> "
"<guimenu>File</guimenu> <guimenuitem>Save...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>S</keycap></keycombo> </shortcut> "
"<guimenu>Datoteka</guimenu> <guimenuitem>Shrani...</guimenuitem>"

#. Tag: para
#: menus.docbook:80
#, no-c-format
msgid ""
"This command <action>saves the collection</action>. If the file is "
"<emphasis>Untitled</emphasis> then <guimenuitem>Save...</guimenuitem> is "
"equivalent to <guimenuitem>Save As</guimenuitem>. It is only enabled when "
"the collection has been modified."
msgstr ""
"Ta ukaz <action>shrani zbirko</action>. Če je datoteka <emphasis>Brez "
"naslova</emphasis>, je <guimenuitem>Shrani...</guimenuitem> enakovredno "
"<guimenuitem>Shrani kot</guimenuitem>. Omogočen je le, ko je zbirka "
"spremenjena."

#. Tag: menuchoice
#: menus.docbook:89
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;&Shift;<keycap>S</keycap></keycombo> </shortcut> "
"<guimenu>File</guimenu> <guimenuitem>Save As...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;&Shift;<keycap>S</keycap></keycombo> </shortcut> "
"<guimenu>Datoteka</guimenu> <guimenuitem>Shrani kot...</guimenuitem>"

#. Tag: para
#: menus.docbook:99
#, no-c-format
msgid "This command <action>saves the collection to a new file</action>."
msgstr "Ta ukaz <action>shrani zbirko v novo datoteko</action>."

#. Tag: menuchoice
#: menus.docbook:105
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Save As Template...</guimenuitem>"
msgstr ""
"<guimenu>Datoteka</guimenu> <guimenuitem>Shrani kot predlogo...</guimenuitem>"

#. Tag: para
#: menus.docbook:112
#, no-c-format
msgid ""
"This command <action>saves the collection as a new template</action>. Only "
"the fields are saved, and the custom collection type can be created via the "
"<guimenuitem>New Collection</guimenuitem> command."
msgstr ""
"Ta ukaz <action>shrani zbirko kot novo predlogo</action>. Shranijo se samo "
"polja, vrsto zbirke po meri pa lahko ustvarite z ukazom <guimenuitem>Nova "
"zbirka</guimenuitem>."

#. Tag: menuchoice
#: menus.docbook:118
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>P</keycap></keycombo> </shortcut> "
"<guimenu>File</guimenu> <guimenuitem>Print...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>P</keycap></keycombo> </shortcut> "
"<guimenu>Datoteka</guimenu> <guimenuitem>Natisni...</guimenuitem>"

#. Tag: para
#: menus.docbook:128
#, no-c-format
msgid ""
"This command <action>prints the collection</action>. Printing options may be "
"set in the <interface>Configuration Dialog</interface>."
msgstr ""
"Ta ukaz <action>natisne zbirko</action>. Možnosti tiskanja lahko nastavite v "
"<interface>konfiguracijskem pogovornem oknu</interface>."

#. Tag: menuchoice
#: menus.docbook:134
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Print Preview</guimenuitem>"
msgstr ""
"<guimenu>Datoteka</guimenu> <guimenuitem>Predogled tiskanja</guimenuitem>"

#. Tag: para
#: menus.docbook:141
#, no-c-format
msgid ""
"This command <action>shows a preview of the printed collection</action>."
msgstr "Ta ukaz <action>prikaže predogled natisnjene zbirke</action>."

#. Tag: menuchoice
#: menus.docbook:147
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Import</guimenuitem>"
msgstr "<guimenu>Datoteka</guimenu> <guimenuitem>Uvoz</guimenuitem>"

#. Tag: para
#: menus.docbook:154
#, no-c-format
msgid ""
"This command <action>imports data from another file</action>. &tellico; can "
"import data from a number of <link linkend=\"importing\">other formats</"
"link>."
msgstr ""
"Ta ukaz <action>uvozi podatke iz druge datoteke</action>. &tellico; lahko "
"uvozi podatke iz številnih <link linkend=\"importing\">drugih formatov</"
"link>."

#. Tag: menuchoice
#: menus.docbook:160
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Export</guimenuitem>"
msgstr "<guimenu>Datoteka</guimenu> <guimenuitem>Izvoz</guimenuitem>"

#. Tag: para
#: menus.docbook:167
#, no-c-format
msgid ""
"This command <action>exports the collection to another format</action>. "
"&tellico; can export data to a number of <link linkend=\"exporting\">other "
"formats</link>."
msgstr ""
"Ta ukaz <action>izvozi zbirko v drugo obliko</action>. &tellico; lahko "
"izvozi podatke v številne <link linkend=\"exporting\">druge formate</link>."

#. Tag: menuchoice
#: menus.docbook:173
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>Q</keycap></keycombo> </shortcut> "
"<guimenu>File</guimenu> <guimenuitem>Quit</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>Q</keycap></keycombo> </shortcut> "
"<guimenu>Datoteka</guimenu> <guimenuitem>Zapri</guimenuitem>"

#. Tag: para
#: menus.docbook:183
#, no-c-format
msgid ""
"This command <action>closes the &tellico; window</action>. If the collection "
"has unsaved changes, you will be prompted to save them before continuing."
msgstr ""
"Ta ukaz <action>zapre &tellico; okno</action>. Če ima zbirka neshranjene "
"spremembe, boste pred nadaljevanjem pozvani, da jih shranite."

#. Tag: title
#: menus.docbook:193
#, no-c-format
msgid "The Edit Menu"
msgstr "Meni Urejanje"

#. Tag: menuchoice
#: menus.docbook:201
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>Z</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Undo</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>Z</keycap></keycombo> </shortcut> "
"<guimenu>Uredi</guimenu> <guimenuitem>Razveljavi</guimenuitem>"

#. Tag: para
#: menus.docbook:211
#, no-c-format
msgid ""
"This command <action>undoes the previous action</action>. Not all actions "
"are supported by Undo."
msgstr ""
"Ta ukaz <action>razveljavi prejšnje dejanje</action>. Razveljavitev ne "
"podpira vseh dejanj."

#. Tag: menuchoice
#: menus.docbook:217
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;&Shift;<keycap>Z</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Redo</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;&Shift;<keycap>Z</keycap></keycombo> </shortcut> "
"<guimenu>Uredi</guimenu> <guimenuitem>Ponovi</guimenuitem>"

#. Tag: para
#: menus.docbook:227
#, no-c-format
msgid "This command <action>reverts a previous Undo</action>."
msgstr "Ta ukaz <action>razveljavi prejšnje razveljavitev</action>."

#. Tag: menuchoice
#: menus.docbook:233
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>X</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Cut</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>X</keycap></keycombo> </shortcut> "
"<guimenu>Uredi</guimenu> <guimenuitem>Izreži</guimenuitem>"

#. Tag: para
#: menus.docbook:243
#, no-c-format
msgid ""
"This command <action>removes the selected text</action>, if any, and "
"<action>places a copy of the removed text in the clipboard</action>."
msgstr ""
"Ta ukaz <action>odstrani izbrano besedilo</action>, če obstaja, in "
"<action>postavi kopijo odstranjenega besedila v odložišče</action>."

#. Tag: menuchoice
#: menus.docbook:249
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>C</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Copy</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>C</keycap></keycombo> </shortcut> "
"<guimenu>Uredi</guimenu> <guimenuitem>Kopiraj</guimenuitem>"

#. Tag: para
#: menus.docbook:259
#, no-c-format
msgid ""
"This command <action>copies the selected text</action>, if any, to the "
"clipboard."
msgstr ""
"Ta ukaz <action>kopira izbrano besedilo</action>, če obstaja, v odložišče."

#. Tag: menuchoice
#: menus.docbook:265
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>V</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Paste</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>V</keycap></keycombo> </shortcut> "
"<guimenu>Uredi</guimenu> <guimenuitem>Prilepi</guimenuitem>"

#. Tag: para
#: menus.docbook:275
#, no-c-format
msgid ""
"This command <action>pastes the text in the clipboard</action>, if any, into "
"the editor at the cursor position."
msgstr ""
"Ta ukaz <action>prilepi besedilo v odložišče</action>, če obstaja, v "
"urejevalnik na mestu kazalca."

#. Tag: menuchoice
#: menus.docbook:281
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>A</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Select All</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>A</keycap></keycombo> </shortcut> "
"<guimenu>Uredi</guimenu> <guimenuitem>Izberi vse</guimenuitem>"

#. Tag: para
#: menus.docbook:291
#, no-c-format
msgid ""
"This command <action>selects all the entries</action> in the collection, in "
"the <interface>Column View</interface>."
msgstr ""
"Ta ukaz <action>izbere vse vnose</action> v zbirki v <interface>Pogledu "
"stolpcev</interface>."

#. Tag: menuchoice
#: menus.docbook:297
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;&Shift;<keycap>A</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Deselect</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;&Shift;<keycap>A</keycap></keycombo> </shortcut> "
"<guimenu>Uredi</guimenu> <guimenuitem>Prekliči izbiro</guimenuitem>"

#. Tag: para
#: menus.docbook:307
#, no-c-format
msgid ""
"This command <action>deselects all the entries</action> in the collection."
msgstr "Ta ukaz <action>prekliče izbiro vseh vnosov</action> v zbirki."

#. Tag: menuchoice
#: menus.docbook:313
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>I</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Internet Search...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>I</keycap></keycombo> </shortcut> "
"<guimenu>Uredi</guimenu> <guimenuitem>Internet Iskanje...</guimenuitem>"

#. Tag: para
#: menus.docbook:323
#, no-c-format
msgid ""
"This command <action>opens the <interface>Internet Search Dialog</"
"interface></action> to search for and import entries from various Internet "
"sites, including <ulink url=\"http://amazon.com\">Amazon.com</ulink>."
msgstr ""
"Ta ukaz <action>odpre <interface>Pogovorno okno internetnega iskanja</"
"interface></action> za iskanje in uvoz vnosov z različnih spletnih mest, "
"vključno z <ulink url=\"http://amazon.com\">Amazon.com</ulink>."

#. Tag: menuchoice
#: menus.docbook:329
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>J</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Advanced Filter...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>J</keycap></keycombo> </shortcut> "
"<guimenu>Uredi</guimenu> <guimenuitem>Napredni filter...</guimenuitem>"

#. Tag: para
#: menus.docbook:339
#, no-c-format
msgid ""
"This command <action>opens the <interface>Advanced Filter Dialog</"
"interface></action>."
msgstr ""
"Ta ukaz <action>odpre <interface>Pogovorno okno naprednega filtra</"
"interface></action>."

#. Tag: title
#: menus.docbook:350
#, no-c-format
msgid "The Collection Menu"
msgstr "Meni zbirke"

#. Tag: menuchoice
#: menus.docbook:357
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>N</keycap></keycombo> </shortcut> "
"<guimenu>Collection</guimenu> <guimenuitem>New Entry</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>N</keycap></keycombo> </shortcut> "
"<guimenu>Zbirka</guimenu> <guimenuitem>Nov vnos</guimenuitem>"

#. Tag: para
#: menus.docbook:367
#, no-c-format
msgid ""
"This command <action>opens the <interface>Entry Editor</interface> to edit a "
"new entry</action>."
msgstr ""
"Ta ukaz <action>odpre <interface>Urejevalnik vnosov</interface> za urejanje "
"novega vnosa</action>."

#. Tag: menuchoice
#: menus.docbook:373
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>E</keycap></keycombo> </shortcut> "
"<guimenu>Collection</guimenu> <guimenuitem>Edit Entry</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>E</keycap></keycombo> </shortcut> "
"<guimenu>Zbirka</guimenu> <guimenuitem>Uredi vnos</guimenuitem>"

#. Tag: para
#: menus.docbook:383
#, no-c-format
msgid ""
"This command <action>opens the <interface>Entry Editor</interface> to edit "
"the selected entries</action>."
msgstr ""
"Ta ukaz <action>odpre <interface>Urejevalnik vnosov</interface> za urejanje "
"izbranih vnosov</action>."

#. Tag: menuchoice
#: menus.docbook:389
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>Y</keycap></keycombo> </shortcut> "
"<guimenu>Collection</guimenu> <guimenuitem>Duplicate Entry</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>Y</keycap></keycombo> </shortcut> "
"<guimenu>Zbirka</guimenu> <guimenuitem>Podvojeni vnos</guimenuitem>"

#. Tag: para
#: menus.docbook:399
#, no-c-format
msgid ""
"This command <action>copies, or duplicates, the selected entries</action> as "
"new entries in the collection."
msgstr ""
"Ta ukaz <action>kopira ali podvoji izbrane vnose</action> kot nove vnose v "
"zbirki."

#. Tag: menuchoice
#: menus.docbook:405
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>D</keycap></keycombo> </shortcut> "
"<guimenu>Collection</guimenu> <guimenuitem>Delete Entry</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>D</keycap></keycombo> </shortcut> "
"<guimenu>Zbirka</guimenu> <guimenuitem>Izbriši vnos</guimenuitem>"

#. Tag: para
#: menus.docbook:415
#, no-c-format
msgid "This command <action>deletes the selected entries</action>."
msgstr "Ta ukaz <action>izbriše izbrane vnose</action>."

#. Tag: menuchoice
#: menus.docbook:421
#, no-c-format
msgid "<guimenu>Collection</guimenu> <guimenuitem>Merge Entries</guimenuitem>"
msgstr "<guimenu>Zbirka</guimenu> <guimenuitem>Združi vnose</guimenuitem>"

#. Tag: para
#: menus.docbook:433
#, no-c-format
msgid "This command <action>merges the selected entries</action>."
msgstr "Ta ukaz <action>združi izbrane vnose</action>."

#. Tag: menuchoice
#: menus.docbook:439
#, no-c-format
msgid "<guimenu>Collection</guimenu> <guimenuitem>Update Entry</guimenuitem>"
msgstr "<guimenu>Zbirka</guimenu> <guimenuitem>Posodobi vnos</guimenuitem>"

#. Tag: para
#: menus.docbook:446
#, no-c-format
msgid ""
"This menu contains a list of all available data sources, and can be used to "
"automatically query the source and <action>update the selected entries</"
"action>."
msgstr ""
"Ta meni vsebuje seznam vseh razpoložljivih virov podatkov in ga je mogoče "
"uporabiti za samodejno poizvedovanje po viru in <action>posodabljanje "
"izbranih vnosov</action>."

#. Tag: menuchoice
#: menus.docbook:453
#, no-c-format
msgid "<guimenu>Collection</guimenu> <guimenuitem>Check-out</guimenuitem>"
msgstr ""
"<guimenu>Zbirka</guimenu> <guimenuitem>Zabeleži oddajo v izposojo</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:460
#, no-c-format
msgid ""
"This command <action>opens a dialog box for loaning the selected entries.</"
"action>."
msgstr ""
"Ta ukaz <action>odpre pogovorno okno za izposojo izbranih vnosov.</action>."

#. Tag: menuchoice
#: menus.docbook:466
#, no-c-format
msgid "<guimenu>Collection</guimenu> <guimenuitem>Check-in</guimenuitem>"
msgstr ""
"<guimenu>Zbirka</guimenu> <guimenuitem>Prijavi vračilo iz izposoje</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:473
#, no-c-format
msgid ""
"This command <action>checks-in any of the selected entries which are "
"currently on-loan</action>."
msgstr ""
"Ta ukaz <action>prijavi vračilo katerega koli od izbranih vnosov, ki so "
"trenutno izposojeni</action>."

#. Tag: menuchoice
#: menus.docbook:479
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>R</keycap></keycombo> </shortcut> "
"<guimenu>Collection</guimenu> <guimenuitem>Rename Collection</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>R</keycap></keycombo> </shortcut> "
"<guimenu>Zbirka</guimenu> <guimenuitem>Preimenuj zbirko</guimenuitem>"

#. Tag: para
#: menus.docbook:489
#, no-c-format
msgid ""
"This command <action>opens a dialog box for renaming the collection</action>."
msgstr "Ta ukaz <action>odpre pogovorno okno za preimenovanje zbirke</action>."

#. Tag: menuchoice
#: menus.docbook:495
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>U</keycap></keycombo> </shortcut> "
"<guimenu>Collection</guimenu> <guimenuitem>Collection Fields...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>U</keycap></keycombo> </shortcut> "
"<guimenu>Zbirka</guimenu> <guimenuitem>Zbirna polja ...</guimenuitem>"

#. Tag: para
#: menus.docbook:505
#, no-c-format
msgid ""
"This command <action>opens the <interface>Collection Fields Dialog</"
"interface></action>."
msgstr ""
"Ta ukaz <action>odpre <interface>Pogovorno okno polj zbirke</interface></"
"action>."

#. Tag: menuchoice
#: menus.docbook:511
#, no-c-format
msgid ""
"<guimenu>Collection</guimenu> <guimenuitem>Generate Reports...</guimenuitem>"
msgstr ""
"<guimenu>Zbirka</guimenu> <guimenuitem>Ustvari poročila...</guimenuitem>"

#. Tag: para
#: menus.docbook:518
#, no-c-format
msgid ""
"This command <action>opens the <interface>Report Dialog</interface></action> "
"for generating reports about the collection."
msgstr ""
"Ta ukaz <action>odpre <interface>Pogovorno okno za poročila</interface></"
"action> za ustvarjanje poročil o zbirki."

#. Tag: menuchoice
#: menus.docbook:524
#, no-c-format
msgid ""
"<guimenu>Collection</guimenu> <guisubmenu>Bibliography</guisubmenu> "
"<guimenuitem>Convert to Bibliography</guimenuitem>"
msgstr ""
"<guimenu>Zbirka</guimenu> <guisubmenu>Bibliografija</guisubmenu> "
"<guimenuitem>Pretvori v bibliografijo</guimenuitem>"

#. Tag: para
#: menus.docbook:532
#, no-c-format
msgid ""
"This command <action>converts a book collection to a bibliography</action> "
"by adding certain fields necessary for Bibtex export, and it is only enabled "
"when a book collection is open."
msgstr ""
"Ta ukaz <action>pretvori knjižno zbirko v bibliografijo</action> z "
"dodajanjem določenih polj, potrebnih za izvoz v Bibtex, in je omogočen le, "
"ko je knjižna zbirka odprta."

#. Tag: menuchoice
#: menus.docbook:538
#, no-c-format
msgid ""
"<guimenu>Collection</guimenu> <guisubmenu>Bibliography</guisubmenu> "
"<guimenuitem>String Macros...</guimenuitem>"
msgstr ""
"<guimenu>Zbirka</guimenu> <guisubmenu>Bibliografija</guisubmenu> "
"<guimenuitem>Nizi makrov...</guimenuitem>"

#. Tag: para
#: menus.docbook:546
#, no-c-format
msgid ""
"This command <action>opens a dialog box for editing the Bibtex string "
"macros</action> in the collection. It is only enabled when editing a "
"bibliography."
msgstr ""
"Ta ukaz <action>odpre pogovorno okno za urejanje makrov niza Bibtex</action> "
"v zbirki. Omogočen je samo pri urejanju bibliografije."

#. Tag: menuchoice
#: menus.docbook:552
#, no-c-format
msgid ""
"<guimenu>Collection</guimenu> <guisubmenu>Bibliography</guisubmenu> "
"<guimenuitem>Check for Duplicate Keys</guimenuitem>"
msgstr ""
"<guimenu>Zbirka</guimenu> <guisubmenu>Bibliografija</guisubmenu> "
"<guimenuitem>Preveri podvojene ključe</guimenuitem>"

#. Tag: para
#: menus.docbook:560
#, no-c-format
msgid ""
"This command <action>checks for duplicate Bibtex keys</action> and can "
"filter the collection to show the entries with duplicated keys."
msgstr ""
"Ta ukaz <action>preverja podvojene ključe Bibtex</action> in lahko filtrira "
"zbirko, da prikaže vnose s podvojenimi ključi."

#. Tag: menuchoice
#: menus.docbook:566
#, no-c-format
msgid ""
"<guimenu>Collection</guimenu> <guisubmenu>Bibliography</guisubmenu> "
"<guimenuitem>Copy Bibtex to Clipboard</guimenuitem>"
msgstr ""
"<guimenu>Zbirka</guimenu> <guisubmenu>Bibliografija</guisubmenu> "
"<guimenuitem>Kopiraj Bibtex v odložišče</guimenuitem>"

#. Tag: para
#: menus.docbook:574
#, no-c-format
msgid ""
"This command <action>copies a Bibtex citation</action> to the clipboard so "
"that it can pasted in a LaTeX document."
msgstr ""
"Ta ukaz <action>kopira citat Bibtex</action> v odložišče, da ga lahko "
"prilepite v dokument LaTeX."

#. Tag: menuchoice
#: menus.docbook:580
#, no-c-format
msgid ""
"<guimenu>Collection</guimenu> <guisubmenu>Bibliography</guisubmenu> "
"<guimenuitem>Cite Entry in Lyx</guimenuitem>"
msgstr ""
"<guimenu>Zbirka</guimenu> <guisubmenu>Bibliografija</guisubmenu> "
"<guimenuitem>Citiraj vnos v Lyx</guimenuitem>"

#. Tag: para
#: menus.docbook:588
#, no-c-format
msgid ""
"This command <action>sends a citation for the selected entries</action> to "
"the so-called <emphasis><link linkend=\"hidden-bibtex-options\">lyxpipe</"
"link></emphasis> for use in <application>LyX</application>, "
"<application>Kile</application>, or other LaTeX applications. It is only "
"enabled when editing a bibliography."
msgstr ""
"Ta ukaz <action>pošlje citat za izbrane vnose</action> v tako imenovani "
"<emphasis><link linkend=\"hidden-bibtex-options\">lyxpipe</link></emphasis> "
"za uporabo v <application >LyX</application>, <application>Kile</"
"application> ali drugi aplikaciji za LaTeX. Omogočen je samo pri urejanju "
"bibliografije."

#. Tag: title
#: menus.docbook:599
#, no-c-format
msgid "The Settings and Help Menu"
msgstr "Meni Nastavitve in pomoč"

#. Tag: para
#: menus.docbook:601
#, no-c-format
msgid ""
"Apart from the common &kde; Settings and Help menus described in the <ulink "
"url=\"help:/fundamentals/menus.html\">Menu</ulink> chapter of the &kde; "
"Fundamentals documentation &tellico; has these application specific menu "
"entries:"
msgstr ""
"Poleg običajnega &kde; Meniji Nastavitve in Pomoč, opisani v poglavju <ulink "
"url=\"help:/fundamentals/menus.html\">Meni</ulink> v &kde; Dokumentacija o "
"osnovah &tellico; ima te menijske vnose za posamezne aplikacije:"

#. Tag: menuchoice
#: menus.docbook:609
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Show Group View</guimenuitem>"
msgstr ""
"<guimenu>Nastavitve</guimenu> <guimenuitem>Pokaži pogled skupine</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:616
#, no-c-format
msgid ""
"This command <action>toggles the display of the <interface>Group View</"
"interface></action>."
msgstr ""
"Ta ukaz <action>preklopi prikaz <interface>Pogleda skupine</interface></"
"action>."

#. Tag: menuchoice
#: menus.docbook:622
#, no-c-format
msgid ""
"<guimenu>Settings</guimenu> <guimenuitem>Show Entry Editor</guimenuitem>"
msgstr ""
"<guimenu>Nastavitve</guimenu> <guimenuitem>Pokaži urejevalnik vnosov</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:629
#, no-c-format
msgid ""
"This command <action>toggles the display of the <interface>Entry Editor</"
"interface></action>."
msgstr ""
"Ta ukaz <action>preklopi prikaz <interface>urejevalnika vnosov</interface></"
"action>."

#. Tag: menuchoice
#: menus.docbook:635
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Group Selection</guimenuitem>"
msgstr ""
"<guimenu>Nastavitve</guimenu> <guimenuitem>Izbira skupine</guimenuitem>"

#. Tag: para
#: menus.docbook:642
#, no-c-format
msgid ""
"This command <action>changes the field used to group the entries</action> in "
"the collection."
msgstr ""
"Ta ukaz <action>spremeni polje, ki se uporablja za združevanje vnosov</"
"action> v zbirki."

#. Tag: menuchoice
#: menus.docbook:648
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Lock Layout</guimenuitem>"
msgstr ""
"<guimenu>Nastavitve</guimenu> <guimenuitem>Zakleni postavitev</guimenuitem>"

#. Tag: para
#: menus.docbook:655
#, no-c-format
msgid ""
"This command <action>locks the layout</action> such that the various "
"collection views cannot be moved. Unlocking the layout allows the user to "
"rearrange them."
msgstr ""
"Ta ukaz <action>zaklene postavitev</action> tako, da različnih pogledov "
"zbirke ni mogoče premikati. Odklepanje postavitve omogoča uporabniku, da jih "
"prerazporedi."

#. Tag: menuchoice
#: menus.docbook:661
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Reset Layout</guimenuitem>"
msgstr ""
"<guimenu>Nastavitve</guimenu> <guimenuitem>Ponastavi postavitev</guimenuitem>"

#. Tag: para
#: menus.docbook:668
#, no-c-format
msgid ""
"This command <action>resets the layout</action> to the default view, which "
"may be helpful if the various views become hidden or collapsed."
msgstr ""
"Ta ukaz <action>ponastavi postavitev</action> na privzeti pogled, kar je "
"lahko koristno, če se različni pogledi skrijejo ali strnejo."

#. Tag: menuchoice
#: menus.docbook:674
#, no-c-format
msgid "<guimenu>Help</guimenu> <guimenuitem>Show Log</guimenuitem>"
msgstr "<guimenu>Pomoč</guimenu> <guimenuitem>Prikaži dnevnik</guimenuitem>"

#. Tag: para
#: menus.docbook:681
#, no-c-format
msgid ""
"When the <userinput>tellico --log</userinput> option is used, this command "
"shows the diagnostic log."
msgstr ""
"Ko je uporabljena možnost <userinput>tellico --log</userinput>, ta ukaz "
"prikaže diagnostični dnevnik."
