#, no-c-format
msgid "Reset"
msgstr "Ponastavi"

#. Tag: member
#: index.docbook:527
#, no-c-format
msgid "Reset both input, result and memory"
msgstr "Ponastavi vnos, rezultat in pomnilnik"

#. Tag: guibutton
