msgstr ""
"<shortcut><keycombo>&Ctrl;&Shift;<keycap>S</keycap></keycombo></"
"shortcut><guimenuitem>Shrani kot</guimenuitem>"

#. Tag: action
#: commands.docbook:28
#, no-c-format
msgid "Saves the library under a new name"
msgstr "Shrani knjižnico pod novim imenom"

#. Tag: guimenuitem
#: commands.docbook:31
#, no-c-format
msgid "Save Symbol"
msgstr "Shrani simbol"

#. Tag: listitem
#: commands.docbook:32
#, no-c-format
msgid ""
"<simpara><action>Save the symbol being edited</action></simpara> <simpara>If "
"the symbol being edited was selected from the library, saving will update "
"that symbol. If it is a new symbol, it will be appended to the library and "
"subsequent saves will append another new symbol to the library. </simpara>"
msgstr ""
"<simpara><action>Shrani simbol, ki ga urejate</action></simpara> <simpara>Če "
"je bil simbol, ki ga urejate, izbran iz knjižnice, bo shranjevanje "
"posodobilo ta simbol. Če gre za nov simbol, bo dodan v knjižnico in "
"nadaljnja shranjevanja bodo v knjižnico dodala še en nov simbol. </simpara>"

#. Tag: guimenuitem
#: commands.docbook:39
#, no-c-format
msgid "Save Symbol as New"
msgstr "Shrani simbol kot nov"

#. Tag: listitem
#: commands.docbook:40
#, no-c-format
msgid ""
"<simpara><action>Save the symbol being edited as a new symbol</action></"
"simpara> <simpara>When a symbol is saved as new it will be appended to the "
"library regardless of it having originally been selected from the library "
"for editing. Subsequent saves will append another new symbol to the library. "
"</simpara>"
msgstr ""
"<simpara><action>Shrani simbol, ki ga urejate, kot nov simbol</action></"
"simpara> <simpara>Ko je simbol shranjen kot nov, bo dodan v knjižnico, ne "
"glede na to, da je bil prvotno izbran iz knjižnice za urejanje. Naslednja "
"shranjevanja bodo v knjižnico dodala še en nov simbol. </simpara>"

#. Tag: guimenuitem
#: commands.docbook:47
#, no-c-format
msgid "Import Library"
msgstr "Uvozi knjižnico"

#. Tag: action
#: commands.docbook:48
#, no-c-format
msgid ""
"Import a library appending the contained symbols into the current library"
msgstr "Uvoz knjižnice z dodajanjem vsebovanih simbolov v trenutno knjižnico"

