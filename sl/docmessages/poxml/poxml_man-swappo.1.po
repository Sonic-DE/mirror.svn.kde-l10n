msgid "swap msgid and msgstr fields in a PO file"
msgstr "zamenja polji msgid in msgstr v datoteki PO"

#. Tag: cmdsynopsis
#: man-swappo.1.docbook:23
#, no-c-format
msgid ""
"<command>swappo</command> <group><option><replaceable>filename.po</"
"replaceable></option></group>"
msgstr ""
"<command>swappo</command> <group><option><replaceable>filename.po</"
"replaceable></option></group>"

#. Tag: title
#: man-swappo.1.docbook:31
#, no-c-format
msgid "Description"
msgstr "Opis"

#. Tag: para
#: man-swappo.1.docbook:33
#, no-c-format
msgid ""
"<command>swappo</command> reads the given PO-file and swaps the msgid and "
"msgstr fields for every message. The result is a new PO-file that translates "
"in the opposite direction. For example, if PO-file translates from English "
"to French, the new PO-file will translate from French to English."
msgstr ""
"<command>swappo</command> prebere dano datoteko PO in zamenja polji msgid in "
"msgstr za vsako sporočilo. Rezultat je nova datoteka PO, ki se prevaja v "
"nasprotno smer. Na primer, če se datoteka PO prevede iz angleščine v "
"francoščino, se bo nova datoteka PO prevedla iz francoščine v angleščino."

#. Tag: para
#: man-swappo.1.docbook:39
#, no-c-format
msgid ""
"The new PO-file will be written to standard output. The old PO-file will "
"remain untouched."
msgstr ""
"Nova PO-datoteka bo zapisana na standardni izhod. Stara datoteka PO bo "
"ostala nedotaknjena."

#. Tag: para
#: man-swappo.1.docbook:41
#, no-c-format
