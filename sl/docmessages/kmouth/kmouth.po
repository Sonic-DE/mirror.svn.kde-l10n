"<guimenu>Datoteka</guimenu> <guimenuitem>Shrani zgodovino kot...</"
"guimenuitem>"

#. Tag: action
#: index.docbook:442
#, no-c-format
msgid "Saves the history into a text file."
msgstr "Shrani zgodovino v besedilno datoteko."

#. Tag: menuchoice
#: index.docbook:445
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>P</keycap></keycombo> </shortcut> "
"<guimenu>File</guimenu> <guimenuitem>Print History...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>P</keycap></keycombo> </shortcut> "
"<guimenu>Datoteka</guimenu> <guimenuitem>Natisni zgodovino ...</guimenuitem>"

#. Tag: action
#: index.docbook:452
#, no-c-format
msgid "Prints the history."
msgstr "Natisne zgodovino."

#. Tag: menuchoice
