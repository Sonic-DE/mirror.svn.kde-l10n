#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>Q</keycap></keycombo> </shortcut> "
"<guimenu>File</guimenu> <guimenuitem>Quit</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>Q</keycap></keycombo> </shortcut> "
"<guimenu>Datoteka</guimenu> <guimenuitem>Zapri</guimenuitem>"

#. Tag: action
#: index.docbook:462
#, no-c-format
msgid "Quits &kmouth;"
msgstr "Zapusti &kmouth;"

#. Tag: title
#: index.docbook:468 index.docbook:613
#, no-c-format
msgid "The Edit Menu"
msgstr "Meni Urejanje"

#. Tag: menuchoice
#: index.docbook:471 index.docbook:616
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>X</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Cut</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>X</keycap></keycombo> </shortcut> "
"<guimenu>Uredi</guimenu> <guimenuitem>Izreži</guimenuitem>"

#. Tag: action
#: index.docbook:478
#, no-c-format
msgid ""
"Cuts the selected section and puts it to the clipboard. If there is some "
"text selected in the edit field it is placed in the clipboard. Otherwise the "
"selected sentences in the history (if any) are placed in the clipboard."
msgstr ""
"Izreže izbrani del in ga postavi na odložišče. Če je v polju za urejanje "
"izbrano besedilo, se to postavi na odložišče. V nasprotnem primeru se "
"izbrani stavki v zgodovini (če obstajajo) postavijo na odložišče."

#. Tag: menuchoice
#: index.docbook:486 index.docbook:628
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>C</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Copy</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>C</keycap></keycombo> </shortcut> "
"<guimenu>Uredi</guimenu> <guimenuitem>Kopiraj</guimenuitem>"

#. Tag: action
#: index.docbook:493
#, no-c-format
msgid ""
"Copies the selected section to the clipboard. If there is some text selected "
"in the edit field it is copied to the clipboard. Otherwise the selected "
"sentences in the history (if any) are copied to the clipboard."
msgstr ""
"Kopira izbrani razdelek na odložišče. Če je v polju za urejanje izbrano "
"besedilo, se kopira v odložišče. V nasprotnem primeru se izbrani stavki v "
"zgodovini (če obstajajo) prekopirajo na odložišče."

#. Tag: menuchoice
#: index.docbook:501 index.docbook:640
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>V</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Paste</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>V</keycap></keycombo> </shortcut> "
"<guimenu>Uredi</guimenu> <guimenuitem>Prilepi</guimenuitem>"

#. Tag: action
#: index.docbook:508
#, no-c-format
msgid ""
"Pastes the clipboard contents at the current cursor position into the edit "
"field."
msgstr ""
"Prilepi vsebino odložišča na trenutni položaj kazalke v polje za urejanje."

#. Tag: menuchoice
#: index.docbook:514
#, no-c-format
msgid "<guimenu>Edit</guimenu> <guimenuitem>Speak</guimenuitem>"
msgstr "<guimenu>Uredi</guimenu> <guimenuitem>Govori</guimenuitem>"

#. Tag: action
#: index.docbook:518
#, no-c-format
msgid ""
"Speaks the currently active sentence(s). If there is some text in the edit "
"field it is spoken. Otherwise the selected sentences in the history (if any) "
"are spoken."
msgstr ""
"Izgovarja trenutno aktivne stavke. Če je v polju za urejanje besedilo, se "
"izgovori. V nasprotnem primeru se izgovorijo izbrani stavki v zgodovini (če "
"obstajajo)."

