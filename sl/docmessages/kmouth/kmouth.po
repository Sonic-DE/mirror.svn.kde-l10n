#. Tag: para
#: index.docbook:35
#, no-c-format
msgid ""
"&kmouth; is an application that enables persons that cannot speak to let "
"their computers speak."
msgstr ""
"&kmouth; je aplikacija, ki osebam, ki ne morejo govoriti, omogoča, da "
"pustijo svojim računalnikom govoriti."

#. Tag: keyword
#: index.docbook:42
#, no-c-format
msgid "<keyword>KDE</keyword>"
msgstr "<keyword>KDE</keyword>"

#. Tag: keyword
