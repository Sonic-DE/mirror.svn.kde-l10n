"<guimenu>Datoteka</guimenu> <guimenuitem>Odpri kot zgodovino ...</"
"guimenuitem>"

#. Tag: action
#: index.docbook:432
#, no-c-format
msgid "Opens a text file into as history of spoken sentences."
msgstr "Odpre besedilno datoteko kot zgodovino izgovorjenih stavkov."

#. Tag: menuchoice
#: index.docbook:435
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>S</keycap></keycombo> </shortcut> "
"<guimenu>File</guimenu> <guimenuitem>Save History As...</guimenuitem>"
msgstr ""
