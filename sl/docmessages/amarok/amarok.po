msgstr "Meni Orodja"

#. Tag: para
#: index.docbook:7495
#, no-c-format
msgid "From this menu you can use additional tools and scripts."
msgstr "V tem meniju lahko uporabljate dodatna orodja in skripte."

#. Tag: phrase
#: index.docbook:7505
#, no-c-format
msgid "<phrase>The Tools Menu</phrase>"
msgstr "<phrase>Meni Orodja</phrase>"

#. Tag: para
