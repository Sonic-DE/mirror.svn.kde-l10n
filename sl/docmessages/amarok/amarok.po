#: index.docbook:7920
#, no-c-format
msgid "Control from Console"
msgstr "Nadzor iz konzole"

#. Tag: para
#: index.docbook:7921
#, no-c-format
msgid ""
"To control &amarok; from the console, type <userinput>amarok --help-all</"
"userinput> for a current complete list of available commands."
msgstr ""
"Za nadzor &amarok; s konzole vnesite <userinput>amarok --help-all</"
"userinput> za trenutni celoten seznam razpoložljivih ukazov."

