#, no-c-format
msgid "<para>The Tools Menu</para>"
msgstr "<para>Meni Orodja</para>"

#. Tag: para
#: index.docbook:7528
#, no-c-format
msgid "Allows you to save bookmarks of various types."
msgstr "Omogoča shranjevanje zaznamkov različnih vrst."

#. Tag: guilabel
#: index.docbook:7533
#, no-c-format
msgid "<guilabel>Cover Manager</guilabel>"
msgstr "<guilabel>Upravljalnik naslovnic</guilabel>"

#. Tag: para
#: index.docbook:7536
#, no-c-format
msgid "Allows you to view album covers and fetch missing ones."
msgstr "Omogoča ogled naslovnic albumov in iskanje manjkajočih."

#. Tag: guilabel
#: index.docbook:7541
#, no-c-format
msgid "<guilabel>Equalizer</guilabel>"
msgstr "<guilabel>Izenačevalnik</guilabel>"

#. Tag: para
#: index.docbook:7544
#, no-c-format
msgid "Shows the equalizer."
msgstr "Prikaže izenačevalnik."

#. Tag: guilabel
