#. Tag: para
#: index.docbook:40
#, no-c-format
msgid ""
"&ktorrent; is a bittorrent application by KDE which allows you to download "
"files using the BitTorrent protocol. It enables you to run multiple torrents "
"at the same time and comes with extended features to make it a full-featured "
"client for BitTorrent."
msgstr ""
"&ktorrent; je bittorrent aplikacija KDE, ki omogoča prenos datotek s "
"protokolom BitTorrent. Omogoča vam zagon več tokov hkrati in ima razširjene "
"funkcije, da postane odjemalec z vsemi funkcijami za BitTorrent."

#. Tag: title
#: index.docbook:43
#, no-c-format
msgid "Features"
msgstr "Zmožnosti"

#. Tag: para
#: index.docbook:44
#, no-c-format
msgid "Queuing of torrents"
msgstr "Čakalna vrsta tokov"

#. Tag: para
#: index.docbook:45
#, no-c-format
msgid "Global and per torrent speed limits"
msgstr "Globalne omejitve hitrosti in omejitve hitrosti na tok"

#. Tag: para
#: index.docbook:46
#, no-c-format
msgid "Previewing of certain file types, build in (video and audio)"
msgstr "Predogled določenih vrst datotek, vgradnja (video in avdio)"

#. Tag: para
#: index.docbook:47
#, no-c-format
msgid "Importing of partially or fully downloaded files"
msgstr "Uvoz delno ali v celoti prenesenih datotek"

#. Tag: para
#: index.docbook:48
#, no-c-format
msgid "File prioritization for multi-file torrents"
msgstr "Prednostna naloga datotek za tokove z več datotekami"

#. Tag: para
#: index.docbook:49
#, no-c-format
msgid "Selective downloading for multi-file torrents"
msgstr "Selektivno nalaganje za tokove z več datotekami"

#. Tag: para
#: index.docbook:50
#, no-c-format
msgid ""
"Kick/ban peers with an additional IP Filter dialog for list/edit purposes"
msgstr ""
"Izbriši/izključi vrstnike z dodatnim pogovornim oknom filtra IP za namene "
"seznama/urejanja"

#. Tag: para
#: index.docbook:51
#, no-c-format
msgid "UDP tracker support"
msgstr "Podpora za sledenje UDP"

#. Tag: para
#: index.docbook:52
#, no-c-format
msgid "Support for private trackers and torrents"
msgstr "Podpora za zasebne sledilnike in tokove"

#. Tag: para
#: index.docbook:53
#, no-c-format
msgid "Support for µTorrent's peer exchange"
msgstr "Podpora za enakovredno izmenjavo µTorrent"

#. Tag: para
#: index.docbook:54
#, no-c-format
msgid "Support for protocol encryption (compatible with Azureus)"
msgstr "Podpora za šifriranje protokola (združljivo z Azureusom)"

#. Tag: para
#: index.docbook:55
#, no-c-format
msgid "Support for creating trackerless torrents"
msgstr "Podpora za ustvarjanje tokov brez sledenja"

#. Tag: para
#: index.docbook:56
#, no-c-format
msgid "Support for distributed hash tables (DHT, the Mainline version)"
msgstr "Podpora za porazdeljene zgoščene tabele (DHT, različica Mainline)"

#. Tag: para
#: index.docbook:57
#, no-c-format
msgid ""
"Support for UPnP to automatically forward ports on a LAN with dynamic "
"assigned hosts"
msgstr ""
"Podpora za UPnP za samodejno posredovanje vrat v LAN z dinamično dodeljenimi "
"gostitelji"

#. Tag: para
#: index.docbook:58
#, no-c-format
msgid "Support for webseeds"
msgstr "Podpora za spletna semena"

#. Tag: para
#: index.docbook:59
#, no-c-format
msgid "System tray integration"
msgstr "Integracija sistemske vrstice"

#. Tag: para
#: index.docbook:60
#, no-c-format
msgid "Tracker authentication support"
msgstr "Podpora za preverjanje pristnosti sledilnika"

#. Tag: para
#: index.docbook:61
#, no-c-format
msgid "Connection though a proxy"
msgstr "Povezava prek posrednika"

#. Tag: para
#: index.docbook:62
#, no-c-format
msgid "Interprocess control via DBus interface"
msgstr "Medprocesno krmiljenje prek vmesnika DBus"

