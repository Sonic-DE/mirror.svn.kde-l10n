#. Tag: title
#: commands.docbook:3
#, no-c-format
msgid "Command Reference"
msgstr "Referenca ukazov"

#. Tag: title
#: commands.docbook:6
#, no-c-format
msgid "Menu Items"
msgstr "Elementi menija"

#. Tag: para
#: commands.docbook:8
#, no-c-format
msgid "A brief overview of some special menu items in &kcalc;:"
msgstr "Kratek pregled nekaterih posebnih postavk menija v &kcalc;:"

#. Tag: menuchoice
#: commands.docbook:12
#, no-c-format
msgid "<guimenu>Constants</guimenu> <guimenuitem>Mathematics</guimenuitem>"
msgstr "<guimenu>Konstante</guimenu> <guimenuitem>Matematika</guimenuitem>"

#. Tag: action
#: commands.docbook:16
#, no-c-format
msgid "Display Pi, Euler Number or Golden Ratio."
msgstr "Prikaži pi, Eulerjevo število ali zlati rez."

#. Tag: menuchoice
#: commands.docbook:21
#, no-c-format
msgid ""
"<guimenu>Constants</guimenu> <guimenuitem>Electromagnetism</guimenuitem>"
msgstr ""
"<guimenu>Konstante</guimenu> <guimenuitem>Elektromagnetizem</guimenuitem>"

#. Tag: action
#: commands.docbook:25
#, no-c-format
msgid ""
"Display Light Speed, Elementary Charge, Impedance of Vacuum, Permeability of "
"Vacuum or Permittivity of Vacuum."
msgstr ""
"Prikaži svetlobno hitrost, elementarni naboj, impedanco vakuuma, prepustnost "
"vakuuma ali prepustnost vakuuma."

#. Tag: menuchoice
#: commands.docbook:31
#, no-c-format
msgid ""
"<guimenu>Constants</guimenu> <guimenuitem>Atomic &amp; Nuclear</guimenuitem>"
msgstr ""
"<guimenu>Konstante</guimenu> <guimenuitem>Atomi &amp; Jedro</guimenuitem>"

#. Tag: action
#: commands.docbook:35
#, no-c-format
msgid ""
"Display Planck's Constant, Elementary Charge or Fine-Structure Constant."
msgstr ""
"Prikaži Planckovo konstanto, elementarni naboj ali konstanto fine strukture."

#. Tag: menuchoice
#: commands.docbook:41
#, no-c-format
msgid "<guimenu>Constants</guimenu> <guimenuitem>Thermodynamics</guimenuitem>"
msgstr "<guimenu>Konstante</guimenu> <guimenuitem>Termodinamika</guimenuitem>"

#. Tag: action
#: commands.docbook:45
#, no-c-format
msgid ""
"Display Boltzmann Constant, Atomic Mass Unit, Molar Gas Constant, Stefan-"
"Boltzmann Constant or Avogadro's Number."
msgstr ""
"Prikaži Boltzmannovo konstanto, enoto za atomsko maso, molsko plinsko "
"konstanto, Stefan-Boltzmannovo konstanto ali Avogadrovo število."

#. Tag: menuchoice
#: commands.docbook:51
#, no-c-format
msgid "<guimenu>Constants</guimenu> <guimenuitem>Gravitation</guimenuitem>"
msgstr "<guimenu>Konstante</guimenu> <guimenuitem>Gravitacija</guimenuitem>"

#. Tag: para
#: commands.docbook:55
#, no-c-format
msgid "Display Constant of Gravitation or Earth Acceleration."
msgstr "Prikaz konstante gravitacije ali zemeljskega pospeška."

#. Tag: menuchoice
#: commands.docbook:60
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Simple Mode</guimenuitem>"
msgstr ""
"<guimenu>Nastavitve</guimenu> <guimenuitem>Enostavni način</guimenuitem>"

#. Tag: action
#: commands.docbook:64
#, no-c-format
msgid "Displays the simple math buttons."
msgstr "Prikaže preproste matematične gumbe."

#. Tag: menuchoice
#: commands.docbook:69
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Science Mode</guimenuitem>"
msgstr ""
"<guimenu>Nastavitve</guimenu> <guimenuitem>Znanstveni način</guimenuitem>"

#. Tag: action
#: commands.docbook:73
#, no-c-format
msgid "Displays trigonometric and science buttons."
msgstr "Prikaže trigonometrične in znanstvene gumbe."

#. Tag: menuchoice
#: commands.docbook:78
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Statistic Mode</guimenuitem>"
msgstr ""
"<guimenu>Nastavitve</guimenu> <guimenuitem>Statistični način</guimenuitem>"

#. Tag: action
#: commands.docbook:82
#, no-c-format
msgid "Displays <link linkend=\"statistical-mode\">statistic buttons.</link>"
msgstr "Prikaže <link linkend=\"statistical-mode\">statistične gumbe.</link>"

#. Tag: menuchoice
#: commands.docbook:88
#, no-c-format
msgid ""
"<guimenu>Settings</guimenu> <guimenuitem>Numeral System Mode</guimenuitem>"
msgstr ""
"<guimenu>Nastavitve</guimenu> <guimenuitem>Način številskega sistema</"
"guimenuitem>"

#. Tag: action
#: commands.docbook:92
#, no-c-format
msgid ""
"Displays <link linkend=\"and-or-xor\">logic buttons</link> and allows "
"changing the numeral system."
msgstr ""
"Prikaže <link linkend=\"and-or-xor\">logične gumbe</link> in omogoča "
"spreminjanje številskega sistema."

#. Tag: menuchoice
#: commands.docbook:98
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Show History</guimenuitem>"
msgstr ""
"<guimenu>Nastavitve</guimenu> <guimenuitem>Prikaži zgodovino</guimenuitem>"

#. Tag: action
#: commands.docbook:102
#, no-c-format
msgid "Display the history."
msgstr "Prikaži zgodovino."

#. Tag: menuchoice
#: commands.docbook:107
#, no-c-format
msgid ""
"<guimenu>Settings</guimenu> <guimenuitem>Constants Buttons</guimenuitem>"
msgstr ""
"<guimenu>Nastavitve</guimenu> <guimenuitem>Konstantni gumbi</guimenuitem>"

#. Tag: action
#: commands.docbook:111
#, no-c-format
msgid ""
"Display constants buttons. They are available in <link linkend=\"science-mode"
"\">science mode</link> and <link linkend=\"statistical-mode\">statistic "
"mode</link>."
msgstr ""
"Gumbi za prikaz konstant. Na voljo so v <link linkend=\"science-mode"
"\">načinu znanosti</link> in <link linkend=\"statistical-mode\">načinu "
"statistike</link>."

#. Tag: menuchoice
#: commands.docbook:117
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Show Bit Edit</guimenuitem>"
msgstr ""
"<guimenu>Nastavitve</guimenu> <guimenuitem>Prikaži bitno urejanje</"
"guimenuitem>"

#. Tag: action
#: commands.docbook:121
#, no-c-format
msgid ""
"Displays a bit edit field. Click on a bit to toggle it. Only available in "
"<link linkend=\"numeral-system-mode\">numeral system mode</link>."
msgstr ""
"Prikaže polje za urejanje bitov. Kliknite malo, da ga preklopite. Na voljo "
"samo v <link linkend=\"numeral-system-mode\">načinu številskega sistema</"
"link>."

#. Tag: para
#: commands.docbook:128
#, no-c-format
msgid ""
"Additionally &kcalc; has the common <guimenu>File</guimenu>, <guimenu>Edit</"
"guimenu>, <guimenu>Settings</guimenu> and <guimenu>Help</guimenu> menu "
"items, for more information read the sections about the <ulink url=\"help:/"
"fundamentals/menus.html\">Menus</ulink> in the &kde; Fundamentals."
msgstr ""
"Poleg tega &kcalc; ima običajne menijske elemente <guimenu>Datoteka</"
"guimenu>, <guimenu>Uredi</guimenu>, <guimenu>Nastavitve</guimenu> in "
"<guimenu>Pomoč</guimenu>, za več informacij preberite razdelke o <ulink url="
"\"help:/fundamentals/menus.html\">Meniji</ulink> v &kde; Osnove."
