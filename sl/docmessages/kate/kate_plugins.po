#~ msgid ""
#~ "The contents of all editable template fields are available as variables "
#~ "in this scope. For example in a snippet containing <userinput>"
#~ "${<replaceable>field</replaceable>}</userinput>, a variable called "
#~ "<userinput>field</userinput> will be present which contains the up-to-"
