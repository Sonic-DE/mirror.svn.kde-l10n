#: index.docbook:59
#, no-c-format
msgid "&kdiff3; is a file and folder diff and merge tool which"
msgstr "&kdiff3; je orodje za razlikovanje in spajanje datotek in map, ki"

#. Tag: para
#: index.docbook:62
#, no-c-format
msgid "compares and merges two or three text input files or folders,"
msgstr "primerja in združuje dve ali tri datoteke ali mape za vnos besedil,"

#. Tag: para
#: index.docbook:63
#, no-c-format
msgid "shows the differences line by line and character by character(!),"
msgstr "prikazuje razlike vrstico po vrstici in znak po znaku (!),"

#. Tag: para
#: index.docbook:64
#, no-c-format
msgid "provides an automatic merge-facility,"
msgstr "zagotavlja samodejno zlivanje,"

#. Tag: para
#: index.docbook:65
#, no-c-format
msgid "has an editor for comfortable solving of merge-conflicts,"
msgstr "ima urejevalnik za udobno reševanje sporov zlivanja,"

#. Tag: para
#: index.docbook:66
#, no-c-format
msgid "provides network transparency via KIO,"
msgstr "zagotavlja preglednost omrežja prek KIO,"

#. Tag: para
#: index.docbook:67
#, no-c-format
msgid "has options to highlight or hide changes in white-space or comments,"
msgstr ""
"ima možnosti za označevanje ali skrivanje sprememb v belem prostoru ali "
"komentarjih,"

#. Tag: para
#: index.docbook:68
#, no-c-format
msgid "supports Unicode, UTF-8 and other file encodings,"
msgstr "podpira Unicode, UTF-8 in druga kodiranja datotek,"

#. Tag: para
#: index.docbook:69
#, no-c-format
msgid "prints differences,"
msgstr "natisne razlike,"

#. Tag: para
#: index.docbook:70
#, no-c-format
msgid "supports version control keyword and history merging."
msgstr "podpira združevanje ključnih besed in zgodovine nadzora različic."

