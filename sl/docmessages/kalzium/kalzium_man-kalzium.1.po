#, no-c-format
msgid ""
"<command>kalzium</command> <group><option>Options</option></group> <group "
"choice=\"opt\"><option>--molecule <replaceable>filename</replaceable></"
"option></group>"
msgstr ""
"<command>kalzium</command> <group><option>Options</option></group> <group "
"choice=\"opt\"><option>--molecule <replaceable>imena datotek</replaceable></"
"option></group>"

#. Tag: title
#: man-kalzium.1.docbook:36
#, no-c-format
msgid "Description"
msgstr "Opis"

#. Tag: para
#: man-kalzium.1.docbook:38
#, no-c-format
msgid ""
"&kalzium; is a program which shows you the Periodic System of the Elements "
"(PSE). You can use &kalzium; to search for information about the elements or "
"to learn facts about the PSE."
msgstr ""
"&kalzium; je program, ki prikazuje periodni sistem elementov (PSE). S "
"funkcijo &kalzium; lahko poiščete informacije o elementih ali se seznanite z "
"dejstvi o PSE."

#. Tag: para
#: man-kalzium.1.docbook:42
#, no-c-format
msgid ""
"&kalzium; provides you with all kinds of information about the PSE. You can "
"look up lots of information about the elements and also use visualisations "
"to show them."
msgstr ""
"&kalzium; vsebuje vse vrste informacij o sistemu PSE. Poiščete lahko veliko "
"informacij o elementih in jih prikažete z vizualizacijami."

#. Tag: para
#: man-kalzium.1.docbook:46
#, no-c-format
msgid "This package is part of the official KDE edutainment module."
msgstr "Ta paket je del uradnega izobraževalnega modula KDE."

#. Tag: title
#: man-kalzium.1.docbook:51
#, no-c-format
msgid "Options"
msgstr "Možnosti"

#. Tag: option
#: man-kalzium.1.docbook:55
#, no-c-format
msgid "--molecule <replaceable>filename</replaceable>"
msgstr "--molecule <replaceable>ime datoteke</replaceable>"

#. Tag: para
#: man-kalzium.1.docbook:56
#, no-c-format
msgid ""
"Open the given molecule file in cml, xyz, ent, pdb, alc, chm, cdx, cdxml, "
"c3d1, c3d2, gpr, mdl, mol, sdf, sd, crk3d, cht, dmol, bgf, gam, inp, gamin, "
"gamout, tmol, fract, mpd, or mol2 format."
msgstr ""
"Odpre datoteko z danimi molekulami v cml, xyz, ent, pdb, alc, chm, cdx, "
"cdxml, c3d1, c3d2, gpr, mdl, mol, sdf, sd, crk3d, cht, dmol, bgf, gam, inp, "
"gamin, gamout, tmol, fract, mpd,ali mol2 formatu."

