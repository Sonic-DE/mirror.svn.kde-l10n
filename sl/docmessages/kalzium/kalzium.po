#. Tag: para
#: index.docbook:47
#, no-c-format
msgid ""
"&kalzium; is a program which shows you the Periodic Table of Elements. You "
"can use &kalzium; to search for information about the elements or to learn "
"facts about the periodic table."
msgstr ""
"&kalzium; je program, ki prikazuje periodni sistem elementov. S programom "
"&kalzium; lahko poiščete informacije o elementih ali spoznate dejstva o "
"periodnem sistemu elementov."

#. Tag: keyword
#: index.docbook:53
#, no-c-format
msgid "<keyword>KDE</keyword>"
msgstr "<keyword>KDE</keyword>"

#. Tag: keyword
#: index.docbook:54 index.docbook:57
#, no-c-format
