#. Tag: title
#: features.docbook:2
#, no-c-format
msgid "Features"
msgstr "Zmožnosti"

#. Tag: para
#: features.docbook:3
#, no-c-format
msgid "The current feature list and other planned features is shown here."
msgstr ""
"Tukaj je prikazan trenutni seznam funkcij in druge načrtovane funkcije."

#. Tag: para
#: features.docbook:5
#, no-c-format
msgid "Creation of new patterns"
msgstr "Ustvarjanje novih vzorcev"

#. Tag: para
#: features.docbook:7
#, no-c-format
msgid "User defined size"
msgstr "Uporabniško določena velikost"

#. Tag: para
#: features.docbook:8
#, no-c-format
msgid "Selection of material color"
msgstr "Izbira barve materiala"

#. Tag: para
#: features.docbook:9
#, no-c-format
msgid "Insertion of a background images for tracing"
msgstr "Vstavljanje slik ozadja za sledenje"

#. Tag: para
#: features.docbook:10
#, no-c-format
msgid "Importing of various image formats"
msgstr "Uvoz različnih formatov slik"

#. Tag: para
#: features.docbook:11
#, no-c-format
msgid "Importing options allow"
msgstr "Možnosti uvoza omogočajo"

#. Tag: para
#: features.docbook:13
#, no-c-format
msgid "Limiting the number of colors"
msgstr "Omejitev števila barv"

#. Tag: para
#: features.docbook:14
#, no-c-format
msgid "Limiting colors to a specific palette"
msgstr "Omejitev barv na določeno paleto"

#. Tag: para
#: features.docbook:15
#, no-c-format
msgid "Scaling to a finished size"
msgstr "Povečanje na končno velikost"

#. Tag: para
#: features.docbook:16
#, no-c-format
msgid "Support for transparency in images"
msgstr "Podpora za preglednost slik"

#. Tag: para
#: features.docbook:17
#, no-c-format
msgid "Allow the use of fractional stitches"
msgstr "Dovoljeno uporabo delnih šivov"

#. Tag: para
#: features.docbook:22
#, no-c-format
msgid "Editing of existing patterns, Editing tools will include"
msgstr "Urejanje obstoječih vzorcev, vključno z orodji za urejanje"

#. Tag: para
#: features.docbook:24
#, no-c-format
msgid "Open and filled rectangles"
msgstr "Odprti in zapolnjeni pravokotniki"

#. Tag: para
#: features.docbook:25
#, no-c-format
msgid "Open and filled ellipses"
msgstr "Odprte in zapolnjene elipse"

#. Tag: para
#: features.docbook:26
#, no-c-format
msgid "Filled polygons"
msgstr "Zapolnjeni poligoni"

#. Tag: para
#: features.docbook:27
#, no-c-format
msgid "Painting"
msgstr "Slikanje"

#. Tag: para
#: features.docbook:28
#, no-c-format
msgid "Lines"
msgstr "Črte"

#. Tag: para
#: features.docbook:29
#, no-c-format
msgid "Erasing stitches, knots and backstitches"
msgstr "Brisanje šivov, vozlov in hrbtnih šivov"

#. Tag: para
#: features.docbook:30
#, no-c-format
msgid "Color selection from existing stitches"
msgstr "Izbira barve iz obstoječih šivov"

#. Tag: para
#: features.docbook:31
#, no-c-format
msgid "Swapping two colors"
msgstr "Premenjava dveh barv"

#. Tag: para
#: features.docbook:32
#, no-c-format
msgid "Replace one color with another"
msgstr "Zamenja eno barvo z drugo"

#. Tag: para
#: features.docbook:33
#, no-c-format
msgid "Text with user defined fonts and sizes"
msgstr "Besedilo z uporabniško določenimi pisavami in velikostmi"

#. Tag: para
#: features.docbook:34
#, no-c-format
msgid "Cut, copy and paste of rectangular areas."
msgstr "Izrez, kopiranje in lepljenje pravokotnih površin"

#. Tag: para
#: features.docbook:35
#, no-c-format
msgid "Unlimited undo and redo"
msgstr "Neomejeno razveljavitev in uveljavitev"

#. Tag: para
#: features.docbook:36
#, no-c-format
msgid "Mirroring, horizontally and vertically."
msgstr "Zrcaljenje vodoravno in navpično."

#. Tag: para
#: features.docbook:37
#, no-c-format
msgid "Rotation, 90, 180 and 270 degrees anti clockwise."
msgstr "Vrtenje, 90, 180 in 270 stopinj v nasprotni smeri urinega kazalca."

#. Tag: para
#: features.docbook:38
#, no-c-format
msgid "Resizing of the canvas"
msgstr "Spreminjanje velikosti platna"

#. Tag: para
#: features.docbook:40
#, no-c-format
msgid "Extend canvas left, top, right, bottom"
msgstr "Razširjanje platna levo, zgoraj, desno, spodaj"

#. Tag: para
#: features.docbook:41
#, no-c-format
msgid "Cropping canvas to pattern"
msgstr "Obrezovanje platna po vzorcu"

#. Tag: para
#: features.docbook:42
#, no-c-format
msgid "Cropping canvas to selection"
msgstr "Obrezovanje platna na izbor"

#. Tag: para
#: features.docbook:43
#, no-c-format
msgid "Inserting rows and columns"
msgstr "Vstavljanje vrstic in stolpcev"

#. Tag: para
#: features.docbook:44
#, no-c-format
msgid "Center the pattern on the canvas"
msgstr "Centriranje vzorca na platnu"

#. Tag: para
#: features.docbook:47
#, no-c-format
msgid "Conversion between floss schemes"
msgstr "Pretvorba med shemami nitke"

#. Tag: para
#: features.docbook:50
#, no-c-format
msgid "Use of standard floss pallets, DMC, Anchor, etc."
msgstr "Uporaba standardnih palet nitke, DMC, Anchor itd."

#. Tag: para
#: features.docbook:51
#, no-c-format
msgid "Create customized floss pallets"
msgstr "Ustvari prilagojene palete z nitko"

#. Tag: para
#: features.docbook:52
#, no-c-format
msgid "Create new colors for any floss pallet"
msgstr "Ustvari nove barve za vsako paleto z nitko"

#. Tag: para
#: features.docbook:53
#, no-c-format
msgid "Save / Load current palette"
msgstr "Shrani/naloži trenutno paleto"

#. Tag: para
#: features.docbook:54
#, no-c-format
msgid "Use of standard stitches"
msgstr "Uporaba standardnih šivov"

#. Tag: para
#: features.docbook:55
#, no-c-format
msgid "Pattern library manager"
msgstr "Upravljalnik knjižnice vzorcev"

#. Tag: para
#: features.docbook:57
#, no-c-format
msgid "Create new library patterns"
msgstr "Ustvari nove vzorce knjižnice"

#. Tag: para
#: features.docbook:58
#, no-c-format
msgid "Insert library patterns into a design"
msgstr "Vstavi vzorce knjižnice v dizajn"

#. Tag: para
#: features.docbook:59
#, no-c-format
msgid "Drag and drop from the library to the pattern"
msgstr "Povleci in spusti iz knjižnice v vzorec"

#. Tag: para
#: features.docbook:60
#, no-c-format
msgid "Drag and drop from one library to another"
msgstr "Povleci in spusti iz ene knjižnice v drugo"

#. Tag: para
#: features.docbook:61
#, no-c-format
msgid "Assign key press to patterns for use with the Alphabet tool"
msgstr "Pritisk tipke dodelite vzorcem za uporabo z orodjem Alphabet"

#. Tag: para
#: features.docbook:64
#, no-c-format
msgid "Free use of backstitching"
msgstr "Prosta uporaba hrbtnih šivov"

#. Tag: para
#: features.docbook:65
#, no-c-format
msgid "Printing of completed patterns and floss keys"
msgstr "Tiskanje dokončanih vzorcev in ključev iz nitke"

#. Tag: para
#: features.docbook:67
#, no-c-format
msgid "Pattern image"
msgstr "Slika vzorca"

#. Tag: para
#: features.docbook:68
#, no-c-format
msgid "Instructions"
msgstr "Navodila"

#. Tag: para
#: features.docbook:69
#, no-c-format
msgid "Floss key and stitch summary"
msgstr "Povzetek ključa in nitke"

#. Tag: para
#: features.docbook:70
#, no-c-format
msgid "Pattern chart with page map"
msgstr "Tabela vzorcev s stranjo zemljevida"

#. Tag: para
#: features.docbook:71
#, no-c-format
msgid "Text boxes"
msgstr "Besedilna polja"

#. Tag: para
#: features.docbook:74
#, no-c-format
msgid "Mapping of symbols to flosses"
msgstr "Preslikava simbolov v nitke"

#. Tag: para
#: features.docbook:75
#, no-c-format
msgid "Specify the number of threads for stitches and backstitches"
msgstr "Določite število niti za šive in hrbtne šive"

#. Tag: para
#: features.docbook:76
#, no-c-format
msgid "Calibration of floss colors"
msgstr "Kalibracija barv nitke"

#. Tag: para
#: features.docbook:78
#, no-c-format
msgid ""
"Requests for new features can be made to the <ulink url=\"http://bugs.kde.org"
"\">KDE Bugtracking System</ulink>"
msgstr ""
"Zahteve za nove funkcije lahko vložite na <ulink url=\"http://bugs.kde.org"
"\">sistem za sledenje napakam KDE</ulink>"
