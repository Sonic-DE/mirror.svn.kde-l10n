"<guisubmenu>Izbirne maske</guisubmenu><guimenuitem>Barvna maska</guimenuitem>"

#. Tag: action
#: commands.docbook:100
#, no-c-format
msgid "Limit selections to the currently selected color"
msgstr "Omeji izbiro na trenutno izbrano barvo"

#. Tag: menuchoice
#: commands.docbook:102
#, no-c-format
msgid ""
"<guisubmenu>Selection Masks</guisubmenu><guimenuitem>Exclude Backstitches</"
"guimenuitem>"
msgstr ""
"<guisubmenu>Izbirne maske</guisubmenu><guimenuitem>Izključi hrbtne šive</"
"guimenuitem>"

