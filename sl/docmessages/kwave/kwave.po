msgstr "&no-i18n-plugin_sonagram; (Sonagram)"

#. Tag: phrase
#: index.docbook:6805
#, no-c-format
msgid "Screenshot of the setup dialog of the Sonagram Plugin"
msgstr "Posnetek zaslona nastavitvenega pogovornega okna vtičnika Sonagram"

#. Tag: phrase
