#. Tag: para
#: index.docbook:36
#, no-c-format
msgid ""
"&atlantik; is a client for playing &Monopoly;-like board games on the "
"&monopd; network."
msgstr ""
"&atlantik; je odjemalec za igranje &Monopoly; podobnih družabnih iger na "
"omrežju&monopd;."

#. Tag: keyword
#: index.docbook:44
#, no-c-format
msgid "<keyword>KDE</keyword>"
msgstr "<keyword>KDE</keyword>"

#. Tag: keyword
#: index.docbook:45
#, no-c-format
msgid "network client"
msgstr "omrežni odjemalec"

#. Tag: keyword
#: index.docbook:46
#, no-c-format
msgid "Atlantik"
msgstr "Atlantik"

#. Tag: keyword
#: index.docbook:47
#, no-c-format
