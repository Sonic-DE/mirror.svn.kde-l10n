msgid "PuMoKu"
msgstr "PuMoKu"

#. (itstool) path: component/summary
#: org.kde.pumoku.metainfo.xml:12
msgid "A classic 9 × 9 sudoku game"
msgstr "Klasična igra sudoku 9x9"

#. (itstool) path: description/p
#: org.kde.pumoku.metainfo.xml:28
msgid ""
"PuMoKu is a classic, 9 × 9 Sudoku solving game aimed for Plasma Mobile. It "
"comes with flexible highlighting options and (touch) input methods, full "
"undo stack and more."
msgstr ""
"PuMoKu je klasična igra reševanja sudoku velikosti 9x9, namenjena za Plasma "
"Mobile. Ponuja prilagodljive možnosti označevanja in metode vnosa (na "
"dotik), celoten nabor ukazov za razveljavitev in še več."

#. (itstool) path: ul/li
#: org.kde.pumoku.metainfo.xml:30
msgid "Input methods: Cell first, Number first or Hybrid"
msgstr "Načini vnosa: Najprej celica, Najprej številka ali Hibrid"

#. (itstool) path: ul/li
#: org.kde.pumoku.metainfo.xml:31
msgid "Built in sudoku generator"
msgstr "Vgrajen generator sudokujev"

#. (itstool) path: ul/li
#: org.kde.pumoku.metainfo.xml:32
msgid "Automatic undo when the same action is repeated"
msgstr "Samodejna razveljavitev, ko se isto dejanje ponovi"

