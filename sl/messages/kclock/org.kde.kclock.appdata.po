#. (itstool) path: component/name
#: org.kde.kclock.appdata.xml:12
msgid "Clock"
msgstr "Clock"

#. (itstool) path: component/summary
#: org.kde.kclock.appdata.xml:13
msgid "Keep time and set alarms"
msgstr "Upošteva čas in nastavlja alarme"

#. (itstool) path: description/p
#: org.kde.kclock.appdata.xml:18
msgid ""
"A universal clock application for desktop and mobile. Clock includes a "
"stopwatch and a world clock, and allows you to set multiple alarms and "
"timers."
msgstr ""
"Univerzalna aplikacija ure za namizne in mobilne naprave. Ura vključuje "
"štoparico in svetovno uro ter omogoča nastavitev več alarmov in časovnikov."

#. (itstool) path: description/p
#: org.kde.kclock.appdata.xml:19
msgid ""
"It contains alarm, timer, stopwatch and timezone functionalities. Alarms and "
"timers are able to wake the device from suspend on Plasma."
msgstr ""
"Vsebuje alarm, odštevalnik časa, štoparico in funkcionalnost časovnih pasov. "
"Alarm je sposoben tudi aktivirati napravo iz mirovanja, kadar uporablja "
"Plasmo."

#. (itstool) path: screenshot/caption
#: org.kde.kclock.appdata.xml:33
msgid "Mobile view"
msgstr "Mobilni pogled"

#. (itstool) path: screenshot/caption
#: org.kde.kclock.appdata.xml:37
msgid "Desktop view"
msgstr "Namizni pogled"

#. (itstool) path: screenshot/caption
#: org.kde.kclock.appdata.xml:41
msgid "Timers page"
msgstr "Stran merilnikov časa"

#. (itstool) path: screenshot/caption
#: org.kde.kclock.appdata.xml:45
msgid "Timer page"
msgstr "Stran merilnika časa"

#. (itstool) path: screenshot/caption
#: org.kde.kclock.appdata.xml:49
msgid "Stopwatch page"
msgstr "Stran štoparice"

#. (itstool) path: screenshot/caption
#: org.kde.kclock.appdata.xml:53
msgid "Alarms page"
msgstr "Stran alarma"

#. (itstool) path: description/p
#: org.kde.kclock.appdata.xml:111
msgid "New features and bugfixes in this release:"
msgstr "Nove zmožnosti in popravki napak v tej izdaji:"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:113
msgid "Fixed timer add one minute button."
msgstr "Popravljen časovnik gumb za dodaj eno minuto."

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:114
msgid "Switched to tab bar based sidebar (similar to bottom navigation bar)."
msgstr ""
"Preklopljeno na stransko vrstico, ki temelji na vrstici z zavihki (podobno "
"kot spodnja navigacijska vrstica)."

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:131
msgid "Support for background daemon when using flatpak"
msgstr "Podpora za demon ozadja pri uporabi flatpaka"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:132
msgid "Fix excessive log generation on non-Plasma system"
msgstr "Popravljeno prekomerno ustvarjanje dnevnikov v sistemu, ki ni Plasma"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:140
msgid "Fix \"Clock daemon not found\" popup message"
msgstr "Popravljeno pojavno sporočilo \"Demon ure ni bil najden\""

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:141
msgid "Various bugfixes and user interface improvements"
msgstr "Različni popravki napak in izboljšave uporabniškega vmesnika"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:142
msgid "Add a sound picker component for listing alarm sounds"
msgstr "Dodana komponenta za izbiranje zvokov za seznam zvokov alarmov"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:143
msgid "Start snooze only after button is pressed"
msgstr "Zaženi dremež šele po pritisku gumba"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:144
msgid "Fix alarms not working on PinePhone"
msgstr "Popravi alarme, ki ne delujejo na PinePhone"

#. (itstool) path: description/p
#: org.kde.kclock.appdata.xml:150 org.kde.kclock.appdata.xml:167
msgid "Changes:"
msgstr "Spremembe:"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:152
msgid "Kirigami's bottom navigation bar component is now used for mobile"
msgstr ""
"Kirigamijeva komponenta spodnje navigacijske vrstice se zdaj uporablja za "
"mobilne naprave"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:153
msgid "A Plasma style sidebar is now used on desktop"
msgstr "Stranska vrstica v slogu Plasme se zdaj uporablja na namizju"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:154
msgid "The system tray item now only shows when alarms are pending"
msgstr "Element v sistemski vrstici se zdaj prikaže le, ko so alarmi v teku"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:155
msgid "The daemon automatically stops if no alarms and timers are pending"
msgstr "Demon se samodejno ustavi, če ni alarmov in časovnikov v teku"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:156
msgid "Action bars are now used on the timer and alarms forms page"
msgstr ""
"Vrstice dejanj se zdaj uporabljajo na strani obrazcev za časovnik in alarme"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:157
msgid "The settings button has been moved to the top actions bar"
msgstr "Gumb za nastavitve je bil premaknjen v zgornjo vrstico z dejanji"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:169
msgid ""
"Watch DBus for PowerDevil, so wake from suspend always works if PowerDevil "
"is found"
msgstr ""
"Pazite na DBus za PowerDevil, zato prebujanje iz stanja pripravljenosti "
"vedno deluje, če je PowerDevil najden"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:170
msgid "Use consistent dialog style on the settings page"
msgstr "Uporabi dosleden slog dialoga na strani z nastavitvami"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:171
msgid "After editing an alarm, the alarm now automatically is activated"
msgstr "Po urejanju alarma je alarm zdaj samodejno aktiviran"

#. (itstool) path: description/p
#: org.kde.kclock.appdata.xml:178
msgid "New features and bugfixes:"
msgstr "Nove zmožnosti in popravki napak:"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:180
msgid "Added the ability to set timer presets"
msgstr "Dodana je možnost nastavitve prednastavitev časovnika"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:181
msgid "Added ability to increase timer duration by 1m as timer is running"
msgstr ""
"Dodana možnost podaljšanja trajanja časovnika za 1 minuto med delovanjem "
"časovnika"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:182
msgid ""
"Fixed multiple alarm sounds and notifications being played for one alarm"
msgstr "Popravljeno predvajanje več zvokov alarmov in obvestil za en alarm"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:183
msgid "Fixed errors that prevented the application from working in a Flatpak"
msgstr "Popravljene napake, ki so preprečevale delovanje aplikacije v Flatpaku"

