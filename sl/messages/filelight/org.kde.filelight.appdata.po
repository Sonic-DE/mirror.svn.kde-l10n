#. (itstool) path: component/name
#: org.kde.filelight.appdata.xml:10
msgid "Filelight"
msgstr "Filelight"

#. (itstool) path: component/summary
#: org.kde.filelight.appdata.xml:11
msgid "Show disk usage and delete unused files"
msgstr "Prikazuje rabo diska in briše neuporabljene datoteke"

#. (itstool) path: description/p
#: org.kde.filelight.appdata.xml:13
msgid ""
"Filelight is an application to visualize the disk usage on your computer by "
"showing folders using an easy-to-understand view of concentric rings. "
"Filelight makes it simple to free up space!"
msgstr ""
"FIlelight je aplikacija za vizualizacijo porabe diska na vašem računalniku, "
"tako da prikazuje mape v preprosto razumljivih koncentričnih krogih. "
"Filelight poenostavi sproščanje prostora na disku!"

#. (itstool) path: description/p
#: org.kde.filelight.appdata.xml:16
msgid "Features:"
msgstr "Zmožnosti:"

#. (itstool) path: ul/li
#: org.kde.filelight.appdata.xml:18
msgid "Scan local, remote, or removable disks"
msgstr "Preišči krajevne, oddaljene ali odstranljive diske"

#. (itstool) path: ul/li
#: org.kde.filelight.appdata.xml:19
msgid "View detailed information about files and folders"
msgstr "Pogled podrobnih informacij o datotekah in mapah"

#. (itstool) path: ul/li
#: org.kde.filelight.appdata.xml:20
msgid "Delete files or folders that are taking up too much space"
msgstr "Briši datoteke ali mape, ki zavzemajo preveč prostora"

#. (itstool) path: ul/li
#: org.kde.filelight.appdata.xml:21
msgid "Integration into the Dolphin, Konqueror, and Krusader file managers"
msgstr "Vključitev v upravljalnike datotek Dolphin, Konqueror in Krusader"

#. (itstool) path: ul/li
#: org.kde.filelight.appdata.xml:22
msgid "Configurable color schemes"
msgstr "Nastavljive barvne sheme"

#~ msgid ""
#~ "Filelight creates an interactive map of concentric segmented-rings that "
#~ "helps visualize disk usage on your computer"
#~ msgstr ""
#~ "Filelight ustvari interaktivni zemljevid koncentričnih krožnih izsekov, "
#~ "ki pomagajo prikazati porabo diska na vašem računalniku"

#~ msgid ""
#~ "Filelight is an application to visualize the disk usage on your computer"
#~ msgstr ""
#~ "Filelight je program za vidno predstavitev porabe diska na vašem "
#~ "računalniku"

