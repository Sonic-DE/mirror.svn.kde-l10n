msgid "Shisen-Sho Mahjongg-like Tile Game"
msgstr "Igra s ploščicami Shisen-Sho, podobna Mahjonggu"

#. (itstool) path: description/p
#: org.kde.kshisen.appdata.xml:12
msgid ""
"KShisen is a solitaire-like game played using the standard set of Mahjong "
"tiles. Unlike Mahjong however, KShisen has only one layer of scrambled tiles."
msgstr ""
"KShisen je pasjansi podobna igra, ki uporablja običajni nabor ploščic "
"Mahjonga. Za razliko od Mahjonga pa ima KShisen le eno plast pomešanih "
"ploščic."

