#. (itstool) path: component/name
#: org.kde.kio_zeroconf.metainfo.xml:9
msgid "Zeroconf Support"
msgstr "Podpora Zeroconf"

#. (itstool) path: component/summary
#: org.kde.kio_zeroconf.metainfo.xml:10
msgid "Browse local network services in Dolphin's Network page"
msgstr "Brskaj po lokalnih omrežnih storitvah v Dolphinu na strani omrežja"

#. (itstool) path: description/p
#: org.kde.kio_zeroconf.metainfo.xml:12
msgid ""
"Adds an entry to Dolphin's Network page to show local services such as "
"printers which advertise themselves with DNSSD (called Avahi or Bonjour by "
"other projects)."
msgstr ""
"Doda vnos na strani Dolphin's omrežje, da prikaže lokalne storitve, kot so "
"tiskalniki, ki se oglašujejo z DNSSD (imenovani tudi Avahi ali Bonjour pri "
"drugih projektih)."
