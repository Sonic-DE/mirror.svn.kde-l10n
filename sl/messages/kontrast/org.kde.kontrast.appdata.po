msgid "Check color contrast"
msgstr "Preveri barvni kontrast"

#. (itstool) path: description/p
#: org.kde.kontrast.appdata.xml:14
msgid ""
"Kontrast is a color contrast checker and tells you if your color "
"combinations are distinct enough to be readable and accessible."
msgstr ""
"Kontrast je kontrolnik barvnega kontrasta in vam pove, ali so vaše barvne "
"kombinacije dovolj različne, da so berljive in dostopne."

