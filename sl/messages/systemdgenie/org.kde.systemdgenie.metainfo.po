#. (itstool) path: component/summary
#: org.kde.systemdgenie.metainfo.xml:12
msgid "System service manager"
msgstr "Upravljalnik storitev sistema"

#. (itstool) path: description/p
#: org.kde.systemdgenie.metainfo.xml:14
msgid ""
"systemdGenie allows graphical management of systemd units, including user "
"units, and provides control over logind sessions. It also includes an "
"integrated text editor for easy modification of unit and configuration files."
msgstr ""
"systemdGenie omogoča grafično upravljanje sistemskih enot, vključno z enoto "
"uporabnika in zagotavlja nadzor nad sejami logind. Vključuje tudi vgrajen "
"urejevalnik besedil za enostavno spreminjanje enot in konfiguracijskih "
"datotek."
