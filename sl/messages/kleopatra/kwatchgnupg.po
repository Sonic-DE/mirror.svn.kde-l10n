#: kwatchgnupgmainwin.cpp:69
#, kde-format
msgid "[%1] Log cleared"
msgstr "[%1] Dnevnik počiščen"

#: kwatchgnupgmainwin.cpp:76
#, kde-format
msgid "C&lear History"
msgstr "Počisti zgodovino"

#: kwatchgnupgmainwin.cpp:105
#, kde-format
msgid "[%1] Log stopped"
msgstr "[%1] Beleženje zaustavljeno"

#: kwatchgnupgmainwin.cpp:110
#, kde-format
msgid ""
"The watchgnupg logging program could not be found.\n"
"Please make sure that watchgnupg is installed."
msgstr ""
"Programa za beleženje dnevnik watchgnupg ni bilo mogoče najti.\n"
"Prepričajte se, da je watchgnupg nameščen."

#: kwatchgnupgmainwin.cpp:111 kwatchgnupgmainwin.cpp:121
#, kde-format
msgid "[%1] Failed to start %2"
msgstr "[%1] Neuspel zagon %2"

#: kwatchgnupgmainwin.cpp:120
#, kde-format
msgid ""
"The watchgnupg logging process could not be started.\n"
"Please make sure that watchgnupg is installed properly."
msgstr ""
"Postopka beleženja dnevnika watchgnupg ni bilo mogoče zagnati.\n"
"Prepričajte se, da je watchgnupg pravilno nameščen."

#: kwatchgnupgmainwin.cpp:125
#, kde-format
msgid "[%1] Log started"
msgstr "[%1] Beleženje začeto"

#: kwatchgnupgmainwin.cpp:134
#, kde-format
msgid ""
"The watchgnupg logging process died.\n"
"Do you want to try to restart it?"
msgstr ""
"Opravilo beleženja watchgnupg je umrlo.\n"
"Ali ga želite znova zagnati?"

#: kwatchgnupgmainwin.cpp:136
#, kde-format
msgctxt "@action:button"
msgid "Try Restart"
msgstr "Poskusite ponovni zagon"

#: kwatchgnupgmainwin.cpp:137
#, kde-format
msgctxt "@action:button"
msgid "Do Not Try"
msgstr "Ne poskušajte"

#: kwatchgnupgmainwin.cpp:139
#, kde-format
msgid "====== Restarting logging process ====="
msgstr "====== Ponovno zaganjanje opravila beleženja ====="

#: kwatchgnupgmainwin.cpp:143
#, kde-format
msgid ""
"The watchgnupg logging process is not running.\n"
"This log window is unable to display any useful information."
msgstr ""
"Opravilo beleženja watchgnupg ne teče.\n"
"To okno z dnevnikom ne prikazuje nobenega uporabnega podatka."

#: kwatchgnupgmainwin.cpp:167
#, kde-format
