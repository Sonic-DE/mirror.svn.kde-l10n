#: src/main.cpp:49
#, kde-format
msgctxt "Longer description in about page"
msgid ""
"<p>KomoDo is a todo manager that uses todo.txt specification. It parses any "
"compliant todo.txt files and turns them into easy to use list of tasks.</p>"
msgstr ""
"<p>KomoDo je upravljalnik opravil, ki uporablja specifikacijo todo.txt. "
"Razčleni vse skladne datoteke todo.txt in jih pretvori v enostavne sezname "
"opravil.</p>"

