#: src/ui/TodoDelegate.qml:380
#, kde-format
msgctxt "Syntax quick guide"
msgid ""
"<p>Order of items matters:</p><pre>Completion Priority Creation-Date "
"Description</pre><ul><li>x : Completion status. Remove to set task "
"incompleted.</li><li>(A) : Priority. Can be from A to Z. Optional.</"
"li><li>Completion Date: Date in Year-Month-Day format. Add only if there is "
"creation date and task is completed.</li><li>Creation date: Date in Year-"
"Month-Day format. Optional, but recommended.</li><li>Description: General "
"task description. Mandatory.<ul><li>+Project: Projects this task is relevant "
"to. Optional.</li><li>@Context: In which contexts this task is relevant in. "
"Optional.</li><li>key:value: Various key-value pairs of information. "
"Optional.</li></ul></li></ul><p>Description, contexts, key:value-pairs and "
"projects can be mixed with each other.</p><p>For more detailed information "
"and examples, click on the Help button.</p><br>"
msgstr ""
"<p>Vrstni red elementov je pomemben:</p><pre>Dokončanje Prednost Datum "
"ustvarjanja Opis</pre><ul><li>x: Stanje dokončanja. Odstranite, da nastavite "
"opravilo kot nedokončano.</li><li>(A): Prednost. Lahko je od A do Z. "
"Neobvezno.</li><li>Datum dokončanja: Datum v obliki leto-mesec-dan. Dodajte "
"le, če obstaja datum ustvarjanja in je opravilo končano.</li><li>Datum "
"ustvarjanja: Datum v obliki leto-mesec-dan. Neobvezno, vendar priporočljivo."
"</li><li>Opis: Splošen opis opravila. Obvezno.<ul><li>+Project: Projekti, za "
"katere je to opravilo pomembno. Neobvezno.</li><li>@Context: V katerih "
"kontekstih je to opravilo pomembno. Neobvezno.</li><li>key:vrednost: "
"Različni pari ključ-vrednost informacij. Neobvezno.</li></ul></li></"
"ul><p>Description, kontekste, pare ključ:vrednost in projekte je mogoče "
"kombinirati.</p><p>Za podrobnejše informacije in primere kliknite gumb Pomoč."
"</p><br>"

