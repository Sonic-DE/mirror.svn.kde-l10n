#. (itstool) path: component/name
#: org.kde.partitionmanager.appdata.xml:11
msgid "KDE Partition Manager"
msgstr "Upravljalnik razdelkov za KDE"

#. (itstool) path: component/summary
#: org.kde.partitionmanager.appdata.xml:12
msgid "Manage disks, partitions, and file systems"
msgstr "Upravlja diskovne naprave, razdelke diskov in datotečne sisteme"

#. (itstool) path: description/p
#: org.kde.partitionmanager.appdata.xml:14
msgid ""
"KDE Partition Manager is a utility to help you manage the disks, partitions, "
"and file systems on your computer. It allows you to easily create, copy, "
"move, delete, back up, restore, and resize them without losing data. It "
"supports a large number of file systems, including ext2/3/4, btrfs, "
"reiserfs, NTFS, FAT16/32, JFS, XFS and more."
msgstr ""
"Upravljalnik razdelkov za KDE je pripomoček, ki vam omogoča upravljanje z "
"diski, razdelki in datotečnimi sistemi na vašem računalniku. Z njim lahko "
"enostavno ustvarite, kopirate, premaknete, izbrišete, varnostno kopirate in "
"obnovite ter spreminjate velikost razdelkov brez izgube podatkov. Podpira "
"veliko število datotečnih sistemov vključno z ext2/3/4, btrfs, reiserfs, "
"NTFS, FAT16/32, JFS, XFS in drugimi."

#~ msgid "Features:"
#~ msgstr "Zmožnosti:"

