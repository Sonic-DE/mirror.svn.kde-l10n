#: org.kde.kalarm.appdata.xml:211
msgid "Release description"
msgstr "Opis izdaje"

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:43
msgid "Fix sound files being played at the wrong volume when using VLC."
msgstr ""
"Odpravljena napaka, zaradi katere se zvočne datoteke pri uporabi VLC "
"predvajajo z napačno glasnostjo."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:51
msgid ""
"Fix hang evaluating recurring date-only alarms when start-of-day time is non-"
"zero."
msgstr ""
"Odpravljena težava z zatikanjem pri ocenjevanju ponavljajočih se alarmov "
"samo za datum, ko čas začetka dneva ni enak nič."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:52
msgid ""
"Fix hang evaluating next recurrence time for time zones with daylight "
"savings time."
msgstr ""
"Odpravljeno je zatikanje pri ocenjevanju naslednjega časa ponovitve za "
"časovne pasove z zimskim časom."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:60
msgid "Prevent multiple Defer Alarm dialogs for the same event."
msgstr "Prepreči več pogovornih oken za odložitev alarma za isti dogodek."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:61
msgid ""
"If Defer is disabled for a notification alarm, don't show two Edit buttons."
msgstr ""
"Če je možnost Odloži za obvestilni alarm onemogočena, ne prikaže dveh gumbov "
"za urejanje."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:69
msgid ""
"If a recurrence is suppressed by work time/holidays/exception, suppress its "
"sub-repetitions."
msgstr ""
"Če je ponovitev izključena zaradi delovnega časa/praznikov/izjeme, izključi "
"njene podponovitve."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:70
msgid ""
"Improvements and bug fixes to recurrence/work time/holidays calculations."
msgstr ""
"Izboljšave in popravki napak pri izračunih ponavljanja/delovnega časa/"
"praznikov."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:71
msgid "Fix formatting of user messages which showed HTML tags."
msgstr ""
"Popravljeno oblikovanje uporabniških sporočil, ki so prikazovala oznake HTML."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:72
msgid ""
"Distinguish between daily and minutely sub-repetitions in alarm calendar."
msgstr "V koledarju alarmov loči med dnevnimi in minutnimi podponovitvemi."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:73
msgid ""
"Only mark calendars as 'KeepFormat' if the user declines to update them."
msgstr ""
"Koledarje označi kot \"KeepFormat\" samo, če uporabnik zavrne njihovo "
"posodabljanje."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:82
msgid ""
"If an alarm is late-cancelled, don't remove the event if a sub-repetition is "
"still due."
msgstr ""
"Če je alarm preklican pozno, dogodka ne odstrani, če je še vedno treba "
"izvesti podponovitev."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:83
msgid ""
"Fix infinite loop when alarms trigger, if they are read-only or if the "
"calendar is non-writable."
msgstr ""
"Odpravljena je neskončna zanka, ko se sprožijo alarmi, če so samo za branje "
"ali če koledar ni mogoče zapisovati."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:84
msgid ""
"In edit dialog, don't display high accuracy warning if start time is before "
"now."
msgstr ""
"V pogovornem oknu za urejanje se opozorilo o visoki natančnosti ne prikaže, "
"če je začetni čas pred zdajci."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:93
msgid "Remove excess spacing in Preferences dialog."
msgstr "Odstrani odvečni razmik v pogovornem oknu Nastavitve."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:101
msgid "Prevent message windows taking keyboard focus when they pop up."
msgstr ""
"Prepreči, da bi okna s sporočili prevzela fokus tipkovnice, ko se pojavijo."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:111
msgid "Implement audio backends as plugins to allow user selection."
msgstr ""
"Implementira zvočne zaledne sisteme kot vtičnike, da omogoči uporabnikovo "
"izbiro."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:112
msgid "Clean up time spin box appearance in some styles, e.g. Oxygen."
msgstr "Čas čiščenja videza vrtljivega polja v nekaterih slogih, npr. Oxygen."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:120
msgid "Fix KAlarm exiting before executing session restoration."
msgstr "Popravi je izhod KAlarma pred izvedbo obnovitve seje."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:128
msgid "Fix system tray showing blank KAlarm icon under XFCE."
msgstr ""
"Popravi težavo, zaradi katere je bila v sistemski vrstici pod XFCE prikazana "
"prazna ikona KAlarm."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:136
msgid ""
"Show normal decorated alarm windows over full screen applications on X11."
msgstr ""
"Prikaži običajna okrašena okna alarmov čez celozaslonske aplikacije na X11."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:137
msgid "Fix Akonadi functionality not working."
msgstr "Popravi napako, zaradi katere funkcionalnost Akonadija ne delujejo."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:138
msgid "Make fade work each time a repeated sound alarm is played."
msgstr "Naj se postopno utiša vsakič, ko se predvaja ponovljeni zvočni alarm."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:139
msgid "Fix Edit Alarm dialog error setting time if user's time zone is UTC."
msgstr ""
"Popravi napako pri nastavitvi časa v pogovornem oknu za urejanje alarma, če "
"je časovni pas uporabnika UTC."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:140
msgid "Fix build on FreeBSD if using MPV audio."
msgstr "Popravi gradnjo na FreeBSD, če uporablja MPV zvok."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:148
msgid "Show all Run Mode options in Preferences dialog."
msgstr "Prikaže vse možnosti načina delovanja v pogovornem oknu Nastavitve."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:149
msgid "Provide build option to use VLC or MPV to play sounds."
msgstr "Zagotovi možnost gradnje za uporabo VLC ali MPV za predvajanje zvokov."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:150
msgid "Convert to Qt 6.5 QDateTime/QTimeZone changes."
msgstr "Pretvori spremembe QDateTime/QTimeZone v Qt 6.5."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:159
msgid "Fix crash if kernel alarm timers are supported."
msgstr "Odpravljeno je sesutje, če so podprti časovniki alarmov jedra."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:160
msgid "Fix Wake from Suspend not working when using RTC wake."
msgstr ""
"Popravi napako, zaradi katere prebujanje iz stanja mirovanja ne deluje pri "
"uporabi RTC wake."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:161
msgid ""
"Display any audio error message immediately when using Try button while "
"editing an alarm."
msgstr ""
"Pri uporabi gumba Poskusi med urejanjem alarma takoj prikaže vsako zvočno "
"sporočilo o napaki."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:162
msgid "Fix failure to play sound files using VLC on some systems."
msgstr ""
"Popravi napako pri predvajanju zvočnih datotek z uporabo VLC na nekaterih "
"sistemih."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:170
msgid "Fix repeating audio alarms only playing once."
msgstr ""
"Popravi napako, zaradi katere se ponavljajoči zvočni alarmi predvajajo samo "
"enkrat."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:178
msgid "Use VLC instead of libcanberra to play sounds."
msgstr "Za predvajanje zvokov uporabi VLC namesto libcanberre."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:186
msgid "Fix crash after editing new alarm if spell checking is enabled."
msgstr ""
"Popravi sesutje po urejanju novega alarma, če je omogočeno preverjanje "
"črkovanja."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:196
msgid "Display error message if error occurs trying to play an audio file."
msgstr ""
"Prikaže se sporočilo o napaki, če se pojavi napaka pri predvajanju zvočne "
"datoteke."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:204
msgid "Use libcanberra instead of Phonon to play sounds, for thread safety."
msgstr ""
"Uporabi libcanberra za predvajanje zvokov namesto Phonona za varnost niti."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:205
msgid "In Edit Alarm dialog, allow save if Set Volume checkbox is toggled."
msgstr ""
"V pogovornem oknu Urejanje alarma dovoli shranjevanje, če je potrditveno "
"polje Nastavi glasnost preklopljeno."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:213
msgid "Convert to Qt6 / KDE Frameworks 6."
msgstr "Pretvori v Qt6 / KDE Frameworks 6."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:214
msgid ""
"Enable wake-from-suspend for multiple alarms if user kernel alarm timers are "
"supported (Linux only)."
msgstr ""
"Omogoči wake-from-suspend za več alarmov, če so podprti časovniki alarmov "
"uporabniškega jedra (samo za Linux)."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:215
msgid ""
"Set units for reminder and late-cancel depending on date-only selection in "
"Edit Alarm Template dialog."
msgstr ""
"Nastavi enote za opomnik in pozni preklic glede na izbiro samo datuma v "
"pogovornem oknu Urejanje predloge alarma."

#. (itstool) path: ul/li
#: org.kde.kalarm.appdata.xml:216
msgid "Remove migration of pre-Akonadi KResources calendar configuration."
msgstr "Odstrani selitev konfiguracije koledarja KResources pred Akonadijem."
