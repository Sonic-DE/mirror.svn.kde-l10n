#: desktop/org.kde.spectacle.desktop.cmake:2
msgctxt "GenericName"
msgid "Screenshot Capture Utility"
msgstr "Pripomoček za zajem zaslona"

#: desktop/org.kde.spectacle.desktop.cmake:56 desktop/spectacle.notifyrc:4
msgctxt "Name"
msgid "Spectacle"
msgstr "Spectacle"

#: desktop/org.kde.spectacle.desktop.cmake:109
msgctxt "Comment"
msgid "Take screenshots and screen recordings"
msgstr "Zajemajte posnetke zaslona in snemajte zaslon"

#: desktop/org.kde.spectacle.desktop.cmake:147
msgctxt "Keywords"
msgid "snapshot;capture;print;screenshot;snipping;snipping tool;snip;"
msgstr ""
"zajem zaslona;zajem;tisk;slika zaslona;zajemalno orodje;zajemanje;snip;"
"posnetek;posnetek zaslona;snemanje;snemanje zaslona;"

#: desktop/org.kde.spectacle.desktop.cmake:206
msgctxt "Name"
msgid "Capture Entire Desktop"
msgstr "Zajemi celotno namizje"

#: desktop/org.kde.spectacle.desktop.cmake:264
