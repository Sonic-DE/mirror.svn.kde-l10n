msgid "Capture Current Monitor"
msgstr "Zajemi trenutni zaslon"

#: desktop/org.kde.spectacle.desktop.cmake:322
msgctxt "Name"
msgid "Capture Active Window"
msgstr "Zajemi dejavno okno"

#: desktop/org.kde.spectacle.desktop.cmake:380
msgctxt "Name"
msgid "Capture Rectangular Region"
msgstr "Zajemi pravokotno območje"

#: desktop/org.kde.spectacle.desktop.cmake:438
msgctxt "Name"
msgid "Capture Window Under Cursor"
msgstr "Zajemi okno pod kazalko"

#: desktop/org.kde.spectacle.desktop.cmake:491
