#: org.kde.arianna.appdata.xml:14
msgid ""
"An ebook reader and library management app supporting \".epub\" files. "
"Arianna discovers your books automatically, and sorts them by categories, "
"genres and authors."
msgstr ""
"Bralnik elektronskih knjig in upravljalnik knjižnice, ki podpira datoteke \"."
"epub\". Arianna samodejno odkriva vaše knjige in jih razvrsti po "
"kategorijah, žanrih in avtorjih."

