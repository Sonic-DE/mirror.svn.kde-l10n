msgid "Pix"
msgstr "Pix"

#. (itstool) path: component/summary
#: org.kde.pix.appdata.xml:8
msgid "Image Gallery"
msgstr "Galerija slik"

#. (itstool) path: description/p
#: org.kde.pix.appdata.xml:14
msgid ""
"Pix is an image gallery and image viewer. Pix can be used to open images "
"with other applications like an image editor, add tags to the files, add "
"annotations to pictures, rotate and share them."
msgstr ""
"Pix je galerija slik in pregledovalnik slik. Pix lahko uporabite za "
"odpiranje slik z drugimi aplikacijami kot npr. z urejevalniki slik, lahko "
"dodajate oznake datotek, napise k slikam, jih lahko zavrtite in delite z "
"drugimi."

