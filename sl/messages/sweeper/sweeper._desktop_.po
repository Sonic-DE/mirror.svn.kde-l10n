#: org.kde.sweeper.desktop:8
msgctxt "Name"
msgid "Sweeper"
msgstr "Sweeper"

#: org.kde.sweeper.desktop:75
msgctxt "GenericName"
msgid "System Cleaner"
msgstr "Čistilnik sistema"

#: org.kde.sweeper.desktop:142
msgctxt "Comment"
msgid ""
"Helps to clean unwanted traces the user leaves on the system and to regain "
"disk space removing unused temporary files"
msgstr ""
"Pomaga pri čiščenju neželenih sledi, ki jih uporabnik pušča na sistemu, in "
"sproščanju prostora na disku z odstranjevanjem neuporabljenih začasnih "
"datotek"
