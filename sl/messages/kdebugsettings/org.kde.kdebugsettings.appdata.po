#. (itstool) path: component/name
#: org.kde.kdebugsettings.appdata.xml:13
msgid "KDebugSettings"
msgstr "KDebugSettings"

#. (itstool) path: component/summary
#: org.kde.kdebugsettings.appdata.xml:14
msgid "Set which debug messages are shown"
msgstr "Nastavite, katera sporočila za odkrivanje napak so prikazana"

#. (itstool) path: description/p
#: org.kde.kdebugsettings.appdata.xml:16
msgid ""
"KDebugSettings edits which QLoggingCategory are displayed. QLoggingCategory "
"prints messages on the console for applications and you can define which "
"applications display messages for information, warning or critical errors to "
"help debugging Qt applications."
msgstr ""
"KDebugSettings ureja, katere kategorije QLoggingCategory so prikazane. "
"QLoggingCategory tiska sporočila na konzolo za aplikacije in določite lahko, "
"katere aplikacije prikazujejo sporočila za informacije, opozorila ali "
"kritične napake, tako da pomagajo odpravljati napake aplikacij Qt."

