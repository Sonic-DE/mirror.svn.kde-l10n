#: kwrited-autostart.desktop:2
msgctxt "Name"
msgid "KDE Write Daemon"
msgstr "Ozadnji program za pisanje za KDE"

#: kwrited-autostart.desktop:91
msgctxt "Comment"
msgid "Watch for messages from local users sent with write(1) or wall(1)"
msgstr ""
"Opazuj sporočila od krajevnih uporabnikov, poslanih z write(1) ali wall(1)"

#: kwrited.notifyrc:3
msgctxt "Name"
msgid "Local System Message Service"
msgstr "Krajevna storitev sporočil"

#: kwrited.notifyrc:48
msgctxt "Comment"
msgid "Local system message service"
msgstr "Krajevna storitev za sistemska sporočila"

#: kwrited.notifyrc:117
msgctxt "Name"
msgid "New message received"
msgstr "Prejeto novo sporočilo"

#: kwrited.notifyrc:192
msgctxt "Comment"
msgid "The daemon received a new message sent with wall(1) or write(1)"
msgstr ""
"Ozadnji strežnik je prejel novo sporočilo, ki je bilo poslano z wall(1) ali "
"write(1)"

#~ msgctxt "Name"
#~ msgid "Write Daemon"
#~ msgstr "Ozadnji program za pisanje"
