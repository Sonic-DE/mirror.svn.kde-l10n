#. (itstool) path: component/summary
#: org.kde.krdc.appdata.xml:5
msgid "Connect with RDP or VNC to another computer"
msgstr "Povežite se z RDP ali VNC z drugim računalnikom"

#. (itstool) path: description/p
#: org.kde.krdc.appdata.xml:11
msgid ""
"KRDC is a client application that allows you to view or even control the "
"desktop session on another machine that is running a compatible server. VNC "
"and RDP is supported."
msgstr ""
"KRDC je odjemalska aplikacija, ki vam omogoča ogled ali celo nadzor nad sejo "
"namizja na drugem računalniku, ki ga poganja združljiv strežnik. Podprta sta "
"VNC in RDP."
