#. (itstool) path: ul/li
#: org.kde.CrowTranslate.metainfo.xml:63
msgid "Automate fastest Mozhi instance selection."
msgstr "Avtomatizira najhitrejšo izbiro pojavka Mozhi."

#. (itstool) path: ul/li
#: org.kde.CrowTranslate.metainfo.xml:64
msgid ""
"Automatically assign the fastest instance on the first startup instead of "
"selecting it randomly."
msgstr ""
"Samodejno dodeli najhitrejši pojavek ob prvem zagonu, namesto da ga izbere "
"naključno."

#. (itstool) path: ul/li
#: org.kde.CrowTranslate.metainfo.xml:65
msgid "CLI: By default, use the instance from settings."
msgstr "CLI: Privzeto uporabi pojavek iz nastavitev."

#. (itstool) path: ul/li
#: org.kde.CrowTranslate.metainfo.xml:66
msgid "CLI: Verify language codes."
msgstr "CLI: Preveri jezikovne kode."

#. (itstool) path: ul/li
#: org.kde.CrowTranslate.metainfo.xml:67
msgid "CLI: Do not print empty translations on error."
msgstr "CLI: V primeru napake ne izpisuje praznih prevodov."

#. (itstool) path: ul/li
#: org.kde.CrowTranslate.metainfo.xml:68
msgid "CLI: The --help command returns exit code 1."
msgstr "CLI: Ukaz --help vrne izhodno kodo 1."

#. (itstool) path: ul/li
#: org.kde.CrowTranslate.metainfo.xml:69
msgid "Fix language codes for Persian and Chinese Simplified."
msgstr "Popravi jezikovne kode za perzijščino in poenostavljeno kitajščino."

#. (itstool) path: ul/li
#: org.kde.CrowTranslate.metainfo.xml:70
msgid "Fix loading of Qt translations."
msgstr "Popravljeno nalaganje prevodov Qt."

#. (itstool) path: ul/li
#: org.kde.CrowTranslate.metainfo.xml:92
msgid ""
"Migrate from direct API calls to Mozhi. If you experience slow translation "
"speeds, try selecting a closer instance in the settings."
msgstr ""
"Preseli se z neposrednih klicev API-ja na Mozhi. Če imate počasne hitrosti "
"prevajanja, poskusite v nastavitvah izbrati bližji pojavek."

#. (itstool) path: ul/li
#: org.kde.CrowTranslate.metainfo.xml:93
msgid "Change short option for --speak-translation to -r."
msgstr "Spremeni kratko možnost za --speak-translation v -r."

#. (itstool) path: ul/li
#: org.kde.CrowTranslate.metainfo.xml:94
msgid "Change short option for --speak-source to -o."
msgstr "Spremeni kratko možnost za --speak-source v -o."

#. (itstool) path: ul/li
#: org.kde.CrowTranslate.metainfo.xml:95
msgid "Remove flags from languages."
msgstr "Odstrani zastavice iz jezikov."

#. (itstool) path: ul/li
#: org.kde.CrowTranslate.metainfo.xml:96
msgid "Fix autotranslate checkbox overlap."
msgstr "Odpravi prekrivanje potrditvenih polj za samodejno prevajanje."

#. (itstool) path: ul/li
#: org.kde.CrowTranslate.metainfo.xml:97
msgid "Change application ID to org.kde.CrowTranslate."
msgstr "Spremeni ID aplikacije v org.kde.CrowTranslate."

#. (itstool) path: ul/li
#: org.kde.CrowTranslate.metainfo.xml:98
msgid "Disable \"Start minimized\" by default."
msgstr "Privzeto onemogoči možnost \"Začni strnjeno\"."

#. (itstool) path: ul/li
#: org.kde.CrowTranslate.metainfo.xml:99
msgid "Use icons that are compatible with Adwaita."
msgstr "Uporabi ikone, ki so združljive z Adwaito."

#. (itstool) path: ul/li
#: org.kde.CrowTranslate.metainfo.xml:100
msgid "Use Breeze icons as fallback."
msgstr "Uporabi ikone Breeze kot rezervo."

#. (itstool) path: ul/li
#: org.kde.CrowTranslate.metainfo.xml:101
msgid "Remove updater functionality for Windows."
msgstr "Odstrani zmožnost posodabljanja za Windows."

#. (itstool) path: ul/li
#: org.kde.CrowTranslate.metainfo.xml:123
msgid "Enable new LibreTranslate langs."
msgstr "Omogoči nove jezike LibreTranslate."

#. (itstool) path: ul/li
#: org.kde.CrowTranslate.metainfo.xml:124
msgid "Require Qt5X11Extras on Linux."
msgstr "Zahteva Qt5X11Extras na Linuxu."

#. (itstool) path: ul/li
#: org.kde.CrowTranslate.metainfo.xml:125
msgid "Add and remove old, non-existed, broken Libre and Lingva instances."
msgstr ""
"Doda in odstrani stare, neobstoječe, pokvarjene pojavke Libre in Lingva."

#. (itstool) path: ul/li
#: org.kde.CrowTranslate.metainfo.xml:126
msgid "Improve accessibility for screen readers."
msgstr "Izboljša dostopnost za bralnike zaslona."

#. (itstool) path: ul/li
#: org.kde.CrowTranslate.metainfo.xml:134
msgid ""
"Remove spaces in settings paths. Everywhere instead of \"Crow Translate\" "
