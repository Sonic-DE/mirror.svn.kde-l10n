#. (itstool) path: component/name
#: org.kde.CrowTranslate.metainfo.xml:10
msgid "Crow Translate"
msgstr "Crow Translate"

#. (itstool) path: component/summary
#: org.kde.CrowTranslate.metainfo.xml:14
msgid "Application that allows you to translate and speak text using Mozhi"
msgstr ""
"Prevajalnik, ki vam omogoča prevajanje in izgovorjavo besedila z uporabo "
"Mozhi"

#. (itstool) path: description/p
#: org.kde.CrowTranslate.metainfo.xml:18
msgid ""
"Application written in C++ / Qt that allows you to translate and speak text "
"using Mozhi."
msgstr ""
"Aplikacija napisana v C++ / Qt, ki vam omogoča prevajanje in izgovorjavo "
"besedila z uporabo Mozhi."

#. (itstool) path: description/p
#: org.kde.CrowTranslate.metainfo.xml:19
msgid "Features:"
msgstr "Zmožnosti:"

#. (itstool) path: ul/li
#: org.kde.CrowTranslate.metainfo.xml:21
msgid ""
"Multiple translation engines provided by Mozhi (some instances can disable "
"specific engines)*"
msgstr ""
"Mozhi ponuja več prevajalskih mehanizmov (nekateri pojavki lahko onemogočijo "
"določene motorje)*"

#. (itstool) path: ul/li
#: org.kde.CrowTranslate.metainfo.xml:22
msgid "Translate and speak text from screen or selection"
msgstr "Prevede in izgovarja besedilo z zaslona ali izbire"

#. (itstool) path: ul/li
#: org.kde.CrowTranslate.metainfo.xml:23
msgid "Highly customizable shortcuts"
msgstr "Zelo prilagodljive bližnjice"

#. (itstool) path: ul/li
#: org.kde.CrowTranslate.metainfo.xml:24
msgid "Command-line interface with rich options"
msgstr "Vmesnik ukazne vrstice z bogatimi možnostmi"

#. (itstool) path: ul/li
#: org.kde.CrowTranslate.metainfo.xml:25
msgid "D-Bus API"
msgstr "D-Bus API"

#. (itstool) path: ul/li
#: org.kde.CrowTranslate.metainfo.xml:26
msgid "Available for Linux and Windows"
msgstr "Na voljo za Linux in Windows"

#. (itstool) path: description/p
#: org.kde.CrowTranslate.metainfo.xml:28
msgid ""
"*While Mozhi acts as a proxy to protect your privacy, the third-party "
"services it uses may store and analyze the text you send."
msgstr ""
"*Medtem ko Mozhi deluje kot posrednik za zaščito vaše zasebnosti, lahko "
"storitve tretjih oseb, ki jih uporablja, shranijo in analizirajo besedilo, "
"ki ga pošiljate."

