#: src/org.kde.labplot2.desktop:34 src/org.kde.labplot.desktop:34
msgctxt "GenericName"
msgid "Data Visualization and Analysis software"
msgstr "Programje za vizualizacijo in analizo podatkov"

#: src/org.kde.labplot2.desktop:64 src/org.kde.labplot.desktop:64
msgctxt "Comment"
msgid ""
"LabPlot is a FREE, open source and cross-platform Data Visualization and "
"Analysis software accessible to everyone."
msgstr ""
"LabPlot je prosto, odprtokodno in več-platformno programje za vizualizacijo "
"in analizo podatkov dostopno za vsakogar."

#~ msgctxt "Comment"
#~ msgid ""
#~ "LabPlot is a KDE-application for interactive graphing and analysis of "
#~ "scientific data."
#~ msgstr ""
#~ "LabPlot je aplikacija na namizju KDE za interaktivno grafiko in analizo "
#~ "znanstvenih podatkov."
