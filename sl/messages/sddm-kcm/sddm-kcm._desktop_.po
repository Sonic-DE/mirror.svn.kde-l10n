msgid "SDDM"
msgstr "SDDM"

#: kcm_sddm.actions:58
msgctxt "Name"
msgid "Save Settings"
msgstr "Shrani nastavitve"

#: kcm_sddm.actions:109
msgctxt "Description"
msgid "Save Settings in SDDM"
msgstr "Shrani nastavitve v SDDM"

#: kcm_sddm.actions:163
msgctxt "Name"
msgid "Install an SDDM theme"
msgstr "Namesti temo SDDM"

#: kcm_sddm.actions:213
msgctxt "Description"
msgid "Extract a zip file containing an SDDM theme to the SDDM theme location"
msgstr "Ekstrahiraj datoteko zip, ki vsebuje temo SDDM, na lokacijo teme SDDM"

#: kcm_sddm.actions:254
msgctxt "Name"
msgid "Uninstall an SDDM theme"
msgstr "Odstrani temo SDDM"

#: kcm_sddm.actions:304
msgctxt "Description"
msgid "Remove a previously installed SDDM theme"
msgstr "Odstrani prej nameščeno temo SDDM"

#: kcm_sddm.actions:345
msgctxt "Name"
msgid "Synchronize Settings"
msgstr "Uskladi nastavitve"

#: kcm_sddm.actions:391
msgctxt "Description"
msgid "Synchronize user settings with SDDM settings"
msgstr "Uskladi uporabniške nastavitve z nastavitvami SDDM"

#: kcm_sddm.actions:432
msgctxt "Name"
msgid "Reset Settings"
msgstr "Ponastavi nastavitve"

#: kcm_sddm.actions:478
msgctxt "Description"
msgid "Reset SDDM settings to factory default state"
msgstr "Ponovno nastavi SDDM na tovarniško privzeto stanje"

