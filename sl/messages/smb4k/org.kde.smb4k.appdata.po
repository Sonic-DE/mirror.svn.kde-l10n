msgstr "Predogled vsebine oddaljenega skupnega diska"

#. (itstool) path: ul/li
#: org.kde.smb4k.appdata.xml:29
msgid "Default login"
msgstr "Privzeta prijava"

#. (itstool) path: ul/li
#: org.kde.smb4k.appdata.xml:30
msgid "Special handling of home shares"
msgstr "Posebna obravnava domačih skupnih diskov"

#. (itstool) path: ul/li
#: org.kde.smb4k.appdata.xml:31
msgid "Ability to bookmark favorite shares"
