msgstr "Podpora naprednim možnostim priklopa"

#. (itstool) path: ul/li
#: org.kde.smb4k.appdata.xml:34
msgid "Support of printer shares"
msgstr "Podpora skupni rabi tiskalnikov"

#. (itstool) path: ul/li
#: org.kde.smb4k.appdata.xml:35
msgid ""
