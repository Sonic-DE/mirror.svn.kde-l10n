"Povečajte del zaslona, ki je blizu miškinega kazalca; aktivirano z bližnjico "
"tipkovnice"

#: src/plugins/maximize/package/metadata.json
msgctxt "Description"
msgid "Stretch windows when they are maximized or restored"
msgstr "Raztegni okna, ko so razprta ali obnovljena"

#: src/plugins/minimizeall/package/metadata.json
msgctxt "Description"
msgid "Adds a shortcut to minimize and restore all windows"
msgstr "Doda bližnjico za pomanjšanje in obnovitev vseh oken"

#: src/plugins/mouseclick/metadata.json
msgctxt "Description"
msgid ""
"Creates an animation whenever a mouse button is clicked. This is useful for "
"screenrecordings/presentations. Activated with a keyboard shortcut"
msgstr ""
"Ustvari animacijo, ko kliknete miškin gumb. To je koristno za posnetke "
"zaslona/predstavitve. Aktivirano z bližnjico tipkovnice"

#: src/plugins/mousemark/metadata.json
msgctxt "Description"
msgid ""
"Allows you to draw lines on the desktop; activated with a keyboard shortcut"
msgstr "Omogoča risanje črt na namizju; aktivirano z bližnjico tipkovnice"

#: src/plugins/outputlocator/metadata.json
msgctxt "Description"
msgid "Show screen names"
msgstr "Prikaži imena zaslonov"

#: src/plugins/overview/metadata.json
msgctxt "Description"
msgid ""
"Allows you to overview virtual desktops and windows; activated with a "
"keyboard shortcut"
msgstr ""
"Omogoča pregled navideznih namizij in oken; aktivirano z bližnjico tipkovnice"

#: src/plugins/scale/package/metadata.json
msgctxt "Description"
msgid "Make windows scale in and out when they are shown or hidden"
msgstr "Naj se okna povečajo in zmanjšajo, ko so prikazana ali skrita"

#: src/plugins/screenedge/metadata.json
msgctxt "Description"
msgid ""
"Highlights screen edges and corners that trigger actions when touched as the "
"cursor approaches them"
msgstr ""
"Osvetli robove in vogale zaslona, ​​ki ob dotiku sprožijo dejanja, ko se jim "
"približa kazalka"

#: src/plugins/screenshot/metadata.json
msgctxt "Description"
msgid "Helper effect for screenshot tools"
msgstr "Učinki pomočnika za orodja posnetka zaslona"

#: src/plugins/sessionquit/package/metadata.json
msgctxt "Description"
msgid "Keep the desktop background alive during logout until the end"
msgstr "Ohranite ozadje namizja dejavno med odjavo vse do konca"

#: src/plugins/sheet/metadata.json
msgctxt "Description"
msgid ""
"Make modal dialogs smoothly fly in and out when they are shown or hidden"
msgstr ""
"Modalna okna gladko priletijo in odletijo, kadar se prikažejo ali skrijejo"

#: src/plugins/showfps/metadata.json
msgctxt "Description"
msgid "Display KWin's performance in the corner of the screen"
msgstr "Prikažite odzivnost Kwin v kotu zaslona"

#: src/plugins/showpaint/metadata.json
msgctxt "Description"
msgid ""
"Highlight areas of the desktop that have been recently updated; activated "
"with a keyboard shortcut"
msgstr ""
"Poudari območja namizja, ki so bili pred kratkim posodobljeni; aktivirano z "
"bližnjico tipkovnice"

#: src/plugins/slideback/metadata.json
msgctxt "Description"
msgid "Slide back windows when another window is raised"
msgstr "Podrsa okna nazaj, ko se dvigne drugo okno"

#: src/plugins/slide/metadata.json
msgctxt "Description"
msgid "Slide between virtual desktops when switching"
msgstr "Drsi med virtualnimi namizji med preklapljanjem"

#: src/plugins/slidingpopups/metadata.json
msgctxt "Description"
msgid "Slide Plasma popups in and out"
msgstr "Zdrsni pojavna okna Plasme navznoter in navzven"

#: src/plugins/squash/package/metadata.json
msgctxt "Description"
msgid "Squash windows when they are minimized"
msgstr "Skrči okna, ko so pomanjšana"

#: src/plugins/startupfeedback/metadata.json
msgctxt "Description"
msgid "Helper effect for startup feedback"
msgstr "Učinek pomočnika pri odzivu zagona"

#: src/plugins/synchronizeskipswitcher/package/metadata.json
msgctxt "Description"
msgid ""
"Hides all windows marked as Skip Taskbar to be also excluded from window "
"switchers (e.g. Alt+Tab)"
msgstr ""
"Skrije vsa okna, označena kot Preskoči opravilno vrstico, da bi bila "
"izključena tudi iz preklopnikov oken (npr. izmenjalka+tabulatorka)"

#: src/plugins/systembell/metadata.json
msgctxt "Description"
msgid "Provides the bell"
msgstr "Zagotavlja zvonec"

#: src/plugins/thumbnailaside/metadata.json
msgctxt "Description"
msgid ""
"Display window thumbnails on the edge of the screen; activated with a "
"keyboard shortcut"
msgstr ""
"Prikažite predogledne sličice oken na robu zaslona; aktivirano z bližnjico "
"tipkovnice"

#: src/plugins/tileseditor/metadata.json
msgctxt "Description"
msgid "Editor for the tiling areas"
msgstr "Urejevalnik za področja s sličicami"

#: src/plugins/trackmouse/metadata.json
msgctxt "Description"
msgid ""
"Display a mouse cursor locating effect; activated with a keyboard shortcut"
msgstr ""
"Prikaži učinek lociranja kazalca miške; aktivirano z bližnjico tipkovnice"

#: src/plugins/translucency/package/metadata.json
msgctxt "Description"
msgid "Make windows translucent under different conditions"
msgstr "Naredite okna prosojna pod različnimi pogoji"

#: src/plugins/videowall/package/metadata.json
msgctxt "Description"
msgid ""
"Spans fullscreen video player over all attached screens to create a Video "
"Wall"
msgstr ""
"Raztegne celozaslonski video predvajalnik na vseh pripete zaslone, da "
"ustvarite video steno"

#: src/plugins/windowaperture/package/metadata.json
msgctxt "Description"
msgid "Move windows into screen corners"
msgstr "Premaknite okna v kote zaslona"

#: src/plugins/windowview/metadata.json
msgctxt "Description"
msgid "Zoom out until all opened windows can be displayed side-by-side"
msgstr "Oddaljite, dokler se vsa odprta okna ne prikažejo eno poleg drugega"

#: src/plugins/wobblywindows/metadata.json
msgctxt "Description"
msgid "Deform windows while they are moving"
msgstr "Deformirajte okna, ko se premikajo"

#: src/plugins/zoom/metadata.json
msgctxt "Description"
msgid "Magnify the entire desktop; activated with a keyboard shortcut"
msgstr "Povečaj celotno namizje; aktivirano z bližnjico tipkovnice"

#: src/tabbox/switchers/thumbnail_grid/metadata.json
msgctxt "Description"
msgid "A window switcher layout using a small grid of thumbnails"
msgstr ""
"Okenski preklopnik postavitve z uporabo majhne mreže predoglednih sličic"

