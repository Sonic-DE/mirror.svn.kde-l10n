#. (itstool) path: component/name
#: org.kde.dragonplayer.appdata.xml:9
msgid "Dragon Player"
msgstr "Dragon Player"

#. (itstool) path: component/summary
#: org.kde.dragonplayer.appdata.xml:10
msgid "Play video files and streams"
msgstr "Predvajaj video datoteke in tokove"

#. (itstool) path: description/p
#: org.kde.dragonplayer.appdata.xml:12
msgid ""
"Dragon Player is a video player focusing on simplicity instead of features. "
"Its easy-to-use interface is designed to get out of your way and simply play "
"your video files and streams."
msgstr ""
"Dragon Player je video predvajalnik, ki se osredotoča na preprostost namesto "
"na zmožnosti. Njegov vmesnik, ki je enostaven za uporabo, je zasnovan tako, "
"da se vam umakne in preprosto predvaja vaše video datoteke in tokove."

#. (itstool) path: description/p
#: org.kde.dragonplayer.appdata.xml:15
msgid "Features:"
msgstr "Zmožnosti:"

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:17
msgid ""
"Click to play or pause, and double-click to enter or exit full screen mode."
msgstr ""
"Kliknite za predvajanje ali začasno ustavitev in dvokliknite za vstop ali "
"izhod iz celozaslonskega načina."

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:18
msgid ""
"Choose the subtitle language, and automatically load the right one for your "
"language, if possible."
msgstr ""
"Izberite jezik podnapisov in po možnosti samodejno naložite pravega za svoj "
"jezik."

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:19
msgid "Choose the audio track."
msgstr "Izberite zvočni posnetek."

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:20
msgid "Choose the video track."
msgstr "Izberite video posnetek."

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:21
msgid "Adjust the volume by scrolling."
msgstr "Prilagodite glasnost s pomikanjem."

#~ msgid "Video player with focus on simplicity"
#~ msgstr "Predvajalnik videov osredotočen na enostavnost"

#~ msgid "Simple Interface"
#~ msgstr "Preprost vmesnik"

#~ msgid ""
#~ "Resuming videos: Starts playing a video where you were watching it last "
#~ "time"
#~ msgstr ""
#~ "Nadaljevanje videov: predvajanje videa se začne tam, kjer ste prej končali"

#~ msgid ""
#~ "Support for subtitles: Automatically loads subtitles with the matching "
#~ "name"
#~ msgstr ""
#~ "Podpora podnapisom: samodejno naloži podnapise z ujemajočim se imenom"

#~ msgid "Video display settings (brightness, contrast)"
#~ msgstr "Nastavitve prikaza videa (svetlost, kontrast)"

#~ msgid ""
#~ "Due to using Solid and Phonon DragonPlayer is independent of any "
#~ "multimedia framework or hardware abstraction layer"
#~ msgstr ""
#~ "Z uporabo Solid in Phonon je Dragon Player neodvisen od predstavnostnih "
#~ "ogrodij ali plasti nad strojno opremo"

#~ msgid "Supports playing CDs and DVDs"
#~ msgstr "Podpora predvajanju CD-jev in DVD-jev"
