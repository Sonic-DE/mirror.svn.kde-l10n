#. (itstool) path: component/name
#: org.kde.spacebar.appdata.xml:4
msgid "Spacebar"
msgstr "Spacebar"

#. (itstool) path: component/summary
#: org.kde.spacebar.appdata.xml:5
msgid "SMS/MMS messaging client"
msgstr "Odjemalec za SMS/MMS"

#. (itstool) path: description/p
#: org.kde.spacebar.appdata.xml:12
msgid ""
"Spacebar is a SMS/MMS messaging client. It allows you to send text messages, "
"pictures and other files over a cellular network."
msgstr ""
"Spacebar je odjemalec sporočil SMS/MMS. Dovoljuje pošiljanje besedilnih "
"sporočil, slik in ostalih datotek v mobilnem omrežju."

#~ msgid "KDE Community"
#~ msgstr "Skupnost KDE"

#~ msgid ""
#~ "Spacebar is a telepathy client for Plasma Mobile, that is primarily "
#~ "written for sending and receiving SMS/MMS."
#~ msgstr ""
#~ "Spacebar je odjemalec programa telepahy za Plasma Mobile, ki je v "
#~ "prvenstveno napisan za pošiljanje in prejemanje SMS/MMS-ov."
