msgstr "يبدأ لعبة جديدة."

#. Tag: menuchoice
#: index.docbook:156
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>H</keycap></keycombo></"
"shortcut> <guimenu>Game</guimenu><guimenuitem>Show High Scores</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>H</keycap></keycombo> </"
"shortcut> <guimenu>لعبة</guimenu> <guimenuitem>أظهر النتائج القياسية</"
"guimenuitem>"

#. Tag: action
#: index.docbook:160
#, no-c-format
msgid "Brings up the high scores dialog."
msgstr "يفتح حوار النتائج القياسية."

#. Tag: menuchoice
#: index.docbook:163
#, no-c-format
msgid "<guimenu>Game</guimenu><guimenuitem>Change Level</guimenuitem>"
msgstr "<guimenu>لعبة</guimenu> <guimenuitem>غيّر المستوى</guimenuitem>"

#. Tag: action
#: index.docbook:166
#, no-c-format
msgid ""
"Brings up the level selection dialog. Be careful: changing the current level "
"will make the game consider you as a cheater, so you will not able to "
"register in the high scores table."
msgstr ""
"يفتح حوار اختيار المستوى. احذر: تغيير المستوى الحالي سيجعل اللعبة تعتبرك "
"غشاشًا، ولن تتمكن من التسجيل في جدول النتائج القياسية."

#. Tag: menuchoice
#: index.docbook:169
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>Q</keycap></keycombo></"
"shortcut> <guimenu>Game</guimenu><guimenuitem>Quit</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>Q</keycap></keycombo> </"
"shortcut> <guimenu>لعبة</guimenu> <guimenuitem>أنهِ</guimenuitem>"

#. Tag: para
#: index.docbook:173
#, no-c-format
msgid "<action>Quits</action> &kapman;."
msgstr "<action>ينهي</action> كابمان."

#. Tag: menuchoice
#: index.docbook:177
#, no-c-format
