#. Tag: para
#: index.docbook:59
#, no-c-format
msgid "&kdiff3; is a file and folder diff and merge tool which"
msgstr "المقارن هي أداة لمقارنة ودمج الملفات والمجلدات والتي"

#. Tag: para
#: index.docbook:62
#, no-c-format
msgid "compares and merges two or three text input files or folders,"
msgstr "وتقارن وتدمج ملفين أو ثلاثة ملفات أو مجلدات إدخال نصية،"

#. Tag: para
#: index.docbook:63
#, no-c-format
msgid "shows the differences line by line and character by character(!),"
msgstr "تُظهر الفروقات سطراً بسطر ورمزاً برمز (!)،"

#. Tag: para
#: index.docbook:64
#, no-c-format
msgid "provides an automatic merge-facility,"
msgstr "وتوفر ميزة الدمج الآلي،"

#. Tag: para
#: index.docbook:65
#, no-c-format
msgid "has an editor for comfortable solving of merge-conflicts,"
msgstr "وبها محرر لحل مشاكل الدمج بسهولة،"

#. Tag: para
#: index.docbook:66
#, no-c-format
msgid "provides network transparency via KIO,"
msgstr "وتوفر شفافية الشبكة عبر KIO،"

#. Tag: para
#: index.docbook:67
#, no-c-format
msgid "has options to highlight or hide changes in white-space or comments,"
msgstr ""
"ولديها خيارات لإبراز أو إخفاء التغييرات في المسافات البيضاء أو التعليقات،"

#. Tag: para
#: index.docbook:68
#, no-c-format
msgid "supports Unicode, UTF-8 and other file encodings,"
msgstr "وتتعامل مع ترميز يونيكود و UTF-8 وترميزات الملفات الأخرى،"

#. Tag: para
#: index.docbook:69
#, no-c-format
msgid "prints differences,"
msgstr "وتطبع الفروق,"

#. Tag: para
#: index.docbook:70
#, no-c-format
msgid "supports version control keyword and history merging."
msgstr "وتتيح التحكم في الإصدار ودمج السجل."

