#. Tag: para
#: index.docbook:262
#, no-c-format
msgid "Power Management (Energy Saving, Activity Settings, Advanced Settings)"
msgstr "إدارة الطاقة (توفير الطاقة، إعدادات الأنشطة، إعدادات متقدمة)"

#. Tag: para
#: index.docbook:265
#, no-c-format
msgid "Bluetooth"
msgstr "بلوتوث"

#. Tag: para
#: index.docbook:268
#, no-c-format
msgid "Removable Storage (Device Actions, Digital Camera, Removable Devices)"
