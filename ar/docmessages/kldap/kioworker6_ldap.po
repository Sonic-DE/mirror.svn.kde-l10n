#. Tag: para
#: index.docbook:17
#, no-c-format
msgid ""
"<acronym>ldap</acronym> is the lightweight directory access protocol. It "
"provides access to an X.500 directory, or to a stand-alone <acronym>LDAP</"
"acronym> server."
msgstr ""
"<acronym>ldap</acronym> هو ميفاق الوصول الخفيف إلى الدليل. وهو يتيح الوصول "
"إلى دليل X.500 أو إلى خادم <acronym>LDAP</acronym> مستقل."

#. Tag: para
#: index.docbook:21
#, no-c-format
msgid "You can use the ldap KIO worker as follows:"
msgstr "يمكنك استخدام عامل KIO الخاص بـ LDAP على النحو التالي:"

#. Tag: para
#: index.docbook:23
#, no-c-format
msgid ""
"<userinput>ldap://host:port/ou=People,o=where,c=de??sub</userinput> for a "
"subtree-query"
msgstr ""
"<userinput>ldap://host:port/ou=People,o=where,c=de??sub</userinput> لاستعلام "
"عن شجرة فرعية"

#. Tag: para
#: index.docbook:26
#, no-c-format
msgid ""
"or <userinput>ldap://host:port/cn=MM,ou=People,o=where,c=de??base</"
"userinput> for a complete branch."
msgstr ""
"أو <userinput>ldap://host:port/cn=MM,ou=People,o=where,c=de??base</"
"userinput> للحصول على فرع كامل."
