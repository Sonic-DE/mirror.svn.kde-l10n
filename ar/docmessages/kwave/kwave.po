#: index.docbook:7962
#, no-c-format
msgid "&no-i18n-tag;Labels"
msgstr "&no-i18n-tag;Labels"

#. Tag: entry
#: index.docbook:7963
#, no-c-format
msgid "The list of labels/markers."
msgstr "قائمة التسميات/العلامات."

#. Tag: entry
#: index.docbook:7968
#, no-c-format
msgid "&no-i18n-tag;Length"
msgstr "&no-i18n-tag;Length"

#. Tag: entry
#: index.docbook:7969
#, no-c-format
msgid "Length of the file in samples."
msgstr "طول الملف بالعينات."

#. Tag: entry
#: index.docbook:7974
#, no-c-format
msgid "&no-i18n-tag;License"
msgstr "&no-i18n-tag;License"

#. Tag: entry
#: index.docbook:7975
#, no-c-format
msgid ""
"License information, &eg;, <quote>All Rights Reserved</quote>, <quote>Any "
"Use Permitted</quote>, an URL to a license or the Attribution-ShareAlike 4.0 "
"International (<quote>distributed under the terms of the Attribution-"
"ShareAlike 4.0 International License. See &url_cc_by_sa_4; for details</"
"quote>), &etc;"
msgstr ""
"معلومات الترخيص، مثل: <quote>جميع الحقوق محفوظة</quote>، <quote>يُسمح بأي "
"استخدام</quote>، رابط URL لترخيص أو رخصة المشاع الإبداعي (نسب المصنف - "
"الترخيص بالمثل 4.0) الدولية (<quote>موزع بموجب شروط رخصة المشاع الإبداعي "
"(نسب المصنف - الترخيص بالمثل 4.0) الدولية. راجع &url_cc_by_sa_4; للتفاصيل</"
"quote>)، وغير ذلك؛"

#. Tag: entry
#: index.docbook:7985
#, no-c-format
msgid "&no-i18n-tag;Medium"
msgstr "&no-i18n-tag;Medium"

#. Tag: entry
#: index.docbook:7986
#, no-c-format
msgid ""
"Describes the original subject of the file, where it was first recorded. "
"Example: <quote>orchestra</quote>"
msgstr ""
"يصف الموضوع الأصلي للملف، أين سُجل لأول مرة. مثال: <quote>orchestra</quote>"

#. Tag: entry
#: index.docbook:7992
#, no-c-format
msgid "&no-i18n-tag;Mime Type"
msgstr "&no-i18n-tag;Mime Type"

#. Tag: entry
#: index.docbook:7993
#, no-c-format
msgid "Mime type of the file format"
msgstr "نوع Mime لتنسيق الملف"

#. Tag: entry
#: index.docbook:7998
#, no-c-format
msgid "&no-i18n-tag;Emphasis"
msgstr "&no-i18n-tag;Emphasis"

#. Tag: entry
#: index.docbook:7999
#, no-c-format
msgid "Audio emphasis mode"
msgstr "وضع تشديد الصوت"

#. Tag: entry
#: index.docbook:8004
#, no-c-format
msgid "&no-i18n-tag;Layer"
msgstr "&no-i18n-tag;Layer"

#. Tag: entry
#: index.docbook:8005
#, no-c-format
msgid "MPEG Layer, I, II or III"
msgstr "طبقة إم بي إي جي، I، II أو III"

#. Tag: entry
#: index.docbook:8010
#, no-c-format
msgid "&no-i18n-tag;Mode Extension"
msgstr "&no-i18n-tag;Mode Extension"

#. Tag: entry
#: index.docbook:8011
#, no-c-format
msgid "MPEG Mode Extension (only if Joint Stereo)"
msgstr "امتداد وضع إم بي إي جي (فقط إذا كان مجسم مشترك)"

#. Tag: entry
#: index.docbook:8016 index.docbook:8144
#, no-c-format
msgid "&no-i18n-tag;Version"
msgstr "&no-i18n-tag;Version"

#. Tag: entry
#: index.docbook:8017
#, no-c-format
msgid "MPEG Version, 1, 2 or 2.5"
msgstr "إصدار إم بي إي جي، 1، 2 أو 2.5"

#. Tag: entry
#: index.docbook:8022
#, no-c-format
msgid "&no-i18n-tag;Name"
msgstr "&no-i18n-tag;Name"

