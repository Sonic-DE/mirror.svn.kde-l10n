#. Tag: title
#: index.docbook:5191
#, no-c-format
msgid "&no-i18n-plugin_debug; (Debug Functions)"
msgstr "&no-i18n-plugin_debug; (وظائف التنقيح)"

#. Tag: literal
#: index.docbook:5195
#, no-c-format
msgid "&no-i18n-plugin_debug;"
msgstr "&no-i18n-plugin_debug;"

#. Tag: para
#: index.docbook:5199 index.docbook:5248 index.docbook:5477 index.docbook:5567
#: index.docbook:5723 index.docbook:6078 index.docbook:6171 index.docbook:6477
#: index.docbook:6702 index.docbook:6827 index.docbook:6965
#, no-c-format
msgid "function"
msgstr "الدالة"

#. Tag: para
#: index.docbook:5204
#, no-c-format
msgid ""
"Provides various internal commands useful for debugging and scripting "
"&kwave;. These functions are only available through the main menu if &kwave; "
"has been compiled in debug mode (built with the option CMAKE_WITH_DEBUG)."
msgstr ""
"يوفر أوامر داخلية متنوعة مفيدة لتنقيح وبرمجة موجة. هذه الوظائف متاحة فقط عبر "
"القائمة الرئيسة إذا كان برنامج موجة قد جُمع في وضع التنقيح (بني باستخدام "
"الخيار CMAKE_WITH_DEBUG)."

#. Tag: emphasis
#: index.docbook:5213 index.docbook:5491 index.docbook:5583 index.docbook:5737
#, no-c-format
