"shortcut> <guimenu>Game</guimenu> <guimenuitem>Show High Scores</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>H</keycap></keycombo></"
"shortcut> <guimenu>لعبة</guimenu> <guimenuitem>أظهر الأرقام القياسية</"
"guimenuitem>"

#. Tag: action
#: index.docbook:247
#, no-c-format
msgid "Show the highest scores so far."
msgstr "أظهر أعلى الأرقام القياسية حتى الآن."

#. Tag: menuchoice
#: index.docbook:254
#, no-c-format
msgid "<guimenu>Game</guimenu> <guimenuitem>Single Player</guimenuitem>"
msgstr "<guimenu>لعبة</guimenu> <guimenuitem>لاعب واحد</guimenuitem>"

#. Tag: action
#: index.docbook:262
#, no-c-format
msgid "Start a game with your computer as the opponent."
msgstr "ابدأ لعبة يكون فيها الحاسوب هو الخصم."

#. Tag: menuchoice
#: index.docbook:269
#, no-c-format
msgid "<guimenu>Game</guimenu> <guimenuitem>Host Game…</guimenuitem>"
msgstr "<guimenu>لعبة</guimenu> <guimenuitem>استضف لعبة…</guimenuitem>"

#. Tag: action
#: index.docbook:277
#, no-c-format
msgid "Start the server so another player can connect to you."
msgstr "ابدأ الخادوم ليتمكن لاعب آخر من الاتصال بك."

#. Tag: menuchoice
#: index.docbook:284
#, no-c-format
msgid "<guimenu>Game</guimenu> <guimenuitem>Connect to Game…</guimenuitem>"
msgstr "<guimenu>لعبة</guimenu> <guimenuitem>اتصل بلعبة…</guimenuitem>"

#. Tag: action
#: index.docbook:292
#, no-c-format
msgid "Connect to a server to start a game."
msgstr "اتصل بخادوم لبدء لعبة."

#. Tag: menuchoice
#: index.docbook:299
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>Q</keycap></keycombo> </"
"shortcut> <guimenu>Game</guimenu> <guimenuitem>Quit</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>Q</keycap></keycombo> </"
"shortcut> <guimenu>لعبة</guimenu> <guimenuitem>أنهِ</guimenuitem>"

