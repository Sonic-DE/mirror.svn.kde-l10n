#, no-c-format
msgid ""
"<shortcut><keycap>F5</keycap></shortcut> <guimenu>Game</guimenu> "
"<guimenuitem>Restart Game</guimenuitem>"
msgstr ""
"<shortcut><keycap>F5</keycap></shortcut> <guimenu>لعبة</guimenu> "
"<guimenuitem>أعد تشغيل اللعبة</guimenuitem>"

#. Tag: action
#: index.docbook:232
#, no-c-format
msgid "Restart the game."
msgstr "أعد تشغيل اللعبة."

#. Tag: menuchoice
#: index.docbook:239
#, no-c-format
