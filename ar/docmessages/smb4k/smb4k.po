#, no-c-format
msgid ""
"<guimenu>File</guimenu> <guisubmenu>Profiles</guisubmenu> <guimenuitem>Work</"
"guimenuitem>"
msgstr ""
"<guimenu>ملف</guimenu> <guisubmenu>التشكيلات</guisubmenu> "
"<guimenuitem>العمل</guimenuitem>"

#. Tag: para
