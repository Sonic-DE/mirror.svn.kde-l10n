"  - - - - - - - -       R * * * * - - - -          - - - - - - - -\n"
"  - - - - - - - -         - - - - O - - -          - - - - - - - -"
msgstr ""
"- - - - - - - -         - - - - - - - -          - - - - - - - -\n"
"  - - - - O - - -         - - O - O - - -          - - - - - - - -\n"
"R * * * * - - - -         - - - * - - - -          O - - - - - - -\n"
