"                                2                         3"

#. Tag: para
#: index.docbook:149
#, no-c-format
msgid ""
"As mentioned above, a reflection occurs when a beam emerges from the same "
"point it was sent in. This can happen in several ways:"
msgstr ""
"كما ذكرنا أعلاه، يحدث الانعكاس عندما يخرج الشعاع من النقطة نفسها التي أرسل "
"منها. يمكن أن يحدث هذا بعدة طرق:"

#. Tag: screen
#: index.docbook:154
#, no-c-format
msgid ""
"- - - - - - - -         - - - - - - - -          - - - - - - - -\n"
"  - - - - O - - -         - - O - O - - -          - - - - - - - -\n"
"R * * * * - - - -         - - - * - - - -          O - - - - - - -\n"
"  - - - - O - - -         - - - * - - - -        R - - - - - - - -\n"
"  - - - - - - - -         - - - * - - - -          - - - - - - - -\n"
