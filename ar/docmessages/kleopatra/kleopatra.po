#: index.docbook:2435
#, no-c-format
msgid "Lineedit"
msgstr "تحرير سطر"

#. Tag: literal
#: index.docbook:2438
#, no-c-format
msgid "int32"
msgstr "int32"

#. Tag: entry
#: index.docbook:2439
#, no-c-format
msgid "Lineedit (unformatted)"
msgstr "تحرير سطر (غير منسق)"

#. Tag: entry
#: index.docbook:2440
#, no-c-format
msgid "Spinbox"
msgstr "صندوق عددي"

