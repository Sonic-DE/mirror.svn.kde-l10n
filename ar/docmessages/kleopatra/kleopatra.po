#: index.docbook:2448 index.docbook:2452
#, no-c-format
msgid "specialised control"
msgstr "عنصر تحكم متخصص"

#. Tag: literal
#: index.docbook:2451
#, no-c-format
msgid "ldap server"
msgstr "خادم ldap"

#. Tag: literal
#: index.docbook:2456
#, no-c-format
msgid "key fingerprint"
msgstr "بصمة المفتاح"

