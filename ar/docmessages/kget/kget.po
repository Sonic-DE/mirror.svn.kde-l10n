#. Tag: title
#: index.docbook:52
#, no-c-format
msgid "Introduction"
msgstr "مقدمة"

#. Tag: para
#: index.docbook:56
#, no-c-format
msgid "Start &kget; (you should see a Drop Target)"
msgstr "ابدأ كجت (يجب أن ترى هدف الإسقاط)"

#. Tag: para
#: index.docbook:57
#, no-c-format
msgid "Drag and drop the required &URL; in the &kget; window/Drop Target."
msgstr "اسحب وأسقط العنوان المطلوب في نافذة كجت أو هدف الإسقاط."

#. Tag: screeninfo
