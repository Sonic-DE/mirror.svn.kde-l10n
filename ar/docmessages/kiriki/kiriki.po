#. Tag: para
#: index.docbook:100
#, no-c-format
msgid ""
"Dice on display: '15155'. The sum is: '15'='5'+'5'+'5'. Dice on display: "
"'51555'. The sum is: '20'='5'+'5'+'5'+'5'."
msgstr ""
