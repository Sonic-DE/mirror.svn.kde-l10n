#. Tag: para
#: index.docbook:99
#, no-c-format
msgid ""
"Dice on display: '14142'. The sum is: '8'='4'+'4'. Dice on display: '41414'. "
"The sum is: '12'='4'+'4'+'4'."
msgstr ""
"النرد الظاهر: '14142'. المجموع هو: '8'='4'+'4'. النرد الظاهر: '41414'. "
"المجموع هو: '12'='4'+'4'+'4'."

#. Tag: para
#: index.docbook:100
#, no-c-format
msgid "<guilabel>5s</guilabel>: Sum of all dice valued ‘5’."
