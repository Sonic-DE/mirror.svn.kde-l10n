#. Tag: title
#: menus.docbook:2
#, no-c-format
msgid "The Menu Entries"
msgstr "مدخلات القائمة"

#. Tag: title
#: menus.docbook:5
#, no-c-format
msgid "The File Menu"
msgstr "قائمة ملف"

#. Tag: menuchoice
#: menus.docbook:10
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>N</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>New</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>N</keycap></keycombo> </"
"shortcut> <guimenu>ملف</guimenu> <guimenuitem>جديد</guimenuitem>"

#. Tag: para
#: menus.docbook:18
#, no-c-format
msgid "This starts a new document in a new and independent editor window."
msgstr "يبدأ هذا مستندًا جديدًا في نافذة محرر جديدة ومستقلة."

#. Tag: menuchoice
#: menus.docbook:25
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>New Window</guimenuitem>"
msgstr "<guimenu>ملف</guimenu> <guimenuitem>نافذة جديدة</guimenuitem>"

#. Tag: para
#: menus.docbook:30
#, no-c-format
msgid ""
"Create another window containing the current document. All changes to the "
"document in one window are reflected in the other window and vice versa."
msgstr ""
"تُنشأ نافذة أخرى تحتوي على المستند الحالي. تنعكس جميع التغييرات التي تجرى على "
"المستند في نافذة واحدة على النافذة الأخرى والعكس صحيح."

#. Tag: menuchoice
#: menus.docbook:36
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>O</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Open...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>O</keycap></keycombo> </"
"shortcut> <guimenu>ملف</guimenu> <guimenuitem>افتح...</guimenuitem>"

#. Tag: para
#: menus.docbook:44
#, no-c-format
msgid ""
"Displays a standard &kde; <guilabel>Open File</guilabel> dialog. Use the "
"file view to select the file you want to open, and click on <guibutton>Open</"
"guibutton> to open it."
msgstr ""
"يعرض مربع حوار كيدي المبدئي <guilabel>افتح ملفًا</guilabel>. استعمل عرض "
"الملفات لتحديد الملف الذي تريد فتحه، وانقر على <guibutton>افتح</guibutton> "
"لفتحه."

#. Tag: menuchoice
#: menus.docbook:51
#, no-c-format
msgid "<guimenu>File</guimenu> <guisubmenu>Open Recent</guisubmenu>"
msgstr "<guimenu>ملف</guimenu> <guisubmenu>افتح الحديث</guisubmenu>"

#. Tag: para
#: menus.docbook:56
#, no-c-format
msgid ""
"This is a shortcut to open recently saved documents. Clicking on this item "
"opens a list to the side of the menu with several of the most recently saved "
"files. Clicking on a specific file will open it in &kappname; - if the file "
"still resides at the same location."
msgstr ""
"هذا اختصار لفتح المستندات المحفوظة حديثًا. يفتح النقر على هذا العنصر قائمة "
"بجانب القائمة تحتوي على العديد من الملفات المحفوظة مؤخرًا. سيؤدي النقر على "
"ملف معين إلى فتحه في كيت - إذا كان الملف لا يزال موجودًا في الموقع نفسه."

#. Tag: menuchoice
#: menus.docbook:67
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>S</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Save</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>S</keycap></keycombo> </"
"shortcut> <guimenu>ملف</guimenu> <guimenuitem>احفظ</guimenuitem>"

#. Tag: para
#: menus.docbook:75
#, no-c-format
msgid ""
"This saves the current document. If there has already been a save of the "
"document then this will overwrite the previously saved file without asking "
"for the user's consent. If it is the first save of a new document the save "
"as dialog (described below) will be invoked."
msgstr ""
"يحفظ هذا المستند الحالي. إذا سُبق حفظ المستند، فسيؤدي ذلك إلى الكتابة فوق "
"الملف المحفوظ سابقًا دون طلب موافقة المستخدم. إذا كان هذا هو الحفظ الأول "
"لمستند جديد، فسيُستدعى مربع حوار \"احفظ باسم\" (الموضح أدناه)."

#. Tag: menuchoice
#: menus.docbook:85
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>S</keycap></"
"keycombo> </shortcut> <guimenu>File</guimenu> <guimenuitem>Save As...</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>S</keycap></"
"keycombo> </shortcut> <guimenu>ملف</guimenu> <guimenuitem>احفظ باسم...</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:93
#, no-c-format
msgid ""
"This allows a document to be saved with a new file name. This is done by "
"means of the file dialog box described above in the <link linkend=\"file-open"
"\">Open</link> section of this help file."
msgstr ""
"يسمح هذا بحفظ المستند باسم ملف جديد. يُنفذ ذلك عن طريق مربع حوار الملف الموضح "
"أعلاه في قسم <link linkend=\"file-open\">افتح</link> في ملف الدليل هذا."

#. Tag: menuchoice
#: menus.docbook:102
#, no-c-format
msgid ""
"<guimenu>File</guimenu> <guimenuitem>Save As with Encoding</guimenuitem>"
msgstr "<guimenu>ملف</guimenu> <guimenuitem>احفظ باسم مع الترميز</guimenuitem>"

#. Tag: para
#: menus.docbook:107
#, no-c-format
msgid "Save a document with a new file name in a different encoding."
msgstr "يُحفظ المستند باسم ملف جديد وترميز مختلف."

#. Tag: menuchoice
#: menus.docbook:113
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Save Copy As</guimenuitem>"
msgstr "<guimenu>ملف</guimenu> <guimenuitem>احفظ نسخة باسم</guimenuitem>"

#. Tag: para
#: menus.docbook:118
#, no-c-format
msgid ""
"Save a copy of the document with a new file name and continue editing the "
"original document."
msgstr ""
"تُحفظ نسخة من المستند باسم ملف جديد مع الاستمرار في تحرير المستند الأصلي."

#. Tag: menuchoice
#: menus.docbook:124
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"><keycap>F5</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Reload</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"><keycap>F5</keycap></keycombo> </"
"shortcut> <guimenu>ملف</guimenu> <guimenuitem>أعد التحميل</guimenuitem>"

#. Tag: para
#: menus.docbook:132
#, no-c-format
msgid ""
"Reloads the active file from disk. This command is useful if another program "
"or process has changed the file while you have it open in &kappname;."
msgstr ""
"يُعاد تحميل الملف النشط من القرص. يفيد هذا الأمر إذا قام برنامج أو عملية أخرى "
"بتغيير الملف أثناء فتحه في كيت."

#. Tag: menuchoice
#: menus.docbook:140
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>P</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Print...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>P</keycap></keycombo> </"
"shortcut> <guimenu>ملف</guimenu> <guimenuitem>اطبع...</guimenuitem>"

#. Tag: para
#: menus.docbook:148
#, no-c-format
msgid ""
"Opens a simple print dialog allowing the user to specify what, where, and "
"how to print."
msgstr "يفتح مربع حوار طباعة بسيطًا يتيح للمستخدم تحديد ماذا وأين وكيف سيطبع."

#. Tag: menuchoice
#: menus.docbook:158
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Export as HTML</guimenuitem>"
msgstr "<guimenu>ملف</guimenu> <guimenuitem>صدر كـ HTML</guimenuitem>"

#. Tag: para
#: menus.docbook:163
#, no-c-format
msgid ""
"Save the currently open document as an &HTML; file, which will be formatted "
"using the current syntax highlighting and color scheme settings."
msgstr ""
"يُحفظ المستند المفتوح حاليًا كملف HTML، والذي سيُنَسق باستعمال إعدادات تمييز "
"الصيغة ومخطط الألوان الحاليين."

#. Tag: menuchoice
#: menus.docbook:169
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>W</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Close</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>W</keycap></keycombo> </"
"shortcut> <guimenu>ملف</guimenu> <guimenuitem>أغلق</guimenuitem>"

#. Tag: para
#: menus.docbook:177
#, no-c-format
msgid ""
"Close the active file with this command. If you have made unsaved changes, "
"you will be prompted to save the file before &kappname; closes it."
msgstr ""
"يُغلق الملف النشط بهذا الأمر. إذا أجريت تغييرات غير محفوظة، فستُطالب بحفظ "
"الملف قبل أن يغلقه كيت."

#. Tag: menuchoice
#: menus.docbook:185
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>Q</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Quit</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>Q</keycap></keycombo> </"
"shortcut> <guimenu>ملف</guimenu> <guimenuitem>أنهِ</guimenuitem>"

#. Tag: para
#: menus.docbook:193
#, no-c-format
msgid ""
"This will close the editor window, if you have more than one instance of "
"&kappname; running, through the <guimenuitem>New</guimenuitem> or "
"<guimenuitem>New Window</guimenuitem> menu items, those instances will not "
"be closed."
msgstr ""
"سيغلق هذا نافذة المحرر، وإذا كان لديك أكثر من نسخة من كيت تعمل، من خلال "
"عناصر القائمة <guimenuitem>جديد</guimenuitem> أو <guimenuitem>نافذة جديدة</"
"guimenuitem>، فلن تُغلق تلك النسخ."

#. Tag: title
#: menus.docbook:207
#, no-c-format
msgid "The Edit Menu"
msgstr "قائمة حرر"

#. Tag: menuchoice
#: menus.docbook:212
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>Z</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Undo</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>Z</keycap></keycombo> </"
"shortcut> <guimenu>تحرير</guimenu> <guimenuitem>تراجع</guimenuitem>"

#. Tag: para
#: menus.docbook:220
#, no-c-format
msgid "Undo the last editing command (typing, copying, cutting &etc;)"
msgstr "يُتراجع عن أمر التحرير الأخير (كتابة، نسخ، قص، إلخ.)"

#. Tag: para
#: menus.docbook:221
#, no-c-format
msgid ""
"This may undo several editing commands of the same type, like typing in "
"characters."
msgstr "قد يتراجع هذا عن عدة أوامر تحرير من النوع نفسه، مثل كتابة المحارف."

#. Tag: menuchoice
#: menus.docbook:227
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>Z</keycap></"
"keycombo> </shortcut> <guimenu>Edit</guimenu> <guimenuitem>Redo</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>Z</keycap></"
"keycombo> </shortcut> <guimenu>تحرير</guimenu> <guimenuitem>أعد</guimenuitem>"

#. Tag: para
#: menus.docbook:235
#, no-c-format
msgid "This will reverse the most recent change (if any) made using Undo."
msgstr "سيعكس هذا أحدث تغيير (إن وُجد) أجري باستعمال \"تراجع\"."

#. Tag: menuchoice
#: menus.docbook:240
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>X</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Cut</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>X</keycap></keycombo> </"
"shortcut> <guimenu>تحرير</guimenu> <guimenuitem>قص</guimenuitem>"

#. Tag: para
#: menus.docbook:248
#, no-c-format
msgid ""
"This command deletes the current selection and places it on the clipboard. "
"The clipboard works invisibly and provides a way to transfer data between "
"applications."
msgstr ""
"يحذف هذا الأمر التحديد الحالي ويضعه في الحافظة. تعمل الحافظة بشكل غير مرئي "
"وتوفر طريقة لنقل البيانات بين التطبيقات."

#. Tag: menuchoice
#: menus.docbook:255
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>C</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Copy</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>C</keycap></keycombo> </"
"shortcut> <guimenu>تحرير</guimenu> <guimenuitem>انسخ</guimenuitem>"

#. Tag: para
#: menus.docbook:263
#, no-c-format
msgid ""
"This copies the currently selected text to the clipboard so that it may be "
"pasted elsewhere. The clipboard works invisibly and provides a way to "
"transfer data between applications."
msgstr ""
"ينسخ هذا النص المحدد حاليًا إلى الحافظة بحيث يمكن لصقه في مكان آخر. تعمل "
"الحافظة بشكل غير مرئي وتوفر طريقة لنقل البيانات بين التطبيقات."

#. Tag: menuchoice
#: menus.docbook:270
#, no-c-format
msgid "<guimenu>Edit</guimenu> <guimenuitem>Copy as HTML</guimenuitem>"
msgstr "<guimenu>تحرير</guimenu> <guimenuitem>انسخ كـ HTML</guimenuitem>"

#. Tag: para
#: menus.docbook:275
#, no-c-format
msgid ""
"Copy the selection as &HTML;, formatted using the current syntax "
"highlighting and color scheme settings."
msgstr ""
"يُنسخ التحديد كـ HTML، منسقًا باستعمال إعدادات تمييز الصيغة ومخطط الألوان "
"الحاليين."

#. Tag: menuchoice
#: menus.docbook:281
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>V</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Paste</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>V</keycap></keycombo> </"
"shortcut> <guimenu>تحرير</guimenu> <guimenuitem>الصق</guimenuitem>"

#. Tag: para
#: menus.docbook:289
#, no-c-format
msgid ""
"This will insert the first item in the clipboard at the cursor position. The "
"clipboard works invisibly and provides a way to transfer data between "
"applications."
msgstr ""
"سيدرج هذا العنصر الأول في الحافظة عند موضع المؤشر. تعمل الحافظة بشكل غير "
"مرئي وتوفر طريقة لنقل البيانات بين التطبيقات."

#. Tag: para
#: menus.docbook:292
#, no-c-format
msgid ""
"If Overwrite Selection is enabled, the pasted text will overwrite the "
"selection, if any."
msgstr ""
"إذا فُعلت ميزة \"الكتابة فوق التحديد\"، فسيقوم النص الملصق بالكتابة فوق "
"التحديد، إن وجد."

#. Tag: menuchoice
#: menus.docbook:297
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;&Ins;</keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Paste Selection</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;&Ins;</keycombo> </"
"shortcut> <guimenu>تحرير</guimenu> <guimenuitem>الصق التحديد</guimenuitem>"

#. Tag: para
#: menus.docbook:305
#, no-c-format
msgid ""
"This will paste the <ulink url=\"https://en.wikipedia.org/wiki/"
"Clipboard_(computing)#X_Window_System\">mouse selection</ulink> contents "
"that were chosen previously. Mark some text with the mouse pointer to paste "
"it in the currently open file using this menu item."
msgstr ""
"سيلصق هذا محتويات <ulink url=\"https://en.wikipedia.org/wiki/"
"Clipboard_(computing)#X_Window_System\">تحديد الفأرة</ulink> التي اختيرت "
"سابقًا. ظلل بعض النص بمؤشر الفأرة لصقه في الملف المفتوح حاليًا باستعمال عنصر "
"القائمة هذا."

#. Tag: menuchoice
#: menus.docbook:310
#, no-c-format
msgid ""
"<guimenu>Edit</guimenu> <guimenuitem>Swap with clipboard contents</"
"guimenuitem>"
msgstr ""
"<guimenu>تحرير</guimenu> <guimenuitem>بادل مع محتويات الحافظة</guimenuitem>"

#. Tag: para
#: menus.docbook:315
#, no-c-format
msgid ""
"This will swap the selected text with the <ulink url=\"https://en.wikipedia."
"org/wiki/Clipboard_(computing)#X_Window_System\">clipboard</ulink> contents."
msgstr ""
"يؤدي هذا إلى مبادلة النص المحدد مع محتويات <ulink url=\"https://en.wikipedia."
"org/wiki/Clipboard_(computing)#X_Window_System\">الحافظة</ulink>."

#. Tag: menuchoice
#: menus.docbook:320
#, no-c-format
msgid ""
"<guimenu>Edit</guimenu> <guimenuitem>Clipboard History Paste</guimenuitem>"
msgstr ""
"<guimenu>تحرير</guimenu> <guimenuitem>لصق من تأريخ الحافظة</guimenuitem>"

#. Tag: para
#: menus.docbook:325
#, no-c-format
msgid ""
"This will open a dialog to select and paste an entry from the clipboard "
"history."
msgstr "سيؤدي هذا إلى فتح حوار لاختيار مدخلة من تأريخ الحافظة ولصقها."

#. Tag: menuchoice
#: menus.docbook:330
#, no-c-format
msgid "<guimenu>Edit</guimenu> <guimenuitem>Input Modes</guimenuitem>"
msgstr "<guimenu>تحرير</guimenu> <guimenuitem>أوضاع الإدخال</guimenuitem>"

#. Tag: para
#: menus.docbook:335
#, no-c-format
msgid ""
"Switch between a normal and a vi-like, modal editing mode. The vi input mode "
"supports the most used commands and motions from vim's normal and visual "
"mode and has an optional vi mode statusbar. This status bar shows commands "
"while they are being entered, output from commands and the current mode. The "
"behavior of this mode can be configured in the <link linkend=\"pref-edit-vi-"
"input-mode\">Vi Input Mode</link> tab of the <guilabel>Editing</guilabel> "
"page in &kappname;'s settings dialog."
msgstr ""
"بدّل بين وضع التحرير العادي ووضع يشبه vi. يدعم وضع إدخال vi الأوامر والحركات "
"الأكثر استخدامًا من وضعي vim العادي والمرئي، ويحتوي على شريط حالة اختياري "
"لوضع vi. يعرض شريط الحالة هذا الأوامر أثناء إدخالها، ومخرجات الأوامر والوضع "
"الحالي. يمكن ضبط سلوك هذا الوضع في تبويب <link linkend=\"pref-edit-vi-input-"
"mode\">وضع إدخال Vi</link> في صفحة <guilabel>التحرير</guilabel> في حوار "
"إعدادات كايت."

#. Tag: menuchoice
#: menus.docbook:345
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ins;</keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Overwrite Mode</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ins;</keycombo> </shortcut> "
"<guimenu>تحرير</guimenu> <guimenuitem>وضع الكتابة الفوقية</guimenuitem>"

#. Tag: para
#: menus.docbook:353
#, no-c-format
msgid ""
"Toggles the Insert/Overwrite modes. When the mode is <guilabel>INS</"
"guilabel>, you insert characters where the cursor is. When the mode is "
"<guilabel>OVR</guilabel>, writing characters will replace the current "
"characters if your cursor is positioned before any character. The status bar "
"shows the current state of the Overwrite Mode, either <guilabel>INS</"
"guilabel> or <guilabel>OVR</guilabel>."
msgstr ""
"يبدل بين وضعي الإدراج والكتابة الفوقية. عندما يكون الوضع <guilabel>INS</"
"guilabel>، ستُدرج المحارف مكان المؤشر. وعندما يكون الوضع <guilabel>OVR</"
"guilabel>، فإن كتابة المحارف ستستبدل المحارف الحالية إذا كان المؤشر موضوعًا "
"قبل أي محرف. يعرض شريط الحالة الحالة الحالية لوضع الكتابة الفوقية، إما "
"<guilabel>INS</guilabel> أو <guilabel>OVR</guilabel>."

#. Tag: menuchoice
#: menus.docbook:362
#, no-c-format
msgid "<guimenu>Edit</guimenu> <guimenuitem>Read Only Mode</guimenuitem>"
msgstr "<guimenu>تحرير</guimenu> <guimenuitem>وضع القراءة فقط</guimenuitem>"

#. Tag: para
#: menus.docbook:367
#, no-c-format
msgid ""
"Set the current document to Read Only mode. This prevents any text addition "
"and any changes in the document formatting."
msgstr ""
"اجعل المستند الحالي في وضع القراءة فقط. يمنع هذا أي إضافة نصية وأي تغييرات "
"في تنسيق المستند."

#. Tag: menuchoice
#: menus.docbook:373
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>F</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Find...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>F</keycap></keycombo> </"
"shortcut> <guimenu>تحرير</guimenu> <guimenuitem>بحث...</guimenuitem>"

#. Tag: para
#: menus.docbook:381
#, no-c-format
msgid ""
"This opens the incremental search bar at the bottom of the editor window. On "
"the left side of the bar is a button with an icon to close the bar, followed "
"by a small text box for entering the search pattern."
msgstr ""
"يؤدي هذا إلى فتح شريط البحث التزايدي في الجزء السفلي من نافذة المحرر. يوجد "
"على الجانب الأيسر من الشريط زر به أيقونة لإغلاق الشريط، يليه مربع نص صغير "
"لإدخال نمط البحث."

#. Tag: para
#: menus.docbook:384
#, no-c-format
msgid ""
"When you start entering characters of your search pattern, the search starts "
"immediately. If there is a match in the text this is highlighted and the "
"background color of the entry field changes to light green. If the search "
"pattern does not match any string in the text, this is indicated by a light "
"red background color of the entry field."
msgstr ""
"عندما تبدأ في إدخال محارف نمط البحث، يبدأ البحث فورًا. إذا كان هناك تطابق في "
"النص، فسيُبرز ويتغير لون خلفية حقل الإدخال إلى الأخضر الفاتح. إذا لم يطابق "
"نمط البحث أي سلسلة نصية في النص، فيُشار إلى ذلك بلون خلفية أحمر فاتح لحقل "
"الإدخال."

#. Tag: para
#: menus.docbook:388 menus.docbook:488
#, no-c-format
msgid ""
"Use the <inlinemediaobject><imageobject><imagedata fileref=\"arrow-up-"
"double-22.png\" format=\"PNG\"/></imageobject></inlinemediaobject> or "
"<inlinemediaobject><imageobject><imagedata fileref=\"arrow-down-double-22.png"
"\" format=\"PNG\"/></imageobject></inlinemediaobject> button to jump to the "
"next or previous match in the document."
msgstr ""
"استخدم الزر <inlinemediaobject><imageobject><imagedata fileref=\"arrow-up-"
"double-22.png\" format=\"PNG\"/></imageobject></inlinemediaobject> أو "
"<inlinemediaobject><imageobject><imagedata fileref=\"arrow-down-double-22.png"
"\" format=\"PNG\"/></imageobject></inlinemediaobject> للانتقال إلى التطابق "
"التالي أو السابق في المستند."

#. Tag: para
#: menus.docbook:392
#, no-c-format
msgid ""
"Matches in the document are highlighted even when you close the search bar. "
"To clear this highlighting, press the &Esc; key."
msgstr ""
"تُبرز التطابقات في المستند حتى عند إغلاق شريط البحث. لمسح هذا الإبراز، اضغط "
"على مفتاح &Esc;."

#. Tag: para
#: menus.docbook:394
#, no-c-format
msgid ""
"You can choose whether the search should be case sensitive. Selecting "
"<inlinemediaobject><imageobject><imagedata fileref=\"format-text-"
"superscript-22.png\" format=\"PNG\"/></imageobject></inlinemediaobject> will "
"limit finds to entries that match the case (upper or lower) of each of the "
"characters in the search pattern."
msgstr ""
"يمكنك اختيار ما إذا كان البحث يجب أن يكون حساسًا لحالة الأحرف. سيؤدي اختيار "
"<inlinemediaobject><imageobject><imagedata fileref=\"format-text-"
"superscript-22.png\" format=\"PNG\"/></imageobject></inlinemediaobject> إلى "
"قصر النتائج على المدخلات التي تطابق حالة (كبيرة أو صغيرة) كل محرف في نمط "
"البحث."

#. Tag: para
#: menus.docbook:399
#, no-c-format
msgid ""
"Click on the <inlinemediaobject><imageobject><imagedata fileref=\"configure-"
"shortcuts-22.png\" format=\"PNG\"/></imageobject></inlinemediaobject> button "
"at the right side of the incremental search bar to switch to the power "
"search and replace bar."
msgstr ""
"انقر على زر <inlinemediaobject><imageobject><imagedata fileref=\"configure-"
"shortcuts-22.png\" format=\"PNG\"/></imageobject></inlinemediaobject> على "
"الجانب الأيمن من شريط البحث التزايدي للتبديل إلى شريط البحث والاستبدال "
"المتقدم."

#. Tag: menuchoice
#: menus.docbook:407
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"><keycap>F3</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guisubmenu>Find Variants</guisubmenu> "
"<guimenuitem>Find Next</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"><keycap>F3</keycap></keycombo> </"
"shortcut> <guimenu>تحرير</guimenu> <guisubmenu>تنويعات البحث</guisubmenu> "
"<guimenuitem>ابحث عن التالي</guimenuitem>"

#. Tag: para
#: menus.docbook:416
#, no-c-format
msgid ""
"This repeats the last find operation, if any, without calling the "
"incremental search bar, and searching forwards through the document starting "
"from the cursor position."
msgstr ""
"يؤدي هذا إلى تكرار عملية البحث الأخيرة، إن وجدت، دون استدعاء شريط البحث "
"التزايدي، والبحث للأمام عبر المستند بدءًا من موضع المؤشر."

#. Tag: menuchoice
#: menus.docbook:423
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Shift;<keycap>F3</keycap></keycombo> "
"</shortcut> <guimenu>Edit</guimenu> <guisubmenu>Find Variants</guisubmenu> "
"<guimenuitem>Find Previous</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Shift;<keycap>F3</keycap></keycombo> "
"</shortcut> <guimenu>تحرير</guimenu> <guisubmenu>تنويعات البحث</guisubmenu> "
"<guimenuitem>ابحث عن السابق</guimenuitem>"

#. Tag: para
#: menus.docbook:432
#, no-c-format
msgid ""
"This repeats the last find operation, if any, without calling the "
"incremental search bar, and searching backwards instead of forwards through "
"the document."
msgstr ""
"يؤدي هذا إلى تكرار عملية البحث الأخيرة، إن وجدت، دون استدعاء شريط البحث "
"التزايدي، والبحث للخلف بدلاً من الأمام عبر المستند."

#. Tag: menuchoice
#: menus.docbook:441
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>H</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guisubmenu>Find Variants</guisubmenu> "
"<guimenuitem>Find Selected</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>H</keycap></keycombo> </"
"shortcut> <guimenu>تحرير</guimenu> <guisubmenu>تنويعات البحث</guisubmenu> "
"<guimenuitem>ابحث عن المحدد</guimenuitem>"

#. Tag: para
#: menus.docbook:450
#, no-c-format
msgid "Finds next occurrence of selected text."
msgstr "يبحث عن التطابق التالي للنص المحدد."

#. Tag: menuchoice
#: menus.docbook:455
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>H</keycap></"
"keycombo> </shortcut> <guimenu>Edit</guimenu> <guisubmenu>Find Variants</"
"guisubmenu> <guimenuitem>Find Selected Backwards</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>H</keycap></"
"keycombo> </shortcut> <guimenu>تحرير</guimenu> <guisubmenu>تنويعات البحث</"
"guisubmenu> <guimenuitem>ابحث عن المحدد للخلف</guimenuitem>"

#. Tag: para
#: menus.docbook:464
#, no-c-format
msgid "Finds previous occurrence of selected text."
msgstr "يبحث عن التطابق السابق للنص المحدد."

#. Tag: menuchoice
#: menus.docbook:469
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>R</keycap></keycombo> </"
"shortcut> <guimenu>Edit</guimenu> <guimenuitem>Replace...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>R</keycap></keycombo> </"
"shortcut> <guimenu>تحرير</guimenu> <guimenuitem>استبدل...</guimenuitem>"

#. Tag: para
#: menus.docbook:477
#, no-c-format
msgid ""
"This command opens the power search and replace bar. On the upper left side "
"of the bar is a button with an icon to close the bar, followed by a small "
"text box for entering the search pattern."
msgstr ""
"يفتح هذا الأمر شريط البحث والاستبدال المتقدم. يوجد في الجانب العلوي الأيسر "
"من الشريط زر به أيقونة لإغلاق الشريط، يليه مربع نص صغير لإدخال نمط البحث."

#. Tag: para
#: menus.docbook:480
#, no-c-format
msgid ""
"You can control the search mode by selecting <guilabel>Plain text</"
"guilabel>, <guilabel>Whole words</guilabel>, <guilabel>Escape sequences</"
"guilabel> or <guilabel>Regular expression</guilabel> from the drop down box."
msgstr ""
"يمكنك التحكم في وضع البحث باختيار <guilabel>نص مجرد</guilabel>، أو "
"<guilabel>كلمات كاملة</guilabel>، أو <guilabel>تتابعات الهروب</guilabel> أو "
"<guilabel>تعبير نمطي</guilabel> من المربع المنسدل."

#. Tag: para
#: menus.docbook:484
#, no-c-format
msgid ""
"If <guilabel>Escape sequences</guilabel> or <guilabel>Regular expression</"
"guilabel> are selected, the <guibutton>Add...</guibutton> menuitem at the "
"bottom of the context menu of the text boxes will be enabled and allows you "
"to add escape sequences or regular expression items to the search or replace "
"pattern from predefined lists."
msgstr ""
"إذا اختير <guilabel>تتابعات الهروب</guilabel> أو <guilabel>تعبير نمطي</"
"guilabel>، فسيُفعل عنصر القائمة <guibutton>أضف...</guibutton> في أسفل القائمة "
"السياقية لمربعات النص، مما يسمح لك بإضافة تتابعات هروب أو عناصر تعبير نمطي "
"إلى نمط البحث أو الاستبدال من قوائم محددة مسبقًا."

#. Tag: para
#: menus.docbook:492
#, no-c-format
msgid ""
"Enter the text to replace with in the text box labeled <guilabel>Replace</"
"guilabel> and click the <guibutton>Replace</guibutton> button to replace "
"only the highlighted text or the <guibutton>Replace All</guibutton> button "
"to replace the search text in the whole document."
msgstr ""
"أدخل النص المراد الاستبدال به في مربع النص المسمى <guilabel>استبدل</"
"guilabel> وانقر فوق زر <guibutton>استبدل</guibutton> لاستبدال النص المبرز "
"فقط أو زر <guibutton>استبدل الكل</guibutton> لاستبدال نص البحث في المستند "
"بأكمله."

#. Tag: para
#: menus.docbook:496
#, no-c-format
msgid ""
"You can modify the search and replace behavior by selecting different "
"options at the bottom of the bar. Selecting "
"<inlinemediaobject><imageobject><imagedata fileref=\"format-text-"
"superscript-22.png\" format=\"PNG\"/></imageobject></inlinemediaobject> will "
"limit finds to entries that match the case (upper or lower) of each of the "
"characters in the search pattern. <inlinemediaobject><imageobject><imagedata "
"fileref=\"edit-select-all-22.png\" format=\"PNG\"/></imageobject></"
"inlinemediaobject> will search and replace within the current selection "
"only. The <guilabel>Find All</guilabel> button highlights all matches in the "
"document and shows the number of found matches in a small popup."
msgstr ""
"يمكنك تعديل سلوك البحث والاستبدال باختيار خيارات مختلفة في أسفل الشريط. "
"سيؤدي اختيار <inlinemediaobject><imageobject><imagedata fileref=\"format-"
"text-superscript-22.png\" format=\"PNG\"/></imageobject></inlinemediaobject> "
"إلى قصر النتائج على المدخلات التي تطابق حالة الأحرف في نمط البحث. سيؤدي "
"<inlinemediaobject><imageobject><imagedata fileref=\"edit-select-all-22.png"
"\" format=\"PNG\"/></imageobject></inlinemediaobject> إلى البحث والاستبدال "
"داخل التحديد الحالي فقط. يبرز زر <guilabel>ابحث عن الكل</guilabel> جميع "
"التطابقات في المستند ويعرض عدد التطابقات الموجودة في منبثقة صغيرة."

#. Tag: para
#: menus.docbook:506
#, no-c-format
msgid ""
"Click on the <inlinemediaobject><imageobject><imagedata fileref=\"configure-"
"shortcuts-22.png\" format=\"PNG\"/></imageobject></inlinemediaobject> button "
"at the right side of the power search and replace bar to switch to the "
"incremental search bar."
msgstr ""
"انقر على زر <inlinemediaobject><imageobject><imagedata fileref=\"configure-"
"shortcuts-22.png\" format=\"PNG\"/></imageobject></inlinemediaobject> على "
"الجانب الأيمن من شريط البحث والاستبدال المتقدم للتبديل إلى شريط البحث "
"التزايدي."

#. Tag: title
#: menus.docbook:519
#, no-c-format
msgid "The Selection Menu"
msgstr "قائمة التحديد"

#. Tag: menuchoice
#: menus.docbook:523
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>A</keycap></keycombo> </"
"shortcut> <guimenu>Selection</guimenu> <guimenuitem>Select All</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>A</keycap></keycombo> </"
"shortcut> <guimenu>التحديد</guimenu> <guimenuitem>حدد الكل</guimenuitem>"

#. Tag: para
#: menus.docbook:531
#, no-c-format
msgid ""
"This will select the entire document. This could be very useful for copying "
"the entire file to another application."
msgstr ""
"سيؤدي هذا إلى تحديد المستند بأكمله. قد يكون هذا مفيدًا جدًا لنسخ الملف بأكمله "
"إلى تطبيق آخر."

#. Tag: menuchoice
#: menus.docbook:537
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>A</keycap></"
"keycombo> </shortcut> <guimenu>Selection</guimenu> <guimenuitem>Deselect</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>A</keycap></"
"keycombo> </shortcut> <guimenu>التحديد</guimenu> <guimenuitem>ألغِ التحديد</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:545
#, no-c-format
msgid "Deselects the selected text in the editor if any."
msgstr "يُلغى تحديد النص المحدد في المحرر إن وُجد."

#. Tag: menuchoice
#: menus.docbook:550
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>B</keycap></"
"keycombo> </shortcut> <guimenu>Selection</guimenu> <guimenuitem>Block "
"Selection Mode</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>B</keycap></"
"keycombo> </shortcut> <guimenu>التحديد</guimenu> <guimenuitem>وضع تحديد "
"الكتل</guimenuitem>"

#. Tag: para
#: menus.docbook:558
#, no-c-format
msgid ""
"Toggles Selection Mode. When the Selection Mode is <guilabel>BLOCK</"
"guilabel>, the status bar contains the string <guilabel>[BLOCK]</guilabel> "
"and you can make vertical selections, &eg; select column 5 to 10 in lines 9 "
"to 15."
msgstr ""
"يبدل وضع التحديد. عندما يكون وضع التحديد هو <guilabel>BLOCK</guilabel>، "
"يحتوي شريط الحالة على السلسلة <guilabel>[BLOCK]</guilabel> ويمكنك إجراء "
"تحديدات عمودية، مثل تحديد الأعمدة من 5 إلى 10 في السطور من 9 إلى 15."

#. Tag: menuchoice
#: menus.docbook:596
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>D</keycap></keycombo> </"
"shortcut> <guimenu>Selection</guimenu> <guimenuitem>Comment</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>D</keycap></keycombo> </"
"shortcut> <guimenu>التحديد</guimenu> <guimenuitem>علق</guimenuitem>"

#. Tag: para
#: menus.docbook:603
#, no-c-format
msgid ""
"This adds one space to the beginning of the line where the text cursor is "
"located or to the beginning of any selected lines."
msgstr ""
"يضيف هذا مسافة واحدة إلى بداية السطر حيث يوجد مؤشر النص أو إلى بداية أي سطور "
"محددة."

#. Tag: menuchoice
#: menus.docbook:610
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>D</keycap></"
"keycombo> </shortcut> <guimenu>Selection</guimenu> <guimenuitem>Uncomment</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>D</keycap></"
"keycombo> </shortcut> <guimenu>التحديد</guimenu> <guimenuitem>ألغِ التعليق</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:617
#, no-c-format
msgid ""
"This removes one space (if any exist) from the beginning of the line where "
"the text cursor is located or from the beginning of any selected lines."
msgstr ""
"يزيل هذا مسافة واحدة (إن وجدت) من بداية السطر حيث يوجد مؤشر النص أو من بداية "
"أي سطور محددة."

#. Tag: menuchoice
#: menus.docbook:623
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>J</keycap></keycombo> </"
"shortcut> <guimenu>Selection</guimenu> <guimenuitem>Join Lines</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>J</keycap></keycombo> </"
"shortcut> <guimenu>التحديد</guimenu> <guimenuitem>اضمم السطور</guimenuitem>"

#. Tag: para
#: menus.docbook:630
#, no-c-format
msgid ""
"Joins the selected lines, or the current line and the line below with one "
"white space character as a separator. Leading/trailing white space on joined "
"lines is removed in the affected ends."
msgstr ""
"يضم السطور المحددة، أو السطر الحالي والسطر الذي أسفله مع محرف مسافة بيضاء "
"واحد كفاصل. تُزال المسافات البيضاء البادئة/اللاحقة في السطور المضمومة في "
"الأطراف المتأثرة."

#. Tag: menuchoice
#: menus.docbook:636
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Alt;<keycap>U</keycap></"
"keycombo> </shortcut> <guimenu>Selection</guimenu> "
"<guimenuitem>Capitalization</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Alt;<keycap>U</keycap></"
"keycombo> </shortcut> <guimenu>التحديد</guimenu> <guimenuitem>حالة الأحرف</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:643
#, no-c-format
msgid "Capitalize the selected text or the current word."
msgstr "يُحول النص المحدد أو الكلمة الحالية إلى أحرف كبيرة استهلالية."

#. Tag: menuchoice
#: menus.docbook:648
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>U</keycap></keycombo> </"
"shortcut> <guimenu>Selection</guimenu> <guimenuitem>Uppercase</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>U</keycap></keycombo> </"
"shortcut> <guimenu>التحديد</guimenu> <guimenuitem>أحرف كبيرة</guimenuitem>"

#. Tag: para
#: menus.docbook:655
#, no-c-format
msgid "Put the selected text or the letter after the cursor in uppercase."
msgstr "يُحول النص المحدد أو الحرف الذي بعد المؤشر إلى أحرف كبيرة."

#. Tag: menuchoice
#: menus.docbook:660
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>U</keycap></"
"keycombo> </shortcut> <guimenu>Selection</guimenu> <guimenuitem>Lowercase</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>U</keycap></"
"keycombo> </shortcut> <guimenu>التحديد</guimenu> <guimenuitem>أحرف صغيرة</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:667
#, no-c-format
msgid "Put the selected text or the letter after the cursor in lowercase."
msgstr "يُحول النص المحدد أو الحرف الذي بعد المؤشر إلى أحرف صغيرة."

#. Tag: menuchoice
#: menus.docbook:672
#, no-c-format
msgid ""
"<guimenu>Selection</guimenu> <guimenuitem>Clean Indentation</guimenuitem>"
msgstr "<guimenu>التحديد</guimenu> <guimenuitem>نظف الإزاحة</guimenuitem>"

#. Tag: para
#: menus.docbook:677
#, no-c-format
msgid ""
"This cleans the indentation for the current selection or for the line the "
"cursor is currently in. Cleaning the indentation ensures that all your "
"selected text follows the indentation mode you choose."
msgstr ""
"ينظف هذا الإزاحة للتحديد الحالي أو للسطر الذي يوجد فيه المؤشر حاليًا. يضمن "
"تنظيف الإزاحة أن جميع النصوص المحددة تتبع وضع الإزاحة الذي تختاره."

#. Tag: menuchoice
#: menus.docbook:684
#, no-c-format
msgid "<guimenu>Selection</guimenu> <guimenuitem>Format Indent</guimenuitem>"
msgstr "<guimenu>تحديد</guimenu> <guimenuitem>نسق الإزاحة</guimenuitem>"

#. Tag: para
#: menus.docbook:689
#, no-c-format
msgid ""
"Causes a realign of the current line or selected lines using the indentation "
"mode and indentation settings in the document."
msgstr ""
"يسبب إعادة محاذاة للسطر الحالي أو السطور المحددة باستخدام وضع الإزاحة "
"وإعدادات الإزاحة في المستند."

#. Tag: menuchoice
#: menus.docbook:695
#, no-c-format
msgid "<guimenu>Selection</guimenu> <guimenuitem>Align On...</guimenuitem>"
msgstr "<guimenu>تحديد</guimenu> <guimenuitem>حاذِ بناءً على...</guimenuitem>"

#. Tag: para
#: menus.docbook:700
#, no-c-format
msgid ""
"This command aligns lines in the selected block or whole document on the "
"column given by a regular expression that you will be prompted for."
msgstr ""
"يحاذي هذا الأمر السطور في الكتلة المحددة أو المستند بأكمله بناءً على العمود "
"المعطى بواسطة تعبير نمطي سيُطلب منك إدخاله."

#. Tag: para
#: menus.docbook:701
#, no-c-format
msgid ""
"If you give an empty pattern it will align on the first non-blank character "
"by default."
msgstr "إذا أعطيت نمطًا فارغًا، فسيحاذي على أول محرف غير فارغ مبدئيًا."

#. Tag: para
#: menus.docbook:702
#, no-c-format
msgid "If the pattern has a capture it will indent on the captured match."
msgstr "إذا كان النمط يحتوي على التقاط، فسوف يزيح بناءً على التطابق الملتقط."

#. Tag: emphasis
#: menus.docbook:703
#, no-c-format
msgid "Examples:"
msgstr "أمثلة:"

#. Tag: para
#: menus.docbook:704
#, no-c-format
msgid ""
"With '<userinput>-</userinput>' it will insert spaces before the first '-' "
"of each lines to align them all on the same column."
msgstr ""
"باستخدام '<userinput>-</userinput>'، سيُدرج مسافات قبل أول '-' في كل سطر "
"لمحاذاتها جميعًا على نفس العمود."

#. Tag: para
#: menus.docbook:705
#, no-c-format
msgid ""
"With '<userinput>alignon :\\\\s+(.)</userinput>' it will insert spaces "
"before the first non-blank character that occurs after a colon to align them "
"all on the same column."
msgstr ""
"باستخدام '<userinput>alignon :\\\\s+(.)</userinput>'، سيُدرج مسافات قبل أول "
"محرف غير فارغ يظهر بعد النقطتين لمحاذاتها جميعًا على نفس العمود."

#. Tag: menuchoice
#: menus.docbook:710
#, no-c-format
msgid "<guimenu>Selection</guimenu> <guimenuitem>Apply Word Wrap</guimenuitem>"
msgstr "<guimenu>تحديد</guimenu> <guimenuitem>طبق لف الكلمات</guimenuitem>"

#. Tag: para
#: menus.docbook:714
#, no-c-format
msgid ""
"Apply static word wrapping on all the document. That means that a new line "
"of text will automatically start when the current line exceeds the length "
"specified by the <guilabel>Wrap words at</guilabel> option in the Editing "
"tab in <menuchoice> <guimenu>Settings</guimenu><guimenuitem>Configure "
"Editor...</guimenuitem></menuchoice> menu."
msgstr ""
"طبق لف الكلمات الساكن على كل المستند. هذا يعني أن سطرًا جديدًا من النص سيبدأ "
"آليًا عندما يتجاوز السطر الحالي الطول المحدد بخيار <guilabel>لف الكلمات عند</"
"guilabel> في تبويب التحرير في قائمة <menuchoice> <guimenu>إعدادات</"
"guimenu><guimenuitem>اضبط المحرر...</guimenuitem></menuchoice>."

#. Tag: menuchoice
#: menus.docbook:723
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Alt;&Up;</keycombo> </shortcut> "
"<guimenu>Selection</guimenu> <guimenuitem>Add Caret above Cursor</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Alt;&Up;</keycombo> </shortcut> "
"<guimenu>التحديد</guimenu> <guimenuitem>أضف مؤشرًا فوق المؤشر الحالي</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:730
#, no-c-format
msgid ""
"Adds another caret above the current cursor. The caret is placed in the line "
"directly above and in the same column as the current cursor."
msgstr ""
"يضيف علامة إقحام أخرى فوق المؤشر الحالي. توضع علامة الإقحام في السطر الموجود "
"فوقه مباشرة وفي نفس عمود المؤشر الحالي."

#. Tag: menuchoice
#: menus.docbook:735
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Alt;&Down;</keycombo> </"
"shortcut> <guimenu>Selection</guimenu> <guimenuitem>Add Caret below Cursor</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Alt;&Down;</keycombo> </"
"shortcut> <guimenu>التحديد</guimenu> <guimenuitem>أضف مؤشرًا أسفل المؤشر "
"الحالي</guimenuitem>"

#. Tag: para
#: menus.docbook:742
#, no-c-format
msgid ""
"Adds another caret below the current cursor. The caret is placed in the line "
"directly above and in the same column as the current cursor."
msgstr ""
"يضيف علامة إقحام أخرى أسفل المؤشر الحالي. توضع علامة الإقحام في السطر "
"الموجود أسفله مباشرة وفي نفس عمود المؤشر الحالي."

#. Tag: menuchoice
#: menus.docbook:747
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift;<keycap>I</keycap></"
"keycombo> </shortcut> <guimenu>Selection</guimenu> <guimenuitem>Add Cursors "
"to Line Ends</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift;<keycap>I</keycap></"
"keycombo> </shortcut> <guimenu>التحديد</guimenu> <guimenuitem>أضف مؤشرات إلى "
"نهايات السطور</guimenuitem>"

#. Tag: para
#: menus.docbook:754
#, no-c-format
msgid "Adds a cursor to every currently selected line."
msgstr "يضاف مؤشر إلى كل سطر محدد حاليًا."

#. Tag: menuchoice
#: menus.docbook:759
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt;<keycap>J</keycap></keycombo> </"
"shortcut> <guimenu>Selection</guimenu> <guimenuitem>Find and Select Next "
"Occurrence</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt;<keycap>J</keycap></keycombo> </"
"shortcut> <guimenu>التحديد</guimenu> <guimenuitem>ابحث عن التكرار التالي "
"وحدده</guimenuitem>"

#. Tag: para
#: menus.docbook:766
#, no-c-format
msgid ""
"Finds the next occurrence of the word currently under the cursor, selects it "
"and adds a cursor."
msgstr ""
"يبحث عن التكرار التالي للكلمة الموجودة حاليًا تحت المؤشر، ويحددها ويضيف مؤشرًا."

#. Tag: menuchoice
#: menus.docbook:771
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Alt;&Shift;<keycap>J</keycap></"
"keycombo> </shortcut> <guimenu>Selection</guimenu> <guimenuitem>Find and "
"Select All Occurrences</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Alt;&Shift;<keycap>J</keycap></"
"keycombo> </shortcut> <guimenu>التحديد</guimenu> <guimenuitem>ابحث عن جميع "
"التكرارات وحددها</guimenuitem>"

#. Tag: para
#: menus.docbook:778
#, no-c-format
msgid ""
"Finds all occurrences of the word currently under the cursor, selects them "
"and adds a cursor for each of them."
msgstr ""
"يبحث عن جميع تكرارات الكلمه الموجودة حاليًا تحت المؤشر، ويحددها ويضيف مؤشرًا "
"لكل منها."

#. Tag: title
#: menus.docbook:788
#, no-c-format
msgid "The View Menu"
msgstr "قائمة عرض"

#. Tag: menuchoice
#: menus.docbook:793
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>+</keycap></keycombo> </"
"shortcut> <guimenu>View</guimenu> <guimenuitem>Enlarge Font</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>+</keycap></keycombo> </"
"shortcut> <guimenu>عرض</guimenu> <guimenuitem>كبر الخط</guimenuitem>"

#. Tag: para
#: menus.docbook:800
#, no-c-format
msgid "This increases the display font size."
msgstr "يزيد هذا حجم خط العرض."

#. Tag: menuchoice
#: menus.docbook:804
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>-</keycap></keycombo> </"
"shortcut> <guimenu>View</guimenu> <guimenuitem>Shrink Font</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>-</keycap></keycombo> </"
"shortcut> <guimenu>عرض</guimenu> <guimenuitem>صغر الخط</guimenuitem>"

#. Tag: para
#: menus.docbook:811
#, no-c-format
msgid "This decreases the display font size."
msgstr "يقلل هذا حجم خط العرض."

#. Tag: menuchoice
#: menus.docbook:815
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"><keycap>F10</keycap></keycombo> </"
"shortcut> <guimenu>View</guimenu> <guisubmenu>Word Wrap</guisubmenu> "
"<guimenuitem>Dynamic Word Wrap</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"><keycap>F10</keycap></keycombo> </"
"shortcut> <guimenu>عرض</guimenu> <guisubmenu>لف الكلمات</guisubmenu> "
"<guimenuitem>لف كلمات ديناميكي</guimenuitem>"

#. Tag: para
#: menus.docbook:823
#, no-c-format
msgid ""
"Toggles dynamic word wrap in the current view. Dynamic word wrap makes all "
"the text in a view visible without the need for horizontal scrolling by "
"rendering one actual line on more visual lines as needed."
msgstr ""
"يبدل لف الكلمات الديناميكي في العرض الحالي. يجعل لف الكلمات الديناميكي كل "
"النص في العرض مرئيًا دون الحاجة إلى التمرير الأفقي عبر تصيير سطر حقيقي واحد "
"على عدة سطور مرئية حسب الحاجة."

#. Tag: menuchoice
#: menus.docbook:830
#, no-c-format
msgid ""
"<guimenu>View</guimenu> <guisubmenu>Word Wrap</guisubmenu> "
"<guisubmenu>Dynamic Word Wrap Indicators</guisubmenu>"
msgstr ""
"<guimenu>عرض</guimenu> <guisubmenu>لف الكلمات</guisubmenu> "
"<guisubmenu>مؤشرات لف الكلمات الديناميكي</guisubmenu>"

#. Tag: para
#: menus.docbook:836
#, no-c-format
msgid ""
"Choose when and how the dynamic word wrap indicators should be displayed. "
"This is only available if the <guilabel>Dynamic Word Wrap</guilabel> option "
"is checked."
msgstr ""
"اختر متى وكيف يجب عرض مؤشرات لف الكلمات الديناميكي. يتوفر هذا فقط إذا كان "
"خيار <guilabel>لف كلمات ديناميكي</guilabel> مفعلًا."

#. Tag: menuchoice
#: menus.docbook:843
#, no-c-format
msgid ""
"<guimenu>View</guimenu> <guisubmenu>Word Wrap</guisubmenu> <guimenuitem>Show "
"Static Word Wrap Marker</guimenuitem>"
msgstr ""
"<guimenu>عرض</guimenu> <guisubmenu>لف الكلمات</guisubmenu> <guimenuitem>أظهر "
"علامة لف الكلمات الساكن</guimenuitem>"

#. Tag: para
#: menus.docbook:849
#, no-c-format
msgid ""
"If this option is checked, a vertical line will be drawn at the word wrap "
"column as defined in the <menuchoice> <guimenu>Settings</guimenu> "
"<guimenuitem>Configure Editor...</guimenuitem></menuchoice> in the Editing "
"tab. Please note that the word wrap marker is only drawn if you use a fixed "
"pitch font."
msgstr ""
"إذا فعل هذا الخيار، فسيُرسم خط عمودي عند عمود لف الكلمات كما هو محدد في "
"<menuchoice> <guimenu>إعدادات</guimenu> <guimenuitem>اضبط المحرر...</"
"guimenuitem></menuchoice> في تبويب التحرير. يرجى ملاحظة أن علامة لف الكلمات "
"تُرسم فقط إذا كنت تستخدم خطًا ثابت العرض."

#. Tag: menuchoice
#: menus.docbook:859
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"><keycap>F6</keycap></keycombo> </"
"shortcut> <guimenu>View</guimenu> <guisubmenu>Borders</guisubmenu> "
"<guimenuitem>Show Icon Border</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"><keycap>F6</keycap></keycombo> </"
"shortcut> <guimenu>عرض</guimenu> <guisubmenu>الحدود</guisubmenu> "
"<guimenuitem>أظهر حد الأيقونات</guimenuitem>"

#. Tag: para
#: menus.docbook:868
#, no-c-format
msgid ""
"This is a toggle item. Setting it on checked will make the Icon Border "
"visible in the left side of the active editor, and vice versa. The Icon "
"Border indicates the positions of the marked lines in the editor."
msgstr ""
"هذا عنصر تبديل. تفعيله سيجعل حد الأيقونات مرئيًا في الجانب الأيسر من المحرر "
"النشط، والعكس صحيح. يشير حد الأيقونات إلى مواقع السطور المعلمة في المحرر."

#. Tag: menuchoice
#: menus.docbook:875
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\"><keycap>F11</keycap></keycombo> </"
"shortcut> <guimenu>View</guimenu> <guisubmenu>Borders</guisubmenu> "
"<guimenuitem>Show Line Numbers</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\"><keycap>F11</keycap></keycombo> </"
"shortcut> <guimenu>عرض</guimenu> <guisubmenu>الحدود</guisubmenu> "
"<guimenuitem>أظهر أرقام السطور</guimenuitem>"

#. Tag: para
#: menus.docbook:884
#, no-c-format
msgid ""
"This is a toggle Item. Setting it on checked will make a pane displaying the "
"line numbers of the document visible in the left border of the active "
"editor, and vice versa."
msgstr ""
"هذا عنصر تبديل. تفعيله سيجعل لوحة تعرض أرقام سطور المستند مرئية في الحد "
"الأيسر للمحرر النشط، والعكس صحيح."

#. Tag: menuchoice
#: menus.docbook:891
#, no-c-format
msgid ""
"<guimenu>View</guimenu> <guisubmenu>Borders</guisubmenu> <guimenuitem>Show "
"Scrollbar Marks</guimenuitem>"
msgstr ""
"<guimenu>عرض</guimenu> <guisubmenu>الحدود</guisubmenu> <guimenuitem>أظهر "
"علامات شريط التمرير</guimenuitem>"

#. Tag: para
#: menus.docbook:897
#, no-c-format
msgid ""
"If this option is checked, the view will show marks on the vertical "
"scrollbar. The marks are equivalent to the marks on the <link linkend=\"view-"
"show-icon-border\">Icon Border</link>."
msgstr ""
"إذا فعل هذا الخيار، فسيعرض العرض علامات على شريط التمرير العمودي. العلامات "
"تعادل العلامات الموجودة على <link linkend=\"view-show-icon-border\">حد "
"الأيقونات</link>."

#. Tag: menuchoice
#: menus.docbook:904
#, no-c-format
msgid ""
"<guimenu>View</guimenu> <guisubmenu>Borders</guisubmenu> <guimenuitem>Show "
"Scrollbar Mini-Map</guimenuitem>"
msgstr ""
"<guimenu>عرض</guimenu> <guisubmenu>الحدود</guisubmenu> <guimenuitem>أظهر "
"الخريطة المصغرة لشريط التمرير</guimenuitem>"

#. Tag: para
#: menus.docbook:909
#, no-c-format
msgid ""
"This will replace the scrollbar with a visualization of the current "
"document. For more information on the scrollbar minimap, see <xref linkend="
"\"kate-part-scrollbar-minimap\"/>."
msgstr ""
"سيستبدل هذا شريط التمرير بتصور مرئي للمستند الحالي. لمزيد من المعلومات حول "
"الخريطة المصغرة لشريط التمرير، راجع <xref linkend=\"kate-part-scrollbar-"
"minimap\"/>."

#. Tag: menuchoice
#: menus.docbook:915
#, no-c-format
msgid "<guimenu>View</guimenu> <guimenuitem>Code Folding</guimenuitem>"
msgstr "<guimenu>عرض</guimenu> <guimenuitem>طي الكود</guimenuitem>"

#. Tag: para
#: menus.docbook:919
#, no-c-format
msgid ""
"These options pertain to <ulink url=\"help:/katepart/advanced-editing-tools-"
"code-folding.html\">code folding</ulink>:"
msgstr ""
"تتعلق هذه الخيارات بـ <ulink url=\"help:/katepart/advanced-editing-tools-"
"code-folding.html\">طي الكود</ulink>:"

#. Tag: menuchoice
#: menus.docbook:925
#, no-c-format
msgid ""
"<guimenu>View</guimenu> <guisubmenu>Borders</guisubmenu> <guisubmenu>Code "
"Folding</guisubmenu> <guimenuitem>Show Folding Markers</guimenuitem>"
msgstr ""
"<guimenu>عرض</guimenu> <guisubmenu>الحدود</guisubmenu> <guisubmenu>طي الكود</"
"guisubmenu> <guimenuitem>أظهر علامات الطي</guimenuitem>"

#. Tag: para
#: menus.docbook:931
#, no-c-format
msgid ""
"Toggles the display of the folding marker pane in the left side of the view."
msgstr "يبدل عرض لوحة علامات الطي في الجانب الأيسر من العرض."

#. Tag: menuchoice
#: menus.docbook:936
#, no-c-format
msgid ""
"<guimenu>View</guimenu> <guisubmenu>Code Folding</guisubmenu> "
"<guimenuitem>Fold Current Node</guimenuitem>"
msgstr ""
"<guimenu>عرض</guimenu> <guisubmenu>طي الكود</guisubmenu> <guimenuitem>اطوِ "
"العقدة الحالية</guimenuitem>"

#. Tag: para
#: menus.docbook:941
#, no-c-format
msgid "Collapse the region that contains the cursor."
msgstr "اطوِ المنطقة التي تحتوي على المؤشر."

#. Tag: menuchoice
#: menus.docbook:945
#, no-c-format
msgid ""
"<guimenu>View</guimenu> <guisubmenu>Code Folding</guisubmenu> "
"<guimenuitem>Unfold Current Node</guimenuitem>"
msgstr ""
"<guimenu>عرض</guimenu> <guisubmenu>طي الكود</guisubmenu> <guimenuitem>افرد "
"العقدة الحالية</guimenuitem>"

#. Tag: para
#: menus.docbook:950
#, no-c-format
msgid "Expand the region that contains the cursor."
msgstr "افرد المنطقة التي تحتوي على المؤشر."

#. Tag: menuchoice
#: menus.docbook:954
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>-</keycap></"
"keycombo> </shortcut> <guimenu>View</guimenu> <guisubmenu>Code Folding</"
"guisubmenu> <guimenuitem>Fold Toplevel Nodes</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>-</keycap></"
"keycombo> </shortcut> <guimenu>عرض</guimenu> <guisubmenu>طي الكود</"
"guisubmenu> <guimenuitem>اطوِ العقد العلوية</guimenuitem>"

#. Tag: para
#: menus.docbook:962
#, no-c-format
msgid ""
"Collapse all toplevel regions in the document. Click on the right pointing "
"triangle to expand all toplevel regions."
msgstr ""
"اطوِ جميع المناطق ذات المستوى الأعلى في المستند. انقر على المثلث المتجه "
"لليمين لفرد جميع المناطق ذات المستوى الأعلى."

#. Tag: menuchoice
#: menus.docbook:967
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>+</keycap></"
"keycombo> </shortcut> <guimenu>View</guimenu> <guisubmenu>Code Folding</"
"guisubmenu> <guimenuitem>Unfold Toplevel Nodes</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>+</keycap></"
"keycombo> </shortcut> <guimenu>عرض</guimenu> <guisubmenu>طي الكود</"
"guisubmenu> <guimenuitem>افرد العقد العلوية</guimenuitem>"

#. Tag: para
#: menus.docbook:975
#, no-c-format
msgid "Expand all toplevel regions in the document."
msgstr "افرد جميع المناطق ذات المستوى الأعلى في المستند."

#. Tag: guimenuitem
#: menus.docbook:984
#, no-c-format
msgid "Show Non-Printable Spaces"
msgstr "أظهر المسافات غير المطبوعة"

#. Tag: para
#: menus.docbook:986
#, no-c-format
msgid "Show/hide bounding box around non-printable spaces."
msgstr "أظهر/أخفِ مربع الإحاطة حول المسافات غير المطبوعة."

#. Tag: title
#: menus.docbook:995
#, no-c-format
msgid "The Go Menu"
msgstr "قائمة انتقل"

#. Tag: menuchoice
#: menus.docbook:999
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>G</keycap></keycombo> </"
"shortcut> <guimenu>Go</guimenu> <guimenuitem>Go to Line...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>G</keycap></keycombo> </"
"shortcut> <guimenu>انتقل</guimenu> <guimenuitem>اذهب إلى السطر...</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:1007
#, no-c-format
msgid ""
"This opens the goto line bar at the bottom of the window which is used to "
"have the cursor jump to a particular line (specified by number) in the "
"document. The line number may be entered directly into the text box or "
"graphically by clicking on the up or down arrow spin controls at the side of "
"the text box. The little up arrow will increase the line number and the down "
"arrow decrease it. Close the bar with a click on the button with an icon on "
"the left side of the bar."
msgstr ""
"يفتح هذا شريط الانتقال إلى السطر في أسفل النافذة والذي يستخدم لجعل المؤشر "
"يقفز إلى سطر معين (محدد برقم) في المستند. يمكن إدخال رقم السطر مباشرة في "
"مربع النص أو رسوميًا بالنقر فوق ضوابط السهمين لأعلى أو لأسفل بجانب مربع النص. "
"سيزيد السهم الصغير للأعلى رقم السطر وسيقلله السهم للأسفل. أغلق الشريط بنقرة "
"على الزر الذي يحمل أيقونة على الجانب الأيسر من الشريط."

#. Tag: menuchoice
#: menus.docbook:1019
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>E</keycap></keycombo> </"
"shortcut> <guimenu>Go</guimenu> <guimenuitem>Go to Previous Editing Line</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>E</keycap></keycombo> </"
"shortcut> <guimenu>اذهب</guimenu> <guimenuitem>اذهب إلى سطر التحرير السابق</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:1027
#, no-c-format
msgid ""
"This action jumps the previous editing line in the <link linkend="
"\"multicursor-modifier-configure\">multicursor configuration</link>."
msgstr ""
"يقفز هذا الإجراء إلى سطر التحرير السابق في <link linkend=\"multicursor-"
"modifier-configure\">تشكيلة المؤشرات المتعددة</link>."

#. Tag: menuchoice
#: menus.docbook:1033
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>E</keycap></"
"keycombo> </shortcut> <guimenu>Go</guimenu> <guimenuitem>Go to Next Editing "
"Line</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>E</keycap></"
"keycombo> </shortcut> <guimenu>اذهب</guimenu> <guimenuitem>اذهب إلى سطر "
"التحرير التالي</guimenuitem>"

#. Tag: para
#: menus.docbook:1041
#, no-c-format
msgid ""
"This action jumps the next editing line in the <link linkend=\"multicursor-"
"modifier-configure\">multicursor configuration</link>."
msgstr ""
"يقفز هذا الإجراء إلى سطر التحرير التالي في <link linkend=\"multicursor-"
"modifier-configure\">تشكيلة المؤشرات المتعددة</link>."

#. Tag: menuchoice
#: menus.docbook:1047
#, no-c-format
msgid ""
"<guimenu>Go</guimenu> <guimenuitem>Go to Previous Modified Line</guimenuitem>"
msgstr ""
"<guimenu>اذهب</guimenu> <guimenuitem>اذهب إلى السطر المعدل السابق</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:1052
#, no-c-format
msgid ""
"Lines that were changed since opening the file are called modified lines. "
"This action jumps the previous modified line."
msgstr ""
"السطور التي تغيرت منذ فتح الملف تسمى سطورًا معدلة. يقفز هذا الإجراء إلى السطر "
"المعدل السابق."

#. Tag: menuchoice
#: menus.docbook:1058
#, no-c-format
msgid ""
"<guimenu>Go</guimenu> <guimenuitem>Go to Next Modified Line</guimenuitem>"
msgstr ""
"<guimenu>اذهب</guimenu> <guimenuitem>اذهب إلى السطر المعدل التالي</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:1063
#, no-c-format
msgid ""
"Lines that were changed since opening the file are called modified lines. "
"This action jumps the next modified line."
msgstr ""
"السطور التي تغيرت منذ فتح الملف تسمى سطورًا معدلة. يقفز هذا الإجراء إلى السطر "
"المعدل التالي."

#. Tag: menuchoice
#: menus.docbook:1069
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>6</keycap></keycombo> </"
"shortcut> <guimenu>Go</guimenu> <guimenuitem>Go to Matching Bracket</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>6</keycap></keycombo> </"
"shortcut> <guimenu>اذهب</guimenu> <guimenuitem>اذهب إلى القوس المطابق</"
"guimenuitem>"

#. Tag: para
#: menus.docbook:1077
#, no-c-format
msgid "Move the cursor to the associated opening or closing bracket."
msgstr "حرك المؤشر إلى قوس الفتح أو الإغلاق المرتبط."

#. Tag: menuchoice
#: menus.docbook:1082
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>6</keycap></"
"keycombo> </shortcut> <guimenu>Go</guimenu> <guimenuitem>Select to Matching "
"Bracket</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>6</keycap></"
"keycombo> </shortcut> <guimenu>اذهب</guimenu> <guimenuitem>حدد حتى القوس "
"المطابق</guimenuitem>"

#. Tag: para
#: menus.docbook:1090
#, no-c-format
msgid "Selects the text between associated opening and closing brackets."
msgstr "يحدد النص بين قوسي الفتح والإغلاق المرتبطين."

#. Tag: menuchoice
#: menus.docbook:1095
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>6</keycap></"
"keycombo> </shortcut> <guimenu>Go</guimenu> <guisubmenu>Bookmarks</"
"guisubmenu>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>6</keycap></"
"keycombo> </shortcut> <guimenu>اذهب</guimenu> <guisubmenu>العلامات المرجعية</"
"guisubmenu>"

#. Tag: para
#: menus.docbook:1103
#, no-c-format
msgid ""
"Below the entries described here, one entry for each bookmark in the active "
"document will be available. The text will be the first few words of the "
"marked line. Choose an item to move the cursor to the start of that line. "
"The editor will scroll as necessary to make that line visible."
msgstr ""
"أسفل المدخلات الموصوفة هنا، ستتوفر مدخلة واحدة لكل علامة مرجعية في المستند "
"النشط. سيكون النص هو الكلمات القليلة الأولى من السطر المعلم. اختر عنصرًا "
"لتحريك المؤشر إلى بداية ذلك السطر. سيقوم المحرر بالتمرير حسب الضرورة لجعل "
"هذا السطر مرئيًا."

#. Tag: menuchoice
#: menus.docbook:1112
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>B</keycap></keycombo> </"
"shortcut> <guimenu>Go</guimenu> <guisubmenu>Bookmarks</guisubmenu> "
"<guimenuitem>Set Bookmark</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>B</keycap></keycombo> </"
"shortcut> <guimenu>اذهب</guimenu> <guisubmenu>العلامات المرجعية</guisubmenu> "
"<guimenuitem>عيّن علامة مرجعية</guimenuitem>"

#. Tag: para
#: menus.docbook:1121
#, no-c-format
msgid ""
"Sets or removes a bookmark in the current line of the active document. (If "
"it's there, it is removed, otherwise one is set.)"
msgstr ""
"يضبط أو يزيل علامة مرجعية في السطر الحالي من المستند النشط. (إذا كانت "
"موجودة، تُزال، وإلا فستُضبط واحدة)."

#. Tag: menuchoice
#: menus.docbook:1127
#, no-c-format
msgid ""
"<guimenu>Go</guimenu> <guisubmenu>Bookmarks</guisubmenu> <guimenuitem>Clear "
"All Bookmarks</guimenuitem>"
msgstr ""
"<guimenu>اذهب</guimenu> <guisubmenu>العلامات المرجعية</guisubmenu> "
"<guimenuitem>امسح جميع العلامات المرجعية</guimenuitem>"

#. Tag: para
#: menus.docbook:1133
#, no-c-format
msgid ""
"This command will remove all the markers from the document as well as the "
"list of markers which is appended at the bottom of this menu item."
msgstr ""
"سيزيل هذا الأمر جميع العلامات من المستند بالإضافة إلى قائمة العلامات الملحقة "
"في أسفل عنصر القائمة هذا."

#. Tag: menuchoice
#: menus.docbook:1141
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt;&PgUp;</keycombo> </shortcut> "
"<guimenu>Go</guimenu> <guisubmenu>Bookmarks</guisubmenu> "
"<guimenuitem>Previous</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt;&PgUp;</keycombo> </shortcut> "
"<guimenu>اذهب</guimenu> <guisubmenu>العلامات المرجعية</guisubmenu> "
"<guimenuitem>السابق</guimenuitem>"

#. Tag: para
#: menus.docbook:1149
#, no-c-format
msgid ""
"This will move the cursor to beginning of the first above line with a "
"bookmark. The menuitem text will include the line number and the first piece "
"of text on the line. This item is only available when there is a bookmark in "
"a line above the cursor."
msgstr ""
"سيؤدي هذا إلى تحريك المؤشر إلى بداية أول سطر أعلاه يحتوي على علامة مرجعية. "
"سيتضمن نص عنصر القائمة رقم السطر وأول قطعة نصية في السطر. يتوفر هذا العنصر "
"فقط عندما تكون هناك علامة مرجعية في سطر فوق المؤشر."

#. Tag: menuchoice
#: menus.docbook:1156
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt;&PgDn;</keycombo> </shortcut> "
"<guimenu>Go</guimenu> <guisubmenu>Bookmarks</guisubmenu> <guimenuitem>Next</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt;&PgDn;</keycombo> </shortcut> "
"<guimenu>اذهب</guimenu> <guisubmenu>العلامات المرجعية</guisubmenu> "
"<guimenuitem>التالي</guimenuitem>"

#. Tag: para
#: menus.docbook:1164
#, no-c-format
msgid ""
"This will move the cursor to beginning of the next line with a bookmark. The "
"menuitem text will include the line number and the first piece of text on "
"the line. This item is only available when there is a bookmark in a line "
"below the cursor."
msgstr ""
"سيؤدي هذا إلى تحريك المؤشر إلى بداية السطر التالي الذي يحتوي على علامة "
"مرجعية. سيتضمن نص عنصر القائمة رقم السطر وأول قطعة نصية في السطر. يتوفر هذا "
"العنصر فقط عندما تكون هناك علامة مرجعية في سطر أسفل المؤشر."

#. Tag: title
#: menus.docbook:1176
#, no-c-format
msgid "The Tools Menu"
msgstr "قائمة أدوات"

#. Tag: menuchoice
#: menus.docbook:1181
#, no-c-format
msgid "<guimenu>Tools</guimenu> <guisubmenu>Mode</guisubmenu>"
msgstr "<guimenu>أدوات</guimenu> <guisubmenu>الوضع</guisubmenu>"

#. Tag: para
#: menus.docbook:1186
#, no-c-format
msgid ""
"Choose the filetype scheme you prefer for the active document. This "
"overwrites the global filetype mode set in <menuchoice> <guimenu>Settings</"
"guimenu><guimenuitem>Configure Editor...</guimenuitem></menuchoice> in the "
"Filetypes tab for your current document only."
msgstr ""
"اختر مخطط نوع الملف الذي تفضله للمستند النشط. يتجاوز هذا وضع نوع الملف العام "
"المحدد في <menuchoice> <guimenu>إعدادات</guimenu><guimenuitem>اضبط المحرر..."
"</guimenuitem></menuchoice> في تبويب أنواع الملفات لمستندك الحالي فقط."

#. Tag: menuchoice
#: menus.docbook:1194
#, no-c-format
msgid "<guimenu>Tools</guimenu> <guisubmenu>Highlighting</guisubmenu>"
msgstr "<guimenu>أدوات</guimenu> <guisubmenu>الإبراز</guisubmenu>"

#. Tag: para
#: menus.docbook:1199
#, no-c-format
msgid ""
"Choose the Highlighting scheme you prefer for the active document. This "
"overwrites the global highlighting mode set in <menuchoice> "
"<guimenu>Settings</guimenu><guimenuitem>Configure Editor...</guimenuitem> </"
"menuchoice> for your current document only."
msgstr ""
"اختر مخطط الإبراز الذي تفضله للمستند النشط. يتجاوز هذا وضع الإبراز العام "
"المحدد في <menuchoice> <guimenu>إعدادات</guimenu><guimenuitem>اضبط المحرر..."
"</guimenuitem> </menuchoice> لمستندك الحالي فقط."

#. Tag: menuchoice
#: menus.docbook:1207
#, no-c-format
msgid "<guimenu>Tools</guimenu> <guisubmenu>Indentation</guisubmenu>"
msgstr "<guimenu>أدوات</guimenu> <guisubmenu>الإزاحة</guisubmenu>"

#. Tag: para
#: menus.docbook:1212
#, no-c-format
msgid ""
"Choose the style of indentation you want for your active document. This "
"overwrites the global indentation mode set in <menuchoice> "
"<guimenu>Settings</guimenu><guimenuitem>Configure Editor...</guimenuitem> </"
"menuchoice> for your current document only."
msgstr ""
"اختر نمط الإزاحة الذي تريده لمستندك النشط. يتجاوز هذا وضع الإزاحة العام "
"المحدد في <menuchoice> <guimenu>إعدادات</guimenu><guimenuitem>اضبط المحرر..."
"</guimenuitem> </menuchoice> لمستندك الحالي فقط."

#. Tag: menuchoice
#: menus.docbook:1220
#, no-c-format
msgid "<guimenu>Tools</guimenu> <guisubmenu>Encoding</guisubmenu>"
msgstr "<guimenu>أدوات</guimenu> <guisubmenu>الترميز</guisubmenu>"

#. Tag: para
#: menus.docbook:1225
#, no-c-format
msgid ""
"You can overwrite the default encoding set in <menuchoice> "
"<guimenu>Settings</guimenu><guimenuitem>Configure Editor...</guimenuitem> </"
"menuchoice> in the <guilabel>Open/Save</guilabel> page to set a different "
"encoding for your current document. The encoding you set here will be only "
"valid for your current document."
msgstr ""
"يمكنك تجاوز الترميز المبدئي المحدد في <menuchoice> <guimenu>إعدادات</"
"guimenu><guimenuitem>اضبط المحرر...</guimenuitem> </menuchoice> في صفحة "
"<guilabel>فتح/حفظ</guilabel> لتعيين ترميز مختلف لمستندك الحالي. سيكون "
"الترميز الذي تعينه هنا صالحًا لمستندك الحالي فقط."

#. Tag: menuchoice
#: menus.docbook:1234
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu> <guisubmenu>Add Byte Mark Order (BOM)</guisubmenu>"
msgstr ""
"<guimenu>أدوات</guimenu> <guisubmenu>أضف علامة ترتيب البايتات (BOM)</"
"guisubmenu>"

#. Tag: para
#: menus.docbook:1239
#, no-c-format
msgid ""
"Checking this action you can explicitly add a byte order mark for unicode "
"encoded documents. The byte order mark (BOM) is a Unicode character used to "
"signal the endianness (byte order) of a text file or stream, for more "
"information see <ulink url=\"https://en.wikipedia.org/wiki/Byte_order_mark"
"\">Byte Order Mark</ulink>."
msgstr ""
"بتفعيل هذا الإجراء، يمكنك صراحة إضافة علامة ترتيب البايتات للمستندات المرمزة "
"بيونيكود. علامة ترتيب البايتات (BOM) هي محرف يونيكود يستخدم للإشارة إلى "
"ترتيب البايتات لملف نصي أو دفق، لمزيد من المعلومات راجع <ulink url=\"https://"
"en.wikipedia.org/wiki/Byte_order_mark\">علامة ترتيب البايتات</ulink>."

#. Tag: menuchoice
#: menus.docbook:1247
#, no-c-format
msgid "<guimenu>Tools</guimenu> <guisubmenu>End of Line</guisubmenu>"
msgstr "<guimenu>أدوات</guimenu> <guisubmenu>نهاية السطر</guisubmenu>"

#. Tag: para
#: menus.docbook:1252
#, no-c-format
msgid ""
"Choose your preferred end of line mode for your active document. This "
"overwrites the global end of line mode set in <menuchoice> "
"<guimenu>Settings</guimenu><guimenuitem>Configure Editor...</guimenuitem> </"
"menuchoice> for your current document only."
msgstr ""
"اختر وضع نهاية السطر المفضل لمستندك النشط. يتجاوز هذا وضع نهاية السطر العام "
"المحدد في <menuchoice> <guimenu>إعدادات</guimenu><guimenuitem>اضبط المحرر..."
"</guimenuitem> </menuchoice> لمستندك الحالي فقط."

#. Tag: menuchoice
#: menus.docbook:1260
#, no-c-format
msgid "<guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu>"
msgstr "<guimenu>أدوات</guimenu> <guisubmenu>السكربتات</guisubmenu>"

#. Tag: para
#: menus.docbook:1265
#, no-c-format
msgid ""
"This submenu contains a list of all scripted actions. The list can easily be "
"modified by <link linkend=\"dev-scripting-command-line\">writing your own "
"scripts</link>. This way, &katepart; can be extended with user-defined tools."
msgstr ""
"تحتوي هذه القائمة الفرعية على قائمة بجميع الإجراءات البرمجية. يمكن تعديل "
"القائمة بسهولة عن طريق <link linkend=\"dev-scripting-command-line\">كتابة "
"سكربتاتك الخاصة</link>. بهذه الطريقة، يمكن توسيع مكون محرر كايت بأدوات "
"يحددها المستخدم."

#. Tag: menuchoice
#: menus.docbook:1273
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu> "
"<guisubmenu>Navigation</guisubmenu>"
msgstr ""
"<guimenu>أدوات</guimenu> <guisubmenu>السكربتات</guisubmenu> "
"<guisubmenu>التنقل</guisubmenu>"

#. Tag: menuchoice
#: menus.docbook:1281
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift;&Up;</keycombo> </"
"shortcut> <guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu> "
"<guisubmenu>Navigation</guisubmenu> <guimenuitem>Move cursor to previous "
"matching indent</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift;&Up;</keycombo> </"
"shortcut> <guimenu>أدوات</guimenu> <guisubmenu>السكربتات</guisubmenu> "
"<guisubmenu>التنقل</guisubmenu> <guimenuitem>حرك المؤشر إلى الإزاحة المطابقة "
"السابقة</guimenuitem>"

#. Tag: para
#: menus.docbook:1290
#, no-c-format
msgid ""
"Moves the cursor to the first line above the current line that is indented "
"at the same level as the current line."
msgstr ""
"يحرك المؤشر إلى أول سطر فوق السطر الحالي والمزاح بنفس مستوى السطر الحالي."

#. Tag: menuchoice
#: menus.docbook:1297
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift;&Down;</keycombo> </"
"shortcut> <guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu> "
"<guisubmenu>Navigation</guisubmenu> <guimenuitem>Move cursor to next "
"matching indent</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Alt;&Shift;&Down;</keycombo> </"
"shortcut> <guimenu>أدوات</guimenu> <guisubmenu>السكربتات</guisubmenu> "
"<guisubmenu>التنقل</guisubmenu> <guimenuitem>حرك المؤشر إلى الإزاحة المطابقة "
"التالية</guimenuitem>"

#. Tag: para
#: menus.docbook:1306
#, no-c-format
msgid ""
"Moves the cursor to the first line below the current line that is indented "
"at the same level as the current line."
msgstr ""
"يحرك المؤشر إلى أول سطر أسفل السطر الحالي والمزاح بنفس مستوى السطر الحالي."

#. Tag: menuchoice
#: menus.docbook:1322
