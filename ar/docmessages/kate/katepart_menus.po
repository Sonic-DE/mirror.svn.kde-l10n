"<guisubmenu>التحرير</guisubmenu>"

#. Tag: menuchoice
#: menus.docbook:1330
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu> <guisubmenu>Scripts</guisubmenu> "
"<guisubmenu>Editing</guisubmenu> <guimenuitem>Sort Selected Text</"
"guimenuitem>"
msgstr ""
"<guimenu>أدوات</guimenu> <guisubmenu>السكربتات</guisubmenu> "
"<guisubmenu>التحرير</guisubmenu> <guimenuitem>فرز النص المحدد</guimenuitem>"

#. Tag: para
#: menus.docbook:1336
#, no-c-format
msgid "Sorts the selected text or whole document in ascending order."
msgstr "فرز النص المحدد أو المستند بأكمله ترتيبًا تصاعديًا."

