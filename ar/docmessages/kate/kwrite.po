#. Tag: para
#: index.docbook:33
#, no-c-format
msgid ""
"&kwrite; is a text editor by &kde; allowing you to edit one file at the time "
"per window."
msgstr ""
"كاتبك هو محرر نصوص من كيدي يتيح لك تحرير ملف واحد في المرة الواحدة لكل نافذة."

#. Tag: keyword
#: index.docbook:37
#, no-c-format
msgid "<keyword>KDE</keyword>"
msgstr "<keyword>كيدي</keyword>"

#. Tag: keyword
#: index.docbook:38
#, no-c-format
msgid "KWrite"
msgstr "كاتبك"

#. Tag: keyword
#: index.docbook:39
#, no-c-format
msgid "text"
msgstr "نص"

#. Tag: keyword
#: index.docbook:40
#, no-c-format
msgid "editor"
