msgstr ""
"<link linkend=\"kate-application-plugin-xmltools\">إكمال XML</link> - يسرد "
"عناصر XML والسمات وقيم السمات والكيانات المسموح بها بواسطة DTD"

#. Tag: para
#: plugins.docbook:121
#, no-c-format
msgid ""
"<link linkend=\"kate-application-plugin-xmlcheck\">&XML; Validation</link>- "
"Validates &XML; files using xmllint"
msgstr ""
"<link linkend=\"kate-application-plugin-xmlcheck\">تحقق XML</link> - يتحقق "
"من صحة ملفات XML باستخدام xmllint"

#. Tag: para
#: plugins.docbook:124
#, no-c-format
msgid ""
"<link linkend=\"kate-application-plugin-compilerexplorer\">Compiler "
