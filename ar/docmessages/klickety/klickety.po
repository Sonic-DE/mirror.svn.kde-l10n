msgstr "<phrase>خيارات الخلفية</phrase>"

#. Tag: title
#: index.docbook:498
#, no-c-format
msgid "Custom Game options"
msgstr "خيارات اللعبة المخصصة"

#. Tag: para
#: index.docbook:499
#, no-c-format
msgid ""
"You can set the <guilabel>Height:</guilabel> and <guilabel>Width:</guilabel> "
"of the board and the <guilabel>Color count:</guilabel> used in your custom "
"level."
msgstr ""
"يمكنك ضبط <guilabel>الارتفاع:</guilabel> و <guilabel>العرض:</guilabel> للوحة "
"و <guilabel>عدد الألوان:</guilabel> المستخدمة في مستواك المخصص."

