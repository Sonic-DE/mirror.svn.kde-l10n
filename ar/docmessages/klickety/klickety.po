msgstr "محدد <guilabel>السمة</guilabel>"

#. Tag: para
#: index.docbook:457
#, no-c-format
msgid ""
"Use the <guilabel>Theme</guilabel> selector to set a theme for the game."
msgstr "استخدم محدد <guilabel>السمة</guilabel> لضبط سمة للعبة."

