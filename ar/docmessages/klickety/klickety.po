#, no-c-format
msgid "<title>Background options</title>"
msgstr "<title>خيارات الخلفية</title>"

#. Tag: para
#: index.docbook:471
#, no-c-format
msgid ""
"You can choose a background graphic for the game. There are three kinds of "
"background type you can use."
msgstr ""
"يمكنك اختيار رسم خلفية للعبة. هناك ثلاثة أنواع من أنواع الخلفيات التي يمكنك "
"استخدامها."

#. Tag: guilabel
#: index.docbook:475
#, no-c-format
msgid "Theme"
msgstr "السمة"

#. Tag: para
#: index.docbook:476
#, no-c-format
msgid "Use the background shipped with the current theme."
msgstr "استخدم الخلفية المرفقة مع السمة الحالية."

#. Tag: guilabel
#: index.docbook:479
#, no-c-format
msgid "Color"
msgstr "اللون"

#. Tag: para
#: index.docbook:480
#, no-c-format
msgid "Use a custom solid color for the background."
msgstr "استخدم لونا صلبا مخصصا للخلفية."

#. Tag: guilabel
#: index.docbook:483
#, no-c-format
msgid "Image"
msgstr "صورة"

#. Tag: para
#: index.docbook:484
#, no-c-format
msgid "Use an image for the background graphic."
msgstr "استخدم صورة لرسم الخلفية."

#. Tag: screeninfo
#: index.docbook:489
#, no-c-format
