msgid "The Kamoso Handbook"
msgstr "كتيّب كاموسو"

#. Tag: personname
#: index.docbook:12
#, no-c-format
msgid ""
"<firstname>This documentation was converted from the KDE UserBase <ulink url="
"\"http://userbase.kde.org/Kamoso\">Kamoso</ulink> page and updated by the "
"&kde; documentation team.</firstname> <surname></surname>"
msgstr ""
"<firstname>حُوِّل هذا التوثيق من صفحة <ulink url=\"http://userbase.kde.org/"
"Kamoso\">كاموسو</ulink> في قاعدة بيانات مستخدمي كيدي وحُدّث بواسطة فريق توثيق "
"كيدي.</firstname> <surname></surname>"

