"<replaceable> directory</replaceable></group> <group choice=\"opt"
"\"><option>--generate</option></group> <group choice=\"opt"
"\"><option><replaceable>file</replaceable></option></group>"
msgstr ""
"<command>kpat</command> <group choice=\"opt\"><option>--solvegame</option> "
"<replaceable> ملف</replaceable></group> <group choice=\"opt\"><option>--"
"solve</option> <replaceable> رقم</replaceable></group> <group choice=\"opt"
"\"><option>--start</option> <replaceable> رقم</replaceable></group> <group "
"choice=\"opt\"><option>--end</option> <replaceable> رقم</replaceable></"
"group> <group choice=\"opt\"><option>--gametype</option> <replaceable> لعبة</"
"replaceable></group> <group choice=\"opt\"><option>--testdir</option> "
