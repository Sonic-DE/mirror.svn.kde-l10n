msgstr "يعرض معلومات الرخصة"

#. Tag: term
#: man-kpat.6.docbook:128
#, no-c-format
msgid "<option>--desktopfile</option> <replaceable>file name</replaceable>"
msgstr "<option>--desktopfile</option> <replaceable>اسم الملف</replaceable>"

#. Tag: para
#: man-kpat.6.docbook:129
#, no-c-format
msgid "The base file name of the desktop entry for this application."
msgstr "اسم الملف الأساسي لمدخل سطح المكتب لهذا التطبيق."

#. Tag: replaceable
#: man-kpat.6.docbook:133
#, no-c-format
msgid "file"
msgstr "ملف"

#. Tag: para
#: man-kpat.6.docbook:135
#, no-c-format
msgid "File to load"
msgstr "الملف المراد تحميله"

