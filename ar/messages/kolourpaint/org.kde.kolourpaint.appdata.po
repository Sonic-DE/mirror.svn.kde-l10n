#. (itstool) path: component/name
#: org.kde.kolourpaint.appdata.xml:10
msgid "KolourPaint"
msgstr "الرسام"

#. (itstool) path: component/summary
#: org.kde.kolourpaint.appdata.xml:11
msgid "Paint Program"
msgstr "برنامج تلوين"

#. (itstool) path: description/p
#: org.kde.kolourpaint.appdata.xml:13
msgid ""
"KolourPaint is a simple painting program to quickly create raster images. It "
"is useful as a touch-up tool and for simple image editing tasks."
msgstr ""
"الرسام هو برنامج رسم بسيط لإنشاء صور نقطية بسرعة. إنه مفيد كأداة تحسين ومهام "
"بسيطة لتحرير الصور."

#. (itstool) path: description/p
#: org.kde.kolourpaint.appdata.xml:17
msgid "Features:"
msgstr "الميزات:"

#. (itstool) path: ul/li
#: org.kde.kolourpaint.appdata.xml:19
msgid ""
"Support for drawing various shapes - lines, rectangles, rounded rectangles, "
"ovals and polygons"
msgstr ""
"يوفّر رسم أشكال مختلفة - خطوط ومستطيلات ومستطيلات مستديرة الشكل وأشكال "
"بيضاوية ومضلعات"

#. (itstool) path: ul/li
#: org.kde.kolourpaint.appdata.xml:20
msgid "Curves, lines and text"
msgstr "المنحنيات والخطوط والنص"

#. (itstool) path: ul/li
#: org.kde.kolourpaint.appdata.xml:21
msgid "Color picker"
msgstr "منتق الألوان"

#. (itstool) path: ul/li
#: org.kde.kolourpaint.appdata.xml:22
