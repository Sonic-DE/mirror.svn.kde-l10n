#. (itstool) path: component/name
#: org.kde.okular.kirigami.appdata.xml:6
msgid "Okular Mobile"
msgstr "اوكلار محمول"

#. (itstool) path: component/summary
#: org.kde.okular.kirigami.appdata.xml:7
msgid "Document Viewer"
msgstr "عارض المستندات"

#. (itstool) path: description/p
#: org.kde.okular.kirigami.appdata.xml:13
msgid ""
"Okular is a universal document viewer developed by KDE. Okular works on "
"multiple platforms, including but not limited to Linux, Windows, Mac OS X, "
"*BSD, etc."
msgstr ""
"اوكلار هو عارض مستندات عالمي مطور بواسطة كِيدِي. يعمل اوكلار على أنظمة أساسية "
"متعددة، بما في ذلك على سبيل المثال لا الحصر لينكس و ويندوز و Mac OS X و * "
"BSD وما إلى ذلك."

#. (itstool) path: description/p
#: org.kde.okular.kirigami.appdata.xml:16
msgid "Features:"
msgstr "الميزات:"

#. (itstool) path: ul/li
#: org.kde.okular.kirigami.appdata.xml:18
msgid ""
"Supported Formats: PDF, PS, Tiff, DjVu, Images, DVI, XPS, Fiction Book, "
"Comic Book, Plucker, EPub, Fax"
msgstr ""
"يدعم التنسيقات: PDF و PS و Tiff و DjVu و Images و DVI و XPS  و Fiction Book "
"و Comic Book و Plucker و EPub و Fax"

#. (itstool) path: ul/li
#: org.kde.okular.kirigami.appdata.xml:19
msgid "Sidebar with contents, thumbnails, reviews and bookmarks"
msgstr ""
"الشريط الجانبي مع المحتويات والصور المصغرة والمراجعات والإشارات المرجعية"

#. (itstool) path: ul/li
