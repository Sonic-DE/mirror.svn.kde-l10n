#: reminder/browserintegrationreminder.json
msgctxt "Description"
msgid ""
"Provides a link to the browser extension if the Plasma Browser Integration "
"host is installed"
msgstr "يقدّم رابطًا إلى امتداد المتصفّح إن ثُبّت مضيف تكامل بلازما مع المتصفّح"

#~ msgctxt "Name"
#~ msgid "Plasma Browser Integration Host"
#~ msgstr "مضيف تكامل بلازما مع المتصفّح"

