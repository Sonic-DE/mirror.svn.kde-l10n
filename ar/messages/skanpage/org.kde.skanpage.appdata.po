msgstr "خيارات قابلة للضبط لمسح الجهاز"

#. (itstool) path: ul/li
#: org.kde.skanpage.appdata.xml:22
msgid "Reordering, rotation, and deletion of scanned pages"
msgstr "إعادة ترتيب وتدوير وحذف الصفحات الممسوحة ضوئيًا"

#. (itstool) path: ul/li
