#. (itstool) path: component/name
#: org.kde.skanpage.appdata.xml:14
msgid "Skanpage"
msgstr "ماسح الصفحات"

#. (itstool) path: component/summary
#: org.kde.skanpage.appdata.xml:15
msgid "Scan multi-page documents and images"
msgstr "امحُ المستندات متعددة الصفحات والصور"

#. (itstool) path: description/p
#: org.kde.skanpage.appdata.xml:17
msgid ""
"Skanpage is a simple scanning application optimized for multi-page document "
"scanning. It can also scan and save single-page documents and images."
msgstr ""
"ماسح الصفحات تطبيق مسح ضوئي بسيط مصمم لمسح المستندات متعددة الصفحات ضوئياً. "
"يمكنه أيضا مسح وحفظ الصور والمستندات ذات الصفحة الواحدة."

#. (itstool) path: description/p
#: org.kde.skanpage.appdata.xml:18
msgid "Features:"
msgstr "الميزات:"

#. (itstool) path: ul/li
#: org.kde.skanpage.appdata.xml:20
msgid "Scanning from flatbed and ADF scanners"
msgstr "المسح الضوئي من الماسحات الضوئية المسطحة ووحدة تغذية المستندات الآليّة"

#. (itstool) path: ul/li
#: org.kde.skanpage.appdata.xml:21
