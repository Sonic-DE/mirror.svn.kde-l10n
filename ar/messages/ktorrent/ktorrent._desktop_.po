#: ktorrent/ktorrent.notifyrc:4
msgctxt "Comment"
msgid "KTorrent"
msgstr "سيولك"

#: ktorrent/ktorrent.notifyrc:67
msgctxt "Name"
msgid "Torrent silently opened"
msgstr "فُتح سيل بهدوء"

#: ktorrent/ktorrent.notifyrc:117
msgctxt "Name"
msgid "Torrent stopped by error"
msgstr "توقّف سيل بسبب خطأ"

#: ktorrent/ktorrent.notifyrc:174
msgctxt "Name"
msgid "Torrent has finished downloading"
msgstr "انتهى تنزيل السّيل"

#: ktorrent/ktorrent.notifyrc:231
msgctxt "Name"
msgid "Maximum share ratio reached"
msgstr "وصلتُ أقصى نسبة للمشاركة"

#: ktorrent/ktorrent.notifyrc:288
msgctxt "Name"
msgid "Maximum seed time reached"
msgstr "وصلتُ أقصى زمن للتّزويد"

#: ktorrent/ktorrent.notifyrc:345
msgctxt "Name"
msgid "Disk space is running low"
msgstr "مساحة القرص منخفضة"

#: ktorrent/ktorrent.notifyrc:402
msgctxt "Name"
msgid "Corrupted data has been found"
msgstr "وُجدت بيانات معطوبة"

#: ktorrent/ktorrent.notifyrc:460
msgctxt "Name"
msgid "Torrent cannot be enqueued"
msgstr "تعذّر وضع السّيل في قائمة الانتظار"

#: ktorrent/ktorrent.notifyrc:517
msgctxt "Name"
msgid "Torrent cannot be started"
msgstr "تعذّر بدء السّيل"

#: ktorrent/ktorrent.notifyrc:574
msgctxt "Name"
msgid "Torrent cannot be loaded silently"
msgstr "تعذّر تحميل سيل بهدوء"

#: ktorrent/ktorrent.notifyrc:631
msgctxt "Name"
msgid "DHT is not enabled"
msgstr "‏DHT ليس ممكّنًا"

#: ktorrent/ktorrent.notifyrc:686
msgctxt "Name"
msgid "Event generated by plugin"
msgstr "ولّدت ملحقة حدثًا"

#: ktorrent/ktorrent.notifyrc:738
msgctxt "Name"
msgid "Magnet link download started"
msgstr "بدأ تنزيل الوصلة الممغنطة"

#: ktorrent/ktorrent.notifyrc:789
msgctxt "Name"
msgid "Magnet link copied to clipboard"
msgstr "نُسخت الوصلة المُمغنطة إلى الحافظة"

