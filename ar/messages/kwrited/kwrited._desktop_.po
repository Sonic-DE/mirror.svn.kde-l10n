#: kwrited-autostart.desktop:2
msgctxt "Name"
msgid "KDE Write Daemon"
msgstr "عفريت كِيدِي للكتابة"

#: kwrited-autostart.desktop:91
msgctxt "Comment"
msgid "Watch for messages from local users sent with write(1) or wall(1)"
msgstr "يراقب رسائل المستخدمين المحليين المرسلة بِـ wall(1) أو write(1)."

#: kwrited.notifyrc:3
msgctxt "Name"
msgid "Local System Message Service"
msgstr "خدمة رسائل النّظام المحليّة"

#: kwrited.notifyrc:48
msgctxt "Comment"
msgid "Local system message service"
msgstr "خدمة رسائل النّظام المحليّة"

#: kwrited.notifyrc:117
msgctxt "Name"
msgid "New message received"
msgstr "استُقبلت رسالة جديدة"

#: kwrited.notifyrc:192
msgctxt "Comment"
msgid "The daemon received a new message sent with wall(1) or write(1)"
msgstr "استقبل العفريت رسالة جديدة أُرسلت بِـ wall(1) أو write(1)."

#~ msgctxt "Name"
#~ msgid "Write Daemon"
