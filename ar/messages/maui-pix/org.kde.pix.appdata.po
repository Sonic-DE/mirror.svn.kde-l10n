#: org.kde.pix.appdata.xml:7
msgid "Pix"
msgstr "بكس"

#. (itstool) path: component/summary
#: org.kde.pix.appdata.xml:8
msgid "Image Gallery"
msgstr "معرض صور"

#. (itstool) path: description/p
#: org.kde.pix.appdata.xml:14
msgid ""
"Pix is an image gallery and image viewer. Pix can be used to open images "
"with other applications like an image editor, add tags to the files, add "
"annotations to pictures, rotate and share them."
msgstr ""
"بكس هو معرض صور وعارض صور. يمكن استخدام بكس لفتح الصور باستخدام تطبيقات أخرى "
"مثل محرر الصور وإضافة وسوم إلى الملفات وإضافة تعليقات توضيحية إلى الصور "
"وتدويرها ومشاركتها."

#. (itstool) path: screenshot/caption
#: org.kde.pix.appdata.xml:23
msgid "The Pix music player"
msgstr "مشغّل الموسيقى بكس"
