#, kde-format
msgctxt "@title:window"
msgid "Select Audio Track"
msgstr "حدد مسار الصوت"

#: core/dplugins/generic/tools/videoslideshow/vidslideoutputpage.cpp:214
#, kde-format
msgid "Soundtrack Duration:"
msgstr "مدة المسار الصوتي:"

#: core/dplugins/generic/tools/videoslideshow/vidslideoutputpage.cpp:220
#, kde-format
msgid "Soundtrack Preview:"
msgstr "معاينة المسار الصوتي:"

#: core/dplugins/generic/tools/videoslideshow/vidslideoutputpage.cpp:227
#, kde-format
msgid ""
"<i>Notes about soundtrack: if the audio length is smaller than video, it "
"will be played in loop. If the audio length is larger than video, it will be "
"trimmed. Leave this setting empty if you do not want a soundtrack to the "
"media.</i>"
msgstr ""
"<i>ملاحظات حول المسار الصوتي: إذا كان طول الصوت أصغر من الفيديو، سيعاد "
"تشغيله في حلقة. إذا كان طول الصوت أكبر من الفيديو، سيقص. اترك هذا الإعداد "
"فارغاً إذا لا تريد مساراً صوتياً للوسائط.</i>"

#: core/dplugins/generic/tools/videoslideshow/vidslideoutputpage.cpp:248
#, kde-format
msgid "Audio Track"
msgstr "مقطوعة صوتية"

