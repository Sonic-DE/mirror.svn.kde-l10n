#: core/dplugins/dimg/heif/dimgheifexportsettings.cpp:71
#, kde-format
msgid "HEIF quality:"
msgstr "جودة HEIF:"

#: core/dplugins/dimg/heif/dimgheifexportsettings.cpp:73
#, kde-format
msgid ""
"<p>The quality value for HEIF images:</p><p><b>1</b>: low quality (high "
"compression and small file size)<br><b>50</b>: medium quality<br><b>75</b>: "
"good quality (default)<br><b>100</b>: high quality (no compression and large "
"file size)</p><p><b>Note: HEIF is not a lossless image compression format "
"when you use this setting.</b></p>"
msgstr ""
"<p>قيمة الجودة لصور HEIF:</p><p><b>1</b>: جودة منخفضة (ضغط عالٍ وحجم ملف "
"صغير)<br><b>50</b>: جودة متوسطة<br><b>75</b>: جودة جيدة (مبدئي)<br><b>100</"
"b>: جودة عالية (لا يوجد ضغط وحجم ملف كبير)</p><p><b>ملاحظة: HEIF ليس تنسيق "
"ضغط صورة غير منقوص عندما تستخدم هذا الإعداد.</b></p>"

