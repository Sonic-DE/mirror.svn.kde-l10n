msgstr "أنشئ صورة بانوراميّة"

#: core/dplugins/generic/tools/panorama/panoramaplugin.cpp:62
#, kde-format
msgid "A tool to create panorama"
msgstr "أداة لإنشاء بانوراما"

#: core/dplugins/generic/tools/panorama/panoramaplugin.cpp:67
#, kde-format
msgid ""
"<p>This tool allows users to assemble images together to create large "
"panorama.</p><p>To create panorama image, you need to use images taken from "
"same point of view with a tripod and exposed with same settings.</p><p>The "
"tool is able to assemble shots taken horizontally, vertically, or as a "
"matrix. Take care that target image will become huge and require a lot of "
"memory to be processed.</p>"
msgstr ""
"<p>هذه الأداة تسمح للمستخدمين بتجميع الصور معًا لإنشاء بانوراما كبيرة.</"
"p><p>لإنشاء صورة بانورامية، تحتاج إلى استخدام صور أخذت من نفس النقطة "
"باستخدام حامل ثلاثي وعرضت بنفس الإعدادات.</p><p>الأداة قادرة على تجميع "
"اللقطات الأفقية، الرأسية، أو كمصفوفة. انتبه أن الصورة المستهدفة ستصبح ضخمة "
"وتتطلب الكثير من الذاكرة للمعالجة.</p>"

#: core/dplugins/generic/tools/panorama/panoramaplugin.cpp:102
#, kde-format
msgctxt "@action"
msgid "Create panorama..."
msgstr "أنشئ صورة بانوراميّة..."

