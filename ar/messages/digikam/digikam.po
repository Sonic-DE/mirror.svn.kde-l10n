#: core/libs/widgets/text/localizeconfig.cpp:221
#, kde-format
msgctxt "@label"
msgid "Online Translator:"
msgstr "المترجم الشبكي:"

#: core/libs/widgets/text/localizeconfig.cpp:223
#, kde-format
msgctxt "@option"
msgid "Select here the online engine to translate text"
msgstr "اختر هنا المحرك الشبكي لترجمة النص"

#: core/libs/widgets/text/localizeconfig.cpp:230
#, kde-kuit-format
msgctxt "@info"
msgid ""
"<para>The translator engine is an online Web-service used to translate text "
"from one language to another one. This feature is available on metadata "
"option where alternative language is supported, as Title, Caption, etc. The "
"translation process is fully automated but it requires an Internet "
"connection to work.</para><para>User can select the more appropriate "
"translator engine depending of desired target language, as not all world-"
"wide languages are supported by online Web-services.</para>"
msgstr ""
"<para>محرك الترجمة هو خدمة شبكية تستخدم لترجمة النص من لغة إلى أخرى. هذه "
"الميزة متاحة في خيارات البيانات الوصفية حيث تدعم اللغة البديلة، مثل العنوان "
"والتعليق وما إلى ذلك. عملية الترجمة تتم بشكل آلي بالكامل ولكنها تحتاج اتصال "
"بالإنترنت لكي تعمل.</para><para>بإمكان المستخدم اختيار محرك الترجمة الأكثر "
"ملاءمة اعتمادًا على اللغة الهدف المرغوبة، حيث لا تدعم جميع اللغات العالمية من "
"قبل الخدمات الشبكية.</para>"

#: core/libs/widgets/text/localizeconfig.cpp:320
#, kde-format
msgctxt "@title"
msgid "Available Translator Languages (%1/%2)"
msgstr "لغات الترجمة المتاحة (%1/%2)"

