#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:223
#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:309
#, kde-format
msgid "Green Filter"
msgstr "مرشّح أخضر"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:224
#, kde-format
msgid ""
"<b>Black & White with Green Filter</b>:<p>Simulate black and white film "
"exposure using a green filter. This is useful for all scenic shoots, "
"especially portraits photographed against the sky.</p>"
msgstr ""
"<b>أبيض وأسود مع مرشح أخضر</b>:<p>حاكي عرض فيلم بالأبيض والأسود باستخدام "
"مرشح أخضر. هذا مفيد لجميع اللقطات الخلابة، وخاصة الصور الشخصية التي التقطت "
"مقابل السماء.</p>"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:229
#, kde-format
msgid "Orange Filter"
msgstr "مرشّح برتقاليّ"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:230
#, kde-format
msgid ""
"<b>Black & White with Orange Filter</b>:<p>Simulate black and white film "
"exposure using an orange filter. This will enhance landscapes, marine scenes "
"and aerial photography.</p>"
msgstr ""
"<b>أبيض وأسود مع مرشح برتقالي</b>:<p>حاكي عرض فيلم بالأبيض والأسود باستخدام "
"مرشح برتقالي. هذا سيعزز المناظر الطبيعية، والمشاهد البحرية، والتصوير الجوي.</"
"p>"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:235
#, kde-format
msgid "Red Filter"
msgstr "مرشّح أحمر"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:236
#, kde-format
msgid ""
"<b>Black & White with Red Filter</b>:<p>Simulate black and white film "
"exposure using a red filter. This creates dramatic sky effects, and "
"simulates moonlight scenes in the daytime.</p>"
msgstr ""
"<b>أبيض وأسود مع مرشح أحمر</b>:<p>حاكي عرض فيلم بالأبيض والأسود باستخدام "
"مرشح أحمر. هذا يخلق تأثيرات سماء درامية، ويحاكي مشاهد ضوء القمر في النهار.</"
"p>"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:241
#, kde-format
msgid "Yellow Filter"
msgstr "مرشّح أصفر"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:242
#, kde-format
msgid ""
"<b>Black & White with Yellow Filter</b>:<p>Simulate black and white film "
"exposure using a yellow filter. This has the most natural tonal correction, "
"and improves contrast. Ideal for landscapes.</p>"
msgstr ""
"<b>أبيض وأسود مع مرشح أصفر</b>:<p>حاكي عرض فيلم بالأبيض والأسود باستخدام "
"مرشح أصفر. هذا لديه التصحيح اللوني الأكثر طبيعية، ويحسن التباين. مثالي "
"للمناظر الطبيعية.</p>"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:247
#, kde-format
msgid "Yellow-Green Filter"
msgstr "مرشّح أخضر مصفرّ"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:248
#, kde-format
msgid ""
"<b>Black & White with Yellow-Green Filter</b>:<p>Simulate black and white "
"film exposure using a yellow-green filter. A yellow-green filter is highly "
"effective for outdoor portraits because red is rendered dark while green "
"appears lighter. Great for correcting skin tones, bringing out facial "
"expressions in close-ups and emphasizing the feeling of liveliness. This "
"filter is highly effective for indoor portraits under tungsten lighting.</p>"
msgstr ""
"<b>أبيض وأسود مع مرشح أصفر-أخضر</b>:<p>حاكي عرض فيلم بالأبيض والأسود "
"باستخدام مرشح أصفر-أخضر. المرشح الأصفر-الأخضر فعال جدا للصور الشخصية في "
"الهواء الطلق لأن الأحمر يظهر داكنا بينما الأخضر يظهر أفتح. ممتاز لتصحيح "
"درجات لون البشرة، وإبراز تعابير الوجه في اللقطات القريبة والتأكيد على الشعور "
"بالحيوية. هذا المرشح فعال جدا للصور الشخصية في الأماكن المغلقة تحت إضاءة "
"التنغستن.</p>"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:255
#, kde-format
msgid "Blue Filter"
msgstr "مرشّح أزرق"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:256
#, kde-format
msgid ""
"<b>Black & White with Blue Filter</b>:<p>Simulate black and white film "
"exposure using a blue filter. This accentuates haze and fog. Used for dye "
"transfer and contrast effects.</p>"
msgstr ""
"<b>أبيض وأسود مع مرشح أزرق</b>:<p>حاكي عرض فيلم بالأبيض والأسود باستخدام "
"مرشح أزرق. هذا يبرز الضباب والدخان. استخدمه لنقل الصبغة وتأثيرات التباين.</p>"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:261
#, kde-format
msgid "Strength:"
msgstr "الشّدّة:"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:267
#, kde-format
msgid "Here, set the strength adjustment of the lens filter."
msgstr "هنا، اضبط ضبط قوة مرشح العدسة."

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:278
#, kde-format
msgid "No Tone Filter"
msgstr "لا يوجد مرشح نغمة"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:279
#, kde-format
msgid "<b>No Tone Filter</b>:<p>Do not apply a tone filter to the image.</p>"
msgstr "<b>لا يوجد مرشح نغمة</b>:<p>لا تطبق مرشح نغمة على الصورة.</p>"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:282
#, kde-format
msgid "Sepia Filter"
msgstr "مرشح بني داكن"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:283
#, kde-format
msgid ""
"<b>Black & White with Sepia Tone</b>:<p>Gives a warm highlight and mid-tone "
"while adding a bit of coolness to the shadows - very similar to the process "
"of bleaching a print and re-developing in a sepia toner.</p>"
msgstr ""
"<b>أبيض وأسود مع نغمة بنية داكنة</b>:<p>يمنح إضاءة دافئة ونغمة متوسطة مع "
"إضافة القليل من البرودة إلى الظلال - مشابه جدا لعملية تبييض الطبعة وإعادة "
"تطويرها في حبر بني داكن.</p>"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:288
#, kde-format
msgid "Brown Filter"
msgstr "مرشّح بنّيّ"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:289
#, kde-format
msgid ""
"<b>Black & White with Brown Tone</b>:<p>This filter is more neutral than the "
"Sepia Tone filter.</p>"
msgstr ""
"<b>أبيض وأسود مع نغمة بنية</b>:<p>هذا المرشح أكثر حيادية من مرشح النغمة "
"البنية الداكنة.</p>"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:293
#, kde-format
msgid "Cold Filter"
msgstr "مرشح بارد"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:294
#, kde-format
msgid ""
"<b>Black & White with Cold Tone</b>:<p>Start subtly and replicate printing "
"on a cold tone black and white paper such as a bromide enlarging paper.</p>"
msgstr ""
"<b>أبيض وأسود مع نغمة باردة</b>:<p>ابدأ بمهارة وحاكي الطباعة على ورق أبيض "
"وأسود بنغمة باردة مثل ورق تكبير البروميد.</p>"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:299
#, kde-format
msgid "Selenium Filter"
msgstr "مرشح سيلينيوم"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:300
#, kde-format
msgid ""
"<b>Black & White with Selenium Tone</b>:<p>This effect replicates "
"traditional selenium chemical toning done in the darkroom.</p>"
msgstr ""
"<b>أبيض وأسود مع نغمة سيلينيوم</b>:<p>هذا التأثير يحاكي التلوين الكيميائي "
"التقليدي للسيلينيوم الذي يجري في الغرفة المظلمة.</p>"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:304
#, kde-format
msgid "Platinum Filter"
msgstr "مرشح بلاتينيوم"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:305
#, kde-format
msgid ""
"<b>Black & White with Platinum Tone</b>:<p>This effect replicates "
"traditional platinum chemical toning done in the darkroom.</p>"
msgstr ""
"<b>أبيض وأسود مع نغمة بلاتينيوم</b>:<p>هذا التأثير يحاكي التلوين الكيميائي "
"التقليدي للبلاتينيوم الذي يجري في الغرفة المظلمة.</p>"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:310
#, kde-format
msgid ""
"<b>Black & White with greenish tint</b>:<p>This effect is also known as "
