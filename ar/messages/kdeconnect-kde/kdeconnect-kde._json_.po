#: plugins/sendnotifications/kdeconnect_sendnotifications.json
msgctxt "Description"
msgid ""
"Broadcast this computer's notifications, so they can be shown on other "
"devices."
msgstr "بُثّ إشعارات هذا الحاسوب، لتظهر على الأجهزة الأخرى."

#: plugins/sftp/kdeconnect_sftp.json
msgctxt "Description"
msgid "Browse the remote device filesystem using SFTP"
msgstr "تصفّح نظام ملفّات الجهاز البعيد باستخدام SFTP"

#: plugins/shareinputdevices/kdeconnect_shareinputdevices.json
msgctxt "Description"
