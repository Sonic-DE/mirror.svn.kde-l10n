#. (itstool) path: component/name
#: org.kde.massif_visualizer.appdata.xml:12
msgid "Massif-Visualizer"
msgstr "مصور Massif"

#. (itstool) path: component/summary
#: org.kde.massif_visualizer.appdata.xml:13
msgid "A visualizer for Valgrind Massif data files"
msgstr "مصور لملفات بيانات Massif من Valgrind"

#. (itstool) path: description/p
#: org.kde.massif_visualizer.appdata.xml:15
msgid ""
"Massif Visualizer is a tool that - who'd guess that - visualizes massif "
"data. You run your application in Valgrind with --tool=massif and then open "
"the generated massif.out.%pid in the visualizer. Gzip or Bzip2 compressed "
"massif files can also be opened transparently."
msgstr ""
"مصور Massif أداة - من يظن ذلك؟ - تصور بيانات Massif. شغّل تطبيقك في Valgrind "
"باستخدام --tool=massif ثم افتح الملف massif.out.%pid المُنشأ في المصور. افتح "
"ملفات Massif المضغوطة بـ Gzip أو Bzip2 أيضًا بـ **آلي**ة."

