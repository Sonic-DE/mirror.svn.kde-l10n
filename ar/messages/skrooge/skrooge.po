msgstr "%1 سيتم استبدالها بالتاريخ السابق بتنسيق yyyy-MM-dd"

#: skgbankmodeler/skgunitobject.cpp:2234
#, kde-format
msgctxt "Description test for a text file used to define a source of download"
msgid ""
"The mode (HTML or CSV or CSVR). In HTML mode, only one value will be "
"extracted from downloaded page. In CSV mode, a value per line will be "
"extracted. CSVR means CSV in reverse mode."
msgstr ""
"الوضع (HTML أو CSV أو CSVR). في وضع HTML، سيتم استخراج قيمة واحدة فقط من "
"الصفحة التي نزلت. في وضع CSV، سيتم استخراج قيمة لكل سطر. CSVR تعني CSV "
"بالوضع المعكوس."

#: skgbankmodeler/skgunitobject.cpp:2241
#, kde-format
msgctxt "Description test for a text file used to define a source of download"
msgid "The regular expression for the price (see %1)"
msgstr "التعبير النمطي للسعر (اطلع على %1)"

#: skgbankmodeler/skgunitobject.cpp:2248
#, kde-format
msgctxt "Description test for a text file used to define a source of download"
msgid "The regular expression for the date (see %1)"
msgstr "التعبير النمطي للتاريخ (اطلع على %1)"

