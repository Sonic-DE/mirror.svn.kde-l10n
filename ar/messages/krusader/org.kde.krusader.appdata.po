msgid "Features:"
msgstr "الميزات:"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:16
msgid "Extensive archive handling"
msgstr "معالجة موسعة للأرشيفات"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:17
msgid "Mounted filesystem support"
msgstr "دعم توصيل نظام الملفات"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:18
msgid "FTP support"
msgstr "دعم اف تي بي"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:19
msgid "Advanced search module"
msgstr "وحدة بحث متقدمة"

#. (itstool) path: ul/li
