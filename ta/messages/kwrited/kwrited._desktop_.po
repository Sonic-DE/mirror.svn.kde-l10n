#: kwrited-autostart.desktop:2
msgctxt "Name"
msgid "KDE Write Daemon"
msgstr "KDE Write Daemon"

#: kwrited-autostart.desktop:91
msgctxt "Comment"
msgid "Watch for messages from local users sent with write(1) or wall(1)"
msgstr "உள் பயனர் அணுப்பியதுடன் write(1) or wall(1) அதிலிருந்து பார்க்கவேண்டிய தகவல்கள்"

#: kwrited.notifyrc:3
msgctxt "Name"
msgid "Local System Message Service"
msgstr "கணினிக்குள் தகவலனுப்பும் சேவை"

#: kwrited.notifyrc:48
msgctxt "Comment"
msgid "Local system message service"
msgstr "கணினிக்குள் தகவலனுப்பும் சேவை"

#: kwrited.notifyrc:117
msgctxt "Name"
msgid "New message received"
msgstr "New message received"

#: kwrited.notifyrc:192
msgctxt "Comment"
msgid "The daemon received a new message sent with wall(1) or write(1)"
msgstr "The daemon received a new message sent with wall(1) or write(1)"

