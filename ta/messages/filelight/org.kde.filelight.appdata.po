#. (itstool) path: component/name
#: org.kde.filelight.appdata.xml:10
msgid "Filelight"
msgstr "ஃபைல்-லைட்"

#. (itstool) path: component/summary
#: org.kde.filelight.appdata.xml:11
msgid "Show disk usage and delete unused files"
msgstr "வட்டுப் பயன்பாட்டைக் காட்டி, தேவையில்லாத கோப்புகளை அகற்ற உதவும்"

#. (itstool) path: description/p
#: org.kde.filelight.appdata.xml:13
msgid ""
"Filelight is an application to visualize the disk usage on your computer by "
"showing folders using an easy-to-understand view of concentric rings. "
"Filelight makes it simple to free up space!"
msgstr ""
"உங்கள் கணினியிலுள்ள அடைவுகளின் அளவுகளை நீங்கள் எளிதில் புரிந்துகொள்ளும் வகையில் ஃபைல்-லைட் "
"காட்டும். தேவையில்லாதவற்றை சுலபமாக அகற்றி இடத்தை காலி செய்யலாம்!"

#. (itstool) path: description/p
#: org.kde.filelight.appdata.xml:16
msgid "Features:"
msgstr "அம்சங்கள்:"

#. (itstool) path: ul/li
#: org.kde.filelight.appdata.xml:18
msgid "Scan local, remote, or removable disks"
msgstr "உள்ளமை, தொலை, மற்றும் கழற்றக்கூடிய வட்டுகளை ஆராயும்"

#. (itstool) path: ul/li
#: org.kde.filelight.appdata.xml:19
msgid "View detailed information about files and folders"
msgstr "கோப்புகளின் மற்றும் அடைவுகளின் விவரங்களைக் காட்டும்"

#. (itstool) path: ul/li
#: org.kde.filelight.appdata.xml:20
msgid "Delete files or folders that are taking up too much space"
msgstr "மிகப்பெரிய கோப்புகளையும் அடைவுகளையும் எளிதில் அகற்ற உதவும்"

#. (itstool) path: ul/li
#: org.kde.filelight.appdata.xml:21
msgid "Integration into the Dolphin, Konqueror, and Krusader file managers"
msgstr "டால்பின், கான்கொரர், குரூசெடர் போன்ற கோப்பு உலாவிகளுடனான ஒருங்கிணைப்பு"

#. (itstool) path: ul/li
#: org.kde.filelight.appdata.xml:22
msgid "Configurable color schemes"
msgstr "மாற்றியமைக்க‍க்கூடிய நிறத்திட்டங்கள்"

#~ msgid ""
#~ "Filelight is an application to visualize the disk usage on your computer"
#~ msgstr "ஃபைல்-லைட், உங்கள் கணினியின் வட்டுச்சேமிப்பக பயன்பாட்டை காண உதவும் சேயலி ஆகும்"

#~ msgid "File system navigation by mouse clicks"
#~ msgstr "சுட்டியின் மூலம் கோப்பு முறைமையில் உலாவலாம்"

#~ msgid ""
#~ "Files and directories can be copied or removed directly from the context "
#~ "menu"
#~ msgstr ""
#~ "வலது-க்ளிக் பட்டியிலிருந்தே கோப்புகளையும் அடைவுகளையும் நகர்த்தலாம் அல்லது நகலெடுக்கலாம்"
