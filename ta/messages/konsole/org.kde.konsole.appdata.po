#. (itstool) path: component/name
#: org.kde.konsole.appdata.xml:6
msgid "Konsole"
msgstr "கான்சோல்"

#. (itstool) path: component/summary
#: org.kde.konsole.appdata.xml:7
msgid "Use the command line interface"
msgstr "முனைய இடைமுகப்பைப் பயன்படுத்துங்கள்"

#. (itstool) path: description/p
#: org.kde.konsole.appdata.xml:12
msgid ""
"Konsole is a terminal to run a command shell. It provides a command line "
"interface for directly controlling your computer."
msgstr ""
"கான்சோல், முனைய இடைமுகப்பை இயக்கும் செயலி ஆகும். உங்கள் கணினி நீங்கள் நேரடியாக "
"கட்டுப்படுத்த இது உதவும்."

#. (itstool) path: description/p
#: org.kde.konsole.appdata.xml:13
msgid "Features:"
msgstr "அம்சங்கள்:"

#. (itstool) path: ul/li
#: org.kde.konsole.appdata.xml:15
msgid "Tabs"
msgstr "கீற்றுகள்"

#. (itstool) path: ul/li
#: org.kde.konsole.appdata.xml:16
msgid "Multiple profiles"
msgstr "பல பயன்முறைகள்"

#. (itstool) path: ul/li
#: org.kde.konsole.appdata.xml:17
msgid "Silence and Activity monitoring"
msgstr "செயல்பாடு மற்றும் அமைதிக்காக கண்காணித்தல்"

#. (itstool) path: ul/li
#: org.kde.konsole.appdata.xml:18
msgid "Bookmark support"
msgstr "நினைவுக்குறிக்கான ஆதரவு"

#. (itstool) path: ul/li
#: org.kde.konsole.appdata.xml:19
msgid "Searching"
msgstr "தேடல்"

#. (itstool) path: ul/li
#: org.kde.konsole.appdata.xml:20
msgid "Saving output"
msgstr "வெளியீட்டை சேமிப்பது"

#. (itstool) path: screenshot/caption
#: org.kde.konsole.appdata.xml:32
msgid "Konsole being used as a terminal emulator"
msgstr "முனையக் கருவியாக கான்சோல் பயன்படுத்தப்படுவது"

#~ msgid "Terminal"
#~ msgstr "முனையம்"
