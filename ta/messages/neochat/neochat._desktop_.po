#: org.kde.neochat.desktop:5 src/app/neochat.notifyrc:3
#: src/app/plasma-runner-neochat.desktop:4
msgctxt "Name"
msgid "NeoChat"
msgstr "நியோச்சாட்"

#: org.kde.neochat.desktop:50
msgctxt "GenericName"
msgid "Matrix Client"
msgstr "Matrix வாங்கி"

#: org.kde.neochat.desktop:94
msgctxt "Comment"
msgid "Chat on Matrix"
msgstr "மேட்ரிக்ஸில் உரையாட உதவும்"

#: src/app/neochat.notifyrc:49
msgctxt "Comment"
msgid "A client for matrix, the decentralized communication protocol"
msgstr "மையமில்லா தகவல் பரிமாற்ற நெறிமுறையான மேட்ரிக்ஸுக்கான செயலி"

#: src/app/neochat.notifyrc:96
msgctxt "Name"
msgid "New message"
msgstr "புதிய செய்தி"

#: src/app/neochat.notifyrc:140
msgctxt "Comment"
msgid "There is a new message"
msgstr "ஒரு புதிய செய்தி உள்ளது"

#: src/app/neochat.notifyrc:186
msgctxt "Name"
msgid "New Invitation"
msgstr "புதிய அழைப்பிதழ்"

#: src/app/neochat.notifyrc:229
msgctxt "Comment"
msgid "There is a new invitation to a room"
msgstr "ஓர் அரங்கிற்கான புதிய அழைப்பிதழ் உள்ளது"

#: src/app/neochat.notifyrc:275
msgctxt "Name"
msgid "Share"
msgstr "பகிர்"

#: src/app/neochat.notifyrc:313
msgctxt "Comment"
msgid "The result of sharing a piece of content"
msgstr "எதையோ பகிர்ந்த‍தன் விளைவு"

#: src/app/plasma-runner-neochat.desktop:49
msgctxt "Comment"
msgid "Find rooms in NeoChat"
msgstr "நியோச்சாட்டில் அரங்குகளை கண்டுபிடிக்கும்"

#~ msgctxt "Comment"
#~ msgid "Client for the Matrix protocol"
#~ msgstr "Matrix நெறிமுறைக்கான வாங்கி"
