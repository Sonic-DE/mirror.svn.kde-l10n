#: kcm_sddm.actions:2
msgctxt "Name"
msgid "SDDM"
msgstr "SDDM"

#: kcm_sddm.actions:58
msgctxt "Name"
msgid "Save Settings"
msgstr "அமைப்புகளை சேமி"

#: kcm_sddm.actions:109
msgctxt "Description"
msgid "Save Settings in SDDM"
msgstr "அமைப்புகளை SDDM-இல் சேமிக்கும்"

#: kcm_sddm.actions:163
msgctxt "Name"
msgid "Install an SDDM theme"
msgstr "SDDM தோற்றத்திட்டத்தை நிறுவு"

#: kcm_sddm.actions:213
msgctxt "Description"
msgid "Extract a zip file containing an SDDM theme to the SDDM theme location"
msgstr "SDDM தோற்றத்திட்டங்களுக்கான இருப்பிடத்திற்கு ஓர் காப்பகக்கோப்பைப் பிரித்தெடுக்கும்"

#: kcm_sddm.actions:254
msgctxt "Name"
msgid "Uninstall an SDDM theme"
msgstr "SDDM தோற்றத்திட்டத்தை நீக்கு"

#: kcm_sddm.actions:304
msgctxt "Description"
msgid "Remove a previously installed SDDM theme"
msgstr "முன்பு நிறுவிய SDDM தோற்றத்திட்டத்தை நீக்கும்"

#: kcm_sddm.actions:345
msgctxt "Name"
msgid "Synchronize Settings"
msgstr "அமைப்புகளை ஒத்திசையசெய்"

#: kcm_sddm.actions:391
msgctxt "Description"
msgid "Synchronize user settings with SDDM settings"
msgstr "பயனரின் அமைப்புகளை SDDM அமைப்புகளாக அமைக்கும்"

#: kcm_sddm.actions:432
msgctxt "Name"
msgid "Reset Settings"
msgstr "அமைப்புகளை மீட்டமை"

#: kcm_sddm.actions:478
msgctxt "Description"
msgid "Reset SDDM settings to factory default state"
msgstr "SDDM அமைப்புகளை இயல்புநிலைக்கு மீட்டமைக்கும்"

#: sddmtheme.knsrc:4
msgctxt "Name"
msgid "Login Screen"
msgstr "நுழைவு திரை"
