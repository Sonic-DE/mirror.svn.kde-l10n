#. (itstool) path: component/name
#: org.kde.khelpcenter.metainfo.xml:9
msgid "Help Center"
msgstr "உதவி மையம்"

#. (itstool) path: component/summary
#: org.kde.khelpcenter.metainfo.xml:10
msgid "Browse and search documentation"
msgstr "கையேடுகளில் தேடி உலாவலாம்"

#. (itstool) path: description/p
#: org.kde.khelpcenter.metainfo.xml:12
msgid ""
"An application to search and read the documentation for all your KDE "
"applications and system utilities"
msgstr ""
"கே.டீ.யீ. செயலிகளுக்கும் இயங்குதள நிரல்களுக்கும் உள்ள கையேடுகளை படிக்கவும் அவற்றுக்குள் "
"தேடவும் உதவும் செயலி"

#. (itstool) path: description/p
#: org.kde.khelpcenter.metainfo.xml:15
msgid "Features:"
msgstr "அம்சங்கள்:"

#. (itstool) path: ul/li
#: org.kde.khelpcenter.metainfo.xml:17
msgid ""
"Show documentation from various sources (applications from KDE community, "
"man pages, etc)"
msgstr ""
"பல இடங்களிலிருந்தான கையேடுகளை காட்டும் (கே.டீ.யீ. செயலிகள், இயங்குதள கையேடுகள் "
"இத்தியாதி)"

#. (itstool) path: ul/li
#: org.kde.khelpcenter.metainfo.xml:18
msgid "Search through the available documentation"
msgstr "கையேடுகளில் தேடுங்கள்"

