#: discover/org.kde.discover.desktop.cmake:2
#: notifier/org.kde.discover.notifier.desktop.cmake:2
msgctxt "Name"
msgid "Discover"
msgstr "டிஸ்கவர்"

#: discover/org.kde.discover.desktop.cmake:61
msgctxt "Comment"
msgid "Install and remove apps and add-ons"
msgstr "செயலிகளையும் துணைநிரல்களையும் நிறுவி நீக்கலாம்"

#: discover/org.kde.discover.desktop.cmake:108
msgctxt "GenericName"
msgid "Software Center"
msgstr "மென்பொருள் மையம்"

#: discover/org.kde.discover.desktop.cmake:169
msgctxt "Keywords"
msgid ""
"program;software;store;repository;package;add;install;uninstall;remove;"
"update;apps;applications;games;flatpak;snap;addons;add-ons;firmware;"
msgstr ""
"program;software;store;repository;package;add;install;uninstall;remove;"
"update;apps;applications;games;flatpak;snap;addons;add-ons;firmware;மென்பொருள்;"
"பயன்பாடு;செயலி;ஆப்ஸ்;ஆப்சு;நிரல்;கிடங்கு;களஞ்சியம்;தொகுப்பு;சேர்;நிறுவு;நிறுவல்;நீக்கு;"
"புதுப்பி;புதுப்பித்தல்;ஃபலாட்பாக்;ஸ்னாப்;சுனாப்;செருகுநிரல்;துணை நிரல்கள்;துணைநிரல்;"
"சாதனநிரல்;"

#: discover/org.kde.discover.desktop.cmake:213
msgctxt "Name"
msgid "See Available Updates"
msgstr "கிடைக்கும் புதுப்பிப்புகளை காட்டும்"

#: libdiscover/backends/AlpineApkBackend/org.kde.discover.alpineapkbackend.actions:2
msgctxt "Name"
msgid "Package management"
msgstr "தொகுப்பு மேலாண்மை"

#: libdiscover/backends/AlpineApkBackend/org.kde.discover.alpineapkbackend.actions:45
msgctxt "Description"
msgid "Install/remove/upgrade packages"
msgstr "தொகுப்புகளை நிறுவலாம், நீக்கலாம், மற்றும் புதுப்பிக்கலாம்."

#: libdiscover/backends/SnapBackend/libsnapclient/org.kde.discover.libsnapclient.actions:2
msgctxt "Name"
msgid "Snap login action"
msgstr "Snap நுழைவுச் செயல்"

#: libdiscover/backends/SnapBackend/libsnapclient/org.kde.discover.libsnapclient.actions:60
msgctxt "Description"
msgid "Allows snap front-ends to log in"
msgstr "snap இடைமுகப்புகளை நுழைய விடும்"

#: libdiscover/resources/discoverabstractnotifier.notifyrc:4
msgctxt "Comment"
msgid "Discover"
msgstr "டிஸ்கவர்"

#: libdiscover/resources/discoverabstractnotifier.notifyrc:65
msgctxt "Name"
msgid "Updates Are Available"
msgstr "புதுப்பிப்புகள் உள்ளன"

#: libdiscover/resources/discoverabstractnotifier.notifyrc:124
msgctxt "Comment"
msgid "Updates Available"
msgstr "புதுப்பிப்புகள் உள்ளன"

#: libdiscover/resources/discoverabstractnotifier.notifyrc:186
msgctxt "Name"
msgid "Successful Offline Update"
msgstr "வெற்றிகரமான அமர்வுக்கு-வெளியான-புதுப்பிப்பு"

#: libdiscover/resources/discoverabstractnotifier.notifyrc:238
msgctxt "Comment"
msgid "System updated successfully"
msgstr "கணினி வெற்றிகரமாக புதுப்பிக்கப்பட்டுள்ளது"

#: libdiscover/resources/discoverabstractnotifier.notifyrc:294
msgctxt "Name"
msgid "Failed Offline Update"
msgstr "தோல்வியடைந்த அமர்வுக்கு-வெளியான-புதுப்பிப்பு"

#: libdiscover/resources/discoverabstractnotifier.notifyrc:346
msgctxt "Comment"
msgid "System update failed"
msgstr "கணினியின் புதுப்பிப்பு தோல்வியடைந்தது"

#: libdiscover/resources/discoverabstractnotifier.notifyrc:402
msgctxt "Name"
msgid "Repair Started"
msgstr "பழுதுநீக்கம் துவக்கப்பட்டது"

#: libdiscover/resources/discoverabstractnotifier.notifyrc:453
msgctxt "Name"
msgid "Repaired Successfully"
msgstr "வெற்றிகரமாக சரிசெய்யப்பட்டுள்ளது"

#: libdiscover/resources/discoverabstractnotifier.notifyrc:505
msgctxt "Name"
msgid "Repair Failed"
msgstr "சரிசெய்வது தோல்வியடைந்தது"

#: libdiscover/resources/discoverabstractnotifier.notifyrc:557
msgctxt "Comment"
msgid "Repair failure after offline update"
msgstr "அமர்வுக்கு-வெளியான-புதுப்பிப்பின் தோல்வியை சரிசெய்வது"

#: libdiscover/resources/discoverabstractnotifier.notifyrc:613
msgctxt "Name"
msgid "Restart is Required"
msgstr "மீள்துவக்க வேண்டும்"

#: libdiscover/resources/discoverabstractnotifier.notifyrc:670
msgctxt "Name"
msgid "Upgrade available"
msgstr "புதிய பதிப்பு உள்ளது"
