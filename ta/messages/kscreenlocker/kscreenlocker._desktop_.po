#: greeter/themes/org.kde.passworddialog/metadata.desktop:2
msgctxt "Name"
msgid "Password dialog"
msgstr "கடவுச்சொல் உரைப்பெட்டி"

#: greeter/themes/org.kde.passworddialog/metadata.desktop:55
msgctxt "Comment"
msgid ""
"Screen locker that provides a password dialog and an interface to switch the "
"current user"
msgstr "கடவுச்சொல் உரைப்பெட்டியையும் பயனர் மாற்ற இடைமுகப்பையும் வழங்கும் திரைப்பூட்டி"

#: kscreenlocker.notifyrc:3
msgctxt "Comment"
msgid "Screen Saver"
msgstr "திரை பூட்டு"

#: kscreenlocker.notifyrc:57
msgctxt "Name"
msgid "Screen locked"
msgstr "துரை பூட்டப்பட்டுள்ளது"

#: kscreenlocker.notifyrc:110
msgctxt "Comment"
msgid "The screen has been locked"
msgstr "துரை பூட்டப்பட்டுள்ளது"

#: kscreenlocker.notifyrc:165
msgctxt "Name"
msgid "Screen unlocked"
msgstr "திரை திறக்கப்பட்டுள்ளது"

#: kscreenlocker.notifyrc:218
msgctxt "Comment"
msgid "The screen has been unlocked"
msgstr "திரைப்பூட்டு திறக்கப்பட்டுள்ளது"

#~ msgctxt "Name"
#~ msgid "Screen Locking"
#~ msgstr "திரை பூட்டல்"
