#: kcm/kcm_screenlocker.json
msgctxt "X-KDE-Keywords"
msgid ""
"lock,resume,screensaver,screenlock,locking,block,blocking,password,sleep,"
"close lid,lock automatically,screen lock appearance,screen lock theme,screen "
"lock wallpaper,lockscreen,lock screen"
msgstr ""
"lock,resume,screensaver,screenlock,locking,block,blocking,password,sleep,"
"close lid,lock automatically,screen lock appearance,screen lock theme,screen "
"lock wallpaper,lockscreen,lock screen, பூட்டு, எழுப்பு, தொடர், திரைகாப்பி, "
"திரைகாப்பு, திரைபூட்டு, திரை பூட்டு, பூட்டுவது, தடு, தடுப்பது, பாதுகாப்பு, "
"பாதுகாப்பது, கடவுச்சொல், தூக்கம், தூங்கு, உறக்கம், மூடி, தானாக பூட்டு, பின்புலப் படம், "
"பின்புல படம், பின்னணிப் படம், பின்னணி படம், பின்னணிப்படம், பூட்டு திரை, பூட்டுதிரை"

