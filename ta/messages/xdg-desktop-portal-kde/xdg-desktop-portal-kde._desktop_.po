msgctxt "Name"
msgid "Portal"
msgstr ""

#: src/xdg-desktop-portal-kde.notifyrc:3
msgctxt "Comment"
msgid "Integrating applications into the KDE Plasma desktop"
msgstr "கே.டீ.யீ. பிளாஸ்மா பணிமேடையில் செயலிகளை ஒருங்கிணைக்கும்"

#: src/xdg-desktop-portal-kde.notifyrc:50
#, fuzzy
msgctxt "Name"
msgid "KDE Portal Integration"
msgstr "கே.டீ.யீ. Portal ஒருங்கிணைப்பு"

#: src/xdg-desktop-portal-kde.notifyrc:98
msgctxt "Name"
msgid "Screencasting failed"
msgstr "திரைப்பகிர்வு தோல்வியடைந்தது"

#: src/xdg-desktop-portal-kde.notifyrc:144
msgctxt "Comment"
msgid "An error was encountered while screencasting"
msgstr "திரையை பகிரும்போது சிக்கல் ஏற்பட்டது"

#: src/xdg-desktop-portal-kde.notifyrc:194
msgctxt "Name"
msgid "Started Remote Desktop"
msgstr "பணிமேடை தொலையியக்கம் துவக்கப்பட்டது"

#: src/xdg-desktop-portal-kde.notifyrc:238
msgctxt "Comment"
msgid "An application gained control over your input and displays"
msgstr "உள்ளீட்டையும் திரைகளையும் கட்டுப்படுத்தும் அனுமதியை ஓர் செயலி பெற்றுள்ளது"

#: src/xdg-desktop-portal-kde.notifyrc:286
msgctxt "Name"
msgid "Input Capture Started"
msgstr "உள்ளீட்டு பிடிப்பு துவங்கியது"

#: src/xdg-desktop-portal-kde.notifyrc:320
msgctxt "Comment"
msgid "Input is now being managed by an application"
msgstr "உள்ளீட்டை ஓர் செயலி நிர்வகிக்கிறது"

