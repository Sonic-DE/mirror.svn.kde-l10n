#. (itstool) path: component/name
#: org.kde.plasma.disks.metainfo.xml:11
msgid "Plasma Disks"
msgstr "Plasma-diskar"

#. (itstool) path: component/summary
#: org.kde.plasma.disks.metainfo.xml:12
msgid "Hard disk health monitoring for KDE Plasma"
msgstr "Overvaking av harddisk-helse for KDE Plasma"

#. (itstool) path: description/p
#: org.kde.plasma.disks.metainfo.xml:14
msgid ""
"Plasma Disks monitors S.M.A.R.T. data of disks and alerts the user when "
"signs of imminent failure appear."
msgstr ""
"Plasma Disks overvaker S.M.A.R.T.-data på harddiskar og varslar brukaren når "
"det finst teikn på nærleg havari."

