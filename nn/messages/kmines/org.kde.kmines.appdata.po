#. (itstool) path: component/summary
#: org.kde.kmines.appdata.xml:10
msgid "Minesweeper-like Game"
msgstr "Minesveipar-liknande spel"

#. (itstool) path: description/p
#: org.kde.kmines.appdata.xml:12
msgid ""
"KMines is a classic Minesweeper game. The idea is to uncover all the squares "
"without blowing up any mines. When a mine is blown up, the game is over."
msgstr ""
"KMinesveipar er eit klassisk minesveiparspel. Målet er å avdekkja alle ruter "
"som ikkje har miner på seg. Treff du derimot på ei rute med ei mine, går "
"mina av og du tapar spelet."
