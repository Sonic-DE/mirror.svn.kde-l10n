#. (itstool) path: component/name
#: org.kde.kiten.appdata.xml:10
msgid "Kiten"
msgstr "Kiten"

#. (itstool) path: component/summary
#: org.kde.kiten.appdata.xml:11
msgid "Japanese Reference and Study Tool"
msgstr "Språk- og studieverktøy for japansk"

#. (itstool) path: description/p
#: org.kde.kiten.appdata.xml:13
msgid ""
"Kiten is a Japanese reference and study tool. It features an English to "
"Japanese and Japanese to English dictionary, as well as a Kanji dictionary. "
"For the Kanji dictionary there are multiple ways supported to look up "
"characters."
msgstr ""
"Kiten er språk- og studieverktøy for japansk. Det inneheld ei ordliste med "
"tovegs omsetjing mellom engelsk og japansk, samt ei Kanji-ordliste. I Kanji-"
"ordliste kan du slå opp teikn på fleire ulike måtar."

#. (itstool) path: screenshot/caption
#: org.kde.kiten.appdata.xml:21
msgid "Practicing Japanese dictionary with Kiten"
msgstr "Studerer japansk ordliste med Kiten"

#. (itstool) path: screenshot/caption
