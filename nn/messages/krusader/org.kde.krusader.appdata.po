msgstr "Funksjonar:"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:16
msgid "Extensive archive handling"
msgstr "Omfattande støtte for filarkiv"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:17
msgid "Mounted filesystem support"
msgstr "Støtte for monterte filsystem"

#. (itstool) path: ul/li
