msgid "File Manager"
msgstr "Filhandsamar"

#. (itstool) path: description/p
#: org.kde.krusader.appdata.xml:13
msgid ""
"Krusader is an advanced twin panel (commander style) file manager for KDE "
"Plasma and other desktops in the *nix world"
msgstr ""
"Krusader er ein avansert filhandsamar med topanelsutforming for KDE Plasma "
"og skrivebordsmiljø i *nix-verda"

