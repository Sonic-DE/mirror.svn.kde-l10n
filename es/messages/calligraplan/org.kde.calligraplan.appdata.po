#. (itstool) path: component/name
#: org.kde.calligraplan.appdata.xml:7
msgid "Plan"
msgstr "Plan"

#. (itstool) path: component/summary
#: org.kde.calligraplan.appdata.xml:8
msgid "Project Management"
msgstr "Gestor de proyectos"

#. (itstool) path: description/p
#: org.kde.calligraplan.appdata.xml:10
msgid ""
"Plan is a project management application. It is intended for managing "
"moderately large projects with multiple resources."
msgstr ""
"Plan es una aplicación para gestionar proyectos. Está enfocada a la gestión "
"de proyectos moderadamente grandes con varios recursos."

#. (itstool) path: description/p
#: org.kde.calligraplan.appdata.xml:13
msgid "Features:"
msgstr "Funcionalidades:"

#. (itstool) path: ul/li
#: org.kde.calligraplan.appdata.xml:15
msgid "Multiple views: Gant Charts, Resource View, Accounts View"
msgstr "Varias vistas: diagramas de Gant, Vista de recursos, vista de cuentas"

#. (itstool) path: ul/li
#: org.kde.calligraplan.appdata.xml:16
msgid ""
"Uses standard structures: Work breakdown structure (WBS), Resource breakdown "
"structure (RBS), Cost breakdown structure (CBS)"
msgstr ""
"Utiliza estructuras estándar: estructura de desglose del trabajo (WBS), "
"estructura de desglose de los recursos (RBS), estructura de desglose de los "
"costes (CBS)"

#. (itstool) path: ul/li
#: org.kde.calligraplan.appdata.xml:17
msgid "Configurable level of detail on Gantt Chart"
msgstr "Nivel de detalles configurable en el diagrama de Gantt"

#. (itstool) path: ul/li
#: org.kde.calligraplan.appdata.xml:18
msgid "Supports Summarytasks, Tasks, and milestones"
msgstr "Permite el uso de tareas de resumen, tareas e hitos"

#. (itstool) path: ul/li
#: org.kde.calligraplan.appdata.xml:19
msgid "Configurable Scheduling Constraints"
msgstr "Restricciones de planificación configurables"

#. (itstool) path: description/p
#: org.kde.calligraplan.appdata.xml:38
msgid "Fix version in the cmake"
msgstr "Se ha corregido la versión en el cmake."

