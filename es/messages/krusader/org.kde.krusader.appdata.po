#. (itstool) path: component/summary
#: org.kde.krusader.appdata.xml:8
msgid "File Manager"
msgstr "Gestor de archivos"

#. (itstool) path: description/p
#: org.kde.krusader.appdata.xml:13
msgid ""
"Krusader is an advanced twin panel (commander style) file manager for KDE "
"Plasma and other desktops in the *nix world"
msgstr ""
"Krusader es un gestor de archivos avanzado con paneles gemelos (al estilo de "
"commander) para KDE Plasma y otros escritorios del mundo *nix"

