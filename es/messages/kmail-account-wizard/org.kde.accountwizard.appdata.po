#. (itstool) path: component/name
#: org.kde.accountwizard.appdata.xml:9
msgid "Account Wizard"
msgstr "Asistente de cuentas"

#. (itstool) path: component/summary
#: org.kde.accountwizard.appdata.xml:10
msgid "Configure accounts"
msgstr "Configurar cuentas"

#. (itstool) path: description/p
#: org.kde.accountwizard.appdata.xml:12
msgid ""
"Accountwizard allows to edit, create, delete accounts. Accountwizard "
"supports IMAP/POP3/Kolab account type. Account information can be found by "
"using ispd service."
msgstr ""
"El asistente de cuentas le permite crear, modificar y borrar cuentas. "
"Permite usar cuentas de tipo IMAP, POP3 y Kolab. La información sobre la "
"cuenta se puede encontrar usando el servicio ispd."

#~ msgid "Accountwizard allows to edit, create, delete accounts."
#~ msgstr "Este asistente permite crear, modificar y borrar cuentas."
