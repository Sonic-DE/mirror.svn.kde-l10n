#. (itstool) path: component/name
#: org.kde.kalk.appdata.xml:12
msgid "Calculator"
msgstr "Calculadora"

#. (itstool) path: component/summary
#: org.kde.kalk.appdata.xml:13
msgid "A feature rich calculator"
msgstr "Una calculadora con numerosas funciones"

#. (itstool) path: description/p
#: org.kde.kalk.appdata.xml:18
msgid "Kalk is a convergent calculator for Plasma."
msgstr "Kalk es una calculadora convergente para Plasma."

#. (itstool) path: screenshot/caption
#: org.kde.kalk.appdata.xml:22
msgid "Calculator Page"
msgstr "Página de la calculadora"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:95
msgid "Show decimal separator according to locale"
msgstr "Mostrar el separador decimal según la configuración regional"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:96
msgid "Fix bug preventing input of comma"
msgstr "Se ha corregido un error que impedía la entrada de comas."

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:104
msgid "General bugfixing and code quality improvements"
msgstr "Corrección de errores generales y mejoras en la calidad del código."

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:112
msgid "Rearrange trigonometric functions to be together"
msgstr ""
"Se han reorganizado las funciones trigonométricas para que estén juntas."

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:113
msgid "Various user-interface improvements"
msgstr "Varias mejoras de la interfaz de usuario"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:120
msgid "Rework sidebar design"
msgstr "Se ha rediseñado la barra lateral."

#. (itstool) path: description/p
#: org.kde.kalk.appdata.xml:133
msgid "Changes:"
msgstr "Cambios:"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:135
msgid "Updated the application icon"
msgstr "Se ha actualizado el icono de la aplicación"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:136
msgid "Added support for parentheses keyboard input"
msgstr ""
"Se ha añadido compatibilidad para la entrada de paréntesis con el teclado."

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:137
msgid "Fixed the calculator drawer opening when the application opens"
msgstr ""
"Se ha corregido la apertura del cajón de la calculadora cuando se abre la "
"aplicación."

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:138
msgid ""
"Changed backspace icon to use a proper system icon instead of a font "
"provided one"
msgstr ""
"Se ha modificado el icono de retroceso para usar un icono del sistema "
"adecuado en lugar de uno proporcionado por una fuente."

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:139
msgid "Added keyboard support to unit converter"
msgstr "Se ha añadido compatibilidad con el teclado al conversor de unidades."

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:140
msgid "Fixed page change animation for binary calculator"
msgstr "Animación de cambio de página fija para la calculadora binaria."

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:141
msgid "Enabled qml debugging when compiled in debug mode"
msgstr ""
"Se ha activado modo de depuración qml cuando se compila en modo de "
"depuración."

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:142
msgid "Added ability to recognize the decimal separator in other locales"
msgstr ""
"Se ha añadido la capacidad de reconocer el separador decimal en otras "
"configuraciones regionales."
