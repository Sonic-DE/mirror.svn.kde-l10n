#: org.kde.kjournaldbrowser.appdata.xml:14
msgid "Journald Browser"
msgstr "Explorador de Journald"

#. (itstool) path: component/summary
#: org.kde.kjournaldbrowser.appdata.xml:15
msgid "Browser for journald databases"
msgstr "Explorador de bases de datos de journald"

#. (itstool) path: description/p
#: org.kde.kjournaldbrowser.appdata.xml:17
msgid ""
"Journald-browser is a reference implementation of the kjournald library and "
"provides a flexible tool to browse in local, remote and offline journald "
"databases."
msgstr ""
"El explorador de journald es una implementación de referencia de la "
"biblioteca kjournald que proporciona una herramienta flexible para explorar "
"las bases de datos locales, remotas y sin conexión de journald."

