#. (itstool) path: component/name
#: org.kde.phonebook.metainfo.xml:4
msgid "Phonebook"
msgstr "Agenda telefónica"

#. (itstool) path: component/summary
#: org.kde.phonebook.metainfo.xml:5
msgid "View and edit contacts"
msgstr "Vea y edite sus contactos"

#. (itstool) path: component/developer_name
#: org.kde.phonebook.metainfo.xml:8
msgid "KDE Community"
msgstr "Comunidad KDE"

#. (itstool) path: description/p
#: org.kde.phonebook.metainfo.xml:10
msgid ""
"Convergent contact management application for both desktop and mobile "
"devices."
msgstr ""
"Aplicación convergente para la administración de contactos en el escritorio "
"y en dispositivos móviles."

#. (itstool) path: description/p
#: org.kde.phonebook.metainfo.xml:11
msgid ""
"It provides a central place for starting conversations. Depending on the "
"information available about a contact, respective actions are displayed."
msgstr ""
"Proporciona un lugar central para iniciar conversaciones. Dependiendo de la "
"información disponible de un contacto, se mostrarán las acciones "
"correspondientes."

