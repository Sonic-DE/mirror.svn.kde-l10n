#. (itstool) path: component/name
#: org.kde.kget.appdata.xml:9
msgid "KGet"
msgstr "KGet"

#. (itstool) path: component/summary
#: org.kde.kget.appdata.xml:10
msgid "Download manager"
msgstr "Gestor de descargas"

#. (itstool) path: description/p
#: org.kde.kget.appdata.xml:12
msgid "KGet is a versatile and user-friendly download manager."
msgstr "KGet es un gestor de descargas versátil y amigable."

#. (itstool) path: description/p
#: org.kde.kget.appdata.xml:15
msgid "Features:"
msgstr "Funcionalidades:"

#. (itstool) path: ul/li
#: org.kde.kget.appdata.xml:17
msgid "Downloading files from FTP and HTTP(S) sources."
msgstr "Descarga de archivos de fuentes FTP y HTTP(S)."

#. (itstool) path: ul/li
#: org.kde.kget.appdata.xml:18
msgid ""
"Pausing and resuming of downloading files, as well as the ability to restart "
"a download."
msgstr ""
"Pausa y reanudación de los archivos en descarga, así como la posibilidad de "
"reiniciar descargas."

#. (itstool) path: ul/li
#: org.kde.kget.appdata.xml:19
msgid "Tells lots of information about current and pending downloads."
msgstr ""
"Muestra gran cantidad de información sobre las descargas actuales y "
"pendientes."

#. (itstool) path: ul/li
#: org.kde.kget.appdata.xml:20
msgid "Embedding into system tray."
msgstr "Se puede empotrar en la bandeja del sistema."

#. (itstool) path: ul/li
#: org.kde.kget.appdata.xml:21
msgid "Integration with the Konqueror web browser."
msgstr "Integración con el navegador web Konqueror."

#. (itstool) path: ul/li
#: org.kde.kget.appdata.xml:22
msgid ""
"Metalink support which contain multiple URLs for downloads, along with "
"checksums and other information."
msgstr ""
"Permite usar Metalink, que contiene múltiples URL para las descargas, además "
"de sumas de verificación y otra información."

#. (itstool) path: screenshot/caption
#: org.kde.kget.appdata.xml:31
msgid "Downloading files with KGet"
msgstr "Descargando archivos con KGet"
