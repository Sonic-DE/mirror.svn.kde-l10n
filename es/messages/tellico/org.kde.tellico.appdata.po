"scripts externos"

#. (itstool) path: ul/li
#: org.kde.tellico.appdata.xml:30
msgid "Imports CDDB data for cataloging audio CDs"
msgstr "Importa datos CDDB para catalogar CD de audio"

#. (itstool) path: ul/li
