msgid "Network"
msgstr "Red"

#: modules/account/metadata.json
msgctxt "Description"
msgid "Allow the user to set the account name."
msgstr "Permitir que el usuario defina el nombre de la cuenta."

#: modules/cellular/metadata.json
msgctxt "Description"
msgid "Allow the user to configure the cellular network."
msgstr "Permitir que el usuario configure la red móvil."

#: modules/finished/metadata.json
msgctxt "Description"
msgid ""
"Shown when the initial system setup is completed, and the user can commit "
"the changes."
msgstr ""
"Se muestra cuando se completa la configuración inicial del sistema y el "
"usuario puede enviar los cambios."

#: modules/hostname/metadata.json
msgctxt "Description"
msgid "Allow the user to set the system hostname."
msgstr "Permitir que el usuario defina el nombre de máquina del sistema."

#: modules/keyboard/metadata.json
msgctxt "Description"
msgid "Allow the user to choose the keyboard layout."
msgstr "Permitir que el usuario escoja la distribución del teclado."

#: modules/language/metadata.json
msgctxt "Description"
msgid "Allow the user to set the system language."
msgstr "Permitir que el usuario defina el idioma del sistema."

#: modules/prepare/metadata.json
msgctxt "Description"
msgid "Allows the user to configure the environment before using it."
msgstr "Permitir que el usuario configure el entorno antes de usarlo."

#: modules/time/metadata.json
msgctxt "Description"
msgid "Allow the user to set the timezone."
msgstr "Permitir que el usuario defina la zona horaria."

#: modules/wifi/metadata.json
msgctxt "Description"
msgid "Allow the user to connect to a Wi-Fi network."
msgstr "Permitir que el usuario pueda conectarse a una red wifi."

