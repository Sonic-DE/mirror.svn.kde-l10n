#: core/smb4k.notifyrc:3 smb4k/org.kde.smb4k.desktop:3
msgctxt "Name"
msgid "Smb4K"
msgstr "Smb4K"

#: core/smb4k.notifyrc:44 smb4k/org.kde.smb4k.desktop:80
msgctxt "Comment"
msgid "Advanced Network Neighborhood Browser"
msgstr "Navegador de entorno de red avanzado"

#: core/smb4k.notifyrc:87
msgctxt "Name"
msgid "Notification"
msgstr "Notificación"

#: core/smb4k.notifyrc:128
msgctxt "Comment"
msgid "The user is notified about an action"
msgstr "Se notifica al usuario de una acción"

#: core/smb4k.notifyrc:169
msgctxt "Name"
msgid "Warning"
msgstr "Advertencia"

#: core/smb4k.notifyrc:210
msgctxt "Comment"
msgid "A warning is shown to the user"
msgstr "Se muestra una advertencia al usuario"

#: core/smb4k.notifyrc:252
msgctxt "Name"
msgid "Error"
msgstr "Error"

#: core/smb4k.notifyrc:293
msgctxt "Comment"
msgid "An error message is shown to the user"
msgstr "Se muestra un mensaje de error al usuario"

#: core/smb4k.notifyrc:333
msgctxt "Name"
msgid "Share mounted"
msgstr "Recurso compartido montado"

#: core/smb4k.notifyrc:371
msgctxt "Comment"
msgid "A share has been mounted"
msgstr "Se ha montado un recurso compartido"

#: core/smb4k.notifyrc:413
msgctxt "Name"
msgid "Share unmounted"
msgstr "Recurso compartido desmontado"

#: core/smb4k.notifyrc:451
msgctxt "Comment"
msgid "A share has been unmounted"
msgstr "Se ha desmontado un recurso compartido"

#: core/smb4k.notifyrc:493
msgctxt "Name"
msgid "Shares mounted"
msgstr "Recursos compartidos montados"

#: core/smb4k.notifyrc:531
msgctxt "Comment"
msgid "Multiple shares have been mounted"
msgstr "Se han montado varios recursos compartidos"

#: core/smb4k.notifyrc:573
msgctxt "Name"
msgid "Shares unmounted"
msgstr "Recursos compartidos desmontados"

#: core/smb4k.notifyrc:611
msgctxt "Comment"
msgid "Multiple shares have been unmounted"
msgstr "Se han desmontado varios recursos compartidos"

#: core/smb4k.notifyrc:653
msgctxt "Name"
msgid "Migrating login credentials"
msgstr "Migrando credenciales de inicio de sesión"

#: core/smb4k.notifyrc:682
msgctxt "Comment"
msgid ""
"The login credentials are migrated to the new format and the active password "
"manager"
msgstr ""
"Las credenciales de inicio de sesión son migradas al nuevo formato y al "
"gestor de contraseñas activo"

#: core/smb4k.notifyrc:714
msgctxt "Name"
msgid "Mimetype not supported"
msgstr "Tipo MIME no soportado"

#: core/smb4k.notifyrc:752
msgctxt "Comment"
msgid "The mimetype of the file that is to be printed is not supported"
msgstr "El tipo MIME del archivo a imprimir no está soportado"

#: core/smb4k.notifyrc:794
msgctxt "Name"
msgid "Bookmark exists"
msgstr "Marcador existente"

#: core/smb4k.notifyrc:832
msgctxt "Comment"
msgid "The bookmark exists"
msgstr "El marcador ya existe"

#: core/smb4k.notifyrc:875
msgctxt "Name"
msgid "Bookmark label in use"
msgstr "Etiqueta de marcador en uso"

#: core/smb4k.notifyrc:913
msgctxt "Comment"
msgid "The label for the bookmark already exists"
msgstr "La etiqueta del marcador ya existe"

#: core/smb4k.notifyrc:956
msgctxt "Name"
msgid "Mounting failed"
msgstr "Montaje fallido"

#: core/smb4k.notifyrc:995
msgctxt "Comment"
msgid "Mounting a share failed"
msgstr "El montaje de un recurso compartido ha fallado"

#: core/smb4k.notifyrc:1038
msgctxt "Name"
msgid "Unmounting failed"
msgstr "Desmontaje fallido"

#: core/smb4k.notifyrc:1077
msgctxt "Comment"
msgid "Unmounting a share failed"
msgstr "El desmontaje de un recurso compartido ha fallado"

#: core/smb4k.notifyrc:1120
msgctxt "Name"
msgid "Unmounting not allowed"
msgstr "Desmontaje no permitido"

#: core/smb4k.notifyrc:1158
msgctxt "Comment"
msgid "The unmounting of a certain share is not allowed"
msgstr "El desmontaje de un cierto recurso compartido no está permitido"

#: core/smb4k.notifyrc:1201
msgctxt "Name"
msgid "Synchronization failed"
msgstr "Sincronización fallida"

#: core/smb4k.notifyrc:1240
msgctxt "Comment"
msgid "The synchronization of a share and a local copy failed"
msgstr ""
"La sincronización de un recurso compartido y una copia local ha fallado"

#: core/smb4k.notifyrc:1282
msgctxt "Name"
msgid "Command not found"
msgstr "Orden no encontrada"

#: core/smb4k.notifyrc:1322
msgctxt "Comment"
msgid "A required command could not be found"
msgstr "No se ha podido encontrar una orden necesaria"

#: core/smb4k.notifyrc:1365
msgctxt "Name"
msgid "Cannot bookmark printer"
msgstr "No se puede añadir una impresora como marcador"

#: core/smb4k.notifyrc:1403
msgctxt "Comment"
msgid "A printer cannot be bookmarked"
msgstr "Una impresora no se puede añadir como marcador"

#: core/smb4k.notifyrc:1446
msgctxt "Name"
msgid "File not found"
msgstr "Archivo no encontrado"

#: core/smb4k.notifyrc:1487
msgctxt "Comment"
msgid "A file could not be found"
msgstr "No se ha podido encontrar un archivo"

#: core/smb4k.notifyrc:1530
msgctxt "Name"
msgid "Opening file failed"
msgstr "Apertura de archivo fallida"

#: core/smb4k.notifyrc:1568
msgctxt "Comment"
msgid "A file could not be opened"
msgstr "No se ha podido abrir un archivo"

#: core/smb4k.notifyrc:1611
msgctxt "Name"
msgid "Reading file failed"
msgstr "Lectura de archivo fallida"

#: core/smb4k.notifyrc:1649
msgctxt "Comment"
msgid "A file could not be read"
msgstr "No se ha podido leer un archivo"

#: core/smb4k.notifyrc:1692
msgctxt "Name"
msgid "mkdir failed"
msgstr "mkdir falló"

#: core/smb4k.notifyrc:1731
msgctxt "Comment"
msgid "A directory could not be created"
msgstr "No se ha podido crear un directorio"

#: core/smb4k.notifyrc:1774
msgctxt "Name"
msgid "Process error"
msgstr "Error de proceso"

#: core/smb4k.notifyrc:1814
msgctxt "Comment"
msgid "A process error occurred"
msgstr "Ha ocurrido un error en un proceso"

#: core/smb4k.notifyrc:1857
msgctxt "Name"
msgid "Action failed"
msgstr "Acción fallida"

#: core/smb4k.notifyrc:1897
msgctxt "Comment"
msgid "A KAuth action failed"
msgstr "Una acción de KAuth ha fallado"

#: core/smb4k.notifyrc:1939
msgctxt "Name"
msgid "Invalid URL"
msgstr "URL no válido"

#: core/smb4k.notifyrc:1980
msgctxt "Comment"
msgid "An invalid URL was passed"
msgstr "Se ha pasado un URL no válido"

#: core/smb4k.notifyrc:2022
msgctxt "Name"
msgid "Network communication failed"
msgstr "Ha fallado la comunicación de red"

#: core/smb4k.notifyrc:2057
msgctxt "Comment"
msgid "A network related action could not be performed or failed"
msgstr ""
"Una acción relacionada con la red no se ha podido ejecutar o ha fallado"

#: core/smb4k.notifyrc:2097
msgctxt "Name"
msgid "Zeroconf error"
msgstr "Error de Zeroconf"

#: core/smb4k.notifyrc:2130
msgctxt "Comment"
msgid "An error with the Zeroconf daemon occurred"
msgstr "Ha ocurrido un error con el demonio de Zeroconf"

#: core/smb4k.notifyrc:2167
msgctxt "Name"
msgid "Keychain error"
msgstr "Error de llavero"

#: core/smb4k.notifyrc:2196
msgctxt "Comment"
msgid ""
"An error occurred while reading the login credentials from the secure storage"
msgstr ""
"Ocurrió un error al leer las credenciales de inicio de sesión desde el "
"almacenaje seguro"

#: helpers/smb4kmounthelper.actions:2
msgctxt "Name"
msgid "Mount action"
msgstr "Acción de montaje"

#: helpers/smb4kmounthelper.actions:39
msgctxt "Description"
msgid "Mounts a share"
msgstr "Monta un recurso compartido"

#: helpers/smb4kmounthelper.actions:80
msgctxt "Name"
msgid "Unmount action"
msgstr "Acción de desmontaje"

#: helpers/smb4kmounthelper.actions:117
msgctxt "Description"
msgid "Unmounts a share"
msgstr "Desmonta un recurso compartido"

#: smb4k/org.kde.smb4k.desktop:44
msgctxt "GenericName"
msgid "Advanced Network Browser for SAMBA"
msgstr "Navegador de red avanzado para SAMBA"
