#. (itstool) path: component/name
#: org.kde.kbackup.appdata.xml:6
msgid "KBackup"
msgstr "KBackup"

#. (itstool) path: component/summary
#: org.kde.kbackup.appdata.xml:7
msgid "Create backups as .tar files to a local folder or remote URL"
msgstr ""
"Crear copias de seguridad como archivos .tar en una carpeta local o URL "
"remota"

#. (itstool) path: description/p
#: org.kde.kbackup.appdata.xml:9
msgid ""
"KBackup is an application which lets you back up your data in a simple, user "
"friendly way"
msgstr ""
"KBackup es una aplicación que le permite hacer copias de seguridad de sus "
"datos de una manera sencilla y fácil de usar"

#. (itstool) path: description/p
#: org.kde.kbackup.appdata.xml:12
msgid "Features:"
msgstr "Características:"

#. (itstool) path: ul/li
#: org.kde.kbackup.appdata.xml:14
msgid ""
"Using profile files with definitions for Folders and files to be included or "
"excluded from the backup"
msgstr ""
"Use perfiles con definiciones para las carpetas y archivos a ser incluidos o "
"excluidos de la copia de seguridad"

#. (itstool) path: ul/li
#: org.kde.kbackup.appdata.xml:15
msgid ""
"The backup target can be either a locally mounted device like a ZIP drive, "
"USB stick, etc. or any remote URL"
msgstr ""
"El objetivo de la copia de seguridad puede ser un dispositivo montado "
"localmente como una memoria USB, una unidad ZIP, etc; o cualquier URL remota"

#. (itstool) path: ul/li
#: org.kde.kbackup.appdata.xml:16
msgid "Running automated backups without using a graphical user interface"
msgstr ""
"Ejecución automática de copias de seguridad sin usar una interfaz gráfica de "
"usuario"
