#. (itstool) path: component/name
#: org.kde.skanlite.appdata.xml:10
msgid "Skanlite"
msgstr "Skanlite"

#. (itstool) path: component/summary
#: org.kde.skanlite.appdata.xml:11
msgid "Image Scanning Application"
msgstr "Aplicación para escanear imágenes"

#. (itstool) path: description/p
#: org.kde.skanlite.appdata.xml:13
msgid ""
"Skanlite is a simple image scanning application to scan and save images. It "
"is optimized for scanning with flatbed scanners. Skanlite can capture not "
"only photos and documents, but also transparent slides and filmstrips, with "
"supported scanners."
msgstr ""
"Skanlite es una sencilla aplicación para escanear y guardar imágenes. Está "
"optimizada para escáneres de cama plana. Además de fotos y documentos, "
"Skanlite puede escanear diapositivas y filminas con los escáneres admitidos."

#. (itstool) path: description/p
#: org.kde.skanlite.appdata.xml:17
msgid "Features:"
msgstr "Características:"

#. (itstool) path: ul/li
#: org.kde.skanlite.appdata.xml:19
msgid ""
"Save dialog for every image scanned or saving the images immediately in a "
"specified folder with auto-generated names and format"
msgstr ""
"Diálogo para guardar las imágenes escaneadas o para guardarlas "
"inmediatamente en la carpeta indicada con nombres generados automáticamente "
"y en el formato indicado."

#. (itstool) path: ul/li
#: org.kde.skanlite.appdata.xml:20
msgid "Support for networks scanners"
msgstr "Permite el uso de escáneres en red."

#. (itstool) path: ul/li
#: org.kde.skanlite.appdata.xml:21
msgid "Preview with selection feature for the final scan"
msgstr "Vista previa con función de selección para el escaneo final."

#. (itstool) path: ul/li
#: org.kde.skanlite.appdata.xml:22
msgid "Scanning multiple selections of an image"
msgstr "Escanear múltiples selecciones de una imagen."

#. (itstool) path: screenshot/caption
#: org.kde.skanlite.appdata.xml:27
msgid "Skanlite's basic options screen with a scanned image visible"
msgstr "Pantalla de opciones básicas de Skanlite con una imagen escaneada"
