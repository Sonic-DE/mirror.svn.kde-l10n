msgid "A colorful tileset designed for kids of all ages."
msgstr "Fichas llenas de color diseñadas para niños de todas las edades."

#: tilesets/bamboo.desktop:2
msgctxt "Name"
msgid "Bamboo"
msgstr "Bambú"

#: tilesets/bamboo.desktop:55
msgctxt "Description"
msgid "Japanese tileset with brightly-colored kanji on a soft woodgrain"
msgstr "Fichas japonesas con kanjis de brillantes colores sobre madera clara"

#: tilesets/classic.desktop:2
msgctxt "Name"
msgid "Classic"
msgstr "Clásico"

#: tilesets/classic.desktop:65
msgctxt "Description"
msgid "Chinese tileset, inspired by the classic version shipped with KDE 3"
msgstr "Fichas chinas, inspiradas en la versión clásica incluida con KDE 3"

#: tilesets/default.desktop:68
msgctxt "Description"
msgid "Art inspired by real Japanese Mahjongg tiles"
msgstr "Arte inspirado en las fichas del auténtico Mahjongg japonés"

#: tilesets/egypt.desktop:2
