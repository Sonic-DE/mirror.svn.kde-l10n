#. (itstool) path: component/name
#: org.kde.liquidshell.appdata.xml:4
msgid "liquidshell"
msgstr "liquidshell"

#. (itstool) path: component/summary
#. (itstool) path: description/p
#: org.kde.liquidshell.appdata.xml:5 org.kde.liquidshell.appdata.xml:10
msgid "liquidshell is an alternative to plasmashell"
msgstr "liquidshell es una alternativa a plasmashell"

#. (itstool) path: description/p
#: org.kde.liquidshell.appdata.xml:11
msgid ""
"It does not use QtQuick but instead relies on QtWidgets, therefore no "
"hardware graphics acceleration is needed."
msgstr ""
"No usa QtQuick, sino que se basa en QtWidgets, por lo que no se necesita "
"aceleración de gráficos por hardware."

#. (itstool) path: description/p
#: org.kde.liquidshell.appdata.xml:13
msgid "Main Features:"
msgstr "Funciones principales:"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:15
msgid "Wallpaper per virtual desktop"
msgstr "Fondo de pantalla por escritorio virtual"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:16
msgid "No animations, no CPU hogging, low Memory footprint"
msgstr "Sin animaciones, no acapara la CPU, bajo impacto en la memoria"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:17
msgid "Instant startup"
msgstr "Inicio instantáneo"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:18
msgid "No use of activities"
msgstr "No se usan las actividades"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:19
msgid "QtWidgets based, therefore follows widget style from systemsettings"
msgstr "Basado en QtWidgets, por lo que sigue el estilo de widgets del sistema"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:20
msgid ""
"Icons are used from your globally defined icon theme from systemsettings"
msgstr ""
"Usa iconos del tema definido globalmente en las preferencias del sistema"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:21
msgid ""
"Colors are used from your globally defined color theme from systemsettings"
msgstr ""
"Usa colores del tema definido globalmente en las preferencias del sistema"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:22
msgid ""
"Can additionally be styled with css by passing the commandline option -"
"stylesheet filename.css (see included example stylesheet.css)"
msgstr ""
"Puede usar estilos adicionales con CSS mediante la opción de la línea de "
"órdenes «-stylesheet archivo.css» (consulte el ejemplo incluido stylesheet."
"css)"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:23
msgid ""
"uses existing KDE dialogs for most configurations, e.g. StartMenu, Virtual "
"Desktops, Bluetooth, Network"
msgstr ""
"Usa los diálogos de KDE existentes para la mayoría de las configuraciones, "
"como menú de inicio, escritorios virtuales, Bluetooth y red"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:24
msgid "One bottom DesktopPanel"
msgstr "Un panel de escritorio inferior"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:25
msgid "Desktop Applets"
msgstr "Miniaplicaciones de escritorio"

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:43
msgid "Added install options (sleep/shutdown after install)"
msgstr ""
"Se han añadido opciones de instalación (suspender/apagar después de la "
"instalación)."

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:44
msgid "Improved EULA handling on package installation"
msgstr "Manejo mejorado del EULA en la instalación de paquetes."

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:45
msgid "Added long format of time and date display to calendar popup"
msgstr ""
"Se ha añadido un formato largo de visualización de fecha y hora a la ventana "
"emergente del calendario."

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:46
msgid "Create default folder for storing quicklaunch apps"
msgstr ""
"Crear una carpeta predeterminada para almacenar aplicaciones de inicio "
"rápido."

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:47
msgid "SysLoad widget width depends on CPU count"
msgstr ""
"La anchura del widget de la carga del sistema depende del número de CPU."

#. (itstool) path: ul/li
#. (itstool) path: description/p
#: org.kde.liquidshell.appdata.xml:48 org.kde.liquidshell.appdata.xml:54
msgid "Bugfixes and adjustments to newer KDE components"
msgstr ""
"Corrección de errores y ajustes para los componentes de KDE más recientes."

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:60
msgid "Notifications show how long they remain open (small animation)"
msgstr ""
"Las notificaciones muestran el tiempo que permanecerán abiertas (con una "
"pequeña animación)."

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:61
msgid "Weather Applet shows moon phase"
msgstr "La miniaplicación meteorológica muestra la fase lunar."

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:62
msgid "Disk Usage Applet watches for mount/unmount to react quicker for update"
msgstr ""
"La miniaplicación de uso del disco vigila los montajes y los desmontajes "
"para reaccionar rápidamente cuando se produzcan."

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:63
msgid "Display improvements in software updates component"
msgstr ""
"Mejoras de visualización en el componente de actualizaciones de software."

#. (itstool) path: ul/li
#: org.kde.liquidshell.appdata.xml:64
msgid ""
"Added DBUS-Menu support (some apps don't provide own menu but only via DBUS, "
"e.g. MS teams)"
msgstr ""
"Se ha añadido compatibilidad con DBUS-Menu (algunas aplicaciones no "
"proporcionan un menú propio, aunque sí mediante DBUS, como MS Teams)."
