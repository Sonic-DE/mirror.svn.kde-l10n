#: org.kde.arianna.appdata.xml:14
msgid ""
"An ebook reader and library management app supporting \".epub\" files. "
"Arianna discovers your books automatically, and sorts them by categories, "
"genres and authors."
msgstr ""
"Un lector de eBook y aplicación de gestión de biblioteca compatible con "
"archivos «.epub». Arianna descubre sus libros automáticamente y los ordena "
"por categorías, géneros y autores."

