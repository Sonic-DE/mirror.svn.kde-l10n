#: plugins/datenums/datenums.json
msgctxt "Description"
msgid ""
"For each day this plugin shows its daynumber of the year at the top of the "
"agenda view. For example, February 1 is day 32 of the year."
msgstr ""
"Para cada día, este complemento muestra el número de día del año en la parte "
"superior de la vista de agenda. Por ejemplo, el 1 de febrero es el día 32 "
"del año."

#: plugins/hebrew/hebrew.json
msgctxt "Description"
msgid "Shows all dates in KOrganizer also in the Jewish calendar system."
msgstr ""
"Muestra todas las fechas de KOrganizer también en el sistema de calendario "
"hebreo."

#: plugins/lunarphases/lunarphases.json
msgctxt "Description"
msgid "This plugin shows the day's lunar phase (New, First, Last, Full)"
msgstr ""
"Este complemento muestra la fase lunar del día (nueva, creciente, llena, "
"menguante)"

#: plugins/picoftheday/picoftheday.json
msgctxt "Description"
