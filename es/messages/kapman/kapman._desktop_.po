#: src/org.kde.kapman.desktop:4
msgctxt "Name"
msgid "Kapman"
msgstr "Kapman"

#: src/org.kde.kapman.desktop:63
msgctxt "GenericName"
msgid "Pac-Man Clone"
msgstr "Clon de Pac-Man"

#: src/org.kde.kapman.desktop:117
msgctxt "Comment"
msgid "Eat pills escaping ghosts"
msgstr "Come píldoras para escapar de los fantasmas"

#: themes/invisible.desktop:2
msgctxt "Name"
msgid "Invisible"
msgstr "Invisible"

#: themes/invisible.desktop:59
msgctxt "Description"
msgid ""
"Getting bored with Kapman? More than 100,000 points over level 20? Next "
"step: the invisible maze!"
msgstr ""
"¿Te aburres con Kapman? ¿Has conseguido más de 100.000 puntos en el nivel "
"20? Siguiente paso: ¡el laberinto invisible!"

#: themes/matches.desktop:2
msgctxt "Name"
msgid "Matches"
msgstr "Cerillas"

#: themes/matches.desktop:59
msgctxt "Description"
msgid "A matches drawn maze"
msgstr "Un laberinto dibujado con cerillas"

#: themes/mountain.desktop:2
msgctxt "Name"
msgid "Mountain Adventure"
msgstr "Aventura de montaña"

#: themes/mountain.desktop:55
msgctxt "Description"
msgid "Default"
msgstr "Predeterminado"

#: themes/mummies_crypt.desktop:2
msgctxt "Name"
msgid "Mummies Crypt"
msgstr "La cripta de las momias"

#: themes/mummies_crypt.desktop:54
msgctxt "Description"
msgid "Avoid the mummies at all costs!"
msgstr "¡Evita las momias a toda costa!"

#: themes/retro.desktop:2
msgctxt "Name"
msgid "Retro"
msgstr "Retro"

#: themes/retro.desktop:58
