#: org.kde.pix.appdata.xml:7
msgid "Pix"
msgstr "Pix"

#. (itstool) path: component/summary
#: org.kde.pix.appdata.xml:8
msgid "Image Gallery"
msgstr "Galería de imágenes"

#. (itstool) path: description/p
#: org.kde.pix.appdata.xml:14
msgid ""
"Pix is an image gallery and image viewer. Pix can be used to open images "
"with other applications like an image editor, add tags to the files, add "
"annotations to pictures, rotate and share them."
msgstr ""
"Pix es una galería de imágenes y visor de imágenes. Se puede usar Pix para "
"abrir imágenes con otras aplicaciones como editores de imágenes, añadir "
"etiquetas a los archivos, añadir anotaciones a las imágenes, rotarlas y "
"compartirlas."

