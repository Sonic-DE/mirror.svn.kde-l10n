#. (itstool) path: component/name
#: org.kde.ktechlab.appdata.xml:11
msgid "KTechlab"
msgstr "KTechlab"

#. (itstool) path: component/summary
#: org.kde.ktechlab.appdata.xml:12
msgid "IDE for microcontrollers and electronics"
msgstr "IDE para microcontroladores y sistemas electrónicos"

#. (itstool) path: description/p
#: org.kde.ktechlab.appdata.xml:14
msgid ""
"KTechlab is an IDE for microcontrollers and electronics designed to be as "
"easy to use and unintrusive as possible."
msgstr ""
"KTechlab es un entorno de desarrollo integrado para microcontroladores y "
"electrónica diseñado para que sea fácil de usar y lo menos intrusivo posible."

#. (itstool) path: description/p
#: org.kde.ktechlab.appdata.xml:17
msgid "Features:"
msgstr "Funciones:"

#. (itstool) path: ul/li
#: org.kde.ktechlab.appdata.xml:19
msgid "Wide range of components with editable characteristics"
msgstr "Amplio abanico de componentes con características editables"

#. (itstool) path: ul/li
#: org.kde.ktechlab.appdata.xml:20
msgid "Visual editor for circuits"
msgstr "Editor de circuitos visual"

#. (itstool) path: ul/li
#: org.kde.ktechlab.appdata.xml:21
msgid "Context help for the components"
msgstr "Ayuda de contexto para los componentes"

#. (itstool) path: ul/li
#: org.kde.ktechlab.appdata.xml:22
msgid "Two modes of connector routing: automatic and manual"
msgstr "Dos modos de rutas de conectores: automático y manual"

#. (itstool) path: ul/li
#: org.kde.ktechlab.appdata.xml:23
msgid ""
"Several ways to define the PIC logic: assembly code, Microbe (own high level "
"programming language) code, C code, and visual FlowCode"
msgstr ""
"Diversos modos de definir la lógica del PIC: código ensamblador, código "
"Microbe (lenguaje de programación propio de alto nivel), código C y FlowCode "
"visual"

#. (itstool) path: ul/li
#: org.kde.ktechlab.appdata.xml:24
msgid "Interconversion of the programming code between supported languages"
msgstr ""
"Conversión interna del código de programación entre los lenguajes permitidos"

#. (itstool) path: ul/li
#: org.kde.ktechlab.appdata.xml:25
msgid "Inbuilt debugger"
msgstr "Depurador integrado"

#. (itstool) path: ul/li
#: org.kde.ktechlab.appdata.xml:26
msgid "Simulation with oscilloscope and probes"
msgstr "Simulación con osciloscopio y sondas"

#. (itstool) path: ul/li
#: org.kde.ktechlab.appdata.xml:27
msgid "Uploading the assembly code to PIC using hardware programmer"
msgstr "Envío del código ensamblador al PIC usando el programador hardware"

#. (itstool) path: description/p
#: org.kde.ktechlab.appdata.xml:41
msgid ""
"This release should compile and run on systems where KDELibs4Support "
"libraries are not available."
msgstr ""
"Esta versión debe poderse compilar y ejecutar en sistemas donde no están "
"disponibles las bibliotecas KDELibs4Support."
