#. (itstool) path: component/name
#: org.kde.telly-skout.appdata.xml:8
msgid "Telly Skout"
msgstr "Telly Skout"

#. (itstool) path: component/summary
#: org.kde.telly-skout.appdata.xml:9
msgid "A convergent Kirigami TV guide"
msgstr "Una guía de TV convergente de Kirigami"

#. (itstool) path: description/p
#: org.kde.telly-skout.appdata.xml:20
msgid ""
"Telly Skout is a convergent Kirigami TV guide. It shows the TV program for "
"your favorite channels from TV Spielfilm or an XMLTV file."
msgstr ""
"Telly Skout es una guía de TV convergente creada con Kirigami. Muestra los "
"programas de TV de sus canales favoritos de TV Spielfilm o de un archivo "
"XMLTV."

#. (itstool) path: screenshot/caption
#: org.kde.telly-skout.appdata.xml:24
msgid "Favorites"
msgstr "Favoritos"

#. (itstool) path: screenshot/caption
#: org.kde.telly-skout.appdata.xml:28
msgid "Select Favorites"
msgstr "Seleccionar favoritos"

#. (itstool) path: screenshot/caption
#: org.kde.telly-skout.appdata.xml:32
msgid "Sort Favorites"
msgstr "Ordenar favoritos"

#. (itstool) path: description/p
#: org.kde.telly-skout.appdata.xml:58 org.kde.telly-skout.appdata.xml:81
#: org.kde.telly-skout.appdata.xml:111 org.kde.telly-skout.appdata.xml:141
msgid "TV Spielfilm fetcher"
msgstr "Extractor de TV Spielfilm."

#. (itstool) path: ul/li
#: org.kde.telly-skout.appdata.xml:60
msgid "Fix \"Select Favorites\" page does not list channels."
msgstr ""
"Se ha corregido que la página «Seleccionar favoritos» no listara los canales."

#. (itstool) path: description/p
#: org.kde.telly-skout.appdata.xml:62 org.kde.telly-skout.appdata.xml:73
#: org.kde.telly-skout.appdata.xml:88 org.kde.telly-skout.appdata.xml:116
msgid "\"Favorites\" page"
msgstr "Página de «Favoritos»."

#. (itstool) path: ul/li
#: org.kde.telly-skout.appdata.xml:64
msgid "Add date selection."
msgstr "Añadir selección de fechas."

#. (itstool) path: ul/li
#: org.kde.telly-skout.appdata.xml:65
msgid "Improve handling of gaps/overlaps in the programs."
msgstr "Se ha mejorado el manejo de huecos/solapamientos de los programas."

#. (itstool) path: description/p
#: org.kde.telly-skout.appdata.xml:67
msgid "Add Android support."
msgstr "Se ha añadido compatibilidad con Android."

#. (itstool) path: ul/li
#: org.kde.telly-skout.appdata.xml:75
msgid "Show refetch button in top toolbar on mobile."
msgstr ""
"Mostrar el botón de volver a extraer en la barra de herramientas superior de "
"los móviles."

#. (itstool) path: ul/li
#: org.kde.telly-skout.appdata.xml:83
msgid "Fix program stop time before start time (missing programs)."
msgstr ""
"Se ha corregido la hora de finalización del programa anterior a la hora de "
"inicio del programa (programas ausentes)."

#. (itstool) path: ul/li
#: org.kde.telly-skout.appdata.xml:84
msgid "Fix program description with multiple paragraphs."
msgstr "Se ha corregido la descripción del programa con múltiples párrafos."

#. (itstool) path: ul/li
#: org.kde.telly-skout.appdata.xml:85
msgid "Fix program description with multiple names for one role."
msgstr ""
"Se ha corregido la descripción del programa con múltiples nombres para un "
"papel."

#. (itstool) path: ul/li
#: org.kde.telly-skout.appdata.xml:86
msgid "Fix programs could not be fetched for 123.tv."
msgstr "Se ha corregido que no se pudieran extraer programas de 123.tv."

#. (itstool) path: ul/li
#: org.kde.telly-skout.appdata.xml:90
msgid "Add refetch button."
msgstr "Se ha añadido un botón para volver a extraer."

#. (itstool) path: ul/li
#: org.kde.telly-skout.appdata.xml:91
msgid "Speed up program description update."
msgstr "Se ha acelerado la actualización de la descripción de los programas."

#. (itstool) path: ul/li
#: org.kde.telly-skout.appdata.xml:92
msgid "Wrap header text."
msgstr "Ajustar dinámicamente el texto de la cabecera."

#. (itstool) path: ul/li
#: org.kde.telly-skout.appdata.xml:93
msgid "Fix placeholder message not shown if no favorites selected."
msgstr ""
"Se ha corregido el mensaje de relleno que no se mostraba si no había "
"favoritos seleccionados."

#. (itstool) path: ul/li
#: org.kde.telly-skout.appdata.xml:94
msgid "Fix background does not fill program field completely."
msgstr ""
"Se ha corregido que el fondo no rellenase completamente el campo del "
"programa."

#. (itstool) path: description/p
#: org.kde.telly-skout.appdata.xml:96
msgid "\"Select Favorites\" page"
msgstr "Página «Seleccionar favoritos»."

#. (itstool) path: ul/li
#: org.kde.telly-skout.appdata.xml:98
msgid "Fix loading placeholder when loading channels."
msgstr ""
"Se ha corregido la carga del texto de relleno cuando se cargan canales."

#. (itstool) path: ul/li
#: org.kde.telly-skout.appdata.xml:113
msgid "Handle incorrect stop times."
msgstr "Contemplar los tiempos de parada incorrectos."

#. (itstool) path: ul/li
#: org.kde.telly-skout.appdata.xml:114
msgid "Enhance program description."
msgstr "Se ha mejorado la descripción del programa."

#. (itstool) path: ul/li
#: org.kde.telly-skout.appdata.xml:118
msgid "Show loading placeholder."
msgstr "Mostrar un texto de relleno de carga."

#. (itstool) path: ul/li
#: org.kde.telly-skout.appdata.xml:119
msgid "Enable dragging with mouse."
msgstr "Permitir que se pueda arrastrar con el ratón."

#. (itstool) path: description/p
#: org.kde.telly-skout.appdata.xml:121
msgid "Do not allow to remove favorites on the \"Sort Favorites\" page."
msgstr ""
"No permitir la eliminación de favoritos en la página «Ordenar favoritos»."

#. (itstool) path: description/p
#: org.kde.telly-skout.appdata.xml:122
msgid "Improve performance."
msgstr "Se ha mejorado el rendimiento."

#. (itstool) path: ul/li
#: org.kde.telly-skout.appdata.xml:143
msgid "Fix missing channel icons."
msgstr "Se han corregido los iconos de canal ausentes."

#. (itstool) path: ul/li
#: org.kde.telly-skout.appdata.xml:144
msgid "Fix missing programs if there is pagination."
msgstr "Se ha corregido los programas ausentes cuando existe paginación."

#. (itstool) path: ul/li
#: org.kde.telly-skout.appdata.xml:145
msgid "Fix missing programs around new year."
msgstr "Se ha corregido la ausencia de programas alrededor del año nuevo."

#. (itstool) path: ul/li
#: org.kde.telly-skout.appdata.xml:146
msgid "Fix time zone handling."
msgstr "Se ha corregido el manejo de la zona horaria."

#. (itstool) path: ul/li
#: org.kde.telly-skout.appdata.xml:147
msgid "Show simultaneous programs."
msgstr "Mostrar programas simultáneos."

#. (itstool) path: ul/li
#: org.kde.telly-skout.appdata.xml:148
msgid "Add setting for prefetch period."
msgstr "Se ha añadido un ajuste para el período de preextracción."

#. (itstool) path: description/p
#: org.kde.telly-skout.appdata.xml:150
msgid "Add user interface settings to configure the favorites view."
msgstr ""
"Se han añadido ajustes de la interfaz de usuario para configurar la vista de "
"favoritos."

#. (itstool) path: description/p
#: org.kde.telly-skout.appdata.xml:151
msgid "Improve performance (e.g. avoid unnecessary database access)."
msgstr ""
"Se ha mejorado el rendimiento (por ejemplo, para evitar accesos innecesarios "
"a la base de datos)."
