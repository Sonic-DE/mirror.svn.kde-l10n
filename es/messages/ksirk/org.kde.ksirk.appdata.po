#. (itstool) path: component/name
#: org.kde.ksirk.appdata.xml:10
msgid "KsirK"
msgstr "KsirK"

#. (itstool) path: component/summary
#: org.kde.ksirk.appdata.xml:11
msgid "World Domination Strategy Game"
msgstr "Juego de estrategia de dominación del mundo"

#. (itstool) path: description/p
#: org.kde.ksirk.appdata.xml:13
msgid ""
"KsirK is a computerized version of the well known strategic board game Risk. "
"The goal of the game is simply to conquer the world by attacking your "
"neighbors with your armies."
msgstr ""
"KsirK es una versión informatizada del conocido juego de estrategia Risk. El "
"objetivo del juego es conquistar el mundo usando ejércitos para atacar a los "
"vecinos."

#. (itstool) path: description/p
#: org.kde.ksirk.appdata.xml:17
msgid "Features:"
msgstr "Funciones:"

#. (itstool) path: ul/li
#: org.kde.ksirk.appdata.xml:19
msgid "Support for 1-6 human or computer (AI) players"
msgstr "Permite de 1 a 6 jugadores humanos o de la computadora (IA)"

#. (itstool) path: ul/li
#: org.kde.ksirk.appdata.xml:20
msgid "Multi-player gaming over a network"
msgstr "Juego multijugador a través de una red"

#. (itstool) path: ul/li
#: org.kde.ksirk.appdata.xml:21
msgid "You can easily create new skins with SVG graphics and the skin editor"
msgstr ""
"Se pueden crear nuevas pieles fácilmente con gráficos SVG y el editor de "
"pieles"

#. (itstool) path: ul/li
#: org.kde.ksirk.appdata.xml:22
msgid "Hot New Stuff support. You can easily download and install new skins"
msgstr "Se pueden descargar e instalar nuevas pieles con facilidad"
