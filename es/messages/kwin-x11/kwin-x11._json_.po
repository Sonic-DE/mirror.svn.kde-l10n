#: src/plugins/logout/package/metadata.json
msgctxt "Description"
msgid "Fade to the logout screen"
msgstr "Desvanecer al mostrar la pantalla de cierre de sesión"

#: src/plugins/magiclamp/metadata.json
msgctxt "Description"
msgid "Simulate a magic lamp when minimizing windows"
msgstr "Simular una lámpara mágica al minimizar las ventanas"

#: src/plugins/magnifier/metadata.json
msgctxt "Description"
msgid ""
"Magnify the section of the screen that is near the mouse cursor; activated "
"with a keyboard shortcut"
msgstr ""
"Ampliar la sección de la pantalla que está cerca del cursor del ratón; se "
"activa con un atajo de teclado"

#: src/plugins/maximize/package/metadata.json
msgctxt "Description"
msgid "Stretch windows when they are maximized or restored"
msgstr "Estirar las ventanas cuando se maximizan o se restauran"

#: src/plugins/minimizeall/package/metadata.json
msgctxt "Description"
msgid "Adds a shortcut to minimize and restore all windows"
msgstr ""
"Añade un atajo de teclado para minimizar y restaurar todas las ventanas"

#: src/plugins/mouseclick/metadata.json
msgctxt "Description"
msgid ""
"Creates an animation whenever a mouse button is clicked. This is useful for "
"screenrecordings/presentations. Activated with a keyboard shortcut"
msgstr ""
"Crea una animación cada vez que se pulsa un botón del ratón. Resulta útil "
"durante la grabación de la pantalla y las presentaciones. Se activa con un "
"atajo de teclado."

#: src/plugins/mousemark/metadata.json
msgctxt "Description"
msgid ""
"Allows you to draw lines on the desktop; activated with a keyboard shortcut"
msgstr ""
"Le permite dibujar líneas en el escritorio; se activa con un atajo de teclado"

#: src/plugins/outputlocator/metadata.json
msgctxt "Description"
msgid "Show screen names"
msgstr "Mostrar nombres de las pantallas"

#: src/plugins/overview/metadata.json
msgctxt "Description"
msgid ""
"Allows you to overview virtual desktops and windows; activated with a "
"keyboard shortcut"
msgstr ""
"Le permite mostrar una vista general de los escritorios virtuales y de las "
"ventanas; se activa con un atajo de teclado"

#: src/plugins/scale/package/metadata.json
msgctxt "Description"
msgid "Make windows scale in and out when they are shown or hidden"
msgstr "Hacer que las ventanas se escalen al mostrarlas y al ocultarlas"

#: src/plugins/screenedge/metadata.json
msgctxt "Description"
msgid ""
"Highlights screen edges and corners that trigger actions when touched as the "
"cursor approaches them"
msgstr ""
"Resalta los bordes y las esquinas de la pantalla que desencadenan acciones "
"cuando se tocan al aproximar el cursor"

#: src/plugins/screenshot/metadata.json
msgctxt "Description"
msgid "Helper effect for screenshot tools"
msgstr "Efecto auxiliar para las herramientas de captura de pantalla"

#: src/plugins/sessionquit/package/metadata.json
msgctxt "Description"
msgid "Keep the desktop background alive during logout until the end"
msgstr ""
"Mantener vivo el fondo del escritorio hasta el final durante el cierre de "
"sesión"

#: src/plugins/sheet/metadata.json
msgctxt "Description"
msgid ""
"Make modal dialogs smoothly fly in and out when they are shown or hidden"
msgstr ""
"Hace que los diálogos modales vuelen suavemente hacia adentro y hacia afuera "
"cuando se muestran u ocultan"

#: src/plugins/showfps/metadata.json
msgctxt "Description"
msgid "Display KWin's performance in the corner of the screen"
msgstr "Mostrar el rendimiento de KWin en una esquina de la pantalla"

#: src/plugins/showpaint/metadata.json
msgctxt "Description"
msgid ""
"Highlight areas of the desktop that have been recently updated; activated "
"with a keyboard shortcut"
msgstr ""
"Resaltar áreas del escritorio que se han actualizado recientemente; se "
"activa con un atajo de teclado"

#: src/plugins/slideback/metadata.json
msgctxt "Description"
msgid "Slide back windows when another window is raised"
msgstr ""
"Deslizar hacia atrás las ventanas cuando otra ventana pasa al primer plano"

#: src/plugins/slide/metadata.json
msgctxt "Description"
msgid "Slide between virtual desktops when switching"
msgstr "Deslizar los escritorios virtuales al cambiar entre ellos"

#: src/plugins/slidingpopups/metadata.json
msgctxt "Description"
msgid "Slide Plasma popups in and out"
msgstr "Deslizar las ventanas emergentes de Plasma al mostrarlas y ocultarlas"

#: src/plugins/squash/package/metadata.json
msgctxt "Description"
msgid "Squash windows when they are minimized"
msgstr "Aplastar las ventanas cuando se minimizan"

#: src/plugins/startupfeedback/metadata.json
msgctxt "Description"
msgid "Helper effect for startup feedback"
msgstr "Efecto auxiliar para la notificación de lanzamiento"

#: src/plugins/synchronizeskipswitcher/package/metadata.json
msgctxt "Description"
msgid ""
"Hides all windows marked as Skip Taskbar to be also excluded from window "
"switchers (e.g. Alt+Tab)"
msgstr ""
"Oculta todas las ventanas marcadas como «Omitir barra de tareas» para que "
"también se excluyan de los selectores de ventanas (por ejemplo, Alt+Tab)"

#: src/plugins/systembell/metadata.json
msgctxt "Description"
msgid "Provides the bell"
msgstr "Proporciona el timbre del sistema"

#: src/plugins/thumbnailaside/metadata.json
msgctxt "Description"
msgid ""
"Display window thumbnails on the edge of the screen; activated with a "
"keyboard shortcut"
msgstr ""
"Mostrar miniaturas de las ventanas en el borde de la pantalla; se activa con "
"un atajo de teclado"

#: src/plugins/tileseditor/metadata.json
msgctxt "Description"
msgid "Editor for the tiling areas"
msgstr "Editor para las áreas de mosaico"

#: src/plugins/trackmouse/metadata.json
msgctxt "Description"
msgid ""
"Display a mouse cursor locating effect; activated with a keyboard shortcut"
msgstr ""
"Muestra un efecto de localización del cursor del ratón; se activa con un "
"atajo de teclado"

#: src/plugins/translucency/package/metadata.json
msgctxt "Description"
msgid "Make windows translucent under different conditions"
msgstr "Hacer que las ventanas sean transparentes bajo distintas condiciones"

#: src/plugins/videowall/package/metadata.json
msgctxt "Description"
msgid ""
"Spans fullscreen video player over all attached screens to create a Video "
"Wall"
msgstr ""
"Amplía el reproductor de video en pantalla completa a todas las pantallas "
"conectadas para crear un muro de vídeo"

#: src/plugins/windowaperture/package/metadata.json
msgctxt "Description"
msgid "Move windows into screen corners"
msgstr "Mover las ventanas a las esquinas de la pantalla"

#: src/plugins/windowview/metadata.json
msgctxt "Description"
msgid "Zoom out until all opened windows can be displayed side-by-side"
msgstr ""
"Reducir hasta que todas las ventanas abiertas se puedan mostrar una al lado "
"de la otra"

#: src/plugins/wobblywindows/metadata.json
msgctxt "Description"
msgid "Deform windows while they are moving"
msgstr "Deformar las ventanas mientras se mueven"

#: src/plugins/zoom/metadata.json
msgctxt "Description"
msgid "Magnify the entire desktop; activated with a keyboard shortcut"
msgstr "Ampliar todo el escritorio; se activa con un atajo de teclado"

#: src/tabbox/switchers/thumbnail_grid/metadata.json
msgctxt "Description"
msgid "A window switcher layout using a small grid of thumbnails"
msgstr ""
"Un esquema de selector de ventanas que usa una pequeña cuadrícula de "
"miniaturas"

