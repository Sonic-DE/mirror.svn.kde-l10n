#. (itstool) path: component/name
#: org.kde.knights.appdata.xml:9
msgid "KNights"
msgstr "KNights"

#. (itstool) path: component/summary
#: org.kde.knights.appdata.xml:10
msgid "Chess game"
msgstr "Juego de ajedrez"

#. (itstool) path: description/p
#: org.kde.knights.appdata.xml:12
msgid ""
"KNights is a chess game. As a player, your goal is to defeat your opponent "
"by checkmating their king."
msgstr ""
"KNights es un juego de ajedrez. Como jugador, tu objetivo consiste en vencer "
"a tu oponente haciendo jaque mate a su rey."

#. (itstool) path: description/p
#: org.kde.knights.appdata.xml:15
msgid "Features:"
msgstr "Funciones:"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:17
msgid "Local play between two players on the same computer"
msgstr "Partida local entre dos jugadores en el mismo equipo"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:18
msgid "Play against any computer program that supports the XBoard protocol"
msgstr ""
"Jugar contra cualquier programa de computadora que use el protocolo XBoard"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:19
msgid "Play on the Free Internet Chess Server (FICS)"
msgstr "Jugar en el servidor de ajedrez libre de Internet (FICS)"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:20
msgid "Watching two computer engines play against each other"
msgstr "Observar cómo juegan dos programas de ajedrez entre sí"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:21
msgid "Support for legal move checking"
msgstr "Permite comprobar los movimientos legales"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:22
msgid "Markers for possible moves, opponent’s last move and sources of check"
msgstr ""
"Marcadores para posibles movimientos, último movimiento del oponente y "
"fuentes de jaque"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:23
msgid "Board borders and site notations"
msgstr "Bordes del tablero y notaciones del sitio"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:24
msgid "Complete time control, with Plasma-styled clocks"
msgstr "Completo control del tiempo, con paneles al estilo de Plasma"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:25
msgid ""
"Several themes, with the possibility of downloading new ones from within the "
"program"
msgstr ""
"Diversos temas, con la posibilidad de descargar otros nuevos desde el "
"programa"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:26
msgid "Animated moves (configurable)"
msgstr "Movimientos animados (configurables)"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:27
msgid ""
"Views for playing on a chess server, including a seek graph, text console, "
"and chat widget"
msgstr ""
"Visores para jugar en un servidor de ajedrez, incluidos un gráfico de "
"búsqueda, una consola de texto y una ventana de charla"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:28
msgid "Option to undo and redo moves"
msgstr "Opción para deshacer y rehacer movimientos"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:29
msgid "Graphic interface for making and receiving offers from remote players"
msgstr "Interfaz gráfica para hacer y recibir ofertas de jugadores remotos"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:30
msgid ""
"Support for the UCI protocol (used by Stockfish, Chessbase, and many others)"
msgstr "Permite usar el protocolo UCI (usado por Stockfish, Chessbase y otros)"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:31
msgid "Support for saving and loading Portable game notation (PGN) files"
msgstr "Permite guardar y cargar archivos de notación portable de juego (PGN)"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:32
msgid "Speak opponent’s moves"
msgstr "Leer los movimientos del oponente"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:33
msgid "Ability to control the program via a D-Bus interface"
msgstr "Posibilidad de controlar el programa a través de la interfaz D-Bus"

