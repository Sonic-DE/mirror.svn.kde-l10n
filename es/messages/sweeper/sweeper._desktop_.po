#: org.kde.sweeper.desktop:75
msgctxt "GenericName"
msgid "System Cleaner"
msgstr "Limpiador del sistema"

#: org.kde.sweeper.desktop:142
msgctxt "Comment"
msgid ""
"Helps to clean unwanted traces the user leaves on the system and to regain "
"disk space removing unused temporary files"
msgstr ""
"Ayuda a borrar el rastro no deseado que deja el usuario en el sistema y "
"permite ganar espacio en disco eliminando archivos temporales no usados"
