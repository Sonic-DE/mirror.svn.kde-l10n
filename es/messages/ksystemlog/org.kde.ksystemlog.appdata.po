msgstr "Vista en pestañas para poder mostrar varios registros a la vez"

#. (itstool) path: ul/li
#: org.kde.ksystemlog.appdata.xml:15
msgid "Auto display new lines logged"
msgstr "Muestra de forma automática las nuevas líneas registradas"

#. (itstool) path: ul/li
