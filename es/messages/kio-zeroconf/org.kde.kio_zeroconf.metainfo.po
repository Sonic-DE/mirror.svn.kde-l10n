msgid "Zeroconf Support"
msgstr "Implementación de Zeroconf"

#. (itstool) path: component/summary
#: org.kde.kio_zeroconf.metainfo.xml:10
msgid "Browse local network services in Dolphin's Network page"
msgstr ""
"Explorar los servicios de la red local en la página de Redes de Dolphin"

#. (itstool) path: description/p
#: org.kde.kio_zeroconf.metainfo.xml:12
msgid ""
"Adds an entry to Dolphin's Network page to show local services such as "
"printers which advertise themselves with DNSSD (called Avahi or Bonjour by "
"other projects)."
msgstr ""
"Añade una entrada a la página de Redes de Dolphin para mostrar los servicios "
"locales, como impresoras, que se anuncian a sí mismos mediante DNSSD "
"(llamado Avahi o Bonjour en otros proyectos)."
