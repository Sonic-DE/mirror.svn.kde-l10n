#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:136 org.kde.kweather.appdata.xml:144
#: org.kde.kweather.appdata.xml:152
msgid "User interface improvements and bugfixes"
msgstr "Mejoras de la interfaz de usuario y corrección de fallos"

#. (itstool) path: description/p
#: org.kde.kweather.appdata.xml:159 org.kde.kweather.appdata.xml:174
#: org.kde.kweather.appdata.xml:185
msgid "Changes:"
msgstr "Cambios:"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:161
msgid "Performance improvements in Dynamic view"
msgstr "Mejoras de rendimiento en la vista dinámica."

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:162
msgid "Dynamic view action bar rewritten to be inline to content"
msgstr ""
"Barra de acción de vista dinámica reescrita para estar en línea con el "
"contenido."

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:163
msgid "Allow setting non-current location in default forecasts page"
msgstr ""
"Permitir configurar una ubicación no actual en la página de pronósticos "
"predeterminada."

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:164
msgid "Added ability to fetch temperature units from system locale"
msgstr ""
"Se ha añadido la capacidad de obtener unidades de temperatura de la "
"configuración regional del sistema."

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:165
msgid "Fixed timezone format not being correctly read for local location time"
msgstr ""
"Corrección para el formato de zona horaria no se lee correctamente para la "
"hora de la ubicación local."

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:176
msgid "Rewrote the weather plasmoid"
msgstr "Reescritura del plasmoide de meteorología."

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:177
msgid "Use inline page indicator for flat mode forecasts"
msgstr "Usar el indicador de página en línea para pronósticos en modo plano."

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:178
msgid "Fix location ordering not persisting"
msgstr "Se ha corregido el problema de que el orden de ubicación no persistía."

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:187
msgid "Reworked the locations page to better handle long location names"
msgstr ""
"Se ha modificado la página de ubicaciones para manejar mejor los nombres "
"largos de ubicaciones."

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:188
msgid "Add maximum width to dynamic forecast to better deal with widescreen"
msgstr ""
"Se ha añadido la anchura máxima al pronóstico dinámico para aprovechar mejor "
"las pantallas anchas."

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:189
msgid "Remove plasmoid (it is being reworked!)"
msgstr "Eliminar plasmoide (¡se está trabajando en ello!)"

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:190
msgid "Fixed default page not being loaded when new locations are added"
msgstr ""
"Se ha corregido el problema de que la página predeterminada no se cargaba "
"cuando se añadían nuevas ubicaciones."

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:191
msgid "Unify application settings location"
msgstr "Unificar la ubicación de la configuración de la aplicación."

#. (itstool) path: ul/li
#: org.kde.kweather.appdata.xml:192
msgid "Enable qml debugging when in debug mode"
msgstr "Habilitar modo de depuración qml en el modo de depuración."
