#, kde-format
msgctxt "@action:button"
msgid "Try Restart"
msgstr "Intentar reiniciarlo"

#: kwatchgnupgmainwin.cpp:137
#, kde-format
msgctxt "@action:button"
msgid "Do Not Try"
msgstr "No intentarlo"

#: kwatchgnupgmainwin.cpp:139
#, kde-format
