#. (itstool) path: component/summary
#: org.kde.accessibilityinspector.metainfo.xml:12
msgid "Inspect your application accessibility tree"
msgstr "Inspeccionar el árbol de accesibilidad de las aplicaciones"

#. (itstool) path: description/p
#: org.kde.accessibilityinspector.metainfo.xml:14
msgid ""
"Accessibility Inspector is as the name suggests an inspector for your "
"application accessibility tree. It lets you check all the items exposed via "
"At-SPI, too."
msgstr ""
"El inspector de accesibilidad es, como su nombre sugiere, un inspector del "
"árbol de accesibilidad de las aplicaciones. También permite comprobar todos "
"los elementos expuestos mediante At-SPI."

