#. Tag: sect2
#: introduction.docbook:1
#, no-c-format
msgid "&WORK-IN-PROGRESS;"
msgstr "&WORK-IN-PROGRESS;"

#. Tag: para
#: introduction.docbook:3
#, no-c-format
msgid ""
"The &portfolio; lets you manage multiple projects from a single application."
msgstr ""
"El &portfolio; le permite administrar múltiples proyectos desde una única "
"aplicación."

#. Tag: para
#: introduction.docbook:5
#, no-c-format
msgid "Two use cases:"
msgstr "Dos casos de uso:"

#. Tag: para
#: introduction.docbook:8
#, no-c-format
msgid ""
"Managing multiple projects, giving an overview of where to focus attention."
msgstr ""
"Gestión de múltiples proyectos, ofreciendo una visión general de dónde se "
"debe centrar la atención."

#. Tag: para
#: introduction.docbook:11
#, no-c-format
msgid ""
"Inspecting and planning projects enterprise wide. Assisting with handling "
"delays, changing priorities or incorporating new projects."
msgstr ""
"Inspección y planificación de proyectos en toda la empresa. Asistencia en la "
"gestión de retrasos, cambios de prioridades o incorporación de nuevos "
"proyectos."

#. Tag: para
#: introduction.docbook:16
#, no-c-format
msgid "Features:"
msgstr "Funcionalidades:"

#. Tag: para
#: introduction.docbook:19
#, no-c-format
msgid "Schedule or re-schedule multiple projects."
msgstr "Programación o reprogramación de varios proyectos."

#. Tag: para
#: introduction.docbook:22
#, no-c-format
msgid "Resource levelling across projects."
msgstr "Nivelación de recursos entre proyectos."

#. Tag: para
#: introduction.docbook:25
#, no-c-format
msgid "Inspect planned resource usage across projects."
msgstr "Inspección del uso de recursos planificado entre proyectos."

#. Tag: para
#: introduction.docbook:28
#, no-c-format
msgid ""
"Inspect and update progress information in table form as well as in charts."
msgstr ""
"Inspección y actualización de la información de avance en forma de tablas y "
"gráficos."

#. Tag: para
#: introduction.docbook:31
#, no-c-format
msgid "Inspect project gantt charts."
msgstr "Inspección de diagramas de Gantt del proyecto."
