#. Tag: title
#: projectperformanceview.docbook:1
#, no-c-format
msgid "Description"
msgstr "Descripción"

#. Tag: para
#: projectperformanceview.docbook:2
#, no-c-format
msgid ""
"The Project performance view is a project management chart where can be "
"understood the actual situation of the project according to the Earned Value "
"Method."
msgstr ""
"La vista de desempeño del proyecto es un diagrama de gestión del proyecto "
"donde se puede entender la situación actual del proyecto según el método del "
"«Valor ganado»."

#. Tag: para
#: projectperformanceview.docbook:18
#, no-c-format
msgid "where:"
msgstr "donde:"

#. Tag: para
#: projectperformanceview.docbook:21
#, no-c-format
msgid "BCWS means Budgeted Cost Work Scheduled,"
msgstr "BCWS significa «Costo presupuestado del trabajo planificado»,"

#. Tag: para
#: projectperformanceview.docbook:22
#, no-c-format
msgid "BCWP means Budgeted Cost Work Performed,"
msgstr "BCWP significa «Costo presupuestado del trabajo realizado»,"

#. Tag: para
#: projectperformanceview.docbook:23
#, no-c-format
msgid "ACWP means Actual Cost Work Performed."
msgstr "ACWP significa «Costo real del trabajo realizado»."

#. Tag: para
#: projectperformanceview.docbook:25
#, no-c-format
msgid "All these are considered as effort in hours and costs."
msgstr "Todos ellos se consideran un esfuerzo en horas y costos."

#. Tag: para
#: projectperformanceview.docbook:27
#, no-c-format
msgid "PI are the Performance Indexes, where:"
msgstr "PI son los índices de desempeño, donde:"

#. Tag: para
#: projectperformanceview.docbook:30
#, no-c-format
msgid "CPI is the Cost Performance Index,"
msgstr "CPI es el «Índice de desempeño del costo»,"

#. Tag: para
#: projectperformanceview.docbook:31
#, no-c-format
msgid "SPI is the Schedule Performance Index."
msgstr "SPI es el «Índice de desempeño planificado»."
