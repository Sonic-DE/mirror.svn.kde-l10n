#. Tag: title
#: resourceassignmentview.docbook:2
#, no-c-format
msgid "<title>Description</title>"
msgstr "<title>Descripción</title>"

#. Tag: para
#: resourceassignmentview.docbook:3
#, no-c-format
msgid ""
"The Resource Assignment View displays the scheduled task-resource "
"assignments in a table."
msgstr ""
"La vista de asignación de recursos muestra las asignaciones de tarea-recurso "
"planificadas en una tabla."

#. Tag: para
#: resourceassignmentview.docbook:5
#, no-c-format
msgid "This view can severely impact performance in large projects."
msgstr ""
"Esta vista puede afectar severamente al rendimiento en proyectos grandes."

#. Tag: title
#: resourceassignmentview.docbook:26
#, no-c-format
msgid "Data"
msgstr "Datos"

#. Tag: para
#: resourceassignmentview.docbook:27
#, no-c-format
msgid "The following columns are displayed as default:"
msgstr "Las siguientes columnas se muestran de forma predeterminada:"

#. Tag: guilabel
#: resourceassignmentview.docbook:34
#, no-c-format
msgid "Column"
msgstr "Columna"

#. Tag: guilabel
#: resourceassignmentview.docbook:35
#, no-c-format
msgid "<guilabel>Description</guilabel>"
msgstr "<guilabel>Descripción</guilabel>"

#. Tag: para
#: resourceassignmentview.docbook:41
#, no-c-format
msgid "Name"
msgstr "Nombre"

#. Tag: para
#: resourceassignmentview.docbook:44
#, no-c-format
msgid "The name of the object (Resource group, resource, task)"
msgstr "El nombre del objeto (grupo de recursos, recurso, tarea)"

#. Tag: para
#: resourceassignmentview.docbook:49
#, no-c-format
msgid "Total"
msgstr "Total"

#. Tag: para
#: resourceassignmentview.docbook:52
#, no-c-format
msgid "The total assignment for a resource"
msgstr "La asignación total para un recurso"

#. Tag: para
#: resourceassignmentview.docbook:57
#, no-c-format
msgid "Dates"
msgstr "Fechas"

#. Tag: para
#: resourceassignmentview.docbook:60
#, no-c-format
msgid ""
"The total assignments for a resource per day and the assignments for the "
"resource per task."
msgstr ""
"Las asignaciones totales para un recurso por día y las asignaciones para el "
"recurso por tarea."

#. Tag: title
#: resourceassignmentview.docbook:67
#, no-c-format
msgid "Editing data"
msgstr "Edición de datos"

#. Tag: para
#: resourceassignmentview.docbook:68
#, no-c-format
msgid "The task description and progress can be edited using the context menu."
msgstr ""
"La descripción y el avance de una tarea se pueden editar usando el menú de "
"contexto."
