#. Tag: para
#: introduction.docbook:2
#, no-c-format
msgid "Features include:"
msgstr "Las funcionalidades incluyen:"

#. Tag: para
#: introduction.docbook:5
#, no-c-format
msgid ""
"Task management using the <link linkend=\"task-editor\">Task Editor</"
"link>&nbsp;"
msgstr ""
"Gestión de tareas usando el <link linkend=\"task-editor\">Editor de tareas</"
"link>&nbsp;"

#. Tag: para
#: introduction.docbook:6
#, no-c-format
msgid "Work breakdown structure with configurable WBS codes"
msgstr "Estructura de desglose del trabajo con códigos EDT configurables"

#. Tag: para
#: introduction.docbook:7
#, no-c-format
msgid "Tasks, summary tasks, and milestones"
msgstr "Tareas, tareas resumidas y metas"

#. Tag: para
#: introduction.docbook:8
#, no-c-format
msgid "Different types of time constraints"
msgstr "Diferentes tipos de restricciones de tiempo"

#. Tag: para
#: introduction.docbook:9
#, no-c-format
msgid "Different types of dependencies."
msgstr "Diferentes tipos de dependencias."

#. Tag: para
#: introduction.docbook:12
#, no-c-format
msgid ""
"Resource management using the <link linkend=\"resource-editor\">Resource "
"Editor</link>&nbsp;"
msgstr ""
"Gestión de recursos usando el <link linkend=\"resource-editor\">Editor de "
"recursos</link>&nbsp;"

#. Tag: para
#: introduction.docbook:13
#, no-c-format
msgid "Resource breakdown structure"
msgstr "Estructura de desglose de recursos"

#. Tag: para
#: introduction.docbook:14
#, no-c-format
msgid "Working- and material resource types"
msgstr "Tipos de recursos de trabajo y materiales"

#. Tag: para
#: introduction.docbook:15
#, no-c-format
msgid "Resource allocation on group level"
msgstr "Asignación de recursos a nivel de grupo"

#. Tag: para
#: introduction.docbook:16
#, no-c-format
msgid "Resource teams"
msgstr "Equipos de recursos"

#. Tag: para
#: introduction.docbook:19
#, no-c-format
msgid ""
"Work time &amp; vacation definition using the <link linkend=\"work-and-"
"vacation-editor\">Work and Vacation Editor</link>&nbsp;"
msgstr ""
"Definición de tiempo de trabajo y vacaciones usando el <link linkend=\"work-"
"and-vacation-editor\">Editor de tiempo de trabajo y vacaciones</link>&nbsp;"

#. Tag: para
#: introduction.docbook:20
#, no-c-format
msgid ""
"Cost management using the <link linkend=\"cost-breakdown-structure-editor"
"\">Cost Breakdown Structure Editor</link>&nbsp;"
msgstr ""
"Gestión de costos usando el <link linkend=\"cost-breakdown-structure-editor"
"\">Editor de estructura de desglose de costos</link>&nbsp;"

#. Tag: para
#: introduction.docbook:21
#, no-c-format
msgid "Earned value management"
msgstr "Gestión del valor ganado"

#. Tag: para
#: introduction.docbook:22
#, no-c-format
msgid ""
"Project scheduling using the <link linkend=\"schedules-editor\">Schedules "
"Editor</link>&nbsp;"
msgstr ""
"Planificación de proyectos usando el <link linkend=\"schedules-editor"
"\">Editor de planificaciones</link>&nbsp;"

#. Tag: para
#: introduction.docbook:23
#, no-c-format
msgid "Schedule forward from start time or backward from finish time"
msgstr ""
"Planificar hacia adelante desde la hora de inicio o hacia atrás desde la "
"hora de finalización"

#. Tag: para
#: introduction.docbook:24
#, no-c-format
msgid "Allow or avoid resource overbooking"
msgstr "Permitir o evitar la sobrerreserva de recursos"

#. Tag: para
#: introduction.docbook:25
#, no-c-format
msgid ""
"PERT distribution with optimistic-, pessimistic-, and most likely estimates"
msgstr "Distribución PERT con estimaciones optimista, pesimista y más probable"

#. Tag: para
#: introduction.docbook:26
#, no-c-format
msgid ""
"Multiple schedules with a possibility to schedule from current progress "
"information"
msgstr ""
"Planificaciones múltiples con la posibilidad de planificar a partir de la "
"información de avance actual"

#. Tag: para
#: introduction.docbook:29
#, no-c-format
msgid ""
"Task tracking using the <link linkend=\"task-execution-view\">Task Execution "
"View</link> or <link linkend=\"task-status-view\">Task Status View</"
"link>&nbsp;"
msgstr ""
"Seguimiento de tareas usando la <link linkend=\"task-execution-view\">Vista "
"de ejecución de tareas</link> o la <link linkend=\"task-status-view\">Vista "
"del estado de las tareas</link>&nbsp;"
