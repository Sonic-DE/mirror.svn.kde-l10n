#. Tag: para
#: resourceassignmentganttview.docbook:55
#, no-c-format
msgid "Start Time"
msgstr "Hora de inicio"

#. Tag: para
#: resourceassignmentganttview.docbook:58
#, no-c-format
msgid "The start of the assignment"
msgstr "El inicio de la asignación"

#. Tag: para
#: resourceassignmentganttview.docbook:63
#, no-c-format
msgid "End Time"
msgstr "Hora de finalización"

#. Tag: para
#: resourceassignmentganttview.docbook:66
#, no-c-format
