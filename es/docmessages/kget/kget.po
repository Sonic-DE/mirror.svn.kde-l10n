msgstr "<phrase>Captura de pantalla de &kget;</phrase>"

#. Tag: title
#: index.docbook:74
#, no-c-format
msgid "&kget; Drop Target"
msgstr "Etiqueta para soltar de &kget;"

#. Tag: para
#: index.docbook:76
#, no-c-format
msgid "The &kget; Drop Target has four options."
msgstr "La etiqueta para soltar de &kget; tiene cuatro opciones."

#. Tag: screeninfo
#: index.docbook:81
#, no-c-format
msgid "<screeninfo>Screenshot of &kget; drop target</screeninfo>"
msgstr ""
"<screeninfo>Captura de pantalla de la etiqueta de soltar de &kget;</"
"screeninfo>"

#. Tag: phrase
#: index.docbook:87
#, no-c-format
msgid "<phrase>Screenshot of &kget; drop target</phrase>"
msgstr ""
"<phrase>Captura de pantalla de la etiqueta de soltar de &kget;</phrase>"

#. Tag: title
#: index.docbook:93
#, no-c-format
msgid "&kget; Drop Target options"
msgstr "Opciones de la etiqueta para soltar de &kget;"

#. Tag: para
#: index.docbook:94
#, no-c-format
msgid "Right click on the drop target to see the options."
msgstr ""
"Para ver las opciones, haga clic con el botón derecho sobre la etiqueta para "
"soltar."

#. Tag: menuchoice
#: index.docbook:101
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>R</keycap></keycombo> </"
"shortcut> <guimenuitem>Start / Resume All</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>R</keycap></keycombo> </"
"shortcut> <guimenuitem>Iniciar / reanudar todo</guimenuitem>"

#. Tag: action
#: index.docbook:110
#, no-c-format
msgid ""
"To start a download or resume all the pending downloads. The shortcut for "
"doing this is <keycombo action=\"simul\">&Ctrl;<keycap>R</keycap></keycombo>"
msgstr ""
"Para iniciar la descarga o continuar todas las descargas pendientes. El "
"atajo de teclado para hacer esto es <keycombo action=\"simul\">&Ctrl;"
"<keycap>R</keycap></keycombo>"

#. Tag: guimenuitem
#: index.docbook:118
#, no-c-format
msgid "Show/Hide Main Window"
msgstr "Mostrar/ocultar la ventana principal"

#. Tag: action
#: index.docbook:123
#, no-c-format
msgid "This option shows or minimizes the main window to the system tray."
msgstr ""
"Esta opción muestra o minimiza la ventana principal a la bandeja del sistema."

#. Tag: guimenuitem
#: index.docbook:130
#, no-c-format
msgid "Sticky"
msgstr "Fijada"

#. Tag: action
#: index.docbook:135
#, no-c-format
msgid "Makes the &kget; drop target undraggable."
msgstr "Hace que la etiqueta para soltar de &kget; no se pueda arrastrar."

#. Tag: guimenuitem
#: index.docbook:143
#, no-c-format
msgid "Quit &kget;"
msgstr "Salir de &kget;."

#. Tag: action
#: index.docbook:148 index.docbook:698
#, no-c-format
msgid "Quits &kget;"
msgstr "Sale de &kget;."

#. Tag: title
#: index.docbook:157
#, no-c-format
msgid "&kget;'s Configuration window"
msgstr "Pantalla de configuración de &kget;"

#. Tag: menuchoice
#: index.docbook:160
#, no-c-format
msgid "<guimenu>Settings</guimenu> <guimenuitem>Configure &kget;</guimenuitem>"
msgstr ""
"<guimenu>Preferencias</guimenu> <guimenuitem>Configurar &kget;</guimenuitem>"

#. Tag: action
#: index.docbook:164
#, no-c-format
msgid "Opens the &kget; configuration window"
msgstr "Abre la pantalla de configuración de &kget;."

#. Tag: title
#: index.docbook:169
#, no-c-format
msgid "<title>Appearance</title>"
msgstr "<title>Apariencia</title>"

#. Tag: screeninfo
#: index.docbook:172
#, no-c-format
msgid "<screeninfo>Appearance</screeninfo>"
msgstr "<screeninfo>Apariencia</screeninfo>"

#. Tag: phrase
#: index.docbook:178
#, no-c-format
msgid "<phrase>Appearance</phrase>"
msgstr "<phrase>Apariencia</phrase>"

#. Tag: guimenuitem
#: index.docbook:188
#, no-c-format
msgid "<guimenuitem>Appearance</guimenuitem>"
msgstr "<guimenu>Apariencia</guimenu>"

#. Tag: action
#: index.docbook:193
#, no-c-format
msgid "You can modify the various appearance related stuff here."
msgstr ""
"Aquí se pueden modificar diversas cuestiones relacionadas con la apariencia."

#. Tag: guimenuitem
#: index.docbook:200
#, no-c-format
msgid "Use Drop Target"
msgstr "Usar etiqueta para soltar"

#. Tag: action
#: index.docbook:205
#, no-c-format
msgid "Uncheck this if you do not want the &kget; Drop Target."
msgstr ""
"Deje esta opción sin marcar si no desea la etiqueta para soltar de &kget;."

#. Tag: guimenuitem
#: index.docbook:212
#, no-c-format
msgid "Enable animations"
msgstr "Activar animaciones"

#. Tag: action
#: index.docbook:217
#, no-c-format
msgid "Enables few fancy animations."
msgstr "Activa nuevas y atractivas animaciones."

#. Tag: title
#: index.docbook:226
#, no-c-format
msgid "Groups"
msgstr "Grupos"

#. Tag: para
#: index.docbook:227
#, no-c-format
msgid "You can group downloads."
msgstr "Se pueden agrupar las descargas."

#. Tag: screeninfo
#: index.docbook:229
#, no-c-format
msgid "<screeninfo>&kget; Groups</screeninfo>"
msgstr "<screeninfo>Grupos de &kget;</screeninfo>"

#. Tag: phrase
#: index.docbook:235
#, no-c-format
msgid "<phrase>&kget; Groups</phrase>"
msgstr "<phrase>Grupos de &kget;</phrase>"

#. Tag: guimenuitem
#: index.docbook:244
#, no-c-format
msgid "Use default folders for groups as suggestion"
msgstr "Utilizar las carpetas predeterminadas que se sugieren para los grupos"

#. Tag: action
#: index.docbook:249
#, no-c-format
msgid ""
"Tick this box if you want &kget; to use default folders for your downloads."
msgstr ""
"Marque esta casilla si quiere que &kget; utilice las carpetas "
"predeterminadas para sus descargas."

#. Tag: title
#: index.docbook:258
#, no-c-format
msgid "Network"
msgstr "Red"

#. Tag: para
#: index.docbook:259
#, no-c-format
msgid "You can modify your network related settings here."
msgstr "Aquí se pueden modificar las preferencias relacionadas con su red."

#. Tag: screeninfo
#: index.docbook:261
#, no-c-format
msgid "<screeninfo>&kget; Network</screeninfo>"
msgstr "<screeninfo>Red de &kget;</screeninfo>"

#. Tag: phrase
#: index.docbook:267
#, no-c-format
msgid "<phrase>&kget; Network</phrase>"
msgstr "<phrase>Red de &kget;</phrase>"

#. Tag: guimenuitem
#: index.docbook:276
#, no-c-format
msgid "Limit Maximum Downloads Per Group"
msgstr "Límite máximo de descargas por grupo"

#. Tag: action
#: index.docbook:281
#, no-c-format
msgid "Check this box if you want Download limits to be implemented."
msgstr "Marque esta casilla si desea que se establezcan límites de descarga."

#. Tag: guimenuitem
#: index.docbook:288
#, no-c-format
msgid "Speed Limit"
msgstr "Límite de velocidad"

#. Tag: action
#: index.docbook:293
#, no-c-format
msgid "Check this box if you want the Global speed limits to be used."
msgstr ""
"Marque esta casilla si desea que se utilicen los límites de velocidad "
"globales."

#. Tag: guimenuitem
#: index.docbook:301
#, no-c-format
msgid "Global download limit"
msgstr "Límite global de descarga"

#. Tag: action
#: index.docbook:306
#, no-c-format
msgid "Set the maximum global download limit."
msgstr "Establece el límite máximo de descarga global."

#. Tag: guimenuitem
#: index.docbook:314
#, no-c-format
msgid "Global upload limit"
msgstr "Límite global de carga"

#. Tag: action
#: index.docbook:319
#, no-c-format
msgid "Set the maximum upload limit."
msgstr "Establece el límite máximo de carga."

#. Tag: guimenuitem
#: index.docbook:327
#, no-c-format
msgid "Reconnect on Broken Connection"
msgstr "Volver a conectar en caso de interrupción de la conexión"

#. Tag: action
#: index.docbook:332
#, no-c-format
msgid ""
"Check this box if you want &kget; to reconnect after an error or a broken "
"connection."
msgstr ""
"Marque esta casilla si desea que &kget; se vuelva a conectar después de un "
"error o de una interrupción de la conexión."

#. Tag: guimenuitem
#: index.docbook:340
#, no-c-format
msgid "Number of retries"
msgstr "Número de reintentos"

#. Tag: action
#: index.docbook:345
#, no-c-format
msgid "Set the maximum number of time &kget; will try to reconnect."
msgstr ""
"Establece el número máximo de tiempo en el que &kget; intentará volver a "
"conectar."

#. Tag: guimenuitem
#: index.docbook:353
#, no-c-format
msgid "Retry after"
msgstr "Volver a intentarlo tras"

#. Tag: action
#: index.docbook:358
#, no-c-format
msgid "Set the retrying interval here (in seconds)"
msgstr "Aquí se establece el intervalo de reintentos (en segundos)."

#. Tag: title
#: index.docbook:368
#, no-c-format
msgid "Web Interface"
msgstr "Interfaz web"

#. Tag: para
#: index.docbook:369
#, no-c-format
msgid ""
"To enable the web interface, check <guilabel>Enable Web Interface</"
"guilabel>; default port is 8080, and you configure any port higher than "
"1024. Then set <guilabel>User</guilabel> and <guilabel>Password</guilabel>. "
"You can access your web interface at http://127.0.0.1:&lt;port&gt;. You will "
"need to enter the username and password to get access."
msgstr ""
"Para activar la interfaz web, marque <guilabel>Activar interfaz web</"
"guilabel>; el puerto predeterminado es 8080 y puede configurar cualquier "
"puerto mayor que 1024. A continuación, defina el <guilabel>Usuario</"
"guilabel> y la <guilabel>Contraseña</guilabel>. Puede acceder a su interfaz "
"web en http://127.0.0.1:&lt;puerto&gt;. Para acceder, será necesario que "
"introduzca el nombre de usuario y la contraseña."

#. Tag: screeninfo
#: index.docbook:377
#, no-c-format
msgid "<screeninfo>&kget; Web Interface</screeninfo>"
msgstr "<screeninfo>Interfaz web de &kget;</screeninfo>"

#. Tag: phrase
#: index.docbook:383
#, no-c-format
msgid "<phrase>&kget; Web Interface</phrase>"
msgstr "<phrase>Interfaz web de &kget;</phrase>"

#. Tag: title
#: index.docbook:391
#, no-c-format
msgid "Verification"
msgstr "Verificación"

#. Tag: para
#: index.docbook:392
#, no-c-format
msgid "Verify your downloads."
msgstr "Verifique sus descargas."

#. Tag: screeninfo
#: index.docbook:394
#, no-c-format
msgid "<screeninfo>&kget; Verification</screeninfo>"
msgstr "<screeninfo>Verificación de &kget;</screeninfo>"

#. Tag: phrase
#: index.docbook:400
#, no-c-format
msgid "<phrase>&kget; Verification</phrase>"
msgstr "<phrase>Verificación de &kget;</phrase>"

#. Tag: para
#: index.docbook:405
#, no-c-format
msgid ""
"Using the two methods <guilabel>Automatic checksums verification</guilabel> "
"and <guilabel>Signature</guilabel> you can verify your downloads. You just "
"have to tick the <guilabel>Automatic verification</guilabel> check box."
msgstr ""
"Puede verificar las descargas mediante el uso de ambos métodos, "
"<guilabel>Sumas de verificación automáticas</guilabel> y <guilabel>Firma</"
"guilabel>. Solo tiene que marcar la casilla <guilabel>Verificación "
"automática</guilabel>."

#. Tag: title
#: index.docbook:410
#, no-c-format
msgid "Integration"
msgstr "Integración"

#. Tag: guimenuitem
#: index.docbook:415
#, no-c-format
msgid "Use as download manager for Konqueror"
msgstr "Utilizar como gestor de descargas de Konqueror"

#. Tag: action
#: index.docbook:420
#, no-c-format
msgid "You can set &kget; as your download manager for &konqueror;."
msgstr ""
"&kget; se puede configurar para ser el gestor de descargas de &konqueror;."

#. Tag: guimenuitem
#: index.docbook:428
#, no-c-format
msgid "Monitor clipboard for files to download"
msgstr "Supervisar portapapeles en busca de archivos que descargar"

#. Tag: para
#: index.docbook:432
#, no-c-format
msgid ""
"You can turn on this feature that asks if you want to download &URL;s copied "
"into the clipboard."
msgstr ""
"Puede activar esta funcionalidad que se pregunta si desea copiar en el "
"portapapeles las &URL; que descargue."

#. Tag: title
#: index.docbook:441
#, no-c-format
msgid "Advanced"
msgstr "Avanzado"

#. Tag: para
#: index.docbook:442
#, no-c-format
msgid "Modify Advanced Options."
msgstr "Modifique las opciones avanzadas."

#. Tag: screeninfo
#: index.docbook:444
#, no-c-format
msgid "<screeninfo>&kget; Advanced Options</screeninfo>"
msgstr "<screeninfo>Opciones avanzadas de &kget;</screeninfo>"

#. Tag: phrase
#: index.docbook:450
#, no-c-format
msgid "<phrase>&kget; Advanced Options</phrase>"
msgstr "<phrase>Opciones avanzadas de &kget;</phrase>"

#. Tag: guimenuitem
#: index.docbook:459
#, no-c-format
msgid "Enable system tray icon"
msgstr "Activar el icono de la bandeja del sistema"

#. Tag: action
#: index.docbook:464
#, no-c-format
msgid "This check box enables the &kget; system tray icon."
msgstr ""
"Esta casilla de verificación activa el icono de la bandeja del sistema de "
"&kget;."

#. Tag: guimenuitem
#: index.docbook:472
#, no-c-format
msgid "Execute action after all downloads have been finished"
msgstr "Ejecutar acción después de que hayan finalizado todas las descargas"

#. Tag: action
#: index.docbook:477
#, no-c-format
msgid ""
"Check this box to enable Quitting &kget; after all downloads have finished. "
"At startup you can choose to Restore Download state. Such as Stop All "
"downloads/ Start All downloads."
msgstr ""
"Marque esta casilla para activar la salida de &kget; después de que todas "
"las descargas hayan finalizado. Al arrancar, puede elegir Restablecer el "
"estado de descarga, así como Detener todas las descargas o Iniciar todas las "
"descargas."

#. Tag: guimenuitem
#: index.docbook:486
#, no-c-format
msgid "History backend"
msgstr "Motor del historial"

#. Tag: action
#: index.docbook:491
#, no-c-format
msgid "You can choose your history backend as Sqlite or Xml."
msgstr "Para el motor del historial, puede elegir entre Sqlite o Xml."

#. Tag: guimenuitem
#: index.docbook:499
#, no-c-format
msgid "Enable &kde; global progress tracking"
msgstr "Activar el rastreador de progreso global de &kde;"

#. Tag: action
#: index.docbook:504
#, no-c-format
msgid ""
"You can set &kget; to show every single download or show overall progress."
msgstr ""
"Se puede configurar &kget; para mostrar cada descarga individual o mostrar "
"el progreso en general."

#. Tag: title
#: index.docbook:512
#, no-c-format
msgid "Plugins"
msgstr "Complementos"

#. Tag: screeninfo
#: index.docbook:514
#, no-c-format
msgid "<screeninfo>&kget; Plugins Options</screeninfo>"
msgstr "<screeninfo>Opciones de los complementos de &kget;</screeninfo>"

#. Tag: phrase
#: index.docbook:520
#, no-c-format
msgid "<phrase>&kget; Plugins Options</phrase>"
msgstr "<phrase>Opciones de los complementos de &kget;</phrase>"

#. Tag: para
#: index.docbook:524
#, no-c-format
msgid ""
"On this page you can select the transfer plugins to be used. Use the "
"<inlinemediaobject><imageobject><imagedata fileref=\"pluginsettings.png\" "
"format=\"PNG\"/> </imageobject></inlinemediaobject> button to change the "
"default settings for a plugin."
msgstr ""
"En esta página puede seleccionar los complementos de transferencia a usar. "
"Use el botón <inlinemediaobject><imageobject><imagedata fileref="
"\"pluginsettings.png\" format=\"PNG\"/> </imageobject></inlinemediaobject> "
"para cambiar las preferencias predeterminadas para un complemento."

#. Tag: title
#: index.docbook:532
#, no-c-format
msgid "Main Window"
msgstr "Ventana principal"

#. Tag: para
#: index.docbook:533
#, no-c-format
msgid "Overview of &kget;'s Main Window"
msgstr "Vista general de la pantalla principal de &kget;"

#. Tag: title
#: index.docbook:547
#, no-c-format
msgid "The File Menu"
msgstr "El menú Archivo"

#. Tag: menuchoice
#: index.docbook:550
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>N</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>New Download...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>N</keycap></keycombo> </"
"shortcut> <guimenu>Archivo</guimenu> <guimenuitem>Nueva descarga…</"
"guimenuitem>"

#. Tag: action
#: index.docbook:557
#, no-c-format
msgid "Add a new file to download"
msgstr "Añadir un nuevo archivo para descargar"

#. Tag: menuchoice
#: index.docbook:561
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>L</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Import Links...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>L</keycap></keycombo> </"
"shortcut> <guimenu>Archivo</guimenu> <guimenuitem>Importar enlaces…</"
"guimenuitem>"

#. Tag: screeninfo
#: index.docbook:570
#, no-c-format
msgid "<screeninfo>Import Links</screeninfo>"
msgstr "<screeninfo>Importar enlaces</screeninfo>"

#. Tag: phrase
#: index.docbook:576
#, no-c-format
msgid "<phrase>Import Links</phrase>"
msgstr "<phrase>Importar enlaces</phrase>"

#. Tag: action
#: index.docbook:580
#, no-c-format
msgid ""
"This action brings up another window, where you can see and manipulate which "
"file to download. Also you can make a selection based on <guilabel>Videos</"
"guilabel>, <guilabel>Images</guilabel>, <guilabel>Audio</guilabel> and "
"<guilabel>Archives</guilabel>. There is also a text box to filter out "
"results."
msgstr ""
"Esta opción muestra otra pantalla en la que se puede ver y manipular el "
"archivo que se va a descargar. También se puede hacer una selección basada "
"en <guilabel>Vídeos</guilabel>, <guilabel>Imágenes</guilabel>, "
"<guilabel>Audio</guilabel> y <guilabel>Archivos comprimidos</guilabel>. "
"También hay un área de texto para filtrar los resultados."

#. Tag: menuchoice
#: index.docbook:585
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>I</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Import Transfers...</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>I</keycap></keycombo> </"
"shortcut> <guimenu>Archivo</guimenu> <guimenuitem>Importar transferencias…</"
"guimenuitem>"

#. Tag: action
#: index.docbook:592
#, no-c-format
msgid ""
"Loads a <filename class=\"extension\">*.kgt</filename>, <filename class="
"\"extension\">*.metalink</filename>, <filename class=\"extension\">*.meta4</"
"filename> or <filename class=\"extension\">*.torrent</filename> file."
msgstr ""
"Carga un archivo <filename class=\"extension\">*.kgt</filename>, <filename "
"class=\"extension\">*.metalink</filename>, <filename class=\"extension\">*."
"meta4</filename> o <filename class=\"extension\">*.torrent</filename>."

#. Tag: menuchoice
#: index.docbook:596
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>E</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Export Transfers List...</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>E</keycap></keycombo> </"
"shortcut> <guimenu>Archivo</guimenu> <guimenuitem>Exportar lista de "
"transferencias…</guimenuitem>"

#. Tag: action
#: index.docbook:603
#, no-c-format
msgid ""
"Export the highlighted links to a <filename class=\"extension\">.kgt</"
"filename> file, to be loaded later."
msgstr ""
"Exporta los enlaces seleccionados a un archivo <filename class=\"extension"
"\">.kgt</filename> para cargarlos en otro momento."

#. Tag: menuchoice
#: index.docbook:607
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Create a Metalink</guimenuitem>"
msgstr ""
"<guimenu>Archivo</guimenu> <guimenuitem>Crear un Metalink</guimenuitem>"

#. Tag: screeninfo
#: index.docbook:613
#, no-c-format
msgid "Creating a metalink0"
msgstr "Creación de un metalink 0"

#. Tag: phrase
#: index.docbook:619
#, no-c-format
msgid "Creating a Metalink0"
msgstr "Creación de un Metalink 0"

#. Tag: para
#: index.docbook:623
#, no-c-format
msgid ""
"Select between creating a new Metalink and loading an existing Metalink. "
"Click the <guilabel>Next</guilabel> button to proceed."
msgstr ""
"Elija entre crear un nuevo Metalink y cargar un Metalink existente. Haga "
"clic en el botón <guilabel>Siguiente</guilabel> para continuar."

#. Tag: screeninfo
#: index.docbook:626
#, no-c-format
msgid "Creating a metalink1"
msgstr "Creación de un metalink 1"

#. Tag: phrase
#: index.docbook:632
#, no-c-format
msgid "Creating a Metalink1"
msgstr "Creación de un Metalink 1"

#. Tag: para
#: index.docbook:636
#, no-c-format
msgid ""
"Here you can choose to enter some general optional information. Such as "
"where can this metalink be obtained from (Enter the &URL; in the text box "
"next to <guilabel>Origin</guilabel>)."
msgstr ""
"Aquí puede elegir introducir cierta información opcional general, tal como "
"de dónde se puede obtener este metalink (introduzca la &URL; en el área de "
"texto situada junto a <guilabel>Origen</guilabel>)."

#. Tag: screeninfo
#: index.docbook:639
#, no-c-format
msgid "Creating a metalink2"
msgstr "Creación de un metalink 2"

#. Tag: phrase
#: index.docbook:645
#, no-c-format
msgid "Creating a Metalink2"
msgstr "Creación de un Metalink 2"

#. Tag: para
#: index.docbook:649
#, no-c-format
msgid ""
"Here you have to enter the &URL; from where you are trying to download the "
"file. Also you can enter some optional information such as Preference "
"(Priority) for a particular mirror if you are adding more then one mirrors, "
"for the file you want to download."
msgstr ""
"Aquí hay que introducir la &URL; desde la cual se está intentando descargar "
"el archivo. También se puede introducir cierta información opcional como la "
"Preferencia (prioridad) para un espejo concreto, en caso de que se "
"especifique más de un espejo para el archivo que se quiere descargar."

#. Tag: screeninfo
#: index.docbook:652
#, no-c-format
msgid "Creating a metalink 3"
msgstr "Creación de un metalink 3"

#. Tag: phrase
#: index.docbook:658
#, no-c-format
msgid "Creating a Metalink 3"
msgstr "Creación de un Metalink 3"

#. Tag: para
#: index.docbook:662
#, no-c-format
msgid ""
"You should be able to see a new window where all your files which will be "
"imported will be shown."
msgstr ""
"Debería aparecer una nueva ventana en la que se muestran todos los archivos "
"que se van a importar."

#. Tag: menuchoice
#: index.docbook:667
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>H</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Transfer History</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>H</keycap></keycombo> </"
"shortcut> <guimenu>Archivo</guimenu> <guimenuitem>Historial de "
"transferencias</guimenuitem>"

#. Tag: screeninfo
#: index.docbook:676
#, no-c-format
msgid "<screeninfo>Transfer History</screeninfo>"
msgstr "<screeninfo>Historial de transferencia</screeninfo>"

#. Tag: phrase
#: index.docbook:682
#, no-c-format
msgid "<phrase>Transfer History</phrase>"
msgstr "<phrase>Historial de transferencias</phrase>"

#. Tag: action
#: index.docbook:686
#, no-c-format
msgid ""
"Opens a new window where you can see all the files downloaded using &kget;. "
"You can manage your history here, including filter and clear the history."
msgstr ""
"Abre una nueva ventana en la que se pueden ver todos los archivos "
"descargados mediante &kget;. Aquí puede gestionar su historial, lo que "
"incluye acciones como filtrar y borrar el historial."

#. Tag: menuchoice
#: index.docbook:691
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>Q</keycap></keycombo> </"
"shortcut> <guimenu>File</guimenu> <guimenuitem>Quit</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>Q</keycap></keycombo> </"
"shortcut> <guimenu>Archivo</guimenu> <guimenuitem>Salir</guimenuitem>"

