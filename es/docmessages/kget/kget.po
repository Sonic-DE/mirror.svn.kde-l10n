#. Tag: title
#: index.docbook:52
#, no-c-format
msgid "Introduction"
msgstr "Introducción"

#. Tag: para
#: index.docbook:56
#, no-c-format
msgid "Start &kget; (you should see a Drop Target)"
msgstr "Inicie &kget; (debería ver una etiqueta para soltar)."

#. Tag: para
#: index.docbook:57
#, no-c-format
msgid "Drag and drop the required &URL; in the &kget; window/Drop Target."
msgstr ""
"Arrastre y suelte la &URL; requerida en la ventana/etiqueta de soltar de "
"&kget;."

#. Tag: screeninfo
#: index.docbook:60 index.docbook:535
#, no-c-format
msgid "<screeninfo>Screenshot of &kget;</screeninfo>"
msgstr "<screeninfo>Captura de pantalla de &kget;</screeninfo>"

#. Tag: phrase
#: index.docbook:66 index.docbook:541
