#: ui.docbook:60
#, no-c-format
msgid "The <emphasis role=\"bold\">Window Menu</emphasis>"
msgstr "<emphasis role=\"bold\">Menú |Ventana</emphasis>"

#. Tag: para
#: ui.docbook:64
#, no-c-format
msgid ""
"The <emphasis role=\"bold\"><link linkend=\"visualdict-titlebar\">Titlebar</"
"link></emphasis>"
msgstr ""
"<emphasis role=\"bold\"><link linkend=\"visualdict-titlebar\">Barra de "
"título</link></emphasis>"

#. Tag: para
#: ui.docbook:68
#, no-c-format
msgid ""
"Buttons to <emphasis>minimize</emphasis>, <emphasis>maximize</emphasis>, or "
"<emphasis>close</emphasis> the window"
msgstr ""
"Botones para <emphasis>minimizar</emphasis>, <emphasis>maximizar</emphasis> "
"o <emphasis>cerrar</emphasis> la ventana"

#. Tag: para
#: ui.docbook:73
#, no-c-format
msgid ""
"The <emphasis role=\"bold\"><link linkend=\"visualdict-menubar\">Menubar</"
"link></emphasis>"
msgstr ""
"The <emphasis role=\"bold\"><link linkend=\"visualdict-menubar\">Barra de "
"menú</link></emphasis>"

#. Tag: para
#: ui.docbook:77
#, no-c-format
msgid ""
"The <emphasis role=\"bold\"><link linkend=\"visualdict-toolbar\">Toolbar</"
"link></emphasis>"
msgstr ""
"<emphasis role=\"bold\"><link linkend=\"visualdict-toolbar\">Barra de "
"herramientas</link></emphasis>"

#. Tag: para
#: ui.docbook:81
#, no-c-format
msgid ""
"A very large <emphasis role=\"bold\"><link linkend=\"visualdict-text-area"
"\">Text Area</link></emphasis> that acts as this program's <emphasis role="
"\"bold\"><link linkend=\"visualdict-central-widget\">Central Widget</link></"
"emphasis>"
msgstr ""
"<emphasis role=\"bold\"><link linkend=\"visualdict-text-area\">Área de "
"texto</link></emphasis> muy grande que actúa como <emphasis role=\"bold"
"\"><link linkend=\"visualdict-central-widget\">Elemento gráfico principal</"
"link></emphasis> de este programa"

#. Tag: para
#: ui.docbook:88
#, no-c-format
msgid ""
"A vertical <emphasis role=\"bold\"><link linkend=\"visualdict-scrollbar"
"\">Scrollbar</link></emphasis> (there is also a horizontal scrollbar below "
"the text box)"
msgstr ""
"<emphasis role=\"bold\"><link linkend=\"visualdict-scrollbar\">Barra de "
"desplazamiento vertical</link></emphasis> (también hay una barra de "
"desplazamiento horizontal situada bajo el área de texto)"

#. Tag: para
#: ui.docbook:93
#, no-c-format
msgid ""
"The <emphasis role=\"bold\"><link linkend=\"visualdict-statusbar"
"\">Statusbar</link></emphasis>"
msgstr ""
"<emphasis role=\"bold\"><link linkend=\"visualdict-statusbar\">Barra de "
"estado</link></emphasis>"

#. Tag: screeninfo
#: ui.docbook:100
#, no-c-format
msgid "Another Window"
msgstr "Otra ventana"

#. Tag: para
#: ui.docbook:119
#, no-c-format
msgid ""
"This is the another window, that of the &dolphin; file manager. Click on "
"part of the window to learn more about it."
msgstr ""
"Esta es la otra ventana, la del administrador de archivos &dolphin;. Haga "
"clic en una parte de la ventana para saber más sobre ella."

#. Tag: para
#: ui.docbook:124
#, no-c-format
msgid ""
"A <emphasis role=\"bold\"><link linkend=\"visualdict-panel\">panel</link></"
"emphasis> that contains a list of Places on the computer system"
msgstr ""
"<emphasis role=\"bold\"><link linkend=\"visualdict-panel\">Panel</link></"
"emphasis> que contiene una lista de lugares del sistema"

#. Tag: para
#: ui.docbook:129
#, no-c-format
msgid ""
"A <emphasis role=\"bold\"><link linkend=\"visualdict-breadcrumb"
"\">Breadcrumb</link></emphasis> of the path of the displayed folder"
msgstr ""
"<emphasis role=\"bold\"><link linkend=\"visualdict-breadcrumb\">Ruta "
"completa</link></emphasis> de la carpeta que se está visualizando"

#. Tag: para
#: ui.docbook:134
#, no-c-format
msgid ""
"A folder <emphasis role=\"bold\"><link linkend=\"visualdict-icon\">Icon</"
"link></emphasis>"
msgstr ""
"<emphasis role=\"bold\"><link linkend=\"visualdict-icon\">Icono</link></"
"emphasis> de carpeta"

#. Tag: para
#: ui.docbook:138
#, no-c-format
msgid ""
"A file <emphasis role=\"bold\"><link linkend=\"visualdict-icon\">Icon</"
"link></emphasis>"
msgstr ""
"<emphasis role=\"bold\"><link linkend=\"visualdict-icon\">Icono</link></"
"emphasis> de archivo"

#. Tag: para
#: ui.docbook:142
#, no-c-format
msgid ""
"A highlighted <emphasis role=\"bold\"><link linkend=\"visualdict-icon"
"\">Icon</link></emphasis>"
msgstr ""
"<emphasis role=\"bold\"><link linkend=\"visualdict-icon\">Icono</link></"
"emphasis> resaltado"

#. Tag: para
#: ui.docbook:146
#, no-c-format
msgid ""
"A <emphasis role=\"bold\"><link linkend=\"visualdict-context-menu\">Context "
"Menu</link></emphasis> listing actions that can be performed on a file"
msgstr ""
"<emphasis role=\"bold\"><link linkend=\"visualdict-context-menu\">Menú de "
"contexto</link></emphasis> que indica las acciones que se pueden realizar "
"sobre el archivo"

#. Tag: para
#: ui.docbook:151
#, no-c-format
msgid ""
"A <emphasis role=\"bold\"><link linkend=\"visualdict-slider\">Slider</link></"
"emphasis> that changes the size of the <link linkend=\"visualdict-icon"
"\">Icons</link> displayed"
msgstr ""
"<emphasis role=\"bold\"><link linkend=\"visualdict-slider\">Deslizador</"
"link></emphasis> que cambia el tamaño de los <link linkend=\"visualdict-icon"
"\">Iconos</link> mostrados"

#. Tag: para
#: ui.docbook:157
#, no-c-format
msgid ""
"More <emphasis role=\"bold\"><link linkend=\"visualdict-panel\">Panels</"
"link></emphasis>"
msgstr ""
"Más <emphasis role=\"bold\"><link linkend=\"visualdict-panel\">Paneles</"
"link></emphasis>"

