#. Tag: keycombo
#: index.docbook:1625
#, no-c-format
msgid "&Ctrl;<keycap>N</keycap>"
msgstr "&Ctrl;<keycap>N</keycap>"

#. Tag: entry
#: index.docbook:1626
#, no-c-format
msgid "New empty Playlist"
msgstr "Nueva lista de reproducción vacía."

#. Tag: keycombo
#: index.docbook:1630
#, no-c-format
msgid "&Ctrl;<keycap>D</keycap>"
msgstr "&Ctrl;<keycap>D</keycap>"

#. Tag: entry
#: index.docbook:1631
#, no-c-format
msgid "New playlist from folder."
msgstr "Nueva lista de reproducción a partir de una carpeta."

#. Tag: keycombo
#: index.docbook:1635
#, no-c-format
msgid "&Ctrl;<keycap>T</keycap>"
msgstr "&Ctrl;<keycap>T</keycap>"

#. Tag: entry
#: index.docbook:1636
#, no-c-format
msgid "Save changes to edited tags."
msgstr "Guarda los cambios de las etiquetas editadas."

