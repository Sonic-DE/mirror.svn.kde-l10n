#. Tag: entry
#: index.docbook:1621
#, no-c-format
msgid "New <link linkend=\"juk-search-playlists\">search playlist</link>."
msgstr ""
"Nueva <link linkend=\"juk-search-playlists\">lista de reproducción de "
