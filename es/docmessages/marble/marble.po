#: index.docbook:1184
#, no-c-format
msgid "A plugin that shows the Sun."
msgstr "Un complemento que muestra el sol."

#. Tag: guilabel
#: index.docbook:1188
#, no-c-format
msgid "Weather"
msgstr "Meteorología"

