msgstr "<manvolnum>1</manvolnum>"

#. Tag: refpurpose
#: man-kdesvn.1.docbook:25
#, no-c-format
msgid ""
"<refpurpose>A Subversion client by KDE (standalone application)</refpurpose>"
msgstr ""
"<refpurpose>Un cliente de Subversion para KDE (aplicación autónoma)</"
"refpurpose>"

#. Tag: cmdsynopsis
#: man-kdesvn.1.docbook:29
#, no-c-format
msgid ""
"<command>kdesvn</command> <arg choice=\"opt\"><replaceable>options</"
"replaceable></arg> <arg choice=\"plain\"><replaceable>exec</replaceable></"
"arg> <arg choice=\"plain\"><replaceable>&lt;command&gt;</replaceable></arg> "
"<arg choice=\"opt\"><replaceable>URL</replaceable></arg>"
msgstr ""
"<command>kdesvn</command> <arg choice=\"opt\"><replaceable>opciones</"
"replaceable></arg> <arg choice=\"plain\"><replaceable>ejecutar</"
"replaceable></arg> <arg choice=\"plain\"><replaceable>&lt;orden&gt;</"
"replaceable></arg> <arg choice=\"opt\"><replaceable>URL</replaceable></arg>"

#. Tag: title
#: man-kdesvn.1.docbook:39
#, no-c-format
msgid "Description"
msgstr "Descripción"

#. Tag: para
#: man-kdesvn.1.docbook:40
#, no-c-format
msgid "<para>A Subversion client by KDE (standalone application)</para>"
msgstr "<para>Un cliente de Subversion para KDE (aplicación autónoma)</para>"

#. Tag: title
#: man-kdesvn.1.docbook:43
#, no-c-format
msgid "Options"
msgstr "Opciones"

#. Tag: title
#: man-kdesvn.1.docbook:45
#, no-c-format
msgid "Arguments:"
msgstr "Argumentos:"

#. Tag: term
#: man-kdesvn.1.docbook:48
#, no-c-format
msgid "<emphasis>exec</emphasis> &lt;command&gt;"
msgstr "<emphasis>exec</emphasis> &lt;orden&gt;"

#. Tag: para
#: man-kdesvn.1.docbook:49
#, no-c-format
msgid ""
"Execute subversion command (\"exec help\" for more information, opens KDE "
"Help Center)"
msgstr ""
"Ejecutar orden de Subversion («exec help» para más información, que abre el "
"centro de ayuda de KDE)"

#. Tag: emphasis
#: man-kdesvn.1.docbook:53
#, no-c-format
msgid "<emphasis>URL</emphasis>"
msgstr "<emphasis>URL</emphasis>"

#. Tag: para
#: man-kdesvn.1.docbook:55
#, no-c-format
msgid "Path to local working copy or a repository."
msgstr "Ruta a la copia de trabajo local o a un repositorio."

#. Tag: title
#: man-kdesvn.1.docbook:61
#, no-c-format
msgid "Options:"
msgstr "Opciones:"

#. Tag: option
#: man-kdesvn.1.docbook:64
#, no-c-format
msgid "-r startrev[:endrev]"
msgstr "-r startrev[:endrev]"

#. Tag: para
#: man-kdesvn.1.docbook:66
#, no-c-format
msgid "Execute single subversion command on specific revision(-range)"
msgstr "Ejecuta una orden de Subversion en una revisión (o intervalo) indicada"

#. Tag: option
#: man-kdesvn.1.docbook:70
#, no-c-format
msgid "<option>-R</option>"
msgstr "<option>-R</option>"

#. Tag: para
#: man-kdesvn.1.docbook:72
#, no-c-format
msgid "Ask for revision when executing single command"
msgstr "Preguntar por la revisión cuando se ejecute una orden"

#. Tag: option
#: man-kdesvn.1.docbook:76
#, no-c-format
msgid "<option>-f</option>"
msgstr "<option>-f</option>"

#. Tag: para
#: man-kdesvn.1.docbook:78
#, no-c-format
msgid "Force operation"
msgstr "Forzar la operación"

#. Tag: option
#: man-kdesvn.1.docbook:82
#, no-c-format
msgid "-o &lt;file&gt;"
msgstr "-o &lt;archivo&gt;"

#. Tag: para
#: man-kdesvn.1.docbook:84
#, no-c-format
msgid ""
"Save output of subversion command (eg <quote>cat</quote>) into file &lt;"
"file&gt;"
msgstr ""
"Guardar la salida de la orden de Subversion (por ejemplo, «cat») en el &lt;"
"archivo&gt;"

#. Tag: option
#: man-kdesvn.1.docbook:88
#, no-c-format
msgid "-l &lt;number&gt;"
msgstr "-l &lt;número&gt;"

#. Tag: para
#: man-kdesvn.1.docbook:90
#, no-c-format
msgid "Limit log output to &lt;number&gt;"
msgstr "Limitar la salida de registro a &lt;número&gt;"

#. Tag: title
#: man-kdesvn.1.docbook:99
#, no-c-format
msgid "Example"
msgstr "Ejemplo"

#. Tag: para
#: man-kdesvn.1.docbook:100
#, no-c-format
msgid "kdesvn file:///<replaceable>path/to/local/working/copy</replaceable>"
msgstr ""
"kdesvn file:///<replaceable>ruta/a/la/copia/de/trabajo/local</replaceable>"

#. Tag: para
#: man-kdesvn.1.docbook:101
#, no-c-format
msgid "kdesvn http://<replaceable>remote/svn/project/trunk</replaceable>"
msgstr "kdesvn http://<replaceable>remoto/svn/proyecto/trunk</replaceable>"

#. Tag: title
#: man-kdesvn.1.docbook:105
#, no-c-format
msgid "See Also"
msgstr "Consulte también"

#. Tag: member
#: man-kdesvn.1.docbook:107
#, no-c-format
msgid ""
"Full user documentation is available through the &khelpcenter;. You can also "
"enter the &URL; <emphasis>help:/kdesvn/</emphasis> directly into &konqueror; "
"or you can run <emphasis>`khelpcenter help:/kdesvn/'</emphasis> from the "
"command-line."
msgstr ""
"Dispone de documentación de usuario completa a través del &khelpcenter;. "
"También puede introducir el URL <emphasis>help:/kdesvn/</emphasis> "
"directamente en &konqueror; o ejecutar <emphasis>«khelpcenter help:/"
"kdesvn/»</emphasis> en la línea de órdenes."

