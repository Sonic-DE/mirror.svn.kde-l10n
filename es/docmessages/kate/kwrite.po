#. Tag: para
#: index.docbook:33
#, no-c-format
msgid ""
"&kwrite; is a text editor by &kde; allowing you to edit one file at the time "
"per window."
msgstr ""
"&kwrite; es un editor de texto para &kde; que le permite editar un archivo a "
"la vez por cada ventana."

#. Tag: keyword
#: index.docbook:37
#, no-c-format
msgid "<keyword>KDE</keyword>"
