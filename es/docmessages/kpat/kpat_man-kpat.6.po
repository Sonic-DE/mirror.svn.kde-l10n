msgstr "Muestra los autores de &kpatience; en la ventana del terminal"

#. Tag: option
#: man-kpat.6.docbook:123
#, no-c-format
msgid "--license"
msgstr "--license"

#. Tag: para
#: man-kpat.6.docbook:124
#, no-c-format
