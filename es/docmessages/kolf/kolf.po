msgstr ""
"<guimenu>Juego</guimenu><guimenuitem>Guardar partida como…</guimenuitem>"

#. Tag: para
#: index.docbook:291
#, no-c-format
msgid ""
"Open a file dialog allowing you to <action>save the current game with a "
"filename of your choice.</action>"
msgstr ""
"Abre un diálogo que te permitirá <action>guardar el juego con el nombre de "
