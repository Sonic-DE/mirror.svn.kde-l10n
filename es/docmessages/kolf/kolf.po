"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap></keycap></keycombo></"
"shortcut><guimenu>Hoyo</guimenu><guimenuitem>Deshacer golpe</guimenuitem>"

#. Tag: action
#: index.docbook:415
#, no-c-format
msgid "Undo the last shot you made."
msgstr "Deshace el último golpe efectuado."

