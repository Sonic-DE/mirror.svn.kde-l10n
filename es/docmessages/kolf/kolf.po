"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap> I</keycap></keycombo></"
"shortcut><guimenu>Hoyo</guimenu><guimenuitem>Mostrar información</"
"guimenuitem>"

#. Tag: action
#: index.docbook:403
#, no-c-format
