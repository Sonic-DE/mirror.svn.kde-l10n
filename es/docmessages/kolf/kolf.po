"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap> R</keycap></keycombo></"
"shortcut><guimenu>Hoyo</guimenu><guimenuitem>Reiniciar</guimenuitem>"

#. Tag: para
#: index.docbook:390
#, no-c-format
