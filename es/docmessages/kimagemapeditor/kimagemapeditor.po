#. Tag: title
#: index.docbook:53
#, no-c-format
msgid "Using &kimagemapeditor;"
msgstr "Uso de &kimagemapeditor;"

#. Tag: para
#: index.docbook:55
#, no-c-format
msgid ""
"&kimagemapeditor; is a &HTML; imagemap editor developed by the &kde; "
"community. It allows you to create and modify &HTML; <ulink url=\"http://en."
"wikipedia.org/wiki/Imagemap\">Imagemaps.</ulink>"
msgstr ""
"&kimagemapeditor; es un editor de mapas de imágenes &HTML; desarrollado por "
"la comunidad &kde; que le permite crear y modificar mapas de imágenes &HTML; "
"<ulink url=\"http://en.wikipedia.org/wiki/Imagemap\">Mapas de imagen.</ulink>"

#. Tag: screeninfo
#: index.docbook:61
#, no-c-format
