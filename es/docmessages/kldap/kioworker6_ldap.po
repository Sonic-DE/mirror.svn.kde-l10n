#. Tag: para
#: index.docbook:17
#, no-c-format
msgid ""
"<acronym>ldap</acronym> is the lightweight directory access protocol. It "
"provides access to an X.500 directory, or to a stand-alone <acronym>LDAP</"
"acronym> server."
msgstr ""
"<acronym>ldap</acronym> es un protocolo ligero de acceso a directorios. "
"Proporciona acceso a un directorio X.500, o a un servidor <acronym>LDAP</"
"acronym>."

#. Tag: para
#: index.docbook:21
#, no-c-format
msgid "You can use the ldap KIO worker as follows:"
msgstr "Puede usar el módulo de trabajo ldap del siguiente modo:"

#. Tag: para
#: index.docbook:23
#, no-c-format
msgid ""
"<userinput>ldap://host:port/ou=People,o=where,c=de??sub</userinput> for a "
"subtree-query"
msgstr ""
"<userinput>ldap://maquina:puerto/ou=People,o=where,c=de??sub</userinput> "
"para una petición de un subárbol"

#. Tag: para
#: index.docbook:26
#, no-c-format
msgid ""
"or <userinput>ldap://host:port/cn=MM,ou=People,o=where,c=de??base</"
"userinput> for a complete branch."
msgstr ""
"o <userinput>ldap://maquina:puerto/cn=MM,ou=People,o=where,c=de??base</"
"userinput> para obtener una rama completa."
