#. Tag: entry
#: index.docbook:1944
#, no-c-format
msgid "hyperg_1F1(a,b,x)"
msgstr "hyperg_1F1(a,b,x)"

#. Tag: action
#: index.docbook:1944
#, no-c-format
msgid ""
"confluent hypergeometric function <subscript>1</subscript>F<subscript>1</"
"subscript>(a,b,x) = M(a,b,x) for general parameters a,b"
msgstr ""
"función hipergeométrica confluente <subscript>1</subscript>F<subscript>1</"
"subscript>(a,b,x) = M(a,b,x) para parámetros generales a, b"

#. Tag: entry
#: index.docbook:1945
#, no-c-format
msgid "hyperg_Ui(m,n,x)"
msgstr "hyperg_Ui(m,n,x)"

#. Tag: action
#: index.docbook:1945
#, no-c-format
msgid "confluent hypergeometric function U(m,n,x) for integer parameters m,n"
msgstr ""
"función hipergeométrica confluente U(m,n,x) para parámetros enteros m, n"

#. Tag: entry
#: index.docbook:1946
#, no-c-format
msgid "hyperg_U(a,b,x)"
msgstr "hyperg_U(a,b,x)"

#. Tag: action
#: index.docbook:1946
#, no-c-format
msgid "confluent hypergeometric function U(a,b,x)"
msgstr "función hipergeométrica confluente U(a,b,x)"

#. Tag: entry
#: index.docbook:1947
#, no-c-format
msgid "hyperg_2F1(a,b,c,x)"
msgstr "hyperg_2F1(a,b,c,x)"

#. Tag: action
#: index.docbook:1947
#, no-c-format
msgid ""
"Gauss hypergeometric function <subscript>2</subscript>F<subscript>1</"
"subscript>(a,b,c,x)"
msgstr ""
"función hipergeométrica de Gauss <subscript>2</subscript>F<subscript>1</"
"subscript>(a,b,c,x)"

#. Tag: entry
#: index.docbook:1948
#, no-c-format
msgid "hyperg_2F1c(a<subscript>R</subscript>,a<subscript>I</subscript>,c,x)"
msgstr "hyperg_2F1c(a<subscript>R</subscript>,a<subscript>I</subscript>,c,x)"

#. Tag: action
#: index.docbook:1948
#, no-c-format
msgid ""
