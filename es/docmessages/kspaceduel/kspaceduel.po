msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>Q</keycap></keycombo></"
"shortcut> <guimenu>Juego</guimenu> <guimenuitem>Salir</guimenuitem>"

#. Tag: para
#: index.docbook:204
#, no-c-format
msgid "<action>Quits</action> &kspaceduel;."
msgstr "<action>Sale</action> de &kspaceduel;."

#. Tag: menuchoice
