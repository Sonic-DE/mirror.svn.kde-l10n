#. Tag: title
#: man-checkXML6.1.docbook:32
#, no-c-format
msgid "Description"
msgstr "Descripción"

#. Tag: para
#: man-checkXML6.1.docbook:34
#, no-c-format
msgid ""
"<command>checkXML6</command> is a tool to check for syntax errors in &kde; "
"DocBook &XML; files. It can also be used for other DocBook based &XML; "
"files, but you should use the less specific xmllint(1) tool if you are not "
"writing or otherwise working on &kde; documentation."
msgstr ""
"<command>checkXML6</command> es una herramienta para comprobar los errores "
"de sintaxis en los archivos DocBook &XML; de &kde;. También se puede "
"utilizar para otros DocBook basados en archivos &XML;, aunque debería "
"utilizar la herramienta menos específica xmllint(1) si no está escribiendo "
"ni trabajando en la documentación de &kde;."

