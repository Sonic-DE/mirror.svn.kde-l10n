#. Tag: title
#: man-spectacle.1.docbook:35
#, no-c-format
msgid "Description"
msgstr "Descripción"

#. Tag: para
#: man-spectacle.1.docbook:36
#, no-c-format
msgid ""
"<command>spectacle</command> is a simple application for capturing desktop "
"screenshots. It can capture images of the entire desktop, a single monitor, "
"the currently active window, the window currently under the mouse, or a "
"rectangular region of the screen. The images can then be annotated, printed, "
"sent to other applications for manipulation, or quickly be saved as-is."
msgstr ""
"<command>spectacle</command> es una aplicación sencilla para realizar "
"capturas del escritorio. Puede capturar imágenes de la totalidad del "
"escritorio, de un único monitor, de la ventana activa, de la ventana que "
"está bajo el cursor o de un área rectangular de la pantalla. Las imágenes se "
"pueden anotar, imprimir, enviar a otras aplicaciones o guardar tal cual de "
"forma instantánea."

#. Tag: title
#: man-spectacle.1.docbook:40
#, no-c-format
msgid "Spectacle options"
msgstr "Opciones de Spectacle"

#. Tag: option
#: man-spectacle.1.docbook:44
#, no-c-format
msgid "-h, --help"
msgstr "-h, --help"

#. Tag: para
#: man-spectacle.1.docbook:46
#, no-c-format
msgid "Displays help on commandline options."
msgstr "Muestra ayuda sobre las opciones de la línea de órdenes."

#. Tag: option
#: man-spectacle.1.docbook:51
#, no-c-format
msgid "--help-all"
msgstr "--help-all"

#. Tag: para
#: man-spectacle.1.docbook:53
#, no-c-format
msgid "Displays help including Qt specific options."
msgstr "Muestra ayuda que incluye las opciones específicas de Qt."

#. Tag: option
#: man-spectacle.1.docbook:58
#, no-c-format
msgid "-v, --version"
msgstr "-v, --version"

#. Tag: para
#: man-spectacle.1.docbook:60
#, no-c-format
msgid "Displays version information."
msgstr "Muestra información sobre la versión."

#. Tag: option
#: man-spectacle.1.docbook:65
#, no-c-format
msgid "-f, --fullscreen"
msgstr "-f, --fullscreen"

#. Tag: para
#: man-spectacle.1.docbook:67
#, no-c-format
msgid "Capture the entire desktop (default)."
msgstr "Capturar todo el escritorio (por omisión)."

#. Tag: option
#: man-spectacle.1.docbook:72
#, no-c-format
msgid "--scaled"
msgstr "--scaled"

#. Tag: para
#: man-spectacle.1.docbook:74
#, no-c-format
msgid ""
"When used with <option>-f</option>/<option>--fullscreen</option>, capture "
"all screens scaled to the same size. Has no effect without <option>-f</"
"option>."
msgstr ""
"Cuando se usa con <option>-f</option>/<option>--fullscreen</option>, "
"capturar todas las pantallas escaladas al mismo tamaño. No tiene efecto sin "
"<option>-f</option>."

#. Tag: option
#: man-spectacle.1.docbook:79
#, no-c-format
msgid "-m, --current"
msgstr "-m, --current"

#. Tag: para
#: man-spectacle.1.docbook:81
#, no-c-format
msgid "Capture the current monitor."
msgstr "Capturar el monitor actual."

#. Tag: option
#: man-spectacle.1.docbook:86
#, no-c-format
msgid "-a, --activewindow"
msgstr "-a, --activewindow"

#. Tag: para
#: man-spectacle.1.docbook:88
#, no-c-format
msgid "Capture the active window."
msgstr "Capturar la ventana activa."

#. Tag: option
#: man-spectacle.1.docbook:93
#, no-c-format
msgid "-u, --windowundercursor"
msgstr "-u, --windowundercursor"

#. Tag: para
#: man-spectacle.1.docbook:95
#, no-c-format
msgid ""
"Capture the window currently under the cursor, including parents of pop-up "
"menus."
msgstr ""
"Capturar la ventana que está bajo el cursor, incluyendo ventanas de nivel "
"superior y menús emergentes."

#. Tag: option
#: man-spectacle.1.docbook:100
#, no-c-format
msgid "-t, --transientonly"
msgstr "-t, --transientonly"

#. Tag: para
#: man-spectacle.1.docbook:102
#, no-c-format
msgid ""
"Capture the window currently under the cursor, excluding parents of pop-up "
"menus."
msgstr ""
"Capturar la ventana que está bajo el cursor, excluyendo ventanas de nivel "
"superior y menús emergentes."

#. Tag: option
#: man-spectacle.1.docbook:107
#, no-c-format
msgid "-r, --region"
msgstr "-r, --region"

#. Tag: para
#: man-spectacle.1.docbook:109
#, no-c-format
msgid "Capture a rectangular region of the screen."
msgstr "Capturar una región rectangular de la pantalla."

#. Tag: option
#: man-spectacle.1.docbook:114
#, no-c-format
msgid "-l, --launchonly"
msgstr "-l, --launchonly"

#. Tag: para
#: man-spectacle.1.docbook:116
#, no-c-format
msgid "Launch Spectacle without taking a screenshot."
msgstr "Iniciar Spectacle sin hacer una captura de pantalla."

#. Tag: option
#: man-spectacle.1.docbook:121
#, no-c-format
msgid "-g, --gui"
msgstr "-g, --gui"

#. Tag: para
#: man-spectacle.1.docbook:123
#, no-c-format
msgid "Start in GUI mode (default)."
msgstr "Empezar en el modo con interfaz gráfica de usuario (por omisión)."

#. Tag: option
#: man-spectacle.1.docbook:128
#, no-c-format
msgid "-b, --background"
msgstr "-b, --background"

#. Tag: para
#: man-spectacle.1.docbook:130
#, no-c-format
msgid "Take a screenshot and exit without showing the GUI."
msgstr ""
"Realizar una captura de pantalla y salir sin mostrar la interfaz gráfica de "
"usuario."

#. Tag: option
#: man-spectacle.1.docbook:135
#, no-c-format
msgid "-s, --dbus"
msgstr "-s, --dbus"

#. Tag: para
#: man-spectacle.1.docbook:137
#, no-c-format
msgid "Start in DBus-Activation mode."
msgstr "Empezar en el modo de activación de DBus."

#. Tag: option
#: man-spectacle.1.docbook:142
#, no-c-format
msgid "-n, --nonotify"
msgstr "-n, --nonotify"

#. Tag: para
#: man-spectacle.1.docbook:144
#, no-c-format
msgid ""
"In background mode, do not pop up a notification when the screenshot is "
"taken."
msgstr ""
"En el modo de segundo plano, no mostrar una notificación cuando se realiza "
"una captura de pantalla."

#. Tag: option
#: man-spectacle.1.docbook:149
#, no-c-format
msgid "-o, --output <replaceable>fileName</replaceable>"
msgstr "-o, --output <replaceable>archivo</replaceable>"

#. Tag: para
#: man-spectacle.1.docbook:151
#, no-c-format
msgid ""
"In background mode, save image to specified file <replaceable>fileName</"
"replaceable>."
msgstr ""
"En el modo de segundo plano, guardar la imagen en el <replaceable>archivo</"
"replaceable> indicado."

#. Tag: option
#: man-spectacle.1.docbook:156
#, no-c-format
msgid "-d, --delay <replaceable>delayMsec</replaceable>"
msgstr "-d, --delay <replaceable>milisegundos</replaceable>"

#. Tag: para
#: man-spectacle.1.docbook:158
#, no-c-format
msgid "In background mode, delay before taking the shot (in milliseconds)."
msgstr ""
"En el modo de segundo plano, hacer una pausa antes de realizar la captura "
"(en milisegundos)."

#. Tag: option
#: man-spectacle.1.docbook:163
#, no-c-format
msgid "-c, --copy-image"
msgstr "-c, --copy-image"

#. Tag: para
#: man-spectacle.1.docbook:165
#, no-c-format
msgid ""
"In background mode, copy screenshot only to clipboard, unless -o is also "
"used."
msgstr ""
"En el modo de segundo plano, copiar la captura de pantalla solo en el "
"portapapeles, excepto si también se ha usado -o."

#. Tag: option
#: man-spectacle.1.docbook:170
#, no-c-format
msgid "-C, --copy-path"
msgstr "-C, --copy-path"

#. Tag: para
#: man-spectacle.1.docbook:172
#, no-c-format
msgid "In background mode, copy screenshot file path to clipboard."
msgstr ""
"En el modo de segundo plano, copiar la ruta del archivo de la captura de "
"pantalla en el portapapeles."

#. Tag: option
#: man-spectacle.1.docbook:177
#, no-c-format
msgid "-w, --onclick"
msgstr "-w, --onclick"

#. Tag: para
#: man-spectacle.1.docbook:179
#, no-c-format
msgid "Wait for a click before taking screenshot. Invalidates delay.."
msgstr ""
"Esperar un clic antes de realizar la captura de pantalla. Invalida la demora."

#. Tag: option
#: man-spectacle.1.docbook:184
#, no-c-format
msgid "-i, --new-instance"
msgstr "-i, --new-instance"

#. Tag: para
#: man-spectacle.1.docbook:186
#, no-c-format
msgid "Starts a new GUI instance of spectacle without registering to DBus."
msgstr ""
"Inicia una nueva instancia gráfica de Spectacle sin registrarla en DBus."

#. Tag: option
#: man-spectacle.1.docbook:191
#, no-c-format
msgid "-p, --pointer"
msgstr "-p, --pointer"

#. Tag: para
#: man-spectacle.1.docbook:193
#, no-c-format
msgid "In background mode, include pointer in the screenshot."
msgstr ""
"En el modo de segundo plano, incluir el puntero en la captura de pantalla."

#. Tag: option
#: man-spectacle.1.docbook:198
#, no-c-format
msgid "-e, --no-decoration"
msgstr "-e, --no-decoration"

#. Tag: para
#: man-spectacle.1.docbook:200
#, no-c-format
msgid ""
"In background mode, do not include window decorations in the screenshot."
msgstr ""
"En el modo de segundo plano, no incluir las decoraciones de las ventanas en "
"la captura de pantalla."

#. Tag: option
#: man-spectacle.1.docbook:205
#, no-c-format
msgid "-E, --edit-existing <replaceable>existingFileName</replaceable>"
msgstr "-E, --edit-existing <replaceable>archivoExistente</replaceable>"

#. Tag: para
#: man-spectacle.1.docbook:207
#, no-c-format
msgid "Open and edit existing screenshot file."
msgstr "Abre y edita un archivo de captura de pantalla existente."

#. Tag: title
#: man-spectacle.1.docbook:213
#, no-c-format
msgid "Feedback"
msgstr "Comentarios"

