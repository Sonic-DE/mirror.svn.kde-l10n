#. Tag: para
#: index.docbook:39
#, no-c-format
msgid ""
"The TNEF File Viewer is an application for <ulink url=\"https://en.wikipedia."
"org/wiki/TNEF\">TNEF</ulink> mail attachments."
msgstr ""
"El visor de archivos TNEF es una aplicación para adjuntos de correo <ulink "
"url=\"https://en.wikipedia.org/wiki/TNEF\">TNEF</ulink>."

