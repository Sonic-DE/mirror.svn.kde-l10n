#. Tag: para
#: configure.docbook:167
#, no-c-format
msgid ""
"Enter a name for the new identity in the <guilabel>New Identity</guilabel> "
"edit field. This name will be shown in the identity list."
msgstr ""
"Introduzca el nombre de una nueva identidad en el campo <guilabel>Nueva "
"identidad</guilabel>. Este nombre se mostrará en la lista de identidades."

#. Tag: para
#: configure.docbook:171
#, fuzzy, no-c-format
#| msgid ""
