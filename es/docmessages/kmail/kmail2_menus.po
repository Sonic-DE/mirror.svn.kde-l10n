#. Tag: para
#: menus.docbook:107
#, no-c-format
msgid "Opens saved email messages (.mbox files)."
msgstr "Abre mensajes de correo guardados (archivos .mbox)."

#. Tag: menuchoice
#: menus.docbook:111
#, no-c-format
msgid "<guimenu>File</guimenu><guimenuitem>Open Recent</guimenuitem>"
msgstr "<guimenu>Archivo</guimenu><guimenuitem>Abrir reciente</guimenuitem>"

#. Tag: para
#: menus.docbook:112
#, no-c-format
msgid ""
"Displays a list of recently opened messages. Only those messages that have "
"been saved as .mbox files and subsequently opened will appear on this list. "
"If no such files exist, this menu item will be grayed out."
msgstr ""

#. Tag: menuchoice
#: menus.docbook:118
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>S</keycap></keycombo></"
"shortcut> <guimenu>File</guimenu><guimenuitem>Save As...</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>S</keycap></keycombo></"
"shortcut> <guimenu>Archivo</guimenu><guimenuitem>Guardar como…</guimenuitem>"

#. Tag: para
#: menus.docbook:120
#, fuzzy, no-c-format
#| msgid ""
#| "If you would like to save it to a different format &eg; <filename role="
#| "\"extension\">.txt</filename>, deselect <guilabel>Automatically select "
#| "filename extension (.mbox)</guilabel>, and be sure to change the file "
#| "extension while naming the file."
msgid ""
"Saves the currently displayed message to a <filename role=\"extension\">."
"mbox</filename> file. This file includes all the headers and attachments, in "
"&MIME; format. If you want to save it as a different format (&eg;, as a "
"<filename role=\"extension\">.txt</filename> file), uncheck the "
"<guilabel>Automatically select filename extension (.mbox)</guilabel> box, "
"and add the filename extension before saving the file."
msgstr ""
"Si le gustaría guardarlo en un formato diferente, &eg; <filename role="
"\"extension\">.txt</filename>, desmarque <guilabel>Seleccionar "
"automáticamente la extensión del archivo (.mbox)</guilabel> y asegúrese de "
"cambiar la extensión al nombrar el archivo."

#. Tag: menuchoice
#: menus.docbook:127
#, no-c-format
msgid "<guimenu>File</guimenu><guimenuitem>Export to PDF...</guimenuitem>"
msgstr "<guimenu>Archivo</guimenu><guimenuitem>Exportar a PDF…</guimenuitem>"

#. Tag: para
#: menus.docbook:128
#, no-c-format
msgid "Exports the currently displayed message as a .pdf file."
msgstr "Exporta el mensaje que se muestra actualmente como un archivo PDF."

#. Tag: menuchoice
#: menus.docbook:132
#, no-c-format
msgid "<guimenu>File</guimenu><guimenuitem>Import Messages...</guimenuitem>"
