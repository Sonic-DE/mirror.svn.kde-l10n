"ahora tienen una sección llamada «Fusión de directorio» con estas opciones:"

#. Tag: guilabel
#: index.docbook:1530
#, no-c-format
msgid "Recursive folders"
msgstr "Carpetas recursivas"

#. Tag: para
#: index.docbook:1530
#, no-c-format
msgid "Select whether to search folders recursively."
msgstr "Indica si se realizará la búsqueda en las carpetas de forma recursiva."

#. Tag: guilabel
#: index.docbook:1532
#, no-c-format
msgid "File pattern(s):"
msgstr "Patrones de archivos:"

#. Tag: para
#: index.docbook:1532
#, fuzzy, no-c-format
#| msgid ""
#| "Only files that match any pattern here will be put in the tree. More than "
