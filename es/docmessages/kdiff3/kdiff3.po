#. Tag: para
#: index.docbook:1671
#, no-c-format
msgid "Other things that are possible, but probably less useful are:"
msgstr "Otras cosas posibles, aunque probablemente menos útiles, son:"

#. Tag: para
#: index.docbook:1675
#, no-c-format
msgid "Man-pages (man:),"
msgstr "Páginas de manual (man:)."

#. Tag: para
#: index.docbook:1676
#, no-c-format
msgid "Info-pages (info:),"
