#. Tag: para
#: index.docbook:59
#, no-c-format
msgid "&kdiff3; is a file and folder diff and merge tool which"
msgstr ""
"&kdiff3; es una herramienta para ver diferencias y fusionar archivos y "
"carpetas que:"

#. Tag: para
#: index.docbook:62
#, no-c-format
msgid "compares and merges two or three text input files or folders,"
msgstr "Compara y fusiona dos o tres archivos de texto o carpetas."

#. Tag: para
#: index.docbook:63
#, no-c-format
msgid "shows the differences line by line and character by character(!),"
msgstr "Muestra las diferencias línea a línea y carácter a carácter (!)."

#. Tag: para
#: index.docbook:64
#, no-c-format
msgid "provides an automatic merge-facility,"
msgstr "Proporciona una utilidad de fusión automática."

#. Tag: para
#: index.docbook:65
#, no-c-format
msgid "has an editor for comfortable solving of merge-conflicts,"
msgstr ""
"Tiene un editor para resolver de forma cómoda los conflictos de fusión."

#. Tag: para
#: index.docbook:66
#, no-c-format
msgid "provides network transparency via KIO,"
msgstr "Proporciona transparencia de red a través de KIO."

#. Tag: para
#: index.docbook:67
#, no-c-format
msgid "has options to highlight or hide changes in white-space or comments,"
msgstr ""
"Tiene opciones para resaltar u ocultar los cambios en los espacios en blanco "
"o en los comentarios."

#. Tag: para
#: index.docbook:68
#, no-c-format
msgid "supports Unicode, UTF-8 and other file encodings,"
msgstr "Permite usar Unicode, UTF-8 y otras codificaciones de archivo."

#. Tag: para
#: index.docbook:69
#, no-c-format
msgid "prints differences,"
msgstr "Imprime diferencias."

#. Tag: para
#: index.docbook:70
#, no-c-format
msgid "supports version control keyword and history merging."
msgstr "Permite claves de control de versiones e historial de fusiones."

#. Tag: para
#: index.docbook:72
