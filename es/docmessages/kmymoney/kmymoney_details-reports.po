#, no-c-format
msgid "By Category"
msgstr "Por categoría"

#. Tag: para
#: details-reports.docbook:73
#, no-c-format
msgid "By Month or Week"
msgstr "Por mes o semana"

#. Tag: para
#: details-reports.docbook:74
#, no-c-format
