#. Tag: title
#: man-kmymoney.1.docbook:121
#, no-c-format
msgid "Description"
msgstr "Descripción"

#. Tag: para
#: man-kmymoney.1.docbook:123
#, no-c-format
msgid ""
"&kmymoney; is the Personal Finance Manager by &kde;. It provides the "
"functions required to balance your checkbooks, manage your personal loans "
"and categories your incomes and expenses using a checkbook style graphical "
"user interface."
msgstr ""
"&kmymoney; es el gestor de finanzas personales creado por &kde;. Proporciona "
"las funciones requeridas para hacer el balance de sus cheques, gestionar sus "
"préstamos personales y categorizar sus ingresos y gastos usando un interfaz "
"de usuario el estilo de un libro de cheques."

#. Tag: title
#: man-kmymoney.1.docbook:131
#, no-c-format
msgid "Options"
msgstr "Opciones"

#. Tag: option
#: man-kmymoney.1.docbook:136
#, no-c-format
msgid "--lang"
msgstr "--lang"

#. Tag: para
#: man-kmymoney.1.docbook:138
#, no-c-format
msgid "Language to be used"
msgstr "Idioma a usar"

#. Tag: option
#: man-kmymoney.1.docbook:143
#, no-c-format
msgid "<option>-n</option>"
msgstr "<option>-n</option>"

#. Tag: para
#: man-kmymoney.1.docbook:145
#, no-c-format
msgid "Do not open last used file"
msgstr "No abrir el último archivo usado"

#. Tag: option
#: man-kmymoney.1.docbook:150
#, no-c-format
msgid "--timers"
msgstr "--timers"

#. Tag: para
#: man-kmymoney.1.docbook:152
#, no-c-format
msgid "Enable performance timers"
msgstr "Activa los temporizadores de rendimiento"

#. Tag: option
#: man-kmymoney.1.docbook:157
#, no-c-format
msgid "--nocatch"
msgstr "--nocatch"

#. Tag: para
#: man-kmymoney.1.docbook:159
#, no-c-format
msgid "Do not globally catch uncaught exceptions"
msgstr "No capturar globalmente excepciones no capturadas"

#. Tag: option
#: man-kmymoney.1.docbook:164
#, no-c-format
msgid "--trace"
msgstr "--trace"

#. Tag: para
#: man-kmymoney.1.docbook:166
#, no-c-format
msgid ""
"Turn on program traces. This option is only available when &kmymoney; is "
"compiled in debug mode."
msgstr ""
"Activar las trazas del programa. Esta opción solo está disponible si "
"&kmymoney; se ha compilado en modo de depuración."

#. Tag: option
#: man-kmymoney.1.docbook:174
#, no-c-format
msgid "--dump-actions"
msgstr "--dump-actions"

#. Tag: para
#: man-kmymoney.1.docbook:176
#, no-c-format
msgid ""
"Dump the names of all defined QAction objects to stdout and quit. This "
"option is only available when &kmymoney; is compiled in debug mode."
msgstr ""
"Vuelca los nombres de todos los objetos QAction definidos a «stdout» y sale. "
"Esta opción solo está disponible si &kmymoney; se ha compilado en modo de "
"depuración."

