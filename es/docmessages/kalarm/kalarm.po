msgstr ""
"Una lista de direcciones de correo electrónico de destinatarios, separadas "
"por comas."

#. Tag: parameter
#: index.docbook:4471
#, no-c-format
msgid "subject"
msgstr "asunto"

#. Tag: para
#: index.docbook:4473
#, no-c-format
msgid "Specifies the subject line of the email."
msgstr "Especifica la línea del asunto del correo."

#. Tag: para
#: index.docbook:4480
#, no-c-format
