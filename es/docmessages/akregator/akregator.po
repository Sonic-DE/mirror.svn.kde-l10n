#. Tag: para
#: index.docbook:1065
#, no-c-format
msgid "<action>Open</action> your mail client and attach the link in the mail."
msgstr ""
"<action>Abrir</action> su cliente de correo y adjuntar el enlace en el "
"correo."

#. Tag: menuchoice
#: index.docbook:1069
#, no-c-format
msgid "<guimenu>Article</guimenu> <guimenuitem>Send File...</guimenuitem>"
msgstr "<guimenu>Artículo</guimenu> <guimenuitem>Enviar archivo…</guimenuitem>"

