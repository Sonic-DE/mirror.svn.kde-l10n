msgstr ""
"<action>Abrir</action> el artículo actual en una pestaña dentro &akregator;"

#. Tag: menuchoice
#: index.docbook:1011
#, no-c-format
msgid ""
"<shortcut><keycap>Return</keycap></shortcut> <guimenu>Article</guimenu> "
"<guimenuitem>Open in Background Tab</guimenuitem>"
msgstr ""
"<shortcut><keycap>Intro</keycap></shortcut> <guimenu>Artículo</guimenu> "
"<guimenuitem>Abrir en pestaña de fondo</guimenuitem>"

#. Tag: para
#: index.docbook:1016
#, no-c-format
msgid ""
"<action>Load</action> the current article in into a new tab, but not "
"automatically activate that tab. That is useful to browse a feed, open all "
"interesting articles into background tabs and later read them all."
msgstr ""
"<action>Carga</action> el artículo actual en una nueva pestaña, pero no "
"activa automáticamente la pestaña. Esto es útil para examinar una fuente, "
"abrir todos los artículos interesantes en pestañas de fondo y leerlas todas "
"posteriormente."

#. Tag: menuchoice
#: index.docbook:1023
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl; &Shift;<keycap>Return</keycap></"
"keycombo></shortcut> <guimenu>Article</guimenu> <guimenuitem>Open in "
"External Browser.</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl; &Shift;<keycap>Volver</keycap></"
"keycombo></shortcut> <guimenu>Artículo</guimenu> <guimenuitem>Abrir en un "
"navegador externo.</guimenuitem>"

#. Tag: para
#: index.docbook:1029
#, no-c-format
msgid "<action>Open</action> the current article in an external browser"
msgstr "<action>Abrir</action> el artículo actual en un navegador externo"

#. Tag: menuchoice
#: index.docbook:1033
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>I</keycap></keycombo></"
"shortcut> <guimenu>Article</guimenu> <guimenuitem>Mark as Important</"
"guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>I</keycap></keycombo></"
"shortcut> <guimenu>Artículo</guimenu> <guimenuitem>Marcar como importante</"
"guimenuitem>"

#. Tag: para
#: index.docbook:1039
#, no-c-format
msgid "<action>Mark</action> the current article as important"
msgstr "<action>Marcar</action> el artículo actual como importante"

#. Tag: menuchoice
#: index.docbook:1043
#, no-c-format
msgid "<guimenu>Article</guimenu> <guimenuitem>Mark as</guimenuitem>"
msgstr "<guimenu>Artículo</guimenu> <guimenuitem>Marcar como</guimenuitem>"

#. Tag: para
#: index.docbook:1047
#, no-c-format
msgid ""
"<action>Mark</action> the current article as Read <keycombo action=\"simul"
"\">&Ctrl;<keycap>E</keycap></keycombo>, New <keycombo action=\"simul\">&Ctrl;"
"<keycap>N</keycap></keycombo> or Unread <keycombo action=\"simul\">&Ctrl;"
"<keycap>U</keycap></keycombo>"
msgstr ""
"<action>Marca</action> el articulo actual como leído <keycombo action=\"simul"
"\">&Ctrl;<keycap>E</keycap></keycombo>, nuevo <keycombo action=\"simul"
"\">&Ctrl;<keycap>N</keycap></keycombo> o no leído <keycombo action=\"simul"
"\">&Ctrl;<keycap>U</keycap></keycombo>"

#. Tag: menuchoice
#: index.docbook:1053
#, no-c-format
msgid ""
"<shortcut><keycap>Del</keycap></shortcut> <guimenu>Article</guimenu> "
"<guimenuitem>Delete</guimenuitem>"
msgstr ""
"<shortcut><keycap>Supr</keycap></shortcut> <guimenu>Artículo</guimenu> "
"<guimenuitem>Borrar</guimenuitem>"

#. Tag: para
#: index.docbook:1058
#, no-c-format
