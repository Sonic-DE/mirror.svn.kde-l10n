msgstr "<manvolnum>1</manvolnum>"

#. Tag: refpurpose
#: man-plasmoidviewer.1.docbook:21
#, no-c-format
msgid "Run Plasma widgets in their own window"
msgstr "Ejecutar elementos gráficos de Plasma en su propia ventana"

#. Tag: cmdsynopsis
#: man-plasmoidviewer.1.docbook:25
#, no-c-format
msgid ""
"<command>plasmoidviewer</command> <group choice=\"opt\"><option>-v, --"
"version</option></group> <group choice=\"opt\"><option>-c, --containment</"
"option> <replaceable>name</replaceable></group> <group choice=\"opt"
"\"><option>-a, --applet</option> <replaceable>name</replaceable></group> "
"<group choice=\"opt\"><option>-f, --formfactor</option> <replaceable>name</"
"replaceable></group> <group choice=\"opt\"><option>-l, --location</option> "
"<replaceable>name</replaceable></group> <group choice=\"opt\"><option>-x, --"
"xPosition</option> <replaceable>xPosition</replaceable></group> <group "
"choice=\"opt\"><option>-y, --yPosition</option> <replaceable>yPosition</"
"replaceable></group> <group choice=\"opt\"><option>-s, --size</option> "
"<replaceable>widthXheight</replaceable></group> <group choice=\"opt"
"\"><option>-p, --pixmapcache</option> <replaceable>size</replaceable></"
"group> <group choice=\"opt\"><option>-t, --theme</option> <replaceable>name</"
"replaceable></group> <group choice=\"opt\"><option>-h, --help</option></"
"group> <arg choice=\"opt\">args</arg>"
msgstr ""
"<command>plasmoidviewer</command> <group choice=\"opt\"><option>-v, --"
"version</option></group> <group choice=\"opt\"><option>-c, --containment</"
"option> <replaceable>nombre</replaceable></group> <group choice=\"opt"
"\"><option>-a, --applet</option> <replaceable>nombre</replaceable></group> "
"<group choice=\"opt\"><option>-f, --formfactor</option> <replaceable>nombre</"
"replaceable></group> <group choice=\"opt\"><option>-l, --location</option> "
"<replaceable>nombre</replaceable></group> <group choice=\"opt\"><option>-x, "
"--xPosition</option> <replaceable>posiciónX</replaceable></group> <group "
"choice=\"opt\"><option>-y, --yPosition</option> <replaceable>posiciónY</"
"replaceable></group> <group choice=\"opt\"><option>-s, --size</option> "
"<replaceable>anchuraXaltura</replaceable></group> <group choice=\"opt"
"\"><option>-p, --pixmapcache</option> <replaceable>tamaño</replaceable></"
"group> <group choice=\"opt\"><option>-t, --theme</option> "
"<replaceable>nombre</replaceable></group> <group choice=\"opt\"><option>-h, "
"--help</option></group> <arg choice=\"opt\">args</arg>"

#. Tag: title
#: man-plasmoidviewer.1.docbook:44
#, no-c-format
msgid "Description"
msgstr "Descripción"

#. Tag: para
#: man-plasmoidviewer.1.docbook:45
#, no-c-format
msgid ""
"<command>plasmoidviewer</command> is a graphical tool allowing developers to "
"test Plasma applets."
msgstr ""
"<command>plasmoidviewer</command> es una herramienta gráfica que permite que "
"los desarrolladores prueben miniaplicaciones de Plasma."

#. Tag: para
#: man-plasmoidviewer.1.docbook:48
#, no-c-format
msgid ""
"Only installed applets will be found. <command>kbuildsycoca5</command> may "
"need to be run for newly-installed applets to be found."
msgstr ""
"Solo se encontrarán las miniaplicaciones instaladas. Es posible que necesite "
"ejecutar <command>kbuildsycoca5</command> para poder encontrar "
"miniaplicaciones recién instaladas."

#. Tag: title
#: man-plasmoidviewer.1.docbook:54
#, no-c-format
msgid "Options"
msgstr "Opciones"

#. Tag: option
#: man-plasmoidviewer.1.docbook:58
#, no-c-format
msgid "-v, --version"
msgstr "-v, --version"

#. Tag: para
#: man-plasmoidviewer.1.docbook:59
#, no-c-format
msgid "Displays version information."
msgstr "Muestra información sobre la versión."

#. Tag: option
#: man-plasmoidviewer.1.docbook:62
#, no-c-format
msgid "-c, --containment <replaceable>name</replaceable>"
msgstr "-c, --containment <replaceable>nombre</replaceable>"

#. Tag: para
#: man-plasmoidviewer.1.docbook:63
#, no-c-format
msgid "The name of the containment plugin."
msgstr "Nombre del complemento del contenedor."

#. Tag: option
#: man-plasmoidviewer.1.docbook:66
#, no-c-format
msgid "-a, --applet <replaceable>name</replaceable>"
msgstr "-a, --applet <replaceable>nombre</replaceable>"

#. Tag: para
#: man-plasmoidviewer.1.docbook:67
#, no-c-format
msgid "The name of the applet plugin."
msgstr "Nombre del complemento de la miniaplicación."

#. Tag: option
#: man-plasmoidviewer.1.docbook:70
#, no-c-format
msgid "-f, --formfactor <replaceable>name</replaceable>"
msgstr "-f, --formfactor <replaceable>nombre</replaceable>"

#. Tag: para
#: man-plasmoidviewer.1.docbook:71
#, no-c-format
msgid ""
"The formfactor to use (horizontal, vertical, mediacenter, planar or "
"application)."
msgstr ""
"El factor de forma a usar (horizontal, vertical, centro multimedia, plano o "
"aplicación)."

#. Tag: option
#: man-plasmoidviewer.1.docbook:74
#, no-c-format
msgid "-l, --location <replaceable>name</replaceable>"
msgstr "-l, --location <replaceable>nombre</replaceable>"

#. Tag: para
#: man-plasmoidviewer.1.docbook:75
#, no-c-format
msgid ""
"The location constraint to start the Containment with (floating, desktop, "
"fullscreen, topedge, bottomedge, leftedge, rightedge)."
msgstr ""
"La restricción de posición donde comenzará el contenedor (flotante, "
"escritorio, pantalla completa, borde superior, borde inferior, borde "
"izquierdo, borde derecho)."

#. Tag: option
#: man-plasmoidviewer.1.docbook:79
#, no-c-format
msgid "-x, --xPosition <replaceable>xPosition</replaceable>"
msgstr "-x, --xPosition <replaceable>posiciónX</replaceable>"

#. Tag: para
#: man-plasmoidviewer.1.docbook:80
#, no-c-format
msgid "Set the x position of the plasmoidviewer on the Plasma desktop."
msgstr "Define la posición X del visor de plasmoides en el escritorio Plasma."

#. Tag: option
#: man-plasmoidviewer.1.docbook:83
#, no-c-format
msgid "-y, --yPosition <replaceable>yPosition</replaceable>"
msgstr "-y, --yPosition <replaceable>posiciónY</replaceable>"

#. Tag: para
#: man-plasmoidviewer.1.docbook:84
#, no-c-format
msgid "Set the y position of the plasmoidviewer on the Plasma desktop."
msgstr "Define la posición Y del visor de plasmoides en el escritorio Plasma."

#. Tag: option
#: man-plasmoidviewer.1.docbook:87
#, no-c-format
msgid "-s, --size <replaceable>widthXheight</replaceable>"
msgstr "-s, --size <replaceable>anchoXalto</replaceable>"

#. Tag: para
#: man-plasmoidviewer.1.docbook:88
#, no-c-format
msgid "Set the window size of the plasmoidview."
msgstr "Define el tamaño de la ventana del visor de plasmoides."

#. Tag: option
#: man-plasmoidviewer.1.docbook:91
#, no-c-format
msgid "-p, --pixmapcache <replaceable>size</replaceable>"
msgstr "-p, --pixmapcache <replaceable>tamaño</replaceable>"

#. Tag: para
#: man-plasmoidviewer.1.docbook:92
#, no-c-format
msgid "The size in KB to set the pixmap cache to."
msgstr "El tamaño en kB al que ajustar la caché de mapas de píxeles."

#. Tag: option
#: man-plasmoidviewer.1.docbook:95
#, no-c-format
msgid "-t, --theme <replaceable>name</replaceable>"
msgstr "-t, --theme <replaceable>nombre</replaceable>"

#. Tag: para
#: man-plasmoidviewer.1.docbook:96
#, no-c-format
msgid "The name of the theme which the shell will use."
msgstr "Nombre del tema que usará el intérprete."

#. Tag: option
#: man-plasmoidviewer.1.docbook:99
#, no-c-format
msgid "-h, --help"
msgstr "-h, --help"

#. Tag: para
#: man-plasmoidviewer.1.docbook:100
#, no-c-format
msgid "Displays this help."
msgstr "Muestra esta ayuda."

#. Tag: replaceable
#: man-plasmoidviewer.1.docbook:103
#, no-c-format
msgid "args"
msgstr "args"

#. Tag: para
#: man-plasmoidviewer.1.docbook:104
#, no-c-format
msgid "Data that should be passed to the applet as 'externalData' event."
msgstr ""
"Datos que se deben pasar a la miniaplicación como evento «externalData»."

#. Tag: title
#: man-plasmoidviewer.1.docbook:113
#, no-c-format
msgid "See Also"
msgstr "Vea también"

#. Tag: para
#: man-plasmoidviewer.1.docbook:115
#, no-c-format
msgid ""
"More detailed user documentation is available from <ulink url=\"help:/plasma-"
"desktop\">help:/plasma-desktop</ulink> (either enter this <acronym>URL</"
"acronym> into &konqueror;, or run <userinput><command>khelpcenter</command> "
"<parameter>help:/plasma-desktop</parameter></userinput>)."
msgstr ""
"Dispone de una documentación de usuario más detallada en <ulink url=\"help:/"
"plasma-desktop\">help:/plasma-desktop</ulink> (puede introducir esta "
"<acronym>URL</acronym> en &konqueror; o ejecutar "
"<userinput><command>khelpcenter</command> <parameter>help:/plasma-desktop</"
"parameter></userinput>)."

#. Tag: title
#: man-plasmoidviewer.1.docbook:124
#, no-c-format
msgid "Authors"
msgstr "Autores"

#. Tag: para
#: man-plasmoidviewer.1.docbook:125
#, no-c-format
msgid ""
"<command>plasmoidviewer</command> was written by "
"<personname><firstname>Aaron</firstname><surname>Seigo</surname></"
"personname> <email>aseigo@kde.org</email>."
msgstr ""
"<command>plasmoidviewer</command> ha sido escrito por "
"<personname><firstname>Aaron</firstname><surname>Seigo</surname></"
"personname> <email>aseigo@kde.org</email>."

