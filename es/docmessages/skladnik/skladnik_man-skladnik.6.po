#. Tag: term
#: man-skladnik.6.docbook:84
#, no-c-format
msgid "<option>--desktopfile</option> <parameter>FILENAME</parameter>"
msgstr "<option>--desktopfile</option> <parameter>ARCHIVO</parameter>"

#. Tag: para
#: man-skladnik.6.docbook:86
#, no-c-format
msgid ""
"Use FILENAME as the base file name of the desktop entry for this application."
msgstr ""
"Usa ARCHIVO como el nombre de archivo base de la entrada de escritorio para "
"esta aplicación."

