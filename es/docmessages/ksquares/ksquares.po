msgstr "Pantalla"

#. Tag: para
#: index.docbook:249
#, no-c-format
msgid "Here you can change the &ksquares; color settings."
msgstr "Aquí puedes cambiar las preferencias de color de &ksquares;."

#. Tag: guilabel
#: index.docbook:252
#, no-c-format
msgid "Computer Player"
msgstr "Jugador máquina"

#. Tag: para
#: index.docbook:253
#, no-c-format
