msgstr "&no-i18n-tag;<command>1</command>"

#. Tag: entry
#: index.docbook:5347 index.docbook:6664
#, no-c-format
msgid ""
"Save only the sections that are within the current selection. If nothing is "
"selected, the whole file will be saved."
msgstr ""
"Guarda solo las secciones que se encuentran dentro de la selección actual. "
"Si no hay nada seleccionado, se guardará el archivo entero."

#. Tag: replaceable
#: index.docbook:5361
#, no-c-format
msgid "project file"
msgstr "archivo de proyecto"

#. Tag: para
#: index.docbook:5363
#, no-c-format
msgid ""
"The name of the K3b project file, which will also be used as the base name "
"for the exported file names."
msgstr ""
"El nombre del archivo del proyecto K3b, que también se usará como el nombre "
"base para los nombres de archivos exportados."

