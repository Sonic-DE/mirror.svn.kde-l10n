#. Tag: para
#: index.docbook:2493
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Continue</guibutton> toolbar button and lets "
"the playback continue if it is paused."
msgstr ""
"Se corresponde con el botón <guibutton>Continuar</guibutton> de la barra de "
"herramientas y continua la reproducción si está pausada."

