msgstr "Una cadena que determina el dispositivo de grabación."

#. Tag: para
#: index.docbook:6272
#, no-c-format
msgid "The number of channels to use for recording."
msgstr "El número de canales a usar en la grabación."

#. Tag: replaceable
#: index.docbook:6278
#, no-c-format
msgid "sample rate"
msgstr "frecuencia de muestreo"

#. Tag: para
