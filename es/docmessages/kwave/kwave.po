msgstr "&no-i18n-tag;<command>0</command>"

#. Tag: entry
#: index.docbook:5341 index.docbook:6658
#, no-c-format
msgid "Save all sections of the whole file."
msgstr "Guardar todas las secciones del archivo al completo."

#. Tag: entry
#: index.docbook:5346 index.docbook:5401 index.docbook:5519 index.docbook:5611
#: index.docbook:5813 index.docbook:6041 index.docbook:6611 index.docbook:6663
#: index.docbook:6739 index.docbook:7072 index.docbook:7076 index.docbook:7139
