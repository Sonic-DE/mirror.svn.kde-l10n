msgid "<parameter>milliseconds</parameter>:"
msgstr "<parameter>milisegundos</parameter>:"

#. Tag: entry
#: index.docbook:2571
#, no-c-format
msgid "number of whole milliseconds to wait before executing the command"
msgstr "número de milisegundos a esperar antes de ejecutar la orden"

#. Tag: entry
#: index.docbook:2572 index.docbook:2866
#, no-c-format
msgid "<parameter>command</parameter>:"
msgstr "<parameter>orden</parameter>:"

#. Tag: entry
#: index.docbook:2573
#, no-c-format
