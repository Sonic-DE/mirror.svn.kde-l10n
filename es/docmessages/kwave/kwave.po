#. Tag: title
#: index.docbook:7782
#, no-c-format
msgid "File Info"
msgstr "Información del archivo"

#. Tag: title
#: index.docbook:7783
#, no-c-format
msgid "List of File Info Identifiers"
msgstr "Lista de identificadores de información de archivos"

#. Tag: entry
#: index.docbook:7788
#, no-c-format
msgid "Keyword"
msgstr "Palabra clave"

#. Tag: entry
#: index.docbook:7788
#, no-c-format
msgid "&#x0020;"
msgstr "&#x0020;"

#. Tag: entry
#: index.docbook:7788
#, no-c-format
msgid "Description"
msgstr "Descripción"

#. Tag: entry
#: index.docbook:7793
#, no-c-format
msgid "&no-i18n-tag;Album"
msgstr "&no-i18n-tag;Álbum"

#. Tag: entry
#: index.docbook:7794
#, no-c-format
msgid ""
"Name of the album if the source is an album that consist of more medias."
msgstr "Nombre del álbum si la fuente es un álbum que consiste de más medios."

#. Tag: entry
#: index.docbook:7800
#, no-c-format
msgid "&no-i18n-tag;Annotation"
msgstr "&no-i18n-tag;Anotación"

#. Tag: entry
#: index.docbook:7801 index.docbook:7871
#, no-c-format
msgid ""
"Provides general comments about the file or the subject of the file. If the "
"comment is several sentences long, end each sentence with a period. Do not "
"include newline characters!"
msgstr ""
"Proporciona comentarios generales sobre el archivo o el sujeto del archivo. "
"Si el comentario contiene una longitud de varias oraciones, acabe cada "
"oración con un punto. No incluya caracteres de salto de línea."

#. Tag: entry
#: index.docbook:7808
#, no-c-format
msgid "&no-i18n-tag;Archival location"
msgstr "&no-i18n-tag;Localización del archivo"

#. Tag: entry
#: index.docbook:7809
#, no-c-format
msgid "Indicates where the subject of the file is archived."
msgstr "Indica donde es archivado el sujeto del archivo."

#. Tag: entry
#: index.docbook:7814
#, no-c-format
msgid "&no-i18n-tag;Author"
msgstr "&no-i18n-tag;Autor"

#. Tag: entry
#: index.docbook:7815
#, no-c-format
msgid ""
"Identifies the name of the author of the original subject of the file. "
"Example: <quote>van Beethoven, Ludwig</quote>"
msgstr ""
"Identifica el nombre del autor del tema original del archivo. Ejemplo: "
"<quote>van Beethoven, Ludwig</quote>"

#. Tag: entry
#: index.docbook:7821
#, no-c-format
msgid "&no-i18n-tag;Lower Bitrate"
msgstr "&no-i18n-tag;Frecuencia de bits inferior"

#. Tag: entry
#: index.docbook:7822
#, no-c-format
msgid "Specifies the lower limit in a VBR bitstream."
msgstr "Especifica el límite mínimo en un flujo VBR."

#. Tag: entry
#: index.docbook:7827
#, no-c-format
msgid "&no-i18n-tag;Bitrate Mode"
msgstr "&no-i18n-tag;Modo de frecuencia de bits"

#. Tag: entry
#: index.docbook:7828
#, no-c-format
msgid "Bitrate Mode (ABR, VBR, CBR, &etc;)"
msgstr "Tasa de bits (ABR, VBR, CBR, &etc;)"

#. Tag: entry
#: index.docbook:7833
#, no-c-format
msgid "&no-i18n-tag;Bitrate"
msgstr "&no-i18n-tag;Frecuencia de bits"

#. Tag: entry
#: index.docbook:7834
#, no-c-format
msgid "Nominal bitrate of the audio stream in bits per second"
msgstr "Tasa de bits nominal del flujo de audio en bits por segundo"

#. Tag: entry
#: index.docbook:7839
#, no-c-format
msgid "&no-i18n-tag;Upper Bitrate"
msgstr "&no-i18n-tag;Frecuencia de bits superior"

#. Tag: entry
#: index.docbook:7840
#, no-c-format
msgid "Specifies the upper limit in a VBR bitstream."
msgstr "Especifica el límite superior en un flujo VBR"

#. Tag: entry
#: index.docbook:7845
#, no-c-format
msgid "&no-i18n-tag;Bits per Sample"
msgstr "&no-i18n-tag;Bits por muestra"

#. Tag: entry
#: index.docbook:7846
#, no-c-format
msgid "Specifies the number of bits per sample."
msgstr "Especifica el numero de bits por muestra"

#. Tag: entry
#: index.docbook:7851
#, no-c-format
msgid "&no-i18n-tag;CD"
msgstr "&no-i18n-tag;CD"

#. Tag: entry
#: index.docbook:7852
#, no-c-format
msgid "Number of the CD, if the source is an album of more CDROMs"
msgstr "Número de CD, si la fuente es un álbum de más de un CD."

#. Tag: entry
#: index.docbook:7857
#, no-c-format
msgid "&no-i18n-tag;CDS"
msgstr "&no-i18n-tag;CDS"

#. Tag: entry
#: index.docbook:7858
#, no-c-format
msgid "Number of CDs, if the source is an album of more CDROMs"
msgstr "Número de CDs, si la fuente es un álbum de más de un CD."

#. Tag: entry
#: index.docbook:7863
#, no-c-format
msgid "&no-i18n-tag;Commissioned"
msgstr "&no-i18n-tag;Encargado"

#. Tag: entry
#: index.docbook:7864
#, no-c-format
msgid ""
"Lists the name of the person or organization that commissioned the subject "
"of the file."
msgstr ""
"Lista el nombre de la persona u organización que encargó el tema del archivo."

#. Tag: entry
#: index.docbook:7870
#, no-c-format
msgid "&no-i18n-tag;Comments"
msgstr "&no-i18n-tag;Comentarios"

#. Tag: entry
#: index.docbook:7878
#, no-c-format
msgid "&no-i18n-tag;Compression"
msgstr "&no-i18n-tag;Compresión"

#. Tag: entry
#: index.docbook:7879
#, no-c-format
msgid "Sets a mode for compressing the audio data to reduce disk space."
msgstr ""
"Fija un modo para comprimir el audio y reducir el espacio utilizando en "
"disco."

#. Tag: entry
#: index.docbook:7885
#, no-c-format
msgid "&no-i18n-tag;Contact"
msgstr "&no-i18n-tag;Contacto"

#. Tag: entry
#: index.docbook:7886
#, no-c-format
msgid ""
"Contact information for the creators or distributors of the track. This "
"could be a URL, an email address, the physical address of the producing "
"label."
msgstr ""
"Información de contacto para los creadores o distribuidores de la pista. "
"Esta podría ser una dirección URL, una dirección de correo o la dirección "
"física del sello discográfico."

#. Tag: entry
#: index.docbook:7893
#, no-c-format
msgid "&no-i18n-tag;Copyright"
msgstr "&no-i18n-tag;Copyright"

#. Tag: entry
#: index.docbook:7894
#, no-c-format
msgid ""
"Records the copyright information for the file. If there are multiple "
"copyrights, separate them by a semicolon followed by a space. Example: "
"<quote>Copyright Linux community 2002</quote>"
msgstr ""
"Registra la información de copyright del archivo. Si hay múltiples "
"copyrights, sepárelos mediante punto y coma seguidos de un espacio. Ejemplo: "
"<quote>Copyright Linux community 2002</quote>"

#. Tag: entry
#: index.docbook:7901
#, no-c-format
msgid "&no-i18n-tag;Copyrighted"
msgstr "&no-i18n-tag;Con derechos de autor"

#. Tag: entry
#: index.docbook:7902
#, no-c-format
msgid "Indicates whether the file is protected by copyright or not."
msgstr "Indica si el archivo está sujeto a derechos de autor o no."

#. Tag: entry
#: index.docbook:7907
#, no-c-format
msgid "&no-i18n-tag;Date"
msgstr "&no-i18n-tag;Fecha"

#. Tag: entry
#: index.docbook:7908
#, no-c-format
msgid ""
"Specifies the date the subject of the file was created. Example: "
"<quote>2001-12-24</quote>"
msgstr ""
"Especifica la fecha de creación del archivo. Ejemplo: <quote>2001-12-24</"
"quote>"

#. Tag: entry
#: index.docbook:7914
#, no-c-format
msgid "&no-i18n-tag;Engineer"
msgstr "&no-i18n-tag;Ingeniero"

#. Tag: entry
#: index.docbook:7915
#, no-c-format
msgid ""
"Shows the name of the engineer who worked on the file. If there are multiple "
"engineers, separate the names by a semicolon and a blank."
msgstr ""
"Muestra el nombre del ingeniero que trabajó en el archivo. Si existen varios "
"ingenieros separe los nombres mediante punto y coma y un espacio en blanco."

#. Tag: entry
#: index.docbook:7922
#, no-c-format
msgid "&no-i18n-tag;Estimated Length"
msgstr "&no-i18n-tag;Longitud estimada"

#. Tag: entry
#: index.docbook:7923
#, no-c-format
msgid "Estimated length of the file in samples"
msgstr "Duración estimada del archivo en muestras"

#. Tag: entry
#: index.docbook:7928
#, no-c-format
msgid "&no-i18n-tag;Filename"
msgstr "&no-i18n-tag;Nombre del archivo"

#. Tag: entry
#: index.docbook:7929
#, no-c-format
msgid "Name of the opened file"
msgstr "Nombre del archivo abierto"

#. Tag: entry
#: index.docbook:7934
#, no-c-format
msgid "&no-i18n-tag;File Size"
msgstr "&no-i18n-tag;Tamaño del archivo"

#. Tag: entry
#: index.docbook:7935
#, no-c-format
msgid "Size of the file in bytes"
msgstr "Tamaño del archivo en bytes"

#. Tag: entry
#: index.docbook:7940
#, no-c-format
msgid "&no-i18n-tag;Genre"
msgstr "&no-i18n-tag;Género"

#. Tag: entry
#: index.docbook:7941
#, no-c-format
msgid ""
"Describes the genre or style of the original work. Examples: <quote>classic</"
"quote>, <quote>pop</quote>"
msgstr ""
"Describe el género o estilo del trabajo original. Ejemplos: <quote>clásica</"
"quote>, <quote>pop</quote>"

#. Tag: entry
#: index.docbook:7947
#, no-c-format
msgid "&no-i18n-tag;ISRC"
msgstr "&no-i18n-tag;ISRC"

#. Tag: entry
#: index.docbook:7948
#, no-c-format
msgid ""
"ISRC number for the track; see the ISRC intro page for more information on "
"ISRC numbers. &url_isrc;"
msgstr ""
"Número ISRC para la pista; vea la página introductoria de ISRC para más "
"información sobre los números ISRC: &url_isrc;"

#. Tag: entry
#: index.docbook:7955
#, no-c-format
msgid "&no-i18n-tag;Keywords"
msgstr "&no-i18n-tag;Palabras clave"

#. Tag: entry
#: index.docbook:7956
#, no-c-format
msgid ""
"Provides a list of keywords that refer to the file or subject of the file."
msgstr ""
"Proporciona una lista de palabras clave que hacen referencia al archivo o al "
"tema del archivo."

#. Tag: entry
#: index.docbook:7962
#, no-c-format
msgid "&no-i18n-tag;Labels"
msgstr "&no-i18n-tag;Etiquetas"

#. Tag: entry
#: index.docbook:7963
#, no-c-format
msgid "The list of labels/markers."
msgstr "La lista de etiquetas/marcadores."

#. Tag: entry
#: index.docbook:7968
#, no-c-format
msgid "&no-i18n-tag;Length"
msgstr "&no-i18n-tag;Longitud"

#. Tag: entry
#: index.docbook:7969
#, no-c-format
msgid "Length of the file in samples."
msgstr "Duración del archivo en muestras"

#. Tag: entry
#: index.docbook:7974
#, no-c-format
msgid "&no-i18n-tag;License"
msgstr "&no-i18n-tag;Licencia"

#. Tag: entry
#: index.docbook:7975
#, no-c-format
msgid ""
"License information, &eg;, <quote>All Rights Reserved</quote>, <quote>Any "
"Use Permitted</quote>, an URL to a license or the Attribution-ShareAlike 4.0 "
"International (<quote>distributed under the terms of the Attribution-"
"ShareAlike 4.0 International License. See &url_cc_by_sa_4; for details</"
"quote>), &etc;"
msgstr ""
"Información de licencia, por ejemplo, <quote>Todos los derechos reservados</"
"quote>, <quote>Cualquier uso permitido</quote>, una dirección URL a la "
"licencia o Attribution-ShareAlike 4.0 International (<quote>distribuida bajo "
"los términos de la licencia Attribution-ShareAlike 4.0 International. Ver "
"&url_cc_by_sa_4; para más detalles</quote>), &etc;."

#. Tag: entry
#: index.docbook:7985
#, no-c-format
msgid "&no-i18n-tag;Medium"
msgstr "&no-i18n-tag;Medio"

#. Tag: entry
#: index.docbook:7986
#, no-c-format
msgid ""
"Describes the original subject of the file, where it was first recorded. "
"Example: <quote>orchestra</quote>"
msgstr ""
"Describe el tema original del archivo, esto es, dónde fue grabado "
"inicialmente. Ejemplo: <quote>orquesta</quote>"

#. Tag: entry
#: index.docbook:7992
#, no-c-format
msgid "&no-i18n-tag;Mime Type"
msgstr "&no-i18n-tag;Tipo MIME"

#. Tag: entry
#: index.docbook:7993
#, no-c-format
msgid "Mime type of the file format"
msgstr "Tipo MIME del formato del archivo"

#. Tag: entry
#: index.docbook:7998
#, no-c-format
msgid "&no-i18n-tag;Emphasis"
msgstr "&no-i18n-tag;Énfasis"

#. Tag: entry
#: index.docbook:7999
#, no-c-format
msgid "Audio emphasis mode"
msgstr "Tipo de énfasis del audio"

#. Tag: entry
#: index.docbook:8004
#, no-c-format
msgid "&no-i18n-tag;Layer"
msgstr "&no-i18n-tag;Capa"

#. Tag: entry
#: index.docbook:8005
#, no-c-format
msgid "MPEG Layer, I, II or III"
msgstr "MPEG capa I, II o III"

#. Tag: entry
#: index.docbook:8010
#, no-c-format
msgid "&no-i18n-tag;Mode Extension"
msgstr "&no-i18n-tag;Extensión de modo"

#. Tag: entry
#: index.docbook:8011
#, no-c-format
msgid "MPEG Mode Extension (only if Joint Stereo)"
msgstr "MPEG Mode de extensión (solo con estéreo conjunto)"

#. Tag: entry
#: index.docbook:8016 index.docbook:8144
#, no-c-format
msgid "&no-i18n-tag;Version"
msgstr "&no-i18n-tag;Versión"

#. Tag: entry
#: index.docbook:8017
#, no-c-format
msgid "MPEG Version, 1, 2 or 2.5"
msgstr "MPEG Versión, 1, 2, o 2.5"

#. Tag: entry
#: index.docbook:8022
#, no-c-format
msgid "&no-i18n-tag;Name"
msgstr "&no-i18n-tag;Nombre"

#. Tag: entry
#: index.docbook:8023
#, no-c-format
msgid ""
"Stores the title of the subject of the file. Example: <quote>Symphony No.6, "
"Op.68 &quot;Pastoral&quot;</quote>"
msgstr ""
"Almacena el título del tema del archivo. Ejemplo: <quote>Sinfonía Núm.6, "
"Op.68 &quot;Pastoral&quot;</quote>"

#. Tag: entry
#: index.docbook:8029
#, no-c-format
msgid "&no-i18n-tag;Opus Frame Length"
msgstr "&no-i18n-tag;Duración de la trama Opus"

#. Tag: entry
#: index.docbook:8030
#, no-c-format
msgid ""
"Opus Frame Length in ms (supported values are 2.5, 5, 10, 20, 40, or 60 ms)"
msgstr ""
"Duración de la trama Opus (son valores soportados 2.5, 5, 10, 20, 40 o 60 ms)"

#. Tag: entry
#: index.docbook:8036
#, no-c-format
msgid "&no-i18n-tag;Organization"
msgstr "&no-i18n-tag;Organización"

#. Tag: entry
#: index.docbook:8037
#, no-c-format
msgid ""
"Name of the organization producing the track (i.e. the <quote>record label</"
"quote>)"
msgstr ""
"Nombre de la organización productora de la pista (esto es el <quote>sello "
"discográfico</quote>)"

#. Tag: entry
#: index.docbook:8043
#, no-c-format
msgid "&no-i18n-tag;Original"
msgstr "&no-i18n-tag;Original"

#. Tag: entry
#: index.docbook:8044
#, no-c-format
msgid "Indicates whether the file is an original or a copy"
msgstr "Indica si el archivo es un original o una copia"

#. Tag: entry
#: index.docbook:8049
#, no-c-format
msgid "&no-i18n-tag;Performer"
msgstr "&no-i18n-tag;Intérprete"

#. Tag: entry
#: index.docbook:8050
#, no-c-format
msgid ""
"The artist(s) who performed the work. In classical music this would be the "
"conductor, orchestra, soloists. In an audio book it would be the actor who "
"did the reading."
msgstr ""
"El artista que ha interpretado la pista. En música clásica esto sería el "
"director de orquesta, la orquesta o los solistas. En un audio-libro sería el "
"actor que realizo la lectura."

#. Tag: entry
#: index.docbook:8057
#, no-c-format
msgid "&no-i18n-tag;Private"
msgstr "&no-i18n-tag;Privado"

#. Tag: entry
#: index.docbook:8058
#, no-c-format
msgid "Indicates whether the subject is private"
msgstr "Indica si el tema es privado"

#. Tag: entry
#: index.docbook:8063
#, no-c-format
msgid "&no-i18n-tag;Product"
msgstr "&no-i18n-tag;Producto"

#. Tag: entry
#: index.docbook:8064
#, no-c-format
msgid ""
"Specifies the name or the title the file was originally intended for. "
"Example: <quote>Linux audio collection</quote>"
msgstr ""
"Especifica el nombre o el título previsto inicialmente para el archivo. "
"Ejemplo: <quote>Linux audio collection</quote>"

#. Tag: entry
#: index.docbook:8070
#, no-c-format
msgid "&no-i18n-tag;Sample Format"
msgstr "&no-i18n-tag;Formato de muestreo"

#. Tag: entry
#: index.docbook:8071
#, no-c-format
msgid ""
"Format used for storing the digitized audio samples. Example: <quote>32-bit "
"IEEE floating-point</quote>"
msgstr ""
"Formato usado para almacenar las muestra digitalizadas de audio. Ejemplo: "
"<quote>32-bit IEEE coma flotante</quote>"

#. Tag: entry
#: index.docbook:8077
#, no-c-format
msgid "&no-i18n-tag;Sample Rate"
msgstr "&no-i18n-tag;Tasa de muestreo"

#. Tag: entry
#: index.docbook:8078
#, no-c-format
msgid "Number of samples per second"
msgstr "Número de muestras por segundo"

#. Tag: entry
#: index.docbook:8083
#, no-c-format
msgid "&no-i18n-tag;Software"
msgstr "&no-i18n-tag;Software"

#. Tag: entry
#: index.docbook:8084
#, no-c-format
msgid ""
"Identifies the name of the software package used to create the file. "
"Example: <quote>Kwave v0.6.4-1</quote>"
msgstr ""
"Identifica el nombre del software usado para crear el archivo. Ejemplo: "
"<quote>Kwave v0.6.4-1</quote>"

#. Tag: entry
#: index.docbook:8090
#, no-c-format
msgid "&no-i18n-tag;Source"
msgstr "&no-i18n-tag;Fuente"

#. Tag: entry
#: index.docbook:8091
#, no-c-format
msgid ""
"Identifies the name of the person or organization who supplied the original "
"subject of the file. Example: <quote>Chaotic Sound Research</quote>"
msgstr ""
"Identifica el nombre de la persona u organización que proporcionó el tema "
"original del archivo. Ejemplo: <quote>Chaotic Sound Research</quote>"

#. Tag: entry
#: index.docbook:8098
#, no-c-format
msgid "&no-i18n-tag;Source form"
msgstr "&no-i18n-tag;Forma de la fuente"

#. Tag: entry
#: index.docbook:8099
#, no-c-format
msgid ""
"Identifies the original form of the material that was digitized. Examples: "
"<quote>Record/Vinyl/90RPM</quote>, <quote>Audio DAT</quote>, <quote>tape/"
"CrO2/60min</quote>"
msgstr ""
"Identifica el tipo original del material que fue digitalizado. Ejemplos: "
"<quote>Disco/Vinilo/90RPM</quote>, <quote>Audio DAT</quote>, <quote>Cinta/"
"CrO2/60min</quote>"

#. Tag: entry
#: index.docbook:8106
#, no-c-format
msgid "&no-i18n-tag;Subject"
msgstr "&no-i18n-tag;Tema"

#. Tag: entry
#: index.docbook:8107
#, no-c-format
msgid ""
"Describes the subject of the file. Example: <quote>Bird voices at early "
"morning</quote>"
msgstr ""
"Describe el tema del archivo. Ejemplo: <quote>Sonidos de pájaros en la "
"madrugada</quote>"

#. Tag: entry
#: index.docbook:8113
#, no-c-format
msgid "&no-i18n-tag;Technician"
msgstr "&no-i18n-tag;Técnico"

#. Tag: entry
#: index.docbook:8114
#, no-c-format
msgid ""
"Identifies the technician who digitized the subject file. Example: "
"<quote>Torvalds, Linus</quote>"
msgstr ""
"Identifica el técnico que digitalizó el archivo. Ejemplo: <quote>Torvalds, "
"Linus</quote>"

#. Tag: entry
#: index.docbook:8120
#, no-c-format
msgid "&no-i18n-tag;Track"
msgstr "&no-i18n-tag;Pista"

#. Tag: entry
#: index.docbook:8121
#, no-c-format
msgid "Track of the CD if the source was a CDROM."
msgstr "Pista del CD si la fuente era un CDROM."

#. Tag: entry
#: index.docbook:8126
#, no-c-format
msgid "&no-i18n-tag;Tracks"
msgstr "&no-i18n-tag;Pistas"

#. Tag: entry
#: index.docbook:8127
#, no-c-format
msgid "Number of tracks of the CD if the source was a CDROM."
msgstr "Número de pistas del CD si la fuente era un CDROM."

#. Tag: entry
#: index.docbook:8132
#, no-c-format
msgid "&no-i18n-tag;Channels"
msgstr "&no-i18n-tag;Canales"

#. Tag: entry
#: index.docbook:8133
#, no-c-format
msgid "Specifies the number of channels of the signal."
msgstr "Especifica el número de canales de la señal."

#. Tag: entry
#: index.docbook:8138
#, no-c-format
msgid "&no-i18n-tag;Base Quality"
msgstr "&no-i18n-tag;Calidad base"

#. Tag: entry
#: index.docbook:8139
#, no-c-format
msgid "Base quality of the compression in VBR mode"
msgstr "Calidad base de la compresión en modo VBR"

#. Tag: entry
#: index.docbook:8145
#, no-c-format
msgid ""
"May be used to differentiate multiple versions of the same track title in a "
"single collection. (&eg; remix info)"
msgstr ""
"Podría ser utilizada para diferenciar múltiples versiones de la misma pista "
"en una única colección. (por ejemplo, información de un remix)"
