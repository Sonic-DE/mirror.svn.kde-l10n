#. Tag: title
#: index.docbook:2589
#, no-c-format
msgid "&no-i18n-cmd_delete;"
msgstr "&no-i18n-cmd_delete;"

#. Tag: title
#: index.docbook:2591
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_delete;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_delete;</command>()"

#. Tag: para
#: index.docbook:2592
#, no-c-format
msgid ""
"Deletes the currently selected range of samples. If the selection is empty, "
"this command does nothing. Affects all tracks."
msgstr ""
"Borra el intervalo de muestras actualmente seleccionado. Si la selección "
"está vacía, esta orden no tiene efecto. Afecta a todas las pistas."

#. Tag: title
#: index.docbook:2601
#, no-c-format
msgid "&no-i18n-cmd_delete_track;"
msgstr "&no-i18n-cmd_delete_track;"

#. Tag: title
#: index.docbook:2603
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_delete_track;</"
"command>(<replaceable>index</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_delete_track;</"
"command>(<replaceable>índice</replaceable>)"

#. Tag: para
#: index.docbook:2604
#, no-c-format
msgid ""
"Deletes a track, identified by its index (starting from zero). If no track "
"with the given index exists, this command exits with an error."
msgstr ""
"Borra una pista, identificada por su índice (empezando en cero). Si no "
"existe ninguna pista con el índice dado, esta orden finaliza con error."

#. Tag: entry
#: index.docbook:2610 index.docbook:2733 index.docbook:2772 index.docbook:2800
#: index.docbook:3563 index.docbook:3577 index.docbook:3592
#, no-c-format
msgid "<parameter>index</parameter>:"
msgstr "<parameter>índice</parameter>:"

#. Tag: entry
#: index.docbook:2610
#, no-c-format
msgid "index of the track to delete, starting with 0"
msgstr "índice de la pista a borrar, empezando en 0"

#. Tag: title
#: index.docbook:2615
#, no-c-format
msgid "&no-i18n-cmd_dump_metadata;"
msgstr "&no-i18n-cmd_dump_metadata;"

#. Tag: title
#: index.docbook:2617
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_dump_metadata;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_dump_metadata;</"
"command>()"

#. Tag: para
#: index.docbook:2618
#, no-c-format
msgid ""
"Prints a list of all meta data entries to the console, for diagnostic "
"purposes. (Only available when &kwave; has been compiled with the option "
"<literal>WITH_DEBUG</literal> switched on)."
msgstr ""
"Imprime una lista de todas las entradas de meta-datos en la consola, para "
"diagnosticar. (Solo disponible cuando &kwave; ha sido compilado con la "
"opción <literal>WITH_DEBUG</literal> activada)."

#. Tag: title
#: index.docbook:2627
#, no-c-format
msgid "&no-i18n-tag;e"
msgstr "&no-i18n-tag;e"

#. Tag: title
#: index.docbook:2630
#, no-c-format
msgid "&no-i18n-cmd_expandtolabel;"
msgstr "&no-i18n-cmd_expandtolabel;"

#. Tag: title
#: index.docbook:2632
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_expandtolabel;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_expandtolabel;</"
"command>()"

#. Tag: para
#: index.docbook:2633
#, no-c-format
msgid ""
"Expands the current selection to the labels left and right from the current "
"selection borders. If the border of selection already is on a label, it "
"stays unchanged. If there is no label left or right of the current "
"selection, it will be expanded to the start or end of the file."
msgstr ""
"Expande la selección actual de etiquetas a la izquierda y a la derecha desde "
"los bordes de selección actual. Si el borde de la selección ya está en la "
"etiqueta, permanece sin modificar. Si no hay ninguna etiqueta a la izquierda "
"o la derecha de la selección actual, será expandida al inicio o final del "
"archivo."

#. Tag: title
#: index.docbook:2644
#, no-c-format
msgid "&no-i18n-tag;f"
msgstr "&no-i18n-tag;f"

#. Tag: title
#: index.docbook:2647
#, no-c-format
msgid "&no-i18n-cmd_fileinfo;"
msgstr "&no-i18n-cmd_fileinfo;"

#. Tag: title
#: index.docbook:2649
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_fileinfo;</"
"command>(<replaceable>index</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_fileinfo;</"
"command>(<replaceable>índice</replaceable>)"

#. Tag: para
#: index.docbook:2650
#, no-c-format
msgid "Set a file info entry to a new value."
msgstr "Establece un nuevo valor en la entrada de información del archivo."

#. Tag: entry
#: index.docbook:2655
#, no-c-format
msgid "<parameter>keyword</parameter>:"
msgstr "<parameter>palabra clave</parameter>:"

#. Tag: entry
#: index.docbook:2655
#, no-c-format
msgid "keyword of the entry"
msgstr "palabra clave de la entrada"

#. Tag: entry
#: index.docbook:2656
#, no-c-format
msgid "<parameter>value</parameter>:"
msgstr "<parameter>valor</parameter>:"

#. Tag: entry
#: index.docbook:2656
#, no-c-format
msgid "value of the entry"
msgstr "valor de la entrada"

#. Tag: title
#: index.docbook:2661
#, no-c-format
msgid "&no-i18n-cmd_forward;"
msgstr "&no-i18n-cmd_forward;"

#. Tag: title
#: index.docbook:2663
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_forward;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_forward;</command>()"

#. Tag: para
#: index.docbook:2664
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Forward</guibutton> toolbar button. If the "
"playback is currently running, it skips forward by 1/10 of the visible "
"range. If the playback is not running, this does the same as the command "
"<command>&no-i18n-cmd_view_scroll_right;</command>()."
msgstr ""
"Corresponde al botón <guibutton>Avanzar</guibutton> de la barra de "
"herramientas. Si la reproducción está en marcha, salta un 1/10 de la gama "
"visible. Si la reproducción está parada, esto tiene el mismo efecto que la "
"orden <command>&no-i18n-cmd_view_scroll_right;</command>()."

#. Tag: para
#: index.docbook:2673
#, no-c-format
msgid ""
"<link linkend=\"cmd_sect_view_scroll_right\"><command>&no-i18n-tag;&no-i18n-"
"cmd_view_scroll_right;</command>()</link>, <link linkend=\"cmd_sect_rewind"
"\"><command>&no-i18n-tag;&no-i18n-cmd_rewind;</command>()</link>"
msgstr ""
"<link linkend=\"cmd_sect_view_scroll_right\"><command>&no-i18n-tag;&no-i18n-"
"cmd_view_scroll_right;</command>()</link>, <link linkend=\"cmd_sect_rewind"
"\"><command>&no-i18n-tag;&no-i18n-cmd_rewind;</command>()</link>"

#. Tag: title
#: index.docbook:2681
#, no-c-format
msgid "&no-i18n-tag;g"
msgstr "&no-i18n-tag;g"

#. Tag: title
#: index.docbook:2684
#, no-c-format
msgid "&no-i18n-cmd_goto;"
msgstr "&no-i18n-cmd_goto;"

#. Tag: title
#: index.docbook:2686
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_goto;</command>(<replaceable>pos</"
"replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_goto;</"
"command>(<replaceable>posición</replaceable>)"

#. Tag: para
#: index.docbook:2687
#, no-c-format
msgid ""
"Sets the cursor to the given position and makes it visible in current view. "
"After this the selection has zero length."
msgstr ""
"Establece el cursor en la posición dada y lo hace visible en la vista "
"actual. Después de esto, la selección tiene longitud cero."

#. Tag: entry
#: index.docbook:2693 index.docbook:2711 index.docbook:2756
#, no-c-format
msgid "<parameter>pos</parameter>:"
msgstr "<parameter>posición</parameter>:"

#. Tag: entry
#: index.docbook:2693
#, no-c-format
msgid "position in samples where to go to"
msgstr "posición en muestras a la que desplazarse"

#. Tag: title
#: index.docbook:2698
#, no-c-format
msgid "&no-i18n-tag;i"
msgstr "&no-i18n-tag;i"

#. Tag: title
#: index.docbook:2701
#, no-c-format
msgid "&no-i18n-cmd_insert_at;"
msgstr "&no-i18n-cmd_insert_at;"

#. Tag: title
#: index.docbook:2703
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_insert_at;</"
"command>(<replaceable>pos</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_insert_at;</"
"command>(<replaceable>posición</replaceable>)"

#. Tag: para
#: index.docbook:2704
#, no-c-format
msgid ""
"Inserts the content of the clipboard at the given position, like the command "
"<command>&no-i18n-cmd_paste;</command>(). If the clipboard is currently "
"empty, this function does nothing."
msgstr ""
"Inserta el contenido del portapapeles en la posición seleccionada, como la "
"orden <command>&no-i18n-cmd_paste;</command>(). Si el portapapeles está "
"vacío, esta función no hace nada."

#. Tag: entry
#: index.docbook:2711
#, no-c-format
msgid "position in samples where to insert"
msgstr "posición en muestras en la que insertar"

#. Tag: title
#: index.docbook:2719
#, no-c-format
msgid "&no-i18n-cmd_insert_track;"
msgstr "&no-i18n-cmd_insert_track;"

#. Tag: title
#: index.docbook:2721
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_insert_track;</"
"command>(<replaceable>index</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_insert_track;</"
"command>(<replaceable>índice</replaceable>)"

#. Tag: para
#: index.docbook:2722
#, no-c-format
msgid ""
"Inserts a new track at the given index, using the current length and sample "
"rate settings of the signal. If the index is higher than or equal to the "
"current number of tracks, it will be appended as the last track, same as by "
"the command <command>&no-i18n-cmd_add_track;</command>(). The index of all "
"existing tracks at and after the given index will be incremented by one."
msgstr ""
"Inserta una nueva pista en el índice dado, usando la longitud actual y la "
"configuración de frecuencia de muestreo de la señal. Si el índice es mayor o "
"igual que el número de pistas actual, será añadida como última pista, lo "
"mismo que ocurriría con la orden <command>&no-i18n-cmd_add_track;</"
"command>(). El índice de todas las pistas existentes en la posición del "
"índice dado y posteriores se incrementará en uno."

#. Tag: entry
#: index.docbook:2733
#, no-c-format
msgid "index of the track to insert, starting with 0"
msgstr "índice de la pista a insertar, empezando en 0"

#. Tag: link
#: index.docbook:2737
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_add_track;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_add_track;</command>()"

#. Tag: title
#: index.docbook:2743
#, no-c-format
msgid "&no-i18n-tag;l"
msgstr "&no-i18n-tag;l"

#. Tag: title
#: index.docbook:2746
#, no-c-format
msgid "&no-i18n-cmd_label_add;"
msgstr "&no-i18n-cmd_label_add;"

#. Tag: title
#: index.docbook:2748
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_label_add;</"
"command>(<replaceable>pos</replaceable>[,<replaceable>text</replaceable>])"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_label_add;</"
"command>(<replaceable>posición</replaceable>[,<replaceable>texto</"
"replaceable>])"

#. Tag: para
#: index.docbook:2749
#, no-c-format
msgid ""
"Add a new label at a given position. If the given position already contains "
"a label, then this command does nothing. The label can be given an optional "
"description."
msgstr ""
"Añadir una nueva etiqueta en una posición dada.Si esta posición ya contiene "
"una etiqueta, entonces esta orden no tiene efecto. La etiqueta puede "
"contener una descripción opcional."

#. Tag: entry
#: index.docbook:2756
#, no-c-format
msgid "position in samples where to insert the label"
msgstr "posición dada en muestras en la que insertar la etiqueta"

#. Tag: entry
#: index.docbook:2757 index.docbook:3055
#, no-c-format
msgid "<parameter>text</parameter>:"
msgstr "<parameter>texto</parameter>:"

#. Tag: entry
#: index.docbook:2757
#, no-c-format
msgid "some descriptive text (optional)"
msgstr "alguna descripción textual (opcional)"

#. Tag: title
#: index.docbook:2762
#, no-c-format
msgid "&no-i18n-cmd_label_delete;"
msgstr "&no-i18n-cmd_label_delete;"

#. Tag: title
#: index.docbook:2764
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_label_delete;</"
"command>(<replaceable>index</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_label_delete;</"
"command>(<replaceable>índice</replaceable>)"

#. Tag: para
#: index.docbook:2765
#, no-c-format
msgid ""
"Deletes a label, identified by its index (starting from zero), or all labels "
"when using the special value -1 as index. If no label with the given index "
"exists, this command does nothing."
msgstr ""
"Borra una etiqueta, identificada por su índice (empezando por 0), o todas "
"las etiquetas cuando se usa -1 como índice. Si no existe ninguna etiqueta "
"con el índice indicado, esta orden no tiene efecto."

#. Tag: entry
#: index.docbook:2772
#, no-c-format
msgid ""
"index of the label to delete, starting with 0 or -1 to delete all labels"
msgstr ""
"índice de la etiqueta a borrar, empezando en 0 o -1 para borrar todas las "
"etiquetas"

#. Tag: title
#: index.docbook:2778
#, no-c-format
msgid "&no-i18n-cmd_label_edit;"
msgstr "&no-i18n-cmd_label_edit;"

#. Tag: screeninfo
#: index.docbook:2780 index.docbook:4379 index.docbook:4419 index.docbook:4564
#: index.docbook:4923 index.docbook:5231 index.docbook:5424 index.docbook:5460
#: index.docbook:5550 index.docbook:5643 index.docbook:5706 index.docbook:5750
#: index.docbook:5868 index.docbook:5943 index.docbook:6061 index.docbook:6154
#: index.docbook:6460 index.docbook:6685 index.docbook:6799 index.docbook:6810
#: index.docbook:6948 index.docbook:7002
#, no-c-format
msgid "Screenshot"
msgstr "Captura de pantalla"

#. Tag: phrase
#: index.docbook:2786
#, no-c-format
msgid "Screenshot of the label editing dialog"
msgstr "Captura de pantalla del diálogo de edición de etiquetas"

#. Tag: title
#: index.docbook:2791
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_label_edit;</"
"command>(<replaceable>index</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_label_edit;</"
"command>(<replaceable>índice</replaceable>)"

#. Tag: para
#: index.docbook:2792
#, no-c-format
msgid ""
"Opens a dialog window in which the user can edit the position and the "
"description of a label, which is identified by its index (starting from "
"zero). If no label with the given index exists, this command does nothing."
msgstr ""
"Abre un diálogo en el que el usuario puede editar la posición y la "
"descripción de la etiqueta, identificada por su índice (empezando por cero). "
"Si no existe ninguna etiqueta con el índice dado, esta orden no hace nada."

#. Tag: entry
#: index.docbook:2800
#, no-c-format
msgid "index of the label to edit, starting with 0"
msgstr "índice de la etiqueta a editar, empezando en 0"

#. Tag: title
#: index.docbook:2805
#, no-c-format
msgid "&no-i18n-cmd_loadbatch;"
msgstr "&no-i18n-cmd_loadbatch;"

#. Tag: title
#: index.docbook:2807
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_loadbatch;</"
"command>(<replaceable>filename</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_loadbatch;</"
"command>(<replaceable>archivo</replaceable>)"

#. Tag: para
#: index.docbook:2808
#, no-c-format
msgid ""
"Opens a &kwave; script file and processes the commands in it. Uses the "
"context of the currently opened file or the current main window if no file "
"is loaded."
msgstr ""
"Abre un archivo de script de &kwave; y procesa las órdenes en él. Usa el "
"contexto del archivo actualmente abierto o el de la ventana principal si no "
"hay ningún cargado."

#. Tag: entry
#: index.docbook:2815 index.docbook:3138 index.docbook:3164 index.docbook:3460
#: index.docbook:3493 index.docbook:4234
#, no-c-format
msgid "<parameter>filename</parameter>:"
msgstr "<parameter>archivo</parameter>:"

#. Tag: entry
#: index.docbook:2816
#, no-c-format
msgid "name of the kwave script file including path and extension"
msgstr "Nombre del script kwave incluyendo la ruta y la extensión"

#. Tag: title
#: index.docbook:2821
#, no-c-format
msgid "&no-i18n-cmd_loop;"
msgstr "&no-i18n-cmd_loop;"

#. Tag: title
#: index.docbook:2823
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_loop;</command>()"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_loop;</command>()"

#. Tag: para
#: index.docbook:2824
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Loop</guibutton> toolbar button. Starts the "
"playback (if it is not already running) and lets it play in a loop."
msgstr ""
"Corresponde al botón <guibutton>Bucle</guibutton> de la barra de "
"herramientas. Empieza la reproducción (si no estaba en ejecución) y la "
"reproduce en bucle."

#. Tag: link
#: index.docbook:2832
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_playback_start;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_playback_start;</command>()"

#. Tag: title
#: index.docbook:2838
#, no-c-format
msgid "&no-i18n-tag;m"
msgstr "&no-i18n-tag;m"

#. Tag: title
#: index.docbook:2841
#, no-c-format
msgid "&no-i18n-cmd_menu;"
msgstr "&no-i18n-cmd_menu;"

#. Tag: title
#: index.docbook:2843
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_menu;</command> "
"(<replaceable>command</replaceable>, <replaceable>path</replaceable>, "
"[<replaceable>hotkey</replaceable>], [<replaceable>id</replaceable>])"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_menu;</command> (<replaceable>orden</"
"replaceable>, <replaceable>ruta</replaceable>, [<replaceable>combinación de "
"teclas</replaceable>], [<replaceable>identificador</replaceable>])"

#. Tag: para
#: index.docbook:2849
#, no-c-format
msgid ""
"This is a very powerful command, which is used to add a new entry to the "
"menu or to modify an existing entry. It determines which <emphasis>command</"
"emphasis> is executed when the menu entry is activated, which "
"<emphasis>icon</emphasis> is shown in the menu and which <emphasis>hotkey</"
"emphasis> is used. Each menu entry can be <emphasis>disabled</emphasis> or "
"<emphasis>hidden</emphasis>, can be assigned a unique <emphasis>id</"
"emphasis> and can also join a <emphasis>menu group</emphasis>."
msgstr ""
"Esta es una orden muy potente, que se usa para añadir una nueva entrada al "
"menú o para modificar una entrada existente. Determina que <emphasis>orden</"
"emphasis> se ejecutará cuando se activa la entrada del menú, que "
"<emphasis>icono</emphasis> se muestra en el menú y que <emphasis>atajo de "
"teclado</emphasis> se usará. Cada entra del menú puede ser "
"<emphasis>deshabilitada</emphasis> o <emphasis>escondida</emphasis>, puede "
"asignarsele un <emphasis>identificador</emphasis> único y puede unirse a un "
"<emphasis>grupo de menús</emphasis>."

#. Tag: para
#: index.docbook:2860
#, no-c-format
msgid "You normally do not need this command within a &kwave; script!"
msgstr "¡Normalmente no debería necesitar esta orden en un script &kwave;!"

#. Tag: entry
#: index.docbook:2867
#, no-c-format
msgid ""
"A text command (including parameters) or a command list that will be "
"executed when the menu entry gets activated. If a menu entry does not have a "
"corresponding command (for example if it is a sub menu and not menu entry), "
"you should use the special command <command>ignore</command>()."
msgstr ""
"Una orden de texto (incluyendo parámetros) o una lista de órdenes que será "
"ejecutada cuando la entrada del menú se activa. Si la entrada del menú no "
"tiene una orden asociada (por ejemplo si es un submenú y no a una entrada de "
"menú), debería usar la orden especial <command>ignore</command>()."

#. Tag: entry
#: index.docbook:2876
#, no-c-format
msgid "<parameter>path</parameter>:"
msgstr "<parameter>ruta</parameter>:"

#. Tag: entry
#: index.docbook:2877
#, no-c-format
msgid ""
"The path within the menu, using a <quote><token>/</token></quote> as "
"separator. The last part of the path can be a <emphasis>sub command</"
"emphasis> which modifies some property of the menu entry (see <link linkend="
"\"menu_sub_commands\">below</link>). The last portion of the path (that is "
"not a sub command) produces a menu entry, the parts before produce the main "
"menu entry or sub menus that lead to it. Main menu entries or sub menus are "
"automatically created when a menu entry is created, you do not need them "
"manually."
msgstr ""
"La ruta dentro del menú, usando <quote><token>/</token></quote> como "
"separador. La última parte de la ruta puede ser una <emphasis>sub-orden</"
"emphasis> que modifique alguna propiedad de la entrada del menú (vea <link "
"linkend=\"menu_sub_commands\">más abajo</link>). La última porción de la "
"ruta (que no es la sub-orden) produce una entrada del menú, las partes "
"anteriores producen el menú principal y los sub-menús que nos llevan a él. "
"Las entradas en el menú principal o sub-menús se crean automáticamente "
"cuando una entrada de menú es creada, no hace falta crearlas manualmente."

#. Tag: entry
#: index.docbook:2890
#, no-c-format
msgid "<parameter>hotkey</parameter>:"
msgstr "<para>Combinación de teclas</para>"

#. Tag: entry
#: index.docbook:2891
#, no-c-format
msgid ""
"A bitmask that consists of a combination of predefined <emphasis>keys</"
"emphasis> and <emphasis>modifiers</emphasis>, concatenated with a "
"<quote><token>+</token></quote>. The <emphasis>key</emphasis> can be either "
"a digit, an upper case letter, a function key (<quote>F1</quote> ... "
"<quote>F12</quote>) or any other key name understood by the Qt class "
"<quote><literal>QKeySequence</literal></quote>, including key names for "
"predefined actions (like for example <quote><literal>::Copy</literal></"
"quote>). Typical <emphasis>modifiers</emphasis> are <quote><literal>SHIFT</"
"literal></quote>, <quote><literal>ALT</literal></quote> and "
"<quote><literal>CTRL</literal></quote>."
msgstr ""
"Una máscara de bits que consiste en una combinación de predefinida "
"<emphasis>teclas</emphasis> y <emphasis>modificadores</emphasis>, "
"concatenadas mediante <quote><token>+</token></quote>. La <emphasis>tecla</"
"emphasis> puede ser un dígito, una letra en mayúsculas, una tecla de función "
"(<quote>F1</quote> … <quote>F12</quote>) o cualquier otro nombre de tecla "
"comprendido por la clase de Qt <quote><literal>QKeySequence</literal></"
"quote>, incluyendo los nombres de teclas para las acciones predefinidas "
"(como por ejemplo <quote><literal>::Copy</literal></quote>). Los "
"<emphasis>modificadores</emphasis> más usuales son <quote><literal>Mayús</"
"literal></quote>, <quote><literal>Alt</literal></quote> y "
"<quote><literal>Ctrl</literal></quote>."

#. Tag: entry
#: index.docbook:2909
#, no-c-format
msgid "<parameter>id</parameter>:"
msgstr "<para>identificador</para>"

#. Tag: entry
#: index.docbook:2910
#, no-c-format
msgid ""
"A unique id that can be internally used to identify this menu entry or "
"menu / sub menu. Only uppercase letters, digits and <quote><literal>_</"
"literal></quote> should be used and it should start with "
"<quote><literal>ID_</literal></quote>. It is in your own responsibility to "
"make sure that the same id is not used twice."
msgstr ""
"Un identificador único que puede usarse internamente para identificar esta "
"entrada de menú o menú / sub-menú. Solo se pueden usar letras en mayúsculas, "
"dígitos y <quote><literal>_</literal></quote> y deben comenzar con "
"<quote><literal>ID_</literal></quote>. Es su propia responsabilidad evitar "
"que el mismo identificador su use múltiples veces."

#. Tag: title
#: index.docbook:2920
#, no-c-format
msgid "Sub Commands"
msgstr "Sub-órdenes"

#. Tag: entry
#: index.docbook:2922
#, no-c-format
msgid "<command>&no-i18n-tag;#checkable</command>:"
msgstr "<command>&no-i18n-tag;#checkable</command>:"

#. Tag: entry
#: index.docbook:2923
#, no-c-format
msgid ""
"Makes the menu entry <emphasis>checkable</emphasis>, so that it can be "
"switched on or off."
msgstr ""
"Convierte la entrada de menú en una <emphasis>casilla</emphasis>, para que "
"pueda ser activada o desactivada."

#. Tag: entry
#: index.docbook:2928
#, no-c-format
msgid "<command>&no-i18n-tag;#disabled</command>:"
msgstr "<command>&no-i18n-tag;#disabled</command>:"

#. Tag: entry
#: index.docbook:2929
#, no-c-format
msgid "<emphasis>Disables</emphasis> the menu, sub menu or menu entry."
msgstr ""
"<emphasis>Desactiva</emphasis>  el menú, sub-menú o la entrada de menú."

#. Tag: entry
#: index.docbook:2933
#, no-c-format
msgid "<command>&no-i18n-tag;#enabled</command>:"
msgstr "<command>&no-i18n-tag;#enabled</command>:"

#. Tag: entry
#: index.docbook:2934
#, no-c-format
msgid "<emphasis>Enables</emphasis> the menu, sub menu or menu entry."
msgstr "<emphasis>Activa</emphasis> el menú, sub-menú o la entrada de menú."

#. Tag: entry
#: index.docbook:2938
#, no-c-format
msgid "<command>#exclusive</command>(<replaceable>group</replaceable>):"
msgstr "<command>#exclusive</command>(<replaceable>grupo</replaceable>):"

#. Tag: entry
#: index.docbook:2939
#, no-c-format
msgid ""
"Adds the menu entry to an <emphasis>exclusive</emphasis> "
"<emphasis><replaceable>group</replaceable></emphasis> (one of many "
"selection). The group that is given as parameter should not be used for any "
"other purpose. Only one entry within that group can be selected at a time."
msgstr ""
"Añade la entrada de menú a un <emphasis><replaceable>grupo</replaceable></"
"emphasis> <emphasis>exclusivo</emphasis>  (uno de una sección múltiple). El "
"grupo pasado como parámetro no se usará para ningún otro propósito. Solo una "
"entrada dentro del grupo puede ser seleccionada en cada momento."

#. Tag: entry
#: index.docbook:2947
#, no-c-format
msgid "<command>#group</command>(<replaceable>list</replaceable>):"
msgstr "<command>#group</command>(<replaceable>lista</replaceable>):"

#. Tag: para
#: index.docbook:2948
#, no-c-format
msgid ""
"Adds the menu, sub menu or menu entry to one or more a <emphasis>groups</"
"emphasis>, so that the application can enable/disable a bunch of menu "
"entries without need to know all their unique ids. Multiple groups can be "
"passed as a list with a <quote><literal>,</literal></quote> as separator. "
"Group names have to start with a <quote><literal>@</literal></quote>. The "
"following groups are predefined:"
msgstr ""
"Añade el menú, sub-menú o la entrada de menú  uno o más <emphasis>grupos</"
"emphasis>, de tal manera que la aplicación pueda habilitar/deshabilitar un "
"grupo de entradas de menú sin necesidad de saber todos sus identificadores "
"únicos. Se pueden pasar varios grupos como una lista separada por "
"<quote><literal>,</literal></quote>. Los nombres de grupos deben comenzar "
"con <quote><literal>@</literal></quote>. Existen los siguientes  grupos "
"predeterminados."

#. Tag: term
#: index.docbook:2959
#, no-c-format
msgid "<command>&no-i18n-tag;@CLIPBOARD</command>:"
msgstr "<command>&no-i18n-tag;@CLIPBOARD</command>:"

#. Tag: para
#: index.docbook:2961
#, no-c-format
msgid "Only enabled when the clipboard is not empty."
msgstr "Solo se habilita cuando el portapapeles no está vacío."

#. Tag: term
#: index.docbook:2967
#, no-c-format
msgid "<command>&no-i18n-tag;@LABELS</command>:"
msgstr "<command>&no-i18n-tag;@LABELS</command>:"

#. Tag: para
#: index.docbook:2969
#, no-c-format
msgid "Only enabled when the current signal contains at least one label."
msgstr ""
"Solo se habilita cuando la señal actual contiene al menos una etiqueta."

#. Tag: term
#: index.docbook:2976
#, no-c-format
msgid "<command>&no-i18n-tag;@NOT_CLOSED</command>:"
msgstr "<command>&no-i18n-tag;@NOT_CLOSED</command>:"

#. Tag: para
#: index.docbook:2978
#, no-c-format
msgid ""
"Enabled when the current signal is not closed (the signal might be empty or "
"zero length)."
msgstr ""
"Habilitado cuando la señal actual no está cerrada (la señal puede estar "
"vacía o tener longitud 0)."

#. Tag: term
#: index.docbook:2985
#, no-c-format
msgid "<command>&no-i18n-tag;@SELECTION</command>:"
msgstr "<command>&no-i18n-tag;@SELECTION</command>:"

#. Tag: para
#: index.docbook:2987
#, no-c-format
msgid ""
"Enabled when the selection is not empty (more than one sample is selected)."
msgstr ""
"Habilitado cuando la selección no está vacía (se ha seleccionado más de una "
"muestra)."

#. Tag: term
#: index.docbook:2994
#, no-c-format
msgid "<command>&no-i18n-tag;@SIGNAL</command>:"
msgstr "<command>&no-i18n-tag;@SIGNAL</command>:"

#. Tag: para
#: index.docbook:2996
#, no-c-format
msgid ""
"Enabled when there is some signal loaded and it is not empty or zero length."
msgstr ""
"Habilitado cuando hay alguna señal cargada y no es vacía o con longitud 0."

#. Tag: entry
#: index.docbook:3005
#, no-c-format
msgid "<command>&no-i18n-tag;#hidden</command>:"
msgstr "<command>&no-i18n-tag;#hidden</command>:"

#. Tag: entry
#: index.docbook:3006
#, no-c-format
msgid "<emphasis>Hides</emphasis> the menu, sub menu or menu entry."
msgstr "<emphasis>Esconde</emphasis> el menú, sub-menú o entrada del menú."

#. Tag: entry
#: index.docbook:3009
#, no-c-format
msgid "<command>#icon</command>(<replaceable>name</replaceable>):"
msgstr "<command>#icon</command>(<replaceable>nombre</replaceable>):"

#. Tag: entry
#: index.docbook:3010
#, no-c-format
msgid ""
"Assigns an <emphasis>icon</emphasis> to the menu entry. The icon "
"<emphasis><replaceable>name</replaceable></emphasis> should correspond to an "
"icon file (without path and file extension) that is installed on the system "
"or with &kwave;."
msgstr ""
"Asigna un <emphasis>icono</emphasis> a la entrada de menú. El "
"<emphasis><replaceable>nombre</replaceable></emphasis> del icono debe "
"corresponder a un archivo de icono (sin ruta ni extensión de archivo) que "
"esté instalado en el sistema o con &kwave;."

#. Tag: entry
#: index.docbook:3018
#, no-c-format
msgid ""
"<command>#listmenu</command>(<replaceable>id</replaceable>,"
"<replaceable>command</replaceable>):"
msgstr ""
"<command>#listmenu</command>(<replaceable>identificador</replaceable>,"
"<replaceable>orden</replaceable>):"

#. Tag: entry
#: index.docbook:3019
#, no-c-format
msgid ""
"Inserts a placeholder for a list of menu entries into a sub menu. The unique "
"<emphasis><replaceable>id</replaceable></emphasis> specified in this sub "
"command is used to add/remove or clear the list of menu entries. The "
"<emphasis><replaceable>command</replaceable></emphasis> parameter has to "
"contain <quote><literal>%1</literal></quote> as parameter, which will be "
"replaced with the text of the menu entry when it is activated. This sub "
"command is internally used for the list of recent files, list of tracks and "
"window list."
msgstr ""
"Inserta un marcador de posición para una lista de entradas de menú en un sub-"
"menú. El <emphasis><replaceable>identificador</replaceable></emphasis> único "
"especificado en esta sub-orden se usará para añadir/eliminar o limpiar la "
"lista de entradas de menús. El parámetro de la <emphasis><replaceable>orden</"
"replaceable></emphasis> debe contener <quote><literal>%1</literal></quote>, "
"que se reemplazará con el texto de la entrada de menú cuando se active. Esta "
"sub-orden se usa internamente para la lista de archivos recientes, la lista "
"de pistas y la lista de ventanas."

#. Tag: entry
#: index.docbook:3033
#, no-c-format
msgid "<command>&no-i18n-tag;#separator</command>:"
msgstr "<command>&no-i18n-tag;#separator</command>:"

#. Tag: entry
#: index.docbook:3034
#, no-c-format
msgid "Inserts a separator into a sub menu."
msgstr "Inserta un separador en un sub-menú."

#. Tag: title
#: index.docbook:3044
#, no-c-format
msgid "&no-i18n-cmd_msgbox;"
msgstr "&no-i18n-cmd_msgbox;"

#. Tag: title
#: index.docbook:3046
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_msgbox;</command>(<replaceable>text</"
"replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_msgbox;</command>(<replaceable>texto</"
"replaceable>)"

#. Tag: para
#: index.docbook:3047
#, no-c-format
msgid ""
"Shows a message box with some <emphasis><replaceable>text</replaceable></"
"emphasis> and the two buttons <guibutton>OK</guibutton> (returns without "
"error code) and <guibutton>Cancel</guibutton> (returns and error code). You "
"can use this command to give the user a possibility to abort a running "
"script."
msgstr ""
"Muestra un cuadro de mensaje con algún <emphasis><replaceable>texto</"
"replaceable></emphasis> y dos botones <guibutton>OK</guibutton> (retorna sin "
"código de error) y <guibutton>Cancelar</guibutton> (retorna un código de "
"error). Puede usar esta orden para dar al usuario la posibilidad de parar un "
"script en ejecución."

#. Tag: entry
#: index.docbook:3056
#, no-c-format
msgid ""
"A message that will be shown in the message box, should contain a question "
"that can be answered with <guibutton>OK</guibutton> or <guibutton>Cancel</"
"guibutton>."
msgstr ""
"Un mensaje que se mostrará en el cuadro del mensaje, deberá contener una "
"pregunta que pueda ser respondida con <guibutton>Aceptar</guibutton> o "
"<guibutton>Cancelar</guibutton>"

#. Tag: title
#: index.docbook:3066
#, no-c-format
msgid "&no-i18n-tag;n"
msgstr "&no-i18n-tag;n"

#. Tag: title
#: index.docbook:3069
#, no-c-format
msgid "&no-i18n-cmd_newsignal;"
msgstr "&no-i18n-cmd_newsignal;"

#. Tag: title
#: index.docbook:3071
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_newsignal;</"
"command>( <replaceable>samples</replaceable>, <replaceable>rate</"
"replaceable>, <replaceable>bits</replaceable>, <replaceable>tracks</"
"replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_newsignal;</"
"command>( <replaceable>muestras</replaceable>, <replaceable>tasa</"
"replaceable>, <replaceable>bits</replaceable>, <replaceable>pistas</"
"replaceable>)"

#. Tag: para
#: index.docbook:3077
#, no-c-format
msgid ""
"Creates a new signal, with a given length in <emphasis><replaceable>samples</"
"replaceable></emphasis>, a <emphasis><replaceable>rate</replaceable></"
"emphasis> in samples per second (floating point number), a number of "
"<emphasis><replaceable>bits</replaceable></emphasis> per sample and number "
"of <emphasis><replaceable>tracks</replaceable></emphasis>. You can calculate "
"the length in samples by multiplying the desired length in seconds with the "
"sample rate."
msgstr ""
"Crea una nueva señal, con la longitud dada en "
"<emphasis><replaceable>muestras</replaceable></emphasis>, una "
"<emphasis><replaceable>frecuencia</replaceable></emphasis> en muestras por "
"segundo (número en coma flotante), un número de <emphasis><replaceable>bits</"
"replaceable></emphasis> por muestra y número de "
"<emphasis><replaceable>pistas</replaceable></emphasis>. Puede calcular la "
"longitud en muestras multiplicando la longitud deseada en segundos con la "
"frecuencia de muestreo."

#. Tag: entry
#: index.docbook:3089
#, no-c-format
msgid "<parameter>samples</parameter>:"
msgstr "<parameter>muestras</parameter>:"

#. Tag: entry
#: index.docbook:3090
#, no-c-format
msgid "Length of the signal in samples."
msgstr "Longitud de la señal en muestras."

#. Tag: entry
#: index.docbook:3091
#, no-c-format
msgid "<parameter>rate</parameter>:"
msgstr "<parameter>tasa</parameter>:"

#. Tag: entry
#: index.docbook:3092
#, no-c-format
msgid "<entry>Sample rate in samples per second.</entry>"
msgstr "<entry>Tasa de muestras por segundo.</entry>"

#. Tag: entry
#: index.docbook:3093
#, no-c-format
msgid "<parameter>bits</parameter>:"
msgstr "<parameter>bits</parameter>:"

#. Tag: entry
#: index.docbook:3094
#, no-c-format
msgid ""
"Number of bits per sample, must not be zero, should be a number from 8...32."
msgstr ""
"Número de bits por muestra, no puede ser 0, debería ser un número entre 8 y "
"32."

#. Tag: entry
#: index.docbook:3096
#, no-c-format
msgid "<parameter>tracks</parameter>:"
msgstr "<parameter>pistas</parameter>:"

#. Tag: entry
#: index.docbook:3097
#, no-c-format
msgid "Number of tracks."
msgstr "Número de pistas."

#. Tag: title
#: index.docbook:3102
#, no-c-format
msgid "&no-i18n-cmd_next;"
msgstr "&no-i18n-cmd_next;"

#. Tag: title
#: index.docbook:3104
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_next;</command>()"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_next;</command>()"

#. Tag: para
#: index.docbook:3105
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Next</guibutton> toolbar button. If the "
"playback is currently running, it skips forward to the next label. If the "
"playback is not running, this does the same as the command <command>&no-i18n-"
"cmd_view_scroll_next_label;</command>()."
msgstr ""
"Corresponde al botón de la barra de tareas <guibutton>Siguiente</guibutton>. "
"Si la reproducción está en ejecución, avanza la ejecución hasta la siguiente "
"etiqueta. Si la reproducción no está en ejecución, esto hace lo mismo que la "
"orden <command>&no-i18n-cmd_view_scroll_next_label;</command>()."

#. Tag: para
#: index.docbook:3114
#, no-c-format
msgid ""
"<link linkend=\"cmd_sect_view_scroll_next_label\"><command>&no-i18n-tag;&no-"
"i18n-cmd_view_scroll_next_label;</command>()</link>, <link linkend="
"\"cmd_sect_prev\"><command>&no-i18n-tag;&no-i18n-cmd_prev;</command>()</link>"
msgstr ""
"<link linkend=\"cmd_sect_view_scroll_next_label\"><command>&no-i18n-tag;&no-"
"i18n-cmd_view_scroll_next_label;</command>()</link>, <link linkend="
"\"cmd_sect_prev\"><command>&no-i18n-tag;&no-i18n-cmd_prev;</command>()</link>"

#. Tag: title
#: index.docbook:3122
#, no-c-format
msgid "&no-i18n-tag;o"
msgstr "&no-i18n-tag;o"

#. Tag: title
#: index.docbook:3125
#, no-c-format
msgid "&no-i18n-cmd_open;"
msgstr "&no-i18n-cmd_open;"

#. Tag: title
#: index.docbook:3127
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_open;</"
"command>([<replaceable>filename</replaceable>])"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_open;</command>([<replaceable>nombre "
"de archivo</replaceable>])"

#. Tag: para
#: index.docbook:3128
#, no-c-format
msgid ""
"Opens a file, which can be either a sound file or a &kwave; script. If no "
"file name is passed, then a dialog window will be opened that allows to "
"select an existing file. Depending on the &GUI; mode the file will be opened "
"in the context of a new sub-window (MDI and tab) or in a new main window "
"(SDI, if there was already something loaded)."
msgstr ""
"Abre un archivo, que puede ser un archivo de sonido o un script &kwave;.Si "
"no se le pasa ningún nombre de archivo, entonces se abrirá un diálogo que "
"permite elegir un archivo existente. Dependiendo de la &GUI;, el archivo se "
"abrirá en el contexto de una nueva sub-ventana (MDI y pestaña) o en una "
"nueva ventana principal (SDI, si había algo ya cargado)."

#. Tag: entry
#: index.docbook:3139
#, no-c-format
msgid "name of a file including path and extension"
msgstr "nombre del archivo incluyendo ruta y extensión"

#. Tag: link
#: index.docbook:3143 index.docbook:3332
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_close;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_close;</command>()"

#. Tag: title
#: index.docbook:3149
#, no-c-format
msgid "&no-i18n-cmd_openrecent;"
msgstr "&no-i18n-cmd_openrecent;"

#. Tag: title
#: index.docbook:3151
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_openrecent;</"
"command>(<replaceable>filename</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_openrecent;</"
"command>(<replaceable>nombre de archivo</replaceable>)"

#. Tag: para
#: index.docbook:3152
#, no-c-format
msgid ""
"Practically the same as the command <command>&no-i18n-cmd_open;</command>(), "
"but intended to be used internally for the list of recently opened files in "
"the menu <menuchoice> <guimenu>File</guimenu><guimenu>Open Recent</guimenu> "
"</menuchoice>. In this command the parameter <replaceable>filename</"
"replaceable> is not optional."
msgstr ""
"Prácticamente lo mismo que la orden <command>&no-i18n-cmd_open;</command>(), "
"pero con el fin de ser usado internamente para la lista de archivos "
"recientemente abiertos en el menú <menuchoice> <guimenu>Archivo</"
"guimenu><guimenu>Abrir reciente</guimenu> </menuchoice>. En esta orden, el "
"parámetro <replaceable>nombre de archivo</replaceable> no es opcional."

#. Tag: entry
#: index.docbook:3165
#, no-c-format
msgid "entry of the list of recently opened files"
msgstr "entrada de la lista de los archivos abiertos recientemente"

#. Tag: link
#: index.docbook:3169
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_open;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_open;</command>()"

#. Tag: title
#: index.docbook:3175
#, no-c-format
msgid "&no-i18n-tag;p"
msgstr "&no-i18n-tag;p"

#. Tag: title
#: index.docbook:3178
#, no-c-format
msgid "&no-i18n-cmd_paste;"
msgstr "&no-i18n-cmd_paste;"

#. Tag: title
#: index.docbook:3180
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_paste;</command>()"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_paste;</command>()"

#. Tag: para
#: index.docbook:3181
#, no-c-format
msgid ""
"Replaces the current selection with the content of the clipboard. If the "
"clipboard is empty, this command does nothing. The sample rate of the "
"inserted data is adjusted to match the sample rate of the current signal if "
"necessary. Only enabled tracks are affected, disabled tracks remain "
"unchanged. Please be aware that this might produce a time shift between "
"enabled and disabled tracks! If the number of tracks of the clipboard data "
"differs from the number of enabled tracks, then the data is mixed to be "
"spread equally over all selected tracks."
msgstr ""
"Remplaza la selección actual con el contenido del portapapeles. Si el "
"portapapeles está vacío, estar orden no hace nada. La frecuencia de sampleo "
"de los datos insertados se ajusta a la frecuencia de muestreo de la señal "
"actual si es necesario. Solo afecta a las pistas habilitadas, las pistas "
"deshabilitadas permanecen sin cambios. Tenga en cuenta que esto puede "
"producir un desplazamiento en el tiempo entre las pistas habilitadas y "
"deshabilitadas. Si el número de pistas de los datos del portapapeles difiere "
"del número de pistas habilitadas, entonces los datos se mezclan para ser "
"distribuidos equitativamente entre las pistas seleccionadas."

#. Tag: link
#: index.docbook:3196
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_copy;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_copy;</command>()"

#. Tag: title
#: index.docbook:3202
#, no-c-format
msgid "&no-i18n-cmd_pause;"
msgstr "&no-i18n-cmd_pause;"

#. Tag: para
#: index.docbook:3205
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Pause</guibutton> toolbar button and lets the "
"playback pause if it is currently running, or continue if it is currently "
"paused."
msgstr ""
"Corresponde al botón de la barra de herramientas <guibutton>Pausa</"
"guibutton>, pausando la reproducción si está ejecutándose, o continuando si "
"está pausada."

#. Tag: link
#: index.docbook:3213
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_continue;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_continue;</command>()"

#. Tag: title
#: index.docbook:3219
#, no-c-format
msgid "&no-i18n-cmd_playback_start;"
msgstr "&no-i18n-cmd_playback_start;"

#. Tag: title
#: index.docbook:3221
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_playback_start;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_playback_start;</"
"command>()"

#. Tag: para
#: index.docbook:3222
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Start</guibutton> toolbar button and lets the "
"playback start if it is currently paused."
msgstr ""
"Corresponde al botón de la barra de herramientas <guibutton>Inicio</"
"guibutton>, iniciando la reproducción si está pausada."

#. Tag: title
#: index.docbook:3230
#, no-c-format
msgid "&no-i18n-cmd_plugin;"
msgstr "&no-i18n-cmd_plugin;"

#. Tag: title
#: index.docbook:3232
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_plugin;</command>(<replaceable>name</"
"replaceable>, [<replaceable>parameter</replaceable> ...])"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_plugin;</"
"command>(<replaceable>nombre</replaceable>, [<replaceable>parámetro</"
"replaceable> …])"

#. Tag: para
#: index.docbook:3233
#, no-c-format
msgid ""
"Executes a plugin, with an optional list of parameters. If no parameter list "
"is given, then the setup function of the plugin will be called, using the "
"parameters of the previous invocation or default parameters as input "
"(normally shows a setup dialog, depending on the plugin). Please refer to "
"the chapter about <link linkend=\"plugins\">plugins</link> for a description "
"of the various plugins."
msgstr ""
"Ejecuta un complemento, con una lista opcional de parámetros. Si no se "
"especifica ninguna lista de parámetros, entonces la función de configuración "
"del complemento se invoca usando los parámetros usados en la invocación "
"previa o los parámetros por defecto como entrada (normalmente muestra un "
"diálogo de configuración, dependiendo del complemento). Por favor, vea el "
"capítulo sobre <link linkend=\"plugins\">complementos</link> para recabar "
"más información sobre varios complementos."

#. Tag: entry
#: index.docbook:3244 index.docbook:3268 index.docbook:3290
#, no-c-format
msgid "<parameter>name</parameter>:"
msgstr "<parameter>nombre</parameter>:"

#. Tag: entry
#: index.docbook:3245 index.docbook:3269 index.docbook:3291
#, no-c-format
msgid "the (internal) name of a &kwave; plugin"
msgstr "el nombre (interno) del complemento &kwave;"

#. Tag: entry
#: index.docbook:3246 index.docbook:3270 index.docbook:3292
#, no-c-format
msgid "<parameter>parameter</parameter>:"
msgstr "<parameter>parámetro</parameter>:"

#. Tag: entry
#: index.docbook:3247 index.docbook:3293
#, no-c-format
msgid "a list of parameters understood by the plugin (optional)"
msgstr "una lista de parámetros entendidos por el complemento (opcional)"

#. Tag: para
#: index.docbook:3250
#, no-c-format
msgid ""
"<link linkend=\"cmd_sect_plugin_execute\"><command>&no-i18n-tag;&no-i18n-"
"cmd_plugin_execute;</command>()</link>, <link linkend=\"cmd_sect_plugin_setup"
"\"><command>&no-i18n-tag;&no-i18n-cmd_plugin_setup;</command>()</link>"
msgstr ""
"<link linkend=\"cmd_sect_plugin_execute\"><command>&no-i18n-tag;&no-i18n-"
"cmd_plugin_execute;</command>()</link>, <link linkend=\"cmd_sect_plugin_setup"
"\"><command>&no-i18n-tag;&no-i18n-cmd_plugin_setup;</command>()</link>"

#. Tag: title
#: index.docbook:3258
#, no-c-format
msgid "&no-i18n-cmd_plugin_execute;"
msgstr "&no-i18n-cmd_plugin_execute;"

#. Tag: title
#: index.docbook:3260
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_plugin_execute;</"
"command>(<replaceable>name</replaceable>, [<replaceable>parameter</"
"replaceable> ...])"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_plugin_execute;</"
"command>(<replaceable>nombre</replaceable>, [<replaceable>parámetro</"
"replaceable> …])"

#. Tag: para
#: index.docbook:3261
#, no-c-format
msgid ""
"Similar to the command <command>&no-i18n-cmd_plugin;</command>(), but "
"without calling the setup function of the plugin if no parameters were "
"passed."
msgstr ""
"Similar a la orden <command>&no-i18n-cmd_plugin;</command>(), pero sin "
"llamar a la función de configuración del complemento si no se le indicó "
"ningún parámetro."

#. Tag: entry
#: index.docbook:3271
#, no-c-format
msgid "a list of parameters understood by the plugin"
msgstr "una lista de parámetros entendidos por el complemento"

#. Tag: title
#: index.docbook:3276
#, no-c-format
msgid "&no-i18n-cmd_plugin_setup;"
msgstr "&no-i18n-cmd_plugin_setup;"

#. Tag: title
#: index.docbook:3278
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_plugin_setup;</"
"command>(<replaceable>name</replaceable>, [<replaceable>parameter</"
"replaceable> ...])"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_plugin_setup;</"
"command>(<replaceable>nombre</replaceable>, [<replaceable>parámetro</"
"replaceable> …])"

#. Tag: para
#: index.docbook:3279
#, no-c-format
msgid ""
"Calls the <emphasis>setup</emphasis> function of a plugin, with an optional "
"list of parameters. If no parameter list is given, the parameters of the "
"previous invocation or default parameters will be used as input. This "
"normally shows a setup dialog, depending on the plugin. Please refer to the "
"chapter about <link linkend=\"plugins\">plugins</link> for a description of "
"the various plugins."
msgstr ""
"Invoca la función de <emphasis>configuración</emphasis> de un complemento, "
"con una lista opcional de parámetros. Si no se especifica ninguna lista, se "
"usarán los parámetros de la invocación previa o los parámetros por defecto. "
"Esto normalmente muestra un diálogo de configuración, dependiendo del "
"complemento. Por favor, vea el capítulo sobre <link linkend=\"plugins"
"\">complementos</link> para recabar más información sobre varios "
"complementos."

#. Tag: title
#: index.docbook:3298
#, no-c-format
msgid "&no-i18n-cmd_prev;"
msgstr "&no-i18n-cmd_prev;"

#. Tag: title
#: index.docbook:3300
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_prev;</command>()"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_prev;</command>()"

#. Tag: para
#: index.docbook:3301
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Previous</guibutton> toolbar button. If the "
"playback is currently running, it skips back to the previous label or start "
"of the selection. If the playback is not running, this does the same as the "
"command <command>&no-i18n-cmd_view_scroll_prev_label;</command>()."
msgstr ""
"Corresponde al botón de la barra de herramientas <guibutton>Previo</"
"guibutton>. Si la reproducción está en ejecución, retrasa la ejecución hasta "
"la etiqueta previa o al inicio de la selección. Si la reproducción no está "
"en ejecución, esto hace lo mismo que la orden <command>&no-i18n-"
"cmd_view_scroll_prev_label;</command>()."

#. Tag: para
#: index.docbook:3310
#, no-c-format
msgid ""
"<link linkend=\"cmd_sect_view_scroll_next_label\"><command>&no-i18n-tag;&no-"
"i18n-cmd_view_scroll_prev_label;</command>()</link>, <link linkend="
"\"cmd_sect_next\"><command>&no-i18n-tag;&no-i18n-cmd_next;</command>()</link>"
msgstr ""
"<link linkend=\"cmd_sect_view_scroll_next_label\"><command>&no-i18n-tag;&no-"
"i18n-cmd_view_scroll_prev_label;</command>()</link>, <link linkend="
"\"cmd_sect_next\"><command>&no-i18n-tag;&no-i18n-cmd_next;</command>()</link>"

#. Tag: title
#: index.docbook:3318
#, no-c-format
msgid "&no-i18n-tag;q"
msgstr "&no-i18n-tag;q"

#. Tag: title
#: index.docbook:3321
#, no-c-format
msgid "&no-i18n-cmd_quit;"
msgstr "&no-i18n-cmd_quit;"

#. Tag: title
#: index.docbook:3323
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_quit;</command>()"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_quit;</command>()"

#. Tag: para
#: index.docbook:3324
#, no-c-format
msgid ""
"Closes the current main window, including all sub-windows. In SDI mode this "
"is the same as the command <command>&no-i18n-cmd_close;</command>()."
msgstr ""
"Cierra la ventana principal actual, incluyendo todas sus sub-ventanas. En el "
"modo SDI esto es lo mismo que la orden <command>&no-i18n-cmd_close;</"
"command>()."

#. Tag: title
#: index.docbook:3338
#, no-c-format
msgid "&no-i18n-tag;r"
msgstr "&no-i18n-tag;r"

#. Tag: title
#: index.docbook:3341
#, no-c-format
msgid "&no-i18n-cmd_redo;"
msgstr "&no-i18n-cmd_redo;"

#. Tag: title
#: index.docbook:3343
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_redo;</command>()"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_redo;</command>()"

#. Tag: para
#: index.docbook:3344
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Redo</guibutton> toolbar button and repeats "
"one operation that has been reverted with <command>&no-i18n-cmd_undo;</"
"command>()."
msgstr ""
"Corresponde al botón de la barra de herramientas <guibutton>Rehacer</"
"guibutton> y repite una operación que ha sido revertida con <command>&no-"
"i18n-cmd_undo;</command>()."

#. Tag: link
#: index.docbook:3352 index.docbook:3368 index.docbook:3826
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_undo;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_undo;</command>()"

#. Tag: title
#: index.docbook:3358
#, no-c-format
msgid "&no-i18n-cmd_redo_all;"
msgstr "&no-i18n-cmd_redo_all;"

#. Tag: title
#: index.docbook:3360
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_redo_all;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_redo_all;</command>()"

#. Tag: para
#: index.docbook:3361
#, no-c-format
msgid ""
"Similar to <command>&no-i18n-cmd_redo;</command>(), but re-does as many "
"operations as possible."
msgstr ""
"Similar a <command>&no-i18n-cmd_redo;</command>(), pero rehace tantas "
"operaciones como sea posible."

#. Tag: title
#: index.docbook:3374
#, no-c-format
msgid "&no-i18n-cmd_reenable_dna;"
msgstr "&no-i18n-cmd_reenable_dna;"

#. Tag: title
#: index.docbook:3376
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_reenable_dna;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_reenable_dna;</command>()"

#. Tag: para
#: index.docbook:3377
#, no-c-format
msgid ""
"Some message boxes offer the possibility to prevent them from appearing "
"again (<quote>do not ask again</quote>). This command makes all of them "
"appear again."
msgstr ""
"Algunos cuadros de mensajes ofrecen la posibilidad de prevenir su "
"reaparición (<quote>no preguntar de nuevo</quote>). Esta orden hace que "
"todos los cuadros aparezcan de nuevo."

#. Tag: title
#: index.docbook:3386
#, no-c-format
msgid "&no-i18n-cmd_reset_toolbars;"
msgstr "&no-i18n-cmd_reset_toolbars;"

#. Tag: title
#: index.docbook:3388
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_reset_toolbars;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_reset_toolbars;</"
"command>()"

#. Tag: para
#: index.docbook:3389
#, no-c-format
msgid ""
"Resets all toolbar settings, like location, icon size and text location back "
"to defaults."
msgstr ""
"Reinicia todas las configuraciones de la barra de herramientas, como la "
"localización, el tamaño de los iconos y la localización del texto a sus "
"valores predeterminados."

#. Tag: title
#: index.docbook:3397
#, no-c-format
msgid "&no-i18n-cmd_revert;"
msgstr "&no-i18n-cmd_revert;"

#. Tag: title
#: index.docbook:3399
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_revert;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_revert;</command>()"

#. Tag: para
#: index.docbook:3400
#, no-c-format
msgid ""
"Reverts the currently loaded file back to the last saved state, discarding "
"all changes that are not saved."
msgstr ""
"Revierte el archivo actualmente cargado al último estado guardado, "
"descartando todos los cambios no guardados."

#. Tag: title
#: index.docbook:3408
#, no-c-format
msgid "&no-i18n-cmd_rewind;"
msgstr "&no-i18n-cmd_rewind;"

#. Tag: title
#: index.docbook:3410
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_rewind;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_rewind;</command>()"

#. Tag: para
#: index.docbook:3411
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Rewind</guibutton> toolbar button. If the "
"playback is currently running, it skips backward by 1/10 of the visible "
"range. If the playback is not running, this does the same as the command "
"<command>&no-i18n-cmd_view_scroll_left;</command>()."
msgstr ""
"Corresponde al botón de la barra de herramientas <guibutton>Rebobinar</"
"guibutton>. Si la reproducción está en ejecución, retrasa la ejecución un "
"1/10 de la gama visible. Si la reproducción no está en ejecución, esto hace "
"lo mismo que la orden <command>&no-i18n-cmd_view_scroll_left;</command>()."

#. Tag: para
#: index.docbook:3420
#, no-c-format
msgid ""
"<link linkend=\"cmd_sect_view_scroll_left\"><command>&no-i18n-tag;&no-i18n-"
"cmd_view_scroll_left;</command>()</link>, <link linkend=\"cmd_sect_forward"
"\"><command>&no-i18n-tag;&no-i18n-cmd_forward;</command>()</link>"
msgstr ""
"<link linkend=\"cmd_sect_view_scroll_left\"><command>&no-i18n-tag;&no-i18n-"
"cmd_view_scroll_left;</command>()</link>, <link linkend=\"cmd_sect_forward"
"\"><command>&no-i18n-tag;&no-i18n-cmd_forward;</command>()</link>"

#. Tag: title
#: index.docbook:3428
#, no-c-format
msgid "&no-i18n-tag;s"
msgstr "&no-i18n-tag;s"

#. Tag: title
#: index.docbook:3431
#, no-c-format
msgid "&no-i18n-cmd_save;"
msgstr "&no-i18n-cmd_save;"

#. Tag: title
#: index.docbook:3433
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_save;</command>()"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_save;</command>()"

#. Tag: para
#: index.docbook:3434
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Save</guibutton> toolbar button. Saves the "
"current file if it has modifications. If the file does not already have a "
"name (&eg; a file that has just been created and does not yet have a file "
"name), this command does the same as <command>&no-i18n-cmd_saveas;</"
"command>()."
msgstr ""
"Corresponde al botón de la barra de herramientas <guibutton>Guardar</"
"guibutton>. Guarda el archivo actual si tiene modificaciones. Si el archivo "
"no tiene nombre (&eg; el archivo acaba de ser creado y no tiene nombre de "
"momento), esta orden hace lo mismo que <command>&no-i18n-cmd_saveas;</"
"command>()."

#. Tag: link
#: index.docbook:3444
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_saveas;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_saveas;</command>()"

#. Tag: title
#: index.docbook:3450
#, no-c-format
msgid "&no-i18n-cmd_saveas;"
msgstr "&no-i18n-cmd_saveas;"

#. Tag: title
#: index.docbook:3452
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_saveas;</"
"command>([<replaceable>filename</replaceable>])"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_saveas;</"
"command>([<replaceable>nombre de archivo</replaceable>])"

#. Tag: para
#: index.docbook:3453
#, no-c-format
msgid ""
"Saves the currently opened file under a given file name. If no file name is "
"given as parameter, a dialog will be shown to select the directory and to "
"enter a file name."
msgstr ""
"Guarda el archivo abierto actualmente bajo un nombre de archivo. Si no se "
"especifica ningún nombre de archivo como parámetro, se abrirá un diálogo que "
"permitirá seleccionar el directorio y un nombre de archivo."

#. Tag: entry
#: index.docbook:3461
#, no-c-format
msgid "file name for saving (optional)"
msgstr "nombre del archivo a guardar (opcional)"

#. Tag: title
#: index.docbook:3466
#, no-c-format
msgid "&no-i18n-cmd_saveselect;"
msgstr "&no-i18n-cmd_saveselect;"

#. Tag: title
#: index.docbook:3468
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_saveselect;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_saveselect;</command>()"

#. Tag: para
#: index.docbook:3469
#, no-c-format
msgid ""
"This command does the same as <command>&no-i18n-cmd_save;</command>(), but "
"saves only the currently selected range and the activated tracks instead of "
"the whole file."
msgstr ""
"Esta orden hace lo mismo que <command>&no-i18n-cmd_save;</command>(), pero "
"guarda solo el intervalo actualmente seleccionado y la pista activada en "
"lugar del archivo entero."

#. Tag: link
#: index.docbook:3477
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_save;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_save;</command>()"

#. Tag: title
#: index.docbook:3483
#, no-c-format
msgid "&no-i18n-cmd_select_gui_type;"
msgstr "&no-i18n-cmd_select_gui_type;"

#. Tag: title
#: index.docbook:3485
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_select_gui_type;</"
"command>(<replaceable>mode</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_select_gui_type;</"
"command>(<replaceable>modo</replaceable>)"

#. Tag: para
#: index.docbook:3486
#, no-c-format
msgid ""
"Select a &GUI; mode, which can be either SDI, MDI or Tab mode. Please be "
"aware that this change will immediately take effect!"
msgstr ""
"Selecciona el modo &GUI;, que puede ser SDI, MDI o pestaña. Tenga en cuenta "
"que este cambio tomará efecto inmediato."

#. Tag: entry
#: index.docbook:3494
#, no-c-format
msgid ""
"name of the mode, must be either <quote>SDI</quote>, <quote>MDI</quote> or "
"<quote>TAB</quote>."
msgstr ""
"nombre del modo, que puede ser <quote>SDI</quote>, <quote>MDI</quote> o "
"<quote>TAB</quote>."

#. Tag: title
#: index.docbook:3502
#, no-c-format
msgid "&no-i18n-cmd_select_track_all;"
msgstr "&no-i18n-cmd_select_track_all;"

#. Tag: title
#: index.docbook:3504 index.docbook:3521
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_select_track_all;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_select_track_all;</"
"command>()"

#. Tag: para
#: index.docbook:3505
#, no-c-format
msgid ""
"Mark all tracks <quote>enabled</quote>. This is the same as calling the "
"command <command>&no-i18n-tag;&no-i18n-cmd_select_track_on;</command>() for "
"all existing tracks."
msgstr ""
"<quote>Habilita</quote> todas las pistas. Esto es lo mismo que invocar a la "
"orden <command>&no-i18n-tag;&no-i18n-cmd_select_track_on;</command>() para "
"todas la pistas existentes."

#. Tag: link
#: index.docbook:3513
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_select_track_on;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_select_track_on;</command>()"

#. Tag: title
#: index.docbook:3519
#, no-c-format
msgid "&no-i18n-cmd_select_track_invert;"
msgstr "&no-i18n-cmd_select_track_invert;"

# (filtered) msgid "&no-i18n-cmd_select_track_invert;"
# (filtered) msgstr ""
#. Tag: para
#: index.docbook:3522
#, no-c-format
msgid ""
"Invert the <quote>enabled</quote> state of all tracks. This is the same as "
"calling the command <command>&no-i18n-cmd_select_track_toggle;</command>() "
"for all existing tracks."
msgstr ""
"Invierte el estado de <quote>activación</quote> de las pistas. Esto es lo "
"mismo que invocar la orden <command>&no-i18n-cmd_select_track_toggle;</"
"command>() para todas las pistas."

#. Tag: link
#: index.docbook:3531
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_select_track_toggle;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_select_track_toggle;</command>()"

#. Tag: title
#: index.docbook:3537
#, no-c-format
msgid "&no-i18n-cmd_select_track_none;"
msgstr "&no-i18n-cmd_select_track_none;"

#. Tag: title
#: index.docbook:3539
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_select_track_none;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_select_track_none;</"
"command>()"

#. Tag: para
#: index.docbook:3540
#, no-c-format
msgid ""
"Mark all tracks <quote>disabled</quote>. This is the same as calling the "
"command <command>&no-i18n-cmd_select_track_off;</command>() for all existing "
"tracks."
msgstr ""
"<quote>Deshabilita</quote> todas las pistas. Esto es lo mismo que invocar la "
"orden <command>&no-i18n-cmd_select_track_off;</command>() para todas las "
"pistas existentes."

#. Tag: link
#: index.docbook:3548
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_select_track_off;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_select_track_off;</command>()"

#. Tag: title
#: index.docbook:3554
#, no-c-format
msgid "&no-i18n-cmd_select_track_off;"
msgstr "&no-i18n-cmd_select_track_off;"

#. Tag: title
#: index.docbook:3556
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_select_track_off;</"
"command>(<replaceable>index</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_select_track_off;</"
"command>(<replaceable>índice</replaceable>)"

#. Tag: para
#: index.docbook:3557
#, no-c-format
msgid ""
"Disables a single track, so that it does not get affected by most operations."
msgstr ""
"Deshabilita una pista única, para que no se vea afectada por la mayoría de "
"las operaciones."

#. Tag: entry
#: index.docbook:3564 index.docbook:3578 index.docbook:3593
#, no-c-format
msgid "index of the track, starting with zero"
msgstr "índice de la pista, empezando en 0"

#. Tag: title
#: index.docbook:3569
#, no-c-format
msgid "&no-i18n-cmd_select_track_on;"
msgstr "&no-i18n-cmd_select_track_on;"

#. Tag: title
#: index.docbook:3571
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_select_track_on;</"
"command>(<replaceable>index</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_select_track_on;</"
"command>(<replaceable>índice</replaceable>)"

#. Tag: para
#: index.docbook:3572
#, no-c-format
msgid "Enables a single track, so that it gets affected by all operations."
msgstr ""
"Habilita una pista única, para que se vea afectada por todas las operaciones."

#. Tag: title
#: index.docbook:3583
#, no-c-format
msgid "&no-i18n-cmd_select_track_toggle;"
msgstr "&no-i18n-cmd_select_track_toggle;"

#. Tag: title
#: index.docbook:3585
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_select_track_toggle;</"
"command>(<replaceable>index</replaceable>)"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_select_track_toggle;</"
"command>(<replaceable>índice</replaceable>)"

#. Tag: para
#: index.docbook:3586
#, no-c-format
msgid ""
"Enables a track if it is currently disabled, or disables it if it is "
"currently enabled."
msgstr ""
"Habilita una pista si está actualmente deshabilitada, o la deshabilita si se "
"encuentra actualmente habilitada."

#. Tag: title
#: index.docbook:3598
#, no-c-format
msgid "&no-i18n-cmd_selectall;"
msgstr "&no-i18n-cmd_selectall;"

#. Tag: title
#: index.docbook:3600
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectall;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectall;</command>()"

#. Tag: para
#: index.docbook:3601
#, no-c-format
msgid ""
"Selects the range of the whole signal, from the first to the last sample."
msgstr ""
"Selecciona el intervalo que comprende toda la señal, de la primera a la "
"última muestra."

#. Tag: title
#: index.docbook:3609
#, no-c-format
msgid "&no-i18n-cmd_selectnext;"
msgstr "&no-i18n-cmd_selectnext;"

#. Tag: title
#: index.docbook:3611
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectnext;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectnext;</command>()"

#. Tag: para
#: index.docbook:3612
#, no-c-format
msgid ""
"Selects a range of samples that starts right after the current selection, "
"using the same length as the current selection. The selection is "
"automatically clipped to the end of the signal. For example: if you have "
"selected samples 1000 ... 1019, then the result will be a selection from "
"sample 1020 ... 1039."
msgstr ""
"Selecciona una gama de muestras que comienza justo después de la selección "
"actual, usando la longitud de la selección actual. La selección se copia "
"automáticamente al final de la señal. Por ejemplo: si ha seleccionado las "
"muestras 1000 … 1019, entonces el resultado será la selección desde las "
"muestras 1020 … 1039."

#. Tag: link
#: index.docbook:3622
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_selectprev;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_selectprev;</command>()"

#. Tag: title
#: index.docbook:3628
#, no-c-format
msgid "&no-i18n-cmd_selectnextlabels;"
msgstr "&no-i18n-cmd_selectnextlabels;"

#. Tag: title
#: index.docbook:3630
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectnextlabels;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectnextlabels;</"
"command>()"

#. Tag: para
#: index.docbook:3631
#, no-c-format
msgid ""
"Selects a range of samples between the next two labels after the current "
"selection. If nothing is selected, it selects from the start of the signal "
"up to the first label. Otherwise the left border of the new selection will "
"be the position of first label after the selection (or the last label if "
"there are no more labels right from the selection), and the right border of "
"the new selection will be the first label after the left border of the new "
"selection (or the end of the signal if there is none). This command returns "
"an error when there are no labels at all."
msgstr ""
"Selecciona una gama de muestras entre las dos siguientes etiquetas después "
"de la selección actual. Si no hay nada seleccionado, selecciona desde el "
"inicio de la señal hasta la primera etiqueta. Si no, el límite izquierdo de "
"la nueva selección será la posición de la primera etiqueta después de la "
"selección (o la última etiqueta si no hay más etiquetas a la derecha de la "
"selección), y el límite derecho de la selección será la primera etiqueta "
"después del límite izquierdo de la nueva selección (o el final de la señal "
"si no hay ninguna). Esta orden devolverá error si no existe ninguna etiqueta."

#. Tag: link
#: index.docbook:3645
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_selectprevlabels;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_selectprevlabels;</command>()"

#. Tag: title
#: index.docbook:3651
#, no-c-format
msgid "&no-i18n-cmd_selectnone;"
msgstr "&no-i18n-cmd_selectnone;"

#. Tag: title
#: index.docbook:3653
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectnone;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectnone;</command>()"

#. Tag: para
#: index.docbook:3654
#, no-c-format
msgid "Resets the selection to zero length."
msgstr "Reinicia la selección a longitud cero."

#. Tag: title
#: index.docbook:3661
#, no-c-format
msgid "&no-i18n-cmd_selectprev;"
msgstr "&no-i18n-cmd_selectprev;"

#. Tag: title
#: index.docbook:3663
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectprev;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectprev;</command>()"

#. Tag: para
#: index.docbook:3664
#, no-c-format
msgid ""
"Selects a range of samples that starts left from the current selection, "
"using the same length as the current selection. The selection is "
"automatically clipped to the start of the signal. For example: if you have "
"selected samples 1000 ... 1019, then the result will be a selection from "
"sample 980 ... 999."
msgstr ""
"Selecciona una gama de muestras que comienza a la izquierda de la selección "
"actual, usando la misma longitud que la selección actual. La selección se "
"copia automáticamente al inicio de la señal. Por ejemplo, si ha seleccionado "
"las muestras 1000 … 1019, entonces el resultado será la selección entre las "
"muestras 980 … 999."

#. Tag: link
#: index.docbook:3674
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_selectnext;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_selectnext;</command>()"

#. Tag: title
#: index.docbook:3680
#, no-c-format
msgid "&no-i18n-cmd_selectprevlabels;"
msgstr "&no-i18n-cmd_selectprevlabels;"

#. Tag: title
#: index.docbook:3682
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectprevlabels;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectprevlabels;</"
"command>()"

#. Tag: para
#: index.docbook:3683
#, no-c-format
msgid ""
"Selects a range of samples between the previous two labels before the "
"current selection. If nothing is selected, it selects from the start of the "
"signal up to the first label. Otherwise the right border of the new "
"selection will be the position of first label before the selection (or the "
"first label if there are no more labels left from the selection), and the "
"left border of the new selection will be the first label before the right "
"border of the new selection (or the start of the signal if there is none). "
"This command returns an error when there are no labels at all."
msgstr ""
"Selecciona una gama de muestras entre las dos etiquetas previas antes de la "
"selección actual. Si no hay nada seleccionado, selecciona desde el inicio de "
"la señal hasta la primera etiqueta. Si no, el límite derecho de la nueva "
"selección será la posición de la primera etiqueta antes de la selección (o "
"la primera etiqueta si no hay más etiquetas a la izquierda de la selección), "
"y el límite izquierdo de la selección será la primera etiqueta antes del "
"límite derecho de la nueva selección (o el inicio de la señal si no hay "
"ninguna). Esta orden devolverá error si no existe ninguna etiqueta."

#. Tag: link
#: index.docbook:3697
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_selectnextlabels;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_selectnextlabels;</command>()"

#. Tag: title
#: index.docbook:3703
#, no-c-format
msgid "&no-i18n-cmd_selecttoleft;"
msgstr "&no-i18n-cmd_selecttoleft;"

#. Tag: title
#: index.docbook:3705
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selecttoleft;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selecttoleft;</command>()"

#. Tag: para
#: index.docbook:3706
#, no-c-format
msgid ""
"Sets the start of the selection to the start of the signal, the end of the "
"current selection stays unchanged."
msgstr ""
"Establece el inicio de la selección al inicio de la señal, el final de la "
"selección actual permanece sin cambios."

#. Tag: link
#: index.docbook:3713
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_selecttoright;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_selecttoright;</command>()"

#. Tag: title
#: index.docbook:3719
#, no-c-format
msgid "&no-i18n-cmd_selecttoright;"
msgstr "&no-i18n-cmd_selecttoright;"

#. Tag: title
#: index.docbook:3721
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selecttoright;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selecttoright;</"
"command>()"

#. Tag: para
#: index.docbook:3722
#, no-c-format
msgid ""
"Sets the end of the selection to the end of the signal, the start of the "
"current selection stays unchanged."
msgstr ""
"Establece el final de la selección al final de la señal, el inicio de la "
"selección actual permanece sin cambios."

#. Tag: link
#: index.docbook:3729
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_selecttoleft;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_selecttoleft;</command>()"

#. Tag: title
#: index.docbook:3735
#, no-c-format
msgid "&no-i18n-cmd_selectvisible;"
msgstr "&no-i18n-cmd_selectvisible;"

#. Tag: title
#: index.docbook:3737
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectvisible;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_selectvisible;</"
"command>()"

#. Tag: para
#: index.docbook:3738
#, no-c-format
msgid "Selects the range of samples that is visible in the current window."
msgstr ""
"Selecciona el intervalo de muestras que es visible en la ventana actual."

#. Tag: title
#: index.docbook:3746
#, no-c-format
msgid "&no-i18n-cmd_start;"
msgstr "&no-i18n-cmd_start;"

#. Tag: title
#: index.docbook:3748
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_start;</command>()"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_start;</command>()"

#. Tag: para
#: index.docbook:3749
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Start</guibutton> toolbar button and lets the "
"playback start from the beginning of the selection or continue if it is "
"currently paused."
msgstr ""
"Corresponde al botón de la barra de herramientas <guibutton>Inicio</"
"guibutton> e inicia la reproducción de la selección o la continúa si está "
"pausada."

#. Tag: link
#: index.docbook:3757
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_stop;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_stop;</command>()"

#. Tag: title
#: index.docbook:3763
#, no-c-format
msgid "&no-i18n-cmd_stop;"
msgstr "&no-i18n-cmd_stop;"

#. Tag: title
#: index.docbook:3765
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_stop;</command>()"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_stop;</command>()"

#. Tag: para
#: index.docbook:3766
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Stop</guibutton> toolbar button and lets the "
"playback stop if it is currently running."
msgstr ""
"Corresponde al botón de la barra de herramientas <guibutton>Detener</"
"guibutton> y para la reproducción si está en ejecución."

#. Tag: link
#: index.docbook:3773
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_start;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_start;</command>()"

#. Tag: title
#: index.docbook:3779
#, no-c-format
msgid "&no-i18n-cmd_sync;"
msgstr "&no-i18n-cmd_sync;"

#. Tag: title
#: index.docbook:3781
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_sync;</command>()"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_sync;</command>()"

#. Tag: para
#: index.docbook:3782
#, no-c-format
msgid ""
"Waits until all commands which have been started asynchronously have "
"finished. If nothing is currently queued for delayed execution this command "
"has no effect."
msgstr ""
"Espera a que todas las órdenes iniciadas asíncronamente hayan terminado. Si "
"no hay nada actualmente encolado para una ejecución posterior, esta orden no "
"tiene efecto."

#. Tag: link
#: index.docbook:3790
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_delayed;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_delayed;</command>()"

#. Tag: title
#: index.docbook:3797
#, no-c-format
msgid "&no-i18n-tag;u"
msgstr "&no-i18n-tag;u"

#. Tag: title
#: index.docbook:3800
#, no-c-format
msgid "&no-i18n-cmd_undo;"
msgstr "&no-i18n-cmd_undo;"

#. Tag: title
#: index.docbook:3802
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_undo;</command>()"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_undo;</command>()"

#. Tag: para
#: index.docbook:3803
#, no-c-format
msgid ""
"Corresponds to the <guibutton>Undo</guibutton> toolbar button and reverts "
"the last operation."
msgstr ""
"Corresponde al botón de la barra de tareas <guibutton>Deshacer</guibutton> y "
"revierte la última operación."

#. Tag: link
#: index.docbook:3810
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_redo;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_redo;</command>()"

#. Tag: title
#: index.docbook:3816
#, no-c-format
msgid "&no-i18n-cmd_undo_all;"
msgstr "&no-i18n-cmd_undo_all;"

#. Tag: title
#: index.docbook:3818
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_undo_all;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_undo_all;</command>()"

#. Tag: para
#: index.docbook:3819
#, no-c-format
msgid ""
"Similar to <command>&no-i18n-tag;&no-i18n-cmd_undo;</command>(), but reverts "
"as many operations as possible."
msgstr ""
"Similar a <command>&no-i18n-tag;&no-i18n-cmd_undo;</command>(), pero "
"revierte todas las operaciones posibles."

#. Tag: title
#: index.docbook:3832
#, no-c-format
msgid "&no-i18n-tag;v"
msgstr "&no-i18n-tag;v"

#. Tag: title
#: index.docbook:3835
#, no-c-format
msgid "&no-i18n-cmd_view_scroll_end;"
msgstr "&no-i18n-cmd_view_scroll_end;"

#. Tag: title
#: index.docbook:3837
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_end;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_end;</"
"command>()"

#. Tag: para
#: index.docbook:3838
#, no-c-format
msgid "Scrolls the current view to the <emphasis>end</emphasis> of the signal."
msgstr "Desplaza la vista actual al <emphasis>final</emphasis> de la señal."

#. Tag: link
#: index.docbook:3842
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_start;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_start;</command>()"

#. Tag: title
#: index.docbook:3848
#, no-c-format
msgid "&no-i18n-cmd_view_scroll_left;"
msgstr "&no-i18n-cmd_view_scroll_left;"

#. Tag: title
#: index.docbook:3850
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_left;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_left;</"
"command>()"

#. Tag: para
#: index.docbook:3851
#, no-c-format
msgid ""
"Scrolls the current view by 1/10 of the currently visible range towards the "
"start of the signal. If the start of the signal is reached the visible area "
"starts at offset zero."
msgstr ""
"Desplaza la vista actual un 1/10 del rango visible actual hacia el principio "
"de la señal. Si se alcanza el inicio de la señal, el área visible empieza en "
"0."

#. Tag: link
#: index.docbook:3859
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_right;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_right;</command>()"

#. Tag: title
#: index.docbook:3865
#, no-c-format
msgid "&no-i18n-cmd_view_scroll_next;"
msgstr "&no-i18n-cmd_view_scroll_next;"

#. Tag: title
#: index.docbook:3867
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_next;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_next;</"
"command>()"

#. Tag: para
#: index.docbook:3868
#, no-c-format
msgid ""
"Scrolls the current view towards the end of the signal by the currently "
"visible range."
msgstr ""
"Desplaza la vista actual hacia el final de la señal por el intervalo visible "
"actual."

#. Tag: link
#: index.docbook:3875
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_prev;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_prev;</command>()"

#. Tag: title
#: index.docbook:3881
#, no-c-format
msgid "&no-i18n-cmd_view_scroll_next_label;"
msgstr "&no-i18n-cmd_view_scroll_next_label;"

#. Tag: title
#: index.docbook:3883
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_next_label;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_next_label;</"
"command>()"

#. Tag: para
#: index.docbook:3884
#, no-c-format
msgid ""
"Scrolls right and tries to show the next label centered in the view. If "
"there was no label right from the current position, it will scroll to the "
"end of the signal."
msgstr ""
"Desplaza a la derecha e intenta mostrar la etiqueta siguiente centrada en la "
"vista. Si no hay ninguna etiqueta a la derecha de la posición actual, se "
"desplazará hasta el final de la señal."

#. Tag: link
#: index.docbook:3892
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_prev_label;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_prev_label;</command>()"

#. Tag: title
#: index.docbook:3898
#, no-c-format
msgid "&no-i18n-cmd_view_scroll_prev;"
msgstr "&no-i18n-cmd_view_scroll_prev;"

#. Tag: title
#: index.docbook:3900
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_prev;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_prev;</"
"command>()"

#. Tag: para
#: index.docbook:3901
#, no-c-format
msgid ""
"Scrolls the current view towards the start of the signal by the currently "
"visible range."
msgstr ""
"Desplaza la vista actual hacia el inicio de la señal por el intervalo "
"visible actual."

#. Tag: link
#: index.docbook:3908
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_next;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_next;</command>()"

#. Tag: title
#: index.docbook:3914
#, no-c-format
msgid "&no-i18n-cmd_view_scroll_prev_label;"
msgstr "&no-i18n-cmd_view_scroll_prev_label;"

#. Tag: title
#: index.docbook:3916
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_prev_label;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_prev_label;</"
"command>()"

#. Tag: para
#: index.docbook:3917
#, no-c-format
msgid ""
"Scrolls left and tries to show the previous label centered in the view. If "
"there was no label left from the current position, it will scroll to the "
"start of the signal."
msgstr ""
"Desplaza a la izquierda e intenta mostrar la etiqueta previa centrada en la "
"vista. Si no hay ninguna etiqueta a la izquierda de la posición actual, se "
"desplazará hasta el inicio de la señal."

#. Tag: link
#: index.docbook:3925
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_next_label;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_next_label;</command>()"

#. Tag: title
#: index.docbook:3931
#, no-c-format
msgid "&no-i18n-cmd_view_scroll_right;"
msgstr "&no-i18n-cmd_view_scroll_right;"

#. Tag: title
#: index.docbook:3933
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_right;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_right;</"
"command>()"

#. Tag: para
#: index.docbook:3934
#, no-c-format
msgid ""
"Scrolls the current view by 1/10 of the currently visible range towards the "
"end of the signal. If the end of the signal is reached the visible area ends "
"at the end of the signal."
msgstr ""
"Desplaza la vista actual un 1/10 del rango visible actual hacia el final de "
"la señal. Si se alcanza el final de la señal, el área visible finaliza al "
"final de la señal."

#. Tag: link
#: index.docbook:3942
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_left;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_left;</command>()"

#. Tag: title
#: index.docbook:3948
#, no-c-format
msgid "&no-i18n-cmd_view_scroll_start;"
msgstr "&no-i18n-cmd_view_scroll_start;"

#. Tag: title
#: index.docbook:3950
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_start;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_start;</"
"command>()"

#. Tag: para
#: index.docbook:3951
#, no-c-format
msgid "Scrolls the current view to the start of the signal."
msgstr "Desplaza la vista actual al inicio de la señal."

#. Tag: link
#: index.docbook:3955
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_end;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_view_scroll_end;</command>()"

#. Tag: title
#: index.docbook:3961
#, no-c-format
msgid "&no-i18n-cmd_view_zoom_all;"
msgstr "&no-i18n-cmd_view_zoom_all;"

#. Tag: title
#: index.docbook:3963
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_zoom_all;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_zoom_all;</"
"command>()"

#. Tag: para
#: index.docbook:3964
#, no-c-format
msgid ""
"Adjusts the zoom factor so that the complete signal is visible in the "
"current view."
msgstr ""
"Ajusta el factor de zum para hacer toda la señal visible en la vista actual."

#. Tag: title
#: index.docbook:3972
#, no-c-format
msgid "&no-i18n-cmd_view_zoom_in;"
msgstr "&no-i18n-cmd_view_zoom_in;"

#. Tag: title
#: index.docbook:3974
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_view_zoom_in;</"
"command>([<replaceable>position</replaceable>])"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_view_zoom_in;</"
"command>([<replaceable>posición</replaceable>])"

#. Tag: para
#: index.docbook:3975
#, no-c-format
msgid ""
"Reduces the zoom factor (in samples per pixel) by 30%, so that more details "
"get visible. If a <replaceable>position</replaceable> is given, it tries to "
"show that position centered in the current view, otherwise the center of the "
"view before the zoom change is used for centering. The minimum zoom factor "
"is limited to a minimum of five samples per width of the view."
msgstr ""
"Reduce el factor de zum (en muestras por píxel) en un 30 %, para hacer más "
"detalles visibles. Si se proporciona una <replaceable>posición</"
"replaceable>, intenta mostrar la posición centrada en la vista actual, en "
"caso contrario, el centro de la vista antes del cambio de zum se usará como "
"centro. El factor mínimo de zum está limitado a un mínimo de cinco muestras "
"por anchura de la vista."

#. Tag: entry
#: index.docbook:3987 index.docbook:4024
#, no-c-format
msgid "<parameter>position</parameter>:"
msgstr "<parameter>Posición</parameter>:"

#. Tag: entry
#: index.docbook:3988
#, no-c-format
msgid "a zero based position in samples to center the view (optional)"
msgstr ""
"Una posición basada en muestras y con origen en 0 para centrar la vista "
"(opcional)"

#. Tag: link
#: index.docbook:3992
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_view_zoom_out;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_view_zoom_out;</command>()"

#. Tag: title
#: index.docbook:3998
#, no-c-format
msgid "&no-i18n-cmd_view_zoom_normal;"
msgstr "&no-i18n-cmd_view_zoom_normal;"

#. Tag: title
#: index.docbook:4000
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_zoom_normal;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_zoom_normal;</"
"command>()"

#. Tag: para
#: index.docbook:4001
#, no-c-format
msgid ""
"Sets the zoom factor to one pixel per sample (factor 1.0) and tries to keep "
"the previous center of the view."
msgstr ""
"Establece el factor de zum a un pixel por muestra (factor 1.0) e intenta "
"mantener el centro previo de la vista."

#. Tag: title
#: index.docbook:4009
#, no-c-format
msgid "&no-i18n-cmd_view_zoom_out;"
msgstr "&no-i18n-cmd_view_zoom_out;"

#. Tag: title
#: index.docbook:4011
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_view_zoom_out;"
"([<replaceable>position</replaceable>])</command>"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_view_zoom_out;"
"([<replaceable>posición</replaceable>])</command>"

#. Tag: para
#: index.docbook:4012
#, no-c-format
msgid ""
"Increases the zoom factor (in samples per pixel) by 30%, so that less "
"details get visible. If a <replaceable>position</replaceable> is given, it "
"tries to show that position centered in the current view, otherwise the "
"center of the view before the zoom change is used for centering. The maximum "
"zoom factor is limited to the number of samples of the complete signal and "
"the width of the view."
msgstr ""
"Incrementa el factor de zum (en muestras por pixel) un 30 %, para hacer "
"menos detalles visibles. Si se proporciona una <replaceable>posición</"
"replaceable>, intenta mostrar la posición centrada en la vista actual, en "
"caso contrario, el centro de la vista antes del cambio de zum se usará como "
"centro. El factor máximo de zum está limitado a el número de muestras de la "
"señal completa y la anchura de la vista."

#. Tag: entry
#: index.docbook:4025
#, no-c-format
msgid "a zero based position is samples to center the view (optional)"
msgstr ""
"Una posición basada en muestras y con origen en 0 para centrar la vista "
"(opcional)"

#. Tag: link
#: index.docbook:4029
#, no-c-format
msgid "<command>&no-i18n-tag;&no-i18n-cmd_view_zoom_in;</command>()"
msgstr "<command>&no-i18n-tag;&no-i18n-cmd_view_zoom_in;</command>()"

#. Tag: title
#: index.docbook:4035
#, no-c-format
msgid "&no-i18n-cmd_view_zoom_selection;"
msgstr "&no-i18n-cmd_view_zoom_selection;"

#. Tag: title
#: index.docbook:4037
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_zoom_selection;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_view_zoom_selection;</"
"command>()"

#. Tag: para
#: index.docbook:4038
#, no-c-format
msgid ""
"Adjusts the view (zoom factor and start of visible area) so that it matches "
"the current selection. This command does nothing if the selection is empty."
msgstr ""
"Ajusta la vista (factor de zum e inicio del área visible) para que se "
"corresponda con la selección actual. Esta orden no hace nada si la selección "
"está vacía."

#. Tag: title
#: index.docbook:4047
#, no-c-format
msgid "&no-i18n-tag;w"
msgstr "&no-i18n-tag;w"

#. Tag: title
#: index.docbook:4050
#, no-c-format
msgid "&no-i18n-cmd_window_activate;"
msgstr "&no-i18n-cmd_window_activate;"

#. Tag: title
#: index.docbook:4052
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_activate;</"
"command>(<replaceable>title</replaceable>])"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_activate;</"
"command>(<replaceable>título</replaceable>])"

#. Tag: para
#: index.docbook:4053
#, no-c-format
msgid ""
"Activates a sub-window, identified by its window <replaceable>title</"
"replaceable>. If the sub-window is minimized it will be restored. Only "
"available if in MDI and Tab mode. This command is internally used by the "
"<guisubmenu>Window</guisubmenu> menu."
msgstr ""
"Activa una sub-ventana, identificada por su <replaceable>título</"
"replaceable>. Si la sub-ventana está minimizada, se restaurará. Solo "
"disponible en los modos MDI y Pestaña. Esta orden se usa internamente por el "
"menú <guisubmenu>Ventana</guisubmenu>."

#. Tag: entry
#: index.docbook:4061
#, no-c-format
msgid "<parameter>title</parameter>:"
msgstr "<parameter>título</parameter>:"

#. Tag: entry
#: index.docbook:4062
#, no-c-format
msgid "the title of the sub-window that should be activated"
msgstr "el título de la sub-ventana que debería ser activada"

#. Tag: title
#: index.docbook:4067
#, no-c-format
msgid "&no-i18n-cmd_window_cascade;"
msgstr "&no-i18n-cmd_window_cascade;"

#. Tag: title
#: index.docbook:4069
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_cascade;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_cascade;</"
"command>()"

# (filtered) msgid "&no-i18n-cmd_window_cascade;"
# (filtered) msgstr ""
# (filtered) msgid ""
# (filtered) "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_cascade;</"
# (filtered) "command>()"
# (filtered) msgstr ""
#. Tag: para
#: index.docbook:4070
#, no-c-format
msgid ""
"Cascades all sub-windows when in MDI mode. All sub-windows that are "
"currently minimized stay minimized, they will not be restored."
msgstr ""
"Muestra en cascada todas las sub-ventanas en el modo MDI. Todas las sub-"
"ventanas minimizadas permanecen minimizadas, no serán restauradas."

#. Tag: title
#: index.docbook:4078
#, no-c-format
msgid "&no-i18n-cmd_window_click;"
msgstr "&no-i18n-cmd_window_click;"

#. Tag: title
#: index.docbook:4080
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_click;</"
"command>( <replaceable>class</replaceable>, <replaceable>x</replaceable>, "
"<replaceable>y</replaceable> )"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_click;</"
"command>( <replaceable>clase</replaceable>, <replaceable>x</replaceable>, "
"<replaceable>y</replaceable> )"

#. Tag: para
#: index.docbook:4085
#, no-c-format
msgid ""
"Sends a mouse click event to window, identified by its <replaceable>class</"
"replaceable> name. The event will only be sent to the first window that has "
"the given class name, therefore you should make sure that you have only one "
"instance of the given window when this command gets executed."
msgstr ""
"Envía un evento de click de ratón en la ventana, identificada por su  nombre "
"de <replaceable>clase</replaceable>. El evento solo se enviará a la primera "
"ventana que tiene el nombre de clase especificado, por tanto, debe "
"asegurarse que tiene una sola instancia de la ventana especificada cuando "
"esta orden se ejecuta."

#. Tag: entry
#: index.docbook:4095 index.docbook:4119 index.docbook:4153 index.docbook:4204
#: index.docbook:4232 index.docbook:4257
#, no-c-format
msgid "<parameter>class</parameter>:"
msgstr "<parameter>clase</parameter>:"

#. Tag: entry
#: index.docbook:4096 index.docbook:4120 index.docbook:4154 index.docbook:4205
#: index.docbook:4233 index.docbook:4258
#, no-c-format
msgid "name of the window class"
msgstr "nombre de la clase de ventana"

#. Tag: entry
#: index.docbook:4097 index.docbook:4155
#, no-c-format
msgid "<parameter>x</parameter>:"
msgstr "<parameter>x</parameter>:"

#. Tag: entry
#: index.docbook:4098 index.docbook:4156
#, no-c-format
msgid "x position, relative to the left border of the window (in pixels)"
msgstr "posición x, relativa al borde izquierdo de la ventana (en píxeles)"

#. Tag: entry
#: index.docbook:4099 index.docbook:4157
#, no-c-format
msgid "<parameter>y</parameter>:"
msgstr "<parameter>y</parameter>:"

#. Tag: entry
#: index.docbook:4100 index.docbook:4158
#, no-c-format
msgid "y position, relative to the top border of the window (in pixels)"
msgstr "posición y, relativa al borde superior de la ventana (en píxeles)"

#. Tag: title
#: index.docbook:4105
#, no-c-format
msgid "&no-i18n-cmd_window_close;"
msgstr "&no-i18n-cmd_window_close;"

#. Tag: title
#: index.docbook:4107
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_close;</"
"command>( <replaceable>class</replaceable> )"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_close;</"
"command>( <replaceable>clase</replaceable> )"

#. Tag: para
#: index.docbook:4110
#, no-c-format
msgid ""
"Closes a window, identified by its <replaceable>class</replaceable> name. "
"Only the first window that has the given class name will be closed, "
"therefore you should make sure that you have only one instance of the given "
"window when this command gets executed."
msgstr ""
"Cierra una ventana, identificada por su nombre de <replaceable>clase</"
"replaceable>. Solo la primera ventana que tiene el nombre de clase "
"especificado se cerrará, por tanto, debe asegurarse que tiene una sola "
"instancia de la ventana especificada cuando esta orden se ejecuta."

#. Tag: title
#: index.docbook:4125
#, no-c-format
msgid "&no-i18n-cmd_window_minimize;"
msgstr "&no-i18n-cmd_window_minimize;"

#. Tag: title
#: index.docbook:4127
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-cmd_window_minimize;</command>"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-cmd_window_minimize;</command>"

#. Tag: para
#: index.docbook:4128
#, no-c-format
msgid ""
"Minimizes the currently active sub-window when in MDI mode or the current "
"toplevel window when in SDI or Tab mode."
msgstr ""
"Minimiza la sub-ventana activa actual cuando el modo MDI o la ventana actual "
"de mayor nivel en los modos SDI o pestaña."

#. Tag: title
#: index.docbook:4136
#, no-c-format
msgid "&no-i18n-cmd_window_mousemove;"
msgstr "&no-i18n-cmd_window_mousemove;"

#. Tag: title
#: index.docbook:4138
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_resize;</"
"command>( <replaceable>class</replaceable>, <replaceable>x</replaceable>, "
"<replaceable>y</replaceable> )"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_resize;</"
"command>( <replaceable>clase</replaceable>, <replaceable>x</replaceable>, "
"<replaceable>y</replaceable> )"

#. Tag: para
#: index.docbook:4143
#, no-c-format
msgid ""
"Sends a mouse move event to window, identified by its <replaceable>class</"
"replaceable> name. The event will only be sent to the first window that has "
"the given class name, therefore you should make sure that you have only one "
"instance of the given window when this command gets executed."
msgstr ""
"Envía un evento de movimiento de ratón a la ventana, identificada por su "
"nombre de <replaceable>clase</replaceable>. El evento solo se enviará a la "
"primera ventana que tiene el nombre de clase especificado, por tanto, debe "
"asegurarse que tiene una sola instancia de la ventana especificada cuando "
"esta orden se ejecuta."

#. Tag: title
#: index.docbook:4163
#, no-c-format
msgid "&no-i18n-cmd_window_next_sub;"
msgstr "&no-i18n-cmd_window_next_sub;"

#. Tag: title
#: index.docbook:4165
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_next_sub;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_next_sub;</"
"command>()"

# (filtered) msgid "&no-i18n-cmd_window_next_sub;"
# (filtered) msgstr ""
# (filtered) msgid ""
# (filtered) "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_next_sub;</"
# (filtered) "command>()"
# (filtered) msgstr ""
#. Tag: para
#: index.docbook:4166
#, no-c-format
msgid ""
"Activates the <emphasis>next</emphasis> sub-window when in MDI or Tab mode. "
"If the next sub-window is minimized it will be restored."
msgstr ""
"Activa la sub-ventana <emphasis>siguiente</emphasis> cuando está "
"seleccionado el modo MDI o Pestaña. Si la sub-ventana siguiente está "
"minimizada, se restaurará."

#. Tag: title
#: index.docbook:4174
#, no-c-format
msgid "&no-i18n-cmd_window_prev_sub;"
msgstr "&no-i18n-cmd_window_prev_sub;"

#. Tag: title
#: index.docbook:4176
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_prev_sub;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_prev_sub;</"
"command>()"

# (filtered) msgid "&no-i18n-cmd_window_prev_sub;"
# (filtered) msgstr ""
# (filtered) msgid ""
# (filtered) "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_prev_sub;</"
# (filtered) "command>()"
# (filtered) msgstr ""
#. Tag: para
#: index.docbook:4177
#, no-c-format
msgid ""
"Activates the <emphasis>previous</emphasis> sub-window when in MDI or Tab "
"mode. If the previous sub-window is minimized it will be restored."
msgstr ""
"Activa la sub-ventana <emphasis>previa</emphasis> cuando está seleccionado "
"el modo MDI o Pestaña. Si la sub-ventana previa está minimizada, se "
"restaurará."

#. Tag: title
#: index.docbook:4185
#, no-c-format
msgid "&no-i18n-cmd_window_resize;"
msgstr "&no-i18n-cmd_window_resize;"

#. Tag: title
#: index.docbook:4187
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_resize;</"
"command>( <replaceable>class</replaceable>, <replaceable>width</"
"replaceable>, <replaceable>height</replaceable> )"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_resize;</"
"command>( <replaceable>clase</replaceable>, <replaceable>ancho</"
"replaceable>, <replaceable>alto</replaceable> )"

#. Tag: para
#: index.docbook:4192
#, no-c-format
msgid ""
"Changes the size of a window, identified by its <replaceable>class</"
"replaceable> name to a new <replaceable>width</replaceable> and "
"<replaceable>height</replaceable>. The change will only be applied to the "
"first window that has the given class name, therefore you should make sure "
"that you have only one instance of the given window when this command gets "
"executed."
msgstr ""
"Cambia el tamaño de una ventana, identificada por su nombre de "
"<replaceable>clase</replaceable> a un nueva <replaceable>anchura</"
"replaceable> y <replaceable>altura</replaceable>. El cambio solo aplicará a "
"la primera ventana que tenga el nombre de la clase especificado, por tanto "
"debe asegurarse que tiene una sola instancia de la ventana especificada "
"cuando esta orden se ejecuta."

#. Tag: entry
#: index.docbook:4206
#, no-c-format
msgid "<parameter>width</parameter>:"
msgstr "<parameter>ancho</parameter>:"

#. Tag: entry
#: index.docbook:4207
#, no-c-format
msgid "new width of the window (in pixels)"
msgstr "nueva anchura de la ventana (en píxeles)"

#. Tag: entry
#: index.docbook:4208
#, no-c-format
msgid "<parameter>height</parameter>:"
msgstr "<parameter>alto</parameter>:"

#. Tag: entry
#: index.docbook:4209
#, no-c-format
msgid "new height of the window (in pixels)"
msgstr "nueva altura de la ventana (en píxeles)"

#. Tag: title
#: index.docbook:4214
#, no-c-format
msgid "&no-i18n-cmd_window_screenshot;"
msgstr "&no-i18n-cmd_window_screenshot;"

#. Tag: title
#: index.docbook:4216
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_screenshot;</"
"command>( <replaceable>class</replaceable>, <replaceable>filename</"
"replaceable> )"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_screenshot;</"
"command>( <replaceable>clase</replaceable>, <replaceable>nombre de archivo</"
"replaceable> )"

#. Tag: para
#: index.docbook:4220
#, no-c-format
msgid ""
"Takes a screenshot of a window, identified by its <replaceable>class</"
"replaceable> and saves it to a file. The screenshot will be taken from the "
"first window that has the given class name, therefore you should make sure "
"that you have only one instance of the given window when this command gets "
"executed. Currently the format of the file is hardcoded and has to be "
"<literal>*.png</literal>."
msgstr ""
"Toma una captura de pantalla de la ventana,  identificada por su  nombre de "
"<replaceable>clase</replaceable> y la guarda en un archivo. La captura de "
"pantalla solo se tomará de la primera ventana que tiene el nombre de clase "
"especificado, por tanto, debe asegurarse que tiene una sola instancia de la "
"ventana especificada cuando esta orden se ejecuta. El formato actual del "
"archivo es fijo y tiene que ser <literal>*.png</literal>."

#. Tag: entry
#: index.docbook:4235
#, no-c-format
msgid ""
"name of the file to save the screenshot, must have the extension <literal>*."
"png</literal>"
msgstr ""
"nombre del archivo en el que guardar la captura de pantalla, debe tener la "
"extensión <literal>*.png</literal>"

#. Tag: title
#: index.docbook:4241
#, no-c-format
msgid "&no-i18n-cmd_window_sendkey;"
msgstr "&no-i18n-cmd_window_sendkey;"

#. Tag: title
#: index.docbook:4243
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_sendkey;</"
"command>( <replaceable>class</replaceable>, <replaceable>key code</"
"replaceable> )"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_sendkey;</"
"command>( <replaceable>clase</replaceable>, <replaceable>clave</"
"replaceable> )"

#. Tag: para
#: index.docbook:4247
#, no-c-format
msgid ""
"Sends a key press and release event to a window, identified by its "
"<replaceable>class</replaceable> name. The key will only be sent to the "
"first window that has the given class name, therefore you should make sure "
"that you have only one instance of the given window when this command gets "
"executed."
msgstr ""
"Envía un evento de pulsación y liberación de tecla a la ventana, "
"identificada por su  nombre de <replaceable>clase</replaceable>. La tecla "
"solo se enviará a la primera ventana que tiene el nombre de clase "
"especificado, por tanto, debe asegurarse que tiene una sola instancia de la "
"ventana especificada cuando esta orden se ejecuta."

#. Tag: entry
#: index.docbook:4259
#, no-c-format
msgid "<parameter>key code</parameter>:"
msgstr "<parameter>clave</parameter>:"

#. Tag: entry
#: index.docbook:4260
#, no-c-format
msgid ""
"the key code that should be sent, using the same syntax as used for setting "
"up menus"
msgstr ""
"la clave que debería ser enviada, usando la misma sintaxis usada para "
"instalar los menús"

#. Tag: para
#: index.docbook:4264
#, no-c-format
msgid ""
"Description of the parameter <link linkend=\"cmd_menu_param_hotkey"
"\"><parameter>hotkey</parameter></link> of the <command>&no-i18n-cmd_menu;</"
"command>() command."
msgstr ""
"descripción del parámetro <link linkend=\"cmd_menu_param_hotkey"
"\"><parameter>atajo de teclado</parameter></link> de la orden <command>&no-"
"i18n-cmd_menu;</command>()."

#. Tag: title
#: index.docbook:4273
#, no-c-format
msgid "&no-i18n-cmd_window_tile;"
msgstr "&no-i18n-cmd_window_tile;"

#. Tag: title
#: index.docbook:4275
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_tile;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_tile;</command>()"

# (filtered) msgid "&no-i18n-cmd_window_tile;"
# (filtered) msgstr ""
# (filtered) msgid ""
# (filtered) "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_tile;</command>()"
# (filtered) msgstr ""
#. Tag: para
#: index.docbook:4276
#, no-c-format
msgid ""
"Tiles all sub-windows when in MDI mode, using some scheme of &plasma;. All "
"sub-windows that are currently minimized stay minimized, they will not be "
"restored."
msgstr ""
"Crea un mosaico con todas las sub-ventanas en modo MDI, usando algún esquema "
"de &plasma;. Todas las sub-ventanas que están minimizadas permanecen "
"minimizadas, no serán restauradas."

#. Tag: title
#: index.docbook:4285
#, no-c-format
msgid "&no-i18n-cmd_window_tile_vertical;"
msgstr "&no-i18n-cmd_window_tile_vertical;"

#. Tag: title
#: index.docbook:4287
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_tile_vertical;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_tile_vertical;</"
"command>()"

# (filtered) msgid "&no-i18n-cmd_window_tile_vertical;"
# (filtered) msgstr ""
#. Tag: para
#: index.docbook:4288
#, no-c-format
msgid ""
"Tiles all sub-windows vertically when in MDI mode. All windows that are "
"currently minimized stay minimized, they will not be restored."
msgstr ""
"Crea un mosaico vertical con todas las sub-ventanas en modo MDI. Todas las "
"sub-ventanas que están minimizadas permanecen minimizadas, no serán "
"restauradas."

