msgstr "El menú Juego"

#. Tag: menuchoice
#: index.docbook:101
#, no-c-format
msgid "<guimenu>Game</guimenu><guimenuitem>Show Event Log…</guimenuitem>"
msgstr ""
"<guimenu>Juego</guimenu><guimenuitem>Mostrar registro de eventos…</"
"guimenuitem>"

#. Tag: para
#: index.docbook:103
#, no-c-format
msgid "<action>Display</action> the event log window."
msgstr "<action>Muestra</action> la ventana del registro de eventos."

#. Tag: menuchoice
#: index.docbook:107
#, no-c-format
msgid ""
"<guimenu>Game</guimenu><guimenuitem>Reconnect (After Crash)</guimenuitem>"
msgstr ""
"<guimenu>Juego</guimenu><guimenuitem>Reconectar (tras un fallo)</guimenuitem>"

#. Tag: para
#: index.docbook:109
#, no-c-format
msgid ""
"<action>Reconnect</action> to the last game. This is available only in case "
"&atlantik; did not quit cleanly from a game (usually because it crashed), "
"and cannot be done anymore once you connect to a server."
msgstr ""
"<action>Reconectarse</action> a la última partida. Esto solo estará "
"disponible en el caso de que &atlantik; no haya salido limpiamente de una "
"partida (por lo general, debido a un fallo de la aplicación), y ya no se "
"puede hacer una vez que te conectes a un servidor."

