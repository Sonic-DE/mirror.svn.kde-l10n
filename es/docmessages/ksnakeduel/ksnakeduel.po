msgstr "<phrase>Configuración de temas</phrase>"

#. Tag: para
#: index.docbook:546
#, no-c-format
msgid "This page will allow you to change the theme &ksnakeduel; uses."
msgstr "Esta página te permite cambiar el tema que usa &ksnakeduel;."

