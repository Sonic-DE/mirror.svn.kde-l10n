#. Tag: para
#: index.docbook:17
#, no-c-format
msgid ""
"The <emphasis>file</emphasis> protocol is used by all &kde; applications to "
"display locally available files."
msgstr ""
"El protocolo de <emphasis>archivo</emphasis> se utiliza por todas las "
"aplicaciones de &kde; para mostrar archivos disponibles localmente."

#. Tag: para
#: index.docbook:21
#, no-c-format
msgid ""
"Entering <userinput><command>file:/directoryname</command></userinput> in "
"&konqueror; lists the files of this folder."
msgstr ""
"Introduciendo <userinput><command>file:/nombrededirectorio</command></"
"userinput> en &konqueror; se muestran los archivos de esta carpeta."
