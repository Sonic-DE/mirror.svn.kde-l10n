msgstr "<action>Abre un ejemplo</action> del conjunto predeterminado."

#. Tag: guimenuitem
#: examples.docbook:19
#, no-c-format
msgid "Open Downloaded Example..."
msgstr "Abrir ejemplo descargado…"

#. Tag: action
#: examples.docbook:20
#, no-c-format
msgid "Opens the downloaded examples."
msgstr "Abre los ejemplos descargados."

#. Tag: guimenuitem
#: examples.docbook:23
#, no-c-format
msgid "Download New Experiments..."
msgstr "Descargar nuevos experimentos…"

#. Tag: para
#: examples.docbook:24
#, no-c-format
msgid "<action>Download examples</action> shared by other users."
msgstr "<action>Descarga ejemplos</action> compartidos por otros usuarios."

