#, no-c-format
msgid "Simple source metrics for C and C++"
msgstr "Una aplicación estadística sencilla para archivos de código C o C++."

#. Tag: cmdsynopsis
#: man-cxxmetric.1.docbook:24
#, no-c-format
msgid ""
"<command>cxxmetric</command> <group><option><replaceable>file</replaceable></"
"option></group>"
msgstr ""
"<command>cxxmetric</command> <group><option><replaceable>archivo</"
"replaceable></option></group>"

#. Tag: title
#: man-cxxmetric.1.docbook:33
#, no-c-format
msgid "Description"
msgstr "Descripción"

#. Tag: para
#: man-cxxmetric.1.docbook:35
#, no-c-format
msgid ""
"cxxmetric counts lines of code, comment and blank space and calculates "
"various other statistics for each given source file. Source files must be in "
"C or C++."
msgstr ""
"cxxmetric contabiliza lineas de código, comentarios y espacios en blanco y "
"calculan varias estadísticas para cada una de los archivos de código. Dichos "
"archivos deben estar escritos en C o C++."

#. Tag: para
#: man-cxxmetric.1.docbook:39
#, no-c-format
msgid "This utility is part of the KDE Software Development Kit."
msgstr "Esta aplicación fomra parte del kit de desarrollo de KDE."
