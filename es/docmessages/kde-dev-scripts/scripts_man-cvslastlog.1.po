#. Tag: refpurpose
#: man-cvslastlog.1.docbook:20
#, no-c-format
msgid "Prints the log entry for the last commit for a file."
msgstr ""
"Imprime la entrega del registro de la última modificación de un determinado "
"archivo."

#. Tag: cmdsynopsis
#: man-cvslastlog.1.docbook:24
#, no-c-format
msgid ""
"<command>cvslastlog</command> <group><option><replaceable>filename</"
"replaceable></option></group>"
msgstr ""
"<command>cvslastlog</command> <group><option><replaceable>archivo</"
"replaceable></option></group>"

#. Tag: title
#: man-cvslastlog.1.docbook:32
#, no-c-format
msgid "Description"
msgstr "Descripción"

#. Tag: para
#: man-cvslastlog.1.docbook:34
#, no-c-format
msgid ""
"<command>cvslastlog</command> shows the log associated with the last CVS "
"commit for the given file. It depends on the version of the local file, not "
"the one on the server."
msgstr ""
"<command>cvslastlog</command> muestra el registro asociado con la última "
"entrega al CVS para un determinado archivo. Depende de la versión del "
"archivo local, no de la del servidor."

#. Tag: para
#: man-cvslastlog.1.docbook:38
