#. Tag: refpurpose
#: man-cvslastchange.1.docbook:22
#, no-c-format
msgid "Display the last change committed to &CVS; for a file"
msgstr ""
"Muestra los últimos cambios de un determinado archivo entregados al &CVS;."

#. Tag: cmdsynopsis
#: man-cvslastchange.1.docbook:26
#, no-c-format
msgid "&cvslastchange; <group><replaceable>file</replaceable></group>"
msgstr "&cvslastchange; <group><replaceable>archivo</replaceable></group>"

#. Tag: title
#: man-cvslastchange.1.docbook:33
#, no-c-format
msgid "Description"
msgstr "Descripción"

#. Tag: para
#: man-cvslastchange.1.docbook:35
#, no-c-format
msgid ""
"&cvslastchange; displays the last change committed to &CVS; for a file. It "
"uses <command>cvs diff</command> and <command>cvs log</command> to do this."
msgstr ""
"&cvslastchange; muestra el último cambio de un determinado archivo entregado "
"al &CVS;. Emplea el comando <command>cvs diff</command> y <command>cvs log</"
"command>."

#. Tag: para
#: man-cvslastchange.1.docbook:39
#, no-c-format
msgid "&cvslastchange; works on any &CVS; branch, not just HEAD."
msgstr "&cvslastchange; trabaja en cualquier rama del &CVS;, no solo en HEAD."

#. Tag: para
#: man-cvslastchange.1.docbook:41
#, no-c-format
msgid "This utility is part of the &kde; Software Development Kit."
msgstr "Esta herramienta forma parte del kit de desarrollo de &kde;."

