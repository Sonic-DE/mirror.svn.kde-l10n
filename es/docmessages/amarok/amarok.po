msgid "KDE Global Shortcuts"
msgstr "Accesos rápidos globales de KDE"

#. Tag: para
#: index.docbook:7924
#, no-c-format
msgid ""
"<emphasis>Global Shortcuts</emphasis> are KDE's control key combinations. "
"Use them to control &amarok; from the keyboard as an alternative to using "
"the mouse."
msgstr ""
"Los <emphasis>Accesos rápidos globales</emphasis> son combinaciones de "
"teclas de control de KDE. Úselos para controlar &amarok; desde el teclado "
"como una alternativa al ratón."

