#. Tag: title
#: diskusage.docbook:8
#, no-c-format
msgid "<title>Disk Usage</title>"
msgstr "<title>Uso del disco</title>"

#. Tag: primary
#: diskusage.docbook:10
#, no-c-format
msgid "<primary>Disk Usage</primary>"
msgstr "<primary>Uso del disco</primary>"

#. Tag: para
#: diskusage.docbook:12
#, no-c-format
msgid ""
"The Disk Usage is based on the code of &filelight;. The Disk Usage shows you "
"how your disk space is being used by a graphical representation of your file "
"system. The following presentations are possible:"
msgstr ""
"El uso del disco se basa en el código de &filelight;. El uso del disco "
"muestra cómo se usa el espacio del disco mediante una representación gráfica "
"del sistema de archivos. Están disponibles las siguientes representaciones:"

#. Tag: para
#: diskusage.docbook:18
#, no-c-format
msgid "Line view"
msgstr "Vista de líneas"

#. Tag: para
#: diskusage.docbook:21
#, no-c-format
msgid "Detailed view"
msgstr "Vista detallada"

#. Tag: para
#: diskusage.docbook:24
#, no-c-format
msgid ""
"<application>Filelight</application> view: as a set of concentric segmented-"
"rings"
msgstr ""
"Vista de <application>Filelight</application>: como un conjunto de segmentos "
"anulares concéntricos"

#. Tag: para
#: diskusage.docbook:28
#, no-c-format
msgid ""
"Choose <menuchoice> <guimenu>Tools</guimenu> <guimenuitem>Disk Usage...</"
"guimenuitem> </menuchoice> or <keycombo action=\"simul\">&Alt;&Shift; "
"<keycap>S</keycap></keycombo> to start this feature in a separate window, or "
"open it inside the <link linkend=\"sidebar\">Sidebar</link>."
msgstr ""
"Elija <menuchoice> <guimenu>Herramientas</guimenu> <guimenuitem>Uso del "
"disco…</guimenuitem> </menuchoice> o <keycombo action=\"simul\">&Alt;&Shift; "
"<keycap>S</keycap></keycombo> para iniciar esta función en una ventana "
"independiente, o ábrala dentro de de la <link linkend=\"sidebar\">barra "
"lateral</link>."

#. Tag: para
#: diskusage.docbook:38
#, no-c-format
msgid "Disk Usage Keybindings, right click menu."
msgstr "Asignaciones de teclas para el uso del disco, menú del botón derecho."

#. Tag: para
#: diskusage.docbook:41
#, no-c-format
msgid "<keycap>Del</keycap>: Delete"
msgstr "<keycap>Supr</keycap>: Borrar"

#. Tag: para
#: diskusage.docbook:45
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Ctrl; <keycap>E</keycap></keycombo>: Exclude"
msgstr ""
"<keycombo action=\"simul\">&Ctrl; <keycap>E</keycap></keycombo>: Excluir"

#. Tag: para
#: diskusage.docbook:50
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Shift; <keycap>Arrow Up</keycap></keycombo>: Up "
"one folder"
msgstr ""
"<keycombo action=\"simul\">&Shift; <keycap>Flecha arriba</keycap></"
"keycombo>: Subir una carpeta"

#. Tag: para
#: diskusage.docbook:55
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Ctrl; <keycap>N</keycap></keycombo>: new search"
msgstr ""
"<keycombo action=\"simul\">&Ctrl; <keycap>N</keycap></keycombo>: Nueva "
"búsqueda"

#. Tag: para
#: diskusage.docbook:60
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Ctrl; <keycap>R</keycap></keycombo>: refresh"
msgstr ""
"<keycombo action=\"simul\">&Ctrl; <keycap>R</keycap></keycombo>: Refrescar"

#. Tag: para
#: diskusage.docbook:65
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Ctrl; <keycap>I</keycap></keycombo>: include all"
msgstr ""
"<keycombo action=\"simul\">&Ctrl; <keycap>I</keycap></keycombo>: incluir todo"

#. Tag: para
#: diskusage.docbook:70
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Shift; <keycap>Arrow Down</keycap></keycombo>: "
"step into"
msgstr ""
"<keycombo action=\"simul\">&Shift; <keycap>Flecha abajo</keycap></keycombo>: "
"entrar"

#. Tag: para
#: diskusage.docbook:75
#, no-c-format
msgid "View menu:"
msgstr "Menú vista:"

#. Tag: para
#: diskusage.docbook:78
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Ctrl; <keycap>L</keycap></keycombo>: Line view"
msgstr ""
"<keycombo action=\"simul\">&Ctrl; <keycap>L</keycap></keycombo>: Vista de "
"líneas"

#. Tag: para
#: diskusage.docbook:83
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Ctrl; <keycap>D</keycap></keycombo>: Detailed "
"view"
msgstr ""
"<keycombo action=\"simul\">&Ctrl; <keycap>D</keycap></keycombo>: Vista "
"detallada"

#. Tag: para
#: diskusage.docbook:88
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Ctrl; <keycap>F</keycap></keycombo>: Filelight "
"view"
msgstr ""
"<keycombo action=\"simul\">&Ctrl; <keycap>F</keycap></keycombo>: Vista de "
"Filelight"

#. Tag: para
#: diskusage.docbook:93
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Shift; <keycap>Arrow Right</keycap></keycombo>: "
"Next view"
msgstr ""
"<keycombo action=\"simul\">&Shift; <keycap>Flecha derecha</keycap></"
"keycombo>: Vista siguiente"

#. Tag: para
#: diskusage.docbook:98
#, no-c-format
msgid ""
"<keycombo action=\"simul\">&Shift; <keycap>Arrow Left</keycap></keycombo>: "
"Previous view"
msgstr ""
"<keycombo action=\"simul\">&Shift; <keycap>Flecha izquierda</keycap></"
"keycombo>: Vista anterior"
