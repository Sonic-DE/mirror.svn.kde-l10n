msgid "<command>/exec </command> <replaceable>media amarok</replaceable>"
msgstr "<command>/exec </command> <replaceable>media amarok</replaceable>"

#. Tag: para
#: index.docbook:2671
#, no-c-format
msgid ""
"Sample output: <replaceable>* user is listening to You Give Love A Bad Name "
