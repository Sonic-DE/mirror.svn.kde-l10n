#. Tag: userinput
#: index.docbook:2626
#, no-c-format
msgid ""
"<command>/exec </command> <replaceable>cmd</replaceable> "
"[<replaceable>command line arguments</replaceable>]"
msgstr ""
"<command>/exec </command> <replaceable>cmd</replaceable> "
"[<replaceable>argumentos de linea de ordenes</replaceable>]"

#. Tag: para
#: index.docbook:2629
#, no-c-format
msgid ""
"This script is used to have the output of the command line arguments to be "
"written to your current channel."
msgstr ""
"Este script se utiliza para hacer que la salida de los argumentos de línea "
"de ordenes se escriban en su canal actual."

#. Tag: para
#: index.docbook:2630
#, no-c-format
msgid ""
"Example: To show everyone in your current channel what version of "
"&konversation; you have installed."
msgstr ""
"Ejemplo: Mostrar a todos los presentes en su canal actual que versión de "
"&konversation; tiene instalada."

#. Tag: userinput
#: index.docbook:2631
#, no-c-format
msgid ""
"<command>/exec </command> <replaceable>cmd konversation --version</"
"replaceable>"
msgstr ""
"<command>/exec </command> <replaceable>cmd konversation --version</"
"replaceable>"

#. Tag: para
#: index.docbook:2632
#, no-c-format
msgid "Sample output: <replaceable>Konversation: 1.6</replaceable>"
msgstr "Salida de ejemplo: <replaceable>Konversation: 1.6</replaceable>"

#. Tag: para
#: index.docbook:2633
#, no-c-format
msgid ""
"WARNING! The output of the entire command is posted to everyone in the "
"current channel tab! Please use with care."
msgstr ""
"¡ADVERTENCIA! ¡La salida de la orden completa se publicará a todos los "
"miembros del canal de la pestaña actual! Utilícelo con cuidado."

#. Tag: userinput
#: index.docbook:2638 index.docbook:2643
#, no-c-format
msgid "<command>/exec </command> <replaceable>fortune</replaceable>"
msgstr "<command>/exec </command> <replaceable>fortune</replaceable>"

#. Tag: para
#: index.docbook:2641
#, no-c-format
msgid "This script when run will output a Random Fortune."
msgstr "Cuando ejecute este script mostrará un proverbio aleatorio."

#. Tag: para
#: index.docbook:2642
#, no-c-format
msgid "Example: To output a random fortune to your current channel tab."
msgstr ""
"Ejemplo: Mostrar un proverbio aleatorio en el canal de la pestaña activa."

#. Tag: para
#: index.docbook:2644
#, no-c-format
msgid ""
"Sample output: <replaceable>Random Fortune: Never make any mistaeks. -- "
