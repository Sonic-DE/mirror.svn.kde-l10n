"un error del kernel</replaceable>"

#. Tag: userinput
#: index.docbook:2650
#, no-c-format
msgid ""
"<command>/exec </command> <replaceable>gauge</replaceable> "
"[<replaceable>percentage</replaceable>]"
msgstr ""
"<command>/exec </command> <replaceable>gauge</replaceable> "
"[<replaceable>porcentaje</replaceable>]"

#. Tag: para
#: index.docbook:2653
#, no-c-format
msgid ""
"This script shows a simple text based progress bar for the given percentage."
msgstr ""
"Este script muestra una barra de progreso basada en texto sin formato para "
"el porcentaje indicado."

#. Tag: para
#: index.docbook:2654
#, no-c-format
msgid ""
"Example: To output a progress bar with 50% completion to the current channel "
