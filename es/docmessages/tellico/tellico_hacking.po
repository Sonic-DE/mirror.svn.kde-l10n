msgstr "Max Icon Size=128"

#. Tag: title
#: hacking.docbook:238
#, no-c-format
msgid "Icon Cache Size"
msgstr "Tamaño de la caché de iconos"

#. Tag: para
#: hacking.docbook:240
#, no-c-format
msgid ""
"The maximum numbers of icons cached in memory may be changed with this "
"setting. The default value is 1000."
msgstr ""
"El número máximo de iconos almacenados en la memoria se puede cambiar "
"mediante este ajuste. El valor por defecto es 1000."

#. Tag: userinput
#: hacking.docbook:248
#, no-c-format
msgid "Icon Cache Size=100"
msgstr "Icon Cache Size=100"

#. Tag: title
#: hacking.docbook:253
#, no-c-format
msgid "Image Cache Size"
msgstr "Tamaño de la caché de imágenes"

#. Tag: para
#: hacking.docbook:255
#, no-c-format
msgid ""
"The maximum amount of memory in bytes used for caching all the images may be "
"changed with this setting. The default value is 512 MiB."
msgstr ""
"La cantidad máxima de memoria en bytes usada para almacenar todas las "
"imágenes se puede cambiar con este ajuste. El valor por defecto es 512 MiB."

#. Tag: userinput
#: hacking.docbook:263
#, no-c-format
msgid "Image Cache Size=256000000"
msgstr "Image Cache Size=256000000"

