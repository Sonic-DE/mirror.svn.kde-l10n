msgid "Procedure to edit layout:"
msgstr "Procedimiento para editar el diseño:"

#. Tag: para
#: index.docbook:303
#, no-c-format
msgid ""
"Use the board editor toolbar to create a new layout or to load and edit an "
"existing one."
msgstr ""
"Usa la barra de herramientas del editor del tablero para crear un nuevo "
"diseño o para cargar y modificar uno existente."

#. Tag: para
#: index.docbook:304
#, no-c-format
msgid ""
"Save the layout in your user's local home folder in <filename>"
"$<envar>XDG_DATA_HOME</envar>/kmahjongg/layouts</filename>"
msgstr ""
"Guarda el diseño en tu carpeta personal local <filename>"
"$<envar>XDG_DATA_HOME</envar>/kmahjongg/layouts</filename>"

#. Tag: para
#: index.docbook:305
#, no-c-format
msgid ""
"Create the <filename><replaceable>name_of_your_layout</replaceable>.desktop</"
"filename> file in the same folder."
msgstr ""
"Crea el archivo <filename><replaceable>nombre_del_diseño</replaceable>."
"desktop</filename> en la misma carpeta."

#. Tag: para
#: index.docbook:306
#, no-c-format
msgid "Put the following lines in this file using your favorite text editor:"
msgstr ""
"Escribe las siguientes líneas en dicho archivo usado tu editor de texto "
"favorito:"

#. Tag: programlisting
#: index.docbook:307
#, no-c-format
msgid ""
"[KMahjonggLayout]\n"
"Name=<replaceable>name_of_your_layout</replaceable>\n"
"Description=<replaceable>description_of_your_layout</replaceable>\n"
"VersionFormat=1\n"
"Author=<replaceable>your_name</replaceable>\n"
"AuthorEmail=<replaceable>your_email</replaceable>\n"
"FileName=<replaceable>name_of_your_layout</replaceable>.layout"
msgstr ""
"[KMahjonggLayout]\n"
"Name=<replaceable>nombre_del_diseño</replaceable>\n"
"Description=<replaceable>descripción_del_diseño</replaceable>\n"
"VersionFormat=1\n"
"Author=<replaceable>tu_nombre</replaceable>\n"
"AuthorEmail=<replaceable>tu_email</replaceable>\n"
"FileName=<replaceable>nombre_dedel_diseño</replaceable>.layout"

#. Tag: para
