#: index.docbook:415
#, no-c-format
msgid "<phrase>Configure Dialog</phrase>"
msgstr "<phrase>Diálogo de configuración</phrase>"

#. Tag: para
#: index.docbook:420
#, no-c-format
msgid ""
"<menuchoice><guimenu>Settings</guimenu><guimenuitem>Configure &kmahjongg;…</"
"guimenuitem></menuchoice> opens the <guilabel>Configure - &kmahjongg;</"
"guilabel> dialog."
msgstr ""
"<menuchoice><guimenu>Preferencias</guimenu><guimenuitem>Configurar "
"&kmahjongg;…</guimenuitem></menuchoice> abre el diálogo <guilabel>Configurar "
"&kmahjongg;</guilabel>."

#. Tag: title
#: index.docbook:422
#, no-c-format
msgid "General options"
msgstr "Opciones generales"

#. Tag: guilabel
#: index.docbook:425
#, no-c-format
msgid "Blink matching tiles when first one is selected"
msgstr "Hacer que parpadeen las fichas coincidentes al seleccionar una"

#. Tag: para
#: index.docbook:426
#, no-c-format
msgid ""
"This setting will make the game highlight the selected tile on mouse click, "
"and flash any matching tiles that have a free side at each move. No "
"additional tiles will be highlighted if there are no matching tiles with a "
"free side."
msgstr ""
"Esta opción hace que se resalte la ficha seleccionada con el ratón, y que "
"parpadee cualquier ficha coincidente que tenga una cara libre. No se "
"resaltarán las fichas que no tengan una ficha libre."

#. Tag: guilabel
#: index.docbook:431
#, no-c-format
msgid "Generate solvable games"
msgstr "Generar juegos con solución"

#. Tag: para
#: index.docbook:432
#, no-c-format
msgid "Selects only games that can be solved when you start a new game."
msgstr ""
"Selecciona solo juegos que se puedan resolver cuando inicies una nueva "
"partida."

#. Tag: guilabel
#: index.docbook:437
#, no-c-format
msgid "Show removed tiles"
msgstr "Mostrar las fichas eliminadas"

#. Tag: para
#: index.docbook:438
#, no-c-format
msgid ""
"If checked, this setting allows &kmahjongg; to show the removed tiles on the "
"board."
msgstr ""
"Si está marcado, este ajuste permite que &kmahjongg; muestre las fichas "
"eliminadas del tablero."

#. Tag: title
#: index.docbook:445
#, no-c-format
msgid "Board layout options"
msgstr "Opciones de diseño del tablero"

#. Tag: guilabel
#: index.docbook:448
#, no-c-format
msgid "Random Layout"
msgstr "Diseño aleatorio"

#. Tag: para
#: index.docbook:449
