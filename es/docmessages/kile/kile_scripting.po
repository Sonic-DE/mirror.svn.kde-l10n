msgstr "void document.uncomment();"

#. Tag: para
#: scripting.docbook:1208
#, no-c-format
msgid "Removes comment markers from the selection or current line."
msgstr "Elimina las marcas de comentario de la selección o línea actual."

#. Tag: synopsis
