msgstr "<guimenu>Juego</guimenu> <guimenuitem>Reproducir</guimenuitem>"

#. Tag: para
#: index.docbook:153
#, no-c-format
msgid "Replay the last game."
msgstr "Reproduce la última partida."

#. Tag: menuchoice
#: index.docbook:157
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>Q</keycap></keycombo> </"
