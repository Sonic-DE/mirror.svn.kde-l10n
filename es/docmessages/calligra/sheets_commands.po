#, no-c-format
msgid "<guimenu>Format</guimenu> <guimenuitem>Dissociate Cells</guimenuitem>"
msgstr "<guimenu>Formato</guimenu> <guimenuitem>Disociar celdas</guimenuitem>"

#. Tag: action
#: commands.docbook:711
#, no-c-format
msgid "Dissociate (split apart) previously merged cells."
msgstr "Disocia (separa) las celdas previamente combinadas."

#. Tag: menuchoice
#: commands.docbook:717
#, no-c-format
msgid ""
"<guimenu>Format</guimenu> <guimenuitem>Adjust Row &amp; Column</guimenuitem>"
msgstr ""
"<guimenu>Formato</guimenu> <guimenuitem>Ajustar fila y columna</guimenuitem>"

#. Tag: action
#: commands.docbook:721
#, no-c-format
