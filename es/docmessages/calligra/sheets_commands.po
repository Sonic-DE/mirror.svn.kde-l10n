msgstr "Inserta un carácter especial en la celda seleccionada."

#. Tag: menuchoice
#: commands.docbook:621
#, no-c-format
msgid "<guimenu>Insert</guimenu> <guisubmenu>External Data</guisubmenu>"
msgstr "<guimenu>Insertar</guimenu> <guimenuitem>Datos externos</guimenuitem>"

