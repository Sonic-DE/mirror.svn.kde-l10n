msgstr "Crea, modifica o borra estilos de formato de celda."

#. Tag: menuchoice
#: commands.docbook:664
#, no-c-format
msgid "<guimenu>Format</guimenu> <guisubmenu>Style</guisubmenu>"
msgstr "<guimenu>Formato</guimenu> <guimenuitem>Estilo</guimenuitem>"

#. Tag: para
#: commands.docbook:668
#, no-c-format
msgid ""
"<action>Apply a style to selected cell(s).</action> To manage styles use "
"<menuchoice> <guimenu>Format</guimenu><guimenuitem>Style Manager...</"
"guimenuitem> </menuchoice>"
msgstr ""
"<action>Aplica un estilo a las celdas seleccionadas.</action> Para gestionar "
"los estilos, use <menuchoice> <guimenu>Formato</guimenu><guimenuitem>Gestor "
"de estilos…</guimenuitem> </menuchoice>"

#. Tag: menuchoice
#: commands.docbook:676
#, no-c-format
msgid ""
"<guimenu>Format</guimenu> <guimenuitem>Create Style From Cell...</"
"guimenuitem>"
msgstr ""
"<guimenu>Formato</guimenu> <guimenuitem>Crear estilo desde celda…</"
"guimenuitem>"

#. Tag: para
#: commands.docbook:680
#, no-c-format
msgid ""
"<action>Create a new style from the format of the selected cell.</action> To "
"manage styles use <menuchoice> <guimenu>Format</guimenu><guimenuitem>Style "
"Manager...</guimenuitem> </menuchoice>"
msgstr ""
"<action>Crea un estilo nuevo desde el formato de la celda seleccionada.</"
"action> Para gestionar los estilo, use <menuchoice> <guimenu>Formato</"
"guimenu><guimenuitem>Gestor de estilos…</guimenuitem> </menuchoice>"

#. Tag: menuchoice
#: commands.docbook:689
#, no-c-format
msgid "<guimenu>Format</guimenu> <guimenuitem>AutoFormat...</guimenuitem>"
msgstr "<guimenu>Formato</guimenu> <guimenuitem>Autoformato…</guimenuitem>"

#. Tag: action
#: commands.docbook:693
#, no-c-format
msgid ""
"Autoformat the selected cells: a dialog let you choose between two proposed "
"formats."
msgstr ""
"Da formato automáticamente a las celdas seleccionadas: un diálogo le permite "
"elegir entre los dos formatos propuestos."

#. Tag: menuchoice
#: commands.docbook:698
#, no-c-format
msgid "<guimenu>Format</guimenu> <guimenuitem>Merge Cells</guimenuitem>"
msgstr ""
"<guimenu>Formato</guimenu> <guimenuitem>Fusionar las celdas</guimenuitem>"

