msgstr ""
"Fija los tamaños de filas y columnas para mostrar la(s) celda(s) "
"seleccionada(s) adecuadamente."

#. Tag: menuchoice
#: commands.docbook:727
#, no-c-format
msgid "<guimenu>Format</guimenu> <guisubmenu>Row</guisubmenu>"
msgstr "<guimenu>Formato</guimenu> <guimenuitem>Fila</guimenuitem>"

#. Tag: action
#: commands.docbook:731
#, no-c-format
msgid "Resize, equalize, hide or show row(s)."
msgstr "Cambia el tamaño, iguala, oculta o muestra fila(s)."

#. Tag: menuchoice
#: commands.docbook:736
#, no-c-format
msgid "<guimenu>Format</guimenu> <guisubmenu>Column</guisubmenu>"
msgstr "<guimenu>Formato</guimenu> <guimenuitem>Columna</guimenuitem>"

#. Tag: action
#: commands.docbook:740
#, no-c-format
msgid "Resize, equalize, hide or show column(s)."
msgstr "Cambia el tamaño, iguala, oculta o muestra columna(s)."

#. Tag: menuchoice
#: commands.docbook:745
#, no-c-format
msgid "<guimenu>Format</guimenu> <guisubmenu>Sheet</guisubmenu>"
msgstr "<guimenu>Formato</guimenu> <guimenuitem>Hoja</guimenuitem>"

