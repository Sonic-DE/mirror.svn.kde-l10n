"sistema:"

#. Tag: screeninfo
#: index.docbook:160
#, no-c-format
msgid "<screeninfo>Browse the map</screeninfo>"
msgstr "<screeninfo>Busque el mapa</screeninfo>"

#. Tag: phrase
#: index.docbook:166
#, no-c-format
msgid "<phrase>Browse the map</phrase>"
msgstr "<phrase>Busque el mapa</phrase>"

#. Tag: para
#: index.docbook:171
#, no-c-format
msgid ""
"Location of Provinces or Territories: you are first asked how many questions "
