msgstr "3.3.2 (KDE Gear 21.08)"

#. Tag: para
#: index.docbook:36
#, no-c-format
msgid "&knetwalk;, a game for system administrators."
msgstr "&knetwalk;, un juego para administradores de sistemas."

#. Tag: keyword
#: index.docbook:41
#, no-c-format
msgid "<keyword>KDE</keyword>"
msgstr "<keyword>KDE</keyword>"

#. Tag: keyword
#: index.docbook:42
#, no-c-format
