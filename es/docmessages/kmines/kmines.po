#. Tag: title
#: index.docbook:71
#, no-c-format
msgid "Introduction"
msgstr "Introducción"

#. Tag: title
#: index.docbook:72
#, no-c-format
msgid "Gametype:"
msgstr "Tipo de juego:"

#. Tag: para
#: index.docbook:72
#, no-c-format
msgid "Strategy, Board"
msgstr "Estrategia, Tablero"

#. Tag: title
#: index.docbook:73
#, no-c-format
msgid "Number of possible players:"
