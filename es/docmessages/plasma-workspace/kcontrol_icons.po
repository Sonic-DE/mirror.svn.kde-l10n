#~ "temas de iconos mientras <guilabel>Avanzado</guilabel> le permite "
#~ "configurar cómo se utilizarán los iconos en &plasma;."

#~ msgid "Theme"
#~ msgstr "Tema"

#~ msgid "<screeninfo>Installing A New Icon Theme</screeninfo>"
#~ msgstr "<screeninfo>Instalar un tema de iconos nuevo</screeninfo>"

#~ msgid "<phrase>Installing A New Icon Theme</phrase>"
#~ msgstr "<phrase>Instalar un tema de iconos nuevo</phrase>"

#~ msgid ""
#~ "Clicking this button will remove all files for this theme from your "
#~ "system. A confirmation message is displayed and will ask you if you are "
#~ "really sure you want to remove all the files for this theme."
#~ msgstr ""
#~ "Pulsar este botón eliminará todos los archivos para este tema de su "
