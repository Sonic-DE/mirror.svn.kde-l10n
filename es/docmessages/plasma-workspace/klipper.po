#~ msgid "Exclude Windows"
#~ msgstr "Excluir ventanas"

#~ msgid ""
#~ "Brings up the <guilabel>Disable Actions for windows of type WM_CLASS</"
#~ "guilabel> dialog."
#~ msgstr ""
#~ "Llama al diálogo <guilabel>Desactivar operaciones para ventanas del tipo "
#~ "WM_CLASS</guilabel>."

#~ msgid ""
#~ "Some programs, such as &konqueror;, use the clipboard internally. If you "
#~ "get unwanted &klipper; pop-ups all the time when using a certain "
#~ "application, do the following:"
#~ msgstr ""
#~ "Algunos programas, tales como &konqueror; utilizan el portapapeles "
#~ "internamente. Si recibe menús emergentes de &klipper; constantemente "
#~ "cuando use una cierta aplicación, haga lo siguiente:"

#~ msgid "Open the application."
#~ msgstr "Abra la aplicación."

#~ msgid ""
#~ "From a terminal, run <userinput><command>xprop</command> | <command>grep</"
#~ "command> <parameter>WM_CLASS</parameter></userinput> and then click on "
#~ "the window of the application you are running."
#~ msgstr ""
#~ "Desde un terminal, ejecute <userinput><command>xprop</command> | "
#~ "<command>grep</command> <parameter>WM_CLASS</parameter></userinput> y "
#~ "después pulse sobre la ventana de la aplicación que esté ejecutando."

#~ msgid "The first string after the equals sign is the one to enter."
#~ msgstr ""
#~ "La primera cadena de caracteres después del signo igual es la que hay que "
#~ "introducir."

#~ msgid ""
#~ "Once the WM_CLASS is added, no more actions will be generated for windows "
#~ "of that application."
#~ msgstr ""
#~ "Una vez que haya añadido WM_CLASS, no se generarán más operaciones para "
#~ "las ventanas de esa aplicación."
