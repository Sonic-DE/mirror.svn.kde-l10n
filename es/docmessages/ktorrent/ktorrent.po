#. Tag: para
#: index.docbook:40
#, no-c-format
msgid ""
"&ktorrent; is a bittorrent application by KDE which allows you to download "
"files using the BitTorrent protocol. It enables you to run multiple torrents "
"at the same time and comes with extended features to make it a full-featured "
"client for BitTorrent."
msgstr ""
"&ktorrent; es una aplicación bittorrent para KDE que le permite descargar "
"archivos utilizando el protocolo BitTorrent. Permite ejecutar varios "
"torrents al mismo tiempo y está dotada con funcionalidades extendidas que le "
"convierten en un cliente completo para BitTorrent."

#. Tag: title
#: index.docbook:43
#, no-c-format
msgid "Features"
msgstr "Funcionalidades"

#. Tag: para
#: index.docbook:44
#, no-c-format
msgid "Queuing of torrents"
msgstr "Cola de torrents"

#. Tag: para
#: index.docbook:45
#, no-c-format
msgid "Global and per torrent speed limits"
msgstr "Límite de velocidad global y por torrent"

#. Tag: para
#: index.docbook:46
#, no-c-format
msgid "Previewing of certain file types, build in (video and audio)"
msgstr "Vista previa de ciertos tipos de archivos incorporada (video y audio)"

#. Tag: para
#: index.docbook:47
#, no-c-format
msgid "Importing of partially or fully downloaded files"
msgstr "Importación de archivos parcial o completamente descargados"

#. Tag: para
#: index.docbook:48
#, no-c-format
msgid "File prioritization for multi-file torrents"
msgstr "Priorización de archivos para torrents con varios archivos"

#. Tag: para
#: index.docbook:49
#, no-c-format
msgid "Selective downloading for multi-file torrents"
msgstr "Descarga selectiva para torrents con varios archivos"

#. Tag: para
#: index.docbook:50
#, no-c-format
msgid ""
"Kick/ban peers with an additional IP Filter dialog for list/edit purposes"
msgstr ""
"Expulsión/Prohibición de pares con un diálogo de filtrado de IP adicional "
"para propósitos de listado/edición"

#. Tag: para
#: index.docbook:51
#, no-c-format
msgid "UDP tracker support"
msgstr "Admite rastreadores UDP"

#. Tag: para
#: index.docbook:52
#, no-c-format
msgid "Support for private trackers and torrents"
msgstr "Admite rastreadores y torrents privados"

#. Tag: para
#: index.docbook:53
#, no-c-format
msgid "Support for µTorrent's peer exchange"
msgstr "Admite el intercambio de pares de µTorrent"

#. Tag: para
#: index.docbook:54
#, no-c-format
msgid "Support for protocol encryption (compatible with Azureus)"
msgstr "Admite el cifrado del protocolo (compatible con Azureus)"

#. Tag: para
#: index.docbook:55
#, no-c-format
msgid "Support for creating trackerless torrents"
msgstr "Admite la creación de torrents sin rastreador"

#. Tag: para
#: index.docbook:56
#, no-c-format
msgid "Support for distributed hash tables (DHT, the Mainline version)"
msgstr ""
"Admite las tablas hash distribuidas (DHT, la versión de la línea principal)"

#. Tag: para
#: index.docbook:57
#, no-c-format
msgid ""
"Support for UPnP to automatically forward ports on a LAN with dynamic "
"assigned hosts"
msgstr ""
"Implementación de UPnP para abrir puertos de forma automática en redes LAN "
"con servidores asignados dinámicamente"

#. Tag: para
#: index.docbook:58
#, no-c-format
msgid "Support for webseeds"
msgstr "Admite semillas web"

#. Tag: para
#: index.docbook:59
#, no-c-format
msgid "System tray integration"
msgstr "Integración con la bandeja del sistema"

#. Tag: para
#: index.docbook:60
#, no-c-format
msgid "Tracker authentication support"
msgstr "Implementación de autenticación del rastreador"

#. Tag: para
#: index.docbook:61
#, no-c-format
msgid "Connection though a proxy"
msgstr "Conexión a través de un proxy"

#. Tag: para
#: index.docbook:62
#, no-c-format
msgid "Interprocess control via DBus interface"
msgstr "Control entre procesos a través de la interfaz DBus"

