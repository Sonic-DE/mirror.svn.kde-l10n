msgstr "Elige empezar un ataque con dos ejércitos."

#. Tag: filename
#: index.docbook:564
#, no-c-format
msgid "attackThree.png"
msgstr "attackThree.png"

#. Tag: entry
#: index.docbook:565
#, no-c-format
msgid "Chooses to start an attack with three armies."
msgstr "Elige empezar un ataque con tres ejércitos."

#. Tag: filename
#: index.docbook:569
#, no-c-format
msgid "defendOne.png"
msgstr "defendOne.png"

#. Tag: entry
#: index.docbook:570
#, no-c-format
msgid "Chooses to defend an attacked country with one army."
msgstr "Elige defender un país atacado con un ejército."

#. Tag: filename
#: index.docbook:574
#, no-c-format
msgid "defendTwo.png"
msgstr "defendTwo.png"

#. Tag: entry
#: index.docbook:575
#, no-c-format
msgid "Chooses to defend an attacked country with two armies."
msgstr "Elige defender un país atacado con dos ejércitos."

#. Tag: filename
#: index.docbook:579
#, no-c-format
msgid "moveArmies.png"
msgstr "moveArmies.png"

#. Tag: entry
#: index.docbook:580
#, no-c-format
msgid ""
"Chooses to start the moving of armies between two countries (last action in "
"the turn)."
msgstr ""
"Elige empezar el movimiento de tropas entre dos países (última acción del "
"turno)."

