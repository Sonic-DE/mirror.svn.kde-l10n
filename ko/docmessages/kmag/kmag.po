"shortcut> <guimenu>보기</guimenu> <guimenuitem>확대</guimenuitem>"

#. Tag: para
#: index.docbook:327
#, no-c-format
msgid "Click on this button to zoom-in on the selected region."
msgstr "선택한 영역을 확대하시려면 이 단추를 누르십시오."

#. Tag: menuchoice
#: index.docbook:331
#, no-c-format
msgid "<guimenu>View</guimenu> <guimenuitem>Rotation</guimenuitem>"
msgstr "<guimenu>보기</guimenu> <guimenuitem>회전</guimenuitem>"

#. Tag: para
#: index.docbook:335
#, no-c-format
msgid ""
"Select the rotation degree (<guimenuitem>No Rotation (0 Degrees)</"
