#. Tag: title
#: index.docbook:433
#, no-c-format
msgid "Solving Tasks"
msgstr "문제 풀기"

#. Tag: para
#: index.docbook:434
#, fuzzy, no-c-format
#| msgid ""
#| "After you have solved a given task, you need to enter the result into the "
