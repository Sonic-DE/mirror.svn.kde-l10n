msgid ""
"<acronym>PCI</acronym>-bus/Installed <acronym>PCI</acronym> Cards "
"Information Module"
msgstr ""
"<acronym>PCI</acronym> 버스/설치되어 있는 <acronym>PCI</acronym> 카드 정보 모"
"듈"

#. Tag: para
#: index.docbook:483
#, no-c-format
msgid ""
