#: index.docbook:144
#, no-c-format
msgid "The &infocenter; Toolbar"
msgstr "&infocenter; 도구 모음"

#. Tag: para
#: index.docbook:146
#, no-c-format
msgid ""
"This next section gives you a brief description of what each toolbar item "
"does."
msgstr ""

