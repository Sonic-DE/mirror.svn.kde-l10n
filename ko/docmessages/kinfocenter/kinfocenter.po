#. Tag: para
#: index.docbook:152
#, no-c-format
msgid ""
"This button opens &khelpcenter; with the current help page for the "
"information module."
msgstr ""

#. Tag: title
#: index.docbook:158
#, no-c-format
msgid "Help Menu button"
