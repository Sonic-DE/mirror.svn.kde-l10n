msgid "Features:"
msgstr "기능:"

#. (itstool) path: ul/li
#: org.kde.kapptemplate.appdata.xml:18
msgid "Templates for C++, Ruby, Python and PHP"
msgstr "C++, Ruby, 파이썬, PHP 템플릿"

#. (itstool) path: ul/li
