#. (itstool) path: component/name
#: org.kde.partitionmanager.appdata.xml:11
msgid "KDE Partition Manager"
msgstr "KDE 파티션 관리자"

#. (itstool) path: component/summary
#: org.kde.partitionmanager.appdata.xml:12
msgid "Manage disks, partitions, and file systems"
msgstr "디스크, 파티션, 파일 시스템 관리"

#. (itstool) path: description/p
#: org.kde.partitionmanager.appdata.xml:14
msgid ""
"KDE Partition Manager is a utility to help you manage the disks, partitions, "
"and file systems on your computer. It allows you to easily create, copy, "
"move, delete, back up, restore, and resize them without losing data. It "
"supports a large number of file systems, including ext2/3/4, btrfs, "
"reiserfs, NTFS, FAT16/32, JFS, XFS and more."
msgstr ""
"KDE 파티션 관리자는 컴퓨터의 디스크, 파티션, 파일 시스템을 관리하는 도구입니"
"다. 파티션 작업, 무손실 크기 조정, 백업과 복원이 가능합니다. ext2/3/4, "
"btrfs, reiserfs, NTFS, FAT16/32, JFS, XFS 등의 파일 시스템을 지원합니다."

#~ msgid "Features:"
#~ msgstr "기능:"

#~ msgid ""
#~ "Supports a large number of file systems, including ext2/3/4, btrfs, "
#~ "reiserfs, NTFS, FAT16/32, JFS, XFS and more"
#~ msgstr ""
#~ "EXT2/3/4, btrfs, reiserfs, NTFS, FAT16/32, JFS, XFS 등 파일 시스템 지원"

#~ msgid "Makes use of already available external programs to get its job done"
#~ msgstr "외부 프로그램을 사용한 작업 관리"

#~ msgid "Partition Editor"
#~ msgstr "파티션 편집기"
