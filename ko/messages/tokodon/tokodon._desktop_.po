#: org.kde.tokodon.desktop:4 src/tokodon.notifyrc:5
msgctxt "Name"
msgid "Tokodon"
msgstr "Tokodon"

#: org.kde.tokodon.desktop:44
msgctxt "GenericName"
msgid "Browse the Fediverse"
msgstr "연합우주 탐색하기"

#: org.kde.tokodon.desktop:76
msgctxt "Comment"
msgid "Client for the Mastodon"
msgstr "마스토돈 클라이언트"

#: src/tokodon.notifyrc:46
msgctxt "Comment"
msgid "A client for Mastodon, the decentralized social media"
msgstr "마스토돈 분산 소셜 네트워크 클라이언트"

# 마스토돈 한국어 번역을 따름
#: src/tokodon.notifyrc:82
msgctxt "Name"
msgid "Favorite"
msgstr "좋아요"

#: src/tokodon.notifyrc:118
msgctxt "Comment"
msgid "Someone favorited your post"
msgstr "누군가가 내 글을 좋아요 표시함"

#: src/tokodon.notifyrc:154
msgctxt "Name"
msgid "Boost"
msgstr "부스트"

#: src/tokodon.notifyrc:188
msgctxt "Comment"
msgid "Someone boosted your post"
msgstr "누군가가 내 글을 부스트함"

#: src/tokodon.notifyrc:225 src/tokodon.notifyrc:364
msgctxt "Name"
msgid "Follow"
msgstr "팔로우"

#: src/tokodon.notifyrc:261
msgctxt "Comment"
msgid "Someone followed you"
msgstr "누군가가 나를 팔로우함"

#: src/tokodon.notifyrc:298
msgctxt "Name"
msgid "Follow Request"
msgstr "팔로우 요청"

#: src/tokodon.notifyrc:330
msgctxt "Comment"
msgid "Someone requested to followed you"
msgstr "누군가가 나를 팔로우하려고 요청함"

#: src/tokodon.notifyrc:400
msgctxt "Comment"
msgid "Someone mentioned you"
msgstr "누군가가 나를 멘션함"

#: src/tokodon.notifyrc:437
msgctxt "Name"
msgid "Update"
msgstr "업데이트"

#: src/tokodon.notifyrc:472
msgctxt "Comment"
msgid "Someone edited a post"
msgstr "누군가가 글을 편집함"

#: src/tokodon.notifyrc:508
msgctxt "Name"
msgid "Poll"
msgstr "투표"

#: src/tokodon.notifyrc:540
msgctxt "Comment"
msgid "Someone's poll ended"
msgstr "누군가의 투표가 종료됨"

#: src/tokodon.notifyrc:574
msgctxt "Name"
msgid "Status"
msgstr "게시물"

#: src/tokodon.notifyrc:606
msgctxt "Comment"
msgid "Someone posted a new status"
msgstr "누군가가 새 게시물을 게시함"

#: src/tokodon.notifyrc:641
msgctxt "Name"
msgid "Quote"
msgstr "인용"

#: src/tokodon.notifyrc:662
msgctxt "Comment"
msgid "Someone quoted you"
msgstr "누군가가 나를 인용함"

#: src/tokodon.notifyrc:687
msgctxt "Name"
msgid "Annual Report"
msgstr "연간 보고"

#: src/tokodon.notifyrc:715
msgctxt "Comment"
msgid "Unveil your year's highlights and memorable moments on the Fediverse!"
msgstr "연합우주에서의 올해의 하이라이트와 기억에 남는 순간을 발견하세요!"

#: src/tokodon.notifyrc:746
msgctxt "Name"
msgid "Other"
msgstr "기타"

#: src/tokodon.notifyrc:775
msgctxt "Comment"
msgid "Notifications that do not fit in other categories"
msgstr "다른 모든 분류에 포함되지 않는 알림"

