msgid "An on screen display indicating the desktop change"
msgstr "바탕 화면 변경 상황을 표시하는 OSD"

#: src/plugins/dialogparent/package/metadata.json
msgctxt "Description"
msgid "Darkens the parent window of the currently active dialog"
msgstr "현재 활성 대화 상자의 부모 창을 어둡게 합니다"

#: src/plugins/diminactive/metadata.json
msgctxt "Description"
msgid "Darken inactive windows"
msgstr "비활성 창을 어둡게 합니다"

#: src/plugins/dimscreen/package/metadata.json
msgctxt "Description"
msgid "Darkens the entire screen when requesting root privileges"
msgstr "루트 권한이 필요할 때 화면을 어둡게 합니다"

#: src/plugins/eyeonscreen/package/metadata.json
msgctxt "Description"
msgid "Suck windows into the desktop"
msgstr "창을 바탕 화면으로 흡수"

#: src/plugins/fadedesktop/package/metadata.json
msgctxt "Description"
msgid "Fade between virtual desktops when switching"
msgstr "가상 바탕 화면 사이를 전환할 때 페이드 효과를 사용합니다"

#: src/plugins/fade/package/metadata.json
msgctxt "Description"
msgid "Make windows fade in and out when they are shown or hidden"
msgstr "창이 보여지거나 감춰질 때 페이드 인/아웃을 사용합니다"

#: src/plugins/fadingpopups/package/metadata.json
msgctxt "Description"
msgid "Fade popups in and out"
msgstr "팝업 페이드 인 및 아웃"

#: src/plugins/fallapart/metadata.json
msgctxt "Description"
msgid "Closed windows fall into pieces"
msgstr "닫힌 창이 조각난 채로 떨어지게 합니다"

#: src/plugins/frozenapp/package/metadata.json
msgctxt "Description"
msgid "Desaturate windows of unresponsive (frozen) applications"
msgstr "응답 없는 앱 창을 무채색으로 전환"

#: src/plugins/fullscreen/package/metadata.json
msgctxt "Description"
msgid "Stretch windows going to and leaving full screen mode"
msgstr "창이 전체 화면 모드로 진입하거나 벗어날 때 잡아 당깁니다"

#: src/plugins/glide/metadata.json
msgctxt "Description"
msgid "Glide windows as they appear or disappear"
msgstr "창이 나타나거나 사라질 때 미끄러짐 효과 사용하기"

#: src/plugins/highlightwindow/metadata.json
msgctxt "Description"
msgid "Highlight the appropriate window when hovering over taskbar entries"
msgstr "작업 표시줄의 창 항목을 지나다닐 때 해당하는 창을 강조합니다"

#: src/plugins/invert/metadata.json
msgctxt "Description"
msgid ""
"Inverts the color of the desktop and windows; activated with a keyboard "
"shortcut"
msgstr "바탕 화면과 창의 색 반전, 키보드 단축키로 활성화"

#: src/plugins/kscreen/metadata.json
msgctxt "Description"
msgid "Helper Effect for KScreen"
msgstr "KScreen 도우미 효과"

#: src/plugins/login/package/metadata.json
msgctxt "Description"
msgid "Fade to the desktop when logging in"
msgstr "로그인할 때 바탕 화면으로 페이드합니다"

#: src/plugins/logout/package/metadata.json
msgctxt "Description"
msgid "Fade to the logout screen"
msgstr "로그아웃 화면으로 페이드합니다"

#: src/plugins/magiclamp/metadata.json
msgctxt "Description"
msgid "Simulate a magic lamp when minimizing windows"
msgstr "창을 최소화할 때 요술 램프에 빨려들어가는 애니메이션을 보여줍니다"

#: src/plugins/magnifier/metadata.json
msgctxt "Description"
msgid ""
"Magnify the section of the screen that is near the mouse cursor; activated "
"with a keyboard shortcut"
msgstr "마우스 커서 근처에 있는 화면을 확대, 키보드 단축키로 활성화"

#: src/plugins/maximize/package/metadata.json
msgctxt "Description"
msgid "Stretch windows when they are maximized or restored"
msgstr "창을 최대화하거나 복원할 때 잡아 당깁니다"

#: src/plugins/minimizeall/package/metadata.json
msgctxt "Description"
msgid "Adds a shortcut to minimize and restore all windows"
msgstr "모든 창을 최소화하고 복원하는 단축키를 추가합니다"

#: src/plugins/mouseclick/metadata.json
msgctxt "Description"
msgid ""
"Creates an animation whenever a mouse button is clicked. This is useful for "
"screenrecordings/presentations. Activated with a keyboard shortcut"
msgstr ""
"마우스 단추를 클릭했을 때 애니메이션을 표시합니다. 화면 녹화/프레젠테이션에"
"서 유용합니다. 키보드 단축키로 활성화합니다"

#: src/plugins/mousemark/metadata.json
msgctxt "Description"
msgid ""
"Allows you to draw lines on the desktop; activated with a keyboard shortcut"
msgstr "바탕 화면에 선 그리기, 키보드 단축키로 활성화"

#: src/plugins/outputlocator/metadata.json
msgctxt "Description"
msgid "Show screen names"
msgstr "화면 이름 표시"

#: src/plugins/overview/metadata.json
msgctxt "Description"
msgid ""
"Allows you to overview virtual desktops and windows; activated with a "
"keyboard shortcut"
msgstr "가상 바탕 화면과 창 한눈에 보기, 키보드 단축키로 활성화"

#: src/plugins/scale/package/metadata.json
msgctxt "Description"
msgid "Make windows scale in and out when they are shown or hidden"
msgstr "창이 보여지거나 감춰질 때 크기 조정 효과를 사용합니다"

#: src/plugins/screenedge/metadata.json
msgctxt "Description"
msgid ""
"Highlights screen edges and corners that trigger actions when touched as the "
"cursor approaches them"
msgstr "커서가 화면 경계와 모서리에 다가갈 때 동작을 트리거하는 경우 강조 표시"

#: src/plugins/screenshot/metadata.json
msgctxt "Description"
msgid "Helper effect for screenshot tools"
msgstr "스크린샷 도구 도우미 효과"

#: src/plugins/sessionquit/package/metadata.json
msgctxt "Description"
msgid "Keep the desktop background alive during logout until the end"
msgstr "로그아웃이 끝날 때까지 데스크톱 배경 그림 유지"

#: src/plugins/sheet/metadata.json
msgctxt "Description"
msgid ""
"Make modal dialogs smoothly fly in and out when they are shown or hidden"
msgstr "모달 대화 상자를 보이거나 숨길 때 부드럽게 날아다니도록 합니다"

#: src/plugins/showfps/metadata.json
msgctxt "Description"
msgid "Display KWin's performance in the corner of the screen"
msgstr "KWin의 성능을 화면 구석에 표시합니다"

#: src/plugins/showpaint/metadata.json
msgctxt "Description"
msgid ""
"Highlight areas of the desktop that have been recently updated; activated "
"with a keyboard shortcut"
msgstr "최근에 다시 그려진 바탕 화면의 영역을 표시, 키보드 단축키로 활성화"

#: src/plugins/slideback/metadata.json
msgctxt "Description"
msgid "Slide back windows when another window is raised"
msgstr "다른 창을 올렸을 때 창 뒤로 밀기"

#: src/plugins/slide/metadata.json
msgctxt "Description"
msgid "Slide between virtual desktops when switching"
msgstr "가상 바탕 화면 사이를 전환할 때 슬라이딩 효과를 사용합니다"

#: src/plugins/slidingpopups/metadata.json
msgctxt "Description"
msgid "Slide Plasma popups in and out"
msgstr "Plasma 팝업을 슬라이드 인 및 아웃"

#: src/plugins/squash/package/metadata.json
msgctxt "Description"
msgid "Squash windows when they are minimized"
msgstr "창을 최소화할 때 압축시킵니다"

#: src/plugins/startupfeedback/metadata.json
msgctxt "Description"
msgid "Helper effect for startup feedback"
msgstr "실행 피드백 효과"

#: src/plugins/synchronizeskipswitcher/package/metadata.json
msgctxt "Description"
msgid ""
"Hides all windows marked as Skip Taskbar to be also excluded from window "
"switchers (e.g. Alt+Tab)"
msgstr ""
"작업 표시줄에서 건너뛰도록 표시한 창을 창 전환기에서도 표시하지 않음 (예: Alt"
"+Tab)"

#: src/plugins/systembell/metadata.json
msgctxt "Description"
msgid "Provides the bell"
msgstr "벨을 제공함"

#: src/plugins/thumbnailaside/metadata.json
msgctxt "Description"
msgid ""
"Display window thumbnails on the edge of the screen; activated with a "
"keyboard shortcut"
msgstr "화면 모서리에 창의 섬네일을 표시, 키보드 단축키로 활성화"

#: src/plugins/tileseditor/metadata.json
msgctxt "Description"
msgid "Editor for the tiling areas"
msgstr "타일링 영역 편집기"

#: src/plugins/trackmouse/metadata.json
msgctxt "Description"
msgid ""
"Display a mouse cursor locating effect; activated with a keyboard shortcut"
msgstr "활성화되었을 때 마우스 커서의 위치를 표시, 키보드 단축키로 활성화"

#: src/plugins/translucency/package/metadata.json
msgctxt "Description"
msgid "Make windows translucent under different conditions"
msgstr "다른 조건 하에서 창을 투명하게 만듭니다"

#: src/plugins/videowall/package/metadata.json
msgctxt "Description"
msgid ""
"Spans fullscreen video player over all attached screens to create a Video "
"Wall"
msgstr "전체 화면 동영상 재생기를 모든 화면에 걸쳐서 동영상 벽 만들기"

#: src/plugins/windowaperture/package/metadata.json
msgctxt "Description"
msgid "Move windows into screen corners"
msgstr "창을 화면 꼭짓점으로 이동"

#: src/plugins/windowview/metadata.json
msgctxt "Description"
msgid "Zoom out until all opened windows can be displayed side-by-side"
msgstr "모든 열린 창을 축소시켜서 한 화면에 보이도록 합니다"

#: src/plugins/wobblywindows/metadata.json
msgctxt "Description"
msgid "Deform windows while they are moving"
msgstr "창이 움직일 때 흔듭니다"

#: src/plugins/zoom/metadata.json
msgctxt "Description"
msgid "Magnify the entire desktop; activated with a keyboard shortcut"
msgstr "전체 바탕 화면 확대, 키보드 단축키로 활성화"

#: src/tabbox/switchers/thumbnail_grid/metadata.json
msgctxt "Description"
msgid "A window switcher layout using a small grid of thumbnails"
msgstr "작은 섬네일 격자를 사용하는 창 전환기 레이아웃"

