#. (itstool) path: component/name
#: org.kde.accountwizard.appdata.xml:9
msgid "Account Wizard"
msgstr "Assistente pro Conto"

#. (itstool) path: component/summary
#: org.kde.accountwizard.appdata.xml:10
msgid "Configure accounts"
msgstr "Configura contos"

#. (itstool) path: description/p
#: org.kde.accountwizard.appdata.xml:12
msgid ""
"Accountwizard allows to edit, create, delete accounts. Accountwizard "
"supports IMAP/POP3/Kolab account type. Account information can be found by "
"using ispd service."
msgstr ""
"Accountwizard permitte editar, crear, deler contos. Accountwizard supporta "
"typo de conto de IMAP/POP3/Kolab. Information de conto pote esser usate per "
"usar le servicio ispd."

#~ msgid "Accountwizard allows to edit, create, delete accounts."
#~ msgstr "Accountwizard te permitte modificar, crear, deler contos."
