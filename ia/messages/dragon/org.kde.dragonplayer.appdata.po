#. (itstool) path: component/name
#: org.kde.dragonplayer.appdata.xml:9
msgid "Dragon Player"
msgstr "Dragon Player (Reproductor Dragon)"

#. (itstool) path: component/summary
#: org.kde.dragonplayer.appdata.xml:10
msgid "Play video files and streams"
msgstr "Reproduce Files e fluxos (streams) video"

#. (itstool) path: description/p
#: org.kde.dragonplayer.appdata.xml:12
msgid ""
"Dragon Player is a video player focusing on simplicity instead of features. "
"Its easy-to-use interface is designed to get out of your way and simply play "
"your video files and streams."
msgstr ""
"Dragon Player es un reproductor multimedial ubi le foco es sur simplicitate, "
"in loco de charactersticas. Su interfacie facile a usar es designate per "
"lassar tu strada e simplemente reproduce tu files e fluxos (/streams) video."

#. (itstool) path: description/p
#: org.kde.dragonplayer.appdata.xml:15
msgid "Features:"
msgstr "Characteristicas:"

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:17
msgid ""
"Click to play or pause, and double-click to enter or exit full screen mode."
msgstr ""
"Clicca per reproducer o pausar, e dupleclicca per entrar o exir de modo a "
"plen texto."

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:18
msgid ""
"Choose the subtitle language, and automatically load the right one for your "
"language, if possible."
msgstr ""
"Selige le linguage de subtitulo, e carga automaticamente lo que es correcte "
"per tu linguage, si possibile. "

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:19
msgid "Choose the audio track."
msgstr "Selige le tracia audio."

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:20
msgid "Choose the video track."
msgstr "Selige le tracia video."

#. (itstool) path: ul/li
#: org.kde.dragonplayer.appdata.xml:21
msgid "Adjust the volume by scrolling."
msgstr "Adapta le volumine per rolar."

#~ msgid "Video player with focus on simplicity"
#~ msgstr "Reproductor de video focalisate sur le simplicitate"

#~ msgid "Simple Interface"
#~ msgstr "Interfacie simplice"

#~ msgid ""
#~ "Resuming videos: Starts playing a video where you were watching it last "
#~ "time"
#~ msgstr ""
#~ "Recuperante videos: Initia a reproducer un video ubi tu lo observava le "
#~ "ultime vice"

#~ msgid ""
#~ "Support for subtitles: Automatically loads subtitles with the matching "
#~ "name"
#~ msgstr ""
#~ "Supporto per subtitulos: Autmaticamente carga subtitulos con le nomine "
#~ "correspondente"

#~ msgid "Video display settings (brightness, contrast)"
#~ msgstr "Preferentias de monstrator de video (Brillantia, contrasto)"

#~ msgid ""
#~ "Due to using Solid and Phonon DragonPlayer is independent of any "
#~ "multimedia framework or hardware abstraction layer"
#~ msgstr ""
#~ "Proque DragonPlayer es usante Solid e Phonon illo es independente ab ulle "
#~ "structura de multimedia o strato de abstraction hardware"

#~ msgid "Supports playing CDs and DVDs"
#~ msgstr "Supporta reproducer CDs e DVDs"
