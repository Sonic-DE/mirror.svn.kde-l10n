msgid "Navigation Through Windows"
msgstr "Navigation per fenestras"

#: src/kcms/virtualkeyboard/kcm_virtualkeyboard.json
msgctxt "Description"
msgid "Select which virtual keyboard to use"
msgstr "Selectiona qual claviero virtual usar"

#: src/kcms/xwayland/kcm_kwinxwayland.json
msgctxt "Description"
msgid "Select which keys will be globally available to legacy X11 apps"
msgstr ""
"Selige qual claves essera disponibile globalmente a apps de X11 legacy "
"(hereditage)"

#: src/plugins/blendchanges/metadata.json
msgctxt "Description"
msgid "Animates system style changes"
msgstr "Modificationes de stylo de systema animate"

#: src/plugins/blur/metadata.json
msgctxt "Description"
msgid "Blurs the background behind semi-transparent windows"
msgstr "Obscura le fundo detra fenestras semi-transparente"

#: src/plugins/colorblindnesscorrection/metadata.json
msgctxt "Description"
msgid "Enhances color perception for color blindness"
msgstr "Intensifica perceprion de color per cecitate de color"

#: src/plugins/colorpicker/metadata.json
msgctxt "Description"
msgid "Supports picking a color"
msgstr "Supporta seliger un color"

#: src/plugins/desktopchangeosd/package/metadata.json
msgctxt "Description"
msgid "An on screen display indicating the desktop change"
msgstr "Un monstrator sur le schermo indicante le modification de scriptorio"

#: src/plugins/dialogparent/package/metadata.json
msgctxt "Description"
msgid "Darkens the parent window of the currently active dialog"
msgstr "Il obscura le fenestra genitor del dialogo currentemente active"

#: src/plugins/diminactive/metadata.json
msgctxt "Description"
msgid "Darken inactive windows"
msgstr "Fenestras inactive obscurate"

#: src/plugins/dimscreen/package/metadata.json
msgctxt "Description"
msgid "Darkens the entire screen when requesting root privileges"
msgstr ""
"Il obscura le schermo integre quando il demanda privilegios de super-usator "
"(root)"

#: src/plugins/eyeonscreen/package/metadata.json
msgctxt "Description"
msgid "Suck windows into the desktop"
msgstr "Suger fenestras in le scriptorio"

#: src/plugins/fadedesktop/package/metadata.json
msgctxt "Description"
msgid "Fade between virtual desktops when switching"
msgstr "Pallidi inter scriptorio virtuales quando il commuta"

#: src/plugins/fade/package/metadata.json
msgctxt "Description"
msgid "Make windows fade in and out when they are shown or hidden"
msgstr ""
"Face que fenestras pote pallidir intra e foras quando illos es monstrate o "
"celate"

#: src/plugins/fadingpopups/package/metadata.json
msgctxt "Description"
msgid "Fade popups in and out"
msgstr "Pallidi popups in e foras (in e out)"

#: src/plugins/fallapart/metadata.json
msgctxt "Description"
msgid "Closed windows fall into pieces"
msgstr "Fenestras claudite cade in pecias"

#: src/plugins/frozenapp/package/metadata.json
msgctxt "Description"
msgid "Desaturate windows of unresponsive (frozen) applications"
msgstr "Destura fenestras de applicationes non responsive (congelate)"

#: src/plugins/fullscreen/package/metadata.json
msgctxt "Description"
msgid "Stretch windows going to and leaving full screen mode"
msgstr "Extende fenestras quando va a e abandona modo de schermo plen"

#: src/plugins/glide/metadata.json
msgctxt "Description"
msgid "Glide windows as they appear or disappear"
msgstr "Glissa fenestras quando illes appare e disappare"

#: src/plugins/hidecursor/metadata.json
msgctxt "Description"
msgid "Hide mouse cursor on inactivity or keyboard input"
msgstr "Cela cursor de mus sur inactivitate o ingresso de claviero"

#: src/plugins/highlightwindow/metadata.json
msgctxt "Description"
msgid "Highlight the appropriate window when hovering over taskbar entries"
msgstr ""
"Evidentia le appropriate fenestra quando il es suspendite super entratas de "
"barra de carga"

#: src/plugins/invert/metadata.json
msgctxt "Description"
msgid ""
"Inverts the color of the desktop and windows; activated with a keyboard "
"shortcut"
msgstr ""
"Il inverte le color del scriptorio e del fenestras; activate con un via "
"breve de claviero"

#: src/plugins/kscreen/metadata.json
msgctxt "Description"
msgid "Helper Effect for KScreen"
msgstr "Effecto de adjutante pro KScreen"

#: src/plugins/login/package/metadata.json
msgctxt "Description"
msgid "Fade to the desktop when logging in"
msgstr "Pallidi al scriptorio quando  accedente in identification"

#: src/plugins/logout/package/metadata.json
msgctxt "Description"
msgid "Fade to the logout screen"
msgstr "Pallidi al schermo de abandono (logout)"

#: src/plugins/magiclamp/metadata.json
msgctxt "Description"
msgid "Simulate a magic lamp when minimizing windows"
msgstr "Simula un lampa magic quando minimisa fenestras"

#: src/plugins/magnifier/metadata.json
msgctxt "Description"
msgid ""
"Magnify the section of the screen that is near the mouse cursor; activated "
"with a keyboard shortcut"
msgstr ""
"Aggrandi le section del schermo que es vicin al cursor del mus; activate con "
"un via breve de claviero"

#: src/plugins/maximize/package/metadata.json
msgctxt "Description"
msgid "Stretch windows when they are maximized or restored"
msgstr "Extende fenestras quando illos es maximisate o restabilite"

#: src/plugins/minimizeall/package/metadata.json
msgctxt "Description"
msgid "Adds a shortcut to minimize and restore all windows"
msgstr "Adde un via breve pe minimisar e restabilir omne fenestras"

#: src/plugins/mouseclick/metadata.json
msgctxt "Description"
msgid ""
"Creates an animation whenever a mouse button is clicked. This is useful for "
"screenrecordings/presentations. Activated with a keyboard shortcut"
msgstr ""
"Crea un animation quando un button de mus es pressate. Isto es util pro "
"registrationes de schermo/presentationes. Activate con un via breve de "
"claviero"

#: src/plugins/mousemark/metadata.json
msgctxt "Description"
msgid ""
"Allows you to draw lines on the desktop; activated with a keyboard shortcut"
msgstr ""
"Permitte te designar lineas super le scriptorio; activate con un via breve "
"de claviero"

#: src/plugins/outputlocator/metadata.json
msgctxt "Description"
msgid "Show screen names"
msgstr "Monstra nomines de schermo"

#: src/plugins/overview/metadata.json
msgctxt "Description"
msgid ""
"Allows you to overview virtual desktops and windows; activated with a "
"keyboard shortcut"
msgstr ""
"Permitte te a supervider scriptorios virtual e fenestre; activate con un via "
"breve de claviero"

#: src/plugins/scale/package/metadata.json
msgctxt "Description"
msgid "Make windows scale in and out when they are shown or hidden"
msgstr ""
"Face que fenestras scala intra e foras quando illos es monstrate o celate"

#: src/plugins/screenedge/metadata.json
msgctxt "Description"
msgid ""
"Highlights screen edges and corners that trigger actions when touched as the "
"cursor approaches them"
msgstr ""
"Evidentia margines e angulos de schermo que discatena actiones quando "
"toccate quando le cursor se apporixima lor"

#: src/plugins/screentransform/metadata.json
msgctxt "Description"
msgid "Animates display transformations"
msgstr "Anima transformationes de monstrator "

#: src/plugins/sessionquit/package/metadata.json
msgctxt "Description"
msgid "Keep the desktop background alive during logout until the end"
msgstr ""
"Mantene le fundo de criptorio vive durante le clausura de session usque le "
"fin"

#: src/plugins/shakecursor/metadata.json
msgctxt "Description"
msgid ""
"Makes the cursor larger when the pointer is quickly moved back and forth"
msgstr ""
"Face le cursor plus grande quando le punctator es rapidemente movite retro e "
"avante"

