#. (itstool) path: component/summary
#: org.kde.spacebar.appdata.xml:5
msgid "SMS/MMS messaging client"
msgstr "Cliente de communicar con messages de SMS/MMS"

#. (itstool) path: description/p
#: org.kde.spacebar.appdata.xml:12
msgid ""
"Spacebar is a SMS/MMS messaging client. It allows you to send text messages, "
"pictures and other files over a cellular network."
msgstr ""
"Spacebar es un cliente per messages SMS/MMS. Il te permitte inviar messages "
"de texto, photos e altere files trans un rete cellular."
