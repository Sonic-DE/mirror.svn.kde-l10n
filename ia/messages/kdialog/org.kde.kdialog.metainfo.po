msgid "Display dialog boxes from shell scripts"
msgstr "Monstra quadratos de dialogo ex scripts de shell"

#. (itstool) path: description/p
#: org.kde.kdialog.metainfo.xml:9
msgid ""
"KDialog allows you to display dialog boxes from shell scripts. The syntax is "
"very much inspired from the \"dialog\" command (which shows text mode "
"dialogs)."
msgstr ""
"KDialog te permitte monstrar quadros de dialogo ex scripts de shell. Le "
"synthaxe es multe inspirate al commando  \"dialog\"  (que monstra dialogos "
"de modo texto)."
