#. (itstool) path: component/name
#: org.kde.kgraphviewer.appdata.xml:9
msgid "KGraphViewer"
msgstr " KGraphViewer"

#. (itstool) path: component/summary
#: org.kde.kgraphviewer.appdata.xml:10
msgid "A Graphviz DOT graph viewer"
msgstr "Un visor graphic de Graphviz DOT"

#. (itstool) path: description/p
#: org.kde.kgraphviewer.appdata.xml:12
msgid ""
"KGraphViewer is a Graphviz DOT graph file viewer, aimed to replace the other "
"outdated Graphviz tools. Graphs are commonly used in scientific domains and "
"particularly in computer science."
msgstr ""
"KGraphViewer es un visor de file graphic de Graphviz DOT, intendite a "
"reimplaciar le altere instrumentos antiquate de Graphviz. Graphicos es "
"communemente usate  in dominios scientific e particularmente in informatica."

#. (itstool) path: description/p
#: org.kde.kgraphviewer.appdata.xml:16
msgid "Features:"
msgstr "Characteristicas:"

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:18
msgid "Zooming"
msgstr "Facente zoom"

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:19
