#. (itstool) path: component/name
#: org.kde.skanlite.appdata.xml:10
msgid "Skanlite"
msgstr "Skanlite"

#. (itstool) path: component/summary
#: org.kde.skanlite.appdata.xml:11
msgid "Image Scanning Application"
msgstr "Application pro scander imagines"

#. (itstool) path: description/p
#: org.kde.skanlite.appdata.xml:13
msgid ""
"Skanlite is a simple image scanning application to scan and save images. It "
"is optimized for scanning with flatbed scanners. Skanlite can capture not "
"only photos and documents, but also transparent slides and filmstrips, with "
"supported scanners."
msgstr ""
"Skanlite es un simple application per scander e salveguardar images. Illo es "
"optimisate per scander con scanditores de typo flatbed. Skanlite pote "
"capturar non solmente photos e documentos ma anque slides transparente e "
"strias de film, con scanditores supportate."

