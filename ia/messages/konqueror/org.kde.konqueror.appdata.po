#. (itstool) path: component/name
#: org.kde.konqueror.appdata.xml:9
msgid "Konqueror"
msgstr "Konqueror"

#. (itstool) path: component/summary
#: org.kde.konqueror.appdata.xml:10
msgid "KDE File Manager &amp; Web Browser"
msgstr "Gerente de file de KDE &amp; Navigator de Web"

#. (itstool) path: description/p
#: org.kde.konqueror.appdata.xml:12
msgid ""
"Konqueror is KDE's Webbrowser and swiss-army-knife for any kind of file-"
"management and file previewing."
msgstr ""
"Konqueror es le navigator web de KDE e le instrumento universal pro omne "
"typo de gestion de file e de lor vista preliminar."

#. (itstool) path: description/p
#: org.kde.konqueror.appdata.xml:13
msgid "Features:"
msgstr "Characteristicas:"

#. (itstool) path: ul/li
#: org.kde.konqueror.appdata.xml:15
msgid "Webbrowsing using Qt WebEngine as rendering engine"
msgstr ""
"Navigation de web usante Qt WebEngine como motores de rendition (rendering)"

#. (itstool) path: ul/li
#: org.kde.konqueror.appdata.xml:16
msgid ""
"File management using most of Dolphin's features (including version-control, "
"service menus and the basic UI)"
msgstr ""
"Gerente de file usante le plus de characteristicas de Dolphin (includente le "
"controlo de version, le menu de servicio e le UI basic)"

#. (itstool) path: ul/li
#: org.kde.konqueror.appdata.xml:17
msgid "File management on ftp and sftp servers"
msgstr "Gestion complete su servitores ftp e sftp"

#. (itstool) path: ul/li
#: org.kde.konqueror.appdata.xml:18
msgid ""
"Full featured FTP-client (you can split views to display local and remote "
"folders and previews in the same window)"
msgstr ""
"Complete cliente de FTP (tu pote scinder vistas pro monstrar dossieres local "
"e remote e vistas preliminar in le mesme fenestra)"

#. (itstool) path: ul/li
#: org.kde.konqueror.appdata.xml:19
msgid ""
"Embedded applications to preview files (e.g. Okular and Calligra for "
"documents, Gwenview for pictures, KTextEditor for text-files)"
msgstr ""
"Applicationes includite pro vista preliminar de files (p.ex. Okular e "
"Calligra pro documentos, Gwenview pro images, KTextEditor pro files de texto)"

#. (itstool) path: ul/li
#: org.kde.konqueror.appdata.xml:20
msgid ""
"Different kinds of plugins: Service-menus, KParts (embedded applications), "
"KIO (accessing files using special protocols like http or ftp) and KPart-"
"plugins (like AdBlocker...)"
msgstr ""
"Differente typos de pluigin: Menus de servicio, KParts (applicationes "
"insertate), KIO (accesso a files per protocollos special como http o ftp) e "
"plugins de KPart (como AdBlocker...)"
