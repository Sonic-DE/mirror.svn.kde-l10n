#. (itstool) path: component/name
#: org.kde.kmousetool.appdata.xml:9
msgid "KMouseTool"
msgstr "KMouseTool"

#. (itstool) path: component/summary
#: org.kde.kmousetool.appdata.xml:10
msgid "Automatic clicks to reduce the effects of repetitive strain injury"
msgstr "Clicar automatic per reducer le effectos de damnos sporadic repetitive"

#. (itstool) path: description/p
#: org.kde.kmousetool.appdata.xml:12
msgid ""
"KMouseTool clicks the mouse for you, so you don't have to. KMouseTool works "
"with any mouse or pointing device."
msgstr ""
"KMouseTool cicca le mus per te, assi que tu non debe facer lo. KMouseTool "
"functiona con ulle mus o dispositivo de punctar."

#~ msgid "Automatic Mouse Click"
#~ msgstr "Pulsar automatic de mus"
