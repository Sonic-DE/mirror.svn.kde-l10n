msgid "Install an SDDM theme"
msgstr "Installa  un thema de SDDM"

#: kcm_sddm.actions:213
msgctxt "Description"
msgid "Extract a zip file containing an SDDM theme to the SDDM theme location"
msgstr ""
"Extrahe un file zip continente un thema de SDDM al location de thema SDDM"

