#. (itstool) path: component/summary
#: org.kde.systemdgenie.metainfo.xml:12
msgid "System service manager"
msgstr "Gerente de servicio de Systema"

#. (itstool) path: description/p
#: org.kde.systemdgenie.metainfo.xml:14
msgid ""
"systemdGenie allows graphical management of systemd units, including user "
"units, and provides control over logind sessions. It also includes an "
"integrated text editor for easy modification of unit and configuration files."
msgstr ""
"systemdGenie permitte gerer graphicamente unitates de systemd, includente "
"unitates de usator, e forni controlos sur sessiones de logind. Il anque "
"include editor de texto per modificar facilmente unitates e files de "
"configuration."
