#. (itstool) path: component/name
#: org.kde.kio_zeroconf.metainfo.xml:9
msgid "Zeroconf Support"
msgstr "Supporto de Zeroconf"

#. (itstool) path: component/summary
#: org.kde.kio_zeroconf.metainfo.xml:10
msgid "Browse local network services in Dolphin's Network page"
msgstr "Cerca o naviga in le pagina de servicios de rete de Dolphin "

#. (itstool) path: description/p
#: org.kde.kio_zeroconf.metainfo.xml:12
msgid ""
"Adds an entry to Dolphin's Network page to show local services such as "
"printers which advertise themselves with DNSSD (called Avahi or Bonjour by "
"other projects)."
msgstr ""
"Adde un entrata al pagina de rete de Dolphin per monstrar servicios local "
"tal como imprimitores que annuncia se mesme con DNSSD(appellate Avahi o "
"Bonjour per altere projectos)."
