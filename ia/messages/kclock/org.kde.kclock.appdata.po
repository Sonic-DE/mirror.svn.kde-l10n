msgstr "Pagina de alarma"

#. (itstool) path: description/p
#: org.kde.kclock.appdata.xml:111
msgid "New features and bugfixes in this release:"
msgstr "Nove characteristicas e correctiones de faltas in iste version:"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:113
msgid "Fixed timer add one minute button."
msgstr "Corrigite que le chronometro adde button de un minuta."

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:114
msgid "Switched to tab bar based sidebar (similar to bottom navigation bar)."
msgstr ""
"Comjmutate a barra lateral basate sur barra de scheda (simile al barra de "
"navigation a basso) "

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:131
msgid "Support for background daemon when using flatpak"
msgstr "Supporto per demone de fundo quando usante flatpak"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:132
msgid "Fix excessive log generation on non-Plasma system"
msgstr ""
"Corrige generation excessive de log (registros) sur systema que non es de "
"Plasma"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:140
msgid "Fix \"Clock daemon not found\" popup message"
msgstr "Corrige message de popup \"Demone de Clock (Horologio) non trovate\" "

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:141
msgid "Various bugfixes and user interface improvements"
msgstr "Varie correctiones de faltas e melioramentos de interfacie de usator"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:142
msgid "Add a sound picker component for listing alarm sounds"
msgstr "Adde un componente selector de sono per listar sonos de alarma"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:143
msgid "Start snooze only after button is pressed"
msgstr "Initia snooze (dormettar) solmente post que le button es pressate"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:144
msgid "Fix alarms not working on PinePhone"
msgstr "Corrige alarmas non functionante sur PinePhone"

#. (itstool) path: description/p
#: org.kde.kclock.appdata.xml:150 org.kde.kclock.appdata.xml:167
msgid "Changes:"
msgstr "Modificationes:"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:152
msgid "Kirigami's bottom navigation bar component is now used for mobile"
msgstr ""
"Lecomponente de barra de navigation de basso de Kirigami es nunc usate per "
"mobile"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:153
msgid "A Plasma style sidebar is now used on desktop"
msgstr "Un barra lateral de stilo dePlasmaes nunc usate sur scriptorio"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:154
msgid "The system tray item now only shows when alarms are pending"
msgstr ""
"Le elemento de tabuliero de systema non solmente monstra quando alarmas es "
"pendente"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:155
msgid "The daemon automatically stops if no alarms and timers are pending"
msgstr ""
"Le demoine stoppa automaticamente si necun alarmas e chronometros (timers) "
"es pendente"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:156
msgid "Action bars are now used on the timer and alarms forms page"
msgstr ""
"Barras de action es nunc usate sur le pagina de formas de chronometro e "
"alarmas "

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:157
msgid "The settings button has been moved to the top actions bar"
msgstr ""
"Le button de preferentias ha essite movite al barra de actiones de culmine"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:169
msgid ""
"Watch DBus for PowerDevil, so wake from suspend always works if PowerDevil "
"is found"
msgstr ""
"Observa DBus per PowerDevil, assi que evelia ex suspende functiona sempre si "
"PowerDevil es trovate"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:170
msgid "Use consistent dialog style on the settings page"
msgstr "Usa dialogo de stilo consistente sur le pagina de preferentias"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:171
msgid "After editing an alarm, the alarm now automatically is activated"
msgstr "Post modficar un alarma, le alarma es nunc activate automaticamente"

#. (itstool) path: description/p
#: org.kde.kclock.appdata.xml:178
msgid "New features and bugfixes:"
msgstr "Nove characteristicas e correctiones de faltas:"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:180
msgid "Added the ability to set timer presets"
msgstr ""
"Addite lehabilitate de assignar preinsimules de chronometro (timer presets)"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:181
msgid "Added ability to increase timer duration by 1m as timer is running"
msgstr ""
"Addite habilitate a augmentar duration de chronometro per 1m durante que le "
"chronometro es executante"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:182
msgid ""
"Fixed multiple alarm sounds and notifications being played for one alarm"
msgstr ""
"Corrigite que multiple notificationes e sonos de alarma es executate perun "
"alarma"

#. (itstool) path: ul/li
#: org.kde.kclock.appdata.xml:183
msgid "Fixed errors that prevented the application from working in a Flatpak"
msgstr ""
"Corrigite errores que preveniva le application ab functionar in un Flatpak"

