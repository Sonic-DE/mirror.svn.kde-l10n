msgstr "Надіслати файл за допомогою KDE Connect"

#: plasmoid/package/metadata.json
msgctxt "Name"
msgid "KDE Connect"
msgstr "KDE Connect"

#: plugins/battery/kdeconnect_battery.json
msgctxt "Name"
msgid "Battery monitor"
msgstr "Монітор акумулятора"

#: plugins/clipboard/kdeconnect_clipboard.json
