msgid "ModemManager Telephony integration"
msgstr "Інтеграція телефонії ModemManager"

#: plugins/mousepad/kdeconnect_mousepad.json
msgctxt "Name"
msgid "Receive remote input"
msgstr "Отримання віддаленого введення"

#: plugins/mpriscontrol/kdeconnect_mpriscontrol.json
msgctxt "Name"
msgid "Multimedia control receiver"
msgstr "Отримувач команд щодо керування мультимедійними функціями"

#: plugins/mprisremote/kdeconnect_mprisremote.json
msgctxt "Name"
msgid "Send multimedia control commands"
msgstr "Надсилання команд керування відтворенням мультимедійних даних"

#: plugins/notifications/kdeconnect_notifications.json
msgctxt "Name"
msgid "Receive notifications"
msgstr "Отримати сповіщення"

#: plugins/pausemusic/kdeconnect_pausemusic.json
msgctxt "Name"
msgid "Pause media during calls"
msgstr "Призупинка відтворення під час дзвінків"

#: plugins/ping/kdeconnect_ping.json
msgctxt "Name"
msgid "Ping"
msgstr "Луна-імпульс"

#: plugins/presenter/kdeconnect_presenter.json
msgctxt "Name"
msgid "Presenter"
msgstr "Презентатор"

#: plugins/remotecommands/kdeconnect_remotecommands.json
msgctxt "Name"
msgid "Send commands to execute"
msgstr "Надсилання команд для виконання"

#: plugins/remotecontrol/kdeconnect_remotecontrol.json
msgctxt "Name"
msgid "Send remote mouse input"
msgstr "Надсилання введення з віддаленої миші"

#: plugins/remotekeyboard/kdeconnect_remotekeyboard.json
msgctxt "Name"
msgid "Send remote keyboard input"
msgstr "Надсилання введення з віддаленої клавіатури"

#: plugins/remotesystemvolume/kdeconnect_remotesystemvolume.json
msgctxt "Name"
msgid "Remote volume control"
msgstr "Віддалене керування гучністю"

#: plugins/runcommand/kdeconnect_runcommand.json
msgctxt "Name"
msgid "Execute remote commands"
msgstr "Віддалене виконання команд"

#: plugins/screensaver-inhibit/kdeconnect_screensaver_inhibit.json
msgctxt "Name"
msgid "Inhibit screensaver"
msgstr "Заборона зберігача екрана"

#: plugins/sendnotifications/kdeconnect_sendnotifications.json
msgctxt "Name"
msgid "Send notifications"
msgstr "Надіслати сповіщення"

#: plugins/sftp/kdeconnect_sftp.json
msgctxt "Name"
msgid "Remote filesystem browser"
msgstr "Перегляд віддалених файлових систем"

#: plugins/shareinputdevices/kdeconnect_shareinputdevices.json
msgctxt "Name"
msgid "Share input devices"
msgstr "Спільне використання пристроїв введення"

#: plugins/share/kdeconnect_share.json
msgctxt "Name"
msgid "Share and receive"
msgstr "Оприлюднення і отримання"

#: plugins/sms/kdeconnect_sms.json
msgctxt "Name"
msgid "SMS integration"
msgstr "Інтеграція SMS"

#: plugins/systemvolume/kdeconnect_systemvolume.json
msgctxt "Name"
msgid "Receive volume controls"
msgstr "Отримання даних щодо керування гучністю"

#: plugins/telephony/kdeconnect_telephony.json
msgctxt "Name"
msgid "Telephony integration"
msgstr "Інтеграція з системою телефонії"

#: plugins/virtualmonitor/kdeconnect_virtualmonitor.json
msgctxt "Name"
msgid "Virtual Monitor"
msgstr "Віртуальний монітор"

#: fileitemactionplugin/kdeconnectsendfile.json
msgctxt "Description"
msgid "Send file to other device using KDE Connect"
msgstr "Надіслати файл на інший пристрій за допомогою KDE Connect"

#: plasmoid/package/metadata.json
msgctxt "Description"
msgid "Manage connected devices"
msgstr "Керування з'єднаними пристроями"

#: plugins/battery/kdeconnect_battery.json
msgctxt "Description"
msgid "Share the battery status between devices"
msgstr "Спільне використання даних щодо стану акумулятора між пристроями"

#: plugins/clipboard/kdeconnect_clipboard.json
msgctxt "Description"
msgid "Share the clipboard between devices"
msgstr "Спільне використання буфера обміну даними на пристроях"

#: plugins/connectivity-report/kdeconnect_connectivity_report.json
msgctxt "Description"
msgid "Show your phone's network signal strength"
msgstr "Показ потужності сигналу мережі на вашому телефоні"

#: plugins/contacts/kdeconnect_contacts.json
msgctxt "Description"
msgid "Synchronize contacts from the connected device"
msgstr "Синхронізація контактів зі з'єднаного пристрою"

#: plugins/digitizer/kdeconnect_digitizer.json
msgctxt "Description"
msgid "Use your device as a pressure sensitive drawing tablet"
msgstr "Використовувати пристрій як графічний планшет з детектором тиску"

#: plugins/findmyphone/kdeconnect_findmyphone.json
msgctxt "Description"
msgid "Find your lost phone by making it play an alarm sound"
msgstr "Знайти загублений телефон, наказавши йому відтворити дзвінок"

#: plugins/findthisdevice/kdeconnect_findthisdevice.json
msgctxt "Description"
msgid "Find this device by making it play an alarm sound"
msgstr "Знайти цей пристрій, наказавши йому відтворити дзвінок"

#: plugins/lockdevice/kdeconnect_lockdevice.json
msgctxt "Description"
msgid "Remotely lock and unlock your screen"
msgstr "Віддалене блокування і розблокування екрана"

#: plugins/mmtelephony/kdeconnect_mmtelephony.json
#: plugins/telephony/kdeconnect_telephony.json
msgctxt "Description"
msgid "Show notifications for incoming calls"
msgstr "Показ сповіщень щодо вхідних дзвінків"

#: plugins/mousepad/kdeconnect_mousepad.json
msgctxt "Description"
msgid "Use your phone as a touchpad and keyboard"
msgstr "Скористайтеся телефоном як замінником сенсорної панелі і клавіатури"

#: plugins/mpriscontrol/kdeconnect_mpriscontrol.json
msgctxt "Description"
msgid "Remote control your music and videos"
msgstr "Віддалене керування відтворенням музики та відео"

#: plugins/mprisremote/kdeconnect_mprisremote.json
msgctxt "Description"
msgid "Control multimedia players from this device"
msgstr "Керування мультимедійними програвачами з вашого пристрою"

#: plugins/notifications/kdeconnect_notifications.json
msgctxt "Description"
msgid "Show device's notifications on this computer and keep them in sync"
msgstr ""
"Показ сповіщень з пристрою на цьому комп’ютері та підтримання синхронізації "
"даних сповіщень"

#: plugins/pausemusic/kdeconnect_pausemusic.json
msgctxt "Description"
msgid "Pause music/videos during a phone call"
msgstr "Призупинка відтворення музики і відео на час телефонних дзвінків"

#: plugins/ping/kdeconnect_ping.json
msgctxt "Description"
msgid "Send and receive pings"
msgstr "Надсилання і отримання сигналів підтримання зв’язку"

#: plugins/presenter/kdeconnect_presenter.json
msgctxt "Description"
msgid "Use your mobile device as a presentation pointer"
msgstr "Використання мобільного пристрою як пульту керування презентацією"

#: plugins/remotecommands/kdeconnect_remotecommands.json
msgctxt "Description"
msgid "Trigger commands predefined on the remote device"
msgstr "Запуск команд, попередньо визначених на віддаленому пристрої"

#: plugins/remotecontrol/kdeconnect_remotecontrol.json
msgctxt "Description"
msgid "Use your mouse to send input to another device"
msgstr "Використання миші для надсилання вхідних даних на інший пристрій"

#: plugins/remotekeyboard/kdeconnect_remotekeyboard.json
msgctxt "Description"
msgid "Use your keyboard to send input to another device"
msgstr "Використання клавіатури для надсилання вхідних даних на інший пристрій"

#: plugins/remotesystemvolume/kdeconnect_remotesystemvolume.json
msgctxt "Description"
msgid "Control the volume of the connected device"
msgstr "Керування томом сховища даних на з'єднаному пристрої"

#: plugins/runcommand/kdeconnect_runcommand.json
msgctxt "Description"
msgid "Execute predefined commands remotely"
msgstr "Віддалене виконання попередньо визначених команд"

#: plugins/screensaver-inhibit/kdeconnect_screensaver_inhibit.json
msgctxt "Description"
msgid "Inhibit the screensaver when the device is connected"
msgstr "Забороняє зберігач екрана, якщо з’єднано пристрій"

#: plugins/sendnotifications/kdeconnect_sendnotifications.json
msgctxt "Description"
msgid ""
"Broadcast this computer's notifications, so they can be shown on other "
"devices."
msgstr ""
"Транслювати сповіщення з цього комп’ютера так, щоб їх було показано на інших "
"пристроях."

#: plugins/sftp/kdeconnect_sftp.json
msgctxt "Description"
msgid "Browse the remote device filesystem using SFTP"
msgstr "Перегляд файлових систем на сторонніх пристроях за допомогою SFTP"

#: plugins/shareinputdevices/kdeconnect_shareinputdevices.json
msgctxt "Description"
msgid "Share mouse and keyboard with the remote device"
msgstr "Спільне використання миші і клавіатури з віддаленим пристроєм"

#: plugins/share/kdeconnect_share.json
msgctxt "Description"
msgid "Receive and send files, URLs, or plain text"
msgstr "Отримання і надсилання файлів, адрес або текстових фрагментів"

#: plugins/sms/kdeconnect_sms.json
msgctxt "Description"
msgid "Send and receive SMS"
msgstr "Надсилання і отримання SMS"

#: plugins/systemvolume/kdeconnect_systemvolume.json
msgctxt "Description"
msgid "Enable volume to be controlled from the connected device"
msgstr "Уможливлення керування гучністю зі з'єднаного пристрою"

#: plugins/virtualmonitor/kdeconnect_virtualmonitor.json
msgctxt "Description"
msgid "Use your devices as virtual monitors"
msgstr "Використання ваших пристроїв як віртуальних моніторів"

