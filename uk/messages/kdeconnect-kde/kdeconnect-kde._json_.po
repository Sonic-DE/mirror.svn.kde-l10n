msgid "Clipboard synchronization"
msgstr "Синхронізація буфера обміну"

#: plugins/connectivity-report/kdeconnect_connectivity_report.json
msgctxt "Name"
msgid "Connectivity monitor"
msgstr "Монітор з'єднання"

