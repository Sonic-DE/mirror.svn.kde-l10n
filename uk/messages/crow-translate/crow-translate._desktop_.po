#: data/org.kde.CrowTranslate.desktop.in:3
msgctxt "Name"
msgid "Crow Translate"
msgstr "Crow Translate"

#: data/org.kde.CrowTranslate.desktop.in:31
msgctxt "GenericName"
msgid "Translator"
msgstr "Перекладач"

#: data/org.kde.CrowTranslate.desktop.in:63
msgctxt "Comment"
msgid ""
"A simple and lightweight translator that allows to translate and speak the "
"selected text using Mozhi"
msgstr ""
"Проста і невибаглива до ресурсів програма для перекладу, яка дає вам змогу "
"перекладати і озвучувати позначені фрагменти тексту за допомогою Mozhi"

#: data/org.kde.CrowTranslate.desktop.in:91
msgctxt "Keywords"
msgid "google;yandex;deepl;duckduckgo;libre';mymemory;reverso;text-to-speech;"
msgstr ""
"google;yandex;deepl;duckduckgo;libre';mymemory;reverso;text-to-speech;гугл;"
"яндекс;діпл;дакдакгоу;лібре;маймеморі;реверсо;озвучення;"

#: data/org.kde.CrowTranslate.desktop.in:132
msgctxt "Name"
msgid "Translate selected text"
msgstr "Перекласти позначений текст"

#: data/org.kde.CrowTranslate.desktop.in:165
msgctxt "Name"
msgid "Speak selected text"
msgstr "Озвучити позначений текст"

#: data/org.kde.CrowTranslate.desktop.in:197
msgctxt "Name"
msgid "Speak translation of selected text"
msgstr "Озвучити переклад позначеного фрагмента тексту"

#: data/org.kde.CrowTranslate.desktop.in:229
msgctxt "Name"
msgid "Stop text speaking"
msgstr "Припинити озвучення тексту"

#: data/org.kde.CrowTranslate.desktop.in:261
msgctxt "Name"
msgid "Show main window"
msgstr "Показати головне вікно"

#: data/org.kde.CrowTranslate.desktop.in:296
msgctxt "Name"
msgid "Translate selected text and copy to clipboard"
msgstr "Перекласти позначений текст і скопіювати переклад до буфера обміну"

#: data/org.kde.CrowTranslate.desktop.in:327
msgctxt "Name"
msgid "Recognize text in screen area"
msgstr "Розпізнати текст в області екрана"

#: data/org.kde.CrowTranslate.desktop.in:359
msgctxt "Name"
msgid "Translate text in screen area"
msgstr "Перекласти текст в області екрана"

#: data/org.kde.CrowTranslate.desktop.in:391
msgctxt "Name"
msgid "Toggle the option to negate (invert) the captured image before OCR"
msgstr ""
"Увімкнути або вимкнути створення негатива (інвертування) знятого зображення "
"до оптичного розпізнавання"

#~ msgctxt "Name"
#~ msgid "Breeze"
#~ msgstr "Breeze"

#~ msgctxt "Comment"
#~ msgid "Embedded in qrc to get size dirs matching hicolor theme"
#~ msgstr ""
#~ "Вбудовано до qrc для отримання відповідної кольорової теми для розмірів "
#~ "каталогів"

