#: kcm_sddm.actions:2
msgctxt "Name"
msgid "SDDM"
msgstr "SDDM"

#: kcm_sddm.actions:58
msgctxt "Name"
msgid "Save Settings"
msgstr "Зберегти параметри"

#: kcm_sddm.actions:109
msgctxt "Description"
msgid "Save Settings in SDDM"
msgstr "Зберегти параметри у SDDM"

#: kcm_sddm.actions:163
msgctxt "Name"
msgid "Install an SDDM theme"
msgstr "Встановити тему SDDM"

#: kcm_sddm.actions:213
msgctxt "Description"
msgid "Extract a zip file containing an SDDM theme to the SDDM theme location"
msgstr "Видобути дані з архіву zip, що містить тему SDDM, до каталогу тем SDDM"

#: kcm_sddm.actions:254
msgctxt "Name"
msgid "Uninstall an SDDM theme"
msgstr "Вилучити тему SDDM"

#: kcm_sddm.actions:304
msgctxt "Description"
msgid "Remove a previously installed SDDM theme"
msgstr "Вилучити раніше встановлену тему SDDM"

#: kcm_sddm.actions:345
msgctxt "Name"
msgid "Synchronize Settings"
msgstr "Синхронізувати параметри"

#: kcm_sddm.actions:391
msgctxt "Description"
msgid "Synchronize user settings with SDDM settings"
msgstr "Синхронізація параметрів користувача із параметрами SDDM"

#: kcm_sddm.actions:432
msgctxt "Name"
msgid "Reset Settings"
msgstr "Скинути параметри"

#: kcm_sddm.actions:478
msgctxt "Description"
msgid "Reset SDDM settings to factory default state"
msgstr "Скинути параметри SDDM до типових для системи"

