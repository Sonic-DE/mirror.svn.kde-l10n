msgid "systemd Management Tool"
msgstr "Засіб керування systemd"

#: src/org.kde.systemdgenie.desktop:62
msgctxt "Comment"
msgid "Manage systemd units, timers, sessions and config files"
msgstr "Керування модулями, таймерами, сеансами та файлами налаштувань systemd"

