#: src/helper/systemdgenie.actions:46
msgctxt "Name"
msgid "Save a systemd unit file"
msgstr "Збереження файла модуля systemd"

#: src/helper/systemdgenie.actions:88
msgctxt "Description"
msgid "Administrator authorization is required to save the systemd unit file"
msgstr ""
"Для збереження файла модуля systemd слід пройти розпізнавання на доступ до "
"адміністративних функцій"

#: src/helper/systemdgenie.actions:134
msgctxt "Name"
msgid "Manipulate systemd over D-Bus"
msgstr "Керування systemd за допомогою D-Bus"

#: src/helper/systemdgenie.actions:176
msgctxt "Description"
msgid "Administrator authorization is required to manipulate systemd"
msgstr ""
"Для керування systemd слід пройти розпізнавання на доступ до "
"адміністративних функцій"

#: src/org.kde.systemdgenie.desktop:2
