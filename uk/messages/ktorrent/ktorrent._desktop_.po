#: ktorrent/ktorrent.notifyrc:4
msgctxt "Comment"
msgid "KTorrent"
msgstr "KTorrent"

#: ktorrent/ktorrent.notifyrc:67
msgctxt "Name"
msgid "Torrent silently opened"
msgstr "Торент відкрито без додаткових запитів"

#: ktorrent/ktorrent.notifyrc:117
msgctxt "Name"
msgid "Torrent stopped by error"
msgstr "Торент зупинено через помилку"

#: ktorrent/ktorrent.notifyrc:174
msgctxt "Name"
msgid "Torrent has finished downloading"
msgstr "Отримання торента завершено"

#: ktorrent/ktorrent.notifyrc:231
msgctxt "Name"
msgid "Maximum share ratio reached"
msgstr "Досягнути максимального відношення поширення"

#: ktorrent/ktorrent.notifyrc:288
msgctxt "Name"
msgid "Maximum seed time reached"
msgstr "Досягнуто максимального часу поширення"

#: ktorrent/ktorrent.notifyrc:345
msgctxt "Name"
msgid "Disk space is running low"
msgstr "Вільне місце на диску закінчується"

#: ktorrent/ktorrent.notifyrc:402
msgctxt "Name"
msgid "Corrupted data has been found"
msgstr "Знайдено пошкоджені дані"

#: ktorrent/ktorrent.notifyrc:460
msgctxt "Name"
msgid "Torrent cannot be enqueued"
msgstr "Торент неможливо поставити в чергу"

#: ktorrent/ktorrent.notifyrc:517
msgctxt "Name"
msgid "Torrent cannot be started"
msgstr "Неможливо запустити торент"

#: ktorrent/ktorrent.notifyrc:574
msgctxt "Name"
msgid "Torrent cannot be loaded silently"
msgstr "Неможливо завантажити торент без додаткової інформації"

#: ktorrent/ktorrent.notifyrc:631
msgctxt "Name"
msgid "DHT is not enabled"
msgstr "DHT не увімкнено"

#: ktorrent/ktorrent.notifyrc:686
msgctxt "Name"
msgid "Event generated by plugin"
msgstr "Додатком створено повідомлення про подію"

#: ktorrent/ktorrent.notifyrc:738
msgctxt "Name"
msgid "Magnet link download started"
msgstr "Розпочато отримання за маґнет-посиланням"

#: ktorrent/ktorrent.notifyrc:789
msgctxt "Name"
msgid "Magnet link copied to clipboard"
msgstr "Маґнет-посилання скопійовано до буфера обміну"

#: ktorrent/org.kde.ktorrent.desktop:2
msgctxt "Name"
msgid "KTorrent"
msgstr "KTorrent"

#: ktorrent/org.kde.ktorrent.desktop:66
msgctxt "GenericName"
msgid "BitTorrent Client"
msgstr "Клієнт BitTorrent"

#: ktorrent/org.kde.ktorrent.desktop:137
msgctxt "Comment"
msgid "A BitTorrent program by KDE"
msgstr "Програма BitTorrent від KDE"

#~ msgctxt "Name"
#~ msgid "Scheduler"
#~ msgstr "Планування"

#~ msgctxt "Comment"
#~ msgid "Schedule upload and download limits over a period of a week"
#~ msgstr "Додаток для складання розкладу обмежень на отримання на тиждень"

#~ msgctxt "Name"
#~ msgid "Download Order"
#~ msgstr "Порядок отримання"

#~ msgctxt "Comment"
#~ msgid "Specify the download order of a multi-file torrent"
#~ msgstr "Додаток для визначення порядку отримання багатофайлового торента"

#~ msgctxt "Name"
#~ msgid "Information Widget"
#~ msgstr "Інформаційний віджет"

#~ msgctxt "Comment"
#~ msgid "Displays general information about a torrent in several tabs"
#~ msgstr "Показ загальної інформації про торент у декількох вкладках"

#~ msgctxt "Name"
#~ msgid "IP Filter"
#~ msgstr "Фільтр IP"

#~ msgctxt "Comment"
#~ msgid "Filter IP addresses through a blocklist"
#~ msgstr "Фільтрувати IP-адреси за списком блокування"

#~ msgctxt "Name"
#~ msgid "Log Viewer"
#~ msgstr "Переглядач журналу"

#~ msgctxt "Comment"
#~ msgid "Displays the logging output"
#~ msgstr "Показати відомості з журналу"

#~ msgctxt "Name"
#~ msgid "Magnet Generator"
#~ msgstr "Породжувач Magnet"

#~ msgctxt "Comment"
#~ msgid "Generates magnet links"
#~ msgstr "Створює посилання magnet"

#~ msgctxt "Name"
#~ msgid "Media Player"
#~ msgstr "Медіапрогравач"

#~ msgctxt "Comment"
#~ msgid "Phonon-based media player"
#~ msgstr "Заснований на Phonon додаток програвача для KTorrent"

#~ msgctxt "Name"
#~ msgid "Scan Folder"
#~ msgstr "Сканувати теку"

#~ msgctxt "Comment"
#~ msgid "Scan folders for torrent files and load them"
#~ msgstr "Знайти у теках файли торентів і завантажити їх"

#~ msgctxt "Name"
#~ msgid "Scan for lost files"
#~ msgstr "Пошук втрачених файлів"

#~ msgctxt "Comment"
#~ msgid ""
#~ "Display files in the selected folder that don't belong to any torrent"
#~ msgstr "Показати файли у вибраній теці, які не належать до жодного торента"

#~ msgctxt "Name"
#~ msgid "Search"
#~ msgstr "Пошук"

#~ msgctxt "Comment"
#~ msgid "Search for torrents"
#~ msgstr "Пошук торентів"

#~ msgctxt "Name"
#~ msgid "Shutdown"
#~ msgstr "Вимкнути"

#~ msgctxt "Comment"
#~ msgid "Allows you to shutdown your computer when torrents finish"
#~ msgstr ""
#~ "Надає вам змогу вимкнути комп’ютер після завершення отримання торента"

#~ msgctxt "Name"
#~ msgid "Statistics"
#~ msgstr "Статистика"

#~ msgctxt "Comment"
#~ msgid "Shows statistics about torrents in several graphs"
#~ msgstr "Показує статистику торентів за допомогою декількох графіків"

#~ msgctxt "Name"
#~ msgid "Syndication"
#~ msgstr "Синдикація"

#~ msgctxt "Comment"
#~ msgid "Syndication plugin for KTorrent, supporting RSS and Atom feeds"
#~ msgstr "Додаток синдикації для KTorrent, з підтримкою подач RSS і Atom"

#~ msgctxt "Name"
#~ msgid "UPnP"
#~ msgstr "UPnP"

#~ msgctxt "Comment"
#~ msgid "Forward ports using UPnP"
#~ msgstr "Переспрямування портів за допомогою UPnP"

#~ msgctxt "Name"
#~ msgid "Zeroconf"
#~ msgstr "Zeroconf"

#~ msgctxt "Comment"
#~ msgid "Discover peers on the local network using the Zeroconf protocol"
#~ msgstr "Виявляє вузли у локальній мережі за допомогою протоколу Zeroconf"

#~ msgctxt "Name"
#~ msgid "Scripting"
#~ msgstr "Запис сценаріїв"

#~ msgctxt "Comment"
#~ msgid "Enables Kross scripting support"
#~ msgstr "Уможливлює підтримку Kross"

#~ msgctxt "Name"
#~ msgid "Automatic Remove"
#~ msgstr "Автоматичне вилучення"

#~ msgctxt "Comment"
#~ msgid ""
#~ "Script to automatically remove torrents when they finish downloading or "
#~ "seeding"
#~ msgstr ""
#~ "Скрипт для автоматичного вилучення торентів після завершення їхнього "
#~ "отримання або поширення."

#~ msgctxt "Name"
#~ msgid "Automatic Resume"
#~ msgstr "Автоматичне відновлення"

#~ msgctxt "Comment"
#~ msgid ""
#~ "Script to automatically resume after some time, when the suspended state "
#~ "is enabled"
#~ msgstr ""
#~ "Скрипт для автоматичного поновлення через певний проміжок часу, якщо "
#~ "увімкнено стан присипляння."

#~ msgctxt "Name"
#~ msgid "E-Mail Notifications"
#~ msgstr "Сповіщення електронною поштою"

#~ msgctxt "Comment"
#~ msgid "Script to notify you of events via e-mail"
#~ msgstr "Скрипт для вашого сповіщення про події електронною поштою"

#~ msgctxt "Name"
#~ msgid "Tracker Grouping"
#~ msgstr "Групування координаторів"

#~ msgctxt "Comment"
#~ msgid "Script to create automatic groups based upon tracker URLs"
#~ msgstr "Скрипт для створення автоматичних груп за адресами координаторів"

#~ msgctxt "Comment"
#~ msgid "Plasma widget to keep track of a single torrent"
#~ msgstr "Віджет Плазми для стеження за окремим торентом"

#~ msgctxt "Comment"
#~ msgid "KTorrent data engine, for getting information from KTorrent"
#~ msgstr "Рушій даних KTorrent, для отримання відомостей від KTorrent"

#~ msgctxt "Name"
#~ msgid "Web Interface"
#~ msgstr "Вебінтерфейс"

#~ msgctxt "Comment"
#~ msgid "Allows control of KTorrent via a web interface"
#~ msgstr "Керування KTorrent за допомогою мережевого інтерфейсу"

#~ msgctxt "Name"
#~ msgid "KTorrent Plugin"
#~ msgstr "Додаток до KTorrent"

#~ msgctxt "Name"
#~ msgid "KTorrent Plasma Applet"
#~ msgstr "Аплет Плазми для KTorrent"
