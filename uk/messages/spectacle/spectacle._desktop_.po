#: desktop/org.kde.spectacle.desktop.cmake:611
msgctxt "Name"
msgid "Launch without taking a screenshot"
msgstr "Запустити без створення знімка"

#: desktop/spectacle.notifyrc:57
msgctxt "Comment"
