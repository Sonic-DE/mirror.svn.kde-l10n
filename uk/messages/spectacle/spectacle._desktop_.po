#: desktop/org.kde.spectacle.desktop.cmake:2
msgctxt "GenericName"
msgid "Screenshot Capture Utility"
msgstr "Програма для створення знімків екрана"

#: desktop/org.kde.spectacle.desktop.cmake:56 desktop/spectacle.notifyrc:4
msgctxt "Name"
msgid "Spectacle"
msgstr "Spectacle"

#: desktop/org.kde.spectacle.desktop.cmake:109
msgctxt "Comment"
msgid "Take screenshots and screen recordings"
msgstr "Створення знімків вікон та записів з екрана"

#: desktop/org.kde.spectacle.desktop.cmake:147
msgctxt "Keywords"
msgid "snapshot;capture;print;screenshot;snipping;snipping tool;snip;"
msgstr ""
"знімок;захоплення;друк;знімок вікна;вікно;знімок екрана;екран;нарізка;"
"нарізання;snapshot;capture;print;screenshot;snipping;snip;"

