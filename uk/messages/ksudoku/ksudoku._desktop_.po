#: src/gui/org.kde.ksudoku.desktop:2
msgctxt "Name"
msgid "KSudoku"
msgstr "KSudoku"

#: src/gui/org.kde.ksudoku.desktop:63
msgctxt "GenericName"
msgid "Sudoku Game"
msgstr "Гра у судоку"

#: src/gui/org.kde.ksudoku.desktop:119
msgctxt "Comment"
msgid "KSudoku, Sudoku game & more by KDE"
msgstr "KSudoku, гра у судоку і інше від KDE"

#: src/shapes/4x4.desktop:2
msgctxt "Name"
msgid "4x4"
msgstr "4x4"

#: src/shapes/4x4.desktop:66
msgctxt "Description"
msgid "4x4 shape puzzle"
msgstr "Головоломка 4x4 частинки"

#: src/shapes/6x6.desktop:2
msgctxt "Name"
msgid "6x6"
msgstr "6x6"

#: src/shapes/6x6.desktop:52
msgctxt "Description"
msgid "6x6 puzzle with rectangular blocks"
msgstr "Поле 6x6 з прямокутними блоками"

#: src/shapes/Aztec.desktop:2
msgctxt "Name"
msgid "Aztec"
msgstr "Ацтецька"

#: src/shapes/Aztec.desktop:56
msgctxt "Description"
msgid "Jigsaw variant shaped like an Aztec pyramid"
msgstr "Варіант мозаїки у формі, подібній до ацтецької піраміди"

#: src/shapes/DoubleRoxdoku.desktop:2
msgctxt "Name"
msgid "Double Roxdoku"
msgstr "Подвійне роксдоку"

#: src/shapes/DoubleRoxdoku.desktop:49
msgctxt "Description"
msgid "Three-dimensional puzzle with two interlocking 3x3x3 cubes"
msgstr ""
"Тривимірна головоломка з двома взаємопов’язаними кубічними частинами 3⨯3⨯3"

#: src/shapes/Jigsaw.desktop:2
msgctxt "Name"
msgid "Jigsaw"
msgstr "Мозаїка"

#: src/shapes/Jigsaw.desktop:58
msgctxt "Description"
msgid "Jigsaw shape puzzle"
msgstr "Головоломка з вирізаними шматками дошки"

#: src/shapes/Killer_4x4.desktop:2
msgctxt "Name"
msgid "Tiny Killer"
msgstr "Малий кілер"

#: src/shapes/Killer_4x4.desktop:43
msgctxt "Description"
msgid "4x4 Sudoku, but cages must add to totals shown"
msgstr "Судоку 4x4, але блоки мають складати сумі показане число"

#: src/shapes/Killer_9x9.desktop:2
msgctxt "Name"
msgid "Killer Sudoku"
msgstr "Судоку-кілер"

#: src/shapes/Killer_9x9.desktop:43
msgctxt "Description"
msgid "Classic Sudoku, but cages must add to totals shown"
msgstr "Класичне судоку, але блоки мають складати у сумі показане число"

#: src/shapes/Mathdoku_4x4.desktop:2
msgctxt "Name"
msgid "Mathdoku 101"
msgstr "Матдоку 101"

#: src/shapes/Mathdoku_4x4.desktop:43
msgctxt "Description"
msgid "Size 4x4 grid, with calculated cages"
msgstr "Ґратка розміром 4x4, із обчисленими блоками"

#: src/shapes/Mathdoku_Settable.desktop:2
msgctxt "Name"
msgid "Mathdoku - Settable Size"
msgstr "Матдоку — змінний розмір"

#: src/shapes/Mathdoku_Settable.desktop:43
msgctxt "Description"
msgid "Size 3x3 to 9x9 grid, with calculated cages"
msgstr "Ґратка розміром від 3x3 до 9x9, із обчисленими блоками"

#: src/shapes/Nonomino.desktop:2
msgctxt "Name"
msgid "Nonomino 9x9"
msgstr "Нономіно 9x9"

#: src/shapes/Nonomino.desktop:49
msgctxt "Description"
msgid "Jigsaw variant with irregularly shaped Nonomino blocks"
msgstr "Варіант мозаїки з блоками нономіно неправильної форми"

#: src/shapes/Pentomino.desktop:2
msgctxt "Name"
msgid "Pentomino 5x5"
msgstr "Пентоміно 5x5"

#: src/shapes/Pentomino.desktop:50
msgctxt "Description"
msgid "Jigsaw variant with irregularly shaped Pentomino blocks"
msgstr "Варіант мозаїки з блоками пентоміно неправильної форми"

#: src/shapes/RoxdokuTwin.desktop:2
msgctxt "Name"
msgid "Roxdoku Twin"
msgstr "Роксдоку-близнюки"

#: src/shapes/RoxdokuTwin.desktop:48
msgctxt "Description"
msgid "Three-dimensional puzzle with two 3x3x3 cubes which share a corner"
msgstr ""
"Тривимірна головоломка з двома кубічними частинами 3⨯3⨯3, що перетинаються "
"кутом"

#: src/shapes/Samurai.desktop:2
msgctxt "Name"
msgid "Samurai"
msgstr "Самурай"

#: src/shapes/Samurai.desktop:59
msgctxt "Description"
msgid "Samurai shape puzzle"
msgstr "Головоломка з частинок «Самурай»"

#: src/shapes/SamuraiRoxdoku.desktop:2
msgctxt "Name"
msgid "Samurai Roxdoku"
msgstr "Самурайське роксдоку"

#: src/shapes/SamuraiRoxdoku.desktop:49
msgctxt "Description"
msgid "Samurai three-dimensional puzzle with nine 3x3x3 cubes"
msgstr ""
"Самурайська тривимірна головоломка з дев’ятьма кубічними частинами 3⨯3⨯3"

#: src/shapes/Sohei.desktop:2
msgctxt "Name"
msgid "Sohei"
msgstr "Сохей"

#: src/shapes/Sohei.desktop:51
msgctxt "Description"
msgid "Sohei puzzle with four overlapping 9x9 squares"
msgstr "Варіант сохей з чотирма квадратами 9x9, що перекриваються"

#: src/shapes/Tetromino.desktop:2
msgctxt "Name"
msgid "Tetromino 4x4"
msgstr "Тетроміно 4x4"

#: src/shapes/Tetromino.desktop:50
msgctxt "Description"
msgid "Jigsaw with Tetromino blocks (Tetris pieces)"
msgstr "Мозаїка з блоків тетроміно (подібних до блоків у тетрісі)"

#: src/shapes/TinySamurai.desktop:2
msgctxt "Name"
msgid "Tiny Samurai"
msgstr "Маленький самурай"

#: src/shapes/TinySamurai.desktop:58
msgctxt "Description"
msgid "A smaller samurai puzzle"
msgstr "Менша головоломка «Самурай»"

#: src/shapes/Windmill.desktop:2
msgctxt "Name"
msgid "Windmill"
msgstr "Вітряк"

#: src/shapes/Windmill.desktop:51
msgctxt "Description"
msgid "Windmill puzzle with five overlapping 9x9 squares"
msgstr "Варіант «вітряк» з п’ятьма квадратами 9x9, що перекриваються"

#: src/shapes/XSudoku.desktop:2
msgctxt "Name"
msgid "XSudoku"
msgstr "Кроссудоку"

#: src/shapes/XSudoku.desktop:58
msgctxt "Description"
msgid "XSudoku shape puzzle"
msgstr "Головоломка з правилами кроссудоку"

#: src/themes/abstraction.desktop:2
msgctxt "Name"
msgid "Abstraction"
msgstr "Абстракція"

#: src/themes/abstraction.desktop:51
msgctxt "Description"
msgid "A ksudoku theme with abstract artwork."
msgstr "Тема ksudoku у дусі абстрактного мистецтва."

#: src/themes/default.desktop:2
msgctxt "Name"
msgid "ksudoku_egyptian"
msgstr "ksudoku_egyptian"

#: src/themes/default.desktop:49
msgctxt "Description"
msgid "KSudoku egyptian style theme"
msgstr "KSudoku, тема у єгипетському стилі"

#: src/themes/ksudoku_scrible.desktop:2
msgctxt "Name"
msgid "Scribble"
msgstr "Шкрябанина"

#: src/themes/ksudoku_scrible.desktop:58
msgctxt "Description"
msgid "KSudoku Scribble theme for KDE 4"
msgstr "Тема «Карлючки» KSudoku для KDE 4"
