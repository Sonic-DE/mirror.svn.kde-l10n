msgstr "Шаблони для C++, Ruby, Python та PHP."

#. (itstool) path: ul/li
#: org.kde.kapptemplate.appdata.xml:19
msgid "Categories"
msgstr "Категорії."

#. (itstool) path: ul/li
#: org.kde.kapptemplate.appdata.xml:20
