#: modules/account/metadata.json
msgctxt "Description"
msgid "Allow the user to set the account name."
msgstr "Дозволити користувачеві встановлювати назву облікового запису."

#: modules/cellular/metadata.json
msgctxt "Description"
msgid "Allow the user to configure the cellular network."
msgstr "Дозволити користувачеві налаштовувати стільникову мережу."

#: modules/finished/metadata.json
msgctxt "Description"
msgid ""
"Shown when the initial system setup is completed, and the user can commit "
"the changes."
msgstr ""
"Буде показано після завершення початкового налаштовування системи, і "
"користувач зможе вносити зміни."

#: modules/hostname/metadata.json
msgctxt "Description"
msgid "Allow the user to set the system hostname."
msgstr "Дозволити користувачеві встановлювати назву вузла систми."

#: modules/keyboard/metadata.json
msgctxt "Description"
msgid "Allow the user to choose the keyboard layout."
msgstr "Дозволити користувачеві вибирати розкладку клавіатури."

#: modules/language/metadata.json
msgctxt "Description"
msgid "Allow the user to set the system language."
msgstr "Дозволити користувачеві встановлювати мову інтерфейсу системи."

#: modules/prepare/metadata.json
msgctxt "Description"
msgid "Allows the user to configure the environment before using it."
msgstr "Дозволяє користувачеві налаштовувати середовище до його використання."

#: modules/time/metadata.json
msgctxt "Description"
msgid "Allow the user to set the timezone."
msgstr "Дозволити користувачеві встановлювати часовий пояс."

#: modules/wifi/metadata.json
msgctxt "Description"
msgid "Allow the user to connect to a Wi-Fi network."
msgstr "Дозволити користувачеві встановлювати з'єднання з мережею Wi-Fi."

