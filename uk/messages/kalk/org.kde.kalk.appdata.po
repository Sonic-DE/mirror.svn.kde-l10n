#. (itstool) path: component/name
#: org.kde.kalk.appdata.xml:12
msgid "Calculator"
msgstr "Калькулятор"

#. (itstool) path: component/summary
#: org.kde.kalk.appdata.xml:13
msgid "A feature rich calculator"
msgstr "Калькулятор із широкими можливостями"

#. (itstool) path: description/p
#: org.kde.kalk.appdata.xml:18
msgid "Kalk is a convergent calculator for Plasma."
msgstr "Kalk — потужний калькулятор для Плазми."

#. (itstool) path: screenshot/caption
#: org.kde.kalk.appdata.xml:22
msgid "Calculator Page"
msgstr "Сторінка «Калькулятора»"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:95
msgid "Show decimal separator according to locale"
msgstr "Показ десяткового роздільника відповідно до локалі"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:96
msgid "Fix bug preventing input of comma"
msgstr "Виправлено ваду, яка заважала введенню коми"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:104
msgid "General bugfixing and code quality improvements"
msgstr "Загальне виправлення вад та удосконалення якості коду"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:112
msgid "Rearrange trigonometric functions to be together"
msgstr "Тригонометричні функції зібрано разом"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:113
msgid "Various user-interface improvements"
msgstr "Різноманітні удосконалення інтерфейсу користувача"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:120
msgid "Rework sidebar design"
msgstr "Перероблено дизайн бічної панелі"

#. (itstool) path: description/p
#: org.kde.kalk.appdata.xml:133
msgid "Changes:"
msgstr "Зміни:"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:135
msgid "Updated the application icon"
msgstr "Оновлено піктограму програми"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:136
msgid "Added support for parentheses keyboard input"
msgstr "Додано підтримку введення дужок з клавіатури"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:137
msgid "Fixed the calculator drawer opening when the application opens"
msgstr "Виправлено відкриття панелі калькулятора при відкритті вікна програми"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:138
msgid ""
"Changed backspace icon to use a proper system icon instead of a font "
"provided one"
msgstr ""
"Змінено піктограму витирання введеного так, щоб використовувалася належна "
"піктограма з системи, а не піктограма, яку надано шрифтом"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:139
msgid "Added keyboard support to unit converter"
msgstr "Додано підтримку введення з клавіатури на панелі перетворення одиниць"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:140
msgid "Fixed page change animation for binary calculator"
msgstr "Виправлено анімацію зміни сторінок для двійкового калькулятора"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:141
msgid "Enabled qml debugging when compiled in debug mode"
msgstr ""
"Уможливлено діагностику qml, якщо програму зібрано у діагностичному режимі"

#. (itstool) path: ul/li
#: org.kde.kalk.appdata.xml:142
msgid "Added ability to recognize the decimal separator in other locales"
msgstr ""
"Додано можливість розпізнавання десяткового роздільника в інших локалях"

