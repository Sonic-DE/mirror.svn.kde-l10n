#: core/smb4k.notifyrc:3 smb4k/org.kde.smb4k.desktop:3
msgctxt "Name"
msgid "Smb4K"
msgstr "Smb4K"

#: core/smb4k.notifyrc:44 smb4k/org.kde.smb4k.desktop:80
msgctxt "Comment"
msgid "Advanced Network Neighborhood Browser"
msgstr "Переглядач мережевого оточення з додатковими можливостями"

#: core/smb4k.notifyrc:87
msgctxt "Name"
msgid "Notification"
msgstr "Сповіщення"

#: core/smb4k.notifyrc:128
msgctxt "Comment"
msgid "The user is notified about an action"
msgstr "Користувачеві повідомлено про дію"

#: core/smb4k.notifyrc:169
msgctxt "Name"
msgid "Warning"
msgstr "Попередження"

#: core/smb4k.notifyrc:210
msgctxt "Comment"
msgid "A warning is shown to the user"
msgstr "Користувачеві показано попередження"

#: core/smb4k.notifyrc:252
msgctxt "Name"
msgid "Error"
msgstr "Помилка"

#: core/smb4k.notifyrc:293
msgctxt "Comment"
msgid "An error message is shown to the user"
msgstr "Користувачеві показано повідомлення про помилку"

#: core/smb4k.notifyrc:333
msgctxt "Name"
msgid "Share mounted"
msgstr "Змонтовано ресурс"

#: core/smb4k.notifyrc:371
msgctxt "Comment"
msgid "A share has been mounted"
msgstr "Спільний ресурс було змонтовано"

#: core/smb4k.notifyrc:413
msgctxt "Name"
msgid "Share unmounted"
msgstr "Демонтовано ресурс"

#: core/smb4k.notifyrc:451
msgctxt "Comment"
msgid "A share has been unmounted"
msgstr "Спільний ресурс було демонтовано"

#: core/smb4k.notifyrc:493
msgctxt "Name"
msgid "Shares mounted"
msgstr "Змонтовано ресурси"

#: core/smb4k.notifyrc:531
msgctxt "Comment"
msgid "Multiple shares have been mounted"
msgstr "Змонтовано декілька спільних ресурсів"

#: core/smb4k.notifyrc:573
msgctxt "Name"
msgid "Shares unmounted"
msgstr "Демонтовано ресурси"

#: core/smb4k.notifyrc:611
msgctxt "Comment"
msgid "Multiple shares have been unmounted"
msgstr "Демонтовано декілька спільних ресурсів"

#: core/smb4k.notifyrc:653
msgctxt "Name"
msgid "Migrating login credentials"
msgstr "Перенесення реєстраційних даних"

#: core/smb4k.notifyrc:682
msgctxt "Comment"
msgid ""
"The login credentials are migrated to the new format and the active password "
"manager"
msgstr ""
"Реєстраційні дані перенесено до нового формату та активної програми для "
"керування паролями"

#: core/smb4k.notifyrc:714
msgctxt "Name"
msgid "Mimetype not supported"
msgstr "Підтримки типу MIME не передбачено"

#: core/smb4k.notifyrc:752
msgctxt "Comment"
msgid "The mimetype of the file that is to be printed is not supported"
msgstr "Підтримки друку файлів з таким типом MIME не передбачено"

#: core/smb4k.notifyrc:794
msgctxt "Name"
msgid "Bookmark exists"
msgstr "Така закладка вже існує"

#: core/smb4k.notifyrc:832
msgctxt "Comment"
msgid "The bookmark exists"
msgstr "Закладка вже існує"

#: core/smb4k.notifyrc:875
msgctxt "Name"
msgid "Bookmark label in use"
msgstr "Мітку закладки вже використано"

#: core/smb4k.notifyrc:913
msgctxt "Comment"
msgid "The label for the bookmark already exists"
msgstr "Мітка для закладки вже існує"

#: core/smb4k.notifyrc:956
msgctxt "Name"
msgid "Mounting failed"
msgstr "Невдала спроба монтування"

#: core/smb4k.notifyrc:995
msgctxt "Comment"
msgid "Mounting a share failed"
msgstr "Спроба монтування спільного ресурсу зазнала невдачі"

#: core/smb4k.notifyrc:1038
msgctxt "Name"
msgid "Unmounting failed"
msgstr "Помилка демонтування"

#: core/smb4k.notifyrc:1077
msgctxt "Comment"
msgid "Unmounting a share failed"
msgstr "Помилка демонтування ресурсу"

#: core/smb4k.notifyrc:1120
msgctxt "Name"
msgid "Unmounting not allowed"
msgstr "Демонтування заборонено"

#: core/smb4k.notifyrc:1158
msgctxt "Comment"
msgid "The unmounting of a certain share is not allowed"
msgstr "Демонтування певного ресурсу заборонено"

#: core/smb4k.notifyrc:1201
msgctxt "Name"
msgid "Synchronization failed"
msgstr "Невдала спроба синхронізації"

#: core/smb4k.notifyrc:1240
msgctxt "Comment"
msgid "The synchronization of a share and a local copy failed"
msgstr ""
"Спроба виконання синхронізації між спільним ресурсом і локальною копією "
"зазнала невдачі"

#: core/smb4k.notifyrc:1282
msgctxt "Name"
msgid "Command not found"
msgstr "Команду не знайдено"

#: core/smb4k.notifyrc:1322
msgctxt "Comment"
msgid "A required command could not be found"
msgstr "Не вдалося знайти потрібної вам команди"

#: core/smb4k.notifyrc:1365
msgctxt "Name"
msgid "Cannot bookmark printer"
msgstr "Не можна створювати закладки для принтерів"

#: core/smb4k.notifyrc:1403
msgctxt "Comment"
msgid "A printer cannot be bookmarked"
msgstr "Не можна створювати закладку на принтер"

#: core/smb4k.notifyrc:1446
msgctxt "Name"
msgid "File not found"
msgstr "Файл не знайдено"

#: core/smb4k.notifyrc:1487
msgctxt "Comment"
msgid "A file could not be found"
msgstr "Не вдалося знайти файл"

#: core/smb4k.notifyrc:1530
msgctxt "Name"
msgid "Opening file failed"
msgstr "Спроба відкриття файла зазнала невдачі"

#: core/smb4k.notifyrc:1568
msgctxt "Comment"
msgid "A file could not be opened"
msgstr "Не вдалося відкрити файл"

#: core/smb4k.notifyrc:1611
msgctxt "Name"
msgid "Reading file failed"
msgstr "Помилка читання файла"

#: core/smb4k.notifyrc:1649
msgctxt "Comment"
msgid "A file could not be read"
msgstr "Не вдалося прочитати файл"

#: core/smb4k.notifyrc:1692
msgctxt "Name"
msgid "mkdir failed"
msgstr "Помилка mkdir"

#: core/smb4k.notifyrc:1731
msgctxt "Comment"
msgid "A directory could not be created"
msgstr "Не вдалося створити каталог"

#: core/smb4k.notifyrc:1774
msgctxt "Name"
msgid "Process error"
msgstr "Помилка процесу"

#: core/smb4k.notifyrc:1814
msgctxt "Comment"
msgid "A process error occurred"
msgstr "Помилка під час роботи процесу"

#: core/smb4k.notifyrc:1857
msgctxt "Name"
msgid "Action failed"
msgstr "Спроба виконання дії зазнала невдачі"

#: core/smb4k.notifyrc:1897
msgctxt "Comment"
msgid "A KAuth action failed"
msgstr "Спроба виконання дії KAuth зазнала невдачі"

#: core/smb4k.notifyrc:1939
msgctxt "Name"
msgid "Invalid URL"
msgstr "Некоректна адреса"

#: core/smb4k.notifyrc:1980
msgctxt "Comment"
msgid "An invalid URL was passed"
msgstr "Було передано некоректну адресу"

#: core/smb4k.notifyrc:2022
msgctxt "Name"
msgid "Network communication failed"
msgstr "Невдала спроба обміну даними мережею"

#: core/smb4k.notifyrc:2057
msgctxt "Comment"
msgid "A network related action could not be performed or failed"
msgstr ""
"Не вдалося виконати пов'язану із мережею дію або спроба виконання дії "
"зазнала невдачі"

#: core/smb4k.notifyrc:2097
msgctxt "Name"
msgid "Zeroconf error"
msgstr "Помилка Zeroconf"

#: core/smb4k.notifyrc:2130
msgctxt "Comment"
msgid "An error with the Zeroconf daemon occurred"
msgstr "Сталася помилка, яку пов'язано із фоновою службою Zeroconf"

#: core/smb4k.notifyrc:2167
msgctxt "Name"
msgid "Keychain error"
msgstr "Помилка ланцюжка ключів"

#: core/smb4k.notifyrc:2196
msgctxt "Comment"
msgid ""
"An error occurred while reading the login credentials from the secure storage"
msgstr ""
"Під час спроби прочитати реєстраційні дані для входу з захищеного сховища "
"сталася помилка"

#: helpers/smb4kmounthelper.actions:2
msgctxt "Name"
msgid "Mount action"
msgstr "Дія з монтування"

#: helpers/smb4kmounthelper.actions:39
msgctxt "Description"
msgid "Mounts a share"
msgstr "Монтування ресурсу"

#: helpers/smb4kmounthelper.actions:80
msgctxt "Name"
msgid "Unmount action"
msgstr "Дія з демонтування"

#: helpers/smb4kmounthelper.actions:117
msgctxt "Description"
msgid "Unmounts a share"
msgstr "Демонтування ресурсу"

#: smb4k/org.kde.smb4k.desktop:44
