#: app/ark_dndextract.json.cmake
msgctxt "Name"
msgid "Ark Extract Here"
msgstr "Розпакувати сюди за допомогою Ark"

#: app/compressfileitemaction.json
msgctxt "Name"
msgid "'Compress' service menu"
msgstr "Службове меню «Стиснути»"

#: app/extractfileitemaction.json
msgctxt "Name"
msgid "'Extract' service menu"
msgstr "Службове меню «Видобути»"

#: part/ark_part.json.cmake
msgctxt "Name"
msgid "Archiver"
msgstr "Архіватор"

#: plugins/cli7zplugin/kerfuffle_cli7z.json.cmake
msgctxt "Name"
msgid "7z plugin"
msgstr "Додаток 7z"

#: plugins/cliarjplugin/kerfuffle_cliarj.json.cmake
msgctxt "Name"
msgid "ARJ plugin"
msgstr "Додаток ARJ"

#: plugins/clirarplugin/kerfuffle_clirar.json.cmake
msgctxt "Name"
msgid "RAR plugin"
msgstr "Додаток RAR"

#: plugins/cliunarchiverplugin/kerfuffle_cliunarchiver.json.cmake
msgctxt "Name"
msgid "The Unarchiver plugin"
msgstr "Додаток Unarchiver"

#: plugins/clizipplugin/kerfuffle_clizip.json.cmake
msgctxt "Name"
msgid "Info-zip plugin"
msgstr "Додаток info-zip"

#: plugins/libarchive/kerfuffle_libarchive.json.cmake
msgctxt "Name"
msgid "Libarchive plugin"
msgstr "Додаток libarchive"

#: plugins/libarchive/kerfuffle_libarchive_readonly.json.cmake
msgctxt "Name"
msgid "Libarchive plugin (read-only formats)"
msgstr "Додаток libarchive (формати лише для читання)"

#: part/ark_part.json.cmake
msgctxt "Description"
msgid "Archive Handling Tool"
msgstr "Інструмент для роботи з архівами"

#: plugins/cli7zplugin/kerfuffle_cli7z.json.cmake
msgctxt "Description"
msgid "Full support for the zip and 7z archive formats"
msgstr "Повноцінна підтримка архівів у форматах zip і 7z"

#: plugins/cliarjplugin/kerfuffle_cliarj.json.cmake
msgctxt "Description"
msgid "Full support for the ARJ archive formats"
msgstr "Повноцінна підтримка архівів у форматі ARJ"

#: plugins/clirarplugin/kerfuffle_clirar.json.cmake
msgctxt "Description"
msgid "Full support for the RAR archive format"
msgstr "Повноцінна підтримка архівів у форматі RAR"

#: plugins/cliunarchiverplugin/kerfuffle_cliunarchiver.json.cmake
msgctxt "Description"
msgid "Open and extract RAR and LHA archives"
msgstr "Здатен відкривати і видобувати архіви RAR і LHA"

#: plugins/clizipplugin/kerfuffle_clizip.json.cmake
msgctxt "Description"
msgid "Legacy support for the zip archive format"
msgstr "Підтримка архівів у застарілій версії формату zip"

#: plugins/libarchive/kerfuffle_libarchive.json.cmake
msgctxt "Description"
msgid "Full support for compressed TAR archives"
msgstr "Повноцінна підтримка стиснених архівів TAR"

#: plugins/libarchive/kerfuffle_libarchive_readonly.json.cmake
msgctxt "Description"
msgid "Open and extract DEB, RPM, ISO, AppImage, XAR, CAB, and EXE files"
msgstr ""
"Здатен відкривати і видобувати дані з архівів DEB, RPM, ISO, AppImage, XAR, "
"CAB та EXE"

