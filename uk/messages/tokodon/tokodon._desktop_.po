msgid "Update"
msgstr "Оновлення"

#: src/tokodon.notifyrc:472
msgctxt "Comment"
msgid "Someone edited a post"
msgstr "Хтось вніс зміни до допису"

#: src/tokodon.notifyrc:508
msgctxt "Name"
msgid "Poll"
msgstr "Голосування"

#: src/tokodon.notifyrc:540
msgctxt "Comment"
msgid "Someone's poll ended"
msgstr "Чиєсь голосування завершено"

#: src/tokodon.notifyrc:574
msgctxt "Name"
msgid "Status"
msgstr "Стан"

#: src/tokodon.notifyrc:606
msgctxt "Comment"
msgid "Someone posted a new status"
msgstr "Кимось оприлюднено новий стан"

#: src/tokodon.notifyrc:641
msgctxt "Name"
msgid "Quote"
msgstr "Цитування"

