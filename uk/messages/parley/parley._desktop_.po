#~ msgctxt "Name"
#~ msgid "Example Parley Script"
#~ msgstr "Приклад скрипту Parley"

#~ msgctxt "Comment"
#~ msgid ""
#~ "This example script offers two actions: 1) Move selected vocabulary to a "
#~ "different lesson 2) Change the grade of selected words to known (highest "
#~ "grade)"
#~ msgstr ""
#~ "Цей скрипт-зразок виконує дві функції: 1) Переміщує вибраний словник до "
#~ "іншого уроку. 2) Змінює клас вибраних слів на відому (найвищий клас)."

#~ msgctxt "Name"
#~ msgid "Google Dictionary (translation)"
#~ msgstr "Словник Google (переклад)"

#~ msgctxt "Comment"
#~ msgid "Uses Google Dictionary (translate.google.com) to translate words"
#~ msgstr ""
#~ "Використовує словник Google (translate.google.com) для перекладу слів"

#~ msgctxt "Name"
#~ msgid "LEO Dictionary (Translation)"
#~ msgstr "Словник LEO (переклад)"

#~ msgctxt "Comment"
#~ msgid "Uses LEO Dictionary (dict.leo.org) to translate words"
#~ msgstr "Використовує словник LEO (dict.leo.org) для перекладу слів"

#~ msgctxt "Name"
#~ msgid "Testing Purposes Script"
#~ msgstr "Скрипт для тестування"

#~ msgctxt "Comment"
#~ msgid "Description of what the plugin does"
#~ msgstr "Опис того, що робить додаток"

#~ msgctxt "Name"
#~ msgid "Wiktionary Sound"
#~ msgstr "Звук з Вікісловника"

#~ msgctxt "Comment"
#~ msgid "This script fetches sound files from https://commons.wikimedia.org."
#~ msgstr "Цей скрипт отримує звукові файли з https://commons.wikimedia.org."

#~ msgctxt "Comment"
