#: src/app/org.kde.publicalerts.desktop:2 src/app/publicalerts.notifyrc:4
msgctxt "Name"
msgid "Public Alerts"
msgstr "Попередження цивільного захисту"

#: src/app/org.kde.publicalerts.desktop:30
msgctxt "Comment"
msgid "Weather and emergency alerts."
msgstr "Попередження про природні та аварійні ситуації."

#: src/app/publicalerts.notifyrc:29
msgctxt "Comment"
msgid "Emergency and weather alerts."
msgstr "Попередження про аварійні та природні ситуації."

#: src/app/publicalerts.notifyrc:56
msgctxt "Name"
msgid "Extreme Alert"
msgstr "Попередження про надзвичайні ситуації"

#: src/app/publicalerts.notifyrc:81
msgctxt "Comment"
msgid "Extraordinary threat to life or property."
msgstr "Надзвичайні загрози життю або майну."

#: src/app/publicalerts.notifyrc:110
msgctxt "Name"
msgid "Severe Alert"
msgstr "Попередження про критичні ситуації"

#: src/app/publicalerts.notifyrc:135
msgctxt "Comment"
msgid "Significant threat to life or property."
msgstr "Значна загроза життю або майну."

#: src/app/publicalerts.notifyrc:164
msgctxt "Name"
msgid "Moderate Alert"
msgstr "Попередження про значну загрозу"

#: src/app/publicalerts.notifyrc:189
msgctxt "Comment"
msgid "Possible threat to life or property."
msgstr "Можлива загроза життю або майну."

#: src/app/publicalerts.notifyrc:218
msgctxt "Name"
msgid "Minor Alert"
msgstr "Попередження про незначну загрозу"

#: src/app/publicalerts.notifyrc:243
msgctxt "Comment"
msgid "Minimal or no threat to life or property."
msgstr "Мінімальна загроза життю або майну."
