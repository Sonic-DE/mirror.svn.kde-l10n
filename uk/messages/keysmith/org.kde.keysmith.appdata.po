#: org.kde.keysmith.appdata.xml:10 org.kde.keysmith.appdata.xml:43
msgid "Keysmith"
msgstr "Keysmith"

#. (itstool) path: component/summary
#: org.kde.keysmith.appdata.xml:31
msgid "Two-factor code generator for Plasma Mobile and Desktop"
msgstr ""
"Засіб для створення двофакторних кодів для мобільної і стільничної Плазми"

#. (itstool) path: description/p
#: org.kde.keysmith.appdata.xml:36
msgid "Keysmith generates tokens for your two-factor logins (2FA)"
msgstr "Keysmith створює ключі для двофакторного входу (2FA)"

#. (itstool) path: ul/li
#: org.kde.keysmith.appdata.xml:38
msgid "Time and Hash-based OTP"
msgstr "OTP на основі часових даних і хешів"

#. (itstool) path: ul/li
#: org.kde.keysmith.appdata.xml:99
msgid "General code improvements and bugfixing"
msgstr "Загальне удосконалення програмного коду та виправлення вад"

#. (itstool) path: ul/li
#: org.kde.keysmith.appdata.xml:110
msgid "Reduce default size of main window"
msgstr "Зменшено типовий розмір головного вікна"

#. (itstool) path: ul/li
#: org.kde.keysmith.appdata.xml:111
msgid "Focus password field by default on launch"
msgstr "Реалізовано типове фокусування поля пароля після запуску"

#. (itstool) path: description/p
#: org.kde.keysmith.appdata.xml:126
msgid "Plasma Mobile Gear 21.06 release"
msgstr "Випуск Plasma Mobile Gear 21.06"

#. (itstool) path: ul/li
#: org.kde.keysmith.appdata.xml:128
msgid "Basic support for account issuer property in keysmith"
msgstr "Базова підтримка властивості видавця облікового запису у keysmith"

#. (itstool) path: ul/li
#: org.kde.keysmith.appdata.xml:129
msgid "Support configuring issuer when adding new account"
msgstr ""
"Реалізовано підтримку налаштовування видавця при додаванні нового облікового "
"запису"

#. (itstool) path: ul/li
#: org.kde.keysmith.appdata.xml:130
msgid "Support for configuring advanced HOTP/TOTP token details"
msgstr ""
"Реалізовано підтримку налаштовування додаткових параметрів жетона HOTP/TOTP"

#. (itstool) path: ul/li
#: org.kde.keysmith.appdata.xml:131
msgid "Reduce latency when re-computing tokens"
msgstr "Зменшено латентність при повторному обчисленні жетонів"

#. (itstool) path: ul/li
#: org.kde.keysmith.appdata.xml:132
msgid "Add basic support for otpauth:// URI parsing"
msgstr "Додано підтримку обробки адрес otpauth://"

#. (itstool) path: ul/li
#: org.kde.keysmith.appdata.xml:133
msgid "Allow to accept otpauth:// URI from command line"
msgstr "Уможливлено прийняття адреси otpauth:// з командного рядка"

#. (itstool) path: ul/li
#: org.kde.keysmith.appdata.xml:134
msgid ""
"Add a page to recover when account turns out to be already used while adding "
"it"
msgstr ""
"Додано сторінку відновлення при роботі з обліковими записами, які вже було "
"використано, під час додавання записів"

#. (itstool) path: ul/li
#: org.kde.keysmith.appdata.xml:135
msgid "Add actions to dismiss/cancel an add account form"
msgstr ""
"Додано дії для закриття або скасування форми додавання облікового запису"

#. (itstool) path: ul/li
#: org.kde.keysmith.appdata.xml:136
msgid ""
"Respond to D-Bus activation, allows to open keysmith when already running"
msgstr ""
"Реалізовано відповідь на активацію D-Bus, що уможливлює відкриття keysmith, "
"якщо програму вже запущено"

