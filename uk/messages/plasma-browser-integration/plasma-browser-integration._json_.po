#: flatpak-integrator/browserintegrationflatpakintegrator.json
msgctxt "Name"
msgid "Plasma Browser Integration Flatpak Integration"
msgstr "Інтеграція Flatpak як браузера Плазми"

#: reminder/browserintegrationreminder.json
msgctxt "Name"
msgid "Plasma Browser Integration Installation Reminder"
msgstr "Нагадування щодо встановлення інтеграції браузера із Плазмою"

#: flatpak-integrator/browserintegrationflatpakintegrator.json
msgctxt "Description"
msgid "Automatically enables support for Firefox Flatpak"
msgstr "Автоматично вмикає підтримку для Flatpak Firefox"

#: reminder/browserintegrationreminder.json
msgctxt "Description"
msgid ""
"Provides a link to the browser extension if the Plasma Browser Integration "
"host is installed"
msgstr ""
"Надає посилання на розширення браузера, якщо встановлено основну частину "
"засобу інтеграції браузера із Плазмою"

#~ msgctxt "Name"
#~ msgid "Plasma Browser Integration Host"
#~ msgstr "Вузол інтеграції браузера із Плазмою"

#~ msgctxt "Name|plasma runner"
#~ msgid "Browser History"
#~ msgstr "Журнал навігатора"

#~ msgctxt "Comment"
#~ msgid "Search the browser history for visited websites"
#~ msgstr "Пошук у журналі перегляду інтернету щодо відвіданих сайтів"

