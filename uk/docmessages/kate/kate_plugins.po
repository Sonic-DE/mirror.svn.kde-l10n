msgstr ""
"Запускає виконання програми до інструкції, у якій зараз перебуває курсор."

#. Tag: menuchoice
#: plugins.docbook:1740
#, no-c-format
msgid "<guimenu>Debug</guimenu><guimenuitem>Continue</guimenuitem>"
msgstr "<guimenu>Налагоджування</guimenu><guimenuitem>Продовжити</guimenuitem>"

#. Tag: para
#: plugins.docbook:1743
