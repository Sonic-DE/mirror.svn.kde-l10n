#~ "template &lt;typename T1, typename T2, typename T3&gt;\n"
#~ "class test\n"
#~ "{\n"
#~ "public:\n"
#~ "    /// Default constructor\n"
#~ "    explicit test()\n"
#~ "    {\n"
#~ "    }\n"
#~ "    /// Destructor\n"
#~ "    virtual ~test()\n"
#~ "    {\n"
#~ "    }\n"
#~ "};"
