#~ "режиму зі списку <guisubmenu>Режим перегляду</guisubmenu>."

#~ msgid ""
#~ "If two or more files with the same name (located in different folders) "
#~ "are open in <guimenuitem>List Mode</guimenuitem>, the names of the second "
