#~ msgid "Memory (RAM) : 1 Giga Byte"
#~ msgstr "Пам’ять (RAM): 1 гігабайт"

#~ msgid "Disk : 300 Mega Bytes"
#~ msgstr "Диск: 300 мегабайтів"

#~ msgid ""
#~ "Operating system : &GNU;/&Linux;, &BSD;, MacOSX, &Windows;, Android, "
#~ "SailfishOS"
