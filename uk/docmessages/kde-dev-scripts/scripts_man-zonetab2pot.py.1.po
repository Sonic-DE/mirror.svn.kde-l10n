#. Tag: refpurpose
#: man-zonetab2pot.py.1.docbook:20
#, no-c-format
msgid "Converts a timezone list to a PO file template."
msgstr "Перетворює список часових поясів на шаблон файлів PO."

#. Tag: cmdsynopsis
#: man-zonetab2pot.py.1.docbook:24
#, no-c-format
msgid ""
"<command>zonetab2pot.py</command> <group><option><replaceable>timezone-list</"
"replaceable></option></group>"
msgstr ""
"<command>zonetab2pot.py</command> "
"<group><option><replaceable>список_часових_поясів</replaceable></option></"
"group>"

#. Tag: title
#: man-zonetab2pot.py.1.docbook:32
#, no-c-format
msgid "Description"
msgstr "Опис"

#. Tag: para
#: man-zonetab2pot.py.1.docbook:34
#, no-c-format
msgid ""
"<command>zonetab2pot.py</command> reads the timezone list given on the "
"command-line and converts it to a gettext message file (PO-file) template "
"containing the names of the individual timezones."
msgstr ""
"<command>zonetab2pot.py</command> читає вказаний з командного рядка список "
"часових поясів і перетворює його на шаблон файлів повідомлень gettext (файл "
"PO), у якому містяться назви окремих часових поясів."

#. Tag: para
#: man-zonetab2pot.py.1.docbook:39
#, no-c-format
msgid ""
"The given timezone list should be in the same format as the system zone.tab. "
"If no timezone list is specified on the command-line, <filename>/usr/share/"
"zoneinfo/zone.tab</filename> will be used."
msgstr ""
"Вказаний список часових поясів слід записувати у тому ж форматі, що і "
"системний zone.tab. Якщо у командному рядку не буде вказано списку часових "
"поясів, буде використано файл <filename>/usr/share/zoneinfo/zone.tab</"
"filename>."

#. Tag: para
#: man-zonetab2pot.py.1.docbook:43
#, no-c-format
msgid "The new PO-file template will be written to standard output."
msgstr "Створений файл шаблону файлів PO буде записано до стандартного виводу."

#. Tag: para
#: man-zonetab2pot.py.1.docbook:45
