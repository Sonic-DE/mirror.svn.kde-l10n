#. Tag: phrase
#: index.docbook:1372
#, no-c-format
msgid ""
"<phrase>A screenshot of &kaddressbook;'s <quote>Action</quote> menu.</phrase>"
msgstr "<phrase>Знімок меню «Дія» &kaddressbook;.</phrase>"

