msgstr "<guimenu>Файл</guimenu> <guimenuitem>Показати зображення</guimenuitem>"

#. Tag: para
#: index.docbook:414
#, no-c-format
msgid "<action>Displays </action> the selected image in a new image window."
msgstr ""
"<action>Показує</action> вибране зображення у новому вікні показу зображень."

#. Tag: menuchoice
#: index.docbook:419
#, no-c-format
msgid ""
"<guimenu>File</guimenu> <guimenuitem>Show Image in Active Window</"
"guimenuitem>"
msgstr ""
"<guimenu>Файл</guimenu> <guimenuitem>Показати зображення в активному вікні</"
"guimenuitem>"

#. Tag: para
#: index.docbook:423
#, no-c-format
msgid ""
"<action>Displays </action>the selected image in the active image window."
msgstr ""
"<action>Показує</action> вибране зображення у активному вікні зображення."

#. Tag: menuchoice
#: index.docbook:428
#, no-c-format
msgid ""
"<guimenu>File</guimenu> <guimenuitem>Show Image in Fullscreen Mode</"
"guimenuitem>"
msgstr ""
"<guimenu>Файл</guimenu> <guimenuitem>Показати зображення в повноекранному "
