#: index.docbook:619
#, no-c-format
msgid "Flips the image horizontally"
msgstr "Віддзеркалює зображення горизонтально"

#. Tag: keycap
#: index.docbook:622
#, no-c-format
msgid "<keycap>/</keycap>"
msgstr "<keycap>/</keycap>"

#. Tag: entry
#: index.docbook:623
#, no-c-format
msgid "Flips the image vertically"
msgstr "Віддзеркалює зображення вертикально"

#. Tag: keycap
#: index.docbook:626
#, no-c-format
msgid "<keycap>7</keycap>"
msgstr "<keycap>7</keycap>"

#. Tag: entry
#: index.docbook:627
#, no-c-format
msgid "Rotates 270&deg; clockwise (which is also 90&deg; counter-clockwise)"
msgstr ""
"Обертає зображення на 270&deg; за годинниковою стрілкою (те саме, що поворот "
