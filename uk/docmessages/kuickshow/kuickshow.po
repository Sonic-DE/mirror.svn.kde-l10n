#. Tag: keycap
#: index.docbook:631
#, no-c-format
msgid "<keycap>8</keycap>"
msgstr "<keycap>8</keycap>"

#. Tag: entry
#: index.docbook:632
#, no-c-format
msgid "Rotates 90&deg; clockwise"
msgstr "Обертає зображення на 90&deg; за годинниковою стрілкою"

#. Tag: keycap
#: index.docbook:635
#, no-c-format
msgid "<keycap>9</keycap>"
msgstr "<keycap>9</keycap>"

#. Tag: entry
#: index.docbook:636
#, no-c-format
msgid "Rotates 180&deg; clockwise"
msgstr "Обертає зображення на 180&deg; за годинниковою стрілкою"

#. Tag: entry
#: index.docbook:639
#, no-c-format
msgid "<keycap>Arrow</keycap> keys"
msgstr "Клавіші з <keycap>стрілками</keycap>"

#. Tag: entry
#: index.docbook:640
#, no-c-format
msgid ""
"Move the image (or rather, you, the viewer,) if it is larger than the screen"
msgstr ""
"Пересуває зображення (або, краще сказати, його перегляд), якщо розміри "
"зображення більші за розміри екрана"

#. Tag: keycap
#: index.docbook:644 index.docbook:755
#, no-c-format
msgid "Return"
msgstr "Return"

#. Tag: entry
#: index.docbook:645
#, no-c-format
msgid "Toggles between fullscreen and window mode"
msgstr "Перемикає перегляд між повноекранним режимом і режимом вікна"

#. Tag: keycap
#: index.docbook:648 index.docbook:776
#, no-c-format
msgid "Space"
msgstr "Пробіл"

#. Tag: entry
#: index.docbook:649
#, no-c-format
msgid "Toggles the display of the browser"
msgstr "Вмикає або вимикає показ навігатора"

#. Tag: entry
#: index.docbook:652
#, no-c-format
msgid "&Esc;"
msgstr "&Esc;"

#. Tag: entry
#: index.docbook:653
#, no-c-format
msgid ""
"Closes the image window. This will close &kuickshow; entirely, if you don't "
"have a browser window open."
msgstr ""
"Закриває вікно перегляду зображення. Ця дія завершить роботу &kuickshow;, "
"якщо не відкрито вікно навігатора зображеннями."

#. Tag: entry
#: index.docbook:657
#, no-c-format
msgid ""
"<keycap>B</keycap>/<keycombo action=\"simul\">&Shift;<keycap>B</keycap></"
"keycombo>"
msgstr ""
"<keycap>B</keycap>/<keycombo action=\"simul\">&Shift;<keycap>B</keycap></"
"keycombo>"

#. Tag: entry
#: index.docbook:658
#, no-c-format
msgid "Lightens/darkens the image"
msgstr "Збільшує або зменшує яскравість зображення"

#. Tag: entry
#: index.docbook:661
#, no-c-format
msgid ""
"<keycap>C</keycap>/<keycombo action=\"simul\">&Shift;<keycap>C</keycap></"
"keycombo>"
msgstr ""
"<keycap>C</keycap>/<keycombo action=\"simul\">&Shift;<keycap>C</keycap></"
"keycombo>"

#. Tag: entry
#: index.docbook:662
#, no-c-format
msgid "Adds/Removes contrast"
msgstr "Збільшує або зменшує контрастність зображення"

#. Tag: entry
#: index.docbook:665
#, no-c-format
msgid ""
"<keycap>G</keycap>/<keycombo action=\"simul\">&Shift;<keycap>G</keycap></"
"keycombo>"
msgstr ""
"<keycap>G</keycap>/<keycombo action=\"simul\">&Shift;<keycap>G</keycap></"
"keycombo>"

#. Tag: entry
#: index.docbook:666
#, no-c-format
msgid "More/less <firstterm>gamma</firstterm>"
msgstr "Збільшує або зменшує <firstterm>ступінь контрастності</firstterm>"

#. Tag: keycap
#: index.docbook:669
#, no-c-format
msgid "<keycap>O</keycap>"
msgstr "<keycap>O</keycap>"

#. Tag: entry
#: index.docbook:670
#, no-c-format
msgid ""
"Shows the image in original size. This is only useful when you have enabled "
"automatic scaling."
msgstr ""
"Показує зображення у його початковому розмірі. Це скорочення буде корисним, "
"лише якщо програма працює у режимі автоматично вибору масштабу."

#. Tag: entry
#: index.docbook:674
#, no-c-format
msgid "&Enter;"
msgstr "&Enter;"

#. Tag: entry
#: index.docbook:675
#, no-c-format
msgid "Redisplays the image with the default settings and size."
msgstr "Оновлює показ зображення з типовими параметрами і розмірами."

#. Tag: keycombo
#: index.docbook:679
#, no-c-format
msgid "&Ctrl;<keycap>S</keycap>"
msgstr "&Ctrl;<keycap>S</keycap>"

#. Tag: entry
#: index.docbook:680
#, no-c-format
msgid "Opens the <guilabel>Save As</guilabel> dialog"
msgstr "Відкриває діалогове вікно <guilabel>Зберегти як</guilabel>"

#. Tag: keycap
#: index.docbook:683 index.docbook:794
#, no-c-format
msgid "Delete"
msgstr "Delete"

#. Tag: entry
#: index.docbook:684
#, no-c-format
msgid "Deletes the current image. You will be asked to confirm the request."
msgstr ""
"Вилучає поточне зображення. Програма запитає у вас підтвердження виконання "
"дії."

#. Tag: keycombo
#: index.docbook:688 index.docbook:800
#, no-c-format
msgid "&Shift;<keycap>Delete</keycap>"
msgstr "&Shift;<keycap>Delete</keycap>"

#. Tag: entry
#: index.docbook:689
#, no-c-format
msgid "Deletes the current image without asking for confirmation"
msgstr "Вилучає поточне зображення без підтвердження"

#. Tag: keycombo
#: index.docbook:693
#, no-c-format
msgid "&Alt;<keycap>Return</keycap>"
msgstr "&Alt;<keycap>Return</keycap>"

#. Tag: entry
#: index.docbook:694
#, no-c-format
msgid "Displays the properties of the image"
msgstr "Показує властивості зображення"

#. Tag: keycap
#: index.docbook:697 index.docbook:805
#, no-c-format
msgid "<keycap>F1</keycap>"
msgstr "<keycap>F1</keycap>"

