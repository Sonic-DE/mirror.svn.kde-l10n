msgstr "Передбачено п’ять рівнів складності:"

#. Tag: para
#: index.docbook:182
#, no-c-format
msgid ""
"<guimenuitem>Very easy</guimenuitem>: 12 rows, 12 columns, 5 types of "
"diamonds."
msgstr ""
"<guimenuitem>Дуже простий</guimenuitem>: 12 рядків, 12 стовпчиків, 5 типів "
"діамантів."

#. Tag: para
#: index.docbook:183
#, no-c-format
msgid ""
"<guimenuitem>Easy</guimenuitem>: 10 rows, 10 columns, 5 types of diamonds."
msgstr ""
"<guimenuitem>Простий</guimenuitem>:10 рядків, 10 стовпчиків, 5 типів "
"діамантів."

#. Tag: para
#: index.docbook:184
#, no-c-format
msgid ""
"<guimenuitem>Medium</guimenuitem>: 8 rows, 8 columns, 5 types of diamonds."
msgstr ""
"<guimenuitem> Середній</guimenuitem>:8 рядків, 8 стовпчиків, 5 типів "
"діамантів."

#. Tag: para
#: index.docbook:185
#, no-c-format
msgid ""
"<guimenuitem>Hard</guimenuitem>: 8 rows, 8 columns, 6 types of diamonds."
msgstr ""
"<guimenuitem>Складний</guimenuitem>:8 рядків, 8 стовпчиків, 6 типів "
"діамантів."

#. Tag: para
#: index.docbook:186
#, no-c-format
