msgid "&Ctrl;<keycap>O</keycap>"
msgstr "&Ctrl;<keycap>O</keycap>"

#. Tag: guilabel
#: index.docbook:6992
#, no-c-format
msgid "<guilabel>Previous Track</guilabel>"
msgstr "<guilabel>Попередня композиція</guilabel>"

#. Tag: para
#: index.docbook:6995
#, no-c-format
msgid "Skips back to the last track played within your current session."
msgstr ""
"Повертає програму до відтворення попередньої відтвореної композиції протягом "
"поточного сеансу."

#. Tag: guilabel
#: index.docbook:7003
#, no-c-format
msgid "<guilabel>Play/Pause</guilabel>"
msgstr "<guilabel>Старт/Пауза</guilabel>"

#. Tag: para
#: index.docbook:7006
#, no-c-format
msgid "Starts or temporarily stops the playing of the current media file."
msgstr "Розпочинає або тимчасово зупиняє відтворення поточного файла даних."

#. Tag: keycap
#: index.docbook:7009 index.docbook:8161
#, no-c-format
msgid "Space"
msgstr "Пробіл"

#. Tag: guilabel
#: index.docbook:7014
#, no-c-format
msgid "<guilabel>Stop</guilabel>"
msgstr "<guilabel>Зупинити</guilabel>"

#. Tag: para
#: index.docbook:7017
#, no-c-format
msgid "Stops all playback in progress."
msgstr "Зупиняє відтворення поточної композиції."

#. Tag: guilabel
#: index.docbook:7025
#, no-c-format
msgid "Stop after current Track"
msgstr "Зупинитися після поточної композиції"

#. Tag: para
#: index.docbook:7028
#, no-c-format
msgid ""
"Waits until the current track ends before stopping the playback. This is "
"useful when using a playlist."
msgstr ""
"Очікує на завершення відтворення поточної композиції, перш ніж завершити "
"відтворення. Корисно, якщо ви користуєтеся списком відтворення."

#. Tag: guilabel
#: index.docbook:7036
#, no-c-format
msgid "<guilabel>Next Track</guilabel>"
msgstr "<guilabel>Наступна композиція</guilabel>"

#. Tag: para
#: index.docbook:7039
#, no-c-format
msgid "Skips playback to the next media file in your playlist."
msgstr ""
"Перейти до відтворення наступного файла даних у вашому списку відтворення."

#. Tag: guilabel
#: index.docbook:7044
#, no-c-format
msgid "<guilabel>Quit</guilabel>"
msgstr "<guilabel>Вийти</guilabel>"

#. Tag: para
#: index.docbook:7047
#, no-c-format
msgid "Exits out of &amarok;."
msgstr "Завершує роботу &amarok;."

#. Tag: keycombo
