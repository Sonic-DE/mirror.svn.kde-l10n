#~ msgid ""
#~ "<command>./configure --prefix=`kde-config --prefix`</command> "
#~ "<command>make</command> <command>su -c \"make install\"</command>"
#~ msgstr ""
#~ "<command>./configure --prefix=`kde-config --prefix`</command> "
#~ "<command>make</command> <command>su -c \"make install\"</command>"

#~ msgid "The --enable-final configure flag is no longer supported."
