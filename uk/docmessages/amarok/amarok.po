#, no-c-format
msgid "<guilabel>Play Media...</guilabel>"
msgstr "<guilabel>Відтворити з носія...</guilabel>"

#. Tag: para
#: index.docbook:6984
#, no-c-format
msgid "Opens a media file to be played."
msgstr "Відкриває файл даних для відтворення."

