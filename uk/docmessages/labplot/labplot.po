#: index.docbook:1931
#, no-c-format
msgid ""
"relative Pochhammer symbol ((a,x) - 1)/x where (a,x) = (a)<subscript>x</"
"subscript> := &Gamma;(a + x)/&Gamma;(a)"
msgstr ""
"відносний символ Похгаммера ((a,x) - 1)/x де (a,x) = (a)<subscript>x</"
"subscript> := &Gamma;(a + x)/&Gamma;(a)"

#. Tag: entry
#: index.docbook:1932
#, no-c-format
msgid "gammainc(a,x)"
msgstr "gammainc(a,x)"

#. Tag: action
#: index.docbook:1932
#, no-c-format
msgid ""
"incomplete Gamma Function &Gamma;(a,x) = &int;<subscript>x</"
"subscript><superscript>&infin;</superscript> t<superscript>a-1</superscript> "
"exp(-t) dt for a &gt; 0, x &gt;= 0"
msgstr ""
"неповна гамма-функція &Gamma;(a,x) = &int;<subscript>x</"
"subscript><superscript>&infin;</superscript> t<superscript>a-1</superscript> "
"exp(-t) dt для a &gt; 0, x &gt;= 0"

