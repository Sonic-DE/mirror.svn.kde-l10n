#: index.docbook:1927
#, no-c-format
msgid "logarithm of `n choose m'"
msgstr "логарифм біноміального коефіцієнта"

#. Tag: entry
#: index.docbook:1928
#, no-c-format
msgid "taylor(n,x)"
msgstr "taylor(n,x)"

#. Tag: action
#: index.docbook:1928
#, no-c-format
msgid ""
"Taylor coefficient x<superscript>n</superscript> / n! for x >= 0, n >= 0"
msgstr ""
"коефіцієнт розкладу Тейлора при x<superscript>n</superscript> / n! для x >= "
"0, n >= 0"

#. Tag: entry
#: index.docbook:1929
#, no-c-format
msgid "poch(a,x)"
msgstr "poch(a,x)"

#. Tag: action
#: index.docbook:1929
#, no-c-format
msgid ""
"Pochhammer symbol (a)<subscript>x</subscript> := &Gamma;(a + x)/&Gamma;(x)"
msgstr ""
"символ Похгаммера (a)<subscript>x</subscript> := &Gamma;(a + x)/&Gamma;(x)"

