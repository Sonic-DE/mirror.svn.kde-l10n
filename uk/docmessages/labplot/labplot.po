#: index.docbook:1923
#, no-c-format
msgid "doublefact(n)"
msgstr "doublefact(n)"

#. Tag: action
#: index.docbook:1923
#, no-c-format
msgid "double factorial n!! = n(n-2)(n-4)..."
msgstr "Подвійний факторіал n!! = n(n-2)(n-4)..."

#. Tag: entry
#: index.docbook:1924
#, no-c-format
msgid "lnfact(n)"
msgstr "lnfact(n)"

#. Tag: action
#: index.docbook:1924
#, no-c-format
msgid "logarithm of the factorial of n, log(n!)"
msgstr "логарифм n-факторіала, log(n!)"

