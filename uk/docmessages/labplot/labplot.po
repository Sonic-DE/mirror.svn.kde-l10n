#: index.docbook:1925
#, no-c-format
msgid "lndoublefact(n)"
msgstr "lndoublefact(n)"

#. Tag: action
#: index.docbook:1925
#, no-c-format
msgid "logarithm of the double factorial log(n!!)"
msgstr "логарифм подвійного факторіала log(n!!)"

#. Tag: entry
#: index.docbook:1926
#, no-c-format
msgid "choose(n,m)"
msgstr "choose(n,m)"

#. Tag: action
#: index.docbook:1926
#, no-c-format
