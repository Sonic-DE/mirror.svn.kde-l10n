"subscript><superscript>x</superscript> arctan(t)/t dt"
msgstr ""
"Інтегральний арктангенс AtanInt(x) = &int;<subscript>0</"
"subscript><superscript>x</superscript> arctan(t)/t dt"

#. Tag: entry
#: index.docbook:1910
#, no-c-format
msgid "Fm1(x)"
msgstr "Fm1(x)"

#. Tag: action
#: index.docbook:1910
#, no-c-format
msgid ""
"complete Fermi-Dirac integral with an index of -1, F<subscript>-1</"
"subscript>(x) = e<superscript>x</superscript> / (1 + e<superscript>x</"
"superscript>)"
msgstr ""
"повний інтеграл Фермі-Дірака з індексом -1, F<subscript>-1</subscript>(x) = "
"e<superscript>x</superscript> / (1 + e<superscript>x</superscript>)"

#. Tag: entry
#: index.docbook:1911
#, no-c-format
msgid "F0(x)"
msgstr "F0(x)"

#. Tag: action
#: index.docbook:1911
#, no-c-format
msgid ""
"complete Fermi-Dirac integral with an index of 0, F<subscript>0</"
"subscript>(x) = ln(1 + e<superscript>x</superscript>)"
msgstr ""
"повний інтеграл Фермі-Дірака з індексом 0, F<subscript>0</subscript>(x) = "
"e<superscript>x</superscript> / ( + e<superscript>x</superscript>)"

#. Tag: entry
#: index.docbook:1912
#, no-c-format
msgid "F1(x)"
msgstr "F1(x)"

#. Tag: action
#: index.docbook:1912
#, no-c-format
msgid ""
"complete Fermi-Dirac integral with an index of 1, F<subscript>1</"
"subscript>(x) = &int;<subscript>0</subscript><superscript>&infin;</"
"superscript> (t /(exp(t-x)+1)) dt"
msgstr ""
"повний інтеграл Фермі-Дірака з індексом 1, F<subscript>1</subscript>(x) = "
"&int;<subscript>0</subscript><superscript>&infin;</superscript> (t /(exp(t-"
"x)+1)) dt"

#. Tag: entry
#: index.docbook:1913
#, no-c-format
msgid "F2(x)"
msgstr "F2(x)"

#. Tag: action
#: index.docbook:1913
#, no-c-format
msgid ""
"complete Fermi-Dirac integral with an index of 2, F<subscript>2</"
"subscript>(x) = (1/2) &int;<subscript>0</subscript><superscript>&infin;</"
"superscript> (t<superscript>2</superscript> /(exp(t-x)+1)) dt"
msgstr ""
"повний інтеграл Фермі-Дірака з індексом 2, F<subscript>2</subscript>(x) = "
"&int;<subscript>0</subscript><superscript>&infin;</superscript> (t /(exp(t-"
"x)+1)) dt"

#. Tag: entry
#: index.docbook:1914
#, no-c-format
msgid "Fj(j,x)"
msgstr "Fj(j,x)"

#. Tag: action
#: index.docbook:1914
#, no-c-format
msgid ""
"complete Fermi-Dirac integral with an index of j, F<subscript>j</"
"subscript>(x) = (1/&Gamma;(j+1)) &int;<subscript>0</"
"subscript><superscript>&infin;</superscript> (t<superscript>j</superscript> /"
"(exp(t-x)+1)) dt"
msgstr ""
"повний інтеграл Фермі-Дірака з індексом j, F<subscript>j</subscript>(x) = (1/"
"&Gamma;(j+1)) &int;<subscript>0</subscript><superscript>&infin;</"
"superscript> (t<superscript>j</superscript> /(exp(t-x)+1)) dt"

#. Tag: entry
#: index.docbook:1915
#, no-c-format
msgid "Fmhalf(x)"
msgstr "Fmhalf(x)"

#. Tag: action
#: index.docbook:1915
#, no-c-format
msgid "complete Fermi-Dirac integral F<subscript>-1/2</subscript>(x)"
msgstr "повний інтеграл Фермі-Дірака F<subscript>-1/2</subscript>(x)"

#. Tag: entry
#: index.docbook:1916
#, no-c-format
msgid "Fhalf(x)"
msgstr "Fhalf(x)"

#. Tag: action
#: index.docbook:1916
#, no-c-format
msgid "complete Fermi-Dirac integral F<subscript>1/2</subscript>(x)"
msgstr "повний інтеграл Фермі-Дірака F<subscript>-1/2</subscript>(x)"

#. Tag: entry
#: index.docbook:1917
#, no-c-format
msgid "F3half(x)"
msgstr "F3half(x)"

#. Tag: action
#: index.docbook:1917
#, no-c-format
msgid "complete Fermi-Dirac integral F<subscript>3/2</subscript>(x)"
msgstr "повний інтеграл Фермі-Дірака F<subscript>3/2</subscript>(x)"

#. Tag: entry
#: index.docbook:1918
#, no-c-format
msgid "Finc0(x,b)"
msgstr "Finc0(x,b)"

