#~ "<menuchoice><guimenu>Game</guimenu> <guimenuitem>Pause</guimenuitem></"
#~ "menuchoice> from the menubar or press <keycap>P</keycap>"
#~ msgstr ""
#~ "Щоб призупинити гру натисніть кнопку <guibutton>Пауза</guibutton>, "
#~ "скористайтеся пунктом меню <menuchoice><guimenu>Гра</guimenu> "
