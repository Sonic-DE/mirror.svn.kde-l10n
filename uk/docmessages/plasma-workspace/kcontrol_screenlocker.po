#~ msgid ""
#~ "Check <guilabel>Lock screen on resume</guilabel> if you want a password "
#~ "protected system when waking up from suspension."
#~ msgstr ""
#~ "Позначте пункт <guilabel>Блокувати екран після пробудження</guilabel>, "
#~ "якщо систему має бути захищено паролем після пробудження зі стану "
#~ "присипляння."

