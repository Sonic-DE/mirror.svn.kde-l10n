"<emphasis>Дарований</emphasis>, <emphasis>Взятий у борг</emphasis>, "
"<emphasis>Ключові слова</emphasis>, <emphasis>Рімейк</emphasis> і "
"<emphasis>Коментарі</emphasis>."

#. Tag: title
#: details.docbook:393
#, no-c-format
msgid "Video Game Collections"
msgstr "Збірки відеоігор"

