#~ msgstr ""
#~ "<application><ulink url=\"http://www.gcstar.org\">GCstar</ulink></"
#~ "application> — це альтернативний інструмент керування збірками. Програма "
#~ "підтримує імпорт збірок книг, фільмів, музики, монет, ігор, ігор на дошці "
#~ "та збірок вин."

#~ msgid ""
