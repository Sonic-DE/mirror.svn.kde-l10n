#~ "інструментом керування збірками фільмів. Зазвичай, файли даних "
#~ "<application>GCfilms</application> зберігаються за адресою <filename "
#~ "class=\"directory\">$<envar>HOME</envar>/.local/share/gcfilms/</filename>."

#~ msgid "Importing Griffith Data"
#~ msgstr "Імпортування даних з Griffith"

#~ msgid ""
#~ "<application><ulink url=\"http://griffith.berlios.de/\">Griffith</ulink></"
#~ "application> is an alternate video collection manager. &appname; is able "
#~ "to import most data from a Griffith database."
#~ msgstr ""
#~ "<application><ulink url=\"http://griffith.berlios.de/\">Griffith</ulink></"
#~ "application> — це альтернативний інструмент керування збірками фільмів. "
#~ "&appname; може імпортувати більшу частину даних з баз даних Griffith."

#~ msgid "Importing Referencer Data"
#~ msgstr "Імпортування даних з Referencer"

#~ msgid ""
#~ "<application><ulink url=\"http://icculus.org/referencer/\">Referencer</"
#~ "ulink></application> is a document organizer and bibliography manager for "
#~ "the GNOME desktop. &appname; will import most of the data found in a "
#~ "Referencer database."
#~ msgstr ""
#~ "<application><ulink url=\"http://icculus.org/referencer/\">Referencer</"
#~ "ulink></application> — це інструмент впорядкування документів і "
#~ "бібліографії для стільничного середовища GNOME. &appname; імпортує "
#~ "більшість даних, які зберігаються у базі даних Referencer."

#~ msgid "Exporting Bibtexml"
#~ msgstr "Експортування до Bibtexml"

#~ msgid ""
#~ "<ulink url=\"http://bibtexml.sourceforge.net\">Bibtexml</ulink> is a "
#~ "format for expressing bibtex data via &XML;."
#~ msgstr ""
#~ "<ulink url=\"http://bibtexml.sourceforge.net\">Bibtexml</ulink> — це "
#~ "формат для зберігання даних bibtex у файлах формату XML."

#~ msgid "Exporting Pilot-DB"
#~ msgstr "Експортування до Pilot-DB"

#~ msgid ""
#~ "<ulink url=\"http://pilot-db.sourceforge.net\">Pilot-DB</ulink> is a "
#~ "database format for &PalmOS;. Various desktop applications can read and "
#~ "write Pilot-DB files. Exported <literal role=\"extension\">.pdb</literal> "
#~ "files can be transferred to a PDA, and used directly. At the moment, "
#~ "&appname; is not able to import Pilot-DB files."
#~ msgstr ""
#~ "<ulink url=\"http://pilot-db.sourceforge.net\">Pilot-DB</ulink> є "
#~ "форматом баз даних для Palm OS. Читати і записувати файли у форматі Pilot-"
#~ "DB можуть декілька комп’ютерних програм. Експортовані файли <literal role="
#~ "\"extension\">.pdb</literal> можна надіслати на кишеньковий пристрій або "
#~ "скористатися ними безпосередньо. Поточна версія &appname; не здатна "
#~ "імпортувати файли Pilot-DB."

