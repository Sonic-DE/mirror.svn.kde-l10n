#~ "Встановлює стиль введення XIM (X Input Method (методу введення X)). "
#~ "Можливими значеннями є <parameter>onthespot</parameter>, "
#~ "<parameter>overthespot</parameter>, <parameter>offthespot</parameter> і "
#~ "<parameter>root</parameter>"

#~ msgid "--im &lt;XIM server&gt;"
#~ msgstr "--im &lt;сервер XIM&gt;"

#~ msgid "set XIM server"
#~ msgstr "Встановлює сервер XIM"

#~ msgid "--noxim"
#~ msgstr "--noxim"

#~ msgid "disable XIM"
#~ msgstr "Вимкнути XIM"

#~ msgid "--reverse"
#~ msgstr "--reverse"

#~ msgid "mirrors the whole layout of widgets"
#~ msgstr "Віддзеркалює все компонування віджетів"

#~ msgid "--stylesheet &lt;file.qss&gt;"
#~ msgstr "--stylesheet &lt;файл.qss&gt;"

