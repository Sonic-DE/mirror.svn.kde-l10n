#~ msgid "sets the default button color"
#~ msgstr "Встановлює типовий колір кнопок"

#~ msgid "--name &lt;name&gt;"
#~ msgstr "--name &lt;назва&gt;"

#~ msgid "sets the application name"
#~ msgstr "Встановлює назву програми"

#~ msgid "--title &lt;title&gt;"
#~ msgstr "--title &lt;заголовок&gt;"

#~ msgid "sets the application title (caption)"
#~ msgstr "Встановлює заголовок вікна програми"

#~ msgid "--visual TrueColor"
