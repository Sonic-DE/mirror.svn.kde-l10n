#. Tag: author
#: man-kdesvn.1.docbook:9
#, no-c-format
msgid ""
"<personname> <firstname>Rajko</firstname> <surname>Albrecht</surname> </"
"personname> <email>ral@alwins-world.de</email>"
msgstr ""
"<personname> <firstname>Rajko</firstname> <surname>Albrecht</surname> </"
"personname> <email>ral@alwins-world.de</email>"

#. Tag: date
#: man-kdesvn.1.docbook:14
#, no-c-format
msgid "2016-05-22"
msgstr "22 травня 2016 року"

#. Tag: releaseinfo
#: man-kdesvn.1.docbook:15
#, no-c-format
msgid "kdesvn 2.1.0"
msgstr "kdesvn 2.1.0"

#. Tag: manvolnum
#: man-kdesvn.1.docbook:20
#, no-c-format
msgid "<manvolnum>1</manvolnum>"
msgstr "<manvolnum>1</manvolnum>"

#. Tag: refpurpose
#: man-kdesvn.1.docbook:25
#, no-c-format
msgid ""
"<refpurpose>A Subversion client by KDE (standalone application)</refpurpose>"
msgstr ""
"<refpurpose>Клієнт Subversion, створений розробниками KDE (окрема програма)</"
"refpurpose>"

#. Tag: cmdsynopsis
#: man-kdesvn.1.docbook:29
#, no-c-format
msgid ""
"<command>kdesvn</command> <arg choice=\"opt\"><replaceable>options</"
"replaceable></arg> <arg choice=\"plain\"><replaceable>exec</replaceable></"
"arg> <arg choice=\"plain\"><replaceable>&lt;command&gt;</replaceable></arg> "
"<arg choice=\"opt\"><replaceable>URL</replaceable></arg>"
msgstr ""
"<command>kdesvn</command> <arg choice=\"opt\"><replaceable>параметри</"
"replaceable></arg> <arg choice=\"plain\"><replaceable>exec</replaceable></"
"arg> <arg choice=\"plain\"><replaceable>&lt;команда&gt;</replaceable></arg> "
"<arg choice=\"opt\"><replaceable>адреса</replaceable></arg>"

#. Tag: title
#: man-kdesvn.1.docbook:39
#, no-c-format
msgid "Description"
msgstr "Опис"

#. Tag: para
#: man-kdesvn.1.docbook:40
#, no-c-format
msgid "<para>A Subversion client by KDE (standalone application)</para>"
msgstr ""
"<para>Клієнт Subversion, створений розробниками KDE (окрема програма)</para>"

#. Tag: title
#: man-kdesvn.1.docbook:43
#, no-c-format
msgid "Options"
msgstr "Параметри"

#. Tag: title
#: man-kdesvn.1.docbook:45
#, no-c-format
msgid "Arguments:"
msgstr "Аргументи:"

#. Tag: term
#: man-kdesvn.1.docbook:48
#, no-c-format
msgid "<emphasis>exec</emphasis> &lt;command&gt;"
msgstr "<emphasis>exec</emphasis> &lt;команда&gt;"

#. Tag: para
#: man-kdesvn.1.docbook:49
#, no-c-format
msgid ""
"Execute subversion command (\"exec help\" for more information, opens KDE "
"Help Center)"
msgstr ""
"Виконати вказану команду subversion («exec help» щоб дізнатися більше, "
"відкриває Центр довідки KDE)"

#. Tag: emphasis
#: man-kdesvn.1.docbook:53
#, no-c-format
msgid "<emphasis>URL</emphasis>"
msgstr "<emphasis>адреса</emphasis>"

#. Tag: para
#: man-kdesvn.1.docbook:55
#, no-c-format
msgid "Path to local working copy or a repository."
msgstr "Шлях до локальної робочої копії або сховища."

#. Tag: title
#: man-kdesvn.1.docbook:61
#, no-c-format
msgid "Options:"
msgstr "Параметри:"

#. Tag: option
#: man-kdesvn.1.docbook:64
#, no-c-format
msgid "-r startrev[:endrev]"
msgstr "-r початкова_модифікація[:кінцева_модифікація]"

#. Tag: para
#: man-kdesvn.1.docbook:66
#, no-c-format
msgid "Execute single subversion command on specific revision(-range)"
msgstr ""
"Виконати окрему команду subversion над вказаною модифікацією (діапазоном "
"модифікацій)."

#. Tag: option
#: man-kdesvn.1.docbook:70
#, no-c-format
msgid "<option>-R</option>"
msgstr "<option>-R</option>"

#. Tag: para
#: man-kdesvn.1.docbook:72
#, no-c-format
msgid "Ask for revision when executing single command"
msgstr "Запитати щодо модифікації під час виконання окремої команди"

#. Tag: option
#: man-kdesvn.1.docbook:76
#, no-c-format
msgid "<option>-f</option>"
msgstr "<option>-f</option>"

#. Tag: para
#: man-kdesvn.1.docbook:78
#, no-c-format
msgid "Force operation"
msgstr "Примусове виконання"

#. Tag: option
#: man-kdesvn.1.docbook:82
#, no-c-format
msgid "-o &lt;file&gt;"
msgstr "-o &lt;файл&gt;"

#. Tag: para
#: man-kdesvn.1.docbook:84
#, no-c-format
msgid ""
"Save output of subversion command (eg <quote>cat</quote>) into file &lt;"
"file&gt;"
msgstr ""
"Зберегти дані, виведені командою subversion (наприклад «cat») до файла &lt;"
"файл&gt;"

#. Tag: option
#: man-kdesvn.1.docbook:88
#, no-c-format
msgid "-l &lt;number&gt;"
msgstr "-l &lt;число&gt;"

#. Tag: para
#: man-kdesvn.1.docbook:90
#, no-c-format
msgid "Limit log output to &lt;number&gt;"
msgstr "Обмежити кількість виведених повідомлень журналу до &lt;число&gt;"

#. Tag: title
#: man-kdesvn.1.docbook:99
#, no-c-format
msgid "Example"
msgstr "Приклад"

#. Tag: para
#: man-kdesvn.1.docbook:100
#, no-c-format
msgid "kdesvn file:///<replaceable>path/to/local/working/copy</replaceable>"
msgstr ""
"kdesvn file:///<replaceable>шлях/до/локальної/робочої/копії</replaceable>"

#. Tag: para
#: man-kdesvn.1.docbook:101
#, no-c-format
msgid "kdesvn http://<replaceable>remote/svn/project/trunk</replaceable>"
msgstr "kdesvn http://<replaceable>trunk/віддаленого/проєкту/svn</replaceable>"

#. Tag: title
#: man-kdesvn.1.docbook:105
#, no-c-format
msgid "See Also"
msgstr "Також прочитайте"

#. Tag: member
#: man-kdesvn.1.docbook:107
#, no-c-format
msgid ""
"Full user documentation is available through the &khelpcenter;. You can also "
"enter the &URL; <emphasis>help:/kdesvn/</emphasis> directly into &konqueror; "
"or you can run <emphasis>`khelpcenter help:/kdesvn/'</emphasis> from the "
"command-line."
msgstr ""
"З повним текстом документації користувача можна ознайомитися за допомогою "
"Центру довідки KDE. Крім того, ви можете ввести адресу <emphasis>help:/"
"kdesvn/</emphasis> безпосередньо до konqueror або віддати команду "
"<emphasis>khelpcenter help:/kdesvn/</emphasis> з командного рядка."

#. Tag: member
#: man-kdesvn.1.docbook:110
#, no-c-format
msgid "kf5options(7)"
msgstr "kf5options(7)"

#. Tag: member
#: man-kdesvn.1.docbook:111
#, no-c-format
msgid "qt5options(7)"
msgstr "qt5options(7)"

