#: man-kdesvn.1.docbook:115
#, no-c-format
msgid "Authors"
msgstr "Автори"

#. Tag: literallayout
#: man-kdesvn.1.docbook:116
#, no-c-format
msgid "Rajko Albrecht &lt;ral@alwins-world.de&gt;"
msgstr "Rajko Albrecht &lt;ral@alwins-world.de&gt;"

