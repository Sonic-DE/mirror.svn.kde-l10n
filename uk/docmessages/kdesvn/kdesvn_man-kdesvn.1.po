#~ msgstr "kdesvn 1.7.40 (модифікація: ca4515f)"

#~ msgid "KDESVN"
#~ msgstr "KDESVN"

#~ msgid "Sep 2008"
#~ msgstr "вересень 2008 року"

#~ msgid "K Desktop Environment"
#~ msgstr "Стільничне середовище KDE"

#~ msgid "DESCRIPTION"
#~ msgstr "ОПИС"

#~ msgid "OPTIONS"
#~ msgstr "ПАРАМЕТРИ"

#~ msgid "Generic options:"
#~ msgstr "Загальні параметри:"

#~ msgid "--help"
#~ msgstr "--help"

#~ msgid "Show help about options"
#~ msgstr "Показати довідку щодо параметрів"

#~ msgid "--help-qt"
#~ msgstr "--help-qt"

#~ msgid "Show Qt specific options"
#~ msgstr "Показати параметри, що стосуються Qt"

#~ msgid "--help-kde"
#~ msgstr "--help-kde"

#~ msgid "Show KDE specific options"
#~ msgstr "Показати параметри, що стосуються KDE"

#~ msgid "--help-all"
#~ msgstr "--help-all"

#~ msgid "Show all options"
#~ msgstr "Показати всі параметри"

#~ msgid "Show author information"
#~ msgstr "Показати інформацію щодо автора"

#~ msgid "-v, --version"
#~ msgstr "-v, --version"

#~ msgid "Show version information"
#~ msgstr "Показати інформацію про версію"

#~ msgid "--license"
#~ msgstr "--license"

#~ msgid "Show license information"
#~ msgstr "Показати інформацію про умови ліцензування програми"

#~ msgid "<option>--</option>"
#~ msgstr "<option>--</option>"

#~ msgid "End of options"
#~ msgstr "Кінець параметрів"

#~ msgid "KDE options:"
#~ msgstr "Параметри &kde;:"

#~ msgid "--caption &lt;caption&gt;"
#~ msgstr "--caption &lt;заголовок&gt;"

#~ msgid "Use 'caption' as name in the titlebar"
#~ msgstr "Використовувати «заголовок» як заголовок вікна програми"

#~ msgid "--icon &lt;icon&gt;"
#~ msgstr "--icon &lt;піктограма&gt;"

#~ msgid "Use 'icon' as the application icon"
#~ msgstr "Використати «піктограму» як піктограму програми"

#~ msgid "--config &lt;filename&gt;"
#~ msgstr "--config &lt;назва_файла&gt;"

#~ msgid "Use alternative configuration file"
#~ msgstr "Скористатись іншим файлом налаштувань"

#~ msgid "--nocrashhandler"
#~ msgstr "--nocrashhandler"

#~ msgid "Disable crash handler, to get core dumps"
#~ msgstr ""
#~ "Вимкнути засіб обробки критичних помилок, призначений для створення "
#~ "дампів ядра"

#~ msgid "--waitforwm"
#~ msgstr "--waitforwm"

#~ msgid "Waits for a WM_NET compatible windowmanager"
#~ msgstr "Чекає на засіб керування вікнами, сумісний з WM_NET"

#~ msgid "--style &lt;style&gt;"
#~ msgstr "--style &lt;стиль&gt;"

#~ msgid "sets the application GUI style"
#~ msgstr "встановлює стиль графічного інтерфейсу програми"

#~ msgid "--geometry &lt;geometry&gt;"
#~ msgstr "--geometry &lt;геометрія&gt;"

#~ msgid ""
#~ "sets the client geometry of the main widget - see man X for the argument "
#~ "format"
#~ msgstr ""
#~ "Встановлює клієнтську геометрію головного віджета — щоб дізнатися про "
#~ "формат аргументів, прочитайте довідку (man) з X"

#~ msgid "Qt options:"
#~ msgstr "Параметри Qt:"

#~ msgid "--display &lt;displayname&gt;"
#~ msgstr "--display &lt;назва_дисплея&gt;"

#~ msgid "Use the X-server display 'displayname'"
#~ msgstr "Використовувати дисплей X-сервера «назва_дисплея»"

#~ msgid "--session &lt;sessionId&gt;"
#~ msgstr "--session &lt;ідентифікатор_сеансу&gt;"

#~ msgid "Restore the application for the given 'sessionId'"
#~ msgstr "Відновити програму для сеансу з \"ідентифікатором_сеансу\""

#~ msgid "--cmap"
#~ msgstr "--cmap"

#~ msgid ""
#~ "Causes the application to install a private color map on an 8-bit display"
#~ msgstr ""
#~ "Встановлює особливу карту кольорів для програми на 8-бітовому дисплеї"

#~ msgid "--ncols &lt;count&gt;"
#~ msgstr "--ncols &lt;число&gt;"

#~ msgid ""
#~ "Limits the number of colors allocated in the color cube on an 8-bit "
#~ "display, if the application is using the QApplication::ManyColor color "
#~ "specification"
#~ msgstr ""
#~ "Обмежує кількість кольорів, виділених у кубі кольорів на 8-бітовому "
#~ "дисплеї, якщо програма використовує специфікацію кольорів QApplication::"
#~ "ManyColor"

#~ msgid "--nograb"
#~ msgstr "--nograb"

#~ msgid "tells Qt to never grab the mouse or the keyboard"
#~ msgstr ""
#~ "Повідомляє Qt, що не слід ніколи перехоплювати керування мишею або "
#~ "клавіатурою"

#~ msgid "--dograb"
#~ msgstr "--dograb"

#~ msgid ""
#~ "running under a debugger can cause an implicit -nograb, use -dograb to "
#~ "override"
#~ msgstr ""
#~ "Запуск у засобі для налагоджування може спричинити неявне визначення "
#~ "параметра <option>--nograb</option>, щоб запобігти цьому, скористайтеся "
#~ "параметром <option>--dograb</option>"

#~ msgid "--sync"
#~ msgstr "--sync"

#~ msgid "switches to synchronous mode for debugging"
#~ msgstr "Вмикає синхронний режим, що використовується для налагоджування"

#~ msgid "--fn, --font &lt;fontname&gt;"
#~ msgstr "--fn, --font &lt;назва_шрифту&gt;"

#~ msgid "defines the application font"
#~ msgstr "визначає шрифт програми"

#~ msgid "--bg, --background &lt;color&gt;"
#~ msgstr "--bg, --background &lt;колір&gt;"

#~ msgid ""
#~ "sets the default background color and an application palette (light and "
#~ "dark shades are calculated)"
#~ msgstr ""
#~ "Встановлює типовий колір тла і палітру кольорів програми (світлі і темні "
#~ "тони обчислюються на його основі)"

#~ msgid "--fg, --foreground &lt;color&gt;"
#~ msgstr "--fg, --foreground &lt;колір&gt;"

#~ msgid "sets the default foreground color"
#~ msgstr "Встановлює типовий колір переднього плану."

#~ msgid "--btn, --button &lt;color&gt;"
#~ msgstr "--btn, --button &lt;колір&gt;"

#~ msgid "sets the default button color"
#~ msgstr "Встановлює типовий колір кнопок"

#~ msgid "--name &lt;name&gt;"
#~ msgstr "--name &lt;назва&gt;"

#~ msgid "sets the application name"
#~ msgstr "Встановлює назву програми"

#~ msgid "--title &lt;title&gt;"
#~ msgstr "--title &lt;заголовок&gt;"

#~ msgid "sets the application title (caption)"
#~ msgstr "Встановлює заголовок вікна програми"

#~ msgid "--visual TrueColor"
#~ msgstr "--visual TrueColor"

#~ msgid "forces the application to use a TrueColor visual on an 8-bit display"
#~ msgstr ""
#~ "Вказує програмі, що слід використовувати відображення "
#~ "<parameter>TrueColor</parameter> на 8-бітовому дисплеї"

#~ msgid "--inputstyle &lt;inputstyle&gt;"
#~ msgstr "--inputstyle &lt;стиль_вводу&gt;"

#~ msgid ""
#~ "sets XIM (X Input Method) input style. Possible values are onthespot, "
#~ "overthespot, offthespot and root"
#~ msgstr ""
#~ "Встановлює стиль введення XIM (X Input Method (методу введення X)). "
#~ "Можливими значеннями є <parameter>onthespot</parameter>, "
#~ "<parameter>overthespot</parameter>, <parameter>offthespot</parameter> і "
#~ "<parameter>root</parameter>."

#~ msgid "--im &lt;XIM server&gt;"
#~ msgstr "--im &lt;сервер XIM&gt;"

#~ msgid "set XIM server"
#~ msgstr "Встановлює сервер XIM"

#~ msgid "--noxim"
#~ msgstr "--noxim"

#~ msgid "disable XIM"
#~ msgstr "Вимкнути XIM"

#~ msgid "--reverse"
#~ msgstr "--reverse"

#~ msgid "mirrors the whole layout of widgets"
#~ msgstr "Віддзеркалює все компонування віджетів"

#~ msgid "--stylesheet"
#~ msgstr "--stylesheet"

#~ msgid ""
#~ "&lt;file.qss&gt; applies the Qt stylesheet to the application widgets"
#~ msgstr "&lt;файл.qss&gt; застосовує таблицю стилів Qt до віджетів програми"

