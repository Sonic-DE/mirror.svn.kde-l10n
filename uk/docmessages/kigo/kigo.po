msgstr "<action>Зберегти</action> поточну гру."

#. Tag: menuchoice
#: index.docbook:247
#, no-c-format
msgid ""
"<shortcut><keycap>S</keycap></shortcut> <guimenu>Game</guimenu> "
"<guimenuitem>Start Game</guimenuitem>"
msgstr ""
"<shortcut><keycap>S</keycap></shortcut> <guimenu>Гра</guimenu> "
"<guimenuitem>Почати гру</guimenuitem>"

#. Tag: para
#: index.docbook:251
#, no-c-format
msgid "<action>Starts</action> the new or the loaded game."
msgstr "<action>Почати</action> нову або завантажену гру."

#. Tag: menuchoice
#: index.docbook:255
#, no-c-format
msgid ""
"<shortcut><keycap>F</keycap></shortcut> <guimenu>Game</guimenu> "
"<guimenuitem>Finish Game</guimenuitem>"
msgstr ""
"<shortcut><keycap>F</keycap></shortcut> <guimenu>Гра</guimenu> "
"<guimenuitem>Завершити гру</guimenuitem>"

#. Tag: para
#: index.docbook:259
#, no-c-format
msgid ""
"<action>Finishes</action> the current game. Remember that ending a "
"<literal>Go</literal> game is always a cooperative step."
msgstr ""
"<action>Завершити</action> поточну гру. Пам’ятайте, що завершення гри у го "
"можливе лише за згоди обох гравців."

#. Tag: menuchoice
#: index.docbook:263
