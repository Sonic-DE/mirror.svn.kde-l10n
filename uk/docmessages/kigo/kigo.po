msgid ""
"<shortcut><keycap>P</keycap></shortcut> <guimenu>Move</guimenu> "
"<guimenuitem>Pass Move</guimenuitem>"
msgstr ""
"<shortcut><keycap>P</keycap></shortcut> <guimenu>Хід</guimenu> "
"<guimenuitem>Пропустити хід</guimenuitem>"

#. Tag: para
#: index.docbook:291
#, no-c-format
msgid "Allows you to <action>pass</action> a move."
msgstr "Надає вам змогу <action>пропустити</action> хід."

#. Tag: menuchoice
