"перегляду графу. Серед можливих варіантів:"

#. Tag: guimenuitem
#: index.docbook:532 index.docbook:651
#, no-c-format
msgid "Top Left"
msgstr "Верхній лівий"

#. Tag: para
#: index.docbook:533 index.docbook:652
#, no-c-format
msgid "Places the bird's-eye view at the top left corner;"
msgstr "Розташувати загальний перегляд у верхньому лівому куті;"

#. Tag: guimenuitem
#: index.docbook:537 index.docbook:656
#, no-c-format
msgid "Top Right"
msgstr "Верхній правий"

#. Tag: para
#: index.docbook:538 index.docbook:657
#, no-c-format
msgid "Places the bird's-eye view at the top right corner;"
msgstr "Розташувати загальний перегляд у верхньому правому куті;"

#. Tag: guimenuitem
#: index.docbook:542 index.docbook:661
#, no-c-format
msgid "Bottom Left"
msgstr "Нижній лівий"

#. Tag: para
#: index.docbook:543 index.docbook:662
#, no-c-format
msgid "Places the bird's-eye view at the bottom left corner;"
msgstr "Розташувати загальний перегляд у нижньому лівому куті;"

#. Tag: guimenuitem
#: index.docbook:547 index.docbook:666
#, no-c-format
msgid "Bottom Right"
msgstr "Нижній правий"

#. Tag: para
#: index.docbook:548 index.docbook:667
#, no-c-format
msgid "Places the bird's-eye view at the bottom right corner;"
msgstr "Розташувати загальний перегляд у нижньому правому куті;"

#. Tag: guimenuitem
#: index.docbook:552 index.docbook:671
#, no-c-format
msgid "Automatic"
msgstr "Автоматично"

#. Tag: para
#: index.docbook:553 index.docbook:672
#, no-c-format
msgid ""
