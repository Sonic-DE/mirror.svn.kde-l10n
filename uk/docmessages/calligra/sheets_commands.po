#. Tag: menuchoice
#: commands.docbook:582
#, no-c-format
msgid ""
"<guimenu>Insert</guimenu> <guimenuitem>Special Character...</guimenuitem>"
msgstr ""
"<guimenu>Вставка</guimenu> <guimenuitem>Спеціальний символ...</guimenuitem>"

