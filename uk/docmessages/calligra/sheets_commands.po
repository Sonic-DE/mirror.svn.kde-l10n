#~ msgstr ""
#~ "<guimenu>Формат</guimenu> <guimenuitem>Зменшити відступ</guimenuitem>"

#~ msgid "Move text in selected cell(s) to the left."
#~ msgstr "Пересунути текст у обраних комірках ліворуч."

#~ msgid "<guimenu>Format</guimenu> <guimenuitem>Increase Indent</guimenuitem>"
#~ msgstr ""
#~ "<guimenu>Формат</guimenu> <guimenuitem>Збільшити відступ</guimenuitem>"

#~ msgid "Move text in selected cell(s) to the right."
#~ msgstr "Пересунути текст у обраних комірках праворуч."

#~ msgid ""
#~ "<guimenu>Format</guimenu> <guimenuitem>Increase Precision</guimenuitem>"
#~ msgstr ""
#~ "<guimenu>Формат</guimenu> <guimenuitem>Збільшити точність</guimenuitem>"

