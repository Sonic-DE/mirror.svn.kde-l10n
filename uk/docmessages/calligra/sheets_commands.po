#: commands.docbook:759
#, no-c-format
msgid "Format printed page layout."
msgstr "Змінити компонування друкованої сторінки."

#. Tag: menuchoice
#: commands.docbook:764
#, no-c-format
msgid "<guimenu>Format</guimenu> <guisubmenu>Print Range</guisubmenu>"
msgstr "<guimenu>Формат</guimenu> <guisubmenu>Діапазон друку</guisubmenu>"

