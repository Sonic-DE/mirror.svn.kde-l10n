#: commands.docbook:546
#, no-c-format
msgid "Add or modify a comment."
msgstr "Додати або змінити коментар."

#. Tag: menuchoice
#: commands.docbook:551
#, no-c-format
msgid "<guimenu>Insert</guimenu> <guimenuitem>Function...</guimenuitem>"
msgstr "<guimenu>Вставка</guimenu> <guimenuitem>Функція...</guimenuitem>"

