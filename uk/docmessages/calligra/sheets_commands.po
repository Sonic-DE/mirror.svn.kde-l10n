"Delete <guimenuitem>Cells</guimenuitem>, <guimenuitem>Columns</guimenuitem>, "
"<guimenuitem>Rows</guimenuitem> or <guimenuitem>Sheet</guimenuitem>."
msgstr ""
"Вилучити <guimenuitem>Комірки</guimenuitem>, <guimenuitem>Колонки</"
"guimenuitem>, <guimenuitem>Рядки</guimenuitem> або <guimenuitem>Аркуш</"
"guimenuitem>."

#. Tag: menuchoice
#: commands.docbook:402
#, no-c-format
msgid ""
"<shortcut> <keycap>F2</keycap> </shortcut> <guimenu>Edit</guimenu> "
"<guimenuitem>Modify Cell</guimenuitem>"
msgstr ""
"<shortcut> <keycap>F2</keycap> </shortcut> <guimenu>Зміни</guimenu> "
"<guimenuitem>Змінити комірку</guimenuitem>"

#. Tag: action
#: commands.docbook:409
#, no-c-format
msgid "To modify selected cell in-situ."
msgstr "Призначено для зміни вмісту вибраної комірки на місці."

#. Tag: title
#: commands.docbook:418
#, no-c-format
msgid "The View Menu"
msgstr "Меню «Перегляд»"

