#. Tag: menuchoice
#: commands.docbook:802
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>G</keycap></"
"keycombo> </shortcut> <guimenu>Data</guimenu> <guimenuitem>Named Areas...</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;&Shift;<keycap>G</keycap></"
"keycombo> </shortcut> <guimenu>Дані</guimenu> <guimenuitem>Ділянки з "
"назвами...</guimenuitem>"

