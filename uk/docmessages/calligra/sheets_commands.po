#. Tag: menuchoice
#: commands.docbook:847
#, no-c-format
msgid "<guimenu>Data</guimenu> <guimenuitem>Goal Seek...</guimenuitem>"
msgstr "<guimenu>Дані</guimenu> <guimenuitem>Пошук розв’язку...</guimenuitem>"

