#. Tag: menuchoice
#: commands.docbook:836
#, no-c-format
msgid "<guimenu>Data</guimenu> <guimenuitem>Validity...</guimenuitem>"
msgstr "<guimenu>Дані</guimenu> <guimenuitem>Коректність...</guimenuitem>"

#. Tag: para
#: commands.docbook:840
#, no-c-format
