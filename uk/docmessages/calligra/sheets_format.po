#~ "the <menuchoice><guimenu>Format</guimenu><guimenuitem>Increase Indent</"
#~ "guimenuitem></menuchoice> or <menuchoice><guimenu>Format</"
#~ "guimenu><guimenuitem>Decrease Indent</guimenuitem></menuchoice> menus."
#~ msgstr ""
#~ "Виберіть величину відступу, яку буде використано у комірці, коли ви "
#~ "оберете у меню <menuchoice><guimenu>Формат</"
#~ "guimenu><guimenuitem>Збільшити відступ</guimenuitem></menuchoice> або "
#~ "<menuchoice><guimenu>Формат</guimenu><guimenuitem>Зменшити відступ</"
#~ "guimenuitem></menuchoice>."

#~ msgid "Hide all."
#~ msgstr "Сховати все."
