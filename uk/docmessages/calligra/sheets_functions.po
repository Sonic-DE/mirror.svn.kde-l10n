#, no-c-format
msgid "MOD(value;value)"
msgstr "MOD(значення;значення)"

#. Tag: para
#: functions.docbook:6653
#, no-c-format
msgid "MOD(12;5) returns 2"
msgstr "MOD(12;5) повертає 2"

#. Tag: para
#: functions.docbook:6656
#, no-c-format
msgid "MOD(5;5) returns 0"
msgstr "MOD(5;5) повертає 0"

#. Tag: member
