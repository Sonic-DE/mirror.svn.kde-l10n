#: functions.docbook:6229
#, no-c-format
msgid "KPRODUCT(3;5;7) equals 105"
msgstr "KPRODUCT(3;5;7) дорівнює 105"

#. Tag: para
#: functions.docbook:6232
#, no-c-format
msgid "KPRODUCT(12.5;2) equals 25"
msgstr "KPRODUCT(12,5;2) дорівнює 25"

