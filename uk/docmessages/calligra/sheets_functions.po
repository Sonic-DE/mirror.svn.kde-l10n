#: functions.docbook:6900
#, no-c-format
msgid "<link linkend=\"INT\">INT</link>&nbsp;"
msgstr "<link linkend=\"INT\">INT</link>&nbsp;"

#. Tag: title
#: functions.docbook:6907
#, no-c-format
msgid "RAND"
msgstr "RAND"

#. Tag: para
#: functions.docbook:6908
#, no-c-format
msgid "The RAND() function returns a pseudo-random number between 0 and 1."
msgstr "Функція RAND() повертає псевдовипадкове число між 0 та 1."

#. Tag: para
#: functions.docbook:6913
#, no-c-format
msgid "RAND()"
msgstr "RAND()"

#. Tag: para
#: functions.docbook:6919
#, no-c-format
msgid "RAND() equals for example 0.78309922..."
msgstr "RAND(), наприклад, дорівнює 0,78309922..."

