msgstr "Місяці"

#. Tag: para
#: functions.docbook:1226
#, no-c-format
msgid "EDATE(\"2/22/2002\"; 3) returns \"5/22/2002\""
msgstr "EDATE(\"22.2.2002\"; 3) returns «22.5.2002»"

#. Tag: para
#: functions.docbook:1229
#, no-c-format
