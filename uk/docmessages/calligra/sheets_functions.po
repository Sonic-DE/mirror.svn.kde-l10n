msgstr "Рядок з одного символу, який буде перетворено"

#. Tag: para
#: functions.docbook:335
#, no-c-format
msgid "CHARTOASCII(\"v\") returns 118"
msgstr "CHARTOASCII(\"v\") повертає 118"

