#: functions.docbook:6525
#, no-c-format
msgid "MIN(value;value;...)"
msgstr "MIN(значення;значення;...)"

#. Tag: para
#: functions.docbook:6532
#, no-c-format
msgid "MIN(12;5; 7) returns 5"
msgstr "MIN(12;5; 7) повертає 5"

