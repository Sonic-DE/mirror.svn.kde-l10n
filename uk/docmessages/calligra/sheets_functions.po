#: functions.docbook:895 functions.docbook:1524
#, no-c-format
msgid "<link linkend=\"TODAY\">TODAY</link>&nbsp;"
msgstr "<link linkend=\"TODAY\">TODAY</link>&nbsp;"

#. Tag: title
#: functions.docbook:902
#, no-c-format
msgid "CURRENTDATETIME"
msgstr "CURRENTDATETIME"

#. Tag: para
#: functions.docbook:903
#, no-c-format
msgid "The CURRENTDATETIME() function returns the current date and time."
msgstr "Функція CURRENTDATETIME() повертає поточну дату та час."

#. Tag: para
#: functions.docbook:908
#, no-c-format
msgid "CURRENTDATETIME()"
msgstr "CURRENTDATETIME()"

#. Tag: para
#: functions.docbook:914
#, no-c-format
msgid "CURRENTDATETIME() returns \"Saturday 13 April 2002 19:12:01\""
msgstr "CURRENTDATETIME() повертає «Середа 30 січня 2008 22:02:32»"

#. Tag: title
#: functions.docbook:920
#, no-c-format
msgid "CURRENTTIME"
msgstr "CURRENTTIME"

#. Tag: para
#: functions.docbook:921
#, no-c-format
msgid ""
"The CURRENTTIME() function returns the current time formatted with local "
"parameters."
msgstr ""
"Функція CURRENTTIME() повертає поточний час за форматом, заданим параметрами "
"локалі."

#. Tag: para
#: functions.docbook:926
#, no-c-format
msgid "CURRENTTIME()"
msgstr "CURRENTTIME()"

#. Tag: para
#: functions.docbook:932
#, no-c-format
msgid "CURRENTTIME() returns \"19:12:01\""
msgstr "CURRENTTIME() повертає «19:12:01»"

#. Tag: title
#: functions.docbook:938
#, no-c-format
msgid "DATE"
msgstr "DATE"

#. Tag: para
#: functions.docbook:939
#, no-c-format
msgid "The DATE() function returns the date formatted with local parameters."
msgstr ""
"Функція DATE() повертає дату, показану у відповідності з параметрами локалі."

#. Tag: para
#: functions.docbook:944
#, no-c-format
msgid "DATE(year;month;date)"
msgstr "DATE(рік;місяць;число)"

#. Tag: seg
#: functions.docbook:948 functions.docbook:1091 functions.docbook:1164
#: functions.docbook:1184 functions.docbook:1203 functions.docbook:1330
#: functions.docbook:1760
#, no-c-format
msgid "Year"
msgstr "Рік"

#. Tag: seg
#: functions.docbook:949 functions.docbook:1092 functions.docbook:1165
#: functions.docbook:3270
#, no-c-format
msgid "Month"
msgstr "Місяць"

#. Tag: seg
#: functions.docbook:950 functions.docbook:1093
#, no-c-format
msgid "<seg>Day</seg>"
msgstr "<seg>День</seg>"

#. Tag: para
#: functions.docbook:953
#, no-c-format
msgid "DATE(2000;5;5) returns Friday 05 May 2000"
msgstr "DATE(2000;5;5) повертає П'ятниця 05 Травень 2000"

#. Tag: title
#: functions.docbook:959
#, no-c-format
msgid "DATE2UNIX"
msgstr "DATE2UNIX"

#. Tag: para
#: functions.docbook:960
#, no-c-format
msgid "DATE2UNIX() function converts a date and time value to unix time."
msgstr "Функція DATE2UNIX() перетворює дату і час на значення часу unix."

#. Tag: para
#: functions.docbook:961 functions.docbook:1655
#, no-c-format
msgid "A unix time is the number of seconds after midnight January 1st, 1970."
msgstr "Час unix — це кількість секунд після опівночі 1 січня 1970."

#. Tag: para
#: functions.docbook:966
#, no-c-format
msgid "DATE2UNIX(date)"
msgstr "DATE2UNIX(дата)"

#. Tag: para
#: functions.docbook:973
#, no-c-format
msgid "DATE2UNIX(\"01/01/2000\") returns 946,684,800"
msgstr "DATE2UNIX(\"01.01.2000\") повертає 946.684.800"

#. Tag: title
#: functions.docbook:979
#, no-c-format
msgid "DATEDIF"
msgstr "DATEDIF"

#. Tag: para
#: functions.docbook:980
#, no-c-format
msgid "The DATEDIF() function returns the difference between two dates."
msgstr "Функція DATEDIF() повертає різницю між двома датами."

#. Tag: para
#: functions.docbook:981
#, no-c-format
msgid ""
"Interval must be one of the following: \"m\": month; \"d\": days; \"y\": "
"complete years; \"ym\": month excluding years; \"yd\": days excluding years; "
"\"md\": days excluding months and years"
msgstr ""
"Інтервал має одне з таких значень: \"m\": місяці; \"d\": дні; \"y\": роки "
"повністю; \"ym\": місяців без років; \"yd\": днів без років; \"md\": днів "
"без місяців і років"

#. Tag: para
#: functions.docbook:986
#, no-c-format
msgid "DATEDIF(first date; second date; interval)"
msgstr "DATEDIF(перша дата; друга дата; проміжок)"

#. Tag: seg
#: functions.docbook:990 functions.docbook:1830
#, no-c-format
msgid "First date"
msgstr "Перша дата"

#. Tag: seg
#: functions.docbook:991 functions.docbook:1831
#, no-c-format
msgid "Second date"
msgstr "Друга дата"

#. Tag: seg
#: functions.docbook:992 functions.docbook:1832
#, no-c-format
msgid "interval"
msgstr "проміжок"

#. Tag: para
#: functions.docbook:995
#, no-c-format
msgid ""
"DATEDIF(A1;A2;\"d\") A1 is \"1st of January 1995\" and A2 is \"15th of June "
"1999\" returns number of days 1626"
msgstr ""
"DATEDIF(A1;A2;\"d\"), якщо A1 містить «1 січня 1995», а A2 містить «15 "
"червня 1999», повертає кількість днів 1626"

#. Tag: para
#: functions.docbook:999
#, no-c-format
msgid ""
"DATEDIF(A1;A2;\"m\") A1 is \"1st of January 1995\" and A2 is \"15th of June "
"1999\" returns number of months 53"
msgstr ""
"DATEDIF(A1;A2;\"m\"), якщо A1 містить «1 січня 1995», а A2 містить «15 "
"червня 1999», повернеre кількість місяців — 53"

#. Tag: title
#: functions.docbook:1005
#, no-c-format
msgid "DATEVALUE"
msgstr "DATEVALUE"

#. Tag: para
#: functions.docbook:1006
#, no-c-format
msgid ""
"The DATEVALUE function returns a number representing the day, i.e the number "
"of days elapsed since December 31, 1899."
msgstr ""
"Функція DATEVALUE повертає число, що відповідає поточному дню і дорівнює "
"кількості днів, що минули з 31 грудня 1899 року."

#. Tag: para
#: functions.docbook:1011
#, no-c-format
msgid "DATEVALUE(date)"
msgstr "DATEVALUE(дата)"

#. Tag: para
#: functions.docbook:1018
#, no-c-format
msgid "DATEVALUE(\"2/22/2002\") returns 37309"
msgstr "DATEVALUE(\"22.2.2002\") повертає 37309"

#. Tag: member
#: functions.docbook:1022
#, no-c-format
msgid "<link linkend=\"TIMEVALUE\">TIMEVALUE</link>&nbsp;"
msgstr "<link linkend=\"TIMEVALUE\">TIMEVALUE</link>&nbsp;"

#. Tag: title
#: functions.docbook:1029
#, no-c-format
msgid "<title>DAY</title>"
msgstr "<title>DAY</title>"

#. Tag: para
#: functions.docbook:1030
#, no-c-format
msgid ""
"The DAY functions returns the day of a date. If no parameter is specified "
"the current day gets returned."
msgstr ""
"Функція DAY повертає день місяця заданої дати. Якщо функції не передано "
"параметрів, буде повернуто значення поточного дня місяця."

#. Tag: para
#: functions.docbook:1035
#, no-c-format
msgid "DAY(date)"
msgstr "DAY(дата)"

#. Tag: para
#: functions.docbook:1042
#, no-c-format
msgid "DAY(\"2/22/2002\") returns 22"
msgstr "DAY(\"22.2.2002\") повертає 22"

#. Tag: para
#: functions.docbook:1045
#, no-c-format
msgid "DAY(2323.1285) returns 11"
msgstr "DAY(2323,1285) повертає 11"

#. Tag: member
#: functions.docbook:1049 functions.docbook:1266 functions.docbook:1812
#, no-c-format
msgid "<link linkend=\"MONTH\">MONTH</link>&nbsp;"
msgstr "<link linkend=\"MONTH\">MONTH</link>&nbsp;"

#. Tag: member
#: functions.docbook:1050 functions.docbook:1431
#, no-c-format
msgid "<link linkend=\"YEAR\">YEAR</link>&nbsp;"
msgstr "<link linkend=\"YEAR\">YEAR</link>&nbsp;"

#. Tag: title
#: functions.docbook:1057
#, no-c-format
msgid "DAYNAME"
msgstr "DAYNAME"

#. Tag: para
#: functions.docbook:1058
#, no-c-format
msgid ""
"The DAYNAME() function returns the name of the day of the week (1..7). In "
"some countries the first day of the week is Monday, while in others the "
"first day of the week is Sunday."
msgstr ""
"Функція DAYNAME() повертає назву дня тижня (1..7). В деяких країнах перший "
"день — понеділок, а у інших — неділя."

#. Tag: para
#: functions.docbook:1063
#, no-c-format
msgid "DAYNAME(weekday)"
msgstr "DAYNAME(день тижня)"

#. Tag: seg
#: functions.docbook:1067
#, no-c-format
msgid "Number of day in week (1..7)"
msgstr "Номер дня тижня (1..7)"

#. Tag: para
#: functions.docbook:1070
#, no-c-format
msgid "DAYNAME(1) returns Monday (if the week starts on Monday)"
msgstr "DAYNAME(1) повертає «Понеділок» (якщо тиждень починається в понеділок)"

#. Tag: member
#: functions.docbook:1074
#, no-c-format
msgid "<link linkend=\"WEEKDAY\">WEEKDAY</link>&nbsp;"
msgstr "<link linkend=\"WEEKDAY\">WEEKDAY</link>&nbsp;"

#. Tag: title
#: functions.docbook:1081
#, no-c-format
msgid "DAYOFYEAR"
msgstr "DAYOFYEAR"

#. Tag: para
#: functions.docbook:1082
#, no-c-format
msgid ""
"The DAYOFYEAR() function returns the number of the day in the year (1...365)."
msgstr "Функція DAYOFYEAR() повертає порядковий номер дня у році (1...365)."

#. Tag: para
#: functions.docbook:1087
#, no-c-format
msgid "DAYOFYEAR(year;month;date)"
msgstr "DAYOFYEAR(рік;місяць;число)"

#. Tag: para
#: functions.docbook:1096
#, no-c-format
msgid "DAYOFYEAR(2000;12;1) returns 336"
msgstr "DAYOFYEAR(2000;12;1) повертає 336"

#. Tag: para
#: functions.docbook:1099
#, no-c-format
msgid "DAYOFYEAR(2000;2;29) returns 60"
msgstr "DAYOFYEAR(2000;2;29) повертає 60"

#. Tag: title
#: functions.docbook:1105
#, no-c-format
msgid "DAYS"
msgstr "DAYS"

#. Tag: para
#: functions.docbook:1106
#, no-c-format
msgid "The DAYS() function returns the difference between two dates in days."
msgstr "Функція DAYS() повертає різницю між двома датами у днях."

#. Tag: para
#: functions.docbook:1111
#, no-c-format
msgid "DAYS(date2; date1)"
msgstr "DAYS(дата2; дата1)"

#. Tag: seg
#: functions.docbook:1115 functions.docbook:1467 functions.docbook:1736
#: functions.docbook:1848
#, no-c-format
msgid "First (earlier) date value"
msgstr "Перша (раніша) дата"

#. Tag: seg
#: functions.docbook:1116 functions.docbook:1468 functions.docbook:1737
#: functions.docbook:1849
#, no-c-format
msgid "Second date value"
msgstr "Друга (пізніша) дата"

#. Tag: para
#: functions.docbook:1119
#, no-c-format
msgid "DAYS(\"2002-02-22\"; \"2002-02-26\") returns 4"
msgstr "DAYS(\"2002-02-22\"; \"2002-02-26\") поверне 4"

#. Tag: title
#: functions.docbook:1125
#, no-c-format
msgid "DAYS360"
msgstr "DAYS360"

#. Tag: para
#: functions.docbook:1126
#, no-c-format
msgid ""
"The DAYS360() function returns the number of days from date1 to date2 using "
"a 360-day calendar in which all months are assumed to have 30 days. If "
"method is false (default) the US method will be used, the European otherwise."
msgstr ""
"Функція DAYS360() повертає кількість днів між двома датами (дата1 та дата2) "
"за 360-денним календарем, у якому всі місяці тривають по 30 днів. Якщо "
"значення методу FALSE (типове значення), буде використано метод розрахунків, "
"прийнятий у США, інакше використовуватиметься європейський метод розрахунку."

#. Tag: para
#: functions.docbook:1131
#, no-c-format
msgid "DAYS360(date1; date2; method)"
msgstr "DAYS360(дата1; дата2; метод)"

#. Tag: seg
#: functions.docbook:1135
#, no-c-format
msgid "Date1"
msgstr "Дата1"

#. Tag: seg
#: functions.docbook:1136
#, no-c-format
msgid "Date2"
msgstr "Дата2"

#. Tag: seg
#: functions.docbook:1137
#, no-c-format
msgid "Method"
msgstr "Метод"

#. Tag: para
#: functions.docbook:1140
#, no-c-format
msgid "DAYS360(\"2/22/2002\"; \"4/21/2002\"; FALSE) returns 59"
msgstr "DAYS360(\"2/22/2002\"; \"4/21/2002\"; FALSE) повертає 59"

#. Tag: member
#: functions.docbook:1144
#, no-c-format
msgid "<link linkend=\"DAYS\">DAYS</link>&nbsp;"
msgstr "<link linkend=\"DAYS\">DAYS</link>&nbsp;"

#. Tag: member
#: functions.docbook:1145
#, no-c-format
msgid "<link linkend=\"MONTHS\">MONTHS</link>&nbsp;"
msgstr "<link linkend=\"MONTHS\">MONTHS</link>&nbsp;"

#. Tag: member
#: functions.docbook:1146
#, no-c-format
msgid "<link linkend=\"WEEKS\">WEEKS</link>&nbsp;"
msgstr "<link linkend=\"WEEKS\">WEEKS</link>&nbsp;"

#. Tag: member
#: functions.docbook:1147
#, no-c-format
msgid "<link linkend=\"YEARS\">YEARS</link>&nbsp;"
msgstr "<link linkend=\"YEARS\">YEARS</link>&nbsp;"

#. Tag: title
#: functions.docbook:1154
#, no-c-format
msgid "DAYSINMONTH"
msgstr "DAYSINMONTH"

#. Tag: para
#: functions.docbook:1155
#, no-c-format
msgid ""
"The function DAYSINMONTH() returns the number of days in the given year and "
"month."
msgstr "Функція DAYSINMONTH() повертає кількість днів у даному місяці року."

#. Tag: para
#: functions.docbook:1160
#, no-c-format
msgid "DAYSINMONTH(year;month)"
msgstr "DAYSINMONTH(рік;місяць)"

#. Tag: para
#: functions.docbook:1168
#, no-c-format
msgid "DAYSINMONTH(2000;2) returns 29"
msgstr "DAYSINMONTH(2000;2) повертає 29"

#. Tag: title
#: functions.docbook:1174
#, no-c-format
msgid "DAYSINYEAR"
msgstr "DAYSINYEAR"

#. Tag: para
#: functions.docbook:1175
#, no-c-format
msgid "The function DAYSINYEAR() returns the number of days in the given year."
msgstr "Функція DAYSINYEAR() повертає кількість днів у переданому їй році."

#. Tag: para
#: functions.docbook:1180
#, no-c-format
msgid "DAYSINYEAR(year)"
msgstr "DAYSINYEAR(рік)"

#. Tag: para
#: functions.docbook:1187
#, no-c-format
msgid "DAYSINYEAR(2000) returns 366"
msgstr "DAYSINYEAR(2000) повертає 366"

#. Tag: title
#: functions.docbook:1193
#, no-c-format
msgid "EASTERSUNDAY"
msgstr "EASTERSUNDAY"

#. Tag: para
#: functions.docbook:1194
#, no-c-format
msgid ""
"The EASTERSUNDAY() function returns the date which corresponds to Easter "
"Sunday in the year given as the parameter."
msgstr ""
"Функція EASTERSUNDAY() повертає дату, що відповідає Великодній неділі у році "
"переданому їй як параметр."

#. Tag: para
#: functions.docbook:1199
#, no-c-format
msgid "EASTERSUNDAY(year)"
msgstr "EASTERSUNDAY(рік)"

#. Tag: para
#: functions.docbook:1206
#, no-c-format
msgid "EASTERSUNDAY(2003) returns \"20th April 2003\""
msgstr "EASTERSUNDAY(2003) повертає «20 квітня 2003»"

#. Tag: title
