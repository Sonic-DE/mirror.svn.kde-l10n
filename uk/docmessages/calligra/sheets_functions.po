msgstr "<link linkend=\"DSTDEV\">DSTDEV</link>&nbsp;"

#. Tag: title
#: functions.docbook:785
#, no-c-format
msgid "DSUM"
msgstr "DSUM"

#. Tag: para
#: functions.docbook:786
#, no-c-format
msgid ""
"Sums up the numbers in a column of a database specified by a set of "
"conditions."
msgstr ""
"Обчислює суму чисел у колонці бази даних у комірках, заданих набором умов."

#. Tag: para
#: functions.docbook:791
#, no-c-format
msgid "DSUM(Database; \"Header\"; Conditions)"
msgstr "DSUM(база_даних; \"Заголовок\"; Умови)"

#. Tag: para
#: functions.docbook:800
#, no-c-format
msgid "DSUM(A1:C5; \"Salary\"; A9:A11)"
msgstr "DSUM(A1:C5; \"Зарплата\"; A9:A11)"

#. Tag: title
#: functions.docbook:806
#, no-c-format
msgid "DVAR"
msgstr "DVAR"

#. Tag: para
#: functions.docbook:807
#, no-c-format
msgid ""
"Returns the estimate of the variance of a population based on a sample using "
"all numeric values in a column of a database specified by a set of "
"conditions."
msgstr ""
"Повертає оцінку відхилення генеральної сукупності, що базується на вибірці з "
"всіх числових значень в колонці бази даних за значеннями, що задовольняють "
"набір умов."

#. Tag: para
#: functions.docbook:812
#, no-c-format
msgid "DVAR(Database; \"Header\"; Conditions)"
msgstr "DVAR(База_даних; \"Заголовок\"; Умова)"

#. Tag: para
#: functions.docbook:821
#, no-c-format
msgid "DVAR(A1:C5; \"Salary\"; A9:A11)"
msgstr "DVAR(A1:C5; \"Зарплата\"; A9:A11)"

#. Tag: member
#: functions.docbook:825
#, no-c-format
msgid "<link linkend=\"DVARP\">DVARP</link>&nbsp;"
msgstr "<link linkend=\"DVARP\">DVARP</link>&nbsp;"

#. Tag: title
#: functions.docbook:832
#, no-c-format
msgid "DVARP"
msgstr "DVARP"

#. Tag: para
#: functions.docbook:833
#, no-c-format
msgid ""
"Returns the variance of a population based on the entire population using "
"all numeric values in a column of a database specified by a set of "
"conditions."
msgstr ""
"Повертає відхилення генеральної сукупності, що базується повній сукупності з "
"всіх числових значень в колонці бази даних у комірках, що задовольняють "
"набір умов."

#. Tag: para
#: functions.docbook:838
#, no-c-format
msgid "DVARP(Database; \"Header\"; Conditions)"
msgstr "DVARP(База_даних; \"Заголовок\"; Умови)"

#. Tag: para
#: functions.docbook:847
#, no-c-format
msgid "DVARP(A1:C5; \"Salary\"; A9:A11)"
msgstr "DVARP(A1:C5; \"Зарплата\"; A9:A11)"

#. Tag: member
#: functions.docbook:851
#, no-c-format
msgid "<link linkend=\"DVAR\">DVAR</link>&nbsp;"
msgstr "<link linkend=\"DVAR\">DVAR</link>&nbsp;"

#. Tag: title
#: functions.docbook:858
#, no-c-format
msgid "GETPIVOTDATA"
msgstr "GETPIVOTDATA"

#. Tag: para
#: functions.docbook:859
#, no-c-format
msgid "Fetches summary data from a pivot table."
msgstr "Отримує підсумкові дані зі зведеної таблиці."

#. Tag: para
#: functions.docbook:864
#, no-c-format
msgid "GETPIVOTDATA(Database; \"Sales\")"
msgstr "GETPIVOTDATA(Database; \"Продажі\")"

#. Tag: seg
#: functions.docbook:868
#, no-c-format
msgid "Range containing the pivot table"
msgstr "Діапазон, що містить зведену таблицю"

#. Tag: seg
#: functions.docbook:869
#, no-c-format
msgid "Name of the field of which you want the summary data"
msgstr "Назва поля, для якого ви бажаєте отримати зведені дані"

#. Tag: title
#: functions.docbook:875
#, no-c-format
msgid "Date &amp; Time"
msgstr "Дата і час"

#. Tag: title
#: functions.docbook:878
#, no-c-format
msgid "CURRENTDATE"
msgstr "CURRENTDATE"

#. Tag: para
#: functions.docbook:879
#, no-c-format
msgid ""
"The CURRENTDATE() function returns the current date. It is equivalent to the "
"TODAY function."
msgstr ""
"Функція CURRENTDATE() повертає поточну дату. Вона повністю тотожна з "
"функцією TODAY."

