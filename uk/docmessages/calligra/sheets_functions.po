msgstr "EOMONTH(\"22.2.2002\"; 3) повертає «31.5.2002»"

#. Tag: para
#: functions.docbook:1258
#, no-c-format
msgid "EOMONTH(\"3/12/2002\"; -1) returns \"2/28/2002\""
msgstr "EOMONTH(\"12.3.2002\"; -1) повертає «28.2.2002»"

#. Tag: para
#: functions.docbook:1261
#, no-c-format
msgid "EOMONTH(\"3/12/2002\"; 0) returns \"3/31/2002\""
msgstr "EOMONTH(\"12.3.2002\"; 0) повертає «31.3.2002»"

