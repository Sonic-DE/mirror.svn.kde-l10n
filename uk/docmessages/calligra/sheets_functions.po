msgstr "<link linkend=\"LOGN\">LOGN</link>&nbsp;"

#. Tag: title
#: functions.docbook:6335
#, no-c-format
msgid "LOG10"
msgstr "LOG10"

#. Tag: para
#: functions.docbook:6336
#, no-c-format
msgid "The LOG10() function returns the base-10 logarithm of the argument."
msgstr "Функція LOG10() повертає логарифм x за основою 10."

