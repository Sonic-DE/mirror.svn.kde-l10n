#~ msgid "virtual enabled"
#~ msgstr "віртуальну увімкнено"

#~ msgid ""
#~ "If zero, the use of virtual memory will be disabled, otherwise the use of "
#~ "virtual memory will be enabled."
#~ msgstr ""
#~ "Якщо нуль, використання віртуальної пам’яті буде вимкнено, якщо не нуль — "
#~ "використання віртуальної пам’яті буде увімкнено."

#~ msgid "virtual limited"
#~ msgstr "віртуальну обмежено"

#~ msgid ""
#~ "If zero, the use of virtual memory will be not limited, otherwise the use "
#~ "of virtual memory will be limited. Only has an effect if the parameter "
#~ "<replaceable>virtual enabled</replaceable> has been set to a non zero "
#~ "value."
#~ msgstr ""
#~ "Якщо нуль, об’єм віртуальної пам’яті не буде обмежено, якщо не нуль — "
#~ "використання віртуальної пам’яті обмежуватиметься. Працює, лише якщо "
#~ "встановлено ненульове значення параметра <replaceable>віртуальну "
#~ "увімкнено</replaceable>."

#~ msgid "virtual limit"
#~ msgstr "обмеження віртуальної"

#~ msgid ""
#~ "Limitation of the virtual memory in units of whole MB. Only has an effect "
#~ "if the parameters <replaceable>virtual enabled</replaceable> and "
#~ "<replaceable>virtual limited</replaceable> have both been set to a non "
#~ "zero value."
#~ msgstr ""
#~ "Обмеження віртуальної пам’яті у одиницях цілих МБ. Працює, лише якщо "
#~ "встановлено ненульове значення параметрів <replaceable>віртуальну "
#~ "увімкнено</replaceable> та <replaceable>віртуальну обмежено</replaceable>."

#~ msgid "virtual directory"
#~ msgstr "віртуальний каталог"

#~ msgid ""
#~ "Directory to use for storing swap files that will be used for providing "
#~ "virtual memory. Only has an effect if the parameter <replaceable>virtual "
#~ "enabled</replaceable> has been set to a non zero value."
#~ msgstr ""
#~ "Каталог, до якого слід зберігати файли резервної пам’яті, які "
#~ "використовуватимуться для забезпечення роботи віртуальної пам’яті. "
