"<shortcut><keycap>F8</keycap></shortcut> <guimenu>Settings</guimenu> "
"<guimenuitem>Identities...</guimenuitem>"
msgstr ""
"<shortcut><keycap>F8</keycap></shortcut> <guimenu>Параметри</guimenu> "
