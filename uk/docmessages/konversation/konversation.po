#: index.docbook:2968
#, no-c-format
msgid ""
"<guimenu>Bookmarks</guimenu> <guimenuitem>New Bookmark Folder...</"
"guimenuitem>"
msgstr ""
"<guimenu>Закладки</guimenu> <guimenuitem>Створити теку закладок...</"
"guimenuitem>"

#. Tag: action
#: index.docbook:2973
#, no-c-format
msgid "Creates a new bookmark folder."
msgstr "Створює нову теку закладок."

#. Tag: menuchoice
#: index.docbook:2977
#, no-c-format
