"\"><guimenuitem>State of matter</guimenuitem></ulink>&nbsp;"
msgstr ""
"<ulink url=\"https://uk.wikipedia.org/wiki/"
"%D0%90%D0%B3%D1%80%D0%B5%D0%B3%D0%B0%D1%82%D0%BD%D0%B8%D0%B9_"
"%D1%81%D1%82%D0%B0%D0%BD\"><guimenuitem>Стан речовини</guimenuitem></"
"ulink>&nbsp;"

