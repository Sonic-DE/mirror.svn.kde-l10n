msgstr ""
"<ulink url=\"https://uk.wikipedia.org/wiki/%D0%9A%D0%BE%D0%B2%D0%B0%D0%BB"
"%D0%B5%D0%BD%D1%82%D0%BD%D0%B8%D0%B9_"
"%D1%80%D0%B0%D0%B4%D1%96%D1%83%D1%81\"><guimenuitem>Ковалентний радіус</"
"guimenuitem></ulink>&nbsp;"

#. Tag: para
#: index.docbook:457
#, no-c-format
msgid ""
"<ulink url=\"https://en.wikipedia.org/wiki/Van_der_Waals_radius"
"\"><guimenuitem>Van der Waals</guimenuitem></ulink>: gradient by van der "
"Waals radius."
msgstr ""
"<ulink url=\"https://en.wikipedia.org/wiki/Van_der_Waals_radius"
"\"><guimenuitem>Ван-дер-Ваальс</guimenuitem></ulink>: градієнт за радіусом "
"Ван-дер-Ваальса"

#. Tag: para
#: index.docbook:459
#, no-c-format
msgid ""
"<ulink url=\"https://en.wikipedia.org/wiki/Atomic_Mass\"><guimenuitem>Atomic "
"Mass</guimenuitem></ulink>&nbsp;"
