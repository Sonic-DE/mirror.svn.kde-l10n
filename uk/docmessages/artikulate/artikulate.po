#~ msgid "Learning Controls"
#~ msgstr "Керування навчанням"

#~ msgid ""
#~ "<guilabel>OK</guilabel>: Mark current phrase as learned and continue with "
#~ "next phrase."
#~ msgstr ""
#~ "<guilabel>Гаразд</guilabel>: позначити поточну фразу як вивчену і перейти "
#~ "до вивчення наступної фрази."

#~ msgid ""
#~ "<guilabel>Retry Later</guilabel>: Continue with training next phrase, but "
#~ "try this phrase later again."
#~ msgstr ""
#~ "<guilabel>Повторити пізніше</guilabel>: перейти до вивчення наступної "
