#~ msgid ""
#~ "<guilabel>Stop</guilabel>: Stops the training and proceeds to the "
#~ "statistics view. Current training results are saved to training "
#~ "statistics."
#~ msgstr ""
#~ "<guilabel>Стоп</guilabel>: припинити сеанс навчання і перейти до "
