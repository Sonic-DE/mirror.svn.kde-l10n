#~ msgid "<option>--caption</option> <parameter>caption</parameter>"
#~ msgstr "<option>--caption</option> <parameter>заголовок</parameter>"

#~ msgid "Use <parameter>caption</parameter> as name in the titlebar."
#~ msgstr ""
#~ "Використовувати <parameter>заголовок</parameter> як назву у смужці "
#~ "заголовка вікна програми."

#~ msgid "Use <parameter>icon</parameter> as the application icon."
#~ msgstr ""
#~ "Використовувати <parameter>піктограму</parameter> як піктограму програми."

#~ msgid "Use the alternative configuration <parameter>filename</parameter>"
#~ msgstr ""
#~ "Використовувати альтернативні налаштування <parameter>назва_файла</"
#~ "parameter>"

#~ msgid "--nocrashhandler"
#~ msgstr "--nocrashhandler"

#~ msgid "Disable the crash handler, to get core dumps."
#~ msgstr ""
#~ "Вимкнути засіб обробки критичних помилок, призначений для створення "
#~ "дампів ядра."

#~ msgid "--waitforwm"
#~ msgstr "--waitforwm"

#~ msgid "Waits for a WM_NET compatible windowmanager."
#~ msgstr "Чекає на засіб керування вікнами, сумісний з WM_NET."

#~ msgid "<option>--style</option> <parameter>style</parameter>"
#~ msgstr "<option>--style</option> <parameter>стиль</parameter>"

#~ msgid "Sets the application &GUI; style."
#~ msgstr "Встановлює стиль графічного інтерфейсу програми."

#~ msgid "<option>--geometry</option> <parameter>geometry</parameter>"
#~ msgstr "<option>--geometry</option> <parameter>геометрія</parameter>"

#~ msgid "Sets the client geometry of the main widget."
#~ msgstr "Встановлює клієнтську геометрію головного віджета."

#~ msgid "<replaceable>qt5options</replaceable>(7)"
#~ msgstr "<replaceable>qt5options</replaceable>(7)"

