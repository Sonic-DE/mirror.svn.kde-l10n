#, no-c-format
msgid "&Ctrl;<keycap>H</keycap>"
msgstr "&Ctrl;<keycap>H</keycap>"

#. Tag: para
#: index.docbook:883
#, no-c-format
msgid "Show a chat window."
msgstr "Показати вікно спілкування"

#. Tag: keycombo
#: index.docbook:890
#, no-c-format
msgid "&Ctrl;<keycap>G</keycap>"
msgstr "&Ctrl;<keycap>G</keycap>"

#. Tag: para
#: index.docbook:892
#, no-c-format
msgid "Change the viewing angle."
msgstr "Змінює кут перегляду."

#. Tag: keycombo
#: index.docbook:899
#, no-c-format
msgid "&Ctrl;<keycap>D</keycap>"
msgstr "&Ctrl;<keycap>D</keycap>"

#. Tag: para
