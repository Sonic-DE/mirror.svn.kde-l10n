#. Tag: para
#: index.docbook:36
#, no-c-format
msgid "&kget; is an advanced download manager by &kde;"
msgstr ""
"&kget; — це програма для керування отриманням даних, яку створено &kde;"

#. Tag: keyword
#: index.docbook:42
#, no-c-format
msgid "<keyword>KDE</keyword>"
msgstr "<keyword>KDE</keyword>"

#. Tag: keyword
#: index.docbook:43
#, no-c-format
