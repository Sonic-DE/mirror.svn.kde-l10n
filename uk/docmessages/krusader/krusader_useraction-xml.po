"  &lt;icon>document-save-as&lt;/icon>\n"
"  &lt;category>System&lt;/category>\n"
"  &lt;description same_as=\"tooltip\" />\n"
"  &lt;command>%_Copy(&quot;%aCurrent%&quot;, &quot;%_Ask(&quot;new "
