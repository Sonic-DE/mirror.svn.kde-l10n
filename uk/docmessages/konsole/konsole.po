#, no-c-format
msgid ""
"<guimenu>Settings</guimenu><guimenuitem>Configure Notifications...</"
"guimenuitem>"
msgstr ""
"<guimenu>Параметри</guimenu><guimenuitem>Налаштувати сповіщення...</"
"guimenuitem>"

#. Tag: action
