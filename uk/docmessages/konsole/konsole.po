msgstr ""
"<guimenu>Параметри</guimenu> <guimenuitem>Показати смужку стану</guimenuitem>"

#. Tag: action
#: index.docbook:1152
#, no-c-format
msgid "Toggles the statusbar being visible"
msgstr "Вмикає або вимикає видимість смужки стану"

#. Tag: menuchoice
