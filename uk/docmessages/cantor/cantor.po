#: index.docbook:761
#, no-c-format
msgid ""
"<action>Inserts a &latex; entry below the current cursor position.</action>."
msgstr ""
"<action>Вставляє новий запис LaTeX під поточним розташуванням курсора.</"
"action>"

#. Tag: menuchoice
#: index.docbook:764
#, no-c-format
msgid "<guimenu>Worksheet</guimenu> <guimenuitem>Insert Image</guimenuitem>"
msgstr ""
"<guimenu>Аркуш</guimenu> <guimenuitem>Вставити зображення</guimenuitem>"

