#, no-c-format
msgid "Network Folders"
msgstr "Мережеві теки"

#. Tag: keyword
#: index.docbook:56
#, no-c-format
msgid "Network Folder Wizard"
msgstr "Майстер мережевих тек"

#. Tag: keyword
