#~ msgid "Magicfilter"
#~ msgstr "Magicfilter"

#~ msgid ""
#~ "Similarly to the APSfilter program, Magicfilter provides automatic file "
#~ "type recognition functions and, base on that, automatic file conversion "
#~ "to a printable format, depending on the target printer."
