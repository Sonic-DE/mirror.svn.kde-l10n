msgstr "&Ctrl;<keycap>Esc</keycap>"

#. Tag: entry
#: ui.docbook:1366
#, no-c-format
msgid "System Activity"
msgstr "Відкрити вікно програми «Системні процеси»"

#. Tag: keycombo
#: ui.docbook:1370
#, no-c-format
msgid "&Alt;<keycap>F4</keycap>"
msgstr "&Alt;<keycap>F4</keycap>"

