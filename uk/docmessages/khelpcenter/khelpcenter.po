#~ msgid ""
#~ "&khelpcenter; is a part of the &applications;. It can be found on the "
#~ "<ulink url=\"https://download.kde.org/\"> download site</ulink> of the "
#~ "&kde; project, or will be found in your operating system's &khelpcenter; "
#~ "package."
#~ msgstr ""
#~ "&khelpcenter; є частиною комплекту програм &kde;. Цю програму можна "
#~ "знайти на <ulink url=\"https://download.kde.org/\">сайті пакунків</ulink> "
#~ "проєкту&kde;, крім того, цю програму можна встановити за допомогою "
#~ "пакунка &khelpcenter; вашої операційної системи."

#~ msgid ""
#~ "Boolean syntax lets you use the operators <literal>AND</literal>, "
#~ "<literal>OR</literal> and <literal>NOT</literal> to create complex "
#~ "searches. Some examples:"
#~ msgstr ""
#~ "Синтаксис надає вам змогу використовувати логічні оператори <literal>AND</"
#~ "literal>, <literal>OR</literal> і <literal>NOT</literal> для створення "
#~ "складних запитів. Приклади:"

#~ msgid "cat and dog"
#~ msgstr "кіт and пес"

#~ msgid ""
#~ "Searches for pages which have both the words <userinput>cat</userinput> "
#~ "and <userinput>dog</userinput> in them. Pages with only one or the other "
#~ "will not be returned."
#~ msgstr ""
#~ "Шукати сторінки, на яких є обидва слова, <userinput>кіт</userinput> і "
#~ "<userinput>пес</userinput>. Сторінки, на яких є лише одне з цих слів, "
#~ "буде пропущено."

#~ msgid "cat not dog"
#~ msgstr "кіт not пес"

#~ msgid ""
#~ "Searches for pages with <userinput>cat</userinput> in them, but only "
#~ "returns the ones that don't have the word <userinput>dog</userinput> in "
#~ "them."
#~ msgstr ""
#~ "Шукати сторінки зі словом <userinput>кіт</userinput>, але повернути лише "
#~ "ті з них, на яких немає слова <userinput>пес</userinput>."

#~ msgid "cat or (dog not nose)"
#~ msgstr "кіт or (пес not ніс)"

#~ msgid ""
#~ "Searches for pages which contain <userinput>cat</userinput>, and for "
#~ "pages which contain <userinput>dog</userinput> but don't contain "
#~ "<userinput>nose</userinput>. Pages which contain both <userinput>cat</"
#~ "userinput> and <userinput>nose</userinput> would be returned, pages "
#~ "containing all three words would not."
#~ msgstr ""
#~ "Шукати сторінки, на яких є слово <userinput>кіт</userinput>, та сторінки, "
#~ "на яких є слово <userinput>пес</userinput>, але немає слова "
#~ "<userinput>ніс</userinput>. Сторінки, які містять обидва слова, "
#~ "<userinput>кіт</userinput> і <userinput>ніс</userinput>, потраплять до "
#~ "результатів пошуку, а ті, які містять усі три слова, — ні."

