#. Tag: title
#: commands.docbook:2
#, no-c-format
msgid "Command Reference"
msgstr "Довідка щодо команд"

#. Tag: title
#: commands.docbook:5
#, no-c-format
msgid "&kxstitch; Menus"
msgstr "Меню &kxstitch;"

#. Tag: title
#: commands.docbook:7
#, no-c-format
msgid "The File Menu"
msgstr "Меню «Файл»"

#. Tag: menuchoice
#: commands.docbook:11
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>N</keycap></keycombo></"
"shortcut><guimenuitem>New</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl; <keycap>N</keycap></keycombo></"
"shortcut> <guimenuitem>Створити</guimenuitem>"

#. Tag: action
#: commands.docbook:12
#, no-c-format
msgid ""
"Creates a new pattern, using the default values set in the pattern "
"properties dialog."
msgstr ""
"Створити візерунок на основі типових значень, встановлених за допомогою "
"діалогового вікна властивостей візерунка."

#. Tag: menuchoice
#: commands.docbook:15
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>O</keycap></keycombo></"
"shortcut><guimenuitem>Open</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>O</keycap> </keycombo> </"
"shortcut><guimenuitem>Відкрити...</guimenuitem>"

#. Tag: action
#: commands.docbook:16
#, no-c-format
msgid "Opens an existing pattern"
msgstr "Відкрити наявний візерунок."

#. Tag: guimenuitem
#: commands.docbook:19
#, no-c-format
msgid "Open Recent"
msgstr "Відкрити недавні"

#. Tag: action
#: commands.docbook:20
#, no-c-format
msgid "Open a recently used pattern"
msgstr "Відкрити нещодавно редагований візерунок."

#. Tag: menuchoice
#: commands.docbook:23
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>S</keycap></keycombo></"
"shortcut><guimenuitem>Save</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>S</keycap> </keycombo> </"
"shortcut><guimenuitem>Зберегти</guimenuitem>"

#. Tag: action
#: commands.docbook:24
#, no-c-format
msgid "Saves the pattern"
msgstr "Зберегти візерунок"

#. Tag: menuchoice
#: commands.docbook:27
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;&Shift;<keycap>S</keycap></"
"keycombo></shortcut><guimenuitem>Save As</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;&Shift;<keycap>S</keycap></"
"keycombo></shortcut><guimenuitem>Зберегти як</guimenuitem>"

#. Tag: action
#: commands.docbook:28
#, no-c-format
msgid "Saves the pattern under a new name"
msgstr "Зберегти візерунок під новою назвою."

#. Tag: guimenuitem
#: commands.docbook:31
#, no-c-format
msgid "Revert"
msgstr "Повернути"

#. Tag: action
#: commands.docbook:32
#, no-c-format
msgid "Revert the pattern to the last saved state"
msgstr "Повернути візерунок до останнього збереженого стану."

#. Tag: menuchoice
#: commands.docbook:35
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>P</keycap></keycombo></"
"shortcut><guimenuitem>Print</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>P</keycap> </keycombo> </"
"shortcut><guimenuitem>Друкувати...</guimenuitem>"

#. Tag: action
#: commands.docbook:36
#, no-c-format
msgid "Print the pattern"
msgstr "Надрукувати візерунок."

#. Tag: guimenuitem
#: commands.docbook:39
#, no-c-format
msgid "Print Setup"
msgstr "Налаштування друку"

#. Tag: action
#: commands.docbook:40
#, no-c-format
msgid "Set up the printing layout"
msgstr "Налаштувати компонування сторінки для друку."

#. Tag: guimenuitem
#: commands.docbook:43
#, no-c-format
msgid "Import Image"
msgstr "Імпортування зображення"

#. Tag: action
#: commands.docbook:44
#, no-c-format
msgid "Import an image file converting it to stitches"
msgstr ""
"Імпортувати файл зображення та перетворити його на візерунок зі стібків."

#. Tag: guimenuitem
#: commands.docbook:47
#, no-c-format
msgid "File Properties"
msgstr "Властивості файла"

#. Tag: action
#: commands.docbook:48
#, no-c-format
msgid "Display / Edit the document properties"
msgstr "Показати або редагувати властивості документа."

#. Tag: guimenuitem
#: commands.docbook:51
#, no-c-format
msgid "Add Background Image"
msgstr "Додати зображення тла"

#. Tag: action
#: commands.docbook:52
#, no-c-format
msgid "Insert an image as a background for tracing."
msgstr "Вставити зображення як тло для створення на його основі візерунка."

#. Tag: guimenuitem
#: commands.docbook:55
#, no-c-format
msgid "Remove Background Image"
msgstr "Вилучити зображення тла"

#. Tag: action
#: commands.docbook:56
#, no-c-format
msgid ""
"Select a background image to remove. The sub menu for this is populated from "
"the background images previously inserted."
msgstr ""
"Вибрати зображення тла для вилучення. Пунктами у цьому підменю будуть записи "
"раніше вставлених зображень."

#. Tag: menuchoice
#: commands.docbook:59
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>W</keycap></keycombo></"
"shortcut><guimenuitem>Close</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>W</keycap></keycombo></"
"shortcut> <guimenuitem>Закрити</guimenuitem>"

#. Tag: action
#: commands.docbook:60
#, no-c-format
msgid "Close the pattern"
msgstr "Закрити візерунок."

#. Tag: menuchoice
#: commands.docbook:63
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>Q</keycap></keycombo></"
"shortcut><guimenuitem>Quit</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>Q</keycap> </keycombo> </"
"shortcut><guimenuitem>Вийти</guimenuitem>"

#. Tag: simpara
#: commands.docbook:64
#, no-c-format
msgid "<action>Quits</action> &kxstitch;"
msgstr "<action>Завершити роботу</action> &kxstitch;."

#. Tag: title
#: commands.docbook:71
#, no-c-format
msgid "The Edit Menu"
msgstr "Меню «Зміни»"

#. Tag: menuchoice
#: commands.docbook:75
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>Z</keycap></keycombo></"
"shortcut><guimenuitem>Undo</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>Z</keycap></keycombo> </"
"shortcut><guimenuitem>Вернути</guimenuitem>"

#. Tag: action
#: commands.docbook:76
#, no-c-format
msgid ""
"Undo the last change. The list of changes are shown in the History window."
msgstr ""
"Скасувати останню внесену зміну. Список змін буде показано на панелі журналу."

#. Tag: menuchoice
#: commands.docbook:79
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;&Shift;<keycap>Z</keycap></"
"keycombo></shortcut><guimenuitem>Redo</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;&Shift;<keycap>Z</keycap></"
"keycombo></shortcut><guimenuitem>Повторити</guimenuitem>"

#. Tag: action
#: commands.docbook:80
#, no-c-format
msgid ""
"Redo the last change undone. The list of changes are shown in the History "
"window."
msgstr ""
"Повторити останню скасовану зміну. Список змін буде показано на панелі "
"журналу."

#. Tag: menuchoice
#: commands.docbook:83
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>X</keycap></keycombo></"
"shortcut><guimenuitem>Cut</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>X</keycap></keycombo> </"
"shortcut> <guimenuitem>Вирізати</guimenuitem>"

#. Tag: action
#: commands.docbook:84
#, no-c-format
msgid "Cut the selected area to the clipboard"
msgstr "Вирізати позначену область до буфера обміну даними."

#. Tag: menuchoice
#: commands.docbook:87
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>C</keycap></keycombo></"
"shortcut><guimenuitem>Copy</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>C</keycap></keycombo> </"
"shortcut> <guimenuitem>Копіювати</guimenuitem>"

#. Tag: action
#: commands.docbook:88
#, no-c-format
msgid "Copy the selected area to the clipboard"
msgstr "Копіювати позначену область до буфера обміну даними."

#. Tag: menuchoice
#: commands.docbook:91
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>V</keycap></keycombo></"
"shortcut><guimenuitem>Paste</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>V</keycap></keycombo> </"
"shortcut> <guimenuitem>Вставити</guimenuitem>"

#. Tag: action
#: commands.docbook:92
#, no-c-format
msgid "Paste the selected area"
msgstr "Вставити скопійовану область."

#. Tag: menuchoice
#: commands.docbook:95
#, no-c-format
msgid ""
"<guisubmenu>Selection Masks</guisubmenu><guimenuitem>Stitch Mask</"
"guimenuitem>"
msgstr ""
"<guisubmenu>Маски позначення</guisubmenu><guimenuitem>Маска стібків</"
"guimenuitem>"

#. Tag: action
#: commands.docbook:96
#, no-c-format
msgid "Limit selections to the currently selected stitch type"
msgstr "Обмежити позначення до поточного вибраного типу стібків."

#. Tag: menuchoice
#: commands.docbook:99
#, no-c-format
msgid ""
"<guisubmenu>Selection Masks</guisubmenu><guimenuitem>Color Mask</guimenuitem>"
msgstr ""
"<guisubmenu>Маски позначення</guisubmenu><guimenuitem>Маска кольорів</"
"guimenuitem>"

#. Tag: action
#: commands.docbook:100
#, no-c-format
msgid "Limit selections to the currently selected color"
msgstr "Обмежити позначення до поточного вибраного кольору."

#. Tag: menuchoice
#: commands.docbook:102
#, no-c-format
msgid ""
"<guisubmenu>Selection Masks</guisubmenu><guimenuitem>Exclude Backstitches</"
"guimenuitem>"
msgstr ""
"<guisubmenu>Маски позначення</guisubmenu><guimenuitem>Виключення зворотних "
"стібків</guimenuitem>"

#. Tag: action
#: commands.docbook:103
#, no-c-format
msgid "Exclude backstitches from the selection"
msgstr "Виключити зворотні стібки з позначення."

#. Tag: menuchoice
#: commands.docbook:106
#, no-c-format
msgid ""
"<guisubmenu>Selection Masks</guisubmenu><guimenuitem>Exclude Knots</"
"guimenuitem>"
msgstr ""
"<guisubmenu>Маски позначення</guisubmenu><guimenuitem>Виключення вузлів</"
"guimenuitem>"

#. Tag: action
#: commands.docbook:107
#, no-c-format
msgid "Exclude Knots from the selection"
msgstr "Виключити вузли з позначення."

#. Tag: guimenuitem
#: commands.docbook:110
#, no-c-format
msgid "Mirror / Rotate makes copies"
msgstr "Віддзеркалення і обертання створюють копії"

#. Tag: action
#: commands.docbook:111
#, no-c-format
msgid ""
"If set, the mirror and rotate functions will make a copy of the selection, "
"otherwise the selected area is moved"
msgstr ""
"Якщо позначено, дії з віддзеркалення і обертання створюватимуть копію "
"позначення. Якщо пункт позначено не буде, програма пересуватиме і обертатиме "
"позначену область."

#. Tag: menuchoice
#: commands.docbook:114
#, no-c-format
msgid ""
"<guisubmenu>Mirror Selection</guisubmenu><guimenuitem>Horizontally</"
"guimenuitem>"
msgstr ""
"<guisubmenu>Віддзеркалити позначене</guisubmenu><guimenuitem>Горизонтально</"
"guimenuitem>"

#. Tag: action
#: commands.docbook:115
#, no-c-format
msgid "Mirror the selected area horizontally, &ie; flipped from left to right"
msgstr ""
"Віддзеркалити позначену область горизонтально, тобто перевернути її зліва "
"праворуч."

#. Tag: menuchoice
#: commands.docbook:118
#, no-c-format
msgid ""
"<guisubmenu>Mirror Selection</guisubmenu><guimenuitem>Vertically</"
"guimenuitem>"
msgstr ""
"<guisubmenu>Віддзеркалити позначене</guisubmenu><guimenuitem>Вертикально</"
"guimenuitem>"

#. Tag: action
#: commands.docbook:119
#, no-c-format
msgid "Mirrors the selected area vertically, &ie; flipped from top to bottom"
msgstr ""
"Віддзеркалити позначену область вертикально, тобто перевернути її згори вниз."

#. Tag: menuchoice
#: commands.docbook:122
#, no-c-format
msgid ""
"<guisubmenu>Rotate Selection</guisubmenu><guimenuitem>90 degrees</"
"guimenuitem>"
msgstr ""
"<guisubmenu>Обернути позначене</guisubmenu><guimenuitem>На 90°</guimenuitem>"

#. Tag: action
#: commands.docbook:123
#, no-c-format
msgid "Rotate the selected area anti clockwise 90 degrees"
msgstr "Обернути позначену область проти годинникової стрілки на 90°."

#. Tag: menuchoice
#: commands.docbook:126
#, no-c-format
msgid ""
"<guisubmenu>Rotate Selection</guisubmenu><guimenuitem>180 degrees</"
"guimenuitem>"
msgstr ""
"<guisubmenu>Обернути позначене</guisubmenu><guimenuitem>На 180°</guimenuitem>"

#. Tag: action
#: commands.docbook:127
#, no-c-format
msgid "Rotate the selected area anti clockwise 180 degrees"
msgstr "Обернути позначену область проти годинникової стрілки на 180°."

#. Tag: menuchoice
#: commands.docbook:130
#, no-c-format
msgid ""
"<guisubmenu>Rotate Selection</guisubmenu><guimenuitem>270 degrees</"
"guimenuitem>"
msgstr ""
"<guisubmenu>Обернути позначене</guisubmenu><guimenuitem>На 270°</guimenuitem>"

#. Tag: action
#: commands.docbook:131
#, no-c-format
msgid "Rotate the selected area anti clockwise 270 degrees"
msgstr "Обернути позначену область проти годинникової стрілки на 270°."

#. Tag: title
#: commands.docbook:136
#, no-c-format
msgid "Cut, Copy and Paste"
msgstr "Вирізання, копіювання і вставляння"

#. Tag: para
#: commands.docbook:137
#, no-c-format
msgid ""
"Cutting and copying areas of the pattern can make use of stitch and color "
"masks and the exclusion of backstitches and knots to limit the selection."
msgstr ""
"Під час вирізання та копіювання областей візерунка можна використовувати "
"маски стібків та кольорів, а також виключення зворотних стібків та "
"французьких вузлів для вибору потрібного елемента візерунка."

#. Tag: para
#: commands.docbook:141
#, no-c-format
msgid ""
"The paste operation in &kxstitch; allows you to press and hold the &LMB; "
"down roughly in the position that the paste data is to go which will provide "
"an image of the paste data to allow accurate positioning before releasing "
"the mouse button to finalize the position. This technique is also used for "
"the mirroring and rotate functions. The cursor keys can also be used to move "
"the pasted pattern around and the &Enter; key used to fix the position."
msgstr ""
"Під час дії зі вставляння у &kxstitch; ви можете натиснути і утримувати "
"натисненою ліву кнопку миші у приблизній позиції, куди має бути вставлено "
"скопійовані дані, програма покаже зображення вставленої області. Ви зможете "
"визначити для неї точну позицію, перш ніж відпускати кнопку миші для "
"завершення дії. Цією методикою можна також скористатися для віддзеркалення "
"та обертання. За допомогою клавіш зі стрілочками можна пересувати вставлений "
"фрагмент. Натискання клавіші &Enter; зафіксує його остаточну позицію."

#. Tag: title
#: commands.docbook:152
#, no-c-format
msgid "The View Menu"
msgstr "Меню «Перегляд»"

#. Tag: guimenuitem
#: commands.docbook:156
#, no-c-format
msgid "Actual Size"
msgstr "Фактичний розмір"

#. Tag: action
#: commands.docbook:157
#, no-c-format
msgid "Zoom the view so that the screen size approximates the physical size"
msgstr ""
"Встановити на екрані такий масштаб, який приблизно відповідатиме фізичним "
"розмірам надрукованого візерунка."

#. Tag: guimenuitem
#: commands.docbook:160
#, no-c-format
msgid "Fit To Page"
msgstr "Влаштувати в сторінку"

#. Tag: action
#: commands.docbook:161
#, no-c-format
msgid "Zoom the view so that the whole pattern fits within the visible area"
msgstr ""
"Встановити такий масштаб перегляду, за якого у видимій області вміщатиметься "
"увесь візерунок."

#. Tag: guimenuitem
#: commands.docbook:164
#, no-c-format
msgid "Fit To Page Width"
msgstr "Влаштувати в ширину сторінки"

#. Tag: action
#: commands.docbook:165
#, no-c-format
msgid "Zoom the view so that the patterns width fits within the visible area"
msgstr ""
"Встановити такий масштаб перегляду, за якого у видимій області вміщатиметься "
"уся ширина візерунка."

#. Tag: guimenuitem
#: commands.docbook:168
#, no-c-format
msgid "Fit To Page Height"
msgstr "Влаштувати в висоту сторінки"

#. Tag: action
#: commands.docbook:169
#, no-c-format
msgid "Zoom the view so that the patterns height fits within the visible area"
msgstr ""
"Встановити такий масштаб перегляду, за якого у видимій області вміщатиметься "
"уся висота візерунка."

#. Tag: menuchoice
#: commands.docbook:172
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>+</keycap></keycombo></"
"shortcut><guimenuitem>Zoom In</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>+</keycap></keycombo> </"
"shortcut> <guimenuitem>Збільшити</guimenuitem>"

#. Tag: action
#: commands.docbook:173
#, no-c-format
msgid "Zoom in on the editor view"
msgstr "Збільшити масштаб на панелі редагування."

#. Tag: menuchoice
#: commands.docbook:176
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>-</keycap></keycombo></"
"shortcut><guimenuitem>Zoom Out</guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Ctrl;<keycap>-</keycap></keycombo> </"
"shortcut> <guimenuitem>Зменшити</guimenuitem>"

#. Tag: action
#: commands.docbook:177
#, no-c-format
msgid "Zoom out on the editor view"
msgstr "Зменшити масштаб на панелі редагування."

#. Tag: guimenuitem
#: commands.docbook:179
#, no-c-format
msgid "Preview"
msgstr "Перегляд"

#. Tag: action
#: commands.docbook:180
#, no-c-format
msgid "Show or hide the preview window"
msgstr "Показати або приховати панель попереднього перегляду."

#. Tag: guimenuitem
#: commands.docbook:183
#, no-c-format
msgid "Palette"
msgstr "Палітра"

#. Tag: action
#: commands.docbook:184
#, no-c-format
msgid "Show or hide the palette window"
msgstr "Показати або сховати панель палітри."

#. Tag: guimenuitem
#: commands.docbook:187
#, no-c-format
msgid "History"
msgstr "Журнал"

#. Tag: action
#: commands.docbook:188
#, no-c-format
msgid "Show or hide the history window"
msgstr "Показати або сховати панель журналу"

#. Tag: guimenuitem
#: commands.docbook:191
#, no-c-format
msgid "Imported Image"
msgstr "Імпортоване зображення"

#. Tag: action
#: commands.docbook:192
#, no-c-format
msgid "Show or hide the imported image preview window"
msgstr ""
"Показати або приховати панель попереднього перегляду імпортованого "
"зображення."

#. Tag: guimenuitem
#: commands.docbook:195
#, no-c-format
msgid "Show Background Image"
msgstr "Показувати зображення тла"

#. Tag: action
#: commands.docbook:196
#, no-c-format
msgid ""
"Show or hide a background image. The list is generated dynamically based on "
"the inserted background images"
msgstr ""
"Показати або приховати зображення тла. Список цього підменю формуватиметься "
"динамічно, відповідно до списку вставлених зображень тла."

#. Tag: guimenuitem
#: commands.docbook:199
#, no-c-format
msgid "Fit Background Image to Selection"
msgstr "Підібрати розмір зображення тла за позначеним"

#. Tag: action
#: commands.docbook:200
#, no-c-format
msgid "Fit the selected background image to the current selection area"
msgstr ""
"Підібрати розміри вибраного зображення тла до поточної позначеної області."

#. Tag: title
#: commands.docbook:207
#, no-c-format
msgid "The Stitches Menu"
msgstr "Меню «Стібки»"

#. Tag: guimenuitem
#: commands.docbook:211
#, no-c-format
msgid "Quarter Stitch"
msgstr "Чвертьстібок"

#. Tag: action
#: commands.docbook:212
#, no-c-format
msgid ""
"Quarter Stitch, the position is determined by the quadrant of the cell "
"selected"
msgstr ""
"Чвертьстібок, розташування визначатиметься квадрантом позначеної комірки."

#. Tag: guimenuitem
#: commands.docbook:215
#, no-c-format
msgid "Half Stitch"
msgstr "Напівстібок"

#. Tag: action
#: commands.docbook:216
#, no-c-format
msgid ""
"Half Stitch, the direction is determined by the quadrant of the cell selected"
msgstr "Напівстібок, напрямок визначатиметься квадрантом позначеної комірки."

#. Tag: guimenuitem
#: commands.docbook:219
#, no-c-format
msgid "3 Quarter Stitch"
msgstr "Стібок на три чверті"

#. Tag: action
#: commands.docbook:221
#, no-c-format
msgid ""
"Three Quarter Stitch, the orientation is determined by the quadrant of the "
"cell selected"
msgstr ""
"Стібок на три чверті, орієнтація визначатиметься квадрантом позначеної "
"комірки."

#. Tag: guimenuitem
#: commands.docbook:224
#, no-c-format
msgid "<guimenuitem>Full Stitch</guimenuitem>"
msgstr "<guimenuitem>Повний стібок</guimenuitem>"

#. Tag: action
#: commands.docbook:225
#, no-c-format
msgid "<action>Full Stitch</action>"
msgstr "<action>Повний стібок.</action>"

#. Tag: guimenuitem
#: commands.docbook:228
#, no-c-format
msgid "Small Half Stitch"
msgstr "Малий половинний стібок"

#. Tag: action
#: commands.docbook:229
#, no-c-format
msgid ""
"A small half stitch, the position is determined by the quadrant of the cell "
"selected"
msgstr ""
"Малий напівстібок, розташування визначатиметься квадрантом позначеної "
"комірки."

#. Tag: guimenuitem
#: commands.docbook:232
#, no-c-format
msgid "Small Full Stitch"
msgstr "Малий повний стібок"

#. Tag: action
#: commands.docbook:233
#, no-c-format
msgid ""
"A small full stitch, the position is determined by the quadrant of the cell "
"selected"
msgstr ""
"Малий повний стібок, розташування визначатиметься квадрантом позначеної "
"комірки."

#. Tag: guimenuitem
#: commands.docbook:236
#, no-c-format
msgid "French Knot"
msgstr "Французький вузол"

#. Tag: action
#: commands.docbook:237
#, no-c-format
msgid "French Knot Stitch"
msgstr "Французький вузол."

#. Tag: title
#: commands.docbook:244
#, no-c-format
msgid "The Tools Menu"
msgstr "Меню «Інструменти»"

#. Tag: guimenuitem
#: commands.docbook:248
#, no-c-format
msgid "Paint"
msgstr "Малювання"

#. Tag: action
#: commands.docbook:249
#, no-c-format
msgid ""
"Paint stitches onto the canvas - Press down the &LMB; and drag around the "
"window. Stitches will be added to each cell passed over. Release the mouse "
"button to stop painting."
msgstr ""
"Малювати стібки на полотні. Натисніть ліву кнопку миші і перетягніть "
"вказівник на панелі редагування. У кожній з комірок, крізь які пройде "
"вказівник, буде додано стібок. Відпустіть кнопку, щоб припинити малювання."

#. Tag: guimenuitem
#: commands.docbook:255
#, no-c-format
msgid "Draw"
msgstr "Креслення"

#. Tag: action
#: commands.docbook:256
#, no-c-format
msgid ""
"Draw a line of stitches onto the canvas - Press down the &LMB; at the start "
"of the line, drag to the required end point of the line and release the "
"mouse button. Stitches will be added to each cell that the line passes "
"through."
msgstr ""
"Намалювати пряму лінію зі стібків на полотні. Наведіть вказівник миші на "
"початкову точку лінії, натисніть і утримуйте ліву кнопку миші. Перетягніть "
"вказівник миші у кінцеву точку лінії і відпустіть кнопку миші. На полотно "
"буде додано стібки у всіх комірках, крізь які проходитиме вказаний вами "
"відрізок прямої."

#. Tag: guimenuitem
#: commands.docbook:263
#, no-c-format
msgid "Erase"
msgstr "Витирання"

#. Tag: action
#: commands.docbook:264
#, no-c-format
msgid ""
"Erase stitches - Press down the &LMB; and drag over the stitches to be "
"deleted. All stitches within the cells passed over will be removed. Release "
"the mouse button to stop erasing. To erase backstitches hold down the &Ctrl; "
"key and left click in the start or end point of the backstitch, if there is "
"more than one backstitch at the digitized point this method will erase the "
"first one found. To delete a specific backstitch, click and drag from one "
"end to the other. To erase french knots hold down the &Shift; key and left "
"click on the knot to delete it."
msgstr ""
"Витерти стібки. Натисніть і утримуйте натисненою ліву кнопку миші і "
"проведіть вказівник так, щоб він пройшовся усіма стібками, які слід "
"вилучити. Усі стібки, крізь комірки яких пройти вказівник, буде вилучено. "
"Щоб припинити витирання, слід відпустити кнопку миші. Щоб витерти зворотні "
"стібки, утримуйте натисненою клавішу &Ctrl; і клацніть лівою кнопкою миші у "
"початковій та кінцевій точках зворотного стібка. Якщо у певній точці є "
"декілька зворотних стібків, буде витерто перший же знайдений стібок. Щоб "
"вилучити якийсь певний стібок, натисніть ліву кнопку миші і проведіть "
"вказівником з одного його кінця до іншого. Щоб вилучити французький вузол, "
"утримуйте натисненою клавішу &Shift;, наведіть вказівник на вузол і клацніть "
"лівою кнопкою."

#. Tag: guimenuitem
#: commands.docbook:273
#, no-c-format
msgid "Draw Rectangle"
msgstr "Малювати прямокутник"

#. Tag: action
#: commands.docbook:274
#, no-c-format
msgid ""
"Draw a rectangle - Press down the &LMB; at one corner of the rectangle and "
"drag to the opposite corner. Release the mouse button and an unfilled "
"rectangle of stitches will be added to the canvas."
msgstr ""
"Намалювати прямокутник. Наведіть вказівник миші на точку, де має бути "
"розташовано одну з вершин прямокутника, натисніть і утримуйте натисненою "
"ліву кнопку миші. Перетягніть вказівник у протилежну вершину, відпустіть "
"кнопку миші. На полотно буде додано незаповнений кольором прямокутник зі "
"стібків."

#. Tag: guimenuitem
#: commands.docbook:281
#, no-c-format
msgid "Fill Rectangle"
msgstr "Заповнений прямокутник"

#. Tag: action
#: commands.docbook:282
#, no-c-format
msgid ""
"Draw a filled rectangle - Press down the &LMB; at one corner of the "
"rectangle and drag to the opposite corner. Release the mouse button and a "
"filled rectangle of stitches will be added to the canvas."
msgstr ""
"Намалювати заповнений прямокутник. Наведіть вказівник миші на точку, де має "
"бути розташовано одну з вершин прямокутника, натисніть і утримуйте "
"натисненою ліву кнопку миші. Перетягніть вказівник у протилежну вершину, "
"відпустіть кнопку миші. На полотно буде додано заповнений кольором "
"прямокутник зі стібків."

#. Tag: guimenuitem
#: commands.docbook:288
#, no-c-format
msgid "Draw Ellipse"
msgstr "Малювати еліпс"

#. Tag: action
#: commands.docbook:289
#, no-c-format
msgid ""
"Draw an ellipse - Press down the &LMB; at one corner of the ellipse and drag "
"to the opposite corner. Release the mouse button and an unfilled ellipse of "
"stitches will be added to the canvas."
msgstr ""
"Намалювати еліпс. Наведіть вказівник миші на точку, де має бути розташовано "
"одну з вершин прямокутника, описаного навколо еліпса, натисніть і утримуйте "
"натисненою ліву кнопку миші. Перетягніть вказівник у протилежну вершину "
"цього прямокутника, відпустіть кнопку миші. На полотно буде додано "
"незаповнений кольором еліпс зі стібків."

#. Tag: guimenuitem
#: commands.docbook:296
#, no-c-format
msgid "Fill Ellipse"
msgstr "Заповнений еліпс"

#. Tag: action
#: commands.docbook:297
#, no-c-format
msgid ""
"Draw a filled ellipse - Press down the &LMB; at one corner of the ellipse "
"and drag to the opposite corner. Release the mouse button and a filled "
"ellipse of stitches will be added to the canvas."
msgstr ""
"Намалювати заповнений еліпс. Наведіть вказівник миші на точку, де має бути "
"розташовано одну з вершин прямокутника, описаного навколо еліпса, натисніть "
"і утримуйте натисненою ліву кнопку миші. Перетягніть вказівник у протилежну "
"вершину цього прямокутника, відпустіть кнопку миші. На полотно буде додано "
"заповнений кольором еліпс зі стібків."

#. Tag: guimenuitem
#: commands.docbook:303
#, no-c-format
msgid "Fill Polygon"
msgstr "Заповнений багатокутник"

#. Tag: action
#: commands.docbook:304
#, no-c-format
msgid ""
"Draw a filled polygon - Click on each cell marking the vertexes of the "
"polygon, click and drag to create more complex curves. Each of the vertexes "
"are marked by a circle with a black line joining them. To close the polygon "
"click on the starting cell again. You can use the &Backspace; key to remove "
"the last point, or the &Esc; key to remove all vertexes and cancel the "
"operation."
msgstr ""
"Намалювати заповнений кольором багатокутник. Клацніть лівою кнопкою миші у "
"кожній з комірок, які є вершинами багатокутника. Для створення складніших "
"кривих натисніть і утримуйте ліву кнопку миші і перетягніть вказівник миші. "
"Кожну з вершин буде позначено кружечком. Вершини буде з’єднано чорною "
"лінією. Замкнути контур багатокутника можна клацанням лівою кнопкою миші у "
"початковій його вершині. Для вилучення останньої вершити натисніть клавішу "
"<keycap>Backspace</keycap>. Щоб вилучити усі вершини і скасувати створення "
"багатокутника, натисніть клавішу &Esc;."

#. Tag: guimenuitem
#: commands.docbook:312
#, no-c-format
msgid "Text"
msgstr "Текст"

#. Tag: action
#: commands.docbook:313
#, no-c-format
msgid ""
"Insert text in stitches. This invokes the text dialog. Select the font "
"required and the size, enter the text and click <guibutton>OK</guibutton>. "
"Press the &LMB; roughly where you would like the text, move the mouse to "
"position the text accurately and then release the mouse button. This is the "
"same as the paste function."
msgstr ""
"Вставити фрагмент тексту, написаний стібками. Програма відкриє діалогове "
"вікно введення тексту. Виберіть гарнітуру та розмір, введіть текст і "
"натисніть кнопку <guibutton>Гаразд</guibutton>. Наведіть вказівник миші на "
"приблизне місце на полотні, де має розпочинатися текст, натисніть і "
"утримуйте ліву кнопку миші, пересуньте вказівник миші так, щоб розташувати "
"текст точно і відпустіть кнопку миші. Ця дія подібна до дії зі вставляння."

#. Tag: guimenuitem
#: commands.docbook:320
#, no-c-format
msgid "Alphabet"
msgstr "Абетка"

#. Tag: action
#: commands.docbook:321
#, no-c-format
msgid ""
"Insert patterns from the currently selected library that match the keys "
"pressed. This allows the creation of pattern alphabets that can have a key "
"assignment. After selecting this tool and clicking a position on the pattern "
"for the insertion point, each key pressed will be searched for in the "
"current library for a matching pattern. If found this will be inserted at "
"the position on the pattern and the insertion position then advanced by the "
"width of the inserted character pattern. The pattern space will be extended "
"right to allow further characters to be entered. Pressing &Enter; will start "
"a new line under the position of the original insertion point, the pattern "
"space will be extended downwards to accommodate the new line if insufficient "
"space is available. &Backspace; will delete the last character entered and "
"the <keycap>Space</keycap> key will advance the insertion point by either "
"the width of a space character in the library or a predetermined amount if "
"no space character exists. The text will wrap onto the next line if the edge "
"of the pattern is reached and the end of a word is detected."
msgstr ""
"Вставити візерунки з поточної вибраної бібліотеки, які відповідають "
"натисненим клавішам. За допомогою цього засобу ви зможете створювати абетки "
"візерунків, з кожною «літерою» яких буде пов’язано певні клавіші. Якщо ви "
"виберете цей інструмент і клацнете лівою кнопкою миші у точці вставлення "
"візерунка, програма почне шукати відповідні візерунки для усіх натиснених "
"після цього клавіш. Якщо відповідний візерунок буде виявлено, програма "
"вставить його на панель редагування, позицію вставлення буде зсунуто на "
"ширину вставленого фрагмента візерунка. Розміри полотна буде збільшено так, "
"щоб праворуч можна було вставити новий фрагмент. Натискання клавіші &Enter; "
"розпочне новий рядок візерунків під позицією початкової точки вставлення. "
"Якщо на полотні буде недостатньо місця, розміри полотна буде збільшено вниз "
"так, щоб на ньому міг вміститися новий рядок візерунків. Натискання клавіші "
"<keycap>Backspace</keycap> призведе до вилучення нового фрагмента візерунка, "
"а натискання клавіші <keycap>Пробіл</keycap> пересуне точку вставлення на "
"ширину пробільного фрагмента у бібліотеці або на попередньо визначену "
"ширину, якщо пробільного фрагмента не існує. Послідовність рядка візерунків "
"буде розірвано на межі полотна за пробільним символом."

#. Tag: guimenuitem
#: commands.docbook:336
#, no-c-format
msgid "Select"
msgstr "Позначення"

#. Tag: action
#: commands.docbook:337
#, no-c-format
msgid ""
"Select a rectangular region - Press down the &LMB; at one corner of the "
"rectangle, drag to the opposite corner and release the button. A selection "
"rectangle is shown to indicate the area."
msgstr ""
"Позначити прямокутну область. Наведіть вказівник миші на точку, де має бути "
"розташовано одну з вершин прямокутника, натисніть і утримуйте натисненою "
"ліву кнопку миші. Перетягніть вказівник у протилежну вершину, відпустіть "
"кнопку миші. На полотні буде позначено прямокутну область."

#. Tag: guimenuitem
#: commands.docbook:343
#, no-c-format
msgid "Color picker"
msgstr "Піпетка"

#. Tag: action
#: commands.docbook:344
#, no-c-format
msgid ""
"Allows the selection of a color from the existing stitches. Hovering over "
"stitches will show a tool tip indicating the color under the cursor. "
"Clicking with the &LMB; will select it."
msgstr ""
"Надає змогу вибрати колір за наявними стібками. Після наведення вказівника "
"на стібок і утримування його нерухомим певний час має з’явитися панель з "
"підказкою щодо кольору під вказівником. Клацанням лівою кнопкою миші можна "
"вибрати цей колір."

#. Tag: guimenuitem
#: commands.docbook:350
#, no-c-format
msgid "Backstitch"
msgstr "Зворотній стібок"

#. Tag: action
#: commands.docbook:351
#, no-c-format
msgid ""
"Add backstitching to the canvas - Press down the &LMB; at the start of the "
"backstitch, it will snap to the closest of 9 points in the cell, drag to the "
"end point of the backstitch and release the mouse button, again this will "
"snap to the nearest of 9 points in the cell."
msgstr ""
"Додати на полотно зворотній стібок. Наведіть вказівник миші на початкову "
"точку зворотного стібка, натисніть і утримуйте ліву кнопку миші. Початкова "
"точка прилипне до найближчої з 9 точок стібка у комірці. Перетягніть "
"вказівник до кінцевої точки зворотного стібка і відпустіть кнопку миші. "
"Знову ж таки, ця точка прилипне до найближчої з дев’яти точок комірки."

#. Tag: title
#: commands.docbook:362
#, no-c-format
msgid "The Palette Menu"
msgstr "Меню «Палітра»"

#. Tag: guimenuitem
#: commands.docbook:366
#, no-c-format
msgid "Palette Manager"
msgstr "Керування палітрою"

#. Tag: action
#: commands.docbook:367
#, no-c-format
msgid ""
"Add and remove colors to the current palette. Assign symbols and the number "
"of strands for the stitching and backstitching."
msgstr ""
"Додати або вилучити кольори з поточної палітри. Визначити позначки та "
"кількість волокон для створення стібків і зворотних стібків."

#. Tag: guimenuitem
#: commands.docbook:373
#, no-c-format
msgid "Show Symbols"
msgstr "Показувати позначки"

#. Tag: action
#: commands.docbook:374
#, no-c-format
msgid "Show the symbols associated with each color"
msgstr "Показувати позначки, пов’язані з кожним з кольорів."

#. Tag: guimenuitem
#: commands.docbook:376
#, no-c-format
msgid "Clear Unused"
msgstr "Вилучити невикористані"

#. Tag: action
#: commands.docbook:377
#, no-c-format
msgid "Removes the unused colors from the palette."
msgstr "Вилучити невикористані кольори з палітри."

#. Tag: guimenuitem
#: commands.docbook:380
#, no-c-format
msgid "Swap Colors"
msgstr "Поміняти кольори місцями"

#. Tag: action
#: commands.docbook:381
#, no-c-format
msgid ""
"The next color selected will be swapped with the currently selected color. "
"If you select the eye dropper tool, you can choose the color to be swapped "
"with directly from the pattern."
msgstr ""
"Наступний вибраний колір буде обміняно місцями з поточним вибраним кольором. "
"Якщо вами буде вибрано інструмент «піпетка» ви зможете вибрати колір для "
"заміни безпосередньо з візерунка."

#. Tag: guimenuitem
#: commands.docbook:387
#, no-c-format
msgid "Replace Colors"
msgstr "Замінити кольори"

#. Tag: action
#: commands.docbook:388
#, no-c-format
msgid ""
"The next color selected will replace the currently selected color. As with "
"swap colors, you can use the eye dropper tool to select the color from the "
"pattern."
msgstr ""
"Наступний вибраний колір замінить собою поточний вибраний колір. Так само, "
"як і для інструмента обміну кольорами, ви можете скористатися інструментом "
"«піпетка» для вибору кольору безпосередньо з візерунка."

#. Tag: title
#: commands.docbook:398
#, no-c-format
msgid "The Library Menu"
msgstr "Меню «Бібліотека»"

#. Tag: guimenuitem
#: commands.docbook:402
#, no-c-format
msgid "Library Manager"
msgstr "Керування бібліотеками"

#. Tag: action
#: commands.docbook:403
#, no-c-format
msgid ""
"Open the pattern library manager which is a non modal dialog allowing the "
"creation and use of libraries of patterns or alphabets. Drag and drop is "
"available to allow the dragging and dropping of patterns from the library to "
"the pattern. Automatic conversion of flosses to suit the current pattern and "
"scaling of the image to the current pattern scale for accurate positioning."
msgstr ""
"Відкрити вікно керування бібліотекою візерунків, немодальне діалогове вікно, "
"за допомогою якого можна створювати та використовувати бібліотеки візерунків "
"або абетки. Візерунки з вікна бібліотеки можна просто перетягувати і скидати "
"на полотно. Передбачено автоматичне перетворення ниток, яке забезпечує "
"відповідність кольорам поточного основного візерунка, та масштабування "
"зображення відповідно до поточного масштабу візерунка для точного "
"позиціювання."

#. Tag: title
#: commands.docbook:415
#, no-c-format
msgid "The Pattern Menu"
msgstr "Меню «Візерунок»"

#. Tag: guimenuitem
#: commands.docbook:419
#, no-c-format
msgid "Extend Pattern"
msgstr "Розширити візерунок"

#. Tag: action
#: commands.docbook:420
#, no-c-format
msgid "Extend the pattern top, left, right and bottom"
msgstr "Розширити полотно вгору, ліворуч, праворуч або вниз."

#. Tag: guimenuitem
#: commands.docbook:423
#, no-c-format
msgid "Center Pattern"
msgstr "Центрувати візерунок"

#. Tag: action
#: commands.docbook:424
#, no-c-format
msgid "Center the pattern in the canvas"
msgstr "Розташувати візерунок по центру полотна."

#. Tag: guimenuitem
#: commands.docbook:427
#, no-c-format
msgid "Crop Canvas To Pattern"
msgstr "Обрізати полотно до візерунка"

#. Tag: action
#: commands.docbook:428
#, no-c-format
msgid "Crop the canvas to the extents of the pattern"
msgstr "Обрізати полотно до розмірів візерунка."

#. Tag: guimenuitem
#: commands.docbook:431
#, no-c-format
msgid "Crop Canvas To Selection"
msgstr "Обрізати полотно до позначеного"

#. Tag: action
#: commands.docbook:432
#, no-c-format
msgid "Crop the canvas to the extents of the current selection"
msgstr "Обрізати полотно до розмірів поточної позначеної області."

#. Tag: guimenuitem
#: commands.docbook:435
#, no-c-format
msgid "Insert Rows"
msgstr "Вставити рядки"

#. Tag: action
#: commands.docbook:436
#, no-c-format
msgid "Insert a number of rows represented by a selection area"
msgstr "Вставити вказану кількість рядків у форматі позначеної області."

#. Tag: guimenuitem
#: commands.docbook:439
#, no-c-format
msgid "Insert Columns"
msgstr "Вставити стовпчики"

#. Tag: action
#: commands.docbook:440
#, no-c-format
msgid "Insert a number of columns represented by a selection area"
msgstr "Вставити вказану кількість стовпчиків у форматі позначеної області."

#. Tag: title
#: commands.docbook:447
#, no-c-format
msgid "The Settings Menu"
msgstr "Меню «Параметри»"

#. Tag: para
#: commands.docbook:448
#, no-c-format
msgid ""
"Apart from the common &kde; Settings menu entries described in the <ulink "
"url=\"help:/fundamentals/menus.html#menus-settings\"> Settings Menu</ulink> "
"chapter of the &kde; Fundamentals &kxstitch; has these application specific "
"menu entries:"
msgstr ""
"Окрім типових для &kde; пунктів меню «Параметри», описаних у <ulink url="
"\"help:/fundamentals/menus.html#menus-settings\">розділі щодо цього меню</"
"ulink> підручника з основ роботи у &kde;, у &kxstitch; передбачено такі "
"додаткові пункти:"

#. Tag: guimenuitem
#: commands.docbook:454
#, no-c-format
msgid "Format Scales As"
msgstr "Форматування масштабів"

#. Tag: action
#: commands.docbook:455
#, no-c-format
msgid "Change the scale display format to Stitches, CM or Inches."
msgstr ""
"Змінити формат показу одиниць на лінійках. Можливі варіанти: стібки, "
"сантиметри або дюйми."

#. Tag: guimenuitem
#: commands.docbook:458
#, no-c-format
msgid "Render Stitches As"
msgstr "Показувати стібки як"

#. Tag: action
#: commands.docbook:459
#, no-c-format
msgid "Change the way stitches are displayed."
msgstr "Змінити спосіб показу стібків."

#. Tag: guimenuitem
#: commands.docbook:462
#, no-c-format
msgid "Render Backstitches As"
msgstr "Показувати зворотні стібки як"

#. Tag: action
#: commands.docbook:463
#, no-c-format
msgid "Change the way backstitches are displayed."
msgstr "Змінити спосіб показу зворотних стібків."

#. Tag: guimenuitem
#: commands.docbook:466
#, no-c-format
msgid "Render Knots As"
msgstr "Показувати вузли як"

#. Tag: action
#: commands.docbook:467
#, no-c-format
msgid "Change the way knots are displayed."
msgstr "Змінити спосіб показу вузлів."

#. Tag: guimenuitem
#: commands.docbook:470
#, no-c-format
msgid "Color Highlight"
msgstr "Кольорове підсвічування"

#. Tag: action
#: commands.docbook:471
#, no-c-format
msgid "Enable or disable color highlight mode"
msgstr "Увімкнути або вимкнути режим підсвічування кольором."

#. Tag: guimenuitem
#: commands.docbook:474
#, no-c-format
msgid "Show Stitches"
msgstr "Показувати стібки"

#. Tag: action
#: commands.docbook:475
#, no-c-format
msgid "Show or hide the stitches"
msgstr "Показати або приховати стібки."

#. Tag: guimenuitem
#: commands.docbook:478
#, no-c-format
msgid "Show Backstitches"
msgstr "Показувати зворотні стібки"

#. Tag: action
#: commands.docbook:479
#, no-c-format
msgid "Show or hide the backstitches"
msgstr "Показати або приховати зворотні стібки."

#. Tag: guimenuitem
#: commands.docbook:482
#, no-c-format
msgid "Show French Knots"
msgstr "Показувати французькі вузли"

#. Tag: action
#: commands.docbook:483
#, no-c-format
msgid "Show or hide the french knots"
msgstr "Показати або приховати французькі вузли."

#. Tag: guimenuitem
#: commands.docbook:486
#, no-c-format
msgid "Show Grid"
msgstr "Показувати сітку"

#. Tag: action
#: commands.docbook:487
#, no-c-format
msgid "Show or hide the grid"
msgstr "Показати або сховати сітку"

#. Tag: guimenuitem
#: commands.docbook:490
#, no-c-format
msgid "Show Background Images"
msgstr "Показувати зображення тла"

#. Tag: action
#: commands.docbook:491
#, no-c-format
msgid "Show or hide all the background images"
msgstr "Показати або приховати зображення тла."

#. Tag: guimenuitem
#: commands.docbook:494
#, no-c-format
msgid "Configure &kxstitch;"
msgstr "Налаштувати &kxstitch;"

#. Tag: action
#: commands.docbook:495
#, no-c-format
msgid ""
"Open &kxstitch; <link linkend=\"ConfigurationDialog\">configuration dialog</"
"link>."
msgstr ""
"Відкрити <link linkend=\"ConfigurationDialog\">діалогове вікно "
"налаштовування &kxstitch;</link>."

#. Tag: title
#: commands.docbook:503
#, no-c-format
msgid "The Help Menu"
msgstr "Меню «Довідка»"

#. Tag: para
#: commands.docbook:504
#, no-c-format
msgid ""
"Additionally &kxstitch; has the common &kde; Help menu items, for more "
"information read the section about the <ulink url=\"help:/fundamentals/menus."
"html#menus-help\">Help Menu</ulink> of the &kde; Fundamentals."
msgstr ""
"Крім того, у &kxstitch; передбачено типові для &kde; пункти меню "
"<guimenu>Довідка</guimenu>. Докладніший опис цих пунктів можна знайти у "
"<ulink url=\"help:/fundamentals/menus.html#menus-help\">розділі щодо меню "
"«Довідка»</ulink> підручника з основ роботи у &kde;."

