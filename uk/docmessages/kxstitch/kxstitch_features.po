#~ msgstr "Обрізання зображення (ще не реалізовано)"

#~ msgid "Creation of custom stitches (not yet supported)"
#~ msgstr "Створення нетипових стібків (ще не реалізовано)"

#~ msgid "Export selected patterns (not yet supported)"
#~ msgstr "Експортування позначених візерунків (ще не реалізовано)"

#~ msgid "Import patterns from an external source (not yet supported)"
#~ msgstr "Імпортування візерунків із зовнішніх джерел (ще не реалізовано)"

