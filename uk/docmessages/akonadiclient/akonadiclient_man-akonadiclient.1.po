msgstr "Задати запис як аргумент"

#. Tag: option
#: man-akonadiclient.1.docbook:382
#, no-c-format
msgid "show"
msgstr "show"

#. Tag: para
#: man-akonadiclient.1.docbook:384
#, no-c-format
msgid "akonadiclient show ITEM"
msgstr "akonadiclient show ЗАПИС"

#. Tag: para
#: man-akonadiclient.1.docbook:385
#, no-c-format
msgid "Shows the raw payload of an item"
msgstr "Вивести необроблений вміст запису"

#. Tag: option
#: man-akonadiclient.1.docbook:390
#, no-c-format
msgid "tags"
msgstr "tags"

#. Tag: para
#: man-akonadiclient.1.docbook:392
#, no-c-format
msgid "akonadiclient tags [OPTIONS]"
msgstr "akonadiclient tags [ПАРАМЕТР]"

#. Tag: para
#: man-akonadiclient.1.docbook:393
#, no-c-format
msgid "List all known tags"
msgstr "Вивести список усіх відомих міток"

#. Tag: para
#: man-akonadiclient.1.docbook:399
#, no-c-format
msgid "Brief output - tag names only"
msgstr "Коротке виведення — лише назви міток"

#. Tag: option
#: man-akonadiclient.1.docbook:403
#, no-c-format
msgid "-u, --urls"
msgstr "-u, --urls"

#. Tag: para
#: man-akonadiclient.1.docbook:404
#, no-c-format
msgid "Brief output - tag URLs only"
msgstr "Коротке виведення — лише адреси міток"

#. Tag: option
#: man-akonadiclient.1.docbook:412
#, no-c-format
msgid "update"
msgstr "update"

#. Tag: para
#: man-akonadiclient.1.docbook:414
#, no-c-format
msgid "akonadiclient update [OPTIONS] ITEM FILE"
msgstr "akonadiclient update [ПАРАМЕТРИ] ЗАПИС ФАЙЛ"

#. Tag: para
#: man-akonadiclient.1.docbook:415
#, no-c-format
msgid "Updates the raw payload of ITEM with the contents of FILE"
msgstr "Оновлює необроблений вміст запису ЗАПИС за вмістом файла ФАЙЛ"

#. Tag: title
#: man-akonadiclient.1.docbook:432
#, no-c-format
msgid "Miscellaneous Commands"
msgstr "Інші команди"

#. Tag: option
#: man-akonadiclient.1.docbook:436
#, no-c-format
msgid "agents"
msgstr "agents"

#. Tag: para
#: man-akonadiclient.1.docbook:438
#, no-c-format
msgid "akonadiclient agents [OPTIONS] [AGENTS...]"
msgstr "akonadiclient agents [ПАРАМЕТРИ] [АГЕНТИ...]"

#. Tag: para
#: man-akonadiclient.1.docbook:439
#, no-c-format
msgid ""
"Allows managing of Akonadi agents like changing their state, restarting an "
"agent or listing all agents and their state."
msgstr ""
"Уможливлює керування агентами Akonadi, зокрема зміну стану, перезапуск "
"агента або виведення списку усіх агентів та їхнього стану."

#. Tag: option
#: man-akonadiclient.1.docbook:444
#, no-c-format
msgid "-l, --list"
msgstr "-l, --list"

#. Tag: para
#: man-akonadiclient.1.docbook:445
#, no-c-format
msgid "List all agents"
msgstr "Вивести список усіх агентів"

#. Tag: option
#: man-akonadiclient.1.docbook:449
#, no-c-format
msgid "-s, --setstate <replaceable>state</replaceable>"
msgstr "-s, --setstate <replaceable>стан</replaceable>"

#. Tag: para
#: man-akonadiclient.1.docbook:450
#, no-c-format
msgid ""
"Set the state for specified agents. Valid states are 'offline' and 'online'."
msgstr ""
"Встановити стан вказаних агентів. Коректними станами є «offline» і «online»."

#. Tag: option
#: man-akonadiclient.1.docbook:454
#, no-c-format
msgid "-g, --getstate"
msgstr "-g, --getstate"

#. Tag: para
#: man-akonadiclient.1.docbook:455
#, no-c-format
msgid "Get the state for specified agents"
msgstr "Отримати стан вказаних агентів"

#. Tag: option
#: man-akonadiclient.1.docbook:459
#, no-c-format
msgid "-i, --info"
msgstr "-i, --info"

#. Tag: para
#: man-akonadiclient.1.docbook:460
#, no-c-format
msgid "Show information about the specified agents"
msgstr "Вивести дані щодо вказаних агентів"

#. Tag: option
#: man-akonadiclient.1.docbook:464
#, no-c-format
msgid "-r, --restart"
msgstr "-r, --restart"

#. Tag: para
#: man-akonadiclient.1.docbook:465
#, no-c-format
msgid "Restarts the specified agents"
msgstr "Перезапустити вказані агенти"

#. Tag: option
#: man-akonadiclient.1.docbook:478
#, no-c-format
msgid "help"
msgstr "help"

#. Tag: para
#: man-akonadiclient.1.docbook:480
#, no-c-format
msgid "akonadiclient help [COMMAND]"
msgstr "akonadiclient help [КОМАНДА]"

#. Tag: para
#: man-akonadiclient.1.docbook:481
#, no-c-format
msgid ""
"Displays help for COMMAND. If COMMAND is not specified then it lists all the "
"available commands"
msgstr ""
"Виводить довідку щодо команди КОМАНДА. Якщо команду не вказано, буде "
"виведено список усіх доступних команд."

#. Tag: option
#: man-akonadiclient.1.docbook:486
#, no-c-format
msgid "shell"
msgstr "shell"

#. Tag: para
#: man-akonadiclient.1.docbook:488
#, no-c-format
msgid "akonadiclient shell"
msgstr "akonadiclient shell"

#. Tag: para
#: man-akonadiclient.1.docbook:489
#, no-c-format
msgid "Enter commands in an interactive shell"
msgstr "Вводити команди у інтерактивній оболонці"

#. Tag: title
#: man-akonadiclient.1.docbook:497
#, no-c-format
msgid "Examples"
msgstr "Приклади"

#. Tag: para
#: man-akonadiclient.1.docbook:498
#, no-c-format
msgid ""
"<emphasis role=\"bold\">akonadiclient list /</emphasis> - Lists all the "
"collections under the root collection"
msgstr ""
"<emphasis role=\"bold\">akonadiclient list /</emphasis> — виводить список "
"усіх збірок у кореневій збірці"

#. Tag: para
#: man-akonadiclient.1.docbook:499
#, no-c-format
msgid ""
"<emphasis role=\"bold\">akonadiclient export /Notes notes.xml</emphasis> - "
"Exports all the items and sub-collections of the /Notes collection to the "
"file 'notes.xml'"
msgstr ""
"<emphasis role=\"bold\">akonadiclient export /Notes notes.xml</emphasis> — "
"експортує усі записи і підлеглі збірки збірки /Notes до файла «notes.xml»"

#. Tag: para
#: man-akonadiclient.1.docbook:500
#, no-c-format
msgid ""
"<emphasis role=\"bold\">akonadiclient agents -l</emphasis> - Lists all agents"
msgstr ""
"<emphasis role=\"bold\">akonadiclient agents -l</emphasis> — виводить список "
"усіх агентів"

#. Tag: para
#: man-akonadiclient.1.docbook:501
#, no-c-format
msgid ""
"<emphasis role=\"bold\">akonadiclient add /Notes note.txt</emphasis> - Adds "
"the contents of the file note.txt as an item in the collection /Notes"
msgstr ""
"<emphasis role=\"bold\">akonadiclient add /Notes note.txt</emphasis> — "
"додати вміст файла note.txt як запису у збірці /Notes"

#. Tag: para
#: man-akonadiclient.1.docbook:502
#, no-c-format
msgid ""
"<emphasis role=\"bold\">akonadiclient add -m application/x-vnd.akonadi."
"calendar.todo /Todos todo.ics</emphasis> - Adds the contents of the file "
"todo.ics as a TODO calendar entry in the collection /Todos"
msgstr ""
"<emphasis role=\"bold\">akonadiclient add -m application/x-vnd.akonadi."
"calendar.todo /Todos todo.ics</emphasis> — додати вміст файла todo.ics як "
"запис календаря завдань до збірки /Todos"

