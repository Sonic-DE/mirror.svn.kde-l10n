#, no-c-format
msgid "Pause"
msgstr "Пауза"

#. Tag: keycap
#: index.docbook:353
#, no-c-format
msgid "<keycap>P</keycap>"
msgstr "<keycap>P</keycap>"

#. Tag: entry
#: index.docbook:354
#, no-c-format
msgid "Show High Scores"
msgstr "Показати найкращі результати"

#. Tag: keycombo
#: index.docbook:354
#, no-c-format
msgid "&Ctrl;<keycap>H</keycap>"
msgstr "&Ctrl;<keycap>H</keycap>"

#. Tag: entry
#: index.docbook:355
#, no-c-format
msgid "Quit"
msgstr "Вийти"

#. Tag: keycombo
#: index.docbook:355
#, no-c-format
msgid "&Ctrl;<keycap>Q</keycap>"
msgstr "&Ctrl;<keycap>Q</keycap>"

#. Tag: entry
#: index.docbook:356
#, no-c-format
msgid "Undo"
msgstr "Вернути"

#. Tag: keycombo
#: index.docbook:356
#, no-c-format
