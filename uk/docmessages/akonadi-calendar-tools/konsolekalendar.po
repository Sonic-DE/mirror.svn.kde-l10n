msgstr "Переглянути наступну подію з календаря."

#. Tag: entry
#: index.docbook:534
#, no-c-format
msgid "<option>--show-next</option> <replaceable>&nbsp;days</replaceable>"
msgstr ""
"<option>--show-next</option> <replaceable>&nbsp;кількість_днів</replaceable>"

#. Tag: entry
#: index.docbook:536
#, no-c-format
