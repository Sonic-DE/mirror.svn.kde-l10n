msgstr "Вилучає існуючу подію з календаря."

#. Tag: entry
#: index.docbook:508
#, no-c-format
msgid "<option>--create</option> <replaceable>&nbsp;filename</replaceable>"
msgstr "<option>--create</option> <replaceable>&nbsp;назва_файла</replaceable>"

#. Tag: entry
#: index.docbook:511
#, no-c-format
msgid "Create a new calendar from existing file."
msgstr "Створити календар з наявного файла."

#. Tag: entry
#: index.docbook:514
#, no-c-format
msgid "<option>--import</option> <replaceable>&nbsp;import-file</replaceable>"
msgstr ""
