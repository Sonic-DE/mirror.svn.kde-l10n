"ідентифікатором (UID)."

#. Tag: entry
#: index.docbook:544
#, no-c-format
msgid "<option>--date</option> <replaceable>&nbsp;date</replaceable>"
msgstr "<option>--date</option> <replaceable>&nbsp;дата</replaceable>"

#. Tag: entry
#: index.docbook:546
#, no-c-format
msgid "Start at this day [YYYY-MM-DD]. Default date is Today"
msgstr "Почати з вказаного дня [РРРР-ММ-ДД]. Типовою датою є поточний день"

#. Tag: entry
#: index.docbook:549
#, no-c-format
msgid "<option>--time</option> <replaceable>&nbsp;time</replaceable>"
msgstr "<option>--time</option> <replaceable>&nbsp;час</replaceable>"

#. Tag: entry
#: index.docbook:551
#, no-c-format
msgid "Start at this time [HH:MM]. Default time for viewing is 07:00."
msgstr "Почати з вказаного часу [ГГ:ХХ]. Типовим часом перегляду є 07:00."

#. Tag: para
#: index.docbook:552 index.docbook:564
#, no-c-format
msgid ""
"To add or change a floating event, use the <option>--time float</option> or "
"the <option>--end-time float</option> options."
