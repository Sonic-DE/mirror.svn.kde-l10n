msgstr ""
"Показати записи про події протягом вказаної кількості днів від поточного дня."

#. Tag: entry
#: index.docbook:539
#, no-c-format
msgid "<option>--uid</option> <replaceable>&nbsp;UID</replaceable>"
msgstr "<option>--uid</option> <replaceable>&nbsp;UID</replaceable>"

#. Tag: entry
#: index.docbook:541
#, no-c-format
msgid "View, delete, or change the event with this Unique-string IDentifier."
msgstr ""
