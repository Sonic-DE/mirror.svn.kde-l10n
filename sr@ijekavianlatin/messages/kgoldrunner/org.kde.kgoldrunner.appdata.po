#. (itstool) path: component/name
#: org.kde.kgoldrunner.appdata.xml:9
msgid "KGoldrunner"
msgstr "K‑zlatobojac"

#. (itstool) path: component/summary
#: org.kde.kgoldrunner.appdata.xml:10
msgid "Hunt Gold, Dodge Enemies and Solve Puzzles"
msgstr "Hvatajte zlato, izbegavajte neprijatelje i rešavajte zagonetke"

# skip-rule: t-action
#. (itstool) path: description/p
#: org.kde.kgoldrunner.appdata.xml:12
msgid ""
"KGoldrunner is an action game where the hero runs through a maze, climbs "
"stairs, dig holes and dodges enemies in order to collect all the gold "
"nuggets and escape to the next level. Your enemies are also after the gold. "
"Worse still, they are after you!."
msgstr ""
"K‑zlatobojac je akciona igra u kojoj junak trči kroz lavirint, penje se uz "
"stepenice, kopa rupe i izbegava neprijatelje kako bio se dokopao svih "
"zlatnih grumenova i pobegao na naredni nivo. I vaši neprijatelji jure za "
"zlatom, i, još gore, za vama!"

#. (itstool) path: description/p
#: org.kde.kgoldrunner.appdata.xml:17
msgid "Features:"
msgstr "Mogućnosti:"

#. (itstool) path: ul/li
