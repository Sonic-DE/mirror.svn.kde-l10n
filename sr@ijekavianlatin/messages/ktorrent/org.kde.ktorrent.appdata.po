#. (itstool) path: component/name
#: org.kde.ktorrent.appdata.xml:10
msgid "KTorrent"
msgstr "KTorrent"

#. (itstool) path: component/summary
#: org.kde.ktorrent.appdata.xml:11
msgid "BitTorrent Client"
msgstr "Bittorrent klijent"

#. (itstool) path: description/p
#: org.kde.ktorrent.appdata.xml:13
msgid ""
"KTorrent is a BitTorrent application by KDE which allows you to download "
"files using the BitTorrent protocol. It enables you to run multiple torrents "
"at the same time and comes with extended features to make it a full-featured "
"client for BitTorrent."
msgstr ""
"KTorrent je program iz KDE‑a kojim možete da preuzimate fajlove preko "
"protokola Bittorrent. Omogućava pokretanje više torenata istovremeno i pruža "
"raznovrsne proširene mogućnosti, što ga čini ga sveobuhvatnim bittorrent "
"klijentom."

#. (itstool) path: description/p
#: org.kde.ktorrent.appdata.xml:18
msgid "Features:"
msgstr "Mogućnosti:"

#. (itstool) path: ul/li
#: org.kde.ktorrent.appdata.xml:20
msgid "Queuing of torrents"
msgstr "Stavljanje torenata u red."

#. (itstool) path: ul/li
