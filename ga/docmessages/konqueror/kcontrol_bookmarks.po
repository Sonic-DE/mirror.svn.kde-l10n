#. Tag: title
#: index.docbook:31
#, no-c-format
msgid "Bookmarks home page"
msgstr ""

#. Tag: para
#: index.docbook:32
#, no-c-format
msgid "This module lets you configure the bookmarks home page."
msgstr ""

#. Tag: para
#: index.docbook:33
#, no-c-format
msgid ""
"To view the bookmarks home page enter <userinput>bookmarks:/</userinput> in "
"the location bar."
msgstr ""

#. Tag: para
#: index.docbook:35
#, no-c-format
msgid ""
"The settings in this module are also accessible by entering "
"<userinput>bookmarks:/config</userinput> in the location bar."
msgstr ""

#. Tag: title
#: index.docbook:38
#, no-c-format
msgid "General settings"
msgstr ""

#. Tag: guilabel
#: index.docbook:41
#, no-c-format
msgid "Number of columns to show"
msgstr ""

#. Tag: para
#: index.docbook:43
#, no-c-format
msgid ""
"Folders are automatically distributed in several columns. The optimal number "
"of columns depends on the width of the &konqueror; window and the number of "
"bookmarks you have."
msgstr ""

#. Tag: guilabel
#: index.docbook:48
#, no-c-format
msgid "Show folder backgrounds"
msgstr ""

#. Tag: para
#: index.docbook:50
#, no-c-format
msgid "Disable it on slow system to disable background images."
msgstr ""

#. Tag: guilabel
#: index.docbook:60
#, no-c-format
msgid "Show bookmarks without folder"
msgstr ""

#. Tag: para
#: index.docbook:62
#, no-c-format
msgid ""
"If this option is unchecked, bookmarks at the root of the hierarchy (not in "
"a folder) are not displayed. If checked, they are gathered in a “root” "
"folder."
msgstr ""

#. Tag: guilabel
#: index.docbook:67
#, no-c-format
msgid "Flatten bookmarks tree"
msgstr ""

#. Tag: para
#: index.docbook:69
#, no-c-format
msgid ""
"Sub-folders are shown within their parent by default. If you activate this "
"option, sub-folders are displayed on their own. It looks less nice but it "
"may help if you have a very big folder you want to spread in two columns."
msgstr ""

#. Tag: guilabel
#: index.docbook:74
#, no-c-format
msgid "Show system places"
msgstr ""

#. Tag: para
#: index.docbook:76
#, no-c-format
msgid ""
"Show a box with common places (Home, Network, …). Useful if you use "
"&konqueror; as a file manager."
msgstr ""

#. Tag: title
#: index.docbook:83
#, no-c-format
msgid "Pixmap cache"
msgstr ""

#. Tag: guilabel
#: index.docbook:86
#, no-c-format
msgid "Disk cache size"
msgstr ""

#. Tag: para
#: index.docbook:88
#, no-c-format
msgid "Specify how much disk space is used to cache the pixmaps."
msgstr ""

#. Tag: guilabel
#: index.docbook:93
#, no-c-format
msgid "Clear Cache"
msgstr ""

#. Tag: para
#: index.docbook:95
#, no-c-format
msgid ""
"Remove all cached images. This may be necessary if some favicons become "
"corrupt and don’t refresh automatically."
msgstr ""
