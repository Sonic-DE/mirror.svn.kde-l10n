#: core/dplugins/dimg/jpeg2000/dimgjpeg2000exportsettings.cpp:64
#, kde-format
msgid ""
"<p>Toggle lossless compression for JPEG 2000 images.</p><p>If this option is "
"enabled, a lossless method will be used to compress JPEG 2000 pictures.</p>"
msgstr ""
"<p>Cas an comhbhrú gan chailliúint le haghaidh íomhánna JPEG 2000.</p><p>Má "
"tá an rogha seo cumasaithe, úsáidfear modh gan chailliúint chun pictiúir "
"JPEG 2000 a chomhbhrú.</p>"

#: core/dplugins/dimg/jpeg2000/dimgjpeg2000exportsettings.cpp:71
#, kde-format
msgid "JPEG 2000 quality:"
msgstr "Cáilíocht JPEG 2000:"

#: core/dplugins/dimg/jpeg2000/dimgjpeg2000exportsettings.cpp:73
#, kde-format
msgid ""
"<p>The quality value for JPEG 2000 images:</p><p><b>1</b>: low quality (high "
"compression and small file size)<br><b>50</b>: medium quality<br><b>75</b>: "
"good quality (default)<br><b>100</b>: high quality (no compression and large "
"file size)</p><p><b>Note: JPEG 2000 is not a lossless image compression "
"format when you use this setting.</b></p>"
msgstr ""
"<p>An luach cáilíochta d'íomhánna JPEG 2000:</p><p><b>1</b>: caighdeán íseal "
"(comhbhrú ard agus méid comhaid beag)<br><b>50</b>: caighdeán "
"meánach<br><b>75</b>: caighdeán maith (réamhshocraithe)<br><b>100</b>: "
"caighdeán ard (gan comhbhrú agus méid comhaid mór)</p><p><b>Tabhair faoi "
"deara: Ní formáid comhbhrú íomhá gan chailliúint é JPEG 2000 nuair a "
"úsáideann tú an socrú seo.</b></p>"

#: core/dplugins/dimg/jpeg2000/dimgjpeg2000plugin.cpp:92
