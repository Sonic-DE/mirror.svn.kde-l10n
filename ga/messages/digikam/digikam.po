#: core/dplugins/generic/view/glviewer/glviewerplugin.cpp:61
#, kde-format
msgid ""
"<p>This tool preview a series of items using OpenGL effects.</p><p><u>Usage:"
"</u></p><table><tr><td colspan=\"2\"><nobr><center><b><h1>Item Access</h1></"
"b></center></nobr></td></tr><tr><td>Previous Item:</td><td><i>Up</i> key</"
"td></tr><tr><td></td><td><i>PgUp</i> key</td></tr><tr><td></td><td><i>Left</"
"i> key</td></tr><tr><td></td><td>Mouse wheel up</td></tr><tr><td>Next Item:</"
"td><td><i>Down</i> key</td></tr><tr><td></td><td><i>PgDown</i> key</td></"
"tr><tr><td></td><td><i>Right</i> key</td></tr><tr><td></td><td>Mouse wheel "
"down</td></tr><tr><td>Quit:</td><td><i>Esc</i> key</td></tr><tr><td colspan="
"\"2\"><nobr><center><b><h1>Item Display</h1></b></center></nobr></td></"
"tr><tr><td>Toggle fullscreen to normal:</td><td><i>f</i> key</td></"
"tr><tr><td>Toggle scroll-wheel action:</td><td><i>c</i> key (either zoom or "
"change item)</td></tr><tr><td>Rotation:</td><td><i>r</i> key</td></"
"tr><tr><td>Reset view:</td><td>double click</td></tr><tr><td>Original size:</"
"td><td><i>o</i> key</td></tr><tr><td>Zooming:</td><td>Move mouse in up-down-"
"direction while pressing the right mouse button</td></tr><tr><td></"
"td><td><i>c</i> key and use the scroll-wheel</td></tr><tr><td></td><td><i>+</"
"i> and <i>-</i> keys</td></tr><tr><td></td><td>ctrl + scrollwheel</td></"
"tr><tr><td>Panning:</td><td>Move mouse while pressing the left button</td></"
"tr><tr><td colspan=\"2\"><nobr><center><b><h1>Others</h1></b></center></"
"nobr></td></tr><tr><td>Show this help:</td><td><i>F1</i> key</td></tr></"
"table>"
msgstr ""
"<p>Réamharcann an uirlis seo ar shraith míreanna ag baint úsáide as "
"éifeachtaí OpenGL.</p><p><u>Úsáid:</u></p><table><tr><td colspan="
"\"2\"><nobr><center><b><h1>Rochtain ar Mhíreanna</h1></b></center></nobr></"
"td></tr><tr><td>Mír Roimhe Seo:</td><td><i>Eochair Suas</i></td></"
"tr><tr><td></td><td><i>Eochair Leathanach Suas</i></td></tr><tr><td></"
"td><td><i>Eochair Chlé</i></td></tr><tr><td></td><td>Roth na luiche suas</"
"td></tr><tr><td>An chéad Mhír Eile:</td><td><i>Eochair Síos</i></td></"
"tr><tr><td></td><td><i>Leathanach Síos</i> eochair</td></tr><tr><td></"
"td><td><i>Eochair ar dheis</i></td></tr><tr><td></td><td>Roth na luiche "
"síos</td></tr><tr><td>Scoir:</td><td><i>Eochair Esc</i></td></tr><tr><td "
"colspan=\"2\"><nobr><center><b><h1>Taispeáint Míre</h1></b></center></nobr></"
"td></tr><tr><td>Athraigh an scáileán iomlán go gnáth:</td><td><i>eochair f</"
"i></td></tr><tr><td>Athraigh gníomh an roth scrolla:</td><td><i>eochair c</"
"i> (súmáil isteach nó athrú míre)</td></tr><tr><td>Rothlú:</"
"td><td><i>eochair r</i></td></tr><tr><td>Athshocraigh radharc:</"
"td><td>cliceáil faoi dhó</td></tr><tr><td>Méid bunaidh:</td><td><i>eochair "
"o</i></td></tr><tr><td>Zúmáil:</td><td>Bog an luch suas-síos agus an cnaipe "
"luiche ar dheis á bhrú agat</td></tr><tr><td></td><td><i>eochair c</i> agus "
"bain úsáid as na heochracha scrolla</td></tr><tr><td></td><td><i>+</i> agus "
"<i>-</i></td></tr><tr><td></td><td>ctrl + roth scrolla</td></"
"tr><tr><td>Panáil:</td><td>Bog an luch agus an cnaipe clé á bhrú agat</td></"
"tr><tr><td colspan=\"2\"><nobr><center><b><h1>Eile</h1></b></center></nobr></"
"td></tr><tr><td>Taispeáin an chabhair seo:</td><td><i>Eochair F1</i></td></"
"tr></table>"

