msgstr "Uirlis chun íomhánna a thiontú go formáid PNG"

#: core/dplugins/bqm/convert/converttopng/converttopngplugin.cpp:62
#, kde-kuit-format
msgctxt "@info"
msgid ""
"<para>This Batch Queue Manager tool can convert images data to PNG format.</"
"para><para>The Portable Network Graphics is a raster-graphics file-format "
"that supports lossless data compression.</para><para>See details about this "
"format from <link url='https://en.wikipedia.org/wiki/"
"Portable_Network_Graphics'>this page</link>.</para>"
msgstr ""
"<para>Is féidir leis an uirlis Bainisteoir Scuaine Baisce seo sonraí "
