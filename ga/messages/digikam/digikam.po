#, kde-format
msgctxt "@option: radio"
msgid "JPEG output"
msgstr "Aschur JPEG"

#: core/dplugins/generic/tools/panorama/wizard/panointropage.cpp:161
#, no-c-format, kde-format
msgctxt "@info: tooltip"
msgid ""
"Selects a JPEG output with 90% compression rate (lossy compression, smaller "
"size)."
msgstr ""
"Roghnaíonn sé aschur JPEG le ráta comhbhrúite 90% (comhbhrú caillteanais, "
"méid níos lú)."

#: core/dplugins/generic/tools/panorama/wizard/panointropage.cpp:163
#, kde-format
msgctxt "@info:whatsthis"
msgid ""
"\"JPEG output\": Using JPEG output, the panorama file will be smaller at the "
"cost of information loss during compression. This is the easiest way to "
"share the result, or print it online or in a shop."
msgstr ""
"\"Aschur JPEG\": Agus aschur JPEG á úsáid, beidh an comhad lánléargais níos "
"lú agus caillfear faisnéis le linn comhbhrú. Seo an bealach is fusa chun an "
"toradh a roinnt, nó é a phriontáil ar líne nó i siopa."

#: core/dplugins/generic/tools/panorama/wizard/panointropage.cpp:169
#, kde-format
msgctxt "@option: radio"
msgid "TIFF output"
msgstr "Aschur TIFF"

#: core/dplugins/generic/tools/panorama/wizard/panointropage.cpp:170
#, kde-format
msgctxt "@info: tooltip"
msgid ""
"Selects a TIFF output compressed using the LZW algorithm (lossless "
"compression, bigger size)."
msgstr ""
"Roghnaíonn sé aschur TIFF atá comhbhrúite ag baint úsáide as an algartam LZW "
"(comhbhrú gan chailliúint, méid níos mó)."

#: core/dplugins/generic/tools/panorama/wizard/panointropage.cpp:172
#, kde-format
msgctxt "@info: whatsthis"
msgid ""
"\"TIFF output\": Using TIFF output, you get the same color depth as your "
"original photos using RAW images at the cost of a bigger panorama file."
msgstr ""
"\"Aschur TIFF\": Agus aschur TIFF á úsáid agat, gheobhaidh tú an doimhneacht "
"datha chéanna le do ghrianghraif bhunaidh ag baint úsáide as íomhánna RAW ar "
"chostas comhaid lánléargais níos mó."

