#, kde-format
msgctxt "@info"
msgid "A tool to convert images to TIFF format"
msgstr "Uirlis chun íomhánna a thiontú go formáid TIFF"

#: core/dplugins/bqm/convert/converttotiff/converttotiffplugin.cpp:62
#, kde-kuit-format
msgctxt "@info"
msgid ""
"<para>This Batch Queue Manager tool can convert images data to TIFF format.</"
"para><para>The Tagged Image File Format is a computer file format for "
"storing raster graphics images, popular among graphic artists, the "
"publishing industry, and photographers.</para><para>See details about this "
"format from <link url='https://en.wikipedia.org/wiki/TIFF'>this page</link>."
"</para>"
msgstr ""
"<para>Is féidir leis an uirlis Bainisteoir Scuaine Baisce seo sonraí "
"íomhánna a thiontú go formáid TIFF.</para><para>Is formáid comhaid ríomhaire "
"í an Fhormáid Comhaid Íomhá Tagged chun íomhánna grafaicí raster a stóráil, "
"atá coitianta i measc ealaíontóirí grafacha, an tionscal foilsitheoireachta, "
"agus grianghrafadóirí.</para><para>Féach sonraí faoin bhformáid seo ón <link "
"url='https://en.wikipedia.org/wiki/TIFF'>leathanach seo</link>.</para>"

#: core/dplugins/bqm/convert/converttowebp/converttowebpplugin.cpp:42
#, kde-format
