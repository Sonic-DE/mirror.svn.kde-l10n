#, kde-format
msgid "No Lens Filter"
msgstr "Gan Scagaire Lionsa"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:220
#, kde-format
msgid ""
"<b>No Lens Filter</b>:<p>Do not apply a lens filter when rendering the image."
"</p>"
msgstr ""
"<b>Gan Scagaire Lionsa</b>:<p>Ná cuir scagaire lionsa i bhfeidhm agus an "
"íomhá á rindreáil.</p>"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:223
#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:309
#, kde-format
msgid "Green Filter"
msgstr "Scagaire Uaine"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:224
#, kde-format
msgid ""
"<b>Black & White with Green Filter</b>:<p>Simulate black and white film "
"exposure using a green filter. This is useful for all scenic shoots, "
"especially portraits photographed against the sky.</p>"
msgstr ""
"<b>Dubh & Bán le Scagaire Glas</b>:<p>Insamhladh nochtadh scannáin dubh agus "
"bán ag baint úsáide as scagaire glas. Tá sé seo úsáideach do gach seisiún "
"radharcach, go háirithe portráidí a ghrianghrafadh i gcoinne na spéire.</p>"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:229
#, kde-format
msgid "Orange Filter"
msgstr "Scagaire Oráiste"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:230
#, kde-format
msgid ""
"<b>Black & White with Orange Filter</b>:<p>Simulate black and white film "
"exposure using an orange filter. This will enhance landscapes, marine scenes "
"and aerial photography.</p>"
msgstr ""
"<b>Dubh & Bán le Scagaire Oráiste</b>:<p>Insamhladh nochtadh scannáin dubh "
"agus bán ag baint úsáide as scagaire oráiste. Cuirfidh sé seo feabhas ar "
"thírdhreacha, radhairc mhuirí agus grianghrafadóireacht ón aer.</p>"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:235
#, kde-format
msgid "Red Filter"
msgstr "Scagaire Dearg"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:236
#, kde-format
msgid ""
"<b>Black & White with Red Filter</b>:<p>Simulate black and white film "
"exposure using a red filter. This creates dramatic sky effects, and "
"simulates moonlight scenes in the daytime.</p>"
msgstr ""
"<b>Dubh & Bán le Scagaire Dearg</b>:<p>Insamhladh nochtadh scannáin dubh "
"agus bán ag baint úsáide as scagaire dearg. Cruthaíonn sé seo éifeachtaí "
"drámatúla spéire, agus insamhladh sé radhairc sholas na gealaí i rith an lae."
"</p>"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:241
#, kde-format
msgid "Yellow Filter"
msgstr "Scagaire Buí"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:242
#, kde-format
msgid ""
"<b>Black & White with Yellow Filter</b>:<p>Simulate black and white film "
"exposure using a yellow filter. This has the most natural tonal correction, "
"and improves contrast. Ideal for landscapes.</p>"
msgstr ""
"<b>Dubh & Bán le Scagaire Buí</b>:<p>Insamhladh nochtadh scannáin dubh agus "
"bán ag baint úsáide as scagaire buí. Tá an ceartú tonúil is nádúrtha aige "
"seo, agus feabhsaíonn sé codarsnacht. Oiriúnach do thírdhreacha.</p>"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:247
#, kde-format
msgid "Yellow-Green Filter"
msgstr "Scagaire Buí-Uaine"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:248
#, kde-format
msgid ""
"<b>Black & White with Yellow-Green Filter</b>:<p>Simulate black and white "
"film exposure using a yellow-green filter. A yellow-green filter is highly "
"effective for outdoor portraits because red is rendered dark while green "
"appears lighter. Great for correcting skin tones, bringing out facial "
"expressions in close-ups and emphasizing the feeling of liveliness. This "
"filter is highly effective for indoor portraits under tungsten lighting.</p>"
msgstr ""
"<b>Dubh & Bán le Scagaire Buí-Uaine</b>:<p>Insamhladh nochtadh scannáin dubh "
"agus bán ag baint úsáide as scagaire buí-uaine. Tá scagaire buí-uaine an-"
"éifeachtach do phortráidí lasmuigh toisc go ndéantar dearg a dhorcha agus go "
"mbíonn glas níos éadroime. Iontach chun toin craicinn a cheartú, léirithe "
"aghaidhe a thabhairt chun cinn i ngrianghraif dhlútha agus béim a chur ar an "
"mbeocht. Tá an scagaire seo an-éifeachtach do phortráidí faoi dhíon faoi "
"sholas tungstain.</p>"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:255
#, kde-format
msgid "Blue Filter"
msgstr "Scagaire Gorm"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:256
#, kde-format
msgid ""
"<b>Black & White with Blue Filter</b>:<p>Simulate black and white film "
"exposure using a blue filter. This accentuates haze and fog. Used for dye "
"transfer and contrast effects.</p>"
msgstr ""
"<b>Dubh & Bán le Scagaire Gorm</b>:<p>Insamhladh nochtadh scannáin dubh agus "
"bán ag baint úsáide as scagaire gorm. Cuireann sé seo béim ar cheo agus ar "
"cheo. Úsáidtear é le haghaidh éifeachtaí aistrithe ruaime agus codarsnachta."
"</p>"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:261
#, kde-format
msgid "Strength:"
msgstr "Neart:"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:267
#, kde-format
msgid "Here, set the strength adjustment of the lens filter."
msgstr "Anseo, socraigh coigeartú neart an scagaire lionsa."

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:278
#, kde-format
msgid "No Tone Filter"
msgstr "Gan Scagaire Ton"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:279
#, kde-format
msgid "<b>No Tone Filter</b>:<p>Do not apply a tone filter to the image.</p>"
msgstr ""
"<b>Gan Scagaire Tone</b>:<p>Ná cuir scagaire ton i bhfeidhm ar an íomhá.</p>"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:282
#, kde-format
msgid "Sepia Filter"
msgstr "Scagaire Donnrua"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:283
#, kde-format
msgid ""
"<b>Black & White with Sepia Tone</b>:<p>Gives a warm highlight and mid-tone "
"while adding a bit of coolness to the shadows - very similar to the process "
"of bleaching a print and re-developing in a sepia toner.</p>"
msgstr ""
"<b>Dubh & Bán le Ton Seipia</b>:<p>Tugann sé seo aird te agus ton lár agus "
"cuireann sé beagán fionnuara leis na scáthanna - an-chosúil leis an "
"bpróiseas chun prionta a bhánú agus a athfhorbairt i dtonóir seipia.</p>"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:288
#, kde-format
msgid "Brown Filter"
msgstr "Scagaire Donn"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:289
#, kde-format
msgid ""
"<b>Black & White with Brown Tone</b>:<p>This filter is more neutral than the "
"Sepia Tone filter.</p>"
msgstr ""
"<b>Dubh & Bán le Ton Donn</b>:<p>Tá an scagaire seo níos neodraí ná an "
"scagaire Ton Sepia.</p>"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:293
#, kde-format
msgid "Cold Filter"
msgstr "Scagaire Fuar"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:294
#, kde-format
msgid ""
"<b>Black & White with Cold Tone</b>:<p>Start subtly and replicate printing "
"on a cold tone black and white paper such as a bromide enlarging paper.</p>"
msgstr ""
"<b>Dubh & Bán le Ton Fuar</b>:<p>Tosaigh go seimh agus déan priontáil "
"mhacasamhlaithe ar pháipéar dubh agus bán le ton fuar amhail páipéar "
"méadaithe bróimíde.</p>"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:299
#, kde-format
msgid "Selenium Filter"
msgstr "Scagaire Seiléiniam"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:300
#, kde-format
msgid ""
"<b>Black & White with Selenium Tone</b>:<p>This effect replicates "
"traditional selenium chemical toning done in the darkroom.</p>"
msgstr ""
"<b>Dubh & Bán le Ton Seiléiniam</b>:<p>Is macasamhail den tonú ceimiceach "
"seiléiniam traidisiúnta a dhéantar sa seomra dorcha é seo.</p>"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:304
#, kde-format
msgid "Platinum Filter"
msgstr "Scagaire Platanaim"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:305
#, kde-format
msgid ""
"<b>Black & White with Platinum Tone</b>:<p>This effect replicates "
"traditional platinum chemical toning done in the darkroom.</p>"
msgstr ""
"<b>Dubh & Bán le Ton Platanam</b>:<p>Is macasamhail den tonú ceimiceach "
"platanam traidisiúnta a dhéantar sa seomra dorcha an éifeacht seo.</p>"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:310
#, kde-format
msgid ""
"<b>Black & White with greenish tint</b>:<p>This effect is also known as "
"Verdante.</p>"
msgstr ""
"<b>Dubh & Bán le lí glas</b>:<p>Tugtar Verdante ar an éifeacht seo freisin.</"
"p>"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:362
#, kde-format
msgid "Lens Filters"
msgstr "Scagairí Lionsa"

#: core/libs/dimg/filters/bw/bwsepiasettings.cpp:364
#, kde-format
msgid "Tone"
msgstr "Ton"

