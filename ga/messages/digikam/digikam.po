#: core/dplugins/dimg/jpeg2000/dimgjpeg2000plugin.cpp:107
#, kde-format
msgctxt "@info"
msgid "An image loader based on Libjasper codec"
msgstr "Luchtóir íomhá bunaithe ar chódc Libjasper"

#: core/dplugins/dimg/jpeg2000/dimgjpeg2000plugin.cpp:112
#, kde-kuit-format
msgctxt "@info"
msgid ""
"<para>This plugin allows users to load and save image using Libjasper codec</"
"para><para>The JPEG (Joint Photographic Experts Group) 2000 standard, "
"finalized in 2001, defines a image-coding scheme using state-of-the-art "
"compression techniques based on wavelet technology. Its architecture is "
"useful for many diverse applications, including image archiving, security "
"systems, digital photography, and medical imaging.</para><para>See <a "
"href='https://en.wikipedia.org/wiki/JPEG_2000'>Joint Photographic Experts "
"Group documentation</a> for details.</para>"
msgstr ""
"<para>Ligeann an breiseán seo d'úsáideoirí íomhá a luchtú agus a shábháil ag "
"baint úsáide as cód Libjasper</para><para>Sainmhíníonn an caighdeán JPEG "
"(Joint Photographic Experts Group) 2000, a tugadh chun críche in 2001, scéim "
"chódaithe íomhá ag baint úsáide as teicnící comhbhrúite den scoth bunaithe "
"ar theicneolaíocht tonnbheagáin. Tá a ailtireacht úsáideach do go leor "
"feidhmchlár éagsúil, lena n-áirítear cartlannú íomhá, córais slándála, "
"grianghrafadóireacht dhigiteach, agus íomháú leighis.</para><para>Féach <a "
"href='https://en.wikipedia.org/wiki/JPEG_2000'>doiciméadacht an Joint "
"Photographic Experts Group</a> le haghaidh sonraí.</para>"

