#: core/libs/template/subjectedit.cpp:47
#, kde-format
msgid ""
"Enter the Informative Provider Reference here. I.P.R is a name registered "
"with the XMP/NAA, identifying the provider that provides an indicator of the "
"content. The default value for the I.P.R is \"XMP\" if a standard Reference "
"Code is used."
msgstr ""
"Cuir isteach an Tagairt Soláthraí Faisnéise anseo. Is ainm é I.P.R atá "
"cláraithe leis an XMP/NAA, a shainaithníonn an soláthraí a sholáthraíonn "
"táscaire den ábhar. Is é \"XMP\" an luach réamhshocraithe don I.P.R má "
"úsáidtear Cód Tagartha caighdeánach."

#: core/libs/template/subjectedit.cpp:53
#, kde-format
msgid ""
"Enter the Subject Reference Number here. Provides a numeric code to indicate "
"the Subject Name plus optional Subject Matter and Subject Detail Names in "
"the language of the service. Subject Reference is a number from the range "
"01000000 to 17999999 and represent a language independent international "
"reference to a Subject. A Subject is identified by its Reference Number and "
"corresponding Names taken from a standard lists given by XMP/NAA. If a "
"standard reference code is used, these lists are the English language "
"reference versions. This field is limited to 8 digit code."
msgstr ""
"Cuir isteach Uimhir Thagartha an Ábhair anseo. Soláthraíonn sé cód uimhriúil "
"chun Ainm an Ábhair móide Ainmneacha Ábhair agus Mionsonraí Ábhair roghnacha "
"a léiriú i dteanga na seirbhíse. Is uimhir í Tagairt Ábhair ón raon 01000000 "
"go 17999999 agus léiríonn sí tagairt idirnáisiúnta neamhspleách teanga "
"d'Ábhar. Aithnítear Ábhar lena Uimhir Thagartha agus Ainmneacha "
"comhfhreagracha a thógtar ó liostaí caighdeánacha arna soláthar ag XMP/NAA. "
"Má úsáidtear cód tagartha caighdeánach, is iad na liostaí seo na leaganacha "
"tagartha Béarla. Tá an réimse seo teoranta do chód 8 ndigit."

#: core/libs/template/subjectedit.cpp:66
#, kde-format
msgid ""
"Enter the Subject Name here. English language is used if you selected a "
"standard XMP/NAA reference code."
msgstr ""
"Cuir isteach Ainm an Ábhair anseo. Úsáidtear an Béarla má roghnaigh tú cód "
"tagartha caighdeánach XMP/NAA."

#: core/libs/template/subjectedit.cpp:70
#, kde-format
msgid ""
"Enter the Subject Matter Name here. English language is used if you selected "
"a standard XMP/NAA reference code."
msgstr ""
"Cuir isteach Ainm an Ábhair anseo. Úsáidtear an Béarla má roghnaigh tú cód "
"tagartha caighdeánach XMP/NAA."

#: core/libs/template/subjectedit.cpp:74
#, kde-format
msgid ""
"Enter the Subject Detail Name here. English language is used if you selected "
"a standard XMP/NAA reference code."
msgstr ""
"Cuir isteach Ainm Sonraí an Ábhair anseo. Úsáidtear Béarla má roghnaigh tú "
"cód tagartha caighdeánach XMP/NAA."

#: core/libs/template/templatelist.cpp:70
#, kde-format
msgctxt "@info"
msgid "Here you can see the metadata template list managed by digiKam."
msgstr ""
"Anseo is féidir leat an liosta teimpléid meiteashonraí atá á bhainistiú ag "
"digiKam a fheiceáil."

#: core/libs/template/templatelist.cpp:73
#, kde-format
msgctxt "@title: template properties"
msgid "Title"
msgstr "Teideal"

#: core/libs/template/templatelist.cpp:74
#, kde-format
msgctxt "@title: template properties"
msgid "Authors"
msgstr "Údair"

#: core/libs/template/templatepanel.cpp:89
#, kde-format
msgid "Author Names:"
msgstr "Ainmneacha Údair:"

#: core/libs/template/templatepanel.cpp:92
#, kde-format
msgid ""
"Enter the names of the photograph's creators. Use semi-colons as separator "
"here."
msgstr ""
"Cuir isteach ainmneacha chruthaitheoirí an ghrianghraif. Bain úsáid as "
"leathstad mar dheighilteoir anseo."

#: core/libs/template/templatepanel.cpp:94
#, kde-format
msgid ""
"<p>This field should contain the names of the persons who created the "
"photograph. If it is not appropriate to add the name of the photographer "
"(for example, if the identity of the photographer needs to be protected) the "
"name of a company or organization can also be used. Once saved, this field "
"should not be changed by anyone.</p><p>To enter more than one name, use "
"<b>semi-colons as separators</b>.</p><p>With IPTC, this field is limited to "
"32 characters.</p>"
msgstr ""
"<p>Ba chóir ainmneacha na ndaoine a chruthaigh an grianghraf a bheith sa "
"réimse seo. Mura bhfuil sé oiriúnach ainm an ghrianghrafadóra a chur leis "
"(mar shampla, más gá céannacht an ghrianghrafadóra a chosaint), is féidir "
"ainm cuideachta nó eagraíochta a úsáid freisin. Nuair a bheidh an réimse seo "
"sábháilte, níor cheart d'aon duine é a athrú.</p><p>Chun níos mó ná ainm "
"amháin a iontráil, bain úsáid as <b>leathstad mar dheighilteoirí</b>.</"
"p><p>Le IPTC, tá an réimse seo teoranta do 32 charachtar.</p>"

#: core/libs/template/templatepanel.cpp:103
#, kde-format
msgid "Authors' Positions:"
msgstr "Seasamh na nÚdair:"

#: core/libs/template/templatepanel.cpp:105
#, kde-format
msgid "Enter the job titles of the authors here."
msgstr "Cuir isteach teidil poist na n-údar anseo."

#: core/libs/template/templatepanel.cpp:107
#, kde-format
msgid ""
"<p>This field should contain the job titles of the authors. Examples might "
"include titles such as: Staff Photographer, Freelance Photographer, or "
"Independent Commercial Photographer. Since this is a qualifier for the "
"Author field, the Author field must also be filled out.</p><p>With IPTC, "
"this field is limited to 32 characters.</p>"
msgstr ""
"<p>Ba chóir teidil poist na n-údar a bheith sa réimse seo. D’fhéadfadh "
"teidil ar nós: Grianghrafadóir Foirne, Grianghrafadóir Saorchleachtóir, nó "
"Grianghrafadóir Tráchtála Neamhspleách a bheith san áireamh sna samplaí. Ós "
"rud é gur cáilitheoir é seo don réimse Údair, ní mór an réimse Údair a "
"líonadh isteach freisin.</p><p>Le IPTC, tá an réimse seo teoranta do 32 "
"charachtar.</p>"

#: core/libs/template/templatepanel.cpp:117
#, kde-format
msgid "Enter the photograph credit here."
msgstr "Cuir isteach creidiúint an ghrianghraif anseo."

#: core/libs/template/templatepanel.cpp:119
#, kde-format
msgid ""
"<p>(synonymous to Provider): Use the Provider field to identify who is "
"providing the photograph. This does not necessarily have to be the author. "
"If a photographer is working for a news agency such as Reuters or the "
"Associated Press, these organizations could be listed here as they are "
"\"providing\" the image for use by others. If the image is a stock "
"photograph, then the group (agency) involved in supplying the image should "
"be listed here.</p><p>With IPTC, this field is limited to 32 characters.</p>"
msgstr ""
"<p>(comhchiallach le Soláthraí): Úsáid an réimse Soláthraí chun a aithint cé "
"atá ag soláthar an ghrianghraif. Ní gá gurb é an t-údar é seo. Má tá "
"grianghrafadóir ag obair do ghníomhaireacht nuachta ar nós Reuters nó "
"Associated Press, d'fhéadfaí na heagraíochtaí seo a liostáil anseo mar go "
"bhfuil siad ag \"soláthar\" na híomhá lena húsáid ag daoine eile. Más "
"grianghraf stoic atá san íomhá, ba chóir an grúpa (an ghníomhaireacht) atá "
"bainteach le soláthar na híomhá a liostáil anseo.</p><p>Le IPTC, tá an "
"réimse seo teoranta do 32 charachtar.</p>"

#: core/libs/template/templatepanel.cpp:131
#, kde-format
msgid ""
"Enter the copyright notice to identify the current owner(s) of the copyright "
"here."
msgstr ""
"Cuir isteach an fógra cóipchirt anseo chun úinéir(í) reatha an chóipchirt a "
"aithint."

#: core/libs/template/templatepanel.cpp:132
#, kde-format
msgid ""
"<p>The Copyright Notice should contain any necessary copyright notice for "
"claiming the intellectual property, and should identify the current owner(s) "
"of the copyright for the photograph. Usually, this would be the "
"photographer, but if the image was done by an employee or as work-for-hire, "
"then the agency or company should be listed. Use the form appropriate to "
"your country. USA: &copy; {date of first publication} name of copyright "
"owner, as in \"&copy;2005 John Doe.\" Note, the word \"copyright\" or the "
"abbreviation \"copr\" may be used in place of the &copy; symbol. In some "
"foreign countries only the copyright symbol is recognized and the "
"abbreviation does not work. Furthermore the copyright symbol must be a full "
"circle with a \"c\" inside; using something like (c) where the parentheses "
"form a partial circle is not sufficient. For additional protection "
"worldwide, use of the phrase, \"all rights reserved\" following the notice "
"above is encouraged. <br>In Europe you would use: Copyright {Year} "
"{Copyright owner}, all rights reserved. <br>In Japan, for maximum "
"protection, the following three items should appear in the copyright field "
"of the IPTC Core: (a) the word, Copyright; (b) year of the first "
"publication; and (c) name of the author. You may also wish to include the "
"phrase \"all rights reserved\".</p><p>With XMP, you can include more than "
"one copyright string using different languages.</p><p>With IPTC, this field "
"is limited to 128 characters.</p>"
msgstr ""
"<p>Ba chóir go mbeadh aon fhógra cóipchirt is gá chun an mhaoin intleachtúil "
"a éileamh san Fhógra Cóipchirt, agus ba chóir go n-aithneodh sé úinéir(í) "
"reatha an chóipchirt don ghrianghraf. De ghnáth, is é an grianghrafadóir a "
"bheadh i gceist, ach má rinne fostaí an íomhá nó má rinneadh í mar obair ar "
"fruiliú, ba chóir an ghníomhaireacht nó an chuideachta a liostáil. Úsáid an "
"fhoirm is iomchuí le haghaidh do thír féin. SAM: &copy; {dáta an chéad "
"fhoilsithe} ainm úinéir an chóipchirt, mar atá i \"&copy;2005 John Doe.\" "
"Tabhair faoi deara, gur féidir an focal \"cóipcheart\" nó an giorrúchán "
"\"copr\" a úsáid in ionad an tsiombail &copy;. I roinnt tíortha iasachta, ní "
"aithnítear ach an tsiombail chóipchirt agus ní oibríonn an giorrúchán. Ina "
"theannta sin, ní mór don tsiombail chóipchirt a bheith ina ciorcal iomlán le "
"\"c\" istigh ann; ní leor rud éigin cosúil le (c) a úsáid nuair a "
"chruthaíonn na lúibíní ciorcal páirteach. Chun cosaint bhreise a fháil ar "
"fud an domhain, moltar úsáid a bhaint as an bhfrása, \"gach ceart ar cosaint"
"\" i ndiaidh an fhógra thuas. <br>San Eoraip, d'úsáidfeá: Cóipcheart "
"{Bliain} {Úinéir an chóipchirt}, gach ceart ar cosaint. <br>Sa tSeapáin, "
"chun an chosaint is mó a fháil, ba chóir na trí mhír seo a leanas a bheith i "
"réimse cóipchirt Chroílár IPTC: (a) an focal, Cóipcheart; (b) bliain an "
"chéad fhoilsithe; agus (c) ainm an údair. B’fhéidir gur mhaith leat an frása "
"\"gach ceart ar cosaint\" a chur san áireamh freisin.</p><p>Le XMP, is "
"féidir leat níos mó ná teaghrán cóipchirt amháin a chur san áireamh ag baint "
"úsáide as teangacha éagsúla.</p><p>Le IPTC, tá an réimse seo teoranta do 128 "
"carachtar.</p>"

#: core/libs/template/templatepanel.cpp:154
#, kde-format
msgid ""
"Enter the list of instructions on how a resource can be legally used here."
msgstr ""
"Cuir isteach an liosta treoracha maidir le conas is féidir acmhainn a úsáid "
"go dleathach anseo."

#: core/libs/template/templatepanel.cpp:155
#, kde-format
msgid ""
"<p>The Right Usage Terms field should be used to list instructions on how a "
"resource can be legally used.</p><p>With XMP, you can include more than one "
"right usage terms string using different languages.</p><p>This field does "
"not exist with IPTC.</p>"
msgstr ""
"<p>Ba chóir an réimse Téarmaí Úsáide Cearta a úsáid chun treoracha a "
"liostáil maidir le conas is féidir acmhainn a úsáid go dleathach.</p><p>Le "
"XMP, is féidir leat níos mó ná teaghrán amháin de théarmaí úsáide cearta a "
"áireamh ag baint úsáide as teangacha éagsúla.</p><p>Níl an réimse seo ann le "
"IPTC.</p>"

#: core/libs/template/templatepanel.cpp:163
#: core/libs/template/templateviewer.cpp:112
#, kde-format
msgctxt "@label: template properties"
msgid "Source:"
msgstr "Foinse:"

#: core/libs/template/templatepanel.cpp:165
#, kde-format
msgid "Enter the original owner of the photograph here."
msgstr "Cuir isteach úinéir bunaidh an ghrianghraif anseo."

#: core/libs/template/templatepanel.cpp:167
#, kde-format
msgid ""
"<p>The Source field should be used to identify the original owner or "
"copyright holder of the photograph. The value of this field should never be "
"changed after the information is entered following the image's creation. "
"While not yet enforced by the custom panels, you should consider this to be "
"a \"write-once\" field. The source could be an individual, an agency, or a "
"member of an agency. To aid in later searches, it is suggested to separate "
"any slashes \"/\" with a blank space. Use the form \"photographer / agency\" "
"rather than \"photographer/agency.\" Source may also be different from "
"Creator and from the names listed in the Copyright Notice.</p><p>With IPTC, "
"this field is limited to 32 characters.</p>"
msgstr ""
"<p>Ba chóir an réimse Foinse a úsáid chun úinéir bunaidh nó sealbhóir "
"cóipchirt an ghrianghraif a aithint. Níor cheart luach an réimse seo a athrú "
"riamh tar éis an fhaisnéis a iontráil i ndiaidh chruthú na híomhá. Cé nach "
"bhfuil sé seo forfheidhmithe ag na painéil saincheaptha go fóill, ba chóir "
"duit a mheas gur réimse \"scríobh uair amháin\" é seo. D'fhéadfadh an "
"fhoinse a bheith ina dhuine aonair, ina ghníomhaireacht, nó ina bhall de "
"ghníomhaireacht. Chun cabhrú le cuardaigh níos déanaí, moltar aon slaiseanna "
"\"/\" a dheighilt le spás bán. Bain úsáid as an bhfoirm \"grianghrafadóir / "
"gníomhaireacht\" seachas \"grianghrafadóir/gníomhaireacht.\" Féadfaidh an "
"fhoinse a bheith difriúil ón gCruthaitheoir agus ó na hainmneacha atá "
"liostaithe san Fhógra Cóipchirt freisin.</p><p>Le IPTC, tá an réimse seo "
"teoranta do 32 charachtar.</p>"

#: core/libs/template/templatepanel.cpp:179
#: core/libs/template/templateviewer.cpp:114
#, kde-format
msgid "Instructions:"
msgstr "Treoracha:"

#: core/libs/template/templatepanel.cpp:181
#, kde-format
msgid "Enter the editorial notice here."
msgstr "Cuir isteach an fógra eagarthóireachta anseo."

#: core/libs/template/templatepanel.cpp:183
#, kde-format
msgid ""
"<p>The Instructions field should be used to list editorial instructions "
"concerning the use of photograph.</p><p>With IPTC, this field is limited to "
"256 characters.</p>"
msgstr ""
"<p>Ba chóir an réimse Treoracha a úsáid chun treoracha eagarthóireachta a "
"liostáil maidir le húsáid grianghraf.</p><p>Le IPTC, tá an réimse seo "
"teoranta do 256 carachtar.</p>"

#: core/libs/template/templatepanel.cpp:220
#, kde-format
msgid "Enter the city of contents here."
msgstr "Cuir isteach cathair na n-ábhar anseo."

#: core/libs/template/templatepanel.cpp:222
#, kde-format
msgid ""
"<p>This field should contain the name of the city where the photograph was "
"taken.</p>"
msgstr ""
"<p>Ba chóir ainm na cathrach inar tógadh an grianghraf a bheith sa réimse "
"seo.</p>"

#: core/libs/template/templatepanel.cpp:230
#, kde-format
msgid "Enter the city sublocation of contents here."
msgstr "Cuir isteach fo-shuíomh cathrach an ábhair anseo."

#: core/libs/template/templatepanel.cpp:232
#, kde-format
msgid ""
"<p>This field should contain the sublocation of the city where the "
"photograph was taken.</p>"
msgstr ""
"<p>Ba chóir go mbeadh fo-shuíomh na cathrach inar tógadh an grianghraf sa "
"réimse seo.</p>"

#: core/libs/template/templatepanel.cpp:240
#, kde-format
msgid "Enter the province or state of contents here."
msgstr "Cuir isteach an cúige nó an stát ina bhfuil an t-ábhar anseo."

#: core/libs/template/templatepanel.cpp:242
#, kde-format
msgid ""
"<p>This field should contain the province or state where the photograph was "
"taken.</p>"
msgstr ""
"<p>Ba chóir go mbeadh an cúige nó an stát inar tógadh an grianghraf sa "
"réimse seo.</p>"

#: core/libs/template/templatepanel.cpp:250
#, kde-format
msgid "<p>Select here the country where the photograph was taken.</p>"
msgstr "<p>Roghnaigh anseo an tír inar tógadh an grianghraf.</p>"

#: core/libs/template/templatepanel.cpp:284
#, kde-format
msgid "Enter the city name of the lead author here."
msgstr "Cuir isteach ainm cathrach an phríomhúdair anseo."

#: core/libs/template/templatepanel.cpp:286
#, kde-format
msgid ""
"<p>This field should contain the city name where the lead author lives.</p>"
msgstr ""
"<p>Ba chóir go mbeadh ainm na cathrach ina gcónaíonn an príomhúdar sa réimse "
"seo.</p>"

#: core/libs/template/templatepanel.cpp:294
#, kde-format
msgid "Enter the country name of the lead author here."
msgstr "Cuir isteach ainm tíre an phríomhúdair anseo."

#: core/libs/template/templatepanel.cpp:296
#, kde-format
msgid ""
"<p>This field should contain the country name where the lead author lives.</"
"p>"
msgstr ""
"<p>Ba chóir go mbeadh ainm na tíre ina gcónaíonn an príomhúdar sa réimse seo."
"</p>"

#: core/libs/template/templatepanel.cpp:301
#: core/libs/template/templateviewer.cpp:152
#, kde-format
msgctxt "@label: template properties"
msgid "Address:"
msgstr "Seoladh:"

#: core/libs/template/templatepanel.cpp:304
#, kde-format
msgid "Enter the address of the lead author here."
msgstr "Cuir isteach seoladh an phríomhúdair anseo."

#: core/libs/template/templatepanel.cpp:306
#, kde-format
msgid ""
"<p>This field should contain the address where the lead author lives.</p>"
msgstr ""
"<p>Ba chóir go mbeadh seoladh cónaithe an phríomhúdair sa réimse seo.</p>"

#: core/libs/template/templatepanel.cpp:311
#: core/libs/template/templateviewer.cpp:154
#, kde-format
msgid "Postal Code:"
msgstr "Cód Poist:"

#: core/libs/template/templatepanel.cpp:314
#, kde-format
msgid "Enter the postal code of the lead author here."
msgstr "Cuir isteach cód poist an phríomhúdair anseo."

#: core/libs/template/templatepanel.cpp:316
#, kde-format
msgid ""
"<p>This field should contain the postal code where the lead author lives.</p>"
msgstr ""
"<p>Ba chóir go mbeadh an cód poist ina gcónaíonn an príomhúdar sa réimse seo."
"</p>"

#: core/libs/template/templatepanel.cpp:321
#, kde-format
msgid "Province:"
msgstr "Cúige:"

