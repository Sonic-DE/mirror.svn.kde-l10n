#: core/libs/dnnmodelmanager/dnnmodelmanager.cpp:347
#, kde-format
msgid "YOLOv11 Nano"
msgstr "YOLOv11 Nano"

#: core/libs/dnnmodelmanager/dnnmodelmanager.cpp:349
#, kde-format
msgctxt "@info:tooltip"
msgid ""
"<p><b>YOLOv11 Nano</b>: small, lightweight neural network offering "
"exceptional speed, but may miss identifying more objects in images. YOLO can "
"detect multiple objects in an image. It is trained to recognize 80 different "
"objects using the COCO dataset.</p>"
msgstr ""
"<p><b>YOLOv11 Nano</b>: líonra néarach beag, éadrom a thairgeann luas "
"eisceachtúil, ach d'fhéadfadh sé nach n-aithneoidh sé níos mó rudaí in "
"íomhánna. Is féidir le YOLO ilréada a bhrath in íomhá. Tá sé oilte chun 80 "
"réad difriúil a aithint ag baint úsáide as an tacar sonraí COCO.</p>"

#: core/libs/dnnmodelmanager/dnnmodelmanager.cpp:354
#, kde-format
msgid "YOLOv11 XLarge"
msgstr "YOLOv11 XLarge"

#: core/libs/dnnmodelmanager/dnnmodelmanager.cpp:356
#, kde-format
msgctxt "@info:tooltip"
msgid ""
"<p><b>YOLOv11 XLarge</b>: large, robust neural network offering good "
"accuracy. It will detect more objects in images than YOLOv11 Nano, but is "
"slower. YOLO can detect multiple objects in an image. It is trained to "
"recognize 80 different objects using the COCO dataset.</p>"
msgstr ""
"<p><b>YOLOv11 XLarge</b>: líonra néarach mór, láidir a thairgeann cruinneas "
"maith. Braithfidh sé níos mó réad in íomhánna ná YOLOv11 Nano, ach tá sé "
"níos moille. Is féidir le YOLO ilréada a bhrath in íomhá. Tá sé oilte chun "
"80 réad difriúil a aithint ag baint úsáide as an tacar sonraí COCO.</p>"

#: core/libs/dnnmodelmanager/dnnmodelmanager.cpp:361
#, kde-format
msgid "EfficientNet B7"
msgstr "ÉifeachtachNet B7"

#: core/libs/dnnmodelmanager/dnnmodelmanager.cpp:363
#, kde-format
msgctxt "@info:tooltip"
msgid ""
"<p><b>EfficientNet B7</b>: large and powerful convoluted neural network. It "
"will detect a single object in an image with high accuracy. EfficientNet B7 "
"was trained to recognize 1,000 different objects using the ImageNet dataset."
"</p>"
msgstr ""
"<p><b>EfficientNet B7</b>: líonra néarónach casta mór agus cumhachtach. "
"Braithfidh sé réad aonair in íomhá le cruinneas ard. Rinneadh oiliúint ar "
"EfficientNet B7 chun 1,000 réad difriúil a aithint ag baint úsáide as tacar "
"sonraí ImageNet.</p>"

