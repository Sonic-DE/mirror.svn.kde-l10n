#: core/libs/tags/autoassignment/autotagsscanwidget.cpp:121
#, kde-format
msgctxt "@item: update the autotags entries in database"
msgid "Update"
msgstr "Nuashonrú"

#: core/libs/tags/autoassignment/autotagsscanwidget.cpp:123
#, kde-format
msgctxt "@info:tooltip"
msgid ""
"<p><b>Replace Existing</b>: clear existing auto-tags and replace with the "
"results of the scan.</p><p><b>Update</b>: add any new auto-tags found to the "
"existing auto-tags.</p>"
msgstr ""
"<p><b>Athsholáthar atá ann cheana féin</b>: glan na clibeanna uathoibríocha "
"atá ann cheana féin agus cuir torthaí an scanadh ina n-áit.</"
"p><p><b>Nuashonrú</b>: cuir aon chlibeanna uathoibríocha nua a aimsítear "
"leis na clibeanna uathoibríocha atá ann cheana féin.</p>"

