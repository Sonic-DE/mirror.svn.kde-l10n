#: core/utilities/firstrun/databasepage.cpp:49
#, kde-format
msgid "<b>Configure where you will store databases</b>"
msgstr "<b>Cumraigh cá stórálfaidh tú bunachair shonraí</b>"

#: core/utilities/firstrun/metadatapage.cpp:51
#, kde-format
msgid "<b>Configure Metadata Storage to Files</b>"
msgstr "<b>Cumraigh Stóráil Meiteashonraí chuig Comhaid</b>"

#: core/utilities/firstrun/metadatapage.cpp:59
#, kde-format
msgid ""
"<qt><p>Set here if you want to store the information assigned to items in "
"digiKam in the files' metadata, to improve interoperability with other photo "
"management programs:</p></qt>"
msgstr ""
"<qt><p>Socraigh anseo más mian leat an fhaisnéis atá sannta do mhíreanna i "
"digiKam a stóráil i meiteashonraí na gcomhad, chun idir-inoibritheacht le "
"cláir bainistíochta grianghraf eile a fheabhsú:</p></qt>"

#: core/utilities/firstrun/metadatapage.cpp:69
#, kde-format
msgid "Do nothing"
msgstr "Ná déan faic"

#: core/utilities/firstrun/metadatapage.cpp:74
#, kde-format
msgid "Add information to files"
msgstr "Cuir faisnéis le comhaid"

#: core/utilities/firstrun/metadatapage.cpp:84
#, kde-format
msgid ""
"<qt><p><i>Note:</i> recording information to the files' metadata can slow "
"down photo management operations.</p></qt>"
msgstr ""
"<qt><p><i>Nóta:</i> is féidir le faisnéis a thaifeadadh i meiteashonraí na "
"gcomhad moill a chur ar oibríochtaí bainistíochta grianghraf.</p></qt>"

#: core/utilities/firstrun/migratefromdigikam4page.cpp:64
#, kde-format
msgid "Migration from digiKam 4"
msgstr "Imirce ó digiKam 4"

#: core/utilities/firstrun/migratefromdigikam4page.cpp:72
#, kde-format
msgid ""
"<qt><p><h1><b>Migrate configuration and metadata from digiKam 4</b></h1></"
"p><p>You can choose here if you want to use the configuration and albums "
"from digiKam 4 in new digiKam. Please note the following warnings:</"
"p><p>Migration is done <b>at your own risk</b>. digiKam developers do not "
"recommend it and do not support it. On the other hand, creating a new "
"configuration might result in loss of tags and other metadata that was not "
"embedded inside the pictures and was only available in digiKam 4's database."
"</p><p>In either case you are recommended to backup the configuration files "
"and databases before proceeding.</p></qt>"
msgstr ""
"<qt><p><h1><b>Aistrigh cumraíocht agus meiteashonraí ó digiKam 4</b></h1></"
"p><p>Is féidir leat a roghnú anseo más mian leat an chumraíocht agus na "
"halbaim ó digiKam 4 a úsáid sa digiKam nua. Tabhair faoi deara na rabhaidh "
"seo a leanas:</p><p>Déantar an t-aistriú <b>ar do phriacal féin</b>. Ní "
"mholann forbróirí digiKam é agus ní thacaíonn siad leis. Ar an láimh eile, "
"d'fhéadfadh sé go gcaillfí clibeanna agus meiteashonraí eile nach raibh "
"leabaithe sna pictiúir agus nach raibh ar fáil ach i mbunachar sonraí "
"digiKam 4 dá gcruthófaí cumraíocht nua.</p><p>In aon chás, moltar duit "
"cúltaca de na comhaid chumraíochta agus na bunachair shonraí a dhéanamh sula "
"dtéann tú ar aghaidh.</p></qt>"

#: core/utilities/firstrun/migratefromdigikam4page.cpp:89
#, kde-format
msgid "Migrate configuration from digiKam 4"
msgstr "Cumraíocht a aistriú ó digiKam 4"

#: core/utilities/firstrun/migratefromdigikam4page.cpp:98
#, kde-format
msgid "Create a new configuration"
msgstr "Cruthaigh cumraíocht nua"

#: core/utilities/firstrun/openfilepage.cpp:53
#, kde-format
msgid "<b>Configure Open File Behavior</b>"
msgstr "<b>Cumraigh Iompar Oscailte Comhaid</b>"

#: core/utilities/firstrun/openfilepage.cpp:61
#, kde-format
msgid ""
"<qt><p>Specify how images should be opened when left-clicked on in the icon "
"view:</p></qt>"
msgstr ""
"<qt><p>Sonraigh conas ba chóir íomhánna a oscailt nuair a chliceálann tú ar "
"chlé orthu sa radharc deilbhíní:</p></qt>"

#: core/utilities/firstrun/openfilepage.cpp:70
#, kde-format
msgid "Open a preview"
msgstr "Oscail réamhamharc"

#: core/utilities/firstrun/openfilepage.cpp:75
#, kde-format
msgid "Open in the editor"
msgstr "Oscail san eagarthóir"

#: core/utilities/firstrun/openfilepage.cpp:85
#, kde-format
msgid ""
"<qt><p><i>Note:</i> using a preview is always faster than using the editor, "
"especially when checking a series of shots. However, you cannot change or "
"fix the image in preview mode. Note that if you want to compare images "
"quickly, it is often better to use the light table: images can be displayed "
"side-by-side, and synchronized zooming and panning can be performed.</p></qt>"
msgstr ""
"<qt><p><i>Nóta:</i> Bíonn sé níos tapúla i gcónaí réamhamharc a úsáid ná an "
"t-eagarthóir a úsáid, go háirithe agus sraith íomhánna á seiceáil. Mar sin "
"féin, ní féidir leat an íomhá a athrú ná a shocrú sa mhodh réamhamhairc. "
"Tabhair faoi deara, más mian leat íomhánna a chur i gcomparáid go tapa, go "
"minic is fearr an tábla solais a úsáid: is féidir íomhánna a thaispeáint "
"taobh le taobh, agus is féidir súmáil agus panáil sioncrónaithe a dhéanamh.</"
"p></qt>"

#: core/utilities/firstrun/previewpage.cpp:52
#, kde-format
msgid "<b>Configure Preview Behavior</b>"
msgstr "<b>Cumraigh Iompar Réamhamhairc</b>"

#: core/utilities/firstrun/previewpage.cpp:60
#, kde-format
msgid ""
"<qt><p>Set here how images are displayed in preview mode and on the light "
"table:</p></qt>"
msgstr ""
"<qt><p>Socraigh anseo conas a thaispeántar íomhánna i mód réamhamhairc agus "
"ar an mbord solais:</p></qt>"

#: core/utilities/firstrun/previewpage.cpp:69
#, kde-format
msgid "Load reduced version of image"
msgstr "Luchtaigh leagan laghdaithe den íomhá"

#: core/utilities/firstrun/previewpage.cpp:74
#, kde-format
msgid "Load image"
msgstr "Luchtaigh íomhá"

#: core/utilities/firstrun/previewpage.cpp:84
#, kde-format
msgid ""
"<qt><p><i>Note:</i> loading a reduced version of an image is faster but can "
"differ from the original, especially with Raw. In this case, a JPEG version "
"of Raw pre-processed by camera is loaded, instead of the real image data. "
"This JPEG image is embedded in the file metadata and is used by the camera "
"to display a Raw image faster to a TV screen.</p></qt>"
msgstr ""
"<qt><p><i>Nóta:</i> Is tapúla leagan laghdaithe d'íomhá a luchtú ach is "
"féidir go mbeidh sé difriúil ón mbunleagan, go háirithe le Amh. Sa chás seo, "
"luchtaítear leagan JPEG de Amh atá réamhphróiseáilte ag an gceamara, in "
"ionad na sonraí íomhá fíor. Tá an íomhá JPEG seo leabaithe i meiteashonraí "
"an chomhaid agus úsáideann an ceamara í chun íomhá Amh a thaispeáint níos "
"tapúla ar scáileán teilifíse.</p></qt>"

#: core/utilities/firstrun/rawpage.cpp:52
#, kde-format
msgid "<b>Configure Raw File Handling</b>"
msgstr "<b>Cumraigh Láimhseáil Comhad Amh</b>"

#: core/utilities/firstrun/rawpage.cpp:60
#, kde-format
msgid "<qt><p>Set here how you want to open Raw images in the editor:</p></qt>"
msgstr ""
"<qt><p>Socraigh anseo conas is mian leat íomhánna Amh a oscailt san "
"eagarthóir:</p></qt>"

#: core/utilities/firstrun/rawpage.cpp:69
#, kde-format
msgid "Open directly, with adjustments made automatically"
msgstr "Oscail go díreach, agus coigeartuithe á ndéanamh go huathoibríoch"

#: core/utilities/firstrun/rawpage.cpp:74
#, kde-format
msgid "Use the Raw import tool to adjust corrections manually"
msgstr ""
"Úsáid an uirlis allmhairithe Amh chun ceartúcháin a choigeartú de láimh"

#: core/utilities/firstrun/rawpage.cpp:84
#, kde-format
msgid ""
"<qt><p><i>Note:</i> the Raw import tool is designed for advanced users who "
"want to have the best control over the image. This requires more time in "
"your workflow.</p></qt>"
msgstr ""
"<qt><p><i>Nóta:</i> tá an uirlis allmhairithe Amh deartha d'úsáideoirí "
"ardleibhéil ar mian leo an smacht is fearr a bheith acu ar an íomhá. Éilíonn "
"sé seo níos mó ama i do shreabhadh oibre.</p></qt>"

#: core/utilities/firstrun/startscanpage.cpp:34
#, kde-format
msgid "Scan Your Collection"
msgstr "Scanáil Do Bhailiúchán"

#: core/utilities/firstrun/startscanpage.cpp:40
#, kde-format
msgid ""
"<qt><p>Congratulations. Your minimal setup is done.</p><p>Remember, you can "
"customize more settings using the digiKam configuration panel. To learn more "
"about the digiKam world, we recommend reading the <b>digiKam handbook</b> "
"using the <b>Help/Handbook</b> menu entry (you need to install the separate "
"digiKam documentation package.) You can also read the manual online from the "
"<a href='https://docs.digikam.org/en/index.html'>dedicated website</a>.</"
"p><p>Press <b>Finish</b> to close this assistant. digiKam will scan your "
"collection to register all albums in the database. Items including in albums "
"are collected after startup stage in background.</p><p><i>Note:</i> "
"depending on your collection size, this operation can take a while. If you "
"cancel the scanning operation, it will start again in the next digiKam "
"session.</p><p>When scanning has completed, at next start-up, digiKam will "
"only check your collection to identify new albums - which is much faster. "
"You can force digiKam to scan for new items manually using the <b>Tools-"
">Maintenance->Scan for new items</b> menu entry.</p></qt>"
msgstr ""
"<qt><p>Comhghairdeas. Tá do shocrú íosta déanta.</p><p>Cuimhnigh, is féidir "
"leat níos mó socruithe a shaincheapadh ag baint úsáide as painéal "
"cumraíochta digiKam. Chun tuilleadh a fhoghlaim faoi shaol digiKam, molaimid "
"duit <b>lámhleabhar digiKam</b> a léamh ag baint úsáide as an iontráil "
"roghchláir <b>Cabhair/Lámhleabhar</b> (ní mór duit an pacáiste "
"doiciméadaithe digiKam ar leith a shuiteáil.) Is féidir leat an lámhleabhar "
"a léamh ar líne freisin ón <a href='https://docs.digikam.org/en/index."
"html'>láithreán gréasáin tiomnaithe</a>.</p><p>Brúigh <b>Críochnaigh</b> "
"chun an cúntóir seo a dhúnadh. Déanfaidh digiKam scanadh ar do bhailiúchán "
"chun gach albam a chlárú sa bhunachar sonraí. Bailítear míreanna atá sna "
"halbaim tar éis an chéim tosaithe sa chúlra.</p><p><i>Nóta:</i> ag brath ar "
"mhéid do bhailiúcháin, féadfaidh an oibríocht seo tamall a thógáil. Má "
"chealaíonn tú an oibríocht scanadh, tosóidh sé arís sa chéad seisiún eile de "
"digiKam.</p><p>Nuair a bheidh an scanadh críochnaithe, ag an gcéad tosaithe "
"eile, ní dhéanfaidh digiKam ach seiceáil ar do bhailiúchán chun albaim nua a "
"aithint - rud atá i bhfad níos tapúla. Is féidir leat digiKam a chur iallach "
"chun scanadh a dhéanamh de láimh le haghaidh míreanna nua ag baint úsáide as "
"an iontráil roghchláir <b>Uirlisí->Cothabháil->Scanadh le haghaidh míreanna "
"nua</b>.</p></qt>"

#: core/utilities/firstrun/tooltipspage.cpp:52
#, kde-format
msgid "<b>Enabled Contextual Tooltips</b>"
msgstr "<b>Leideanna Uirlisí Comhthéacsúla Cumasaithe</b>"

#: core/utilities/firstrun/tooltipspage.cpp:60
#, kde-format
msgid ""
"<qt><p>Set here if you want to show contextual tooltips in icon-view and "
"folder-view:</p></qt>"
msgstr ""
"<qt><p>Socraigh anseo más mian leat leideanna uirlisí comhthéacsúla a "
"thaispeáint in amharc deilbhíní agus in amharc fillteán:</p></qt>"

#: core/utilities/firstrun/tooltipspage.cpp:69
#, kde-format
msgid "Do not show tooltips"
msgstr "Ná taispeáin leideanna uirlisí"

#: core/utilities/firstrun/tooltipspage.cpp:74
#, kde-format
msgid "Use Tooltips"
msgstr "Úsáid Leideanna Uirlisí"

#: core/utilities/firstrun/tooltipspage.cpp:84
#, kde-format
msgid ""
"<qt><p><i>Note:</i> tooltips show photograph and digiKam metadata on the "
"fly, as the mouse moves over items. This can be useful when selecting items. "
"Tooltips are displayed in the album folder view, album icon view, camera "
"icon view, batch queue list, and thumb bar. From the digiKam configuration "
"dialog, you can customize the contents of these tooltips and the fonts used."
"</p></qt>"
msgstr ""
"<qt><p><i>Nóta:</i> Taispeánann leideanna uirlisí meiteashonraí grianghraf "
"agus digiKam ar an toirt, agus an luch ag bogadh thar mhíreanna. Is féidir "
"leis seo a bheith úsáideach agus míreanna á roghnú. Taispeántar leideanna "
"uirlisí i radharc fillteán an albaim, radharc deilbhín an albaim, radharc "
"deilbhín an cheamara, liosta na scuaine baisce, agus barra ordóige. Ón "
"dialóg chumraíochta digiKam, is féidir leat ábhar na leideanna uirlisí seo "
"agus na clónna a úsáidtear a shaincheapadh.</p></qt>"

#: core/utilities/firstrun/welcomepage.cpp:40
#, kde-format
msgid ""
"<qt><p><h1><b>Welcome to digiKam %1</b></h1></p><p>digiKam is an advanced "
"digital photo management application published as open-source.</p><p>This "
"assistant will help you to configure first run settings to be able to use "
"digiKam quickly.</p></qt>"
msgstr ""
"<qt><p><h1><b>Fáilte go digiKam %1</b></h1></p><p>Is feidhmchlár "
"bainistíochta grianghraf digiteach chun cinn é digiKam atá foilsithe mar "
"fhoinse oscailte.</p><p>Cabhróidh an cúntóir seo leat socruithe an chéad "
"rith a chumrú le go mbeidh tú in ann digiKam a úsáid go tapa.</p></qt>"

#: core/utilities/firstrun/welcomepage.cpp:66
#, kde-format
msgid ""
"<qt><br><p>You can ignore the following if you use digiKam for the first "
"time:</p><p><b>Transition from digiKam 4</b></p><p>Configuration files from "
"digiKam 4 are not migrated. The old database can still be used, you just "
"need to choose the same locations for collections and database in the "
"following dialogs. It is recommended to create a backup of your database "
"before proceeding.</p><p>The new location for configuration files is %1 (old "
"%2). There are unresolved problems reported when reusing old configuration "
"files, so it is not recommended to do it for the moment, and therefore use "
"at your own risk.</p></qt>"
msgstr ""
"<qt><br><p>Is féidir leat neamhaird a dhéanamh ar an méid seo a leanas má "
"úsáideann tú digiKam den chéad uair:</p><p><b>Aistriú ó digiKam 4</b></"
"p><p>Ní dhéantar comhaid chumraíochta ó digiKam 4 a aistriú. Is féidir an "
"seanbhunachar sonraí a úsáid fós, níl le déanamh agat ach na suíomhanna "
"céanna a roghnú do bhailiúcháin agus don bhunachar sonraí sna dialóga seo a "
"leanas. Moltar cúltaca de do bhunachar sonraí a chruthú sula dtéann tú ar "
"aghaidh.</p><p>Is é %1 (sean-%2) an suíomh nua do chomhaid chumraíochta. "
"Tuairiscíodh fadhbanna gan réiteach agus seanchomhaid chumraíochta á n-"
"athúsáid, mar sin ní mholtar é sin a dhéanamh faoi láthair, agus dá bhrí sin "
"is ar do phriacal féin a dhéantar é a úsáid.</p></qt>"

