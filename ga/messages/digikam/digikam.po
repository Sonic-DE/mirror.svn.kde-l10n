#: core/utilities/setup/misc/setupmisc_behavior.cpp:95
#, kde-format
msgid "String comparison type:"
msgstr "Cineál comparáide teaghrán:"

#: core/utilities/setup/misc/setupmisc_behavior.cpp:97
#, kde-format
msgctxt "method to compare strings"
msgid "Natural"
msgstr "Nádúrtha"

#: core/utilities/setup/misc/setupmisc_behavior.cpp:98
#, kde-format
msgctxt "method to compare strings"
msgid "Normal"
msgstr "Gnáthchomparáid"

#: core/utilities/setup/misc/setupmisc_behavior.cpp:99
#, kde-format
msgid ""
"<qt>Sets the way in which strings are compared inside digiKam. This eg. "
"influences the sorting of the tree views.<br><b>Natural</b> tries to compare "
"strings in a way that regards some normal conventions and will eg. result in "
"sorting numbers naturally even if they have a different number of digits."
"<br><b>Normal</b> uses a more technical approach. Use this style if you eg. "
"want to entitle albums with ISO dates (201006 or 20090523) and the albums "
"should be sorted according to these dates.</qt>"
msgstr ""
"<qt>Socraíonn sé seo an chaoi a ndéantar comparáid idir teaghráin laistigh "
"de digiKam. Bíonn tionchar aige seo, mar shampla, ar shórtáil na radharcanna "
"crann. Déanann <br><b>Nádúrtha</b> iarracht teaghráin a chur i gcomparáid ar "
"bhealach a thugann aird ar roinnt coinbhinsiúin ghnáth agus mar thoradh air "
"sin, sórtálfar uimhreacha go nádúrtha fiú má tá líon difriúil digití acu. "
"Úsáideann <br><b>Gnáth</b> cur chuige níos teicniúla. Bain úsáid as an stíl "
"seo más mian leat, mar shampla, dátaí ISO (201006 nó 20090523) a thabhairt "
"d'albaim agus ba chóir na halbaim a shórtáil de réir na ndátaí seo.</qt>"

#: core/utilities/setup/misc/setupmisc_behavior.cpp:108
#, kde-format
msgid "Lower bound for minimum similarity:"
msgstr "Teorainn íochtarach don chosúlacht íosta:"

#: core/utilities/setup/misc/setupmisc_behavior.cpp:114
#, kde-format
msgid ""
"Select here the lower bound of the minimum similarity threshold for fuzzy "
"and duplicates searches. The default value is 40. Selecting a lower value "
"than 40 can make the search <b>really</b> slow."
msgstr ""
"Roghnaigh anseo an teorainn íochtarach den tairsí cosúlachta íosta le "
"haghaidh cuardaigh doiléire agus dúblacha. Is é 40 an luach réamhshocraithe. "
"Má roghnaíonn tú luach níos ísle ná 40, is féidir leis an gcuardach a bheith "
"<b>an-mhall</b>."

#: core/utilities/setup/misc/setupmisc_grouping.cpp:29
