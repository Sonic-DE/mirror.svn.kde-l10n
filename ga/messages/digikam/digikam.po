#: core/libs/tags/autoassignment/autotagsscanwidget.cpp:99
#, kde-format
msgctxt "@label"
msgid ""
"<p><b>This tool automatically assigns tags to images by analyzing the image "
"using a deep-learning neural network AI model.</b></p><p>The settings below "
"configure the deep-learning AI model used for analyzing image contents to "
"identify objects. The AI neural network will automatically generate "
"descriptive tags for the image contents and store the results in the "
"database.</p>"
msgstr ""
"<p><b>Sannann an uirlis seo clibeanna go huathoibríoch d'íomhánna tríd an "
"íomhá a anailísiú ag baint úsáide as samhail líonra néarach foghlama domhain "
"AI.</b></p><p>Cumraíonn na socruithe thíos an tsamhail foghlama domhain AI a "
"úsáidtear chun ábhar íomhá a anailísiú chun réada a aithint. Ginfidh an "
"líonra néarach AI clibeanna tuairisciúla go huathoibríoch d'ábhar na híomhá "
"agus stórálfaidh sé na torthaí sa bhunachar sonraí.</p>"

#: core/libs/tags/autoassignment/autotagsscanwidget.cpp:107
#, kde-format
msgctxt "@label with a short translated text about autotags scanning mode"
msgid "Scan Mode:"
msgstr "Mód Scanadh:"

#: core/libs/tags/autoassignment/autotagsscanwidget.cpp:110
#, kde-format
msgctxt "@item: all items to scan with autotags"
msgid "All"
msgstr "Uile"

#: core/libs/tags/autoassignment/autotagsscanwidget.cpp:111
#, kde-format
msgctxt "@item: autotags scan only non assigned items"
msgid "Non-Assigned Only"
msgstr "Neamh-Shannta Amháin"

#: core/libs/tags/autoassignment/autotagsscanwidget.cpp:113
#, kde-format
msgctxt "@info:tooltip"
msgid ""
"<p><b>All</b>: re-scan all items for tags.</p><p><b>Non-Assigned Only</b>: "
"scan only the items with no assigned autotags.</p>"
msgstr ""
"<p><b>Uile</b>: athscanadh a dhéanamh ar gach mír le haghaidh clibeanna.</"
"p><p><b>Neamh-Sannta Amháin</b>: scanadh na míreanna nach bhfuil clibeanna "
"uathoibríocha sannta acu amháin.</p>"

