#: core/dplugins/generic/metadata/geolocationedit/geolocationeditplugin.cpp:65
#, kde-format
msgctxt "@info"
msgid ""
"This tool allows users to change geolocation information from items."
"<br><br>This tool can edit GPS data, manually or over a map. Reverse geo-"
"coding is also available through web services.<br><br>This tool has also an "
"export function to KML to store map traces in Google format.<br><br>Finally, "
"this tool is able to read a GPS trace from a device to synchronize geo-"
"location of items if you camera do not have an embedded GPS device."
msgstr ""
"Ligeann an uirlis seo d’úsáideoirí faisnéis gheolúchála a athrú ó mhíreanna."
"<br><br>Is féidir leis an uirlis seo sonraí GPS a chur in eagar, de láimh nó "
"thar léarscáil. Tá geo-chódú droim ar ais ar fáil freisin trí sheirbhísí "
"gréasáin.<br><br>Tá feidhm easpórtála chuig KML ag an uirlis seo freisin "
"chun rianta léarscáile a stóráil i bhformáid Google.<br><br>Ar deireadh, is "
"féidir leis an uirlis seo rian GPS a léamh ó ghléas chun geo-shuíomh "
"míreanna a shioncrónú mura bhfuil gléas GPS leabaithe i do cheamara."

#: core/dplugins/generic/metadata/geolocationedit/geolocationeditplugin.cpp:103
#, kde-format
msgctxt "@action"
msgid "Edit Geolocation..."
msgstr "Cuir suíomh geo in eagar..."

