#: core/dplugins/editor/filters/blurfx/blurfxtool.cpp:100
#, kde-format
msgid "Focus Blur"
msgstr "Doiléiriú Fócas"

#: core/dplugins/editor/filters/blurfx/blurfxtool.cpp:101
#, kde-format
msgid "Smart Blur"
msgstr "Doiléiriú Cliste"

#: core/dplugins/editor/filters/blurfx/blurfxtool.cpp:102
#, kde-format
msgid "Frost Glass"
msgstr "Gloine Sioc"

#: core/dplugins/editor/filters/blurfx/blurfxtool.cpp:103
#: core/dplugins/generic/tools/wallpaper/wallpaperplugindlg.cpp:82
#, kde-format
msgid "Mosaic"
msgstr "Mósáic"

#: core/dplugins/editor/filters/blurfx/blurfxtool.cpp:105
#, kde-format
msgid ""
"<p>Select the blurring effect to apply to image.</p><p><b>Zoom Blur</b>:  "
"blurs the image along radial lines starting from a specified center point. "
"This simulates the blur of a zooming camera.</p><p><b>Radial Blur</b>: blurs "
"the image by rotating the pixels around the specified center point. This "
"simulates the blur of a rotating camera.</p><p><b>Far Blur</b>: blurs the "
"image by using far pixels. This simulates the blur of an unfocalized camera "
"lens.</p><p><b>Motion Blur</b>: blurs the image by moving the pixels "
"horizontally. This simulates the blur of a linear moving camera.</"
"p><p><b>Softener Blur</b>: blurs the image softly in dark tones and hardly "
"in light tones. This gives images a dreamy and glossy soft focus effect. It "
"is ideal for creating romantic portraits, glamour photographs, or giving "
"images a warm and subtle glow.</p><p><b>Shake Blur</b>: blurs the image by "
"shaking randomly the pixels. This simulates the blur of a random moving "
"camera.</p><p><b>Focus Blur</b>: blurs the image corners to reproduce the "
"astigmatism distortion of a lens.</p><p><b>Smart Blur</b>: finds the edges "
"of color in your image and blurs them without muddying the rest of the image."
"</p><p><b>Frost Glass</b>: blurs the image by randomly disperse light coming "
"through a frosted glass.</p><p><b>Mosaic</b>: divides the photograph into "
"rectangular cells and then recreates it by filling those cells with average "
"pixel value.</p>"
msgstr ""
"<p>Roghnaigh an éifeacht doiléirithe le cur i bhfeidhm ar an íomhá.</"
"p><p><b>Doiléiriú Súmála</b>: doiléiríonn sé an íomhá feadh línte gathacha "
"ag tosú ó phointe lárnach sonraithe. Insamhlaíonn sé seo doiléiriú ceamara "
"súmála.</p><p><b>Doiléiriú Gathach</b>: doiléiríonn sé an íomhá trí na "
"picteilíní a rothlú timpeall an phointe lárnach sonraithe. Insamhlaíonn sé "
"seo doiléiriú ceamara rothlach.</p><p><b>Doiléiriú I bhfad i gcéin</b>: "
"doiléiríonn sé an íomhá trí phicteilíní i bhfad i gcéin a úsáid. "
"Insamhlaíonn sé seo doiléiriú lionsa ceamara neamhfhócasaithe.</"
"p><p><b>Doiléiriú Gluaiseachta</b>: doiléiríonn sé an íomhá trí na "
"picteilíní a bhogadh go cothrománach. Insamhlaíonn sé seo doiléiriú ceamara "
"gluaisteach líneach.</p><p><b>Doiléiriú Bogthóra</b>: doiléiríonn sé an "
"íomhá go bog i dtoin dhorcha agus beagnach i dtoin éadroma. Tugann sé seo "
"éifeacht fhócais bhog aislingeach agus lonrach d'íomhánna. Tá sé iontach "
"maith chun portráidí rómánsúla, grianghraif ghalánta, nó gliondar te agus "
"caolchúiseach a chruthú d’íomhánna.</p><p><b>Doiléiriú Croith</b>: "
"doiléiríonn sé an íomhá trí na picteilíní a chroitheadh go randamach. "
"Insamhlaíonn sé seo doiléiriú ceamara atá ag gluaiseacht go randamach.</"
"p><p><b>Doiléiriú Fócais</b>: doiléiríonn sé coirnéil na híomhá chun "
"saobhadh astigmatism lionsa a atáirgeadh.</p><p><b>Doiléiriú Cliste</b>: "
"aimsíonn sé imill an datha i d’íomhá agus doiléiríonn sé iad gan an chuid "
"eile den íomhá a mhilleadh.</p><p><b>Gloine Sioctha</b>: doiléiríonn sé an "
"íomhá trí sholas a thagann trí ghloine sioctha a scaipeadh go randamach.</"
"p><p><b>Mósáic</b>: roinneann sé an grianghraf ina chealla dronuilleogacha "
"agus ansin athchruthaíonn sé é trí na cealla sin a líonadh le meánluach "
"picteilín.</p>"

