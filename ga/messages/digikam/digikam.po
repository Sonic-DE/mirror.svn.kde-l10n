#: core/dplugins/dimg/heif/dimgheifexportsettings.cpp:64
#, kde-format
msgid ""
"<p>Toggle lossless compression for HEIF images.</p><p>If this option is "
"enabled, a lossless method will be used to compress HEIF pictures.</p>"
msgstr ""
"<p>Cas an comhbhrú gan chailliúint le haghaidh íomhánna HEIF.</p><p>Má tá an "
"rogha seo cumasaithe, úsáidfear modh gan chailliúint chun pictiúir HEIF a "
"chomhbhrú.</p>"

#: core/dplugins/dimg/heif/dimgheifexportsettings.cpp:71
#, kde-format
msgid "HEIF quality:"
msgstr "Cáilíocht HEIF:"

#: core/dplugins/dimg/heif/dimgheifexportsettings.cpp:73
#, kde-format
msgid ""
"<p>The quality value for HEIF images:</p><p><b>1</b>: low quality (high "
"compression and small file size)<br><b>50</b>: medium quality<br><b>75</b>: "
"good quality (default)<br><b>100</b>: high quality (no compression and large "
"file size)</p><p><b>Note: HEIF is not a lossless image compression format "
"when you use this setting.</b></p>"
msgstr ""
"<p>An luach cáilíochta d'íomhánna HEIF:</p><p><b>1</b>: caighdeán íseal "
"(comhbhrú ard agus méid comhaid beag)<br><b>50</b>: caighdeán "
"meánach<br><b>75</b>: caighdeán maith (réamhshocraithe)<br><b>100</b>: "
"caighdeán ard (gan comhbhrú agus méid comhaid mór)</p><p><b>Tabhair faoi "
"deara: Ní formáid comhbhrú íomhá gan chailliúint é HEIF nuair a úsáideann tú "
"an socrú seo.</b></p>"

#: core/dplugins/dimg/heif/dimgheifplugin.cpp:43
