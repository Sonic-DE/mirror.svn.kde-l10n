#. (itstool) path: component/name
#: org.kde.kget.appdata.xml:9
msgid "KGet"
msgstr "KGet"

#. (itstool) path: component/summary
#: org.kde.kget.appdata.xml:10
msgid "Download manager"
msgstr "Download-Verwaltung"

#. (itstool) path: description/p
#: org.kde.kget.appdata.xml:12
msgid "KGet is a versatile and user-friendly download manager."
msgstr ""
"Ein vielseitiges und einfach zu benutzendes Verwaltungsprogramm zum "
"Herunterladen."

#. (itstool) path: description/p
#: org.kde.kget.appdata.xml:15
msgid "Features:"
msgstr "Funktionen:"

#. (itstool) path: ul/li
#: org.kde.kget.appdata.xml:17
msgid "Downloading files from FTP and HTTP(S) sources."
msgstr "Herunterladen von Dateien aus FTP- und HTTP(s)-Adressen."

#. (itstool) path: ul/li
#: org.kde.kget.appdata.xml:18
msgid ""
"Pausing and resuming of downloading files, as well as the ability to restart "
"a download."
msgstr ""
"Anhalten und Fortsetzen des Herunterladens von Dateien, außerdem gibt es "
"auch die Möglichkeit, das Herunterladen neu zu starten."

#. (itstool) path: ul/li
#: org.kde.kget.appdata.xml:19
msgid "Tells lots of information about current and pending downloads."
msgstr "Viele Informationen über aktuelle und anstehende Downloads."

#. (itstool) path: ul/li
#: org.kde.kget.appdata.xml:20
msgid "Embedding into system tray."
msgstr "Eingebettet in den Systemabschnitt der Kontrollleiste."

#. (itstool) path: ul/li
#: org.kde.kget.appdata.xml:21
msgid "Integration with the Konqueror web browser."
msgstr "Integration mit dem Internet-Browser Konqueror."

#. (itstool) path: ul/li
#: org.kde.kget.appdata.xml:22
msgid ""
"Metalink support which contain multiple URLs for downloads, along with "
"checksums and other information."
msgstr ""
"Unterstützung für Metalinks, die mehrere Adressen (Urls) zum Herunterladen "
"enthalten, zusammen mit Prüfsummen und weiteren Informationen."

#. (itstool) path: screenshot/caption
#: org.kde.kget.appdata.xml:31
msgid "Downloading files with KGet"
msgstr "Herunterladen von Dateien mit KGet"
