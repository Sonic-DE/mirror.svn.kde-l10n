#. (itstool) path: component/name
#: org.kde.pimdataexporter.appdata.xml:10
msgid "PIM Data Exporter"
msgstr "PIM-Daten-Export"

#. (itstool) path: component/summary
#: org.kde.pimdataexporter.appdata.xml:11
msgid "Saves all data from PIM apps and restore them in other systems."
msgstr ""
"Speichert alle Daten von PIM-Anwendungen, um sie später in anderen Systemen "
"wiederherzustellen."

#. (itstool) path: description/p
#: org.kde.pimdataexporter.appdata.xml:17
msgid "PIM Data Exporter exports and imports PIM settings"
msgstr ""
"Mit PIM-Daten-Export können Sie PIM-Einstellungen exportieren oder "
"importieren."

