#. (itstool) path: component/name
#: org.kde.kgraphviewer.appdata.xml:9
msgid "KGraphViewer"
msgstr "KGraphViewer"

#. (itstool) path: component/summary
#: org.kde.kgraphviewer.appdata.xml:10
msgid "A Graphviz DOT graph viewer"
msgstr "Ein Anzeigeprogramm für Graphviz-Dot-Diagramme"

#. (itstool) path: description/p
#: org.kde.kgraphviewer.appdata.xml:12
msgid ""
"KGraphViewer is a Graphviz DOT graph file viewer, aimed to replace the other "
"outdated Graphviz tools. Graphs are commonly used in scientific domains and "
"particularly in computer science."
msgstr ""
"KGraphViewer ist Anzeigeprogramm für Graphviz-Dot-Diagrammdateien und soll "
"die anderen veralteten Graphviz-Programme ersetzen. Graphen werden in der "
"Wissenschaft, insbesondere in der Informatik, verwendet."

#. (itstool) path: description/p
#: org.kde.kgraphviewer.appdata.xml:16
msgid "Features:"
msgstr "Funktionen:"

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:18
msgid "Zooming"
msgstr "Größenänderung der Ansichten"

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:19
msgid "Threaded loading of several graphs in tabs"
msgstr "Gleichzeitiges Laden mehrerer Graphen in Unterfenstern"

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:20
msgid "Saving of the recent files list"
msgstr "Speicherung der Liste der zuletzt geöffneten Dateien"

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:21
msgid "Manual reload of files"
msgstr "Manuelles neu laden von Dateien"

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:22
msgid "Display of a bird-eye view of the graph"
msgstr "Anzeige eines Übersichtsfenster für den Graphen"

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:23
msgid "Moving of the graph by dragging"
msgstr "Verschieben des Graphen durch ziehen"

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:24
msgid "Full featured printing"
msgstr "Drucken mit vielen Optionen"

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:25
msgid "Perfect drawing of all graphviz example graphs"
msgstr "perfekte Darstellung aller Graphviz-Beispieldiagramme"

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:26
msgid "Automatically choose dot for directed graphs and neato for undirected"
msgstr ""
"Automatische Wahl von „dot“ für gerichtete und „neato“ für ungerichtete "
"Graphen"

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:27
msgid ""
"Possibility to use an arbitrary layout algorithm as soon as it produces xdot "
"format"
msgstr ""
"Es kann ein beliebiger Layout-Algorithmus verwendet werden, sofern die "
"Ausgabe im Format „xdot“ möglich ist."

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:28
msgid ""
"Automatic reloading with user confirmation of (externally) modified files "
"(configurable)"
msgstr ""
"Erneutes Laden von (extern) geänderten Dateien - automatisch mit Bestätigung "
"durch den Benutzer (einstellbar)"

#. (itstool) path: ul/li
#: org.kde.kgraphviewer.appdata.xml:29
msgid "Open new instances as new tabs in the old one (configurable)"
msgstr ""
"Öffnen neuer Instanzen als Unterfenster im aktuellen Unterfenster "
"(einstellbar)"
