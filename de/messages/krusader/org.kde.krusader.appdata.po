msgid "Krusader"
msgstr "Krusader"

#. (itstool) path: component/summary
#: org.kde.krusader.appdata.xml:8
msgid "File Manager"
msgstr "Dateiverwaltung"

#. (itstool) path: description/p
#: org.kde.krusader.appdata.xml:13
msgid ""
"Krusader is an advanced twin panel (commander style) file manager for KDE "
"Plasma and other desktops in the *nix world"
msgstr ""
"Krusader ist ein fortgeschrittenes Dateiverwaltungsprogramm mit einer "
"zweispaltigen Ansicht für KDE-Plasma und andere Arbeitsfläche unter Unix-"
"Systemen"

#. (itstool) path: description/p
#: org.kde.krusader.appdata.xml:14
msgid "Features:"
msgstr "Funktionen:"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:16
msgid "Extensive archive handling"
msgstr "Umfangreiche Archiv-Verwaltung"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:17
msgid "Mounted filesystem support"
msgstr "Unterstützung für eingebundene Dateisysteme"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:18
msgid "FTP support"
msgstr "Unterstützung für FTP"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:19
msgid "Advanced search module"
msgstr "Erweitertes Suchmodul"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:20
msgid "Internal viewer/editor"
msgstr "Interner Betrachter und Editor"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:21
msgid "Folder synchronisation"
msgstr "Abgleich von Ordnern"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:22
msgid "File content comparisons"
msgstr "Vergleich von Dateiinhalten"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:23
msgid "Powerful batch renaming"
msgstr "Leistungsfähige Stapelverarbeitungsfunktion zum Umbenennen"

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:24
msgid ""
"Support for a wide variety of archive formats and can handle other KIO "
"slaves such as smb or fish."
msgstr ""
"Unterstützung für eine Vielzahl von Archivformaten und Verarbeitung anderer "
"Ein-/Ausgabemodule wie smb oder fish."

#. (itstool) path: ul/li
#: org.kde.krusader.appdata.xml:25
msgid "Completely customizable and very user friendly"
msgstr ""
"Krusader kann in großem Umfang angepasst werden und ist sehr "
"benutzerfreundlich"

