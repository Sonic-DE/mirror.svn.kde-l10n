#. (itstool) path: component/name
#: org.kde.kdiff3.appdata.xml:13
msgid "KDiff3"
msgstr "KDiff3"

#. (itstool) path: component/summary
#: org.kde.kdiff3.appdata.xml:14
msgid "A file and folder comparison and merge tool"
msgstr "Programm zum Vergleichen und Zusammenführen von Dateien und Ordnern"

#. (itstool) path: description/p
#: org.kde.kdiff3.appdata.xml:17
msgid "KDiff3 is a file and folder diff and merge tool which"
msgstr ""
"KDiff3 ist ein Programm zum Anzeigen von Unterschieden und zum "
"Zusammenführen von Dateien und Ordnern."

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:19
msgid "compares and merges two or three text input files or folders,"
msgstr ""
"vergleicht zwei oder drei Textdateien bzw. Ordner und führt sie zusammen,"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:20
msgid "shows the differences line by line and character by character(!),"
msgstr "kann Unterschiede zeilenweise und sogar Zeichen für Zeichen anzeigen,"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:21
msgid "provides an automatic merge-facility,"
msgstr "hat eine Funktion zum automatischen Zusammenführen,"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:22
msgid "has an editor for comfortable solving of merge-conflicts,"
msgstr ""
"enthält einen speziellen komfortablen Editor zum Auflösen von Konflikten "
"beim Zusammenführen,"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:23
msgid "provides network transparency via KIO,"
msgstr "ist mit Hilfe von KIO Netzwerktransparent,"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:24
msgid "has options to highlight or hide changes in white-space or comments,"
msgstr ""
"kann Unterschiede in Leerraum-Zeichen oder Kommentaren besonders hervorheben "
"oder ausblenden,"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:25
msgid "supports Unicode, UTF-8 and other file encodings,"
msgstr "unterstützt Unicode, UTF-8 und weitere Dateikodierungen,"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:26
msgid "prints differences,"
msgstr "druckt Abweichungen,"

#. (itstool) path: ul/li
#: org.kde.kdiff3.appdata.xml:27
msgid "supports version control keyword and history merging."
msgstr ""
"unterstützt Schlüsselwörter für Versionsverwaltung und Verlauf-"
"Zusammenführung."
