#. (itstool) path: component/name
#: org.kde.knights.appdata.xml:9
msgid "KNights"
msgstr "KNights"

#. (itstool) path: component/summary
#: org.kde.knights.appdata.xml:10
msgid "Chess game"
msgstr "Schachspiel"

#. (itstool) path: description/p
#: org.kde.knights.appdata.xml:12
msgid ""
"KNights is a chess game. As a player, your goal is to defeat your opponent "
"by checkmating their king."
msgstr ""
"KNights ist ein Schachspiel, bei dem der Gegner durch Matt setzen des Königs "
"besiegt wird."

#. (itstool) path: description/p
#: org.kde.knights.appdata.xml:15
msgid "Features:"
msgstr "Funktionen:"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:17
msgid "Local play between two players on the same computer"
msgstr "Lokale Spiele zwischen zwei Spielern auf demselben Rechner"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:18
msgid "Play against any computer program that supports the XBoard protocol"
msgstr ""
"Spiele gegen jedes Rechnerprogramm, das das XBoard-Protokoll unterstützt"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:19
msgid "Play on the Free Internet Chess Server (FICS)"
msgstr "Spielen auf dem Free Internet Chess Server (FICS)"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:20
msgid "Watching two computer engines play against each other"
msgstr "Anzeige eines Spiels zweier Schach-Module gegeneinander"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:21
msgid "Support for legal move checking"
msgstr "Überprüfung auf gültige Spielzüge"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:22
msgid "Markers for possible moves, opponent’s last move and sources of check"
msgstr ""
"Markierungen für mögliche Züge, den letzten Zug des Gegners und Spielzüge "
"für Schachmatt"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:23
msgid "Board borders and site notations"
msgstr "Verschiedene Ränder des Schachbretts und Notationen der Schachseiten"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:24
msgid "Complete time control, with Plasma-styled clocks"
msgstr "Vollständige Zeitüberwachung mit Uhren im Plasma-Design"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:25
msgid ""
"Several themes, with the possibility of downloading new ones from within the "
"program"
msgstr ""
"Verschiedene Designs sind in KNights bereits enthalten, weitere Designs "
"können aus dem Programm heraus heruntergeladen werden"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:26
msgid "Animated moves (configurable)"
msgstr "Animierte Züge, einstellbar"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:27
msgid ""
"Views for playing on a chess server, including a seek graph, text console, "
"and chat widget"
msgstr ""
"Ansichten zum Spielen auf einem Schachserver, inklusive Suchgraphen,  "
"Textkonsole und Chatmöglichkeit"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:28
msgid "Option to undo and redo moves"
msgstr "Option zum Zug zurücknehmen und wiederherstellen"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:29
msgid "Graphic interface for making and receiving offers from remote players"
msgstr ""
"Grafische Schnittstelle um Angebote von entfernten Spielen zu senden und zu "
"erhalten"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:30
msgid ""
"Support for the UCI protocol (used by Stockfish, Chessbase, and many others)"
msgstr ""
"Unterstützung für das UCI-Protokoll, das von Stockfish, Chessbase und "
"anderen verwendet wird"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:31
msgid "Support for saving and loading Portable game notation (PGN) files"
msgstr ""
"Laden und speichern von Dateien im Format Portable Spielnotation (*.pgn)"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:32
msgid "Speak opponent’s moves"
msgstr "Züge des Gegners vorlesen"

#. (itstool) path: ul/li
#: org.kde.knights.appdata.xml:33
msgid "Ability to control the program via a D-Bus interface"
msgstr "Das Programm kann über eine D-Bus-Schnittstelle gesteuert werden"

