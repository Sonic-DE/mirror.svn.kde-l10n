#: plasma_workspace.notifyrc:3
msgctxt "Comment"
msgid "System Notifications"
msgstr "Systembenachrichtigungen"

#: plasma_workspace.notifyrc:43
msgctxt "Name"
msgid "Trash: Emptied"
msgstr "Papierkorb: geleert"

#: plasma_workspace.notifyrc:98
msgctxt "Comment"
msgid "The trash has been emptied"
msgstr "Der Papierkorb ist geleert worden"

#: plasma_workspace.notifyrc:157
msgctxt "Name"
msgid "Textcompletion: Rotation"
msgstr "Textvervollständigung: Drehung"

#: plasma_workspace.notifyrc:211
msgctxt "Comment"
msgid "The end of the list of matches has been reached"
msgstr "Das Ende der Liste der Übereinstimmungen ist erreicht worden"

#: plasma_workspace.notifyrc:269
msgctxt "Name"
msgid "Textcompletion: No Match"
msgstr "Textvervollständigung: keine Übereinstimmung"

#: plasma_workspace.notifyrc:323
msgctxt "Comment"
msgid "No matching completion was found"
msgstr "Es ist keine mögliche Vervollständigung gefunden worden"

#: plasma_workspace.notifyrc:381
msgctxt "Name"
msgid "Textcompletion: Partial Match"
msgstr "Textvervollständigung: teilweise Übereinstimmung"

#: plasma_workspace.notifyrc:435
msgctxt "Comment"
msgid "There is more than one possible match"
msgstr "Es gibt mehr als eine mögliche Übereinstimmung"

#: plasma_workspace.notifyrc:494
msgctxt "Name"
msgid "Fatal Error"
msgstr "Schwerer Fehler"

#: plasma_workspace.notifyrc:550
msgctxt "Comment"
msgid "There was a serious error causing the program to exit"
msgstr ""
"Es ist ein schwerer Fehler aufgetreten, woraufhin das Programm beendet wurde."

#: plasma_workspace.notifyrc:609
msgctxt "Name"
msgid "Notification"
msgstr "Benachrichtigung"

#: plasma_workspace.notifyrc:665
msgctxt "Comment"
msgid "Something special happened in the program"
msgstr "Im Programm ist ein besonderes Ereignis eingetreten"

#: plasma_workspace.notifyrc:723
msgctxt "Name"
msgid "Warning"
msgstr "Warnung"

#: plasma_workspace.notifyrc:779
msgctxt "Comment"
msgid "There was an error in the program which may cause problems"
msgstr ""
"Im Programm ist ein Fehler aufgetreten, der Probleme verursachen könnte"

#: plasma_workspace.notifyrc:838
msgctxt "Name"
msgid "Catastrophe"
msgstr "Katastrophe"

#: plasma_workspace.notifyrc:893
msgctxt "Comment"
msgid "A very serious error occurred, at least causing the program to exit"
msgstr ""
"Ein sehr schwerer Fehler ist aufgetreten, der wenigstens das Programm zum "
"Beenden bringt"

#: plasma_workspace.notifyrc:951
msgctxt "Name"
msgid "Application Crash"
msgstr "Absturz einer Anwendung"

#: plasma_workspace.notifyrc:1003
msgctxt "Comment"
msgid "An application just closed unexpectedly"
msgstr "Eine Anwendung wurde unerwartet beendet"

#: plasma_workspace.notifyrc:1057
msgctxt "Name"
msgid "Login"
msgstr "Anmeldung"

#: plasma_workspace.notifyrc:1112
msgctxt "Comment"
msgid "A new session is starting"
msgstr "Eine neue Sitzung wurde gestartet"

#: plasma_workspace.notifyrc:1170
msgctxt "Name"
msgid "Logout"
msgstr "Abmeldung"

#: plasma_workspace.notifyrc:1225
msgctxt "Comment"
msgid "Session is exiting"
msgstr "Die Sitzung wird beendet"

#: plasma_workspace.notifyrc:1284
msgctxt "Name"
msgid "Logout Canceled"
msgstr "Abmeldung abgebrochen"

#: plasma_workspace.notifyrc:1339
msgctxt "Comment"
msgid "Plasma logout was canceled"
msgstr "Der Abmeldevorgang aus Plasma ist abgebrochen worden"

#: plasma_workspace.notifyrc:1397
msgctxt "Name"
msgid "Print Error"
msgstr "Druckfehler"

#: plasma_workspace.notifyrc:1453
msgctxt "Comment"
msgid "A print error has occurred"
msgstr "Ein Fehler beim Drucken ist aufgetreten"

#: plasma_workspace.notifyrc:1512
msgctxt "Name"
msgid "Information Message"
msgstr "Informationsmeldung"

#: plasma_workspace.notifyrc:1568
msgctxt "Comment"
msgid "An information message is being shown"
msgstr "Eine Informationsmeldung wird angezeigt"

#: plasma_workspace.notifyrc:1627
msgctxt "Name"
msgid "Warning Message"
msgstr "Warnmeldung"

#: plasma_workspace.notifyrc:1683
msgctxt "Comment"
msgid "A warning message is being shown"
msgstr "Eine Warnmeldung wird angezeigt"

#: plasma_workspace.notifyrc:1742
msgctxt "Name"
msgid "Critical Message"
msgstr "Kritische Meldung"

#: plasma_workspace.notifyrc:1798
msgctxt "Comment"
msgid "A critical message is being shown"
msgstr "Eine kritische Fehlermeldung wird angezeigt"

#: plasma_workspace.notifyrc:1857
msgctxt "Name"
msgid "Question"
msgstr "Frage"

#: plasma_workspace.notifyrc:1913
msgctxt "Comment"
msgid "A question is being asked"
msgstr "Eine Frage wird gestellt"

#: plasma_workspace.notifyrc:1973
msgctxt "Name"
msgid "Beep"
msgstr "Signalton"

#: plasma_workspace.notifyrc:2028
msgctxt "Comment"
msgid "Sound bell"
msgstr "Signalton"

#: plasma_workspace.notifyrc:2086
msgctxt "Name"
msgid "Widget failed to install"
msgstr "Installation des Miniprogramms fehlgeschlagen"

#: plasma_workspace.notifyrc:2138
msgctxt "Comment"
msgid "A widget could not be installed"
msgstr "Ein Miniprogramm kann nicht installiert werden"

#: plasma_workspace.notifyrc:2193
msgctxt "Name"
msgid "Widget deleted"
msgstr "Miniprogramm wurde gelöscht"

#: plasma_workspace.notifyrc:2247
msgctxt "Comment"
msgid "A widget has been deleted"
msgstr "Ein Miniprogramm wurde gelöscht"

#: plasma_workspace.notifyrc:2304
msgctxt "Name"
msgid "Device plugged in"
msgstr "Gerät angeschlossen"

#: plasma_workspace.notifyrc:2344
msgctxt "Comment"
msgid "A device was plugged in"
msgstr "Ein Gerät ist angeschlossen worden"

#: plasma_workspace.notifyrc:2389
msgctxt "Name"
msgid "Device unplugged"
msgstr "Gerät vom Rechner getrennt"

#: plasma_workspace.notifyrc:2429
msgctxt "Comment"
msgid "A device was unplugged"
msgstr "Ein Gerät ist vom Rechner getrennt worden"

#~ msgctxt "Comment"
#~ msgid "Plasma Workspace"
#~ msgstr "KDE-Plasma-Arbeitsbereich"
