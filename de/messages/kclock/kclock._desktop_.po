msgstr "Eine einfache Kirigami-Uhr."

#: org.kde.kclock.desktop.in:54
msgctxt "Comment"
msgid "Set alarms and timers, use a stopwatch, and manage world clocks"
msgstr ""
"Wecker und Timer einstellen, eine Stoppuhr verwenden und Weltzeituhren "
"verwalten"

