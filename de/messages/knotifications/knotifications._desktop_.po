#: src/android_defaults.notifyrc:2
msgctxt "Name"
msgid "Fatal Error"
msgstr "Schwerer Fehler"

#: src/android_defaults.notifyrc:61
msgctxt "Comment"
msgid "There was a serious error causing the program to exit"
msgstr ""
"Es ist ein schwerer Fehler aufgetreten, woraufhin das Programm beendet wurde."

#: src/android_defaults.notifyrc:122
msgctxt "Name"
msgid "Notification"
msgstr "Benachrichtigung"

#: src/android_defaults.notifyrc:180
msgctxt "Comment"
msgid "Something special happened in the program"
msgstr "Im Programm ist ein besonderes Ereignis eingetreten"

#: src/android_defaults.notifyrc:240
msgctxt "Name"
msgid "Warning"
msgstr "Warnung"

#: src/android_defaults.notifyrc:298
msgctxt "Comment"
msgid "There was an error in the program which may cause problems"
msgstr ""
"Im Programm ist ein Fehler aufgetreten, der Probleme verursachen könnte"

#: src/android_defaults.notifyrc:358
msgctxt "Name"
msgid "Catastrophe"
msgstr "Katastrophe"

#: src/android_defaults.notifyrc:415
msgctxt "Comment"
msgid "A very serious error occurred, at least causing the program to exit"
msgstr ""
"Ein sehr schwerer Fehler ist aufgetreten, der wenigstens das Programm zum "
"Beenden bringt"

