#. (itstool) path: component/name
#: org.kde.gwenview.appdata.xml:9
msgid "Gwenview"
msgstr "Gwenview"

#. (itstool) path: component/summary
#: org.kde.gwenview.appdata.xml:10
msgid "Image Viewer"
msgstr "Bildbetrachter"

#. (itstool) path: description/p
#: org.kde.gwenview.appdata.xml:12
msgid ""
"Gwenview is a fast and easy to use image viewer by KDE, ideal for browsing "
"and displaying a collection of images."
msgstr ""
"Gwenview ist ein schneller und einfach zu verwendender Bildbetrachter "
"besonders für die Anzeige einer Sammlung von Bildern."

#. (itstool) path: description/p
#: org.kde.gwenview.appdata.xml:15
msgid "Features:"
msgstr "Funktionen:"

#. (itstool) path: ul/li
#: org.kde.gwenview.appdata.xml:17
msgid ""
"Simple image editing: rotate, crop, resize, mirror, flip, reduce red eye, "
"and adjust brightness, contrast, or gamma"
msgstr ""
"Einfache Bildbearbeitung: Drehen, Zuschneiden, Größenänderung, Spiegeln, "
"Wenden, Rote-Augen-Korrektur, Anpassen von Helligkeit, Kontrast oder Gamma"

#. (itstool) path: ul/li
#: org.kde.gwenview.appdata.xml:18
msgid ""
"Annotate and mark up images with arrows, shapes, text boxes, image stamps, "
"and more"
msgstr ""
"Versehen Sie Bilder mit Pfeilen, Formen, Textfeldern, Bildstempeln und mehr"

#. (itstool) path: ul/li
#: org.kde.gwenview.appdata.xml:19
msgid "Basic file management actions such as copy, move, delete, and others"
msgstr ""
"Grundlegende Dateiverwaltungsaktionen wie Kopieren, Verschieben, Löschen und "
"weitere"

#. (itstool) path: screenshot/caption
#: org.kde.gwenview.appdata.xml:29
msgid "Main application window displaying an image and controls on the left"
msgstr ""
"Das Hauptfenster der Anwendung. Ein Bild wird angezeigt, die Bedienelemente "
"befinden sich links."

#. (itstool) path: screenshot/caption
#: org.kde.gwenview.appdata.xml:33
msgid "Use Gwenview to manage your image collection"
msgstr "Verwenden Sie Gwenview zur Verwaltung Ihrer Bildersammlung"

#~ msgid ""
#~ "Functions both as a standalone application and an embedded viewer in the "
#~ "Konqueror web browser"
#~ msgstr ""
#~ "Funktioniert sowohl als eigenständiges Programm als auch als "
#~ "eingebetteter Betrachter im Webbrowser Konqueror."

#~ msgid ""
#~ "Supports simple image manipulations: rotate, mirror, flip, and resize"
#~ msgstr ""
#~ "Unterstützt einfache Bildbearbeitung wie Drehen, Spiegeln waagerecht und "
#~ "senkrecht und Größenänderung"

#~ msgid ""
#~ "Gwenview displaying an image, with additional metadata shown in the "
#~ "sidebar"
#~ msgstr ""
#~ "Gwenview zeigt ein Bild mit zusätzlichen Metadaten in der Seitenleiste"

#~ msgid "Can be extended using KIPI plugins."
#~ msgstr "Kann durch KIPI-Module erweitert werden."
