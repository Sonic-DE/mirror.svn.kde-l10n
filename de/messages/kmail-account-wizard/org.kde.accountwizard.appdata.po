#. (itstool) path: component/name
#: org.kde.accountwizard.appdata.xml:9
msgid "Account Wizard"
msgstr "Zugangsassistent"

#. (itstool) path: component/summary
#: org.kde.accountwizard.appdata.xml:10
msgid "Configure accounts"
msgstr "Postfächer einrichten"

#. (itstool) path: description/p
#: org.kde.accountwizard.appdata.xml:12
msgid ""
"Accountwizard allows to edit, create, delete accounts. Accountwizard "
"supports IMAP/POP3/Kolab account type. Account information can be found by "
"using ispd service."
msgstr ""
"Mit dem Zugangsassistenten können Postfächer bearbeitet, erstellt und "
"gelöscht werden. Der Zugangsassistent unterstützt IMAP-, POP- und Kolab-"
"Postfächer. Die Postfachinformationen sind mit dem ispd-Dienst abrufbar."
