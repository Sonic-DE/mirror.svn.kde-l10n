#: modules/account/metadata.json
msgctxt "Description"
msgid "Allow the user to set the account name."
msgstr "Dem Benutzer erlauben, den Kontonamen festzulegen."

#: modules/cellular/metadata.json
msgctxt "Description"
msgid "Allow the user to configure the cellular network."
msgstr "Dem Benutzer erlauben, ein Mobilfunknetz einzurichten."

#: modules/finished/metadata.json
msgctxt "Description"
msgid ""
"Shown when the initial system setup is completed, and the user can commit "
"the changes."
msgstr ""
"Wird angezeigt, wenn die Ersteinrichtung des Systems abgeschlossen ist und "
"der Benutzer die Änderungen speichern kann."

#: modules/hostname/metadata.json
msgctxt "Description"
msgid "Allow the user to set the system hostname."
msgstr "Dem Benutzer erlauben, den Rechnernamen des Systems festzulegen."

#: modules/keyboard/metadata.json
msgctxt "Description"
msgid "Allow the user to choose the keyboard layout."
msgstr "Dem Benutzer erlauben, die Tastaturbelegung auszuwählen."

#: modules/language/metadata.json
msgctxt "Description"
msgid "Allow the user to set the system language."
msgstr "Dem Benutzer erlauben, die Systemsprache festzulegen."

#: modules/prepare/metadata.json
msgctxt "Description"
msgid "Allows the user to configure the environment before using it."
msgstr "Erlaubt dem Benutzer, die Umgebung vor der Verwendung einzurichten."

#: modules/time/metadata.json
msgctxt "Description"
msgid "Allow the user to set the timezone."
msgstr "Dem Benutzer erlauben, die Zeitzone festzulegen."

#: modules/wifi/metadata.json
msgctxt "Description"
msgid "Allow the user to connect to a Wi-Fi network."
msgstr "Dem Benutzer erlauben, eine Verbindung mit einem WLAN herzustellen."

