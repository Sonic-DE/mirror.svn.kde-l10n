#: files/plasma-setup.desktop.in:9 src/auth/org.kde.plasmasetup.actions:8
msgctxt "Name"
msgid "Plasma Setup"
msgstr "Plasma Setup"

#: files/plasma-setup.desktop.in:39
msgctxt "Comment"
msgid "Run the initial system setup for KDE"
msgstr "Die Ersteinrichtung des Systems von KDE starten"

#: src/auth/org.kde.plasmasetup.actions:42
msgctxt "Name"
msgid "Create User"
msgstr "Benutzer erstellen"

#: src/auth/org.kde.plasmasetup.actions:71
msgctxt "Description"
msgid "Create the initial user account"
msgstr "Das erste Benutzerkonto erstellen"

#: src/auth/org.kde.plasmasetup.actions:103
msgctxt "Name"
msgid "Create Completion Flag File"
msgstr "Datei als Nachweis der Fertigstellung erstellen"

#: src/auth/org.kde.plasmasetup.actions:131
msgctxt "Description"
msgid "Write the /etc/plasma-setup-done marker to prevent rerunning setup"
msgstr ""
"Den „/etc/plasma-setup-done“-Marker schreiben, um das Wiederholen der "
"Einrichtung zu verhindern"

#: src/auth/org.kde.plasmasetup.actions:162
msgctxt "Name"
msgid "Create New User Autostart Hook"
msgstr "„Neuer Benutzer“-Autostart-Hook erstellen"

#: src/auth/org.kde.plasmasetup.actions:191
msgctxt "Description"
msgid "Create an autostart hook for the newly created user"
msgstr "Einen Autostart-Hook für den neuen Benutzer erstellen"

#: src/auth/org.kde.plasmasetup.actions:223
msgctxt "Name"
msgid "Remove Autologin"
msgstr "Automatische Anmeldung entfernen"

#: src/auth/org.kde.plasmasetup.actions:252
msgctxt "Description"
msgid "Remove Display Manager autologin configuration"
msgstr ""
"Einstellung für die automatische Anmeldung des Display-Managers entfernen"

#: src/auth/org.kde.plasmasetup.actions:282
msgctxt "Name"
msgid "Set New User Global Theme"
msgstr "Globales Design für den neuen Benutzer festlegen"

#: src/auth/org.kde.plasmasetup.actions:311
msgctxt "Description"
msgid "Set the global theme for the new user"
msgstr "Das globale Design für den neuen Benutzer festlegen"

#: src/auth/org.kde.plasmasetup.actions:343
msgctxt "Name"
msgid "Set New User Display Scaling"
msgstr "Anzeigeskalierung für den neuen Benutzer festlegen"

#: src/auth/org.kde.plasmasetup.actions:372
msgctxt "Description"
msgid "Set display scaling for the new user"
msgstr "Die Anzeigeskalierung für den neuen Benutzer festlegen"

#: src/auth/org.kde.plasmasetup.actions:404
msgctxt "Name"
msgid "Set New User Home Directory Ownership"
msgstr ""
"Die Eigentumsrechte des persönlichen Ordners für den neuen Benutzer festlegen"

#: src/auth/org.kde.plasmasetup.actions:433
msgctxt "Description"
msgid "Set ownership of the new users home directory to the newly created user"
msgstr ""
"Die Eigentumsrechte des persönlichen Ordners werden auf den neu erstellten "
"Benutzer übertragen"

#: src/auth/org.kde.plasmasetup.actions:465
msgctxt "Name"
msgid "Set New User Temporary Autologin"
msgstr "Automatische Anmeldung des neuen Benutzers temporär aktivieren"

#: src/auth/org.kde.plasmasetup.actions:494
msgctxt "Description"
msgid ""
"Set display manager temporary autologin configuration for the newly created "
"user"
msgstr ""
"Automatische Anmeldung des Display-Managers für den neu erstellen Benutzer "
"temporär festlegen"

#~ msgctxt "Name"
#~ msgid "Disable Systemd Unit"
#~ msgstr "Systemd-Unit deaktivieren"

#~ msgctxt "Description"
#~ msgid "Disable the systemd unit for Plasma Setup"
#~ msgstr "Die systemd-Unit für Plasma Setup deaktivieren"

#~ msgctxt "Name"
#~ msgid "KDE Initial System Setup"
#~ msgstr "KDE – Ersteinrichtung des Systems"
