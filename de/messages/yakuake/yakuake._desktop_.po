#: data/org.kde.yakuake.desktop:2
msgctxt "Name"
msgid "Yakuake"
msgstr "Yakuake"

#: data/org.kde.yakuake.desktop:65
msgctxt "GenericName"
msgid "Drop-down Terminal"
msgstr "Aufklapp-Terminal"

#: data/org.kde.yakuake.desktop:128
msgctxt "Comment"
msgid "A drop-down terminal emulator based on KDE Konsole technology."
msgstr "Ein Aufklapp-Terminalemulator basierend auf der KDE-Konsole."

#: data/yakuake.notifyrc:4
msgctxt "Comment"
msgid "Yakuake"
msgstr "Yakuake"

#: data/yakuake.notifyrc:63
msgctxt "Name"
msgid "Silence detected"
msgstr "Keine Aktivität festgestellt"

#: data/yakuake.notifyrc:118
msgctxt "Comment"
msgid "Silence detected in a monitored terminal or session"
msgstr ""
"In einem überwachten Terminal oder einer überwachten Sitzung wird keine "
"Aktivität festgestellt"

#: data/yakuake.notifyrc:175
msgctxt "Name"
msgid "Activity detected"
msgstr "Aktivität festgestellt"

#: data/yakuake.notifyrc:230
msgctxt "Comment"
msgid "Activity detected in a monitored terminal or session"
msgstr ""
"In einem überwachten Terminal oder einer überwachten Sitzung wird Aktivität "
"festgestellt"

#: data/yakuake.notifyrc:287
msgctxt "Name"
msgid "Bell in Visible Session"
msgstr "Signalton in sichtbarer Sitzung"

#: data/yakuake.notifyrc:344
msgctxt "Comment"
msgid "Bell emitted within a visible session"
msgstr "Signalton, der in einer sichtbaren Sitzung ertönt"

#: data/yakuake.notifyrc:404
msgctxt "Name"
msgid "Bell in Non-Visible Session"
msgstr "Signalton in nicht sichtbarer Sitzung"

#: data/yakuake.notifyrc:461
msgctxt "Comment"
msgid "Bell emitted within a non-visible session"
msgstr "Signalton, der in einer nicht sichtbaren Sitzung ertönt"

