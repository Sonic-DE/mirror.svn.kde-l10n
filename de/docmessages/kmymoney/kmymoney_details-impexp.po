#. Tag: title
#: details-impexp.docbook:284 details-impexp.docbook:399
#, no-c-format
msgid "Online Quotes"
msgstr "Online-Kursnotizen"

#. Tag: para
#: details-impexp.docbook:285
#, fuzzy, no-c-format
#| msgid ""
#| "For obtaining online price and currency rate quotations, &gnucash; uses a "
#| "package called <literal>Finance::Quote</literal>. Recent versions of "
