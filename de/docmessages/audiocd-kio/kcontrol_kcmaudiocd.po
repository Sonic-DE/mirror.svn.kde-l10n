#. Tag: title
#: index.docbook:43
#, no-c-format
msgid "The General Tab"
msgstr "Die Karteikarte Allgemein"

#. Tag: screeninfo
#: index.docbook:45
#, no-c-format
msgid "<screeninfo>The <guilabel>General</guilabel> tab</screeninfo>"
