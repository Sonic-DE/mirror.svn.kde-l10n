msgstr "sum(k*x : x=0..10)"

#. Tag: userinput
#: index.docbook:262
#, no-c-format
msgid "f:=p->p*k"
msgstr "f:=p->p*k"

#. Tag: userinput
#: index.docbook:263
#, no-c-format
msgid "f(pi)"
msgstr "f(pi)"

