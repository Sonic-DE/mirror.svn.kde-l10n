"<guimenuitem>Blame range</guimenuitem>"
msgstr ""
"<guimenu>Subversion</guimenu> <guisubmenu>Allgemein</guisubmenu> "
"<guimenuitem>Bereich zum Nachforschen</guimenuitem>"

