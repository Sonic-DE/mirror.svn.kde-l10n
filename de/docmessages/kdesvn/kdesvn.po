"shortcut> <guimenu>Subversion</guimenu> <guisubmenu>Working copy</"
"guisubmenu> <guimenuitem>Diff against HEAD</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;<keycap>H</keycap></keycombo></"
"shortcut> <guimenu>Subversion</guimenu> <guisubmenu>Arbeitskopie</"
"guisubmenu> <guimenuitem>Unterschied zu HEAD</guimenuitem>"

#. Tag: para
#: index.docbook:1990
#, no-c-format
msgid "Diff's current working copy against head of repository."
msgstr "Zeigt die Unterschiede der Arbeitskopie zu HEAD im Projektarchiv."

#. Tag: menuchoice
