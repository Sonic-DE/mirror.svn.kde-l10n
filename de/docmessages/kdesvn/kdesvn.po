msgstr "Öffnet ein Fenster mit einer neuen Instanz von &kdesvn;"

#. Tag: menuchoice
#: index.docbook:1757
#, no-c-format
msgid "<guimenu>File</guimenu> <guimenuitem>Subversion Admin</guimenuitem>"
msgstr "<guimenu>Datei</guimenu> <guimenuitem>Subversion-Admin</guimenuitem>"

#. Tag: para
#: index.docbook:1761
#, no-c-format
