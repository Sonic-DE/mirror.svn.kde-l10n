"<guimenuitem>Move</guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\"><keycap>F2</keycap></keycombo></"
"shortcut> <guimenu>Subversion</guimenu> <guisubmenu>Allgemein</guisubmenu> "
"<guimenuitem>Verschieben</guimenuitem>"

#. Tag: para
#: index.docbook:1872
#, no-c-format
