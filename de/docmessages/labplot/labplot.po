#. Tag: title
#: index.docbook:862
#, no-c-format
msgid "The CAS Worksheet Menu"
msgstr "Das Menü CAS-Arbeitsblatt"

#. Tag: para
#: index.docbook:863
#, no-c-format
msgid ""
"This menu contains all the items that can also be found in the context menu "
"(right mouse) of a CAS worksheet. The menu is only available when a "
"worksheet object is selected on the <guilabel>Project Explorer</guilabel> "
"panel."
msgstr ""

#. Tag: title
#: index.docbook:869
#, no-c-format
msgid "The Datapicker Menu"
msgstr "Das Menü Digitalisierer"

#. Tag: para
#: index.docbook:870
#, no-c-format
msgid ""
"This menu contains all the items that can also be found in the context menu "
"(right mouse) of a datapicker. The menu is only available when a datapicker "
"object is selected on the <guilabel>Project Explorer</guilabel> panel."
msgstr ""

#. Tag: title
#: index.docbook:877
#, no-c-format
msgid "The Settings Menu"
msgstr "Das Menü Einstellungen"

#. Tag: para
#: index.docbook:879
#, no-c-format
