msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;&Shift;<keycap>F</keycap></"
"keycombo></shortcut> <guimenu>Einstellungen</guimenu> "
"<guimenuitem>Vollbildmodus</guimenuitem>"

