msgid "erf(x)"
msgstr "erf(x)"

#. Tag: action
#: index.docbook:1888
#, no-c-format
msgid ""
"error function erf(x) = 2/&radic;&pi; &int;<subscript>0</"
"subscript><superscript>x</superscript> exp(-t<superscript>2</superscript>) dt"
msgstr ""
"Fehlerfunktion erf(x) = 2/&radic;&pi; &int;<subscript>0</"
"subscript><superscript>x</superscript> exp(-t<superscript>2</superscript>) dt"

