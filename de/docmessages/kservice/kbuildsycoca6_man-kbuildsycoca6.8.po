#: man-kbuildsycoca6.8.docbook:136
#, no-c-format
msgid "-h, --help"
msgstr "-h, --help"

#. Tag: para
#: man-kbuildsycoca6.8.docbook:138
#, no-c-format
msgid "Show a brief help text."
msgstr "Zeigt einen kurzen Hilfetext."

#. Tag: option
#: man-kbuildsycoca6.8.docbook:145
