#~ msgid "--nosignal"
#~ msgstr "--nosignal"

#~ msgid ""
#~ "Ordinarily, <command>kbuildsycoca5</command> sends a signal over &DBus; "
#~ "once the cache is updated to all the applications that use KService so "
#~ "that they are always working with the latest information. This option "
#~ "suppresses that behaviour."
#~ msgstr ""
#~ "Normalerweise sendet <command>kbuildsycoca5</command> bei der "
#~ "Aktualisierung des Zwischenspeichers ein Signal über &DBus; an alle "
#~ "Anwendungen, die KService verwenden, damit die Anwendungen immer mit den "
#~ "neuesten Informationen arbeiten. Mit dieser Option wird dieses Verhalten "
#~ "abgeschaltet."

#~ msgid "<varname>cachedir</varname>/ksycoca5"
#~ msgstr "<varname>cachedir</varname>/ksycoca5"

#~ msgid "2014-04-12"
#~ msgstr "2014-04-12"

#~ msgid ""
#~ "The timestamp and other meta-information about the main cache file. On "
#~ "Unix systems, <varname>cachedir</varname> is typically <filename class="
#~ "\"directory\"><envar>XDG_CONFIG_HOME</envar></filename>"
#~ msgstr ""
#~ "Der Zeitstempel und andere Meta-Informationen über die Haupt-"
#~ "Zwischenspeicherdatei. In Unix-Systemen ist <filename class=\"directory"
#~ "\"><envar>XDG_CONFIG_HOME</envar></filename>"

#~ msgid "--checkstamps"
#~ msgstr "--checkstamps"

#~ msgid ""
#~ "Checks the file timestamps of the cache and the resource directories "
#~ "containing the data to be cached, and only updates the database if any of "
#~ "the resource directories have been modified more recently than the cache. "
#~ "Ignored if <option>--nocheckfiles</option> or <option>--noincremental</"
#~ "option> is set."
#~ msgstr ""
#~ "Überprüft die Zeitstempel des Zwischenspeichers und der Ressourcen-Ordner "
#~ "mit den Daten zur Zwischenspeicherung. Die Datenbank wird nur "
#~ "aktualisiert, wenn die Ressourcen-Ordner später als der Zwischenspeicher "
#~ "geändert wurde. Diese Einstellung wird ignoriert, wenn die Option "
#~ "<option>--nocheckfiles</option> oder <option>--noincremental</option> "
#~ "benutzt wird."

#~ msgid "--nocheckfiles"
#~ msgstr "--nocheckfiles"

#~ msgid ""
#~ "Does not rebuild the cache unless something other than a change in the "
#~ "resource files requires it (such as the format of the cache changing, or "
#~ "<varname>XDG_DATA_DIRS</varname> being changed on a Unix system). Ignored "
#~ "if <option>--global</option> is set."
#~ msgstr ""
#~ "Erneuert den Zwischenspeicher nicht, wenn es nicht durch durch Änderungen "
#~ "der Ressourcen-Dateien nötig wird, wie zum Beispiel bei einer Änderung "
#~ "des Formats des Zwischenspeichers oder wenn <varname>XDG_DATA_DIRS</"
#~ "varname> auf einem Unix-System geändert wird. Diese Option wird "
#~ "ignoriert, wenn <option>--global</option> verwendet wird."

