msgstr ""
"Fügt den Inhalt der Zwischenablage an der aktuellen Cursor-Position in das "
"Eingabefeld ein."

#. Tag: menuchoice
#: index.docbook:514
#, no-c-format
msgid "<guimenu>Edit</guimenu> <guimenuitem>Speak</guimenuitem>"
msgstr "<guimenu>Bearbeiten</guimenu><guimenuitem>Sprechen</guimenuitem>"

