#. Tag: title
#: index.docbook:2681
#, no-c-format
msgid "Mount Settings (BSD only)"
msgstr "Allgemeine Einstellungen zum Einhängen nur unter BSD"

#. Tag: para
#: index.docbook:2683
#, no-c-format
