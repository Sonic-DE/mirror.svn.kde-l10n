#. Tag: title
#: index.docbook:56
#, no-c-format
msgid "Introduction"
msgstr "Einleitung"

#. Tag: para
#: index.docbook:58
#, fuzzy, no-c-format
#| msgid ""
#| "&smb4k; is an advanced network neighborhood browser and <ulink url="
#| "\"http://www.samba.org\">Samba</ulink> share mounting utility. It "
#| "provides many handy features that ease your life in a &Windows;-dominated "
#| "network environment:"
msgid ""
"&smb4k; is an advanced network neighborhood browser and <ulink url=\"http://"
"www.samba.org\">Samba</ulink> share mounting utility. It provides many handy "
"features that ease your life in a &Windows;-dominated network environment."
msgstr ""
"&smb4k; ist ein erweiterter Browser für die Netzwerkumgebung und ein "
"Dienstprogramm für das Einhängen von <ulink url=\"http://www.samba.org"
"\">Samba</ulink>-Freigaben. Es bietet viele praktische Funktionen, die den "
"Umgang mit einer &Windows;-dominierten Netzwerkumgebung erleichtern."

