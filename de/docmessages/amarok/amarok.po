#: index.docbook:7897
#, no-c-format
msgid "Keyboard Shortcuts"
msgstr "Tastenkürzel"

#. Tag: para
#: index.docbook:7898
#, no-c-format
msgid ""
"Keyboard shortcuts let you quickly access &amarok;<command>'s</command> "
"power. Change the shortcuts using <menuchoice><guimenu>Settings</"
"guimenu><guimenuitem>Configure Shortcuts...</guimenuitem></menuchoice>."
msgstr ""
"Mit Tastatur-Kurzbefehlen können Sie schnell alle Möglichkeiten von &amarok; "
"erreichen. Ändern Sie die Kurzbefehle mit  "
"<menuchoice><guimenu>Einstellungen</guimenu><guimenuitem>Kurzbefehle "
"festlegen ...</guimenuitem></menuchoice>."

