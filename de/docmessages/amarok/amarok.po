#, no-c-format
msgid "<guilabel>Stop</guilabel>"
msgstr "<guilabel>Anhalten</guilabel>"

#. Tag: para
#: index.docbook:7017
#, no-c-format
msgid "Stops all playback in progress."
msgstr "Beendet die laufende Wiedergabe."

