"Speichert den aktuellen Verlaufsspeicher in einer Text- oder &HTML;-Datei."

#. Tag: menuchoice
#: index.docbook:584
#, no-c-format
msgid ""
"<shortcut><keycombo action=\"simul\">&Ctrl;&Shift;<keycap>P</keycap></"
"keycombo></shortcut> <guimenu>File</guimenu> <guimenuitem>Print Screen ...</"
"guimenuitem>"
msgstr ""
"<shortcut><keycombo action=\"simul\">&Ctrl;&Shift;<keycap>P</keycap></"
