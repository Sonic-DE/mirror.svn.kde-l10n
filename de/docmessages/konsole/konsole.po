"<shortcut><keycombo action=\"simul\">&Ctrl;&Shift;<keycap>V</keycap></"
"keycombo></shortcut> <guimenu>Bearbeiten</guimenu><guimenuitem>Einfügen</"
"guimenuitem>"

#. Tag: action
#: index.docbook:649
#, no-c-format
msgid "Pastes text from the clipboard at the cursor location"
msgstr "Fügt Text aus der Zwischenablage an der Cursor-Position ein."

#. Tag: menuchoice
#: index.docbook:654
#, no-c-format
msgid "<guimenu>Edit</guimenu><guimenuitem>Select All</guimenuitem>"
msgstr ""
"<guimenu>Bearbeiten</guimenu> <guimenuitem>Alles auswählen</guimenuitem>"

