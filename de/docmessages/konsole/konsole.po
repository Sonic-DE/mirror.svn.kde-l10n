#: index.docbook:703
#, no-c-format
msgid "CONT"
msgstr "CONT"

#. Tag: entry
#: index.docbook:704
#, no-c-format
msgid "continue if stopped"
msgstr "(=Continue) Um einen angehaltenen Prozess wieder zu starten"

