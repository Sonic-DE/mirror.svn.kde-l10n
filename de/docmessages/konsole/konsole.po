"Einrichtung von Web-Kürzeln."

#. Tag: guimenuitem
#: index.docbook:276
#, no-c-format
msgid "Open File Manager"
msgstr "In Dateiverwaltung öffnen"

#. Tag: guimenuitem
#: index.docbook:277
#, no-c-format
msgid "Set Encoding"
msgstr "Kodierung festlegen"

#. Tag: guimenuitem
#: index.docbook:278
#, no-c-format
msgid "Clear Scrollback"
msgstr "Verlaufsspeicher leeren"

#. Tag: guimenuitem
#: index.docbook:279
#, no-c-format
msgid "Adjust Scrollback..."
msgstr "Verlaufsspeicher anpassen ..."

#. Tag: para
#: index.docbook:280
#, no-c-format
msgid ""
"<guimenuitem>Show Menu Bar</guimenuitem>, only when the menubar is hidden"
msgstr ""
"<guimenuitem>Menüleiste anzeigen</guimenuitem>, nur wenn die Menüleiste "
"ausgeblendet ist"

#. Tag: guimenuitem
#: index.docbook:281
#, no-c-format
msgid "Switch Profile"
