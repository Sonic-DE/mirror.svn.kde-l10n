#, no-c-format
msgid ""
"Documentation Copyright see the UserBase <ulink url=\"https://userbase.kde."
"org/index.php?title=K3b&amp;action=history\">K3b page history</ulink>"
msgstr ""
"Copyright der Dokumentation: siehe <ulink url=\"https://userbase.kde.org/"
"index.php?title=K3b&amp;action=history\">Versionsgeschichte der K3b-Seite</"
"ulink>"

