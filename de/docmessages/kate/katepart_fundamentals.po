#~ "die Einstellung <guilabel>Leerzeichen statt Tabulatoren für Einrückung "
#~ "verwenden</guilabel> auf der Karteikarte <guilabel>Allgemein</guilabel> "
#~ "der Seite <guilabel>Bearbeitung</guilabel> aktiviert, werden Leerzeichen "
#~ "eingefügt, anderenfalls ein Tabulatorzeichen."

#~ msgid "Auto Completion"
#~ msgstr "Autovervollständigung"

#~ msgid "<guilabel>General</guilabel>"
#~ msgstr "<guilabel>Allgemein</guilabel>"

#~ msgid "Auto Completion enabled"
#~ msgstr "Autovervollständigung aktiviert"

#~ msgid ""
#~ "If enabled, a word completion box automatically pops up during typing "
