#. Tag: guilabel
#: configuring.docbook:145
#, no-c-format
msgid "Dynamic Word Wrap"
msgstr "Dynamischer Zeilenumbruch"

#. Tag: para
#: configuring.docbook:147
#, no-c-format
msgid ""
