"Wechselt zum Unterfenster Fehlerdiagnose in der Werkzeugansicht des Modules."

#. Tag: menuchoice
#: plugins.docbook:2572
#, no-c-format
msgid ""
"<guimenu>LSP Client</guimenu> <guisubmenu>Close all non-diagnostics tabs</"
"guisubmenu>"
msgstr ""
"<guimenu>LSP-Client</guimenu> <guisubmenu>Alle Unterfenster außer "
"Fehlerdiagnose schließen</guisubmenu>"

#. Tag: para
#: plugins.docbook:2577
#, no-c-format
msgid "Close all non-diagnostics (&eg; references) tabs in plugin toolview."
msgstr ""
"Schließt alle Unterfenster ohne Fehlerdiagnose &eg; Referenzen in der "
"Werkzeugansicht des Moduls."

#. Tag: menuchoice
#: plugins.docbook:2582
#, no-c-format
msgid ""
"<guimenu>LSP Client</guimenu> <guisubmenu>Restart LSP Server</guisubmenu>"
msgstr ""
"<guimenu>LSP-Client</guimenu> <guisubmenu>LSP-Server neu starten</guisubmenu>"

#. Tag: para
