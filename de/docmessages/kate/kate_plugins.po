#~ "Der im aktuellen Dokument markierte Text oder eine leere Zeichenkette, "
#~ "wenn kein Text markiert ist."

#~ msgid "%text"
#~ msgstr "%text"

#~ msgid ""
#~ "The full text of the current document. Beware that this may potentially "
#~ "exceed the maximum command length allowed on your system. Use with care."
