msgstr ""
"<guimenu>LSP-Client</guimenu> <guisubmenu>Markierungen für Fehlerdiagnose "
"anzeigen</guisubmenu>"

#. Tag: para
#: plugins.docbook:2557
#, no-c-format
msgid "Add document marks for lines indicated in diagnostics."
msgstr ""
"Dokumentmarkierungen für in der Fehlerdiagnose angezeigte Zeilen hinzufügen."

#. Tag: menuchoice
#: plugins.docbook:2562
#, no-c-format
msgid ""
"<guimenu>LSP Client</guimenu> <guisubmenu>Switch to diagnostic tab</"
"guisubmenu>"
msgstr ""
"<guimenu>LSP-Client</guimenu> <guisubmenu>Zum Unterfenster Fehlerdiagnose "
"wechseln</guisubmenu>"

#. Tag: para
#: plugins.docbook:2567
#, no-c-format
msgid "Switch to the diagnostic tab in the plugin toolview."
