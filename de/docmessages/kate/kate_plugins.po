#: plugins.docbook:604
#, no-c-format
msgid "Build Output"
msgstr "Ausgabe beim Erstellen"

#. Tag: para
#: plugins.docbook:610
#, fuzzy, no-c-format
#| msgid "The <guilabel>Build Output</guilabel> tool view has two tabs:"
msgid "The <guilabel>Build</guilabel> tool view has two static tabs:"
msgstr ""
"Die <guilabel>Ausgabe beim Erstellen</guilabel> zeigt zwei Karteikarten an:"

