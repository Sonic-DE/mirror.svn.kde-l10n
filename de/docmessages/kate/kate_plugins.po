#~ msgid ""
#~ "While reading in the file, the parser keeps lines beginning with the "
#~ "phrase <constant>katetemplate:</constant> and searches them for template "
#~ "information in the form VARIABLENAME=VALUE. The first line not starting "
#~ "with <constant>katetemplate:</constant> will be taken as the start of the "
#~ "template contents. VALUE may contain any character but equal sign (=). "
#~ "Legal variable names are:"
#~ msgstr ""
#~ "Beim Einlesen der Datei werden Zeilen, die mit dem Text "
#~ "<constant>katetemplate:</constant> anfangen, nach Vorlageninformationen "
#~ "in der Form VARIABLENNAME=WERT durchsucht. Der Inhalt der Vorlage beginnt "
#~ "mit der ersten Zeile, die nicht mit <constant>katetemplate:</constant> "
#~ "anfängt. WERT kann beliebige Zeichen bis auf das Gleichheitszeichen (=) "
#~ "enthalten. Gültige Variablennamen sind:"

