#. Tag: para
#: index.docbook:33
#, no-c-format
msgid ""
"&kwrite; is a text editor by &kde; allowing you to edit one file at the time "
"per window."
msgstr ""
"&kwrite; ist ein Texteditor von &kde;, mit dem Sie jede einzelne Datei in "
"einem eigenen Fenster bearbeiten."

#. Tag: keyword
#: index.docbook:37
#, no-c-format
msgid "<keyword>KDE</keyword>"
msgstr "<keyword>KDE</keyword>"

