"<shortcut> <keycombo action=\"simul\">&Alt;&Left;</keycombo></shortcut> "
"<guimenu>Ansicht</guimenu> <guimenuitem>Vorheriges Unterfenster</guimenuitem>"

#. Tag: para
#: menus.docbook:747
#, no-c-format
msgid "Activates the previous tab in the tabbar."
msgstr "Aktiviert das vorherige Unterfenster.in der Unterfensterleiste."

#. Tag: menuchoice
