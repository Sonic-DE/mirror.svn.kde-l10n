#~ "replaceable></parameter>);\n"
#~ "bool document.removeText(<parameter>Cursor <replaceable>von</"
#~ "replaceable></parameter>, <parameter>Cursor <replaceable>bis</"
#~ "replaceable></parameter>);\n"
#~ "bool document.removeText(<parameter>Range <replaceable>bereich</"
#~ "replaceable></parameter>);"

