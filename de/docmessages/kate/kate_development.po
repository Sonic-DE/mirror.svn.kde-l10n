#~ "a small dot."
#~ msgstr ""
#~ "Wenn eingeschaltet, werden Tabulatorzeichen und vorangestellte "
#~ "Leerzeichen durch kleine Punkte dargestellt."

#~ msgid ""
#~ "<command>set-show-indent</command><arg choice=\"req\">BOOLEAN enable</arg>"
#~ msgstr ""
#~ "<command>set-show-indent</command><arg choice=\"req\">BOOLEAN enable</arg>"

#~ msgid ""
#~ "If enabled, indentation will be visualized by a vertical dotted line."
#~ msgstr ""
