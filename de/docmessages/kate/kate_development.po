#~ "Der zurückgegebene Bereich ist ungültig (siehe Range.isValid()), wenn die "
#~ "Textposition nach dem Zeilenende liegt. Befindet sich an der angegebenen "
#~ "Cursor-Position kein Wort, wird ein leere Bereich zurückgegeben."

#~ msgid ""
#~ "String document.charAt(<parameter>int <replaceable>line</replaceable></"
#~ "parameter>, <parameter>int <replaceable>column</replaceable></"
#~ "parameter>);\n"
#~ "String document.charAt(<parameter>Cursor <replaceable>cursor</"
#~ "replaceable></parameter>);"
#~ msgstr ""
#~ "String document.charAt(<parameter>int <replaceable>zeile</replaceable></"
#~ "parameter>, <parameter>int <replaceable>spalte</replaceable></"
#~ "parameter>);\n"
#~ "String document.charAt(<parameter>Cursor <replaceable>cursor</"
#~ "replaceable></parameter>);"

