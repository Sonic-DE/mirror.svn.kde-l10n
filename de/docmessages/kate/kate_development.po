#~ msgstr ""
#~ "Cursor.setPosition(<parameter>int <replaceable>zeile</replaceable></"
#~ "parameter>, <parameter>int <replaceable>spalte</replaceable></parameter>);"

#~ msgid ""
#~ "Sets the cursor position to <replaceable>line</replaceable> and "
#~ "<replaceable>column</replaceable>."
#~ msgstr ""
#~ "Setzt die Cursor-Position auf <replaceable>zeile</replaceable> und "
#~ "<replaceable>spalte</replaceable>."

