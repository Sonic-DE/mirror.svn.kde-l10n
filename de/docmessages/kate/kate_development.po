#~ msgid "If enabled, tabs are replaced with spaces as you type."
#~ msgstr ""
#~ "Wenn eingeschaltet, werden Tabulatorzeichen durch Leerzeichen ersetzt."

#~ msgid ""
#~ "<command>set-remove-trailing-space</command><arg choice=\"req\">BOOLEAN "
