#~ msgstr ""
#~ "<command>set-remove-trailing-space</command><arg choice=\"req\">BOOLEAN "
#~ "enable</arg>"

#~ msgid ""
#~ "If enabled, trailing whitespace are removed whenever the cursor leaves a "
#~ "line."
#~ msgstr ""
#~ "Wenn eingeschaltet, werden Leerzeichen und andere Zwischenräume am "
#~ "Zeilenanfang entfernt, wenn der Cursor eine Zeile verlässt."

#~ msgid ""
