#~ msgstr "Since: &kde; 4.11"

#~ msgid "bool Cursor.isValid();"
#~ msgstr "bool Cursor.isValid();"

#~ msgid ""
#~ "Check whether the cursor is valid. The cursor is invalid, if line and/or "
#~ "column are set to <literal>-1</literal>."
#~ msgstr ""
#~ "Überprüft, ob der Cursor gültig ist. Ein Cursor ist ungültig, wenn die "
#~ "Zeile und oder die Spalte den Wert <literal>-1</literal> haben."

#~ msgid "Example: <function>var valid = cursor.isValid();</function>"
#~ msgstr "Beispiel: <function>var valid = cursor.isValid();</function>"

