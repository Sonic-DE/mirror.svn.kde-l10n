#~ msgstr "Die Quelltext-Ausblendungsspalte &i18n-powermode;"

#~ msgid "Using Bookmarks"
#~ msgstr "Lesezeichen benutzen"

#~ msgid "Using automatic indenting"
#~ msgstr "Automatisches Einrücken benutzen"

#~ msgid "Using Bookmarks &i18n-powermode;"
#~ msgstr "Lesezeichen benutzen &i18n-powermode;"

#~ msgid "Using automatic indenting &i18n-powermode;"
#~ msgstr "Automatisches Einrücken benutzen &i18n-powermode;"

