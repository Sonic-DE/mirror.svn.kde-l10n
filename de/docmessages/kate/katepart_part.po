#~ "<option>--key \"Line Modifications\"</option> <option>--type bool</"
#~ "option> <option><replaceable>false</replaceable></option></userinput>"
#~ msgstr ""
#~ "<prompt>%</prompt> <userinput><command>kwriteconfig</command> <option>--"
#~ "file &rcfile;</option> <option>--group \"Kate View Defaults\"</option> "
#~ "<option>--key \"Line Modifications\"</option> <option>--type bool</"
#~ "option> <option><replaceable>false</replaceable></option></userinput>"

#~ msgid ""
#~ "To re-enable it, simply replace <userinput>false</userinput> with "
#~ "<userinput>true</userinput>. A proper configuration option will be added "
#~ "in &kde; 4.9."
#~ msgstr ""
#~ "Um die Kennzeichnung von Änderungen in Textzeilen wieder einzuschalten, "
#~ "ersetzen Sie <userinput>false</userinput> durch <userinput>true</"
#~ "userinput>. In &kde; 4.9 wird diese Funktion auch im Einstellungsdialog "
#~ "ein- bzw. ausgeschaltet werden können."

#~ msgid "<link>Navigating in the Text</link>"
#~ msgstr "<link>Navigieren im Text</link>"

#~ msgid "See <xref linkend=\"regular-expressions\"/> for more on those."
#~ msgstr ""
#~ "Sehen Sie unter <link linkend=\"regular-expressions\">Reguläre Ausdrücke</"
#~ "link> für weitere Informationen hierzu nach."

#~ msgid "Highlight all"
#~ msgstr "Alle hervorheben"

#~ msgid "If enabled, all matches in the whole document are highlighted."
#~ msgstr ""
#~ "Wenn eingeschaltet, werden alle Treffer im ganzen Dokument hervorgehoben."

#~ msgid "From cursor"
#~ msgstr "Ab Cursorposition"

#~ msgid ""
#~ "If checked, the search will start at cursor position, otherwise it will "
#~ "start at the beginning of the first line in the document."
#~ msgstr ""
#~ "Wenn diese Option eingeschaltet ist, startet die Suche an der aktuellen "
#~ "Cursorposition sonst in der ersten Zeile des Dokumentes."

#~ msgid ""
#~ "You can modify the search behaviour by selecting the different "
#~ "<guilabel>Options</guilabel> described above."
#~ msgstr ""
#~ "Sie können das Verhalten der Suche mit den oben beschriebenen "
#~ "<guilabel>Optionen</guilabel> beeinflussen."

#~ msgid ""
#~ "You can modify the search and replace behaviour by selecting the "
#~ "different options on the right side of the bar."
#~ msgstr ""
#~ "Um das Verhalten des Suchens und Ersetzens zu beeinflussen können Sie die "
#~ "Optionen an der rechten Seite der Leiste verwenden."
