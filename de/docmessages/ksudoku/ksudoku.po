#. Tag: para
#: index.docbook:533
#, no-c-format
msgid "<action>Give a Hint</action> by filling in a vacant square."
msgstr ""
"<action>Gibt einen Tipp</action>, in dem ein Symbol in einer freien Zelle "
"des Gitters eingetragen wird."

#. Tag: menuchoice
#: index.docbook:536
#, no-c-format
msgid "<guimenu>Move</guimenu> <guimenuitem>Solve</guimenuitem>"
msgstr "<guimenu>Zug</guimenu><guimenuitem>Lösen</guimenuitem>"

#. Tag: para
#: index.docbook:540
#, no-c-format
msgid "<action>Instantly solve</action> the puzzle."
msgstr "Hiermit wird das Rätsel sofort gelöst."

