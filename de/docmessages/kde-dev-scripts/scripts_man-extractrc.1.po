#. Tag: cmdsynopsis
#: man-extractrc.1.docbook:24
#, no-c-format
msgid ""
"<command>extractrc</command> <group><option><replaceable>filename</"
"replaceable></option></group>"
msgstr ""
"<command>extractrc</command> <group><option><replaceable>filename</"
"replaceable></option></group>"

#. Tag: title
#: man-extractrc.1.docbook:32
#, no-c-format
msgid "Description"
msgstr "Beschreibung"

#. Tag: para
#: man-extractrc.1.docbook:34
#, no-c-format
msgid ""
"<command>extractrc</command> finds all text tags and other message strings "
"in the given files and writes the corresponding i18n() calls to standard "
"output so that xgettext can parse them."
msgstr ""
"<command>extractrc</command> findet alle Textmarkierungen und andere "
"Nachrichtenzeichenfolgen in den angegebenen Dateien und schreibt die "
"entsprechenden i18n-Aufrufe in die Standardausgabe, sodass sie von xgettext "
"eingelesen werden können."

#. Tag: para
#: man-extractrc.1.docbook:38
#, no-c-format
msgid ""
"It understands both (&Qt;/&kde;) <application>designer</application>'s "
"<acronym>UI</acronym> files and &XML; GUI-RC files."
msgstr ""
"Das Skript versteht sowohl (Qt/&kde;) die <application>UI</application>-"
"Dateien von <application>designer</application> als auch GUI-RC-Dateien im "
"&XML;-Format."

#. Tag: para
#: man-extractrc.1.docbook:42
#, no-c-format
msgid "This utility is part of the KDE Software Development Kit."
msgstr ""
"Dieses Hilfsprogramm ist Teil der &kde; Software-Entwicklungswerkzeuge."

