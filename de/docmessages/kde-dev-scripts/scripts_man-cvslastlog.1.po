#. Tag: refpurpose
#: man-cvslastlog.1.docbook:20
#, no-c-format
msgid "Prints the log entry for the last commit for a file."
msgstr "Gibt den Kommentar zum letzten Einspielvorgang einer Datei aus."

#. Tag: cmdsynopsis
#: man-cvslastlog.1.docbook:24
#, no-c-format
msgid ""
"<command>cvslastlog</command> <group><option><replaceable>filename</"
"replaceable></option></group>"
msgstr ""
"<command>cvslastlog</command> <group><option><replaceable>filename</"
"replaceable></option></group>"

#. Tag: title
#: man-cvslastlog.1.docbook:32
#, no-c-format
msgid "Description"
msgstr "Beschreibung"

#. Tag: para
#: man-cvslastlog.1.docbook:34
#, no-c-format
msgid ""
"<command>cvslastlog</command> shows the log associated with the last CVS "
"commit for the given file. It depends on the version of the local file, not "
"the one on the server."
msgstr ""
"<command>cvslastlog</command> zeigt den Kommentar an, der beim letzten "
"Einspielvorgang für die angegebene Datei vergeben wurde. Hierbei wird auf "
"die Version der lokalen Datei zurückgegriffen, nicht auf die Version auf dem "
"Server."

