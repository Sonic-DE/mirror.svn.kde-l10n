#. Tag: para
#: index.docbook:35
#, no-c-format
msgid ""
"This is the documentation for the &kde; &systemsettings; module that "
"configures graphic tablets."
msgstr ""
"Dies ist die Dokumentation für das &kde; &systemsettings;-Modul, mit dem "
"Grafik-Tabletts eingerichtet werden."

#. Tag: keyword
#: index.docbook:39
#, no-c-format
msgid "<keyword>KDE</keyword>"
msgstr "<keyword>KDE</keyword>"

#. Tag: keyword
#: index.docbook:40
#, no-c-format
msgid "System Settings"
msgstr "Systemeinstellungen"

#. Tag: keyword
#: index.docbook:41
#, no-c-format
msgid "Wacom"
msgstr "Wacom"

#. Tag: keyword
#: index.docbook:42
#, no-c-format
msgid "<keyword>Tablet</keyword>"
