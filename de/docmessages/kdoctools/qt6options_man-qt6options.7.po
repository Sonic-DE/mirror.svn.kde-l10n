#~ msgstr "<option>--name</option> <parameter>Name</parameter>"

#~ msgid "<option>--title</option> <parameter>title</parameter>"
#~ msgstr "<option>--title</option> <parameter>Titel</parameter>"

#~ msgid "<option>--visual</option> <parameter>TrueColor</parameter>"
#~ msgstr "<option>--visual</option> <parameter>TrueColor</parameter>"

#~ msgid ""
#~ "Forces the application to use a <parameter>TrueColor</parameter> visual "
