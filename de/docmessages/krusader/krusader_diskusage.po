#. Tag: title
#: diskusage.docbook:8
#, no-c-format
msgid "<title>Disk Usage</title>"
msgstr "<title>Festplattenbelegung</title>"

#. Tag: primary
#: diskusage.docbook:10
#, no-c-format
msgid "<primary>Disk Usage</primary>"
msgstr "<primary>Festplattenbelegung</primary>"

#. Tag: para
#: diskusage.docbook:12
#, no-c-format
msgid ""
"The Disk Usage is based on the code of &filelight;. The Disk Usage shows you "
"how your disk space is being used by a graphical representation of your file "
"system. The following presentations are possible:"
msgstr ""
"Die Festplattenbelegung verwendet den Quelltext des Programms &filelight;. "
"Es gibt folgende Möglichkeiten der grafischen Anzeige der "
"Speicherplatzbelegung des Dateisystems:"

#. Tag: para
#: diskusage.docbook:18
#, no-c-format
msgid "Line view"
msgstr "Linien-Ansicht"

#. Tag: para
#: diskusage.docbook:21
#, no-c-format
msgid "Detailed view"
msgstr "Ausführlicher Anzeigemodus"

#. Tag: para
#: diskusage.docbook:24
#, no-c-format
msgid ""
"<application>Filelight</application> view: as a set of concentric segmented-"
"rings"
msgstr ""
"<application>Filelight</application>-Ansicht: konzentrische Kreissegmente"

#. Tag: para
#: diskusage.docbook:28
#, no-c-format
msgid ""
"Choose <menuchoice> <guimenu>Tools</guimenu> <guimenuitem>Disk Usage...</"
"guimenuitem> </menuchoice> or <keycombo action=\"simul\">&Alt;&Shift; "
"<keycap>S</keycap></keycombo> to start this feature in a separate window, or "
"open it inside the <link linkend=\"sidebar\">Sidebar</link>."
msgstr ""
"Wählen Sie <menuchoice> <guimenu>Extras</guimenu> "
"<guimenuitem>Festplattenbelegung</guimenuitem> </menuchoice> oder den "
"Kurzbefehl <keycombo action=\"simul\">&Alt;&Shift;<keycap>S</keycap></"
"keycombo>, um die Belegung in einen eigenen Fenster anzuzeigen oder öffnen "
"Sie diese Ansichten im <link linkend=\"sidebar\">Seitenleiste</link>."

#. Tag: para
#: diskusage.docbook:38
#, no-c-format
msgid "Disk Usage Keybindings, right click menu."
msgstr "Kurzbefehle für das Kontextmenü der Festplattenbelegung."

#. Tag: para
#: diskusage.docbook:41
#, no-c-format
msgid "<keycap>Del</keycap>: Delete"
msgstr "<keycap>Entf</keycap>: Entfernen"

