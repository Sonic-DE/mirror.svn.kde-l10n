#, fuzzy
#~ msgid ""
#~ "This problem occurs when you use the <trademark class=\"registered"
#~ "\">NVIDIA</trademark> installer and not the official <trademark class="
#~ "\"registered\">NVIDIA</trademark> packages of your distribution. "
#~ "&krusader; is based on &Qt; which can be linked against the X OpenGL "
