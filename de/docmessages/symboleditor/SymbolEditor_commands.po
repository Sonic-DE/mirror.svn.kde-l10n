msgid "Save Symbol"
msgstr "Symbol speichern"

#. Tag: listitem
#: commands.docbook:32
#, no-c-format
msgid ""
"<simpara><action>Save the symbol being edited</action></simpara> <simpara>If "
"the symbol being edited was selected from the library, saving will update "
"that symbol. If it is a new symbol, it will be appended to the library and "
"subsequent saves will append another new symbol to the library. </simpara>"
msgstr ""
"<simpara><action>Speichert das bearbeiteten Symbol</action></simpara> "
"<simpara>Wenn das bearbeitete Symbol aus der Bibliothek ausgewählt wurde, "
"wird es durch das Speichern aktualisiert. Wenn es ein neues Symbol ist, wird "
"es an die Bibliothek angehängt und nachfolgende Speicherungen fügen der "
"Bibliothek ein weiteres neues Symbol hinzu. </simpara>"

#. Tag: guimenuitem
#: commands.docbook:39
#, no-c-format
msgid "Save Symbol as New"
msgstr "Als neues Symbol speichern"

#. Tag: listitem
#: commands.docbook:40
#, no-c-format
msgid ""
"<simpara><action>Save the symbol being edited as a new symbol</action></"
"simpara> <simpara>When a symbol is saved as new it will be appended to the "
"library regardless of it having originally been selected from the library "
"for editing. Subsequent saves will append another new symbol to the library. "
"</simpara>"
msgstr ""
"<simpara><action>Speichert das bearbeitete Symbol als neues Symbol</action></"
"simpara> <simpara>Wenn ein Symbol als neues Symbol gespeichert wird, wird es "
"an die Bibliothek angehängt unabhängig davon, ob es ursprünglich in der "
"Bibliothek zur Bearbeitung ausgewählt wurde. Nachfolgende Speicherungen "
"fügen ein weiteres neues Symbol an die Bibliothek an. </simpara>"

