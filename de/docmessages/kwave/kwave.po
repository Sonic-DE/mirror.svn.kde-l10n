#: index.docbook:4097 index.docbook:4155
#, no-c-format
msgid "<parameter>x</parameter>:"
msgstr "<parameter>x</parameter>:"

#. Tag: entry
#: index.docbook:4098 index.docbook:4156
#, no-c-format
msgid "x position, relative to the left border of the window (in pixels)"
msgstr "X-Position, relativ zum linken Rand des Fensters (in Pixel)"

#. Tag: entry
#: index.docbook:4099 index.docbook:4157
#, no-c-format
msgid "<parameter>y</parameter>:"
msgstr "<parameter>y</parameter>:"

#. Tag: entry
#: index.docbook:4100 index.docbook:4158
#, no-c-format
msgid "y position, relative to the top border of the window (in pixels)"
msgstr "Y-Position, relativ zur Oberkante des Fensters (in Pixel)"

#. Tag: title
#: index.docbook:4105
#, no-c-format
msgid "&no-i18n-cmd_window_close;"
msgstr "&no-i18n-cmd_window_close;"

#. Tag: title
#: index.docbook:4107
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_close;</"
"command>( <replaceable>class</replaceable> )"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_close;</"
"command>( <replaceable>Klasse</replaceable> )"

#. Tag: para
#: index.docbook:4110
#, no-c-format
msgid ""
"Closes a window, identified by its <replaceable>class</replaceable> name. "
"Only the first window that has the given class name will be closed, "
"therefore you should make sure that you have only one instance of the given "
"window when this command gets executed."
msgstr ""
"Schließt ein Fenster, das über seine <replaceable>Klasse</replaceable> "
"identifiziert wird. Nur das erste Fenster mit dem angegebenen Klassen-Namen "
"wird geschlossen, deshalb sollten Sie sicher stellen dass nur eine einzige "
"Instanz des angegebenen Fensters existiert wenn der Befehl ausgeführt wird."

#. Tag: title
#: index.docbook:4125
#, no-c-format
msgid "&no-i18n-cmd_window_minimize;"
msgstr "&no-i18n-cmd_window_minimize;"

#. Tag: title
#: index.docbook:4127
#, no-c-format
msgid "&i18n-cmd_syntax;<command>&no-i18n-cmd_window_minimize;</command>"
msgstr "&i18n-cmd_syntax;<command>&no-i18n-cmd_window_minimize;</command>"

#. Tag: para
#: index.docbook:4128
#, no-c-format
msgid ""
"Minimizes the currently active sub-window when in MDI mode or the current "
"toplevel window when in SDI or Tab mode."
msgstr ""
"Minimiert das aktuell aktive Unterfenster im MDI-Modus oder das aktuelle "
"Hauptfenster im SDI- oder Unterfenster-Modus."

#. Tag: title
#: index.docbook:4136
#, no-c-format
msgid "&no-i18n-cmd_window_mousemove;"
msgstr "&no-i18n-cmd_window_mousemove;"

#. Tag: title
#: index.docbook:4138
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_resize;</"
"command>( <replaceable>class</replaceable>, <replaceable>x</replaceable>, "
"<replaceable>y</replaceable> )"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_resize;</"
"command>( <replaceable>Klasse</replaceable>, <replaceable>x</replaceable>, "
"<replaceable>y</replaceable> )"

#. Tag: para
#: index.docbook:4143
#, no-c-format
msgid ""
"Sends a mouse move event to window, identified by its <replaceable>class</"
"replaceable> name. The event will only be sent to the first window that has "
"the given class name, therefore you should make sure that you have only one "
"instance of the given window when this command gets executed."
msgstr ""
"Sendet einen Mausbewegungs-Ereignis an ein Fenster das über seine "
"<replaceable>Klasse</replaceable> identifiziert wird. Das Ereignis wird nur "
"zu dem ersten Fenster gesendet das den angegebenen Klassen-Namen hat, "
"deshalb sollten Sie sicher stellen dass nur eine einzige Instanz des "
"angegebenen Fensters existiert wenn der Befehl ausgeführt wird."

#. Tag: title
#: index.docbook:4163
#, no-c-format
msgid "&no-i18n-cmd_window_next_sub;"
msgstr "&no-i18n-cmd_window_next_sub;"

#. Tag: title
#: index.docbook:4165
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_next_sub;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_next_sub;</"
"command>()"

# (filtered) msgid "&no-i18n-cmd_window_next_sub;"
# (filtered) msgstr ""
# (filtered) msgid ""
# (filtered) "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_next_sub;</"
# (filtered) "command>()"
# (filtered) msgstr ""
#. Tag: para
#: index.docbook:4166
#, no-c-format
msgid ""
"Activates the <emphasis>next</emphasis> sub-window when in MDI or Tab mode. "
"If the next sub-window is minimized it will be restored."
msgstr ""
"Aktiviert das <emphasis>nächste</emphasis> Unterfenster wenn im MDI- oder "
"Unterfenster-Modus. Wenn das nächste Unterfenster minimiert war, wird es "
"wiederhergestellt."

#. Tag: title
#: index.docbook:4174
#, no-c-format
msgid "&no-i18n-cmd_window_prev_sub;"
msgstr "&no-i18n-cmd_window_prev_sub;"

#. Tag: title
#: index.docbook:4176
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_prev_sub;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_prev_sub;</"
"command>()"

# (filtered) msgid "&no-i18n-cmd_window_prev_sub;"
# (filtered) msgstr ""
# (filtered) msgid ""
# (filtered) "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_prev_sub;</"
# (filtered) "command>()"
# (filtered) msgstr ""
#. Tag: para
#: index.docbook:4177
#, no-c-format
msgid ""
"Activates the <emphasis>previous</emphasis> sub-window when in MDI or Tab "
"mode. If the previous sub-window is minimized it will be restored."
msgstr ""
"Aktiviert das <emphasis>vorhergehende</emphasis> Unterfenster wenn im MDI- "
"oder Unterfenster-Modus. Wenn das vorhergehende Unterfenster minimiert war, "
"wird es wiederhergestellt."

#. Tag: title
#: index.docbook:4185
#, no-c-format
msgid "&no-i18n-cmd_window_resize;"
msgstr "&no-i18n-cmd_window_resize;"

#. Tag: title
#: index.docbook:4187
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_resize;</"
"command>( <replaceable>class</replaceable>, <replaceable>width</"
"replaceable>, <replaceable>height</replaceable> )"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_resize;</"
"command>( <replaceable>Klasse</replaceable>, <replaceable>Breite</"
"replaceable>, <replaceable>Höhe</replaceable> )"

#. Tag: para
#: index.docbook:4192
#, no-c-format
msgid ""
"Changes the size of a window, identified by its <replaceable>class</"
"replaceable> name to a new <replaceable>width</replaceable> and "
"<replaceable>height</replaceable>. The change will only be applied to the "
"first window that has the given class name, therefore you should make sure "
"that you have only one instance of the given window when this command gets "
"executed."
msgstr ""
"Ändert die Größe eines Fensters, das anhand seiner <replaceable>Klasse</"
"replaceable> identifiziert wird auf eine neue <replaceable>Breite</"
"replaceable> und <replaceable>Höhe</replaceable>. Die Änderung wirkt sich "
"nur auf das erste Fenster mit dem angegebenen Klassen-Namen aus, deshalb "
"sollten Sie sicher stellen dass nur eine einzige Instanz des angegebenen "
"Fensters existiert wenn der Befehl ausgeführt wird."

#. Tag: entry
#: index.docbook:4206
#, no-c-format
msgid "<parameter>width</parameter>:"
msgstr "<parameter>Breite</parameter>:"

#. Tag: entry
#: index.docbook:4207
#, no-c-format
msgid "new width of the window (in pixels)"
msgstr "neue Breite des Fensters (in Pixel)"

#. Tag: entry
#: index.docbook:4208
#, no-c-format
msgid "<parameter>height</parameter>:"
msgstr "<parameter>Höhe</parameter>:"

#. Tag: entry
#: index.docbook:4209
#, no-c-format
msgid "new height of the window (in pixels)"
msgstr "neue Höhe des Fensters (in Pixel)"

#. Tag: title
#: index.docbook:4214
#, no-c-format
msgid "&no-i18n-cmd_window_screenshot;"
msgstr "&no-i18n-cmd_window_screenshot;"

#. Tag: title
#: index.docbook:4216
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_screenshot;</"
"command>( <replaceable>class</replaceable>, <replaceable>filename</"
"replaceable> )"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_screenshot;</"
"command>( <replaceable>Klasse</replaceable>, <replaceable>Dateiname</"
"replaceable> )"

#. Tag: para
#: index.docbook:4220
#, no-c-format
msgid ""
"Takes a screenshot of a window, identified by its <replaceable>class</"
"replaceable> and saves it to a file. The screenshot will be taken from the "
"first window that has the given class name, therefore you should make sure "
"that you have only one instance of the given window when this command gets "
"executed. Currently the format of the file is hardcoded and has to be "
"<literal>*.png</literal>."
msgstr ""
"Erstellt ein Bildschirmfoto eines Fensters, das über seine "
"<replaceable>Klasse</replaceable> identifiziert wird und speichert es in "
"einer Datei. Das Bildschirmfoto wird nur vom ersten Fenster erstellt das den "
"angegebenen Klassen-Namen hat, deshalb sollten Sie sicher stellen dass nur "
"eine einzige Instanz des angegebenen Fensters existiert wenn der Befehl "
"ausgeführt wird.Das Dateiformat ist aktuell festgelegt und muss <literal>*."
"png</literal> sein."

#. Tag: entry
#: index.docbook:4235
#, no-c-format
msgid ""
"name of the file to save the screenshot, must have the extension <literal>*."
"png</literal>"
msgstr ""
"Dateiname unter dem das Bildschirmfoto gespeichert werden soll, muss die "
"Erweiterung <literal>*.png</literal> haben"

#. Tag: title
#: index.docbook:4241
#, no-c-format
msgid "&no-i18n-cmd_window_sendkey;"
msgstr "&no-i18n-cmd_window_sendkey;"

#. Tag: title
#: index.docbook:4243
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_sendkey;</"
"command>( <replaceable>class</replaceable>, <replaceable>key code</"
"replaceable> )"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-cmd_window_sendkey;</"
"command>( <replaceable>Klasse</replaceable>, <replaceable>Tastenkürzel</"
"replaceable> )"

#. Tag: para
#: index.docbook:4247
#, no-c-format
msgid ""
"Sends a key press and release event to a window, identified by its "
"<replaceable>class</replaceable> name. The key will only be sent to the "
"first window that has the given class name, therefore you should make sure "
"that you have only one instance of the given window when this command gets "
"executed."
msgstr ""
"Sendet ein Tastendruck- und Loslassen-Ereignis an ein Fenster das über seine "
"<replaceable>Klasse</replaceable> identifiziert wird. Die Ereignisse werden "
"nur zu dem ersten Fenster gesendet das den angegebenen Klassen-Namen hat, "
"deshalb sollten Sie sicher stellen dass nur eine einzige Instanz des "
"angegebenen Fensters existiert wenn der Befehl ausgeführt wird."

#. Tag: entry
#: index.docbook:4259
#, no-c-format
msgid "<parameter>key code</parameter>:"
msgstr "<parameter>Tastenkürzel</parameter>:"

#. Tag: entry
#: index.docbook:4260
#, no-c-format
msgid ""
"the key code that should be sent, using the same syntax as used for setting "
"up menus"
msgstr ""
"Das zu sendende Tastenkürzel, gleiche Syntax wie beim Einrichten der Menüs"

#. Tag: para
#: index.docbook:4264
#, no-c-format
msgid ""
"Description of the parameter <link linkend=\"cmd_menu_param_hotkey"
"\"><parameter>hotkey</parameter></link> of the <command>&no-i18n-cmd_menu;</"
"command>() command."
msgstr ""
"Beschreibung des Parameters <link linkend=\"cmd_menu_param_hotkey"
"\"><parameter>Tastenkürzel</parameter></link> des Befehls <command>&no-i18n-"
"cmd_menu;</command>()."

#. Tag: title
#: index.docbook:4273
#, no-c-format
msgid "&no-i18n-cmd_window_tile;"
msgstr "&no-i18n-cmd_window_tile;"

#. Tag: title
#: index.docbook:4275
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_tile;</command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_tile;</command>()"

# (filtered) msgid "&no-i18n-cmd_window_tile;"
# (filtered) msgstr ""
# (filtered) msgid ""
# (filtered) "&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_tile;</command>()"
# (filtered) msgstr ""
#. Tag: para
#: index.docbook:4276
#, no-c-format
msgid ""
"Tiles all sub-windows when in MDI mode, using some scheme of &plasma;. All "
"sub-windows that are currently minimized stay minimized, they will not be "
"restored."
msgstr ""
"Kachelt alle Unterfenster wenn im MDI-Modus, auf eine von &plasma; "
"vorgegebene Art und Weise. Alle aktuell minimierten Unterfenster bleiben "
"minimiert, sie werden nicht wiederhergestellt."

#. Tag: title
#: index.docbook:4285
#, no-c-format
msgid "&no-i18n-cmd_window_tile_vertical;"
msgstr "&no-i18n-cmd_window_tile_vertical;"

#. Tag: title
#: index.docbook:4287
#, no-c-format
msgid ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_tile_vertical;</"
"command>()"
msgstr ""
"&i18n-cmd_syntax;<command>&no-i18n-tag;&no-i18n-cmd_window_tile_vertical;</"
"command>()"

# (filtered) msgid "&no-i18n-cmd_window_tile_vertical;"
# (filtered) msgstr ""
#. Tag: para
#: index.docbook:4288
#, no-c-format
msgid ""
"Tiles all sub-windows vertically when in MDI mode. All windows that are "
"currently minimized stay minimized, they will not be restored."
msgstr ""
"Ordnet alle Unterfenster untereinander an wenn im MDI-Modus. Alle aktuell "
"minimierten Unterfenster bleiben minimiert, sie werden nicht "
"wiederhergestellt."

