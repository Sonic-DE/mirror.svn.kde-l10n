#. Tag: para
#: index.docbook:17
#, no-c-format
msgid ""
"<acronym>ldap</acronym> is the lightweight directory access protocol. It "
"provides access to an X.500 directory, or to a stand-alone <acronym>LDAP</"
"acronym> server."
msgstr ""
"<acronym>ldap</acronym> ist das Lightweight Directory Access Protocol. Es "
"bietet Zugriff auf X.500-Verzeichnisse oder <acronym>LDAP</acronym>-Server."

#. Tag: para
#: index.docbook:21
#, no-c-format
msgid "You can use the ldap KIO worker as follows:"
msgstr "Sie können das ldap-Modul folgendermaßen nutzen:"

#. Tag: para
#: index.docbook:23
#, no-c-format
msgid ""
"<userinput>ldap://host:port/ou=People,o=where,c=de??sub</userinput> for a "
"subtree-query"
msgstr ""
"<userinput>ldap://host:port/ou=People,o=where,c=de??sub</userinput> für eine "
"Suche in Unterverzeichnissen"

#. Tag: para
#: index.docbook:26
#, no-c-format
msgid ""
"or <userinput>ldap://host:port/cn=MM,ou=People,o=where,c=de??base</"
"userinput> for a complete branch."
msgstr ""
"oder <userinput>ldap://host:port/cn=MM,ou=People,o=where,c=de??base</"
"userinput> für einen kompletten Zweig."
