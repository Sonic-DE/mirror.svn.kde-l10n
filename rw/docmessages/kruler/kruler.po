#. Tag: title
#: index.docbook:51
#, no-c-format
msgid "Introduction"
msgstr "Intangiriro"

#. Tag: para
#: index.docbook:53
#, fuzzy, no-c-format
msgid ""
"&kruler; is a very simple application, with only one aim in life. To measure "
"pixel distances on your screen. It is useful for working on layout of "
"dialogs, web pages &etc;"
msgstr ""
"&kruler; ni A Byoroheje Porogaramu , Na: Rimwe in Ubuzima . ku Mugaragaza . "

#. Tag: para
#: index.docbook:57
#, fuzzy, no-c-format
msgid ""
"To start &kruler;, choose <menuchoice><guimenu>Applications</"
"guimenu><guisubmenu>Utilities</guisubmenu> <guisubmenu>More Applications</"
"guisubmenu> <guimenuitem>Screen Ruler</guimenuitem></menuchoice> from your "
"application menu."
msgstr ""
"Tangira &vendorShortName; &kruler; , Hitamo... <menuchoice> <guimenu> </"
"guimenu> <guimenuitem> MukusanyaKDE </guimenuitem> </menuchoice> Kuva: "
"<guimenu> </guimenu> Ibikubiyemo . "

