#. Tag: title
#: index.docbook:58
#, no-c-format
msgid "Introduction"
msgstr "Intangiriro"

#. Tag: para
#: index.docbook:60
#, fuzzy, no-c-format
msgid ""
"This is a module for scheduling programs to run in the background. It is a "
"graphical user interface to <command>cron</command>, the &UNIX; system "
"scheduler."
msgstr ""
"&kcron; ni Porogaramu ya:  Kugena ingengabihe Porogaramu Kuri Gukoresha in i "
"Mbuganyuma . ni A Umukoresha Imigaragarire Kuri <command> </command> , i "
"&UNIX; Sisitemu . "

#. Tag: para
#: index.docbook:64
#, fuzzy, no-c-format
msgid ""
"Don't forget to tell your system to start the <filename>crond</filename> "
"cron daemon first, or the settings in this module will not work."
msgstr ""
"Kuri Sisitemu Kuri Tangira &vendorShortName; i <filename> </filename> "
"Dayimoni Itangira , Cyangwa &kcron; Akazi . "

