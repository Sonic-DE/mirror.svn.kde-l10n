"<menuchoice><guimenu>Format</guimenu><guisubmenu>Column</guisubmenu> "
"<guimenuitem>Equalize Column</guimenuitem></menuchoice>."
msgstr ""
"Ubwoko A Umubare Bya Urubariro: Cyangwa Inkingi: i Ingano: ku Hanyuma "
"<menuchoice> <guimenu> </guimenu> <guisubmenu> </guisubmenu> <guimenuitem> </"
