#, fuzzy, no-c-format
msgid ""
"The absolute value of x. &eg;, <userinput>|&minus;4|</userinput> returns 4."
msgstr "IKIMENYETSO . &eg; , <userinput> 2 ^ 4 </userinput> 16 . "

