#, fuzzy, no-c-format
msgid "<term>/</term>"
msgstr "< Ijambo > < /Ijambo > "

#. Tag: para
#: index.docbook:989
#, fuzzy, no-c-format
msgid ""
"The asterisk and slash symbols perform multiplication and division . &eg;, "
"<userinput>3*4/2</userinput> returns 6."
msgstr ""
"na AKARONGOKABERAMYE Ibimenyetso Gukuba (*) na . &eg; , <userinput> 3 * 4 /2 "
"</userinput> 6 . "

