#. Tag: title
#: man-cheatmake.1.docbook:32
#, no-c-format
msgid "Description"
msgstr "Isobanuramiterere"

#. Tag: para
#: man-cheatmake.1.docbook:34
#, fuzzy, no-c-format
msgid ""
"<command>cheatmake</command> is used to save time when recompiling. It can "
"fool make into skipping files that haven't changed in a meaningful way. This "
"can be used for instance when you change a comment in a file but none of the "
"actual code."
msgstr ""
"<command> </command> ni Byakoreshejwe Kuri Kubika Igihe Ryari: . Ubwoko "
"Gusimbuka: %s Idosiye Byahinduwe in A . Byakoreshejwe ya:  Urugero Ryari: "
"Guhindura... A Icyo wongeraho in A Idosiye Ntana kimwe Bya i "
"Inyandikoporogaramu . "

#. Tag: para
#: man-cheatmake.1.docbook:39
#, fuzzy, no-c-format
msgid "This utility is part of the &kde; Software Development Kit."
msgstr "ni Inzira %s Bya i &kde; . "

