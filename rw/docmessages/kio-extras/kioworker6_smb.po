#. Tag: para
#: index.docbook:18
#, fuzzy, no-c-format
msgid ""
"The smb worker enables you to browse the shares of a &Windows; (or Samba) "
"network."
msgstr "Kuri Gushakisha i Bya A &Windows; ( Cyangwa ) urusobe . "

#. Tag: para
#: index.docbook:23
#, fuzzy, no-c-format
msgid ""
"To see the workgroups, enter <userinput><command>smb:/</command></userinput>."
msgstr "i , Injiza <userinput> <command> : /</command> </userinput> . "

#. Tag: para
#: index.docbook:27
#, fuzzy, no-c-format
msgid ""
"<userinput><command>smb://</command><replaceable>a_workgroup</replaceable></"
"userinput> will list the hosts in this workgroup."
msgstr ""
"<userinput> <command> : //</command> <replaceable> </replaceable> </"
"userinput> Urutonde i in iyi Itsinda ry'akazi: . "

#. Tag: para
#: index.docbook:31
#, fuzzy, no-c-format
msgid ""
"To see the shares of a host, enter <userinput><command>smb://</"
"command><replaceable>the_host</replaceable></userinput> or "
"<userinput><command>smb:/</command><replaceable>a_workgroup</replaceable>/"
"<replaceable>the_host</replaceable></userinput>."
msgstr ""
"i Bya A Inturo: , Injiza <userinput> <command> : //</command> <replaceable> "
"</replaceable> </userinput> Cyangwa <userinput> <command> : /</command> "
"<replaceable> </replaceable> /<replaceable> </replaceable> </userinput> . "

#. Tag: para
#: index.docbook:37
#, fuzzy, no-c-format
msgid ""
"To access a share directly enter <userinput><command>smb://</"
"command><replaceable>the_host/the_share</replaceable></userinput> or "
"<userinput><command>smb:/</command><replaceable>a_workgroup</replaceable>/"
"<replaceable>the_host</replaceable>/<replaceable>the_share</replaceable></"
"userinput>"
msgstr ""
"A Gusangiza Injiza <userinput> <command> : //</command> <replaceable> /</"
"replaceable> </userinput> Cyangwa <userinput> <command> : /</command> "
"<replaceable> </replaceable> /<replaceable> </replaceable> /<replaceable> </"
"replaceable> </userinput> "

#. Tag: para
#: index.docbook:44
#, fuzzy, no-c-format
msgid "The smb worker requires that you have libsmbclient to use this worker."
msgstr "Kuri Koresha iyi . "

#. Tag: para
#: index.docbook:48
#, fuzzy, no-c-format
msgid ""
"You can set your default user name and password in the &systemsettings; "
"category <guilabel>Network</guilabel> in "
"<menuchoice><guisubmenu>Connectivity</guisubmenu><guimenuitem> Windows "
"Shares</guimenuitem></menuchoice>. This is especially useful if you are a "
"member of a &Windows; <acronym>NT</acronym> domain. There you can also set "
"your workgroup name, but in most cases this is not required. The worker will "
"ask for your username and password if a default is not set."
msgstr ""
"Gushyiraho Mburabuzi Umukoresha Izina: na Ijambobanga in i &kcontrol; in "
"<menuchoice> <guisubmenu> </guisubmenu> <guimenuitem> </guimenuitem> </"
"menuchoice> . ni NIBA A Bya A &Windows; <acronym> </acronym> Urubuga: . "
"Gushyiraho Itsinda ry'akazi: Izina: , in iyi ni OYA Bya ngombwa . ask ya:  "
"Izina ry'ukoresha na Ijambobanga NIBA A Mburabuzi ni OYA Gushyiraho . "

