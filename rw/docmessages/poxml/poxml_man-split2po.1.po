#. Tag: para
#: man-split2po.1.docbook:33
#, fuzzy, no-c-format
msgid ""
"<command>split2po</command> is a command-line tool that takes the two given "
"DocBook XML files and produces a <command>gettext</command> message file (PO-"
"file) that represents the changes between them. The resulting PO-file is "
"sent to standard output."
msgstr ""
"<command> </command> ni A command - Umurongo: i Kabiri Idosiye na A "
"<command> </command> &Ubutumwa Idosiye ( - Idosiye ) i Amahinduka hagati . - "
"Idosiye ni Yoherejwe: Kuri Bisanzwe Ibisohoka . "

#. Tag: para
#: man-split2po.1.docbook:39
#, fuzzy, no-c-format
msgid ""
"<filename>translated-XML</filename> must be the result of translating "
"<filename>original-XML</filename> into another language. It is this "
"translation that the resulting PO-file will represent."
msgstr ""
"<filename> - </filename> i Igisubizo Bya <filename> ~Umwimerere - </"
"filename> Ururimi: . ni iyi Umwandiko  wahinduwe ururimi i - Idosiye . "

