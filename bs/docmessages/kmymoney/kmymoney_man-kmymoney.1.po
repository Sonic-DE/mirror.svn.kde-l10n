#. Tag: member
#: man-kmymoney.1.docbook:192
#, fuzzy, no-c-format
#| msgid ""
#| "The full documentation for &kmymoney; is maintained as a docbook manual. "
#| "If the &khelpcenter; program is properly installed at your site, the "
#| "command <userinput><command>khelpcenter</command> <parameter>help:/"
#| "kmymoney</parameter></userinput> should give you access to the complete "
#| "manual. Alternatively the manual can be browsed in &konqueror; giving it "
#| "the <acronym>URL</acronym> <ulink url=\"help:/kmymoney\">help:/kmymoney</"
#| "ulink>"
msgid ""
"The full documentation for &kmymoney; is maintained as a docbook manual. If "
"the &khelpcenter; program is properly installed at your site, the command "
"<userinput> <command>khelpcenter</command> <parameter>help:/kmymoney</"
"parameter> </userinput> should give you access to the complete manual. "
"Alternatively the manual can be browsed in &konqueror; giving it the "
"<acronym>URL</acronym> <ulink url=\"help:/kmymoney\">help:/kmymoney</ulink>"
msgstr ""
"Potpuna dokumentacija za &kmymoney; je sadržana u obliku docbook priručnika. "
"Ako je &khelpcenter; program ispravno instaliran na vašoj stranici, komanda "
"<userinput><command>khelpcenter</command> <parameter>help:/kmymoney</"
"parameter></userinput> bi vam trebala omogućiti pristup kompletnom "
"priručniku. Alternativno, priručnik se može pregledati u &konqueror;-u tako "
"se u njega ukuca <acronym>URL</acronym> <ulink url=\"help:/kmymoney\">help:/"
"kmymoney</ulink>."

