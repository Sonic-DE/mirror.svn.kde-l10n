#. Tag: option
#: man-kmymoney.1.docbook:164
#, no-c-format
msgid "--trace"
msgstr "--trace"

#. Tag: para
#: man-kmymoney.1.docbook:166
#, no-c-format
msgid ""
"Turn on program traces. This option is only available when &kmymoney; is "
"compiled in debug mode."
msgstr ""
"Uključite tragove programa. Ova opcija je dostupna samo je kada &kmymoney; "
"kompajliran u debug modu."

#. Tag: option
#: man-kmymoney.1.docbook:174
#, no-c-format
msgid "--dump-actions"
msgstr "--dump-actions"

#. Tag: para
#: man-kmymoney.1.docbook:176
#, fuzzy, no-c-format
#| msgid ""
#| "Dump the names of all defined KAction objects to stdout and quit. This "
#| "option is only available when &kmymoney; is compiled in debug mode."
msgid ""
"Dump the names of all defined QAction objects to stdout and quit. This "
"option is only available when &kmymoney; is compiled in debug mode."
msgstr ""
"Promijenite imena svih definisanih KAction objekata u stdout i quit. Ova "
"opcija je dostupna samo kada je &kmymoney; kompajliran u debug modu."

