#~ msgid "$<envar>KDE_LANG</envar>"
#~ msgstr "$<envar>KDE_LANG</envar>"

#~ msgid ""
#~ "Language locale setting to use. This option makes it possible to set "
#~ "another language environment for a program than what is the default. The "
#~ "correct language pack for this language has to be installed for this "
#~ "option to work. The default language when there is none set is en_US. "
#~ "When deciding upon a language, the following resources are looked up, in "
#~ "order: <envar>KDE_LANG</envar>, configuration file, <envar>LC_CTYPE</"
#~ "envar>, <envar>LC_MESSAGES</envar>, <envar>LC_ALL</envar>, <envar>LANG</"
#~ "envar>."
#~ msgstr ""
#~ "Postavka upotrebe lokalnog jezika. Ova opcija je dostupna samo kada je za "
#~ "neki program postavljen neki drugi jezik u odnosu na onaj koji je "
#~ "unaprijed određen za upotrebu. Odgovarajući jezički paket mora biti "
#~ "instaliran da bi ova opcija radila. Ako ova opcija nije korištena "
#~ "unaprijed određeni jezik za upotrebu je en_US. Prilikom donošenja odluke "
#~ "o tome koji će se jezik koristiti, trebaju se pogledati sljedeći resursi, "
#~ "u ovom redoslijedu: <envar>KDE_LANG</envar>, konfiguracijska datoteka, "
#~ "<envar>LC_CTYPE</envar>, <envar>LC_MESSAGES</envar>, <envar>LC_ALL</"
#~ "envar>, <envar>LANG</envar>."

#~ msgid "$<envar>KDE_UTF8_FILENAMES</envar>"
#~ msgstr "$<envar>KDE_UTF8_FILENAMES</envar>"

#~ msgid ""
#~ "Assume that all filenames are in UTF-8 format regardless of the current "
#~ "language setting. Otherwise the filename format is defined by the "
#~ "language."
#~ msgstr ""
#~ "Pretpostavi da su sva imena datoteka u UTF-8 formatu neovisno od trenutne "
#~ "postavke jezika. U suprotnom, format naziva datoteke je definisan jezikom "
#~ "koji se koristi."

#~ msgid "$<envar>KDE_MULTIHEAD</envar>"
#~ msgstr "$<envar>KDE_MULTIHEAD</envar>"

#~ msgid ""
#~ "If this variable has the value true multihead multiple display mode is "
#~ "enabled. The KDE display will be shared over more than one screen."
#~ msgstr ""
#~ "Ako ova varijabla ima vrijednost tačno, uključen je višeglavni višestruki "
