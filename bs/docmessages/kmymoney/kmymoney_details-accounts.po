#. Tag: title
#: details-accounts.docbook:786
#, no-c-format
msgid "Editing Account Information"
msgstr "Uređivanje informacija računa"

#. Tag: para
#: details-accounts.docbook:787
#, fuzzy, no-c-format
#| msgid ""
#| "To edit a particular account, right-click that account and choose "
