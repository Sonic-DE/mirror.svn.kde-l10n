#: details-search.docbook:338
#, no-c-format
msgid "Search results"
msgstr "Rezultati pretrage"

#. Tag: para
#: details-search.docbook:339
#, fuzzy, no-c-format
#| msgid ""
#| "The <quote>Result</quote> tab displays the Date, Account, Details, "
#| "Reconciliation status, Payment, and Deposit for each transaction that "
#| "matches the search criteria you have entered. Right clicking on the "
#| "header row of the results list allows you to alter the sort order of the "
#| "results."
msgid ""
"The <guilabel>Result</guilabel> tab displays the Entry (entry date, "
"optional,) Date (posting date,) Account, Payee, Details (memo,) C "
"(reconciliation status,) Decrease, and Increase for each transaction that "
"matches the search criteria you have entered. Clicking the &RMB; on the "
"header row of the results list allows you to toggle the display of the "
"optional columns."
msgstr ""
"Kartica <quote>Rezultati</quote> prikazuje Datum, Račun, Detalje, Status "
"usklađenosti, Uplatu i Depozit za svaku transakciju koja odgovara kriteriju "
"pretrage. Desni klik na red u zaglavlju liste rezultata vam omogućava da "
"promijenite redoslijed rezultata."

#. Tag: para
#: details-search.docbook:347
