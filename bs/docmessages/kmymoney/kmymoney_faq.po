#~ msgid ""
#~ "I compiled from source, but the version number in the Help->About dialog "
#~ "no longer gets changed to show the latest git commit, like it used to?"
#~ msgstr ""
#~ "Kompajlirao/la sam iz izvora, ali broj verzije u Pomoć->O aplikaciji "
#~ "dijalogu više se ne mijena tako da prikazuje najnovije git promjene, kao "
#~ "ranije?"

#~ msgid ""
