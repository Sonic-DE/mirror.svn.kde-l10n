#. Tag: title
#: details-investments.docbook:791
#, fuzzy, no-c-format
#| msgid "Updating Prices"
msgid "Updating Security Prices"
msgstr "Ažuriranje cijena"

#. Tag: para
#: details-investments.docbook:792
#, fuzzy, no-c-format
#| msgid ""
#| "There are two ways of updating the prices for your investments. You can "
#| "either enter the new price manually or have &kappname; fetch it from the "
