msgstr "&krdc; postavke - kartica <guilabel>VNC Zadane postavke</guilabel>"

#. Tag: phrase
#: index.docbook:475
#, no-c-format
msgid "&krdc; preferences - <guilabel>VNC Defaults</guilabel> profiles tab"
msgstr ""
"&krdc; postavke - kartica profila <guilabel>VNC Zadane postavke</guilabel>"

#. Tag: screeninfo
#: index.docbook:484
#, no-c-format
msgid "&krdc; preferences - <guilabel>RDP Defaults</guilabel> tab"
msgstr "&krdc; postavke - kartica <guilabel>RDP Zadane postavke</guilabel>"

#. Tag: phrase
#: index.docbook:490
#, no-c-format
msgid "&krdc; preferences - <guilabel>RDP Defaults</guilabel> profiles tab"
msgstr ""
"&krdc; postavke - kartica profila <guilabel>RDP Zadane postavke </guilabel>"

#. Tag: title
#: index.docbook:503
#, no-c-format
msgid "Questions and Answers"
msgstr "Pitanja i odgovori"

#. Tag: para
#: index.docbook:518
#, no-c-format
msgid "Why does <acronym>RDP</acronym> support not work?"
msgstr "Zašto <acronym>RDP</acronym> podrška ne radi?"

#. Tag: para
#: index.docbook:521
#, no-c-format
msgid ""
"<acronym>RDP</acronym> support in &krdc; depends on xfreerdp (FreeRDP). Make "
"sure that you have installed this runtime dependency."
msgstr ""
"<acronym>RDP</acronym> podrška u &krdc; zavisi od xfreerdp (FreeRDP). "
"Provjerire da li ste ovo instalirali."

