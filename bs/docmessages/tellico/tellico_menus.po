msgstr "<guimenu>Datoteka</guimenu> <guimenuitem>Otvori nedavnu</guimenuitem>"

#. Tag: para
#: menus.docbook:63
#, no-c-format
msgid ""
"This command <action>opens a file</action> from a submenu that contains a "
