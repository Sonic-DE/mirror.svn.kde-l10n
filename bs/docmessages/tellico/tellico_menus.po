"uključujući <ulink url=\"http://amazon.com\">Amazon.com</ulink>."

#. Tag: menuchoice
#: menus.docbook:329
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>J</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Advanced Filter...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>J</keycap></keycombo> </shortcut> "
"<guimenu>Izmijeni</guimenu> <guimenuitem>Napredni Filter...</guimenuitem>"

#. Tag: para
#: menus.docbook:339
#, no-c-format
msgid ""
"This command <action>opens the <interface>Advanced Filter Dialog</"
"interface></action>."
msgstr ""
"Ova komanda <action>otvara <interface>Napredni Filter Dijalog</interface></"
"action>."

#. Tag: title
#: menus.docbook:350
