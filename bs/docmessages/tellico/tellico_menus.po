#. Tag: title
#: menus.docbook:193
#, no-c-format
msgid "The Edit Menu"
msgstr ""

#. Tag: menuchoice
#: menus.docbook:201
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>Z</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Undo</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>Z</keycap></keycombo> </shortcut> "
"<guimenu>Izmijeni</guimenu> <guimenuitem>Poništi</guimenuitem>"

#. Tag: para
#: menus.docbook:211
#, no-c-format
msgid ""
"This command <action>undoes the previous action</action>. Not all actions "
"are supported by Undo."
msgstr ""
"Ova komanda<action>poništava prethodnu radnju</action>. Sve radnje nisu "
"podržane  sa Poništi."

#. Tag: menuchoice
#: menus.docbook:217
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;&Shift;<keycap>Z</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Redo</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;&Shift;<keycap>Z</keycap></keycombo> </shortcut> "
"<guimenu>Izmijeni</guimenu> <guimenuitem>Vrati</guimenuitem>"

#. Tag: para
#: menus.docbook:227
#, no-c-format
msgid "This command <action>reverts a previous Undo</action>."
msgstr "Ova komanda <action>vraća prvobitni Poništi</action>."

#. Tag: menuchoice
#: menus.docbook:233
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>X</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Cut</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>X</keycap></keycombo> </shortcut> "
"<guimenu>Izmijeni</guimenu> <guimenuitem>Isijeci</guimenuitem>"

#. Tag: para
#: menus.docbook:243
#, no-c-format
msgid ""
"This command <action>removes the selected text</action>, if any, and "
"<action>places a copy of the removed text in the clipboard</action>."
msgstr ""
"Ova komanda <action>uklanja selektovani tekst</action>, ako ijedan, i "
"<action>i postavlja kopije iklonjenog teksta na clipboard</action>."

#. Tag: menuchoice
#: menus.docbook:249
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>C</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Copy</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>C</keycap></keycombo> </shortcut> "
"<guimenu>Izmijeni</guimenu> <guimenuitem>Kopiraj</guimenuitem>"

