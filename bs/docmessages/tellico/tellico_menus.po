msgstr "<guimenu>Datoteka</guimenu> <guimenuitem>Nova</guimenuitem>"

#. Tag: para
#: menus.docbook:34
#, fuzzy, no-c-format
#| msgid ""
#| "This command <action>creates a new collection</action>. &appname; "
#| "supports <link linkend=\"collection-types\">12 default collection types</"
