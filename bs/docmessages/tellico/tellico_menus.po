"Ova komanda <action>selektuje cijeli unos</action>u kolekciji, u "
"<interface>Kolona Pogled</interface>."

#. Tag: menuchoice
#: menus.docbook:297
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;&Shift;<keycap>A</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Deselect</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;&Shift;<keycap>A</keycap></keycombo> </shortcut> "
"<guimenu>Edituj</guimenu> <guimenuitem>Deselektuj</guimenuitem>"

#. Tag: para
#: menus.docbook:307
#, no-c-format
msgid ""
"This command <action>deselects all the entries</action> in the collection."
