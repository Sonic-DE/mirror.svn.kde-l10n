"<shortcut> <keycombo>&Ctrl;<keycap>Y</keycap></keycombo> </shortcut> "
"<guimenu>Kolekcija</guimenu> <guimenuitem>Duplikat Unosa</guimenuitem>"

#. Tag: para
#: menus.docbook:399
#, no-c-format
msgid ""
"This command <action>copies, or duplicates, the selected entries</action> as "
"new entries in the collection."
msgstr ""
"Ova komanda <action>kopira, ili duplicira, selektovani unos</action> kao "
"novi unos u kolekciji."

#. Tag: menuchoice
#: menus.docbook:405
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>D</keycap></keycombo> </shortcut> "
"<guimenu>Collection</guimenu> <guimenuitem>Delete Entry</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>D</keycap></keycombo> </shortcut> "
"<guimenu>Kolekcija</guimenu> <guimenuitem>Izbriši unos</guimenuitem>"

#. Tag: para
#: menus.docbook:415
#, no-c-format
msgid "This command <action>deletes the selected entries</action>."
msgstr "Ova komanda <action>briše selektovani unos</action>."

#. Tag: menuchoice
#: menus.docbook:421
#, no-c-format
msgid "<guimenu>Collection</guimenu> <guimenuitem>Merge Entries</guimenuitem>"
msgstr "<guimenu>Kolekcija</guimenu> <guimenuitem>Spoji Unos</guimenuitem>"

#. Tag: para
#: menus.docbook:433
#, no-c-format
msgid "This command <action>merges the selected entries</action>."
msgstr "Ova komanda <action>spaja selektovani unos</action>."

#. Tag: menuchoice
#: menus.docbook:439
#, no-c-format
msgid "<guimenu>Collection</guimenu> <guimenuitem>Update Entry</guimenuitem>"
msgstr "<guimenu>Kolekcija</guimenu> <guimenuitem>Ažuriraj Unos</guimenuitem>"

#. Tag: para
#: menus.docbook:446
#, no-c-format
msgid ""
"This menu contains a list of all available data sources, and can be used to "
"automatically query the source and <action>update the selected entries</"
"action>."
msgstr ""
"Ovaj meni sadrži listu svih dostupnih izvora podataka, i može biti korišten "
"za automatsko ispitivanje izvora i <action>i ažuriranje selektovanih unosa</"
"action>."

#. Tag: menuchoice
#: menus.docbook:453
#, no-c-format
msgid "<guimenu>Collection</guimenu> <guimenuitem>Check-out</guimenuitem>"
msgstr "<guimenu>Kolekcija</guimenu> <guimenuitem>Check-out</guimenuitem>"

#. Tag: para
#: menus.docbook:460
#, no-c-format
msgid ""
"This command <action>opens a dialog box for loaning the selected entries.</"
"action>."
msgstr ""
"Ova komanda <action>otvara dijalog okvir za pozajmljivanje selektovanog "
"unosa.</action>."

#. Tag: menuchoice
#: menus.docbook:466
#, no-c-format
msgid "<guimenu>Collection</guimenu> <guimenuitem>Check-in</guimenuitem>"
msgstr "<guimenu>Kolekcija</guimenu> <guimenuitem>Check-in</guimenuitem>"

#. Tag: para
#: menus.docbook:473
#, no-c-format
