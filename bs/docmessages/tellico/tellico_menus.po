"Ova komanda <action>otvara <interface>Editor Unosa</interface> za izmjenu "
"novog unosa</action>."

#. Tag: menuchoice
#: menus.docbook:373
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>E</keycap></keycombo> </shortcut> "
"<guimenu>Collection</guimenu> <guimenuitem>Edit Entry</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>E</keycap></keycombo> </shortcut> "
"<guimenu>Kolekcija</guimenu> <guimenuitem>Izmijeni Unos</guimenuitem>"

