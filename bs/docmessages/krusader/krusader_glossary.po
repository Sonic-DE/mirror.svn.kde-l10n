#. Tag: primary
#: glossary.docbook:9
#, no-c-format
msgid "Glossary"
msgstr "Rječnik"

#. Tag: para
#: glossary.docbook:11
#, no-c-format
msgid ""
"This chapter is intended to explain the various words which have been used "
"throughout the &krusader; documentation. If you believe some acronyms or "
"terms are missing, please do not hesitate to contact the &krusader; "
"documentation team."
msgstr ""
"Ovo poglavlje je najmjenjeno da objasni raznovrsne riječi koje se koriste "
"širom &krusader; dokumentacije. Ako mislite da neki akronimi ili pojmovi "
"nedostaju, molimo da ne okljevate da kontaktirate &krusader; tim za "
"dokumentaciju."

#. Tag: para
#: glossary.docbook:16
#, fuzzy, no-c-format
#| msgid ""
#| "Thanks to <ulink url=\"http://en.wikipedia.org/\">wikipedia.org</ulink> "
#| "the free encyclopedia that anyone can edit."
msgid ""
"Thanks to <ulink url=\"https://en.wikipedia.org/\">wikipedia.org</ulink> the "
"free encyclopedia that anyone can edit."
msgstr ""
"Zahvaljujemo <ulink url=\"http://en.wikipedia.org/\">wikipedia.org</ulink> "
"besplatnoj enciklopediji koju svako može da uredi."

#. Tag: acronym
#: glossary.docbook:21
#, no-c-format
msgid "<acronym>ACL</acronym>"
msgstr "<acronym>ACL</acronym>"

#. Tag: para
#: glossary.docbook:24
#, fuzzy, no-c-format
#| msgid ""
#| "<ulink url=\"http://en.wikipedia.org/wiki/Access_control_list\"> Access "
#| "Control List</ulink>; a concept in computer security used to enforce "
#| "privilege separation. It is a means of determining the appropriate access "
#| "rights to a given object depending on certain aspects of the process that "
#| "is making the request."
msgid ""
"<ulink url=\"https://en.wikipedia.org/wiki/Access_control_list\"> Access "
"Control List</ulink>; a concept in computer security used to enforce "
"privilege separation. It is a means of determining the appropriate access "
"rights to a given object depending on certain aspects of the process that is "
"making the request."
msgstr ""
"<ulink url=\"http://en.wikipedia.org/wiki/Access_control_list\"> Pristup "
"Kontrolnoj Listi</ulink>; koncept za kompjutersku sigurnost koji provodi "
"razdvajanje privilegija. To je sredstvo za utvrđivanje adekvatnih prava "
"pristupa za dati objekat koji zavisi od odre]enih aspekata procesa koji "
"prave taj zahtjev."

#. Tag: acronym
#: glossary.docbook:35
#, no-c-format
msgid "<acronym>BSD</acronym>"
msgstr "<acronym>BSD</acronym>"

#. Tag: para
#: glossary.docbook:38
#, fuzzy, no-c-format
#| msgid ""
#| "<ulink url=\"http://en.wikipedia.org/wiki/Bsd\">Berkeley Software "
#| "Distribution</ulink>; refers to any of several free &UNIX;-compatible "
#| "operating systems, derived from &BSD; &UNIX;."
msgid ""
"<ulink url=\"https://en.wikipedia.org/wiki/Bsd\">Berkeley Software "
"Distribution</ulink>; refers to any of several free &UNIX;-compatible "
"operating systems, derived from &BSD; &UNIX;."
msgstr ""
"<ulink url=\"http://en.wikipedia.org/wiki/Bsd\">Berkeley Software "
"Distribution</ulink>; odnosi se na nekoliko besplatnih &UNIX;-kompatibilnih "
"operatvnih sistema, dostavljenih od &BSD; &UNIX;."

#. Tag: acronym
#: glossary.docbook:47
#, no-c-format
msgid "<acronym>CVS</acronym>"
msgstr "<acronym>CVS</acronym>"

#. Tag: para
#: glossary.docbook:50
#, fuzzy, no-c-format
#| msgid ""
#| "<ulink url=\"http://en.wikipedia.org/wiki/Concurrent_Versions_System\"> "
#| "Concurrent Versions System</ulink>; an important component of Source "
#| "Configuration Management (SCM). By using it, developers can record the "
#| "history of source files and documents."
msgid ""
"<ulink url=\"https://en.wikipedia.org/wiki/Concurrent_Versions_System\"> "
"Concurrent Versions System</ulink>; an important component of Source "
"Configuration Management (SCM). By using it, developers can record the "
"history of source files and documents."
msgstr ""
"<ulink url=\"http://en.wikipedia.org/wiki/Concurrent_Versions_System\"> "
"Concurrent Versions System</ulink>; važna komponenta od Source Configuration "
"Management (SCM). Koristeći ga, programeri mogu snimiti historiju izvornih "
"fajlova i dokumenata."

#. Tag: acronym
#: glossary.docbook:60
#, no-c-format
msgid "<acronym>DEB</acronym>"
msgstr "<acronym>DEB</acronym>"

#. Tag: para
#: glossary.docbook:63
#, fuzzy, no-c-format
#| msgid ""
#| "This is a binary file format that is used by <ulink url=\"http://en."
#| "wikipedia.org/wiki/Debian\"> <trademark class=\"registered\">Debian</"
#| "trademark></ulink> and <trademark class=\"registered\">Debian</trademark>-"
#| "based distributions. It is a suffix of a installation file specifically "
#| "built for these distributions; &eg; <filename>krusader_1.70.1-1_amd64."
#| "deb</filename>. Simply described it is a special archive containing all "
#| "the program files and their proposed location on the system."
msgid ""
"This is a binary file format that is used by <ulink url=\"https://en."
"wikipedia.org/wiki/Debian\"> &Debian;</ulink> and &Debian;-based "
"distributions. It is a suffix of a installation file specifically built for "
"these distributions; &eg; <filename>krusader_1.70.1-1_amd64.deb</filename>. "
"Simply described it is a special archive containing all the program files "
"and their proposed location on the system."
msgstr ""
"Ovaj binarni format fajla koji se koristi od strane <ulink url=\"http://en."
"wikipedia.org/wiki/Debian\"> <trademark class=\"registered\">Debian</"
"trademark></ulink> i <trademark class=\"registered\">Debian</trademark>-"
"bazne distribucije. To je sufiks od instalacionog fajla koji je namjenski "
"napravljen za distribucije; &eg; <filename>krusader_1.70.1-1_amd64.deb</"
"filename>. Drugim riječima to je posebna arhiva koja sadrži sve programske "
"fajlove i predloženu lokaciju u sistemu."

#. Tag: glossterm
#: glossary.docbook:75
#, no-c-format
msgid "&DBus;"
msgstr "&DBus;"

#. Tag: para
#: glossary.docbook:79
#, fuzzy, no-c-format
#| msgid ""
#| "<ulink url=\"http://freedesktop.org/wiki/Software/dbus\">&DBus;</ulink> "
#| "is an inter-service messaging system. Developed by &RedHat;, it was "
#| "heavily influenced by &kde; 3 <link linkend=\"glos-dcop\">&DCOP;</link>, "
#| "which it supersedes. &krusader; can use &DBus; to communicate with other "
#| "applications. On the other hand, you can use &DBus; to control &krusader; "
#| "from other applications. Just use <application>qdbusviewer</application> "
#| "to examine the possibilities."
msgid ""
"<ulink url=\"https://freedesktop.org/wiki/Software/dbus\">&DBus;</ulink> is "
"an inter-service messaging system. Developed by &RedHat;, it was heavily "
"influenced by &kde; 3 <link linkend=\"glos-dcop\">DCOP</link>, which it "
"supersedes. &krusader; can use &DBus; to communicate with other "
"applications. On the other hand, you can use &DBus; to control &krusader; "
"from other applications. Just use <application>qdbusviewer</application> to "
"examine the possibilities."
msgstr ""
"<ulink url=\"http://freedesktop.org/wiki/Software/dbus\">&DBus;</ulink> je "
"međuservisni sistem za slanje poruka. Razvijen od strane &RedHat;, bio je "
"pod velikim utjecajem &kde; 3 <link linkend=\"glos-dcop\">&DCOP;</link>, "
"koji je smijenjen. &krusader; može koristiti &DBus; da komunicira sa ostalim "
"aplikacijama. S druge strane,  možete koristiti &DBus; da kontrolišete "
"&krusader; preko drugih aplikacija. Samo koristite <application>qdbusviewer</"
"application> da istražite mogućnosti."

#. Tag: glossterm
#: glossary.docbook:89
#, fuzzy, no-c-format
#| msgid "&DCOP;"
msgid "DCOP"
msgstr "&DCOP;"

#. Tag: para
#: glossary.docbook:93
#, fuzzy, no-c-format
#| msgid ""
#| "<ulink url=\"http://en.wikipedia.org/wiki/Dcop\">Desktop Communication "
#| "Protocol</ulink>; the interprocess communication protocol used by &kde; 3 "
#| "desktop environment. It enables various &kde; 3 applications to "
#| "communicate with each other. Replaced with <link linkend=\"glos-dbus"
#| "\">&DBus;</link> in &kde; 4."
msgid ""
"<ulink url=\"https://en.wikipedia.org/wiki/Dcop\">Desktop Communication "
"Protocol</ulink>; the interprocess communication protocol used by &kde; 3 "
"desktop environment. It enables various &kde; 3 applications to communicate "
"with each other. Replaced with <link linkend=\"glos-dbus\">&DBus;</link> in "
"&kde; 4."
msgstr ""
"<ulink url=\"http://en.wikipedia.org/wiki/Dcop\">Desktop Komunikaciski "
"Protokol</ulink>; međuproceski komunikaciski protokol koji koristi &kde; 3 "
"desktop okruženje. Omogućava da različite &kde; 3 aplikacije mogu "
"komunicirati međusobno. Zamjenjeno sa <link linkend=\"glos-dbus\">&DBus;</"
"link> in &kde; 4."

#. Tag: acronym
#: glossary.docbook:104
#, no-c-format
msgid "<acronym>FAQ</acronym>"
msgstr "<acronym>FAQ</acronym>"

#. Tag: para
#: glossary.docbook:107
#, no-c-format
msgid ""
"<link linkend=\"faq\">Frequently Asked Questions</link>; a document where "
"questions that arise many times are answered. If you have a question to the "
"developers of &krusader;, you should always have a look at the <link linkend="
"\"faq\">FAQ</link> first."
msgstr ""
"<link linkend=\"faq\">Često Postavljena Pitanja</link>; dokument gdje "
"pitanja koja se javljaju mnogo puta mogu biti odgovorena. Ako imate pitanje "
"za programere &krusader;, trebali bi uvijek pogledati <link linkend=\"faq"
"\">FAQ</link> prvo."

#. Tag: glossterm
#: glossary.docbook:116
#, no-c-format
msgid "&FTP;"
msgstr "&FTP;"

#. Tag: para
#: glossary.docbook:118
#, fuzzy, no-c-format
#| msgid ""
#| "<ulink url=\"http://en.wikipedia.org/wiki/File_Transfer_Protocol\"> File "
#| "Transfer Protocol</ulink>; it is an Internet protocol that allows you to "
#| "retrieve files from so-called &FTP; servers."
msgid ""
"<ulink url=\"https://en.wikipedia.org/wiki/File_Transfer_Protocol\"> File "
"Transfer Protocol</ulink>; it is an Internet protocol that allows you to "
"retrieve files from so-called &FTP; servers."
msgstr ""
"<ulink url=\"http://en.wikipedia.org/wiki/File_Transfer_Protocol\">Protokol "
"Prenosa Datoteka</ulink>; je internet protokol koji omogućava da prenosite "
"fajlove preko takozvanog &FTP; servera."

#. Tag: glossterm
#: glossary.docbook:126
#, no-c-format
msgid "<glossterm>Git</glossterm>"
msgstr "<glossterm>Git</glossterm>"

#. Tag: para
#: glossary.docbook:129
#, fuzzy, no-c-format
#| msgid ""
#| "<ulink url=\"http://en.wikipedia.org/wiki/Git_(software)\"> Git</ulink>; "
#| "a distributed version control system that replaces <link linkend=\"gloss-"
#| "svn\">Subversion</link>. It is used by many software projects including "
#| "&kde; and &krusader;."
msgid ""
"<ulink url=\"https://en.wikipedia.org/wiki/Git_(software)\"> Git</ulink>; a "
"distributed version control system that replaces <link linkend=\"gloss-svn"
"\">Subversion</link>. It is used by many software projects including &kde; "
"and &krusader;."
msgstr ""
"<ulink url=\"http://en.wikipedia.org/wiki/Git_(software)\"> Git</ulink>; "
"distribuirana verzija kontrolnog sistema koji zamjenjuje <link linkend="
"\"gloss-svn\">Subversion</link>. Koristi se u mnogim softverskim projektima "
"uključujući &kde; i &krusader;."

#. Tag: acronym
#: glossary.docbook:139
