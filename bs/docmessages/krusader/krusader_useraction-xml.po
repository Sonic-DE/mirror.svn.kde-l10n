#. Tag: title
#: useraction-xml.docbook:8
#, fuzzy, no-c-format
#| msgid "useraction.xml"
msgid "useractions.xml"
msgstr "useraction.xml"

#. Tag: para
#: useraction-xml.docbook:9
#, fuzzy, no-c-format
#| msgid ""
#| "This appendix gives several examples of <filename>useraction.xml</"
#| "filename> files. With this you can begin to discover the power of the "
#| "<link linkend=\"useractions\">UserActions</link> and start learning how "
#| "to use them. Once you understand how to write UserActions you will find "
#| "that &krusader; is an even more powerful, customizable tool."
msgid ""
"This appendix gives several examples of <filename>useractions.xml</filename> "
"files. With this you can begin to discover the power of the <link linkend="
"\"useractions\">UserActions</link> and start learning how to use them. Once "
"you understand how to write UserActions you will find that &krusader; is an "
"even more powerful, customizable tool."
msgstr ""
"Ovaj dodatak daje nekoliko primjera <filename> useraction.xml </filename> "
"datoteka. Uz ovo možete početi da otkrivate moć <link linkend=\"useractions"
"\"> UserActions </link> i početi učiti kako ga koristiti. Jednom kad "
"shvatite kako napisati UserActions naći ćete da je &krusader; još moćniji, "
"prilagodljiv alat."

#. Tag: para
#: useraction-xml.docbook:15
#, fuzzy, no-c-format
#| msgid ""
#| "Please consider uploading your UserActions at <ulink url=\"http://www.kde-"
#| "files.org/index.php?xcontentmode=660x661x662x663\">kde-files.org</ulink> "
#| "as we are collecting them. If your UserAction is selected by us it will "
#| "be shipped with &krusader; at the next release. We provide also an <ulink "
#| "url=\"http://www.krusader.org/phpBB/viewforum.php?f=11\">UserActions "
#| "Forum</ulink>."
msgid ""
"Please consider uploading your UserActions at <ulink url=\"https://store.kde."
"org\">store.kde.org</ulink> as we are collecting them. If your UserAction is "
"selected by us it will be shipped with &krusader; at the next release."
msgstr ""
"Molimo vas da razmislite da uploadujete svoj UserActions u <ulink url="
"\"http://www.kde-files.org/index.php?xcontentmode=660x661x662x663\"> kde-"
"files.org </ulink> jer ih mi prikupljamo. Ako mi izaberemo vaš UserAction  "
"biće  isporučen sa &krusader; u sljedeće izdanje. Također pružamo  <ulink "
"url=\"http://www.krusader.org/phpBB/viewforum.php?f=11\"> UserActions Forume "
"</ulink> ."

#. Tag: para
#: useraction-xml.docbook:20
#, no-c-format
msgid "Runs <command>uptime</command>"
msgstr "Pokreće <command>uptime </command>"

#. Tag: programlisting
#: useraction-xml.docbook:21
#, no-c-format
msgid ""
"&lt;!DOCTYPE KrusaderUserActions>\n"
" &lt;KrusaderUserActions>\n"
"  &lt;action name=\"uptime\" >\n"
"  &lt;title>Up-time&lt;/title>\n"
"  &lt;tooltip>tells how long since the computer has been booted&lt;/"
"tooltip>\n"
"  &lt;icon>clock&lt;/icon>\n"
"  &lt;category>information&lt;/category>\n"
"  &lt;description same_as=\"tooltip\" />\n"
"  &lt;command executionmode=\"collect_output\" >uptime&lt;/command>\n"
"  &lt;defaultshortcut>Alt+Ctrl+U&lt;/defaultshortcut>\n"
" &lt;/action>\n"
"&lt;/KrusaderUserActions>"
msgstr ""
"&lt;tooltip>tells how long since the computer has been booted&lt;/tooltip>\n"
"  &lt;icon>clock&lt;/icon>\n"
"  &lt;category>information&lt;/category>\n"
"  &lt;description same_as=\"tooltip\" />\n"
"  &lt;command executionmode=\"collect_output\" >uptime&lt;/command>\n"
"  &lt;defaultshortcut>Alt+Ctrl+U&lt;/defaultshortcut>\n"
" &lt;/action>\n"
"&lt;/KrusaderUserActions>"

