#. Tag: title
#: compare.docbook:8
#, no-c-format
msgid "<title>Compare</title>"
msgstr "<title>Uporedi</title>"

#. Tag: para
#: compare.docbook:9
#, fuzzy, no-c-format
#| msgid ""
#| "&krusader; contains several compare functions: <guimenuitem>Compare by "
#| "Content</guimenuitem>, <guimenuitem>Compare Directories</guimenuitem> and "
#| "the <link linkend=\"synchronizer\">Synchronizer</link> compare function "
#| "(the latter is disabled at the compilation time by default)."
msgid ""
"&krusader; contains several compare functions: <guimenuitem>Compare by "
"Content</guimenuitem>, <guimenuitem>Compare Folders</guimenuitem> and the "
"<link linkend=\"synchronizer\">Synchronizer</link> compare function."
msgstr ""
"&krusader; sadrži nekoliko funkcija upoređivanja: <guimenuitem>Uporedi po "
"sadržaju</guimenuitem>, <guimenuitem>Uporedi direktorije</guimenuitem> i "
"<link linkend=\"synchronizer\">Sinhronizator</link> funkcije upoređivanja "
"(slovo je onemogućeno tokom kompilacije prema zadanim postavkama)."

#. Tag: title
#: compare.docbook:15
#, no-c-format
msgid "Compare by Content"
msgstr "Uporedi po sadržaju"

#. Tag: primary
#: compare.docbook:17 compare.docbook:34
#, no-c-format
msgid "<primary>Compare</primary>"
msgstr "<primary>Uporedi</primary>"

#. Tag: secondary
#: compare.docbook:18
#, no-c-format
msgid "Content"
msgstr "Sadržaj"

#. Tag: para
#: compare.docbook:20
#, fuzzy, no-c-format
#| msgid ""
#| "Select one file in each panel and use <menuchoice> <guimenu>File</"
#| "guimenu> <guimenuitem>Compare by content</guimenuitem> </menuchoice>. "
#| "&krusader; will open an external graphical difference tool that is <link "
#| "linkend=\"konfig-dependencies\">configured</link>. &kompare;, <ulink url="
#| "\"http://kdiff3.sourceforge.net\"><application>KDiff3</application></"
#| "ulink> and <ulink url=\"http://furius.ca/xxdiff/\"><application>xxdiff</"
#| "application></ulink> are supported."
msgid ""
"Select one file in each panel and use <menuchoice> <guimenu>File</guimenu> "
"<guimenuitem>Compare by content...</guimenuitem> </menuchoice>. &krusader; "
"will open an external graphical difference tool that is <link linkend="
"\"konfig-dependencies\">configured</link>. &kompare;, <ulink url=\"https://"
"www.kde.org/applications/development/kdiff3/\"><application>KDiff3</"
"application></ulink> and <ulink url=\"http://furius.ca/xxdiff/"
"\"><application>xxdiff</application></ulink> are supported."
msgstr ""
"Odaberite jednu datoteku iz svake ploče i koristite <menuchoice> "
"<guimenu>Datoteka</guimenu> <guimenuitem>Uporedi prema sadržaju</"
"guimenuitem> </menuchoice>. &krusader; će otvoriti vanjski grafički alat za "
"razlike koji je <link linkend=\"konfig-dependencies\">podešen</link>. "
"&kompare;, <ulink url=\"http://kdiff3.sourceforge.net\"><application>KDiff3</"
"application></ulink> i <ulink url=\"http://furius.ca/xxdiff/"
"\"><application>xxdiff</application></ulink> su podržani."

#. Tag: title
#: compare.docbook:32
#, fuzzy, no-c-format
#| msgid "Compare Directories"
msgid "Compare Folders"
msgstr "Poređenje direktorija"

#. Tag: secondary
#: compare.docbook:35
#, no-c-format
msgid "Folders"
msgstr ""

#. Tag: para
#: compare.docbook:37
#, fuzzy, no-c-format
#| msgid ""
#| "Compare the files of each panel by using <menuchoice> <guimenu>Edit</"
#| "guimenu> <guimenuitem>Compare Directories</guimenuitem> </menuchoice>. By "
#| "default newer and single files will be selected in each panel, this "
#| "behaviour can be changed in the <guimenuitem>Compare Setup</guimenuitem> "
#| "menu."
msgid ""
"Compare the files of each panel by using <menuchoice> <guimenu>Edit</"
"guimenu> <guimenuitem>Compare Folders</guimenuitem> </menuchoice>. By "
"default newer and single files will be selected in each panel, this "
"behaviour can be changed in the <guimenuitem>Compare Setup</guimenuitem> "
"menu."
msgstr ""
"Uporedite datoteke iz svake ploče koristeći <menuchoice> <guimenu>Izmijeni</"
"guimenu> <guimenuitem>Poređenje direktorija</guimenuitem> </menuchoice>. "
"Prema zadanim postavkama, novije i pojedinačne datoteke će biti odabrane u "
"svakoj ploči, a ovo se može promijeniti u <guimenuitem>Postavke poređenja</"
"guimenuitem> izborniku."

#. Tag: para
#: compare.docbook:46
#, no-c-format
msgid ""
"The files are not compared by content but by their names and dates only."
msgstr ""
"Datoteke nisu upoređene prema sadržaju nego samo prema njihovim imenima i "
"datumima."

#. Tag: menuchoice
#: compare.docbook:52
#, no-c-format
msgid "<guimenu>Edit</guimenu> <guimenuitem>Compare Setup</guimenuitem>"
msgstr ""
"<guimenu>Izmijeni</guimenu> <guimenuitem>Postavke poređenja</guimenuitem>"

#. Tag: para
