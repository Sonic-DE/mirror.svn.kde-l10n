#. Tag: title
#: diskusage.docbook:8
#, no-c-format
msgid "<title>Disk Usage</title>"
msgstr "<title>Zauzeće diska</title>"

#. Tag: primary
#: diskusage.docbook:10
#, no-c-format
msgid "<primary>Disk Usage</primary>"
msgstr "<primary>Zauzeće diska</primary>"

#. Tag: para
#: diskusage.docbook:12
#, fuzzy, no-c-format
#| msgid ""
#| "The Disk Usage is based on the code of <application>Filelight</"
#| "application>. The Disk Usage shows you how your disk space is being used "
#| "by a graphical representation of your file system. The following "
#| "presentations are possible:"
msgid ""
"The Disk Usage is based on the code of &filelight;. The Disk Usage shows you "
"how your disk space is being used by a graphical representation of your file "
"system. The following presentations are possible:"
msgstr ""
"Zauzeće diska je bazirao na kodu <application>Filelight</application>.  "
"Zauzeće diska vam pokazuje koliko vašeg disk prostora je zauzere grafičkom "
"predstavom vaših sistemskih fajlova. Moguće su sljedeće solucije:"

#. Tag: para
#: diskusage.docbook:18
#, no-c-format
msgid "Line view"
msgstr "Linijski prikaz"

#. Tag: para
#: diskusage.docbook:21
#, no-c-format
msgid "Detailed view"
msgstr "Detaljan prikaz"

#. Tag: para
#: diskusage.docbook:24
#, no-c-format
msgid ""
"<application>Filelight</application> view: as a set of concentric segmented-"
"rings"
msgstr ""
"<application>Light fajl</application> pregled: Kao skup koncentričnih "
"segmentiranih prstenova."

#. Tag: para
#: diskusage.docbook:28
#, fuzzy, no-c-format
#| msgid ""
#| "Choose <menuchoice> <guimenu>Tools</guimenu> <guimenuitem>Disk Usage</"
#| "guimenuitem> </menuchoice> or <keycombo action=\"simul\">&Alt;&Shift; "
#| "<keycap>S</keycap></keycombo> to start this feature in a separate window, "
#| "or open it inside the <link linkend=\"popup_panel\">PopUp Panel</link>."
msgid ""
"Choose <menuchoice> <guimenu>Tools</guimenu> <guimenuitem>Disk Usage...</"
"guimenuitem> </menuchoice> or <keycombo action=\"simul\">&Alt;&Shift; "
"<keycap>S</keycap></keycombo> to start this feature in a separate window, or "
"open it inside the <link linkend=\"sidebar\">Sidebar</link>."
msgstr ""
"Izaberi<menuchoice> <guimenu>Alati</guimenu> <guimenuitem>Zauzeće diska</"
"guimenuitem> </menuchoice> ili<keycombo action=\"simul\">&Alt;&Shift; "
"<keycap>S</keycap></keycombo> da bi započeli ovu značajku u novom prozoru, "
"ili otvorili unutar <link linkend=\"popup_panel\">PopUp Panel</link>."

