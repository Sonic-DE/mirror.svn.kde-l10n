#~ "guimenu> <guimenuitem>Copy</guimenuitem></menuchoice> item, or the "
#~ "<keycombo action=\"simul\">&Ctrl;<keycap>C</keycap></keycombo> shortcut "
#~ "key combination. You can also select <link linkend=\"selection"
#~ "\">multiple</link> files or folders to copy/move as well."
#~ msgstr ""
#~ "Ili ako je stavka <quote>označena</quote> možete koristiti "
#~ "<guiicon>Kopiraj</guiicon> dugme na alatnoj traci ili meni traku "
