#~ "guimenuitem></menuchoice> stavku, ili <keycombo action=\"simul\">&Ctrl;"
#~ "<keycap>C</keycap></keycombo> kombinaciju tipki. Možete također označiti "
#~ "<link linkend=\"selection\">više</link> fajlova ili foldera da kopirate/"
#~ "premjestite također."

#~ msgid ""
#~ "Navigate to the folder you want to copy the item into then Paste the item "
#~ "into the new folder by using the Toolbar <guiicon>Paste</guiicon> button "
#~ "or the Menubar <menuchoice><guimenu>Edit</guimenu> <guimenuitem>Paste</"
