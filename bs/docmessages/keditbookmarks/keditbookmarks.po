#~ "<guilabel>Upravljanje fajlovima</guilabel> stranici postavki."

#~ msgid ""
#~ "The simplest way to remove a file or folder is to position the mouse "
#~ "pointer over its name or icon and press the &RMB;, which will bring up a "
#~ "menu containing the options <guimenuitem>Move to Trash</guimenuitem> and "
