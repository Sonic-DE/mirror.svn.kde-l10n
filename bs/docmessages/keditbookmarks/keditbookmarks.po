#~ "<quote><guimenuitem>Premjesti u kantu za otpatke</guimenuitem></quote> i "
#~ "<quote><guimenuitem>Obriši</guimenuitem></quote> opcije."

#~ msgid "<keycap>Del</keycap> will move the selected item or items to Trash."
