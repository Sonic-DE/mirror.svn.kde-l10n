"<shortcut> <keycombo>&Ctrl;<keycap>P</keycap></keycombo> </shortcut> "
"<guimenu>File</guimenu> <guimenuitem>Print History...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>P</keycap></keycombo> </shortcut> "
"<guimenu>File</guimenu> <guimenuitem>Štampaj istorijat...</guimenuitem>"

#. Tag: action
#: index.docbook:452
#, no-c-format
msgid "Prints the history."
msgstr "Printa historiju."

#. Tag: menuchoice
#: index.docbook:455
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>Q</keycap></keycombo> </shortcut> "
"<guimenu>File</guimenu> <guimenuitem>Quit</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>Q</keycap></keycombo> </shortcut> "
"<guimenu>File</guimenu> <guimenuitem>Izlaz</guimenuitem>"

#. Tag: action
#: index.docbook:462
#, no-c-format
msgid "Quits &kmouth;"
msgstr "Napušta &kmouth;"

#. Tag: title
#: index.docbook:468 index.docbook:613
#, no-c-format
msgid "The Edit Menu"
msgstr "Uređivački meni"

#. Tag: menuchoice
#: index.docbook:471 index.docbook:616
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>X</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Cut</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>X</keycap></keycombo> </shortcut> "
"<guimenu>Izmijeni</guimenu> <guimenuitem>Isijeci</guimenuitem>"

#. Tag: action
#: index.docbook:478
#, fuzzy, no-c-format
#| msgid ""
#| "Cuts the selected section and puts it to the clipboard. If there is some "
#| "text selected in the edit field it is placed it on the clipboard. "
#| "Otherwise the selected sentences in the history (if any) are placed on "
#| "the clipboard."
msgid ""
"Cuts the selected section and puts it to the clipboard. If there is some "
"text selected in the edit field it is placed in the clipboard. Otherwise the "
"selected sentences in the history (if any) are placed in the clipboard."
msgstr ""
"Isjeca se izabrana sekcija i stavlja u clipboard. Ako je neki tekst izabran "
"u polju za uređivanje, stavlja se u clipboard. U suprotnom, u clipboard se "
"stavljaju izabrane rečenice iz historije (ako ih ima)."

#. Tag: menuchoice
#: index.docbook:486 index.docbook:628
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>C</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Copy</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>C</keycap></keycombo> </shortcut> "
"<guimenu>Izmijeni</guimenu> <guimenuitem>Kopiraj</guimenuitem>"

#. Tag: action
#: index.docbook:493
#, no-c-format
msgid ""
"Copies the selected section to the clipboard. If there is some text selected "
"in the edit field it is copied to the clipboard. Otherwise the selected "
"sentences in the history (if any) are copied to the clipboard."
msgstr ""
"Kopira se trenutni izbor u clipboard. Ako je neki tekst izabran u polju za "
"uređivanje, kopira se u clipboard. U suprotnom, u clipboard se kopiraju "
"izabrane rečenice iz historije (ako ih ima)."

#. Tag: menuchoice
#: index.docbook:501 index.docbook:640
#, no-c-format
msgid ""
"<shortcut> <keycombo>&Ctrl;<keycap>V</keycap></keycombo> </shortcut> "
"<guimenu>Edit</guimenu> <guimenuitem>Paste</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>V</keycap></keycombo> </shortcut> "
"<guimenu>Izmijeni</guimenu> <guimenuitem>Umetni</guimenuitem>"

#. Tag: action
#: index.docbook:508
#, no-c-format
msgid ""
"Pastes the clipboard contents at the current cursor position into the edit "
"field."
