"<shortcut> <keycombo>&Ctrl;<keycap>O</keycap></keycombo> </shortcut> "
"<guimenu>File</guimenu> <guimenuitem>Open as History...</guimenuitem>"
msgstr ""
"<shortcut> <keycombo>&Ctrl;<keycap>O</keycap></keycombo> </shortcut> "
"<guimenu>File</guimenu> <guimenuitem>Otvori kao istorijat...</guimenuitem>"

#. Tag: action
#: index.docbook:432
#, no-c-format
msgid "Opens a text file into as history of spoken sentences."
msgstr "Otvara tekstualni fajli iz historije izgovorenih rečenica."

#. Tag: menuchoice
#: index.docbook:435
#, no-c-format
