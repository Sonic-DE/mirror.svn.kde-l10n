#: commands.docbook:870
#, no-c-format
msgid "The Tools Menu"
msgstr "Meni sa alatima"

#. Tag: menuchoice
#: commands.docbook:874
#, no-c-format
msgid "<guimenu>Tools</guimenu> <guimenuitem>Spelling...</guimenuitem>"
msgstr "<guimenu>Alati</guimenu> <guimenuitem>Pravopis...</guimenuitem>"

#. Tag: action
#: commands.docbook:878
#, no-c-format
msgid "Check spelling of words in the worksheet."
msgstr "Provjerava pravopis u riječima u radnoj svesci."

#. Tag: menuchoice
#: commands.docbook:883
#, no-c-format
msgid "<guimenu>Tools</guimenu> <guimenuitem>Custom Lists...</guimenuitem>"
msgstr "<guimenu>Alati</guimenu> <guimenuitem>Pravljena lista...</guimenuitem>"

#. Tag: action
#: commands.docbook:887
#, no-c-format
msgid ""
"View or amend the special series of words recognized by &sheets;. These list "
"can be used to insert special <link linkend=\"series\">series</link> into "
"the worksheet."
msgstr ""
"Pregled specijalnih nizova riječi prepoznatih od strane &sheets;. Ove liste "
"mogu biti korištene za umetanje specijalnih <link linkend=\"series\">nizova</"
"link> u radnu svesku."

#. Tag: menuchoice
#: commands.docbook:893
#, no-c-format
msgid "<guimenu>Tools</guimenu> <guimenuitem>Protect Sheet...</guimenuitem>"
msgstr "<guimenu>Alati</guimenu> <guimenuitem>Zaštiti list...</guimenuitem>"

#. Tag: action
#: commands.docbook:898
#, no-c-format
msgid ""
"Protect the sheet with a password. A dialog pops up prompting you for a "
"password. Unchecking this option will prompt you for the password in order "
"to unprotect the sheet. Protecting a sheet means protecting all cells in the "
"sheet. In a protected sheet, the cells cannot be reformatted or overwritten."
msgstr ""
"Zaštiti list sa šifrom. Okvir iskače tražeći vam šifru. Ako ne označite ovu "
"opciju tražiće vam se šifra da skinete zaštitu sa lista. Zaštita lista znači "
"zaštitu svih ćelija u listu. U zaštićenom listu, ćelije ne mogu biti "
"formatirane ili mijenjane."

#. Tag: menuchoice
#: commands.docbook:903
#, no-c-format
msgid "<guimenu>Tools</guimenu> <guimenuitem>Protect Document...</guimenuitem>"
msgstr ""
"<guimenu>Alati</guimenu> <guimenuitem>Zaštiti dokument...</guimenuitem>"

#. Tag: action
#: commands.docbook:908
#, no-c-format
msgid ""
"Protect the whole document with a password. A dialog pops up prompting you "
"for a password. Unchecking this option will prompt you for the password in "
"order to unprotect the document. In a protected document you cannot rename "
"or remove a sheet. Document protection does not mean that each individual "
"sheet is protected."
msgstr ""
"Zaštiti cijeli dokument šifrom. Okvir iskače tražeći šifru. Ne označavanje "
"ove opcije izbacije prozor koji traži šifru u cilju da skine zaštitu sa "
"dokumenta. U zaštićenom dokumentu ne možete preimenovati ili ukloniti list. "
"Zaštita dokumenta ne znači da je individualni list zaštićen."

#. Tag: menuchoice
#: commands.docbook:917
#, no-c-format
msgid ""
"<shortcut> <keycombo action=\"simul\">&Shift;<keysym>F9</keysym></keycombo> "
"</shortcut> <guimenu>Tools</guimenu> <guimenuitem>Recalculate Sheet</"
"guimenuitem>"
msgstr ""
"<shortcut> <keycombo action=\"simul\">&Shift;<keysym>F9</keysym></keycombo> "
"</shortcut> <guimenu>Alati</guimenu> <guimenuitem>Ponovo proračunaj list</"
"guimenuitem>"

#. Tag: action
#: commands.docbook:924
#, no-c-format
msgid "Recalculate formulae in the current sheet."
msgstr "Ponovo proračunava formule u trenutnom listu."

#. Tag: menuchoice
#: commands.docbook:929
#, no-c-format
msgid ""
"<shortcut> <keysym>F9</keysym> </shortcut> <guimenu>Tools</guimenu> "
"<guimenuitem>Recalculate Document</guimenuitem>"
msgstr ""
"<shortcut> <keysym>F9</keysym> </shortcut> <guimenu>Alati</guimenu> "
"<guimenuitem>Ponovo proračunaj dokument</guimenuitem>"

#. Tag: action
#: commands.docbook:936
#, no-c-format
msgid "Recalculate all sheets."
msgstr "Ponovo proračunava sve listove."

#. Tag: menuchoice
#: commands.docbook:952
#, no-c-format
msgid ""
"<guimenu>Tools</guimenu> <guimenuitem>Execute Script File...</guimenuitem>"
