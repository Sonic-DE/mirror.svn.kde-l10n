msgid "<guimenu>Data</guimenu> <guimenuitem>Validity...</guimenuitem>"
msgstr "<guimenu>Podaci</guimenu> <guimenuitem>Ispravnost...</guimenuitem>"

#. Tag: para
#: commands.docbook:840
#, no-c-format
