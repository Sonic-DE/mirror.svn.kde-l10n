#: commands.docbook:795
#, no-c-format
msgid ""
"This option attempts to interpret text in the selected cell(s) as "
"<acronym>CSV</acronym> data, placing each item into a different cell in the "
"row."
msgstr ""
"Ova opcija pokušava interpretirati tekst u odabranim ćelijama kao "
"<acronym>CSV</acronym> podatak, postavljajući svaku stavku u drugu ćeliju u "
"redu."

