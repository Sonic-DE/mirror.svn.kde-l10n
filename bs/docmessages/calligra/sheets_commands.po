#. Tag: menuchoice
#: commands.docbook:816
#, no-c-format
msgid "<guimenu>Data</guimenu> <guimenuitem>Consolidate...</guimenuitem>"
msgstr "<guimenu>Podaci</guimenu> <guimenuitem>Učvrsti...</guimenuitem>"

#. Tag: para
#: commands.docbook:820
#, no-c-format
msgid ""
"<action>Consolidate data.</action> See the section <link linkend="
"\"consolidate\">Consolidating Data</link> for more details."
msgstr ""
"<action>Učvrsti podatke.</action> Vidjeti odjeljak <link linkend="
"\"consolidate\">Učvršćivanje podataka</link> za više detalja."

#. Tag: menuchoice
#: commands.docbook:826
#, no-c-format
msgid "<guimenu>Data</guimenu> <guimenuitem>Subtotals...</guimenuitem>"
msgstr "<guimenu>Podaci</guimenu> <guimenuitem>Iznosa...</guimenuitem>"

