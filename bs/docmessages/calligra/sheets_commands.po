msgstr ""
"<action>Postavlja ili mijenja grešku provjerom kriterija ili porukom "
"upozorenja za grešku za odabrane ćelije.</action> Vidjeti <link linkend="
"\"validcheck\"> Provjeru ispravnosti</link> za više detalja."

#. Tag: menuchoice
#: commands.docbook:847
#, no-c-format
msgid "<guimenu>Data</guimenu> <guimenuitem>Goal Seek...</guimenuitem>"
msgstr "<guimenu>Podaci</guimenu> <guimenuitem>Traženje cilja...</guimenuitem>"

