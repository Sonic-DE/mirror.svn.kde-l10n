"&lt;separator/&gt;\n"
"&lt;action name=\"edit_find\"/&gt;\n"
"&lt;/menu&gt;\n"
"&lt;menu name=\"Insert\"&gt;&lt;text&gt;Ubaci&lt;/text&gt;\n"
"&lt;action name=\"insert_picture\"/&gt;\n"
