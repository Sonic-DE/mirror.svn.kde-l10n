msgid "<title>Author</title>"
msgstr "<title>Autor</title>"

#. Tag: screeninfo
#: options.docbook:177
#, no-c-format
msgid "<screeninfo>Author</screeninfo>"
msgstr "<screeninfo>Autor</screeninfo>"

#. Tag: para
#: options.docbook:186
#, no-c-format
msgid "Choose an author profile for your document."
msgstr "Izaberite autora profila za vaš dokument."

#. Tag: para
#: options.docbook:189
#, no-c-format
msgid ""
"You can add a new profile or delete the current profile using the buttons to "
"the right of the profiles drop-down list."
msgstr ""
"Možete dodati novi profil ili izbrisati trenutni korištenjem tipki sa desne "
"strane padajuće liste."
