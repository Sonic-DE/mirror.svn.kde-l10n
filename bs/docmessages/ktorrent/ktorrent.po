msgstr "4.0 &kde; 4.5"

#. Tag: para
#: index.docbook:40
#, fuzzy, no-c-format
#| msgid ""
#| "&ktorrent; is a bittorrent application for KDE which allows you to "
#| "download files using the BitTorrent protocol. It enables you to run "
#| "multiple torrents at the same time and comes with extended features to "
#| "make it a full-featured client for BitTorrent."
msgid ""
"&ktorrent; is a bittorrent application by KDE which allows you to download "
"files using the BitTorrent protocol. It enables you to run multiple torrents "
"at the same time and comes with extended features to make it a full-featured "
"client for BitTorrent."
msgstr ""
"&ktorrent; je BitTorrent aplikacija za KDE koji vam omogućuje preuzimanje "
"datoteka putem BitTorrent protokola. To vam omogućuje da pokrenete više "
"torrenta u isto vrijeme, a dolazi s proširene mogućnosti za potpuno "
"opremljenog klijenta za BitTorrent ."

#. Tag: title
#: index.docbook:43
#, no-c-format
msgid "Features"
msgstr "Mogućnosti"

#. Tag: para
#: index.docbook:44
#, no-c-format
msgid "Queuing of torrents"
msgstr "Red za torrente"

#. Tag: para
#: index.docbook:45
#, no-c-format
msgid "Global and per torrent speed limits"
msgstr "Globalna i po torrent ograničenja brzine"

#. Tag: para
#: index.docbook:46
#, no-c-format
msgid "Previewing of certain file types, build in (video and audio)"
msgstr "Prikaz fajlova sigurnog tipa, ugrađenih (vido i zvuk)"

#. Tag: para
#: index.docbook:47
#, no-c-format
msgid "Importing of partially or fully downloaded files"
msgstr "Unos od djelimično ili potpuno preuzetih fajlova"

#. Tag: para
#: index.docbook:48
#, no-c-format
msgid "File prioritization for multi-file torrents"
msgstr "Fajl prioriteta za mutli-fajl torente"

#. Tag: para
#: index.docbook:49
#, no-c-format
msgid "Selective downloading for multi-file torrents"
msgstr "Selektirano preuzimanje za multi-fajl torente"

#. Tag: para
#: index.docbook:50
#, no-c-format
msgid ""
"Kick/ban peers with an additional IP Filter dialog for list/edit purposes"
msgstr ""
"Kick / ban vršnjaka s dodatnim IP Filter dijalog za popis / uređivanje svrhe"

#. Tag: para
#: index.docbook:51
#, no-c-format
msgid "UDP tracker support"
msgstr "UDP podrška za praćenje"

#. Tag: para
#: index.docbook:52
#, no-c-format
msgid "Support for private trackers and torrents"
msgstr "Podrska za privatno praćenje i torrente"

#. Tag: para
#: index.docbook:53
#, no-c-format
msgid "Support for µTorrent's peer exchange"
msgstr "Podrška za  µTorrent's po razmijeni"

#. Tag: para
#: index.docbook:54
#, no-c-format
msgid "Support for protocol encryption (compatible with Azureus)"
msgstr "Podrška za protokol enkripcije  (kompaktibilan sa  Azureus)"

#. Tag: para
#: index.docbook:55
#, no-c-format
msgid "Support for creating trackerless torrents"
msgstr "Support za stvaranje torenta koji se ne mogu pratiti"

#. Tag: para
#: index.docbook:56
#, no-c-format
msgid "Support for distributed hash tables (DHT, the Mainline version)"
msgstr "Podrška za distribuirane heš tabele  (DHT,Mainline verzije)"

#. Tag: para
#: index.docbook:57
#, no-c-format
msgid ""
"Support for UPnP to automatically forward ports on a LAN with dynamic "
"assigned hosts"
msgstr ""
"Podrška za UPnp automatsko unašrijeđenje porta na LAN sa dinamickim "
"dodjeljivanjem hosta"

#. Tag: para
#: index.docbook:58
#, no-c-format
msgid "Support for webseeds"
msgstr "Podrška za webseedes"

#. Tag: para
#: index.docbook:59
#, no-c-format
msgid "System tray integration"
msgstr "Sustav poslužavnik integracija"

#. Tag: para
#: index.docbook:60
#, no-c-format
msgid "Tracker authentication support"
msgstr "Tracker autentifikacije podrške"

#. Tag: para
#: index.docbook:61
#, no-c-format
msgid "Connection though a proxy"
msgstr "Konekcija sa proxy"

#. Tag: para
#: index.docbook:62
#, fuzzy, no-c-format
#| msgid ""
#| "Scripting support via Kross and interprocess control via DBus interface"
msgid "Interprocess control via DBus interface"
msgstr ""
"Podrška za skriptovanje sa Kross i međuprocesnom kontrolom sa DBus "
"interfejsom"

