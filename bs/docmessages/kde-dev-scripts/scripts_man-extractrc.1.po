#. Tag: refpurpose
#: man-extractrc.1.docbook:20
#, no-c-format
msgid "Extract message strings from UI and GUI-RC files"
msgstr "Izvlači stringove poruke iz UI i GUI-RC dokumenata"

#. Tag: cmdsynopsis
#: man-extractrc.1.docbook:24
#, no-c-format
msgid ""
"<command>extractrc</command> <group><option><replaceable>filename</"
"replaceable></option></group>"
msgstr ""
"<command>izvucirc</command> <group><option><replaceable>filename</"
"replaceable></option></group>"

#. Tag: title
#: man-extractrc.1.docbook:32
#, no-c-format
msgid "Description"
msgstr "Opis"

#. Tag: para
#: man-extractrc.1.docbook:34
#, no-c-format
msgid ""
"<command>extractrc</command> finds all text tags and other message strings "
"in the given files and writes the corresponding i18n() calls to standard "
"output so that xgettext can parse them."
msgstr ""
"<command>izvucirc</command> pronalazi sve tekstualne oznake i druge "
"stringove poruka u datom dokumentu i zapisuje odgovarajući  i18n() poziv na "
"standardni izlaz tako da ga xpreuzmitekst može rasčlaniti."

#. Tag: para
#: man-extractrc.1.docbook:38
#, no-c-format
msgid ""
"It understands both (&Qt;/&kde;) <application>designer</application>'s "
"<acronym>UI</acronym> files and &XML; GUI-RC files."
msgstr ""
"Razumije oboje  (&Qt;/&kde;) <application>dizajner</application><acronym>UI</"
"acronym> dokumente i &XML; GUI-RC dokumente."

#. Tag: para
#: man-extractrc.1.docbook:42
#, no-c-format
msgid "This utility is part of the KDE Software Development Kit."
msgstr "Ova opcija je dio KDE softverskog razvojnog alata."

