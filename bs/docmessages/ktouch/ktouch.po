#. Tag: simpara
#: index.docbook:259
#, no-c-format
msgid "Some typing statistics in info boxes at the top"
msgstr "Neke statistike kucanja u kvadratićima na vrhu"

#. Tag: simpara
#: index.docbook:261
#, no-c-format
msgid "The text you need to type"
