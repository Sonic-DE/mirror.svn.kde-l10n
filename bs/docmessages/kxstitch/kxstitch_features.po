#. Tag: title
#: features.docbook:2
#, no-c-format
msgid "Features"
msgstr "Karakteristike"

#. Tag: para
#: features.docbook:3
#, no-c-format
msgid "The current feature list and other planned features is shown here."
msgstr ""
"Trenutna funkcija liste i druge planirane karakteristike je prikazan ovdje."

#. Tag: para
#: features.docbook:5
#, no-c-format
msgid "Creation of new patterns"
msgstr "Kreiranje novog obrazca"

#. Tag: para
#: features.docbook:7
#, no-c-format
msgid "User defined size"
msgstr "Korisnički definirana veličina"

#. Tag: para
#: features.docbook:8
#, no-c-format
msgid "Selection of material color"
msgstr "Pregled boje materijala"

#. Tag: para
#: features.docbook:9
#, no-c-format
msgid "Insertion of a background images for tracing"
msgstr "Umetnite sliku kao pozadinu za traženje."

#. Tag: para
#: features.docbook:10
#, no-c-format
msgid "Importing of various image formats"
msgstr "Uvoz raznih formata slike"

#. Tag: para
#: features.docbook:11
#, no-c-format
msgid "Importing options allow"
msgstr "Uvoz opcija dopušta"

#. Tag: para
#: features.docbook:13
#, no-c-format
msgid "Limiting the number of colors"
msgstr "Ograničenje broja boja"

#. Tag: para
#: features.docbook:14
#, no-c-format
msgid "Limiting colors to a specific palette"
msgstr "Ograničenje boja na specifičnu paletu"

#. Tag: para
#: features.docbook:15
#, no-c-format
msgid "Scaling to a finished size"
msgstr "Skaliranje na završenu veličinu"

#. Tag: para
#: features.docbook:16
#, no-c-format
msgid "Support for transparency in images"
msgstr "Prikaži ili skrij pozadinsku sliku"

#. Tag: para
#: features.docbook:17
#, no-c-format
msgid "Allow the use of fractional stitches"
msgstr "Dopusti upotrebu izlomljenih šavova"

#. Tag: para
#: features.docbook:22
#, no-c-format
msgid "Editing of existing patterns, Editing tools will include"
msgstr "Preuređivanje postojećih šavova, Izmjenjivanje alata sa uključivanjem"

#. Tag: para
#: features.docbook:24
#, no-c-format
msgid "Open and filled rectangles"
msgstr "Otvoreni i popunjeni pravogaonici"

#. Tag: para
#: features.docbook:25
#, no-c-format
msgid "Open and filled ellipses"
msgstr "Otvorene i popunjene elipse"

#. Tag: para
#: features.docbook:26
#, no-c-format
msgid "Filled polygons"
msgstr "Ispunjeni poligoni"

#. Tag: para
#: features.docbook:27
#, no-c-format
msgid "Painting"
msgstr "Bojenje"

#. Tag: para
#: features.docbook:28
#, no-c-format
msgid "Lines"
msgstr "Linije"

#. Tag: para
#: features.docbook:29
#, no-c-format
msgid "Erasing stitches, knots and backstitches"
msgstr "Brisanje šavova, čvorova i duplih šavova"

#. Tag: para
#: features.docbook:30
#, no-c-format
msgid "Color selection from existing stitches"
msgstr "Izbor boje iz postojećih šavova"

#. Tag: para
#: features.docbook:31
#, no-c-format
msgid "Swapping two colors"
msgstr "Zamijena dvije boje"

#. Tag: para
#: features.docbook:32
#, no-c-format
msgid "Replace one color with another"
msgstr "Zamijeni jednu boju drugom"

#. Tag: para
#: features.docbook:33
#, no-c-format
msgid "Text with user defined fonts and sizes"
msgstr "Korisnik definira veličinu i font teksta"

#. Tag: para
#: features.docbook:34
#, no-c-format
msgid "Cut, copy and paste of rectangular areas."
msgstr "Izreži, kopiraj i zalijepi pravougane isječke."

#. Tag: para
#: features.docbook:35
#, no-c-format
msgid "Unlimited undo and redo"
msgstr "Negraničeno poništavanje i vraćanje"

#. Tag: para
#: features.docbook:36
#, no-c-format
msgid "Mirroring, horizontally and vertically."
msgstr "Horizontalno i vertikalno preslikavanje."

#. Tag: para
#: features.docbook:37
#, no-c-format
msgid "Rotation, 90, 180 and 270 degrees anti clockwise."
msgstr "Rotacija, 90, 180, i 270 stepeni suprotno od smjera kazaljke na satu."

#. Tag: para
#: features.docbook:38
#, no-c-format
msgid "Resizing of the canvas"
msgstr "Centriraj obrazac na platnu"

#. Tag: para
#: features.docbook:40
#, no-c-format
msgid "Extend canvas left, top, right, bottom"
msgstr "Proširi obrazac, na vrhu, na dnu, lijevo i desno"

#. Tag: para
#: features.docbook:41
#, no-c-format
msgid "Cropping canvas to pattern"
msgstr "Izreži platno prema obrascu"

#. Tag: para
#: features.docbook:42
#, no-c-format
msgid "Cropping canvas to selection"
msgstr "Izreži obrazac prema označenom"

#. Tag: para
#: features.docbook:43
#, no-c-format
msgid "Inserting rows and columns"
msgstr "Ubaci kolonu i red"

#. Tag: para
#: features.docbook:44
#, no-c-format
msgid "Center the pattern on the canvas"
msgstr "Centriraj obrazac na platnu"

#. Tag: para
#: features.docbook:47
#, no-c-format
msgid "Conversion between floss schemes"
msgstr "Zamjena između končanih šema"

#. Tag: para
#: features.docbook:50
#, no-c-format
msgid "Use of standard floss pallets, DMC, Anchor, etc."
msgstr "Koristi standarde palete za konac, DMC, Anchor, itd."

#. Tag: para
#: features.docbook:51
#, no-c-format
msgid "Create customized floss pallets"
msgstr "Kreiraj prilagođene palete konaca"

#. Tag: para
#: features.docbook:52
#, no-c-format
msgid "Create new colors for any floss pallet"
msgstr "Kreiraj nove boje za bilo koji konac iz palete"

#. Tag: para
#: features.docbook:53
#, no-c-format
msgid "Save / Load current palette"
msgstr "Snimi/Učitaj trenutnu paletu"

#. Tag: para
#: features.docbook:54
#, no-c-format
msgid "Use of standard stitches"
msgstr "Upotreba standardnih šavova"

#. Tag: para
#: features.docbook:55
#, no-c-format
msgid "Pattern library manager"
msgstr "Upravitelj bibliotečkih obrazaca"

#. Tag: para
#: features.docbook:57
#, no-c-format
msgid "Create new library patterns"
msgstr "Kreiraj nove bibliotečke uzorke"

#. Tag: para
#: features.docbook:58
#, no-c-format
msgid "Insert library patterns into a design"
msgstr "Ubaci bibliotečke uzorke u dizajn"

#. Tag: para
#: features.docbook:59
#, no-c-format
msgid "Drag and drop from the library to the pattern"
msgstr "Povuci i ispusti iz biblioteke u obrazac"

#. Tag: para
#: features.docbook:60
#, fuzzy, no-c-format
#| msgid "Drag and drop from the library to the pattern"
msgid "Drag and drop from one library to another"
msgstr "Povuci i ispusti iz biblioteke u obrazac"

#. Tag: para
#: features.docbook:61
#, no-c-format
msgid "Assign key press to patterns for use with the Alphabet tool"
msgstr "Dodjeljivanje tastera za korištenje obrazaca sa abecednim alatom"

#. Tag: para
#: features.docbook:64
#, no-c-format
msgid "Free use of backstitching"
msgstr "Slobodna upotreba duplih šavova"

#. Tag: para
#: features.docbook:65
#, no-c-format
msgid "Printing of completed patterns and floss keys"
msgstr "Ispisivanje cjelovitih obrazaca i ključni konac"

#. Tag: para
#: features.docbook:67
#, no-c-format
msgid "Pattern image"
msgstr "Slika uzoraka"

#. Tag: para
#: features.docbook:68
#, no-c-format
msgid "Instructions"
msgstr "Instrukcije"

#. Tag: para
#: features.docbook:69
#, no-c-format
msgid "Floss key and stitch summary"
msgstr "Ključ konca i sažetak za šavove"

#. Tag: para
#: features.docbook:70
#, no-c-format
msgid "Pattern chart with page map"
msgstr "Grafik mapa sa mapom stranica"

#. Tag: para
#: features.docbook:71
#, no-c-format
msgid "Text boxes"
msgstr "Tekstualne varijable"

#. Tag: para
#: features.docbook:74
#, no-c-format
msgid "Mapping of symbols to flosses"
msgstr "Prikaži simbole koje imaju veze sa bojma"

#. Tag: para
#: features.docbook:75
#, no-c-format
msgid "Specify the number of threads for stitches and backstitches"
msgstr "Odrediti broj niti, šavova i duplih šavova"

#. Tag: para
#: features.docbook:76
#, no-c-format
msgid "Calibration of floss colors"
msgstr "Dijalog kalibracije konca"

#. Tag: para
#: features.docbook:78
#, no-c-format
msgid ""
"Requests for new features can be made to the <ulink url=\"http://bugs.kde.org"
"\">KDE Bugtracking System</ulink>"
msgstr ""
"Zahtjevi za nove karakteristike mogu biti u <ulink url =\"http: //bugs.kde."
"org \"> KDE sistem za ispravljanje grešaka </ulink>"

