msgstr "<keycap>0</keycap> - <keycap>9</keycap>"

#. Tag: member
#: index.docbook:449 index.docbook:493
#, no-c-format
msgid "Input digits"
msgstr "Ulazne cifre"

#. Tag: member
#: index.docbook:451
#, no-c-format
msgid "<keycap>.</keycap> or <keycap>,</keycap>"
msgstr "<keycap>.</keycap> ili <keycap>,</keycap>"

