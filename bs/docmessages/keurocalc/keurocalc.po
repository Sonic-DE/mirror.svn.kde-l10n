msgstr "&Enter; i <keycap>Return</keycap>"

#. Tag: member
#: index.docbook:458 index.docbook:512
#, no-c-format
msgid "Validation of input number considered as a simple, unitless, value"
msgstr ""
"Validacija ulaznog broja koji se smatra kao jednostavna vrijednost bez "
"jedinice."

#. Tag: keycap
#: index.docbook:460
#, no-c-format
msgid "<keycap>%</keycap>"
msgstr "<keycap>%</keycap>"

#. Tag: member
#: index.docbook:461 index.docbook:515
#, no-c-format
msgid "Validation of input number considered as a percentage"
msgstr "Validacija ulaznog broja koji se smatra kao procenat"

#. Tag: member
#: index.docbook:463
#, no-c-format
msgid "&Backspace;"
msgstr "&Backspace;"

#. Tag: member
#: index.docbook:464 index.docbook:499
#, no-c-format
msgid "Removal of last input: digits, decimal separator or operator"
msgstr ""
"Uklanjanje posljednjeg ulaza: broja, decimalnog separatora ili operatora"

#. Tag: member
#: index.docbook:466
#, no-c-format
msgid "&Tab; and <keycombo action=\"simul\">&Shift; &Tab;</keycombo> keys"
msgstr "&Tab; i <keycombo action=\"simul\">&Shift; &Tab;</keycombo> tipka"

#. Tag: member
#: index.docbook:467
#, no-c-format
msgid "Moves from one button to the next or previous one"
msgstr "Prelazak sa jednog dugmeta na naredno ili prethodno"

#. Tag: member
#: index.docbook:469
#, no-c-format
msgid "Arrow keys"
msgstr "Tasteri strelica"

#. Tag: member
#: index.docbook:470
#, no-c-format
msgid "In the currency selection area, moves from one currency to the other"
msgstr "U području odabira valuta, prelazak sa jedne valute na drugu"

#. Tag: member
#: index.docbook:472
#, no-c-format
msgid "Space bar"
msgstr "Space bar"

#. Tag: member
#: index.docbook:473
#, no-c-format
msgid "When focus is on a push button, presses this button"
msgstr "Kada je fokus na tasteru, pritšče ga"

#. Tag: member
#: index.docbook:475
#, no-c-format
msgid "<keycap>E</keycap> or <keycap>$</keycap>"
msgstr "<keycap>E</keycap> ili <keycap>$</keycap>"

#. Tag: member
#: index.docbook:476 index.docbook:505
#, no-c-format
msgid ""
"Validation of input number considered as a value expressed in the reference "
"currency (euro)"
msgstr ""
"Validacija ulaznog broja koji se smatra kao vrijednost izražena u "
"referentnoj valuti (euro)"

#. Tag: keycap
#: index.docbook:479
#, no-c-format
msgid "<keycap>S</keycap>"
msgstr "<keycap>S</keycap>"

#. Tag: member
#: index.docbook:480 index.docbook:518
#, no-c-format
msgid "Change sign of the result"
msgstr "Mjenja predznak rezultata"

#. Tag: member
#: index.docbook:482
#, no-c-format
msgid "Any other key"
msgstr "Bilo koja druga tipka"

#. Tag: member
#: index.docbook:483 index.docbook:509
#, no-c-format
msgid "Validation of input number considered as a number in the other currency"
msgstr "Validacija ulaznog broja koji se smara kao vrijednost u drugoj valuti"

#. Tag: title
#: index.docbook:489
#, no-c-format
msgid "The buttons"
msgstr "Dugmad"

#. Tag: member
#: index.docbook:492
#, no-c-format
msgid "<guibutton>0</guibutton> to <guibutton>9</guibutton>"
msgstr "<guibutton>0</guibutton> do <guibutton>9</guibutton>"

#. Tag: member
#: index.docbook:495
#, no-c-format
msgid "<guibutton>.</guibutton> or <guibutton>,</guibutton>"
msgstr "<guibutton>.</guibutton> ili <guibutton>,</guibutton>"

#. Tag: guibutton
#: index.docbook:498
#, no-c-format
msgid "&lt;-"
msgstr "&lt;-"

#. Tag: guibutton
#: index.docbook:501
#, no-c-format
msgid "<guibutton>AC</guibutton>"
msgstr "<guibutton>AC</guibutton>"

#. Tag: member
#: index.docbook:502
#, no-c-format
msgid "Clear all: both input and result area"
msgstr "Čisti sve: i ulaz i područje rezultata"

#. Tag: member
#: index.docbook:504
#, no-c-format
msgid "<guibutton>€</guibutton> or <guibutton>$</guibutton>"
msgstr "<guibutton>€</guibutton> ili <guibutton>$</guibutton>"

#. Tag: member
#: index.docbook:508
#, no-c-format
msgid "The button labeled with the name of an other currency"
msgstr "Dugme sa imenom neke druge valute"

#. Tag: guibutton
#: index.docbook:511
#, no-c-format
msgid "Enter"
msgstr "Enter"

#. Tag: guibutton
#: index.docbook:514
#, no-c-format
msgid "<guibutton>%</guibutton>"
msgstr "<guibutton>%</guibutton>"

#. Tag: guibutton
#: index.docbook:517
#, no-c-format
msgid "<guibutton>+/-</guibutton>"
msgstr "<guibutton>+/-</guibutton>"

#. Tag: member
#: index.docbook:520
#, no-c-format
msgid ""
"<guibutton>Min</guibutton>, <guibutton>MR</guibutton>, <guibutton>M+</"
"guibutton> and <guibutton>-</guibutton>"
msgstr ""
"<guibutton>Min</guibutton>, <guibutton>MR</guibutton>, <guibutton>M+</"
"guibutton> i <guibutton>-</guibutton>"

#. Tag: member
#: index.docbook:521
#, no-c-format
msgid ""
"Store result in memory, recall memory into result, add result to memory and "
"subtract result from memory"
msgstr ""
"Pohrana rezultata u memoriju, poziv iz memoriju u rezultat, dodavanje "
"rezultata memoriji i oduzimanje rezultata od memorije."

#. Tag: member
#: index.docbook:523
#, no-c-format
msgid ""
"<guibutton>/</guibutton>, <guibutton>X</guibutton>, <guibutton>-</guibutton> "
"and <guibutton>+</guibutton>"
msgstr ""
"<guibutton>/</guibutton>, <guibutton>X</guibutton>, <guibutton>-</guibutton> "
"i <guibutton>+</guibutton>"

#. Tag: guibutton
#: index.docbook:526
#, no-c-format
msgid "Reset"
msgstr "Reset"

#. Tag: member
#: index.docbook:527
#, no-c-format
msgid "Reset both input, result and memory"
msgstr "Resetuje i ulaz i rezultat i memoriju"

#. Tag: guibutton
#: index.docbook:529
#, no-c-format
msgid "About"
msgstr "Informacije"

#. Tag: member
