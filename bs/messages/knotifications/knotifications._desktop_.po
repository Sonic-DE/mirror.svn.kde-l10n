#: src/android_defaults.notifyrc:2
msgctxt "Name"
msgid "Fatal Error"
msgstr "Kobna greška"

#: src/android_defaults.notifyrc:61
msgctxt "Comment"
msgid "There was a serious error causing the program to exit"
msgstr "Došlo je do ozbiljne greške zbog koje je program obustavljen"

#: src/android_defaults.notifyrc:122
msgctxt "Name"
msgid "Notification"
