msgstr "Nešto posebno se dogodilo u programu"

#: src/android_defaults.notifyrc:240
msgctxt "Name"
msgid "Warning"
msgstr "Upozorenje"

#: src/android_defaults.notifyrc:298
msgctxt "Comment"
msgid "There was an error in the program which may cause problems"
msgstr "Došlo je do greške u programu koja može izazvati probleme"

#: src/android_defaults.notifyrc:358
msgctxt "Name"
msgid "Catastrophe"
msgstr "Katastrofa"

#: src/android_defaults.notifyrc:415
msgctxt "Comment"
msgid "A very serious error occurred, at least causing the program to exit"
msgstr "Došlo je do vrlo ozbiljne greške, zbog koje je bar program obustavljen"

