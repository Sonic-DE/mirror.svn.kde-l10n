#: org.kde.ark.appdata.xml:12
msgid "Archiving Tool"
msgstr "Alat za arhiviranje"

#. (itstool) path: description/p
#: org.kde.ark.appdata.xml:14
msgid ""
"Ark is a graphical file compression/decompression utility with support for "
"multiple formats, including tar, gzip, bzip2, rar and zip, as well as CD-ROM "
"images. Ark can be used to browse, extract, create, and modify archives."
msgstr ""
"Ark je grafički alat za kompresiju/dekompresiju s podrškom za više formata, "
"uključujući tar, gzip, bzip2, rar i zip, kao i CD-ROM slike. Ark se može "
"koristiti za kreiranje, izdvjanje i modifikaciju arhiva."

