#. (itstool) path: component/name
#: org.kde.juk.metainfo.xml:7
msgid "JuK"
msgstr "JuK"

#. (itstool) path: component/summary
#: org.kde.juk.metainfo.xml:9
msgid "Music Player"
msgstr "Muzički plejer"

#. (itstool) path: description/p
#: org.kde.juk.metainfo.xml:11
#, fuzzy
#| msgid ""
#| "JuK is an audio jukebox application, supporting collections of MP3, Ogg "
#| "Vorbis, and FLAC audio files. It allows you to edit the \"tags\" of your "
#| "audio files, and manage your collection and playlists. It's main focus, "
#| "in fact, is on music management."
msgid ""
"JuK is an audio jukebox application, supporting collections of MP3, Ogg "
"Vorbis, and FLAC audio files. It allows you to edit the \"tags\" of your "
"audio files, and manage your collection and playlists. Its main focus, in "
"fact, is on music management."
msgstr ""
"JuK je audio džuboks aplikacija, podržavajući kolekcije MP3, Ogg Vorbis, "
"FLAC i audio datoteka. To vam omogućava da izmijenite \"etiketa\" vaših "
"audio datoteka, i upravljate kolekcijama i listama izvođenja. Njegov je "
"glavni fokus, u stvari, je na muzičkom menadžmentu."

#. (itstool) path: description/p
#: org.kde.juk.metainfo.xml:12
msgid "Features:"
msgstr "Svojstva:"

#. (itstool) path: ul/li
#: org.kde.juk.metainfo.xml:14
msgid "Collection list and multiple user defined playlists"
msgstr "Kolekcijska lista i više korisnički definisanih lista izvođenja"

#. (itstool) path: ul/li
#: org.kde.juk.metainfo.xml:15
msgid ""
"Ability to scan directories to automatically import playlists and music "
"files on start up"
msgstr ""
"Mogućnost skeniranja direktorija da automatski uvezete liste izvođenja i "
"muzičke datoteke pri pokretanju"

#. (itstool) path: ul/li
#: org.kde.juk.metainfo.xml:16
msgid ""
"Dynamic Search Playlists that are automatically updated as fields in the "
"collection change"
msgstr ""
"Dinamička pretraga listi izvođenja koja se automatski ažurira kao polja u "
"promjeni kolekcije"

#. (itstool) path: ul/li
#: org.kde.juk.metainfo.xml:17
msgid ""
"A Tree View mode where playlists are automatically generated for sets of "
"albums, artists and genres"
msgstr ""
"Režim pogleda stabla gdje se liste automatski generišu kao skupovi albuma, "
"izvođača i žanrova"

#. (itstool) path: ul/li
#: org.kde.juk.metainfo.xml:18
msgid "Playlist history to indicate which files have been played and when"
msgstr "Istorijat liste izvođenja da indicira koje su datoteke izvođene i kada"

#. (itstool) path: ul/li
#: org.kde.juk.metainfo.xml:19
msgid "Inline search for filtering the list of visible items"
msgstr "Linijska pretraga za filtriranje liste vidljivih objekata"

#. (itstool) path: ul/li
#: org.kde.juk.metainfo.xml:20
msgid "The ability to guess tag information based on the track's file name"
msgstr ""
"Mogućnost pogađanja informacija o oznaci bazirano na imenu datoteke trake"

#. (itstool) path: ul/li
#: org.kde.juk.metainfo.xml:21
msgid "File renamer that can rename files based on the tag content"
msgstr "Preimenovanje datoteka na bazi sadržaja oznake"

#. (itstool) path: ul/li
#: org.kde.juk.metainfo.xml:22
msgid ""
"Tag reading and editing support for many formats including ID3v1, ID3v2 and "
"Ogg Vorbis"
msgstr ""
"Podrška za čitanje i uređivanje oznaka za mnoge formate uključujući ID3v1, "
"ID3v2 i Ogg Vorbis"
